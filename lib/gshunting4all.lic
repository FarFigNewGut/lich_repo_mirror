# ===========================================================================
# STATE
# ===========================================================================
module GSH4AState
  @cooldowns      = {}
  @daily_uses     = {}
  @daily_resets   = {}
  @toggle_done    = {}
  @mounted        = false
  @mount_summoned = false
  @hunting        = true
  @paused         = false
  @last_warn_at   = {}
  @reaction_at       = 0
  @last_aoe_at       = 0
  @last_aoe_npcs     = []
  @uac_tier          = 1   # 1=decent, 2=good, 3=excellent
  @uac_next_attack   = nil # "jab"/"punch"/"kick"/"grapple" when vulnerability announced

  class << self
    attr_accessor :mounted, :mount_summoned, :hunting, :paused
    attr_accessor :reaction_at, :last_aoe_at, :last_aoe_npcs
    attr_accessor :crossbow_loaded, :ranged_kneeling, :stun_pending
    attr_accessor :uac_tier, :uac_next_attack
    attr_accessor :incarnation_expires
    attr_accessor :berserking, :berserk_rounds

    def cd_ready?(key)
      Time.now.to_f >= (@cooldowns[key] || 0)
    end

    def set_cd(key, seconds)
      @cooldowns[key] = Time.now.to_f + seconds.to_f
    end

    def daily_ok?(key, limit)
      reset_daily(key)
      (@daily_uses[key] || 0) < limit
    end

    def use_daily(key)
      reset_daily(key)
      @daily_uses[key] = (@daily_uses[key] || 0) + 1
      save_state
    end

    # Persists today's daily-use counters to disk so they survive script restarts.
    # Keyed to today's date -- a new day automatically gets a clean slate on load.
    def save_state
      return unless defined?(Char) && Char.name && !Char.name.empty?
      path = File.join(PROFILE_DIR, "#{Char.name}_state.yaml")
      data = { "date" => Time.now.strftime("%Y-%m-%d"), "daily_uses" => @daily_uses.dup }
      File.write(path, data.to_yaml)
    rescue StandardError
      nil
    end

    # Loads daily-use counters saved from a previous run today.
    # If the saved date is not today, starts fresh (new day = new charges).
    def load_state
      return unless defined?(Char) && Char.name && !Char.name.empty?
      path = File.join(PROFILE_DIR, "#{Char.name}_state.yaml")
      return unless File.exist?(path)
      data = YAML.safe_load(File.read(path)) rescue nil
      return unless data.is_a?(Hash) && data["date"] == Time.now.strftime("%Y-%m-%d")
      saved = data["daily_uses"]
      return unless saved.is_a?(Hash)
      saved.each { |k, v| @daily_uses[k] = v.to_i }
    rescue StandardError
      nil
    end

    def toggle_done?(key)
      @toggle_done[key]
    end

    def mark_toggle(key)
      @toggle_done[key] = true
    end

    def throttle_ok?(key, secs)
      return false if Time.now.to_f - (@last_warn_at[key] || 0) < secs
      @last_warn_at[key] = Time.now.to_f
      true
    end

    private

    def reset_daily(key)
      now = Time.now.to_f
      if (@daily_resets[key] || 0) < now
        next_midnight = Time.now.tap { |t| t = Time.mktime(t.year, t.month, t.day) + 86400 }.to_f rescue now + 86400
        @daily_resets[key] = next_midnight
        @daily_uses[key]   = 0
      end
    end
  end
end

# ===========================================================================
# SETUP WIZARD
# ===========================================================================
module SetupWizard
  PAGES = [
    "Character", "Society", "Spells", "Weapons",
    "Defense", "Songs", "Combat Abilities",
    "Rogue Guild", "Warrior Guild",
    "Mount", "Scripts", "Hunting Preferences",
    "Trinkets", "Arcarium (Vissi)", "Gemstones"
  ].freeze

  # GTK2/GTK3 compatibility wrappers
  def self.mk_vbox(sp = 6)
    Gtk::VBox.new(false, sp) rescue Gtk::Box.new(Gtk::Orientation::VERTICAL, sp)
  end

  def self.mk_hbox(sp = 6)
    Gtk::HBox.new(false, sp) rescue Gtk::Box.new(Gtk::Orientation::HORIZONTAL, sp)
  end

  def self.mk_hsep
    Gtk::HSeparator.new rescue Gtk::Separator.new(Gtk::Orientation::HORIZONTAL)
  end

  def self.mk_combo_text(options, idx = 0)
    c = begin
      ct = Gtk::ComboBoxText.new
      options.each { |o| ct.append_text(o.to_s) }
      ct
    rescue
      cb = Gtk::ComboBox.new(true)
      options.each { |o| cb.append_text(o.to_s) }
      cb
    end
    c.active = idx
    c
  end

  # ===========================================================================
  # Entry point
  # ===========================================================================
  def self.run
    if Script.current.vars[1] =~ /reset/i
      char = XMLData.name rescue "unknown"
      path = File.join(PROFILE_DIR, "#{char.downcase}.yaml")
      File.delete(path) if File.exist?(path)
      respond "[setup] Profile reset -- starting fresh."
    end

    respond "[gsh4a] Gathering character info -- the setup window will appear in a moment, please wait..."
    @detected = auto_detect

    # Load existing profile so the wizard pre-fills saved values
    char         = XMLData.name rescue "unknown"
    profile_path = File.join(PROFILE_DIR, "#{char.downcase}.yaml")
    @saved_config = File.exist?(profile_path) ? (YAML.load_file(profile_path) rescue {}) : {}
    @profile      = @saved_config

    # Keep the script thread alive while the window is open.
    # Lich 5 drops the game connection when a script thread exits; we must block here.
    # ConditionVariable.wait sleeps the thread efficiently (no busy loop).
    @setup_mutex = Mutex.new
    @setup_cv    = ConditionVariable.new
    @setup_open  = true

    Gtk.queue { init_window }

    @setup_mutex.synchronize { @setup_cv.wait(@setup_mutex) while @setup_open }
  end

  def self.signal_setup_done
    return unless @setup_mutex
    @setup_mutex.synchronize { @setup_open = false; @setup_cv.signal }
  end

  # Recursive inventory flatten -- includes items inside harness, scabbard, cloak, etc.
  def self.all_inv_items
    seen   = {}
    result = []
    top    = safe_inv_top
    queue  = top.dup
    until queue.empty?
      item = queue.shift
      next if seen[item.id]
      seen[item.id] = true
      result << item
      cmap     = safe_containers
      contents = cmap[item.id.to_s] || cmap[item.id] || []
      queue.concat(contents.to_a)
    end
    result
  rescue Exception
    safe_inv_top
  end

  def self.safe_inv_top
    GameObj.inv.to_a
  rescue Exception
    []
  end

  def self.safe_containers
    GameObj.containers || {}
  rescue Exception
    {}
  end

  # ===========================================================================
  # Auto-detection (runs on script thread before GTK window opens)
  # ===========================================================================
  def self.auto_detect
    respond "[setup] Detecting character, society, weapons, armor, arcarium..."
    d = {}

    # Character -- try every known Lich 5 source, take first non-blank value
    d[:name]  = [-> { XMLData.name  }, -> { Char.name  }].lazy.map { |f| f.call rescue nil }.find { |v| v && !v.strip.empty? } || "Unknown"
    d[:race]  = [-> { XMLData.race  }, -> { Char.race  }, -> { Stats.race  }].lazy.map { |f| f.call rescue nil }.find { |v| v && !v.strip.empty? } || ""
    d[:prof]  = [-> { XMLData.prof  }, -> { Char.prof  }, -> { Stats.prof  }].lazy.map { |f| f.call rescue nil }.find { |v| v && !v.strip.empty? } || ""
    d[:level] = [-> { Stats.level   }, -> { XMLData.level }, -> { Char.level }].lazy.map { |f| f.call rescue nil }.find { |v| v && v.to_i > 0 }.to_i

    # Hands -- Lich returns a placeholder object named "Empty" when hands are bare; treat as nil
    rh = GameObj.right_hand rescue nil
    lh = GameObj.left_hand  rescue nil
    rh = nil if rh.nil? || rh.name.to_s =~ /\Aempty\z/i || rh.id.to_i <= 0
    lh = nil if lh.nil? || lh.name.to_s =~ /\Aempty\z/i || lh.id.to_i <= 0
    d[:right_hand] = rh
    d[:left_hand]  = lh

    # Classify left hand: shield, off-hand weapon, or empty
    if lh
      if lh.noun =~ SHIELD_NOUNS
        d[:has_shield]  = true
        d[:shield_noun] = lh.noun
        d[:shield_name] = lh.name
      elsif rh
        # Only dual-wield if BOTH hands have something
        d[:dual_wield] = true
      end
    end

    # Force Lich to populate its container cache for weapon holders so items inside them
    # appear in GameObj.containers for the recursive scan below.
    # Covers scabbards, sheaths, baldrics, sword hooks, harnesses, quivers, cloaks, etc.
    GameObj.inv.to_a.each do |container|
      next unless container.noun =~ /scabbard|sheath|baldric|harness|quiver|sling|hook|cloak|backpack|pack|bag|pouch|sack/i
      capture_detect("look in my #{container.noun}", 1.5)
    end rescue nil

    # Full inventory scan -- recursively includes items inside containers (harness, scabbard, cloak)
    inv = all_inv_items

    # Arcarium -- aversaris (offensive) and vangaris (defensive)
    d[:aversaris] = inv.find { |i| i.name =~ /aversaris/i }
    d[:vangaris]  = inv.find { |i| i.name =~ /vangaris/i }
    d[:aversaris_vissi] = analyze_arcarium_vissi("aversaris arcarium") if d[:aversaris]
    d[:vangaris_vissi]  = analyze_arcarium_vissi("vangaris arcarium")  if d[:vangaris]

    # Armor -- first item whose noun matches common armor nouns
    d[:armor] = inv.find { |i| i.noun =~ ARMOR_NOUNS }
    d[:armor_asg] = guess_armor_asg(d[:armor])

    # UAC gear -- item name must explicitly say UAC or unarmed (not just gloves/boots)
    d[:uac_hands] = inv.select { |i| i.noun =~ UAC_HAND_NOUNS && i.name =~ /uac|unarmed/i }
    d[:uac_feet]  = inv.select { |i| i.noun =~ UAC_FOOT_NOUNS && i.name =~ /uac|unarmed/i }

    # Weapon inventory scan -- for when nothing is in hand (still needed for pg_weapon picker)
    weapon_pat = WEAPON_NOUN_HINTS.map { |pat, _| pat }.reduce { |a, b| Regexp.union(a, b) }
    d[:inventory_weapons] = inv.select { |i|
      n = i.noun.to_s
      next false if n =~ /-haft$|\bhaft$/i
      next false if n =~ /-blade$/i && n !~ /whip.?blade/i
      n =~ weapon_pat
    }

    # Build the full candidate list for script detection -- everything in inventory
    weapon_pat = WEAPON_NOUN_HINTS.map { |pat, _| pat }.reduce { |a, b| Regexp.union(a, b) }
    candidates = []

    # Right hand = primary weapon slot
    candidates << { slot: :primary,   item: rh }                   if rh
    # Left hand = secondary or shield slot
    candidates << { slot: d[:has_shield] ? :shield : :secondary, item: lh } if lh
    # Armor -- already detected from inventory scan
    candidates << { slot: :armor,     item: d[:armor] }             if d[:armor]
    # All inventory weapons not already in hand (covers scabbard, harness, container)
    seen_nouns = candidates.map { |c| c[:item].noun }.compact.to_set
    inv.each do |i|
      next if seen_nouns.include?(i.noun)
      # Skip forge components -- unfinished pieces like handaxe-haft, mace-blade, etc.
      # whip-blade is the one real weapon with "-blade" in its noun, so exclude it from the skip.
      noun_s = i.noun.to_s
      next if noun_s =~ /-haft$|\bhaft$/i
      next if noun_s =~ /-blade$/i && noun_s !~ /whip.?blade/i
      if i.noun =~ weapon_pat
        candidates << { slot: :primary, item: i }
        seen_nouns << i.noun
      elsif i.noun =~ SHIELD_NOUNS
        candidates << { slot: :shield, item: i }
        seen_nouns << i.noun
      elsif i.noun =~ ARMOR_NOUNS
        candidates << { slot: :armor, item: i }
        seen_nouns << i.noun
      elsif (i.noun =~ UAC_HAND_NOUNS || i.noun =~ UAC_FOOT_NOUNS) && i.name =~ /uac|unarmed/i
        candidates << { slot: :primary, item: i }
        seen_nouns << i.noun
      end
    end

    # Analyze every candidate for combat scripts.
    d[:item_scripts] = []

    candidates.each do |c|
      noun = c[:item].noun.to_s.strip
      next if noun.empty?
      out  = capture_detect("analyze my #{noun}", 3.0)
      SCRIPT_TEMPLATES.each do |name, tmpl|
        next if name == "Energy Wings"  # handled by manual checkbox in Scripts tab
        pat = tmpl[:detect_pattern] || /#{Regexp.escape(name)}/i
        next unless out =~ pat
        next if d[:item_scripts].any? { |s| s[:name] == name && s[:noun] == noun }
        tier = if    out =~ /tier\s*(\d)/i then $1.to_i
                 elsif out =~ /\bT(\d)\b/   then $1.to_i
                 else 1 end
        d[:item_scripts] << { name: name, slot: c[:slot], noun: noun, tier: tier }
      end
    end

    # Known spells -- Lich caches spell knowledge from the XML stream; no game command needed
    d[:known_spells] = detect_known_spells

    # Lore ranks -- parse "skills" output for Spiritual Lore sub-skills
    skills_out = capture_detect("skills", 3.0)
    d[:lore_ranks] = parse_lore_ranks(skills_out)

    # CMANs / feats -- "cman info" lists all known CMANs/feats; "weapon info" shows weapon techniques
    raw_feats = parse_ability_list(capture_detect("cman info", 2.5))
    # Enrich each CMAN with stamina cost and cooldown from individual info pages.
    # passive flag comes from the Type column in "cman info" output (most reliable source).
    d[:feats] = raw_feats.map do |feat|
      name    = feat[:name]
      passive = feat[:passive]
      next { name: name, stamina: 0, cd: 0, passive: true } if passive
      detail  = capture_detect("cman info #{name}", 1.5)
      stamina = detail =~ /stamina.*?(\d+)/i      ? $1.to_i : 0
      cd      = detail =~ /(\d+)\s+second.*cool/i ? $1.to_i : 0
      { name: name, stamina: stamina, cd: cd, passive: false }
    end
    d[:techniques]    = parse_technique_list(capture_detect("weapon info",  2.5))
    d[:shield_specs]  = parse_technique_list(capture_detect("shield info",  2.5))
    d[:armor_specs]   = parse_technique_list(capture_detect("armor info",   2.5))
    d[:gem_slots]     = parse_gem_slots(capture_detect("gemstone slot", 3.0))

    # Society -- capture command output for reliable detection
    soc_out = capture_detect("society", 2.5)
    d[:society] = case soc_out
    when /order of voln/i               then "Voln"
    when /guardians of sunfist/i        then "Sunfist"
    when /council of light/i            then "CoL"
    else
      # fallback to XMLData/Society module
      soc_raw = (XMLData.society rescue nil) || (Society.name rescue nil)
      case soc_raw.to_s
      when /voln/i    then "Voln"
      when /sunfist/i then "Sunfist"
      when /council/i, /col/i then "CoL"
      else nil
      end
    end
    d[:society_rank] = if soc_out =~ /rank[:\s]+(\d+)/i then $1.to_i
                       elsif soc_out =~ /(\d+)\s*(st|nd|rd|th)?\s*rank/i then $1.to_i
                       elsif soc_out =~ /master/i && d[:society] == "Voln" then 26
                       else (XMLData.society_rank rescue nil) || (Society.rank rescue nil) || 1
                       end

    d
  end

  # Common English words that should never be treated as feat/ability names
  ABILITY_NAME_SKIP = /\A(?:Each|The|A|An|This|That|These|Those|Any|All|Some|Your|Its|Their|Our|No|Not|Note|Options|Please|You|If|For|To|Of|In|On|At|By|As|Is|Are|Was|Be|Or|And)\z/i.freeze

  # Known always-on passive CMANs/feats -- no activation verb, excluded from the active list.
  # These are confirmed passive from gswiki.play.net/Combat_Maneuvers.
  # If you see an ability here that you CAN activate, remove it and re-run setup.
  PASSIVE_CMANS = [
    "Combat Focus",
    "Combat Toughness",
    "Cunning Defense",
    "Armor Skin",
    "Mobility",
    "Tainted Bond",
    "Specialization I",
    "Specialization II",
    "Specialization III",
    "Specialization IV",
    "Weapon Specialization",
  ].map(&:downcase).freeze

  # Passive check also covers any name starting with these prefixes (handles truncated GS4 output)
  PASSIVE_CMAN_PREFIXES = ["weapon spec", "weapon specializ"].freeze

  # GS4 spell circles and their number ranges (verified against gswiki.play.net/Spell_circle)
  # NOTE: Wizard Base is 901-950, NOT 601-649. Ranger Base is 601-650, NOT 801-849.
  #       801-899 is unused in current GS4. Monks use CMANs; no Monk Base circle.
  SPELL_CIRCLES = [
    { name: "Minor Spiritual",  range: 101..140 },
    { name: "Major Spiritual",  range: 201..240 },
    { name: "Cleric Base",      range: 301..350 },
    { name: "Minor Elemental",  range: 401..435 },
    { name: "Major Elemental",  range: 501..550 },
    { name: "Ranger Base",      range: 601..650 },
    { name: "Sorcerer Base",    range: 701..740 },
    { name: "Wizard Base",      range: 901..950 },
    { name: "Bard Base",        range: 1001..1040 },
    { name: "Empath Base",      range: 1101..1150 },
    { name: "Minor Mental",     range: 1201..1235 },
    { name: "Major Mental",     range: 1301..1320 },
    { name: "Savant Base",      range: 1401..1450 },
    { name: "Paladin Base",     range: 1601..1650 },
    { name: "Arcane",           range: 1700..1750 },
  ].freeze

  # Returns array of { num:, name:, circle: } for every spell the character knows
  def self.detect_known_spells
    known = []
    SPELL_CIRCLES.each do |circle|
      circle[:range].each do |num|
        s = Spell[num] rescue nil
        next unless s
        next unless s.known? rescue false
        known << { num: num, name: s.name.to_s, circle: circle[:name] }
      end
    end
    known
  rescue Exception
    []
  end

  # Parse "skills" output to extract Spiritual Lore sub-skill ranks.
  # GS4 outputs lines like:   Spiritual Lore, Blessings         25       5
  # Returns hash like: { "Blessings" => 25, "Summoning" => 10, "Religion" => 0 }
  # Parses `gemstone slot` output into an array of slot hashes (index 0 = slot 1).
  # Each hash: { equipped: bool, name: str, properties: [str, ...] }
  #
  # Expected format:
  #   Slot 1: a square deep green jewel (Gemstone #2)
  #       * Flare Resonance (Rank 5 of 5)
  #       * Relentless Warder (Rank 2 of 5)
  def self.parse_gem_slots(out)
    slots   = Array.new(MAX_GEMSTONE_SLOTS) { { equipped: false, name: "", properties: [] } }
    current = nil
    return slots if out.strip.empty?
    out.each_line do |line|
      clean = line.gsub(/<[^>]+>/, "").rstrip
      if clean =~ /\bSlot\s+(\d+)\s*:/i
        idx = $1.to_i - 1
        next unless idx >= 0 && idx < MAX_GEMSTONE_SLOTS
        # Everything after "Slot N:" up to the first "(" is the gem description
        gem_desc = clean.sub(/\bSlot\s+\d+\s*:\s*/i, "")
                        .sub(/\s*\(Gemstone\s*#\d+\).*/i, "")
                        .strip.downcase
        slots[idx] = { equipped: !gem_desc.empty?, name: gem_desc, properties: [] }
        current = idx
      elsif current && clean =~ /\*\s+(.+)/
        # Property line: "    * Property Name (Rank X of Y)"
        prop = $1.strip.sub(/\s*\(Rank\s+\d+.*\)\s*\z/i, "").strip
        slots[current][:properties] << prop unless prop.empty?
      end
    end
    slots
  rescue
    Array.new(MAX_GEMSTONE_SLOTS) { { equipped: false, name: "", properties: [] } }
  end

  def self.parse_lore_ranks(out)
    ranks = {}
    # GS4 skills output format: "  Spiritual Lore - Blessings.........|     176      76"
    # Separator is " - " (dash), not a comma. The line has two numbers: bonus then ranks.
    # Use .last to get the ranks column, not .first (which would grab the bonus).
    out.each_line do |line|
      case line
      when /spirit\s+mana\s+control/i                 then ranks["SMC"]           = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(blessings)/i    then ranks["Blessings"]     = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(summoning)/i    then ranks["Summoning"]     = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(religion)/i     then ranks["Religion"]      = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(mysticism)/i    then ranks["Mysticism"]     = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(earth)/i        then ranks["Earth"]         = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(air)/i          then ranks["Air"]           = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(fire)/i         then ranks["Fire"]          = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(water)/i        then ranks["Water"]         = line.scan(/\d+/).last.to_i
      when /sorcerous\s+lore[\s,\-]+(demonology)/i   then ranks["Demonology"]    = line.scan(/\d+/).last.to_i
      when /sorcerous\s+lore[\s,\-]+(necromancy)/i   then ranks["Necromancy"]    = line.scan(/\d+/).last.to_i
      when /mental\s+lore[\s,\-]+(telepathy)/i       then ranks["Telepathy"]     = line.scan(/\d+/).last.to_i
      when /mental\s+lore[\s,\-]+(transference)/i    then ranks["Transference"]  = line.scan(/\d+/).last.to_i
      when /mental\s+lore[\s,\-]+(transformation)/i  then ranks["Transformation"] = line.scan(/\d+/).last.to_i
      when /ranger\s+lore/i                          then ranks["Ranger"]        = line.scan(/\d+/).last.to_i
      when /bard\s+lore/i                            then ranks["Bard"]          = line.scan(/\d+/).last.to_i
      end
    end
    ranks
  rescue Exception
    {}
  end

  def self.spell_offensive?(s)
    OFFENSIVE_SPELL_NUMS.include?(s[:num]) ||
      s[:name].to_s =~ OFFENSIVE_SPELL_PATTERN
  end

  # Parse "cman info" output.
  # GS4 outputs a columnar table with a header row containing "Skill" and "Mnemonic":
  #   Skill            Mnemonic         Ranks  Type      Category    Subcategory
  #   --------------------------------------------------------------------------
  #   Ambush           ambush             5    Passive   Combat      Stealth
  #   ...
  #   The output listed above was generated based on the following filters:
  #   Availability: profession   Type: all   ...
  #
  # We locate the header row, find the column offsets for Skill and Type,
  # then return hashes { name:, passive: } for each data row.
  def self.parse_ability_list(out)
    return [] if out.strip.empty?
    lines = out.each_line.map(&:rstrip)
    header_idx = lines.index { |l| l =~ /\bSkill\b/i && l =~ /\bMnemonic\b/i }
    return [] unless header_idx
    header = lines[header_idx]
    type_col = header =~ /\bType\b/i ? header.index(/\bType\b/i) : nil
    results = []
    lines[(header_idx + 1)..].each do |line|
      break if line =~ /\Athe output listed/i
      next  if line.strip.empty?
      next  if line.strip =~ /\A[-]+\z/
      next  if line.strip =~ /\A\*/
      next  if line =~ /\AAvailability:|Type:\s*all|Category:\s*all|Subcategory:\s*all/i
      name = line.lstrip.split(/\s{2,}/).first.to_s.strip
      next if name.empty? || name.length < 3 || name.length > 50
      next if name =~ /\A\d/ || name =~ /\A[-]+\z/ || name =~ /\A\*/
      next if name =~ /[,\.!?<>]/
      next if name =~ /\w{1,4}>/
      next if name =~ /\A\[/
      next if name =~ /:/
      next if name =~ /\A(you|the|a |an |also|there|it |he |she )/i
      next if name.split.length > 5
      next unless name =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/
      type_str = (type_col && line.length > type_col) ? line[type_col..].split.first.to_s.downcase : ""
      passive  = type_str == "passive"
      results << { name: name, passive: passive }
    end
    results.uniq { |r| r[:name] }
  rescue Exception
    []
  end

  # All known weapon techniques from gswiki.play.net/Verb:WEAPON (verified 2026-06).
  # Used to supply accurate defaults even if "weapon info" output is ambiguous.
  # Keys are mnemonics (lowercase, no spaces) as GS4 uses them.
  WEAPON_TECH_KNOWN = {
    # Brawling (rank 10/25/50/75)
    "twinhammer"    => { name: "Twin Hammerfists",  tech_type: "setup",    min_creatures: 1, rank: 10, category: "Brawling"           },
    "fury"          => { name: "Fury",              tech_type: "assault",  min_creatures: 1, rank: 25, category: "Brawling"           },
    "clash"         => { name: "Clash",             tech_type: "aoe",      min_creatures: 3, rank: 50, category: "Brawling"           },
    "spinkick"      => { name: "Spin Kick",         tech_type: "reaction", min_creatures: 1, rank: 75, category: "Brawling"           },
    # Blunt Weapons (rank 10/25/50/75)
    "dizzyingswing" => { name: "Dizzying Swing",    tech_type: "setup",    min_creatures: 1, rank: 10, category: "Blunt Weapons"      },
    "clobber"       => { name: "Clobber",           tech_type: "reaction", min_creatures: 1, rank: 25, category: "Blunt Weapons"      },
    "pummel"        => { name: "Pummel",            tech_type: "assault",  min_creatures: 1, rank: 50, category: "Blunt Weapons"      },
    "pulverize"     => { name: "Pulverize",         tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Blunt Weapons"      },
    # Edged Weapons (rank 10/25/50/75)
    "cripple"       => { name: "Cripple",           tech_type: "setup",    min_creatures: 1, rank: 10, category: "Edged Weapons"      },
    "riposte"       => { name: "Riposte",           tech_type: "reaction", min_creatures: 1, rank: 25, category: "Edged Weapons"      },
    "flurry"        => { name: "Flurry",            tech_type: "assault",  min_creatures: 1, rank: 50, category: "Edged Weapons"      },
    "wblade"        => { name: "Whirling Blade",    tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Edged Weapons"      },
    # Polearm Weapons (rank 10/25/50/75)
    "charge"        => { name: "Charge",            tech_type: "setup",    min_creatures: 1, rank: 10, category: "Polearm Weapons"    },
    "gthrusts"      => { name: "Guardant Thrusts",  tech_type: "assault",  min_creatures: 1, rank: 25, category: "Polearm Weapons"    },
    "cyclone"       => { name: "Cyclone",           tech_type: "aoe",      min_creatures: 3, rank: 50, category: "Polearm Weapons"    },
    "radialsweep"   => { name: "Radial Sweep",      tech_type: "reaction", min_creatures: 1, rank: 75, category: "Polearm Weapons"    },
    # Ranged Weapons (rank 10/25/50/75)
    "reactiveshot"  => { name: "Reactive Shot",     tech_type: "reaction", min_creatures: 1, rank: 10, category: "Ranged Weapons"     },
    "pindown"       => { name: "Pin Down",          tech_type: "aoe",      min_creatures: 3, rank: 25, category: "Ranged Weapons"     },
    "barrage"       => { name: "Barrage",           tech_type: "assault",  min_creatures: 1, rank: 50, category: "Ranged Weapons"     },
    "volley"        => { name: "Volley",            tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Ranged Weapons"     },
    # Two-Handed Weapons (rank 10/25/50/75)
    "overpower"     => { name: "Overpower",         tech_type: "reaction", min_creatures: 1, rank: 10, category: "Two-Handed Weapons" },
    "thrash"        => { name: "Thrash",            tech_type: "assault",  min_creatures: 1, rank: 25, category: "Two-Handed Weapons" },
    "reversestrike" => { name: "Reverse Strike",    tech_type: "reaction", min_creatures: 1, rank: 50, category: "Two-Handed Weapons" },
    "whirlwind"     => { name: "Whirlwind",         tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Two-Handed Weapons" },
  }.freeze

  # Parse "weapon info" output for weapon techniques.
  # Returns array of { name:, tech_type: } where tech_type is one of:
  #   "assault", "aoe", "reaction", "concentration", "setup", "unknown"
  # The "weapon info" table columns: Skill  Mnemonic  Ranks  Type  Category  Subcategory
  # We capture col[0] (name), col[1] (mnemonic), col[3] (type).
  TECH_TYPE_MAP = {
    /assault/i        => "assault",
    /area.of.effect/i => "aoe",
    /reaction/i       => "reaction",
    /concentration/i  => "concentration",
    /setup/i          => "setup",
  }.freeze

  # Output columns from "weapon info":
  #   Skill           Mnemonic       Ranks  Type             Category
  #   Overpower       overpower      5/5    Reaction         Two-Handed Weapons
  #   Reverse Strike  reversestrike  5/5    Reaction         Two-Handed Weapons
  #   Thrash          thrash         5/5    Assault          Two-Handed Weapons
  #   Whirlwind       whirlwind      5/5    Area of Effect   Two-Handed Weapons
  def self.parse_technique_list(out)
    return [] if out.strip.empty?
    lines = out.each_line.map(&:rstrip)
    header_idx = lines.index { |l| l =~ /\bSkill\b/i && l =~ /\bMnemonic\b/i }
    return [] unless header_idx
    results = []
    lines[(header_idx + 1)..].each do |line|
      break if line =~ /\Athe output listed/i
      next  if line.strip.empty?
      next  if line.strip =~ /\A[-]+\z/
      next  if line.strip =~ /\A\*/          # game notifications (* Player joins, etc.)
      next  if line =~ /\AAvailability:|Type:\s*all|Category:\s*all|Subcategory:\s*all/i
      cols     = line.lstrip.split(/\s{2,}/)
      name     = cols[0].to_s.strip
      mnemonic = cols[1].to_s.strip.downcase
      next if name.empty? || name.length < 3 || name.length > 50
      next if name =~ /\A\d/ || name =~ /\A[-]+\z/ || name =~ /\A\*/
      next if name =~ /[,\.!?<>]/                                   # prose, room descriptions, or Lich aliases
      next if name =~ /\w{1,4}>/                                    # Lich alias prompt (e.g. sj>)
      next if name =~ /\A\[/                                         # ESP / channel: [Merchants]: ...
      next if name =~ /:/                                            # any key:value or channel line
      next if name =~ /\A(the|a |an |you|also|there|it |he |she )/i # sentence starters
      next if name.split.length > 5                                  # real skill names are short
      next unless name =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/             # must be letters/spaces/apostrophe/hyphen only

      # Cross-reference known table first -- most reliable source
      known = WEAPON_TECH_KNOWN[mnemonic]
      if known
        tech_type    = known[:tech_type]
        min_creatures = known[:min_creatures]
        name         = known[:name]   # canonical capitalisation
        min_rank     = known[:rank] || "?"
      else
        raw_type      = cols[3].to_s.strip
        tech_type     = TECH_TYPE_MAP.find { |pat, _| raw_type =~ pat }&.last || "unknown"
        min_creatures = tech_type == "aoe" ? 3 : 1
        raw_ranks     = cols[2].to_s.strip  # e.g. "5/5" from weapon info output
        min_rank      = raw_ranks =~ /\A(\d+)/ ? $1.to_i : "?"
      end

      verb = mnemonic.empty? ? "weapon #{name.downcase.gsub(/\s+/, '')}" : "weapon #{mnemonic}"
      ranks    = cols[2].to_s.strip
      category = cols[4].to_s.strip
      category = known[:category].to_s if category.empty? && known
      results << { name: name, mnemonic: mnemonic, verb: verb, tech_type: tech_type, min_creatures: min_creatures, min_rank: min_rank, ranks: ranks, category: category }
    end
    results.uniq { |r| r[:name] }
  rescue Exception
    []
  end

  def self.analyze_item_scripts(noun)
    return [] if noun.nil? || noun.strip.empty?
    output   = capture_detect("analyze my #{noun}", 3.0)
    detected = []
    SCRIPT_TEMPLATES.each do |name, _|
      next unless output =~ /#{Regexp.escape(name)}/i
      tier = if    output =~ /tier\s*(\d)/i then $1.to_i
               elsif output =~ /\bT(\d)\b/   then $1.to_i
               else 1
               end
      detected << { "name" => name, "tier" => tier }
    end
    detected
  end

  def self.capture_detect(cmd, wait_secs = 2.0)
    lines = []
    hook  = "gsh4a_detect_#{Thread.current.object_id}"
    DownstreamHook.add(hook, proc { |txt| lines << txt; nil })
    UpstreamHook.add(hook, proc { |input| input == "#{cmd}\n" ? nil : input })
    fput cmd
    sleep wait_secs
    DownstreamHook.remove(hook)
    UpstreamHook.remove(hook)
    # Strip XML/SGML tags that Lich injects into the downstream (e.g. <pushBold/>, <prompt time=...>)
    lines.map { |l| l.to_s.gsub(/<[^>]+>/, '').gsub(/&gt;/, '>').gsub(/&lt;/, '<').gsub(/&amp;/, '&') }
         .reject { |l| l.strip.empty? }
         .join("\n")
  rescue
    ""
  ensure
    DownstreamHook.remove(hook) rescue nil
    UpstreamHook.remove(hook)  rescue nil
  end

  ARCARIUM_VERBS = %w[rub push pull turn wave tap knock squeeze clench prod poke].freeze

  # Parses the "Slotted Vissi" table from `analyze my <noun>` output.
  # Returns an array of hashes for every vissi that has a recognized activator verb.
  # Passive vissi (no activator) are excluded; all categories (Primal, Wealth, etc.) are included.
  #
  # Each hash: { name, category, activator, verb, tier, daily_limit, cooldown_secs }
  def self.analyze_arcarium_vissi(noun)
    out = capture_detect("analyze my #{noun}", 7.0)
    return [] if out.strip.empty?

    lines = out.each_line.map(&:rstrip)

    # Find the column header row containing Name / Category / Activator
    header_idx = lines.index { |l| l =~ /\bName\b/i && l =~ /\bCategory\b/i && l =~ /\bActivator\b/i }
    return [] unless header_idx

    # Build a regex that matches a data row: any text, then 2+ spaces, then a known verb, then a space and digit (tier)
    # This is more reliable than indentation since GS4 continuation lines never have a known verb followed by a tier digit.
    verb_pat = Regexp.union(ARCARIUM_VERBS)
    row_re   = /\A\s*(.+?)\s{2,}(\S[\w\s]*?)\s{2,}(#{verb_pat})\s+(\d+)/i

    results = []
    current = nil

    lines[(header_idx + 1)..].each do |line|
      next if line.strip.empty? || line.strip =~ /\A[-=*]+\z/

      if line =~ row_re
        name_raw  = $1.strip
        category  = $2.strip
        activator = $3.downcase
        tier      = $4.to_i
        current = {
          name:          name_raw,
          category:      category,
          activator:     activator,
          verb:          "#{activator} my #{noun}",
          tier:          tier,
          daily_limit:   0,
          cooldown_secs: 0,
        }
        results << current
      else
        next unless current
        current[:daily_limit]   = $1.to_i if line =~ /(\d+)\s+times?\s+per\s+day/i
        current[:cooldown_secs] = $1.to_i if line =~ /(\d+)\s+second\s+cooldown/i
      end
    end

    results
  rescue
    []
  end

  def self.guess_armor_asg(item)
    return nil unless item
    text = "#{item.noun} #{item.name}".downcase
    # Check from most-specific to least-specific
    ARMOR_TYPES.reverse.each do |at|
      return at[:asg] if text =~ at[:nouns]
    end
    nil
  end

  def self.armor_asg_idx(asg)
    ARMOR_TYPES.index { |at| at[:asg] == asg } || 0
  end

  # ===========================================================================
  # Window
  # ===========================================================================
  def self.init_window
    @w  = {}   # flat widget registry
    @ws = {}   # scripts widgets: slot_key -> script_name -> { enabled, tier, abilities }
    @cman_store = @tech_store = @shield_spec_store = @armor_spec_store = nil

    @win = Gtk::Window.new("GSHunting4All -- Character Setup")
    @win.set_default_size(760, 620)
    @win.border_width = 10
    @win.signal_connect("destroy") { signal_setup_done }

    root = mk_vbox(6)

    @w[:nb] = Gtk::Notebook.new
    @w[:nb].show_tabs   = true
    @w[:nb].show_border = true
    PAGES.each_with_index { |title, i| @w[:nb].append_page(build_page(i), Gtk::Label.new(title)) }
    root.pack_start(@w[:nb], true, true, 0)
    root.pack_start(mk_hsep, false, false, 2)

    nav = mk_hbox(8)
    @w[:btn_cancel] = Gtk::Button.new("Cancel")
    @w[:btn_save]   = Gtk::Button.new("Save and Exit")
    @w[:btn_cancel].signal_connect("clicked") { @win.destroy; signal_setup_done }
    @w[:btn_save].signal_connect("clicked")   { do_save }
    nav.pack_start(@w[:btn_cancel], false, false, 0)
    nav.pack_end(@w[:btn_save], false, false, 0)
    root.pack_start(nav, false, false, 0)

    @win.add(root)
    @win.show_all

    update_profession_tabs = proc do
      prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue "") || ""
      songs_pg    = @w[:nb].get_nth_page(5)
      rogue_pg    = @w[:nb].get_nth_page(7)
      warrior_pg  = @w[:nb].get_nth_page(8)
      songs_pg.visible   = !!(prof =~ /Bard/i)     if songs_pg
      rogue_pg.visible   = !!(prof =~ /Rogue/i)    if rogue_pg
      warrior_pg.visible = !!(prof =~ /Warrior/i)  if warrior_pg
    end

    Gtk.queue { update_profession_tabs.call }
    @w[:char_prof]&.signal_connect("changed") { Gtk.queue { update_profession_tabs.call } }
  end

  def self.dual_wield?
    @w[:dual_wield]&.active? rescue false
  end

  # ===========================================================================
  # Page dispatch
  # ===========================================================================
  def self.build_page(idx)
    inner = case idx
    when 0  then pg_character
    when 1  then pg_society
    when 2  then pg_spells
    when 3  then pg_weapon
    when 4  then pg_defense
    when 5  then pg_songs
    when 6  then pg_combat_abilities
    when 7  then pg_rogue_guild
    when 8  then pg_warrior_guild
    when 9  then pg_mount
    when 10 then pg_scripts
    when 11 then pg_hunting
    when 12 then pg_trinkets
    when 13 then pg_arcarium
    when 14 then pg_gemstones
    else Gtk::Label.new("Unknown page #{idx}")
    end
    sw = Gtk::ScrolledWindow.new
    sw.set_policy(:never, :automatic)
    sw.add_with_viewport(inner)
    sw
  end

  # ===========================================================================
  # GTK helpers
  # ===========================================================================
  def self.scrolled(widget)
    s = Gtk::ScrolledWindow.new
    s.set_policy(Gtk::POLICY_NEVER, Gtk::POLICY_AUTOMATIC)
    s.add_with_viewport(widget)
    s
  end

  def self.lrow(label_str, widget)
    hb = mk_hbox(6)
    l  = Gtk::Label.new(label_str)
    l.xalign = 0.0
    hb.pack_start(l, false, false, 0)
    hb.pack_start(widget, true, true, 0)
    hb
  end

  def self.w_entry(key, default = "")
    e = Gtk::Entry.new
    e.text = default.to_s
    @w[key] = e
    e
  end

  def self.w_spin(key, val, lo, hi)
    adj = Gtk::Adjustment.new(val.to_f, lo.to_f, hi.to_f, 1.0, 5.0, 0.0)
    s   = Gtk::SpinButton.new(adj, 1, 0)
    @w[key] = s
    s
  end

  def self.w_combo(key, opts, idx = 0)
    c = mk_combo_text(opts, idx)
    @w[key] = c
    c
  end

  def self.w_check(key, lbl, default = false)
    cb = Gtk::CheckButton.new(lbl)
    cb.active = default
    @w[key] = cb
    cb
  end

  def self.frame_vbox(title)
    f = Gtk::Frame.new(title)
    b = mk_vbox(3)
    b.border_width = 6
    f.add(b)
    [f, b]
  end

  def self.add_row(vb, label, widget)
    vb.pack_start(lrow(label, widget), false, false, 3)
  end

  # ===========================================================================
  # Pages
  # ===========================================================================

  def self.fuzzy_idx(list, raw)
    return 0 if raw.nil? || raw.strip.empty?
    q = raw.strip.downcase
    # exact match first
    i = list.index { |e| e.downcase == q }
    return i if i
    # list entry starts with query (e.g. "Sylvankind" matches "Sylvan")
    i = list.index { |e| e.downcase.start_with?(q) }
    return i if i
    # query starts with list entry (e.g. "Sylvan" is prefix of query "Sylvankind" -- unlikely but safe)
    i = list.index { |e| q.start_with?(e.downcase) }
    return i if i
    # substring in either direction
    i = list.index { |e| e.downcase.include?(q) || q.include?(e.downcase) }
    i || 0
  end

  GS_RACES = %w[
    Aelotoi Dark\ Elf Dwarf Elf Erithian Giantman Gnome Half-Elf
    Halfling Human Krolvin Sylvankind
  ].freeze

  GS_PROFESSIONS = %w[
    Bard Cleric Empath Monk Paladin Ranger
    Rogue Savant Sorcerer Warrior Wizard
  ].freeze

  GS_LEVELS = (120).downto(1).map(&:to_s).freeze

  def self.pg_character
    d     = @detected || {}
    vb    = mk_vbox(6)
    vb.border_width = 10
    lbl   = Gtk::Label.new("Auto-detected from your current login. Change any field if needed.")
    lbl.xalign = 0.0
    vb.pack_start(lbl, false, false, 5)

    race_idx = fuzzy_idx(GS_RACES,        d[:race].to_s)
    prof_idx = fuzzy_idx(GS_PROFESSIONS,  d[:prof].to_s)
    lvl_idx  = GS_LEVELS.index(d[:level].to_s) || 0

    add_row(vb, "Name:",       w_entry(:char_name, d[:name] || "Unknown"))
    add_row(vb, "Race:",       w_combo(:char_race, GS_RACES,        race_idx))
    add_row(vb, "Profession:", w_combo(:char_prof, GS_PROFESSIONS,  prof_idx))
    add_row(vb, "Level:",      w_combo(:char_level, GS_LEVELS,      lvl_idx))

    vb.pack_start(mk_hsep, false, false, 6)
    note = Gtk::Label.new("")
    note.xalign = 0.0
    note.set_line_wrap(true)
    note.set_markup(
      "<i><span foreground='#888888'>" \
      "This script works alongside <b>;eloot</b> (automatic looting) and <b>;eherbs</b> (automatic healing). " \
      "Make sure both scripts are installed in your Lich scripts folder before hunting.\n\n" \
      "READY tip: The script issues READY WEAPON at hunt start to draw your weapon " \
      "(READY 2WEAPON for dual-wielders, READY SHIELD for shield users). " \
      "If you use a weapon harness, make sure your READY aliases are configured in-game." \
      "</span></i>"
    )
    vb.pack_start(note, false, false, 4)

    scrolled(vb)
  end

  def self.pg_society
    d   = @detected || {}
    soc = d[:society]
    vb  = mk_vbox(6)
    vb.border_width = 10

    if soc
      det_lbl = Gtk::Label.new("Detected: #{soc}  (rank #{d[:society_rank] || '?'})")
      det_lbl.xalign = 0.0
      rank_note = Gtk::Label.new("Abilities you have not yet learned are shown grayed out and cannot be selected.")
      rank_note.xalign = 0.0
      rank_note.wrap   = true
      vb.pack_start(det_lbl,    false, false, 4)
      vb.pack_start(rank_note,  false, false, 2)
      @w[:society_name_val] = soc
      @w[:society_rank_val] = d[:society_rank] || 1
      build_society_options(vb, soc, d[:society_rank] || 1)
    else
      none_lbl = Gtk::Label.new("Society not detected. Select yours:")
      none_lbl.xalign = 0.0
      vb.pack_start(none_lbl, false, false, 4)

      soc_combo = w_combo(:society_picker, ["None", "Voln", "Sunfist", "CoL"], 0)
      rank_sp   = w_spin(:society_rank_sp, 1, 1, 300)
      add_row(vb, "Society:", soc_combo)
      add_row(vb, "Rank:",    rank_sp)
      @w[:society_name_val] = nil
      @w[:society_rank_val] = 1

      @w[:society_options_box] = mk_vbox(4)
      vb.pack_start(@w[:society_options_box], false, false, 4)

      soc_combo.signal_connect("changed") do
        sel = ["None", "Voln", "Sunfist", "CoL"][soc_combo.active] rescue "None"
        @w[:society_name_val] = sel == "None" ? nil : sel
        @w[:society_options_box].children.each { |c| @w[:society_options_box].remove(c) }
        build_society_options(@w[:society_options_box], sel, rank_sp.value.to_i) unless sel == "None"
        @w[:society_options_box].show_all
      end
    end

    scrolled(vb)
  end

  def self.build_society_options(container, soc, rank)
    data = SOCIETY_DATA[soc]
    return unless data

    saved_soc     = (@profile.dig("society") || {}) rescue {}
    saved_maintain  = (saved_soc["maintain"]  || []).map { |e| e["name"] }
    saved_ondemand  = (saved_soc["on_demand"] || []).map { |e| e["name"] }
    has_saved = saved_soc["name"] == soc && (!saved_maintain.empty? || !saved_ondemand.empty?)

    mf, mb = frame_vbox("Maintain between fights (buffs)")
    @w[:"#{soc.downcase}_maintain"] = {}
    data[:maintain].each do |e|
      required_rank = e[:rank] || 1
      unlocked = rank >= required_rank
      label = unlocked ? "#{e[:name]}  --  #{e[:desc]}" : "#{e[:name]}  [requires rank #{required_rank}]"
      cb = Gtk::CheckButton.new(label)
      cb.active    = unlocked && (has_saved ? saved_maintain.include?(e[:name]) : true)
      cb.sensitive = unlocked
      @w[:"#{soc.downcase}_maintain"][e[:name]] = cb
      mb.pack_start(cb, false, false, 1)
    end
    container.pack_start(mf, false, false, 4)

    odf, odb = frame_vbox("On-Demand Abilities")
    @w[:"#{soc.downcase}_ondemand"] = {}
    default_on_demand = %w[Symbol\ of\ Mana Symbol\ of\ Restoration
                           Sigil\ of\ Minor\ Bane Sigil\ of\ Major\ Bane
                           Sign\ of\ Healing Sign\ of\ Wracking]
    data[:on_demand].each do |e|
      required_rank = e[:rank] || 1
      unlocked = rank >= required_rank
      label = unlocked ? "#{e[:name]}  --  #{e[:desc]}" : "#{e[:name]}  [requires rank #{required_rank}]"
      cb = Gtk::CheckButton.new(label)
      if unlocked
        cb.active = has_saved ? saved_ondemand.include?(e[:name]) : default_on_demand.include?(e[:name])
      else
        cb.active    = false
        cb.sensitive = false
      end
      @w[:"#{soc.downcase}_ondemand"][e[:name]] = cb
      odb.pack_start(cb, false, false, 1)
    end
    container.pack_start(odf, false, false, 4)
  end

  # Build the fields for one weapon slot (noun + type + sub-panels).
  # Always loads from saved profile -- no inventory auto-detection.
  def self.build_weapon_fields(which, offhand: false)
    saved_wpn  = (@profile.dig("weapons", which) || {}) rescue {}
    noun       = saved_wpn["noun"] || ""
    saved_type = saved_wpn["type"] || "1he"
    # Off-hand (secondary) can only be 1HE or 1HB -- hard restriction
    type_list  = offhand ? WEAPON_TYPES.select { |t| %w[1he 1hb].include?(t[:code]) } : WEAPON_TYPES
    tidx       = type_list.index { |t| t[:code] == saved_type } || 0
    enabled    = saved_wpn.fetch("enabled", which == "primary")
    vb         = mk_vbox(4)

    enabled_cb = w_check(:"#{which}_enabled", "I am using a #{which} weapon", enabled)
    vb.pack_start(enabled_cb, false, false, 2)

    # Bard-only: sonic weapon option inside the primary slot
    is_bard = ((GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "")) =~ /Bard/i
    if which == "primary" && is_bard
      saved_sonic_wpn = saved_wpn.fetch("sonic_weapon", false)
      @w[:sonic_weapon_primary] = Gtk::CheckButton.new("I am fighting with a Sonic Weapon (spell 1012) -- weapon type comes from the Songs tab")
      @w[:sonic_weapon_primary].active = saved_sonic_wpn
      vb.pack_start(@w[:sonic_weapon_primary], false, false, 2)
    end

    fields_box = mk_vbox(4)
    fields_box.sensitive = enabled

    enabled_cb.signal_connect("toggled") { fields_box.sensitive = enabled_cb.active? }

    # When sonic weapon is active, physical noun/type fields are irrelevant
    if which == "primary" && is_bard
      sonic_note = Gtk::Label.new("Sonic Weapon active -- weapon noun and type are set in the Songs tab.")
      sonic_note.xalign = 0.0
      sonic_note.wrap   = true
    end

    type_combo = w_combo(:"#{which}_type", type_list.map { |t| t[:label] }, tidx)

    if which == "primary" && is_bard
      noun_row = lrow("Weapon noun:", w_entry(:"#{which}_noun", noun))
      type_row = lrow("Weapon type:", type_combo)
      fields_box.pack_start(noun_row,    false, false, 3)
      fields_box.pack_start(type_row,    false, false, 3)
      fields_box.pack_start(sonic_note,  false, false, 2)
      sonic_on = @w[:sonic_weapon_primary].active?
      Gtk.queue do
        sonic_note.visible = sonic_on
        noun_row.visible   = !sonic_on
        type_row.visible   = !sonic_on
      end
      @w[:sonic_weapon_primary].signal_connect("toggled") do
        on = @w[:sonic_weapon_primary].active?
        sonic_note.visible = on
        noun_row.visible   = !on
        type_row.visible   = !on
      end
    else
      add_row(fields_box, "Weapon noun:", w_entry(:"#{which}_noun", noun))
      add_row(fields_box, "Weapon type:", type_combo)
    end

    saved_loc = saved_wpn["target_location"].to_s.strip
    loc_labels = ["(none -- center mass)"] + AIM_LOCATIONS.map(&:capitalize)
    loc_idx = saved_loc.empty? ? 0 : (AIM_LOCATIONS.index(saved_loc.downcase).to_i + 1)
    add_row(fields_box, "Aim body part:", w_combo(:"#{which}_target_loc", loc_labels, loc_idx))

    unless offhand
      # ---- Polearm sub-panel (one-handed with shield vs two-handed) ----
      pol_frame, pol_fb = frame_vbox("Polearm Grip")
      saved_pol_shield  = saved_wpn.fetch("polearm_with_shield", false)
      @w[:"#{which}_pol_shield"] = mk_combo_text(
        ["Two-handed (no shield)", "One-handed with shield"],
        saved_pol_shield ? 1 : 0
      )
      pol_fb.pack_start(lrow("How are you using this polearm?", @w[:"#{which}_pol_shield"]), false, false, 2)
      polearm_type_idx = type_list.index { |t| t[:code] == "polearm" }
      fields_box.pack_start(pol_frame, false, false, 4)
      Gtk.queue { pol_frame.visible = (tidx == polearm_type_idx) }

      # ---- Ranged sub-panel (shown only when type == Ranged) ----
      rng_noun      = saved_wpn["ranged_noun"] || ""
      rng_subtype   = saved_wpn["ranged_subtype"] || "bow"
      rng_container = saved_wpn["ammo_container"] || "quiver"
      rng_aim       = saved_wpn.fetch("aim_first", true)
      rng_warn      = (saved_wpn["ammo_warn_at"] || 10).to_f
      rng_sub_idx   = RANGED_SUBTYPES.index(rng_subtype) || 0

      rng_frame, rng_fb = frame_vbox("Ranged Settings")
      @w[:"#{which}_ranged_noun"] = Gtk::Entry.new.tap { |e| e.text = rng_noun }
      @w[:"#{which}_ranged_sub"]  = mk_combo_text(
        ["Bow (long bow, short bow, composite bow)",
         "Crossbow (light, heavy -- must LOAD between shots)",
         "Sling (bullets/stones in container)",
         "Thrown (bola, dart, discus, etc -- items land on ground)"],
        rng_sub_idx)
      @w[:"#{which}_ammo_cont"]  = Gtk::Entry.new.tap { |e| e.text = rng_container }
      @w[:"#{which}_aim_first"]  = Gtk::CheckButton.new("Use AIM before shooting (longer RT, better accuracy)")
      @w[:"#{which}_aim_first"].active = rng_aim
      @w[:"#{which}_ammo_warn"]  = Gtk::SpinButton.new(
        Gtk::Adjustment.new(rng_warn, 0.0, 999.0, 1.0, 5.0, 0.0), 1, 0)

      rnoun_row = lrow("Ranged weapon noun:", @w[:"#{which}_ranged_noun"])
      ammo_row  = lrow("Ammo container noun:", @w[:"#{which}_ammo_cont"])
      warn_row  = lrow("Warn / stop hunting when ammo falls below:", @w[:"#{which}_ammo_warn"])
      aim_row   = @w[:"#{which}_aim_first"]

      rng_fb.pack_start(rnoun_row, false, false, 2)
      rng_fb.pack_start(lrow("Sub-type:", @w[:"#{which}_ranged_sub"]), false, false, 2)
      rng_fb.pack_start(ammo_row, false, false, 2)
      rng_fb.pack_start(Gtk::Label.new(
        "Enter the noun of the container holding your arrows/bolts/stones.\n" \
        "Examples: quiver, case, pouch, satchel"
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 0)
      rng_fb.pack_start(aim_row,  false, false, 2)
      rng_fb.pack_start(warn_row, false, false, 2)
      rng_fb.pack_start(Gtk::Label.new(
        "Set to 0 to disable the ammo check. Script will stop hunting and alert you when count drops to this threshold."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 2)

      rng_hide   = saved_wpn.fetch("hide_to_shoot", false)
      rng_608    = saved_wpn.fetch("use_608_hide",  false)
      rng_kneel  = saved_wpn.fetch("kneel_crossbow", false)
      rng_stay   = saved_wpn.fetch("stay_kneeling",  false)
      is_ranger  = ((GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "")) =~ /Ranger/i

      @w[:"#{which}_hide_to_shoot"]  = Gtk::CheckButton.new("Hide before each shot (open ambush -- Rangers/Rogues with Hiding skill)")
      @w[:"#{which}_hide_to_shoot"].active = rng_hide
      @w[:"#{which}_use_608_hide"]   = Gtk::CheckButton.new("Use Camouflage (608) to enter stealth instead of HIDE (Rangers only -- costs mana; skipped if mana is low)")
      @w[:"#{which}_use_608_hide"].active    = rng_608
      @w[:"#{which}_use_608_hide"].sensitive = rng_hide && is_ranger
      @w[:"#{which}_hide_to_shoot"].signal_connect("toggled") {
        @w[:"#{which}_use_608_hide"].sensitive = @w[:"#{which}_hide_to_shoot"].active? && is_ranger
      }
      @w[:"#{which}_kneel_crossbow"] = Gtk::CheckButton.new("Kneel before firing crossbow (+AS bonus; crossbow only)")
      @w[:"#{which}_kneel_crossbow"].active = rng_kneel
      @w[:"#{which}_stay_kneeling"]  = Gtk::CheckButton.new("Stay kneeling between shots (stand to move/loot)")
      @w[:"#{which}_stay_kneeling"].active  = rng_stay
      @w[:"#{which}_stay_kneeling"].sensitive = rng_kneel
      @w[:"#{which}_kneel_crossbow"].signal_connect("toggled") {
        @w[:"#{which}_stay_kneeling"].sensitive = @w[:"#{which}_kneel_crossbow"].active?
      }
      rng_fb.pack_start(mk_hsep, false, false, 3)
      rng_fb.pack_start(@w[:"#{which}_hide_to_shoot"],  false, false, 2)
      rng_fb.pack_start(@w[:"#{which}_use_608_hide"],   false, false, 2)
      rng_fb.pack_start(@w[:"#{which}_kneel_crossbow"], false, false, 2)
      rng_fb.pack_start(@w[:"#{which}_stay_kneeling"],  false, false, 2)

      update_ranged_sensitivity = proc {
        is_thrown = @w[:"#{which}_ranged_sub"].active == 3
        is_xbow   = @w[:"#{which}_ranged_sub"].active == 1
        ammo_row.sensitive  = !is_thrown
        warn_row.sensitive  = !is_thrown
        aim_row.sensitive   = !is_thrown
        rnoun_row.sensitive = !is_thrown
        @w[:"#{which}_kneel_crossbow"].sensitive = is_xbow
        @w[:"#{which}_stay_kneeling"].sensitive  = is_xbow && @w[:"#{which}_kneel_crossbow"].active?
      }
      @w[:"#{which}_ranged_sub"].signal_connect("changed") { update_ranged_sensitivity.call }
      update_ranged_sensitivity.call

      ranged_type_idx = type_list.index { |t| t[:code] == "ranged" }
      fields_box.pack_start(rng_frame, false, false, 4)
      Gtk.queue { rng_frame.visible = (tidx == ranged_type_idx) }
    end

    type_combo.signal_connect("changed") do
      next if offhand  # offhand combo only has 1HE/1HB -- no sub-panels to toggle
      pol_frame.visible = (type_combo.active == polearm_type_idx)
      rng_frame.visible = (type_combo.active == ranged_type_idx)
    end

    vb.pack_start(fields_box, false, false, 0)
    vb
  end

  def self.pg_weapon
    saved_dual = @profile.dig("weapons", "dual_wield") || false
    vb = mk_vbox(6)
    vb.border_width = 10

    dual_cb = w_check(:dual_wield, "I am dual-wielding (two weapons simultaneously)", saved_dual)
    vb.pack_start(dual_cb, false, false, 3)

    dw_note = Gtk::Label.new("")
    dw_note.wrap = true
    dw_note.xalign = 0.0
    dw_note.set_markup(
      "<small><i><span foreground='#888888'>" \
      "Main hand: if using a katana, the script will automatically verify its grip is set to 1-handed before combat. " \
      "Off-hand type list is restricted to 1HE/1HB weapons. " \
      "Note: old katanas with a longsword or falchion base are valid off-hand choices." \
      "</span></i></small>"
    )
    vb.pack_start(dw_note, false, false, 0)
    Gtk.queue { dw_note.visible = saved_dual }
    dual_cb.signal_connect("toggled") { dw_note.visible = dual_cb.active? }

    vb.pack_start(mk_hsep, false, false, 2)

    pri_frame, pri_fb = frame_vbox("Primary (right hand)")
    pri_fb.pack_start(build_weapon_fields("primary"), false, false, 0)
    vb.pack_start(pri_frame, false, false, 4)

    # Warn when dual-wield is on but primary type is incompatible (2hw or polearm)
    dw_invalid_types = %w[2hw polearm]
    dw_warn = Gtk::Label.new("")
    dw_warn.set_markup("<b><span foreground='red'>Invalid dual-wield main hand: cannot use a Two-Handed or Polearm weapon in dual wield. Change weapon type above.</span></b>")
    dw_warn.wrap = true
    dw_warn.xalign = 0.0
    vb.pack_start(dw_warn, false, false, 0)
    check_dw_warn = proc {
      pri_type_code = (WEAPON_TYPES[@w[:primary_type]&.active.to_i] || {})[:code].to_s
      dw_warn.visible = dual_cb.active? && dw_invalid_types.include?(pri_type_code)
    }
    Gtk.queue { check_dw_warn.call }
    dual_cb.signal_connect("toggled") { check_dw_warn.call }
    @w[:primary_type]&.signal_connect("changed") { check_dw_warn.call }

    sec_frame, sec_fb = frame_vbox("Secondary (left hand / off-hand) -- 1HE/1HB weapons only")
    sec_fb.pack_start(build_weapon_fields("secondary", offhand: true), false, false, 0)
    vb.pack_start(sec_frame, false, false, 4)
    Gtk.queue { sec_frame.visible = saved_dual }

    dual_cb.signal_connect("toggled") { sec_frame.visible = dual_cb.active? }

    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""
    if prof =~ /Rogue|Ranger/i
      saved_amb = (@profile.dig("weapons", "ambush") || {}) rescue {}
      amb_frame, amb_fb = frame_vbox("Ambush Settings")
      @w[:ambush_enabled] = Gtk::CheckButton.new("Use AMBUSH instead of ATTACK when attacking")
      @w[:ambush_enabled].active = saved_amb.fetch("enabled", false)
      @w[:ambush_hide] = Gtk::CheckButton.new("Attempt to HIDE before each ambush (requires hiding skill)")
      @w[:ambush_hide].active = saved_amb.fetch("hide_first", false)
      @w[:ambush_hide].sensitive = @w[:ambush_enabled].active?
      @w[:ambush_enabled].signal_connect("toggled") { @w[:ambush_hide].sensitive = @w[:ambush_enabled].active? }
      amb_fb.pack_start(@w[:ambush_enabled], false, false, 2)
      amb_fb.pack_start(@w[:ambush_hide],    false, false, 2)
      vb.pack_start(amb_frame, false, false, 4)
    end

    if prof =~ /Paladin/i
      saved_hw   = (@profile.dig("weapons", "holy_weapon") || {}) rescue {}
      smc_ranks  = (@detected || {}).dig(:lore_ranks, "SMC").to_i
      summ_ranks = (@detected || {}).dig(:lore_ranks, "Summoning").to_i

      hw_frame, hw_fb = frame_vbox("Holy Weapon (1625) -- Paladin Only")

      @w[:hw_enabled] = Gtk::CheckButton.new("Enable Holy Weapon management")
      @w[:hw_enabled].active = saved_hw.fetch("enabled", false)

      bl_row = mk_hbox(4)
      bl_row.pack_start(Gtk::Label.new("Bond level (1-5, you know this):").tap { |l| l.xalign = 0.0 }, false, false, 0)
      @w[:hw_bond_level] = Gtk::SpinButton.new(
        Gtk::Adjustment.new(saved_hw.fetch("bond_level", 3).to_f, 1.0, 5.0, 1.0, 1.0, 0.0), 1, 0)
      bl_row.pack_start(@w[:hw_bond_level], false, false, 4)

      # Build offensive spell list from Lich's live spell data.
      # Paladin has Minor Spiritual (100-140) and Paladin Base (1600-1635).
      # Include spells whose type contains "attack" or "offense" and are known.
      hw_spell_nums    = (100..140).to_a + (1600..1629).to_a
      hw_spell_exclude = [1609, 1617, 1618].to_set
      hw_spell_list = hw_spell_nums.filter_map do |n|
        next if hw_spell_exclude.include?(n)
        s = Spell[n] rescue nil
        next unless s && (s.known? rescue false)
        next unless s.type.to_s =~ /attack|offense/i
        [n.to_s, "#{n} - #{s.name}"]
      end
      hw_spell_list = [["1615", "1615 - Repentance"]] if hw_spell_list.empty?
      saved_spell  = saved_hw.fetch("spell", "1615").to_s
      spell_idx    = hw_spell_list.index { |k, _| k == saved_spell } || 0

      sp_row = mk_hbox(4)
      sp_row.pack_start(Gtk::Label.new("Spell to infuse:").tap { |l| l.xalign = 0.0 }, false, false, 0)
      @w[:hw_spell] = mk_combo_text(hw_spell_list.map { |_, lbl| lbl }, spell_idx)
      @w[:hw_spell_keys] = hw_spell_list.map { |k, _| k }
      sp_row.pack_start(@w[:hw_spell], false, false, 4)

      mode_row = mk_hbox(4)
      mode_row.pack_start(Gtk::Label.new("When to BESEECH:").tap { |l| l.xalign = 0.0 }, false, false, 0)
      hw_modes   = ["Before every attack", "Once per target", "Once at hunt start"]
      mode_keys  = ["per_attack", "per_target", "once"]
      mode_saved = mode_keys.index(saved_hw.fetch("mode", "per_target")) || 1
      @w[:hw_mode] = mk_combo_text(hw_modes, mode_saved)
      @w[:hw_mode_keys] = mode_keys
      mode_row.pack_start(@w[:hw_mode], false, false, 4)

      @w[:hw_autorefill] = Gtk::CheckButton.new("Auto-refill spell when charges run out")
      @w[:hw_autorefill].active = saved_hw.fetch("autorefill", true)

      charges = summ_ranks / 10
      @w[:hw_info] = Gtk::Label.new(
        "Capacity: #{charges} charges  |  SMC: #{smc_ranks} ranks  |  Summoning: #{summ_ranks} ranks")
      @w[:hw_info].xalign = 0.0

      hw_sensitive = [bl_row, sp_row, mode_row, @w[:hw_autorefill], @w[:hw_info]]
      hw_sensitive.each { |w| w.sensitive = @w[:hw_enabled].active? }
      @w[:hw_enabled].signal_connect("toggled") do
        on = @w[:hw_enabled].active?
        hw_sensitive.each { |w| w.sensitive = on }
      end

      hw_fb.pack_start(@w[:hw_enabled],    false, false, 2)
      hw_fb.pack_start(bl_row,             false, false, 2)
      hw_fb.pack_start(sp_row,             false, false, 2)
      hw_fb.pack_start(mode_row,           false, false, 2)
      hw_fb.pack_start(@w[:hw_autorefill], false, false, 2)
      hw_fb.pack_start(@w[:hw_info],       false, false, 2)
      vb.pack_start(hw_frame, false, false, 4)
    end

    scrolled(vb)
  end

  def self.aoe_add_dialog
    d = Gtk::Dialog.new("Add AoE Step", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(500, 260)

    type_c = mk_combo_text(ROTATION_TYPES, 0)
    d.vbox.pack_start(lrow("Type:", type_c), false, false, 4)

    cmd_e   = Gtk::Entry.new
    cmd_row = lrow("Spell # or verb:", cmd_e)
    d.vbox.pack_start(cmd_row, false, false, 4)

    cond_c = mk_combo_text(ROTATION_CONDS, 0)
    val_sp = Gtk::SpinButton.new(Gtk::Adjustment.new(50.0, 0.0, 9999.0, 1.0, 5.0, 0.0), 1, 0)
    cond_box = mk_hbox(6)
    cond_box.pack_start(Gtk::Label.new("Condition:").tap { |l| l.xalign = 0.0 }, false, false, 0)
    cond_box.pack_start(cond_c, false, false, 0)
    cond_box.pack_start(Gtk::Label.new("N ="), false, false, 4)
    cond_box.pack_start(val_sp, false, false, 0)
    d.vbox.pack_start(cond_box, false, false, 4)

    type_c.signal_connect("changed") do
      type_key = ROTATION_TYPES[type_c.active].split.first rescue "attack"
      cmd_row.visible = %w[spell bolt cman].include?(type_key)
    end

    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      type_key = ROTATION_TYPES[type_c.active].split.first rescue "attack"
      cmd_val  = cmd_e.text.strip
      cond_raw = ROTATION_CONDS[cond_c.active] rescue "always"
      cond_str = cond_raw == "always" ? "always" : cond_raw.gsub("N", val_sp.value.to_i.to_s)
      iter = @aoe_store.append
      @aoe_store.set_value(iter, 0, type_key)
      @aoe_store.set_value(iter, 1, cmd_val)
      @aoe_store.set_value(iter, 2, cond_str)
    end
    d.destroy
  end

  SCRIPT_SLOTS     = ["Primary Weapon", "Secondary Weapon", "Armor", "Shield"].freeze
  SCRIPT_SLOT_KEYS = [:primary, :secondary, :armor, :shield].freeze
  SCRIPT_WHEN_OPTS = %w[per_attack engagement aoe maintenance emergency].freeze

  def self.pg_scripts
    @script_entries = {}
    @scripts_vbox   = mk_vbox(6)
    outer = mk_vbox(8)
    outer.border_width = 10

    outer.pack_start(mk_hsep, false, false, 3)

    detected = (@detected || {})[:item_scripts] || []

    if detected.empty?
      hint = Gtk::Label.new(
        "No scripted items detected.\n" \
        "Items must be in hand or worn when setup runs for auto-detection.\n" \
        "Use 'Add Script' to add any scripted items manually."
      )
      hint.xalign = 0.0
      hint.set_line_wrap(true)
      outer.pack_start(hint, false, false, 5)
    else
      hint = Gtk::Label.new("Detected scripted items. Add more below if any were missed.")
      hint.xalign = 0.0
      outer.pack_start(hint, false, false, 5)
    end

    saved_disabled = (@profile["script_disabled"] || {}) rescue {}
    saved_when_all = {}
    saved_slot_for = {}
    saved_noun_for = {}
    saved_tier_for = {}
    [
      [@profile.dig("weapons", "primary",   "scripts"), :primary,   @profile.dig("weapons", "primary",   "noun").to_s],
      [@profile.dig("weapons", "secondary", "scripts"), :secondary, @profile.dig("weapons", "secondary", "noun").to_s],
      [@profile.dig("armor",   "scripts"),              :armor,     @profile.dig("armor",   "noun").to_s],
      [@profile.dig("shield",  "scripts"),              :shield,    @profile.dig("shield",  "noun").to_s],
    ].each do |scripts, slot_key, slot_noun|
      (scripts || []).each do |sc|
        nm = sc["name"].to_s
        saved_when_all[nm] ||= {}
        saved_slot_for[nm] ||= slot_key
        saved_noun_for[nm] ||= slot_noun
        saved_tier_for[nm] ||= sc["tier"].to_i
        (sc["abilities"] || []).each do |ab|
          saved_when_all[nm][ab["key"].to_s] = ab["when"].to_s if ab["when"]
        end
      end
    end

    detected_names = detected.map { |s| s[:name] }.to_set
    detected.each { |s| add_script_entry(s[:name], s[:slot], s[:noun], s[:tier], s[:wing_type] || "Light", saved_disabled[s[:name]] || [], saved_when_all[s[:name]] || {}) }

    # Load saved-but-not-detected scripts so users can explicitly remove them
    saved_slot_for.each do |name, slot_key|
      next if detected_names.include?(name)
      next if @script_entries.any? { |_, e| e[:name] == name }
      add_script_entry(
        name, slot_key, saved_noun_for[name].to_s,
        saved_tier_for[name] || 1, "Light",
        saved_disabled[name] || [], saved_when_all[name] || {},
        stale: true
      )
    end

    outer.pack_start(mk_hsep, false, false, 3)
    outer.pack_start(@scripts_vbox, false, false, 0)

    add_btn = Gtk::Button.new("+ Add Script")
    add_btn.signal_connect("clicked") { script_add_dialog }
    outer.pack_start(add_btn, false, false, 6)

    scrolled(outer)
  end

  def self.add_script_entry(name, slot_key = :primary, noun = "", tier = 1, wing_type_str = "Light", disabled_keys = [], saved_when = {}, stale: false)
    slots_data = SCRIPT_TEMPLATES[name] || {}
    sf, sb = frame_vbox(name)

    if stale
      stale_lbl = Gtk::Label.new(
        "Not detected this session -- item may not be equipped.\n" \
        "If you no longer own this item, click Remove to clear it from your profile."
      )
      stale_lbl.xalign = 0.0
      stale_lbl.set_line_wrap(true)
      begin stale_lbl.override_color(:normal, Gdk::RGBA.new(0.75, 0.45, 0.0, 1.0)) rescue nil end
      sb.pack_start(stale_lbl, false, false, 4)
    end

    slot_idx = SCRIPT_SLOT_KEYS.index(slot_key) || 0
    slot_c   = mk_combo_text(SCRIPT_SLOTS, slot_idx)
    hint     = slots_data[:noun_hint].to_s
    noun_e   = Gtk::Entry.new
    noun_e.text = noun.to_s.empty? ? hint : noun.to_s
    noun_e.placeholder_text = hint unless hint.empty? rescue nil
    max_tier = (slots_data[:max_tier] || 6).to_f
    tier_adj = Gtk::Adjustment.new(tier.to_f, 1.0, max_tier, 1.0, 1.0, 0.0)
    tier_sp  = Gtk::SpinButton.new(tier_adj, 1, 0)
    detect_b = Gtk::Button.new("Detect Tier")
    rem_b    = Gtk::Button.new("Remove")

    sb.pack_start(lrow("Item slot:", slot_c), false, false, 3)
    sb.pack_start(lrow("Item noun:", noun_e), false, false, 3)

    # Energy Wings: Light vs Dark type selector
    wing_type_c = nil
    if name == "Energy Wings"
      wt_idx      = ENERGY_WINGS_TYPES.index(wing_type_str) || 0
      wing_type_c = mk_combo_text(ENERGY_WINGS_TYPES, wt_idx)
      sb.pack_start(lrow("Wing type:", wing_type_c), false, false, 3)
    end

    tier_hb = mk_hbox(6)
    tier_hb.pack_start(Gtk::Label.new("Tier:"), false, false, 0)
    tier_hb.pack_start(tier_sp,  false, false, 0)
    tier_hb.pack_start(detect_b, false, false, 6)
    tier_hb.pack_start(rem_b,    false, false, 6)
    sb.pack_start(tier_hb, false, false, 3)

    # Per-ability checkboxes + When dropdowns
    ability_checks = {}
    when_combos    = {}
    ab_vbox = mk_vbox(1)
    ab_hdr  = Gtk::Label.new("Abilities (uncheck to disable; choose when to fire):")
    ab_hdr.xalign = 0.0
    sb.pack_start(ab_hdr, false, false, 4)

    build_ability_checks = lambda do
      ab_vbox.children.each { |c| ab_vbox.remove(c) }
      wt_sym   = wing_type_c ? ENERGY_WINGS_TYPES[wing_type_c.active].to_s.downcase.to_sym : nil
      cur_tier = tier_sp.value.to_i
      slot_key_raw = SCRIPT_SLOT_KEYS[slot_c.active] rescue nil
      active_slot = { primary: :weapon, secondary: :weapon, armor: :armor, shield: :shield }[slot_key_raw]
      slots_to_show = active_slot && slots_data.key?(active_slot) ? [active_slot] : slots_data.keys
      slots_to_show.each do |slot_sym|
        abilities = slots_data[slot_sym] || []
        abilities.reject { |a| a[:when] == "skip" || a[:when] == "toggle_startup" }.each do |a|
          next if a[:min_tier] && a[:min_tier] > cur_tier
          next if wt_sym && a[:type] && a[:type] != :both && a[:type] != wt_sym
          key = "#{slot_sym}:#{a[:key]}"

          prev_cb = ability_checks[key]
          checked = prev_cb ? prev_cb.active? : !disabled_keys.include?(key)
          cb = Gtk::CheckButton.new("#{a[:key].upcase} -- #{a[:desc]}")
          cb.active = checked
          ability_checks[key] = cb

          default_when = saved_when[a[:key].to_s]
          default_when = a[:when].to_s if default_when.nil? || default_when.empty?
          prev_wc = when_combos[key]
          prev_idx = prev_wc ? prev_wc.active : nil
          when_idx = SCRIPT_WHEN_OPTS.index(default_when) || 1
          when_idx = prev_idx if prev_idx
          when_c = mk_combo_text(SCRIPT_WHEN_OPTS, when_idx)
          when_combos[key] = when_c

          row_hb = mk_hbox(4)
          row_hb.pack_start(cb,                         true,  true,  0)
          row_hb.pack_start(Gtk::Label.new("When:"),    false, false, 4)
          row_hb.pack_start(when_c,                     false, false, 0)
          ab_vbox.pack_start(row_hb, false, false, 2)
        end
      end
      ab_vbox.show_all
    end

    build_ability_checks.call
    slot_c.signal_connect("changed")           { build_ability_checks.call }
    wing_type_c.signal_connect("changed")      { build_ability_checks.call } if wing_type_c
    tier_sp.signal_connect("value-changed")    { build_ability_checks.call }
    sb.pack_start(ab_vbox, false, false, 2)

    detect_b.signal_connect("clicked") do
      n = noun_e.text.strip
      next if n.empty?
      detect_b.label     = "Detecting..."
      detect_b.sensitive = false
      Thread.new do
        out  = capture_detect("analyze my #{n}", 3.0)
        tier = if    out =~ /tier\s*(\d)/i then $1.to_i
                 elsif out =~ /\bT(\d)\b/   then $1.to_i
                 else nil end
        Gtk.queue do
          tier ? (tier_sp.value = tier.to_f; detect_b.label = "Detected: T#{tier}") \
               : (detect_b.label = "Not found")
          detect_b.sensitive = true
        end
      end
    end

    entry_key = "#{name}::#{slot_key}"
    rem_b.signal_connect("clicked") do
      @script_entries.delete(entry_key)
      @scripts_vbox.remove(sf)
    end

    @scripts_vbox.pack_start(sf, false, false, 4)
    @scripts_vbox.show_all
    @script_entries[entry_key] = { name: name, slot: slot_c, noun: noun_e, tier: tier_sp, wing_type: wing_type_c, ability_checks: ability_checks, when_combos: when_combos }
  end

  def self.script_add_dialog
    d = Gtk::Dialog.new("Add Script", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(400, 160)
    name_c = mk_combo_text(SCRIPT_TEMPLATES.keys.sort, 0)
    d.vbox.pack_start(lrow("Script:", name_c), false, false, 6)
    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      name = SCRIPT_TEMPLATES.keys.sort[name_c.active]
      add_script_entry(name) unless @script_entries.any? { |_, e| e[:name] == name }
    end
    d.destroy
  end

  def self.pg_defense
    d    = @detected || {}
    vb   = mk_vbox(8)
    vb.border_width = 10

    # Armor frame
    af, ab = frame_vbox("Armor")
    armor_item = d[:armor]
    if armor_item
      dl = Gtk::Label.new("Detected: #{armor_item.name}")
      dl.xalign = 0.0
      ab.pack_start(dl, false, false, 2)
    end
    aidx = d[:armor_asg] ? armor_asg_idx(d[:armor_asg]) : 0
    armor_noun_row = lrow("Noun:", w_entry(:armor_noun, armor_item&.noun || "armor"))
    armor_type_row = lrow("Type:", w_combo(:armor_asg, ARMOR_TYPES.map { |t| t[:label] }, aidx))
    ab.pack_start(armor_noun_row, false, false, 3)
    ab.pack_start(armor_type_row, false, false, 3)
    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""
    if prof =~ /Bard/i
      saved_sonic_arm = @profile.dig("armor", "sonic_armor") || false
      @w[:sonic_armor_primary] = Gtk::CheckButton.new("I am wearing Sonic Armor (spell 1014) instead of physical armor")
      @w[:sonic_armor_primary].active = saved_sonic_arm
      bard_arm_note = Gtk::Label.new("Sonic Armor active -- armor noun and type are set in the Songs tab.")
      bard_arm_note.xalign = 0.0; bard_arm_note.wrap = true
      ab.pack_start(@w[:sonic_armor_primary], false, false, 2)
      ab.pack_start(bard_arm_note,            false, false, 2)
      sonic_on = saved_sonic_arm
      Gtk.queue do
        armor_noun_row.visible = !sonic_on
        armor_type_row.visible = !sonic_on
        bard_arm_note.visible  = sonic_on
      end
      @w[:sonic_armor_primary].signal_connect("toggled") do
        on = @w[:sonic_armor_primary].active?
        armor_noun_row.visible = !on
        armor_type_row.visible = !on
        bard_arm_note.visible  = on
      end
    end
    vb.pack_start(af, false, false, 4)

    # Shield frame
    sf, sb = frame_vbox("Shield")
    if d[:shield_name]
      dl = Gtk::Label.new("Detected in left hand: #{d[:shield_name]}")
      dl.xalign = 0.0
      sb.pack_start(dl, false, false, 2)
    end
    sb.pack_start(w_check(:shield_enabled, "I use a shield", d[:has_shield] || false), false, false, 3)
    shield_noun_row = lrow("Noun:", w_entry(:shield_noun, d[:shield_noun] || "shield"))
    sb.pack_start(shield_noun_row, false, false, 3)
    if prof =~ /Bard/i
      saved_sonic_shld = @profile.dig("shield", "sonic_shield") || false
      @w[:sonic_shield_primary] = Gtk::CheckButton.new("I am using a Sonic Shield (spell 1009) instead of a physical shield")
      @w[:sonic_shield_primary].active = saved_sonic_shld
      bard_shld_note = Gtk::Label.new("Sonic Shield active -- shield noun is set in the Songs tab. READY SHIELD is skipped automatically.")
      bard_shld_note.xalign = 0.0; bard_shld_note.wrap = true
      sb.pack_start(@w[:sonic_shield_primary], false, false, 2)
      sb.pack_start(bard_shld_note,            false, false, 2)
      sonic_on = saved_sonic_shld
      Gtk.queue do
        shield_noun_row.visible = !sonic_on
        bard_shld_note.visible  = sonic_on
      end
      @w[:shield_enabled].sensitive = !sonic_on
      @w[:sonic_shield_primary].signal_connect("toggled") do
        on = @w[:sonic_shield_primary].active?
        shield_noun_row.visible = !on
        bard_shld_note.visible  = on
        @w[:shield_enabled].sensitive = !on
      end
    end
    vb.pack_start(sf, false, false, 4)

    # ---- Shield Specializations -----------------------------------------------
    has_saved_ss = (@profile["shield_specs"] || []).any?
    has_any_ss   = Array(d[:shield_specs]).any? || has_saved_ss
    if !has_any_ss
      ssf = Gtk::Frame.new("Shield Specializations")
      ssf.add(Gtk::Label.new("No shield specializations trained yet -- section will appear once you train one.").tap { |l| l.xalign = 0.0; l.wrap = true })
      @shield_spec_store = nil
      vb.pack_start(ssf, false, false, 4)
    else
    ssf, ssb = frame_vbox("Shield Specializations (from SHIELD INFO)")
    ss_hint = Gtk::Label.new(
      "Detected shield specializations. Setup types fire at the start of engagement.\n" \
      "Verb is the mnemonic: e.g. 'shield bash' fires the BASH specialization.\n" \
      "Check 'Use' to activate; leave unchecked for passive/ignored abilities."
    )
    ss_hint.xalign = 0.0; ss_hint.set_line_wrap(true)
    ssb.pack_start(ss_hint, false, false, 3)

    saved_ss = (@profile["shield_specs"] || []).map { |r| [r["name"], r] }.to_h
    # cols: enabled(bool), name, verb, type, min_creatures
    @shield_spec_store = Gtk::ListStore.new(TrueClass, String, String, String, String)
    Array(d[:shield_specs]).each do |spec|
      name      = spec[:name]
      verb      = "shield #{spec[:mnemonic]}"
      tech_type = spec[:tech_type] || "setup"
      saved     = saved_ss[name]
      enabled   = saved ? saved["enabled"] : %w[assault aoe].include?(tech_type)
      iter = @shield_spec_store.append
      @shield_spec_store.set_value(iter, 0, enabled)
      @shield_spec_store.set_value(iter, 1, name)
      @shield_spec_store.set_value(iter, 2, verb)
      @shield_spec_store.set_value(iter, 3, tech_type)
      @shield_spec_store.set_value(iter, 4, spec[:min_creatures].to_s)
    end
    # Restore any manually saved rows not in current detection
    saved_ss.each do |name, r|
      next if Array(d[:shield_specs]).any? { |s| s[:name] == name }
      next unless name.to_s =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/ && name.length >= 3
      iter = @shield_spec_store.append
      @shield_spec_store.set_value(iter, 0, r["enabled"] || false)
      @shield_spec_store.set_value(iter, 1, r["name"].to_s)
      @shield_spec_store.set_value(iter, 2, r["verb"].to_s)
      @shield_spec_store.set_value(iter, 3, r["tech_type"].to_s)
      @shield_spec_store.set_value(iter, 4, r["min_creatures"].to_s)
    end

    ss_tv = Gtk::TreeView.new(@shield_spec_store)
    ss_tog = Gtk::CellRendererToggle.new; ss_tog.activatable = true
    ss_tog.signal_connect("toggled") { |_, path| it = @shield_spec_store.get_iter(path); @shield_spec_store.set_value(it, 0, !@shield_spec_store.get_value(it, 0)) if it }
    ss_tv.append_column(Gtk::TreeViewColumn.new("Use", ss_tog, "active" => 0))
    [["Name", 1], ["Verb", 2], ["Type", 3]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @shield_spec_store.get_iter(path); @shield_spec_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i); c.resizable = true
      ss_tv.append_column(c)
    end
    ss_sw = Gtk::ScrolledWindow.new
    ss_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    ss_sw.add(ss_tv); ss_sw.set_size_request(-1, 120)
    ssb.pack_start(ss_sw, true, true, 0)
    vb.pack_start(ssf, true, true, 4)
    end # has_any_ss

    # ---- Armor Specializations ------------------------------------------------
    asf, asb = frame_vbox("Armor Specializations (from ARMOR INFO)")
    as_hint = Gtk::Label.new(
      "Detected armor specializations. Buff types are passive and do not need activation.\n" \
      "Check 'Use' only for active-use specs; leave unchecked for always-on passive buffs."
    )
    as_hint.xalign = 0.0; as_hint.set_line_wrap(true)
    asb.pack_start(as_hint, false, false, 3)

    saved_as = (@profile["armor_specs"] || []).map { |r| [r["name"], r] }.to_h
    # cols: enabled(bool), name, verb, type, min_creatures
    @armor_spec_store = Gtk::ListStore.new(TrueClass, String, String, String, String)
    Array(d[:armor_specs]).each do |spec|
      name      = spec[:name]
      verb      = "armor #{spec[:mnemonic]}"
      tech_type = spec[:tech_type] || "buff"
      saved     = saved_as[name]
      enabled   = saved ? saved["enabled"] : false  # Buff types are passive by default
      iter = @armor_spec_store.append
      @armor_spec_store.set_value(iter, 0, enabled)
      @armor_spec_store.set_value(iter, 1, name)
      @armor_spec_store.set_value(iter, 2, verb)
      @armor_spec_store.set_value(iter, 3, tech_type)
      @armor_spec_store.set_value(iter, 4, spec[:min_creatures].to_s)
    end
    saved_as.each do |name, r|
      next if Array(d[:armor_specs]).any? { |s| s[:name] == name }
      next unless name.to_s =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/ && name.length >= 3
      iter = @armor_spec_store.append
      @armor_spec_store.set_value(iter, 0, r["enabled"] || false)
      @armor_spec_store.set_value(iter, 1, r["name"].to_s)
      @armor_spec_store.set_value(iter, 2, r["verb"].to_s)
      @armor_spec_store.set_value(iter, 3, r["tech_type"].to_s)
      @armor_spec_store.set_value(iter, 4, r["min_creatures"].to_s)
    end

    as_tv = Gtk::TreeView.new(@armor_spec_store)
    as_tog = Gtk::CellRendererToggle.new; as_tog.activatable = true
    as_tog.signal_connect("toggled") { |_, path| it = @armor_spec_store.get_iter(path); @armor_spec_store.set_value(it, 0, !@armor_spec_store.get_value(it, 0)) if it }
    as_tv.append_column(Gtk::TreeViewColumn.new("Use", as_tog, "active" => 0))
    [["Name", 1], ["Verb", 2], ["Type", 3]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @armor_spec_store.get_iter(path); @armor_spec_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i); c.resizable = true
      as_tv.append_column(c)
    end
    as_sw = Gtk::ScrolledWindow.new
    as_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    as_sw.add(as_tv); as_sw.set_size_request(-1, 120)
    asb.pack_start(as_sw, true, true, 0)
    vb.pack_start(asf, true, true, 4)

    scrolled(vb)
  end

  def self.pg_mount
    vb  = mk_vbox(6)
    vb.border_width = 10
    sm         = (@saved_config || {})["mount"] || {}
    enabled_cb = w_check(:mount_enabled, "I use a combat mount", sm.fetch("enabled", false))
    vb.pack_start(enabled_cb, false, false, 3)
    @w[:mount_noun]  = Gtk::Entry.new.tap { |e| e.text = sm.fetch("noun",        "") }
    @w[:mount_sitem] = Gtk::Entry.new.tap { |e| e.text = sm.fetch("summon_item", "reins") }
    @w[:mount_sverb] = Gtk::Entry.new.tap { |e| e.text = sm.fetch("summon_verb", "wave") }
    add_row(vb, "Mount noun:",   @w[:mount_noun])
    add_row(vb, "Summon item:",  @w[:mount_sitem])
    add_row(vb, "Summon verb:",  @w[:mount_sverb])
    vb.pack_start(w_check(:mount_charge,  "Supports MOUNT CHARGE (used for single-target rotation attacks)",       sm.fetch("has_charge",  false)), false, false, 2)
    vb.pack_start(w_check(:mount_trample, "Supports MOUNT TRAMPLE (used for AoE / multiple-target attacks only)", sm.fetch("has_trample", false)), false, false, 2)
    enabled_cb.signal_connect("toggled") do
      if enabled_cb.active?
        @w[:mount_charge].active  = true
        @w[:mount_trample].active = true
      end
    end
    scrolled(vb)
  end

  ROTATION_TYPES = [
    "spell    -- cast a warding/cyclic spell (incant N, or sing N for Bards)",
    "bolt     -- cast a bolt spell (needs offensive stance)",
    "cman     -- CMAN or feat (uses stamina)",
    "attack   -- basic weapon attack",
    "uac_jab  -- UAC JAB (2s RT)",
    "uac_punch   -- UAC PUNCH (3s RT)",
    "uac_grapple -- UAC GRAPPLE (3s RT)",
    "uac_kick    -- UAC KICK (4s RT)",
    "uac_mstrike -- UAC MSTRIKE (multi-target)",
  ].freeze

  ROTATION_CONDS = [
    "always",
    "mana > N%",
    "mana < N%",
    "stamina > N",
    "stamina < N",
    "creatures >= N",
  ].freeze

  def self.pg_spells
    d         = @detected || {}
    vb        = mk_vbox(6)
    vb.border_width = 10

    known     = Array(d[:known_spells])
    prof      = GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil
    is_bard   = prof =~ /Bard/i
    is_caster = CASTER_PROFESSIONS.include?(prof)
    # Spells managed elsewhere or handled specially -- exclude from the maintain list:
    #   1001-1040: Bard Base managed in Songs tab
    #   1635: Divine Intervention (BESEECH) -- emergency-only, opt-in in Paladin Spells section
    #   1650: Divine Incarnation -- complex multi-ability system, configured in Paladin Spells section
    # 1604: Holy Receptacle (utility), 1620: Prayer of the Devout (utility),
    # 1625: Arm of the Arkati (utility), 1640: Sanctify (utility)
    maintain_known = known.reject { |s|
      (is_bard && s[:num].between?(1001, 1040)) ||
        [1604, 1620, 1625, 1635, 1640, 1650].include?(s[:num])
    }
    offensive, other = maintain_known.partition { |s| spell_offensive?(s) }

    # Rotation dropdowns show offensive spells only -- Bard Base (1001-1040) always excluded (Songs tab owns those)
    # 1635/1650 also excluded: handled in the Paladin Spells section, not the rotation
    all_offensive = known.reject { |s| s[:num].between?(1001, 1040) || [1604, 1620, 1625, 1635, 1640, 1650].include?(s[:num]) }.select { |s| spell_offensive?(s) }
    spell_opts = ["-- None --"] +
      all_offensive.sort_by { |s| s[:num] }.map { |s| "#{s[:num]} -- #{s[:name]}" }

    # ---- Paladin Emergency Spells (1635 + 1650) --------------------------------
    if prof == "Paladin"
      saved_pal = (@saved_config || {})["paladin_spells"] || {}
      lore_ranks = (@detected || {})[:lore_ranks] || {}
      bless_ranks = lore_ranks["Blessings"].to_i

      # 1635 -- Divine Intervention BESEECH
      has_1635 = known.any? { |s| s[:num] == 1635 }
      pf1, pb1 = frame_vbox("Spell 1635 -- Divine Intervention (BESEECH)")
      if has_1635
        desc1 = Gtk::Label.new(
          "BESEECH removes one status effect (stun, web, bind, poison, disease, curse) at no mana cost.\n" \
          "The script fires this automatically when you are stunned, webbed, or bound during a hunt."
        )
        desc1.xalign = 0.0; desc1.set_line_wrap(true)
        pb1.pack_start(desc1, false, false, 3)
        @w[:pal_1635_enabled] = Gtk::CheckButton.new("Enable BESEECH (1635) as emergency status removal")
        @w[:pal_1635_enabled].active = saved_pal.fetch("beseech_enabled", true)
        pb1.pack_start(@w[:pal_1635_enabled], false, false, 2)
      else
        pb1.pack_start(Gtk::Label.new("Spell 1635 not detected -- train it to unlock this option.").tap { |l| l.xalign = 0.0 }, false, false, 3)
        @w[:pal_1635_enabled] = nil
      end
      vb.pack_start(pf1, false, false, 5)

      # 1650 -- Divine Incarnation INCARNATE abilities
      has_1650 = known.any? { |s| s[:num] == 1650 }
      pf2, pb2 = frame_vbox("Spell 1650 -- Divine Incarnation (INCARNATE abilities)")
      if has_1650
        # Armor emergency uses: base 1/day; +1 at 50 bless ranks, +1 at 125 bless ranks
        armor_uses = 1 + (bless_ranks >= 50 ? 1 : 0) + (bless_ranks >= 125 ? 1 : 0)

        desc2 = Gtk::Label.new(
          "Divine Incarnation gives 30 Divine Energy. Spell lasts 5 min (10 min cooldown).\n" \
          "Spiritual Lore, Blessings (#{bless_ranks} ranks detected) -- Armor emergency uses per day: #{armor_uses}.\n" \
          "Choose which abilities the script may use and in what situations."
        )
        desc2.xalign = 0.0; desc2.set_line_wrap(true)
        pb2.pack_start(desc2, false, false, 3)

        @w[:pal_incarn_armor_emerg]  = Gtk::CheckButton.new("INCARNATE ARMOR in emergencies (50% damage resist 30s, #{armor_uses}x/day max)")
        @w[:pal_incarn_zeal]         = Gtk::CheckButton.new("INCARNATE ZEAL per attack (deity flares on next 5 hits, 5 DE)")
        @w[:pal_incarn_smite]        = Gtk::CheckButton.new("INCARNATE SMITE per attack (divine bolt + plasma crit, 5 DE)")
        @w[:pal_incarn_onslaught]    = Gtk::CheckButton.new("INCARNATE ONSLAUGHT for AoE (multi-target, ignores 50%+ stance, 10 DE)")

        @w[:pal_incarn_armor_emerg].active  = saved_pal.fetch("incarn_armor_emergency", true)
        @w[:pal_incarn_zeal].active         = saved_pal.fetch("incarn_zeal", false)
        @w[:pal_incarn_smite].active        = saved_pal.fetch("incarn_smite", true)
        @w[:pal_incarn_onslaught].active    = saved_pal.fetch("incarn_onslaught", true)

        [
          @w[:pal_incarn_armor_emerg],
          @w[:pal_incarn_zeal],
          @w[:pal_incarn_smite],
          @w[:pal_incarn_onslaught],
        ].each { |cb| pb2.pack_start(cb, false, false, 2) }

        # ARMOR RT threshold -- only meaningful when ARMOR emergency is checked
        armor_rt_thresh = saved_pal.fetch("incarn_armor_rt_threshold", 8)
        @w[:pal_incarn_armor_rt] = Gtk::SpinButton.new(
          Gtk::Adjustment.new(armor_rt_thresh.to_f, 1.0, 30.0, 1.0, 1.0, 0.0), 1, 0)
        rt_row = lrow(
          "Use INCARNATE ARMOR when stunned AND roundtime >=  seconds:",
          @w[:pal_incarn_armor_rt]
        )
        rt_row.sensitive = @w[:pal_incarn_armor_emerg].active?
        pb2.pack_start(rt_row, false, false, 2)
        @w[:pal_incarn_armor_emerg].signal_connect("toggled") { rt_row.sensitive = @w[:pal_incarn_armor_emerg].active? }

        rt_note = Gtk::Label.new(
          "ARMOR fires only when: (1) you are stunned, AND (2) your current roundtime is at or above the threshold.\n" \
          "Set lower (e.g. 5s) to fire sooner; higher (e.g. 12s) to conserve daily uses for longer stuns only."
        )
        rt_note.xalign = 0.0; rt_note.set_line_wrap(true)
        pb2.pack_start(rt_note, false, false, 2)

        note2 = Gtk::Label.new(
          "Note: ARMOR emergency mode fires without an active Incarnation -- it is a standalone daily ability.\n" \
          "ZEAL/SMITE/ONSLAUGHT require an active Incarnation (script will cast 1650 first if not active)."
        )
        note2.xalign = 0.0; note2.set_line_wrap(true)
        pb2.pack_start(note2, false, false, 4)
      else
        pb2.pack_start(Gtk::Label.new("Spell 1650 not detected -- train it to unlock this option.").tap { |l| l.xalign = 0.0 }, false, false, 3)
        @w[:pal_incarn_armor_emerg] = @w[:pal_incarn_zeal] = @w[:pal_incarn_smite] = @w[:pal_incarn_onslaught] = nil
        @w[:pal_incarn_armor_rt] = nil
      end
      vb.pack_start(pf2, false, false, 5)
    end
    # ---- end Paladin section ---------------------------------------------------

    # ---- Maintain Spells (merged detected spells + maintain list) --------------
    saved_maintain_nums = ((@saved_config || {}).dig("spells", "maintain") || []).map { |s| s["num"].to_i }.to_set
    mf, mb = frame_vbox("Maintain Spells#{is_bard ? ' (Bard songs managed in Songs tab)' : ''}")

    warn_lbl = Gtk::Label.new(
      "Check any spell you want kept active during hunting. The script maintains spells by casting INCANT <num> whenever the spell is not active.\n\n" \
      "This works for any self-cast buff -- including mana node/regeneration spells that casters use to recover mana faster.\n\n" \
      "Do NOT check spells that require a target, special components, or a non-standard casting procedure -- those will fail or produce errors.\n" \
      "Examples of spells that will NOT work here: Consecrate (targets a weapon), Magic Item Creation, Holy Weapon enhancements, or any spell that prompts for input."
    )
    warn_lbl.xalign = 0.0; warn_lbl.set_line_wrap(true)
    mb.pack_start(warn_lbl, false, false, 4)

    if maintain_known.empty?
      mb.pack_start(Gtk::Label.new(
        "No spells detected -- Lich may not have received spell data yet.\n" \
        "Try re-running setup after casting a spell or logging spells."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 4)
    else
      circles = prof ? (PROFESSION_SPELL_CIRCLES[prof] || []) : []
      unless circles.empty?
        cl = Gtk::Label.new("#{prof} spell circles: #{circles.join(", ")}")
        cl.xalign = 0.0
        mb.pack_start(cl, false, false, 2)
      end
      if is_caster
        cl2 = Gtk::Label.new("#{prof}s hunt primarily with spells -- set your attack rotation below. Check buffs here to keep them maintained.")
        cl2.xalign = 0.0; cl2.set_line_wrap(true)
        mb.pack_start(cl2, false, false, 2)
      end

      @known_spell_checks = {}
      spell_scroll = Gtk::ScrolledWindow.new
      spell_scroll.set_policy(Gtk::POLICY_NEVER, Gtk::POLICY_AUTOMATIC)
      spell_scroll.set_size_request(-1, 180)
      spell_vb = mk_vbox(2)
      spell_vb.border_width = 4

      render_section = lambda do |title, spells|
        next if spells.empty?
        hdr = Gtk::Label.new("<b>#{title}</b>")
        hdr.use_markup = true; hdr.xalign = 0.0
        spell_vb.pack_start(hdr, false, false, 3)
        by_circle = spells.group_by { |s| s[:circle] }
        by_circle.each do |circle, cspells|
          clbl = Gtk::Label.new("  <i>#{circle}</i>")
          clbl.use_markup = true; clbl.xalign = 0.0
          spell_vb.pack_start(clbl, false, false, 1)
          spell_hints = { 1609 => "Divine Shield (aura)", 1617 => "Zealot (aura)", 1618 => "Fervor (aura)" }
          cspells.sort_by { |s| s[:num] }.each do |s|
            display_name = spell_hints[s[:num]] || s[:name]
            cb = Gtk::CheckButton.new("#{s[:num]} -- #{display_name}")
            cb.active = saved_maintain_nums.include?(s[:num])
            @known_spell_checks[s[:num]] = { cb: cb, spell: s }
            spell_vb.pack_start(cb, false, false, 1)
          end
        end
      end
      render_section.call("Defensive Spells", other)

      spell_scroll.add_with_viewport(spell_vb)
      mb.pack_start(spell_scroll, true, true, 0)
    end
    vb.pack_start(mf, false, false, 5)

    # Helper: build a rotation frame with 4 dropdown slots
    build_rot_frame = lambda do |title, hint_text, keys|
      rf, rb = frame_vbox(title)
      hl = Gtk::Label.new(hint_text)
      hl.xalign = 0.0; hl.set_line_wrap(true)
      rb.pack_start(hl, false, false, 3)
      ["1st cast:", "2nd cast:", "3rd cast:", "4th cast:"].each_with_index do |lbl, i|
        c = mk_combo_text(spell_opts, 0)
        @w[keys[i]] = c
        rb.pack_start(lrow(lbl, c), false, false, 2)
      end
      rf
    end

    vb.pack_start(build_rot_frame.call(
      "Single Target Rotation (always fires)",
      "Fires every attack round regardless of how many creatures are present.",
      [:rot_st_1, :rot_st_2, :rot_st_3, :rot_st_4]
    ), false, false, 5)
    ((@saved_config || {}).dig("spells", "rotation") || []).each_with_index do |slot, i|
      key = [:rot_st_1, :rot_st_2, :rot_st_3, :rot_st_4][i]; next unless @w[key]
      num = slot["cmd"].to_s.split.last.to_i; next unless num > 0
      idx = spell_opts.index { |o| o.start_with?("#{num} --") }
      @w[key].active = idx if idx
    end

    # Multi-target threshold -- lives here so it's next to the rotation it controls
    saved_thresh = (@saved_config || {}).dig("hunting", "aoe_threshold") || 3
    tf, tb = frame_vbox("Multi-Target / AoE Threshold")
    thresh_lbl = Gtk::Label.new(
      "When this many or more creatures are in the room, the script also fires the AoE rotation below\n" \
      "(in addition to single-target -- both always run when threshold is met)."
    )
    thresh_lbl.xalign = 0.0; thresh_lbl.set_line_wrap(true)
    tb.pack_start(thresh_lbl, false, false, 3)
    tb.pack_start(lrow("Fire AoE rotation when creatures >=", w_spin(:aoe_threshold, saved_thresh, 2, 20)), false, false, 2)
    vb.pack_start(tf, false, false, 5)

    vb.pack_start(build_rot_frame.call(
      "Multi-Target / AoE Rotation (fires in addition to single-target when threshold is met)",
      "AoE spells go here. Fires every round alongside single-target when creature count >= threshold above.",
      [:rot_mt_1, :rot_mt_2, :rot_mt_3, :rot_mt_4]
    ), false, false, 5)
    ((@saved_config || {}).dig("spells", "aoe_rotation") || []).each_with_index do |slot, i|
      key = [:rot_mt_1, :rot_mt_2, :rot_mt_3, :rot_mt_4][i]; next unless @w[key]
      num = slot["cmd"].to_s.split.last.to_i; next unless num > 0
      idx = spell_opts.index { |o| o.start_with?("#{num} --") }
      @w[key].active = idx if idx
    end


    # ---- Bard songs are configured in the Songs tab ----------------------------

    # ---- Ranger Animal Companion ------------------------------------------------
    if prof =~ /Ranger/i
      saved_rc = (@saved_config || {})["ranger_companion"] || {}
      rcf, rcb = frame_vbox("Ranger Animal Companion (spell 630)")
      rcb.pack_start(Gtk::Label.new(
        "If you have bonded with an Animal Companion (spell 630), the script will set its behavior at hunt start\n" \
        "and optionally direct it to attack your current target each engagement.\n\n" \
        "Behavior modes:\n" \
        "  Offensive -- companion auto-attacks after you attack (no manual directive sent)\n" \
        "  Defensive -- companion guards you for +DS bonus; does not attack\n" \
        "  Neutral   -- companion is idle; script sends TELL COMPANION TO ATTACK each new target"
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

      @w[:rc_enabled] = Gtk::CheckButton.new("I have a bonded Animal Companion")
      @w[:rc_enabled].active = saved_rc.fetch("enabled", false)

      saved_type_idx = RANGER_COMPANION_TYPES.index(saved_rc["companion_type"] || "canine") || 0
      @w[:rc_type] = mk_combo_text(RANGER_COMPANION_TYPES.map(&:capitalize), saved_type_idx)

      saved_beh_idx = RANGER_COMPANION_BEHAVIORS.index(saved_rc["behavior"] || "offensive") || 0
      @w[:rc_behavior] = mk_combo_text(RANGER_COMPANION_BEHAVIORS.map(&:capitalize), saved_beh_idx)

      @w[:rc_attack] = Gtk::CheckButton.new("Direct companion to attack my target each engagement (Neutral mode only; auto in Offensive)")
      @w[:rc_attack].active = saved_rc.fetch("attack_target", true)

      @w[:rc_resummon] = Gtk::CheckButton.new("Re-summon companion if not present in room at hunt start")
      @w[:rc_resummon].active = saved_rc.fetch("resummon", true)

      rc_detail = [
        lrow("Companion type:", @w[:rc_type]),
        lrow("Behavior mode:", @w[:rc_behavior]),
        @w[:rc_attack],
        @w[:rc_resummon],
      ]
      rcb.pack_start(@w[:rc_enabled], false, false, 2)
      rc_detail.each { |r| rcb.pack_start(r, false, false, 2); r.sensitive = @w[:rc_enabled].active? }
      @w[:rc_enabled].signal_connect("toggled") { rc_detail.each { |r| r.sensitive = @w[:rc_enabled].active? } }
      vb.pack_start(rcf, false, false, 5)
    else
      @w[:rc_enabled] = @w[:rc_type] = @w[:rc_behavior] = @w[:rc_attack] = @w[:rc_resummon] = nil
    end
    # ---- end Ranger section -----------------------------------------------------

    # ---- Sorcerer Demon (Minor Summoning 725) -----------------------------------
    if prof =~ /Sorcerer/i
      saved_sd = (@saved_config || {})["sorcerer_demon"] || {}
      sdf, sdb = frame_vbox("Sorcerer Demon (Minor Summoning 725)")
      sdb.pack_start(Gtk::Label.new(
        "Demons summoned via spell 725 cannot fight, but can pick up dropped items.\n" \
        "The script can command your active demon to retrieve your weapon if it is dropped in an emergency."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

      @w[:sd_enabled] = Gtk::CheckButton.new("I keep a Minor Summoning demon active (spell 725)")
      @w[:sd_enabled].active = saved_sd.fetch("enabled", false)

      @w[:sd_fetch_weapon] = Gtk::CheckButton.new("Command demon to fetch my weapon if dropped (emergency)")
      @w[:sd_fetch_weapon].active = saved_sd.fetch("fetch_weapon", false)

      @w[:sd_weapon_noun] = Gtk::Entry.new
      @w[:sd_weapon_noun].text = saved_sd["weapon_noun"].to_s

      sd_detail = [
        @w[:sd_fetch_weapon],
        lrow("Weapon noun (e.g. sword):", @w[:sd_weapon_noun]),
      ]
      sdb.pack_start(@w[:sd_enabled], false, false, 2)
      sd_detail.each { |r| sdb.pack_start(r, false, false, 2); r.sensitive = @w[:sd_enabled].active? }
      @w[:sd_enabled].signal_connect("toggled") { sd_detail.each { |r| r.sensitive = @w[:sd_enabled].active? } }
      vb.pack_start(sdf, false, false, 5)
    else
      @w[:sd_enabled] = @w[:sd_fetch_weapon] = @w[:sd_weapon_noun] = nil
    end
    # ---- end Sorcerer section ---------------------------------------------------

    # ---- Cleric / Empath Spirit Servant (218) -----------------------------------
    if prof =~ /Cleric|Empath/i
      saved_ss2 = (@saved_config || {})["spirit_servant"] || {}
      ssf3, ssb3 = frame_vbox("Spirit Servant (spell 218)")
      ssb3.pack_start(Gtk::Label.new(
        "The Spirit Servant (spell 218) cannot fight, but can carry and retrieve items.\n" \
        "Enable below to have the script command it to fetch your weapon if it is dropped in an emergency."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

      @w[:ss2_enabled] = Gtk::CheckButton.new("I keep a Spirit Servant active (spell 218)")
      @w[:ss2_enabled].active = saved_ss2.fetch("enabled", false)

      @w[:ss2_fetch_weapon] = Gtk::CheckButton.new("Command servant to fetch my weapon if dropped (emergency)")
      @w[:ss2_fetch_weapon].active = saved_ss2.fetch("fetch_weapon", false)

      @w[:ss2_weapon_noun] = Gtk::Entry.new
      @w[:ss2_weapon_noun].text = saved_ss2["weapon_noun"].to_s

      ss2_detail = [
        @w[:ss2_fetch_weapon],
        lrow("Weapon noun (e.g. sword):", @w[:ss2_weapon_noun]),
      ]
      ssb3.pack_start(@w[:ss2_enabled], false, false, 2)
      ss2_detail.each { |r| ssb3.pack_start(r, false, false, 2); r.sensitive = @w[:ss2_enabled].active? }
      @w[:ss2_enabled].signal_connect("toggled") { ss2_detail.each { |r| r.sensitive = @w[:ss2_enabled].active? } }
      vb.pack_start(ssf3, false, false, 5)
    else
      @w[:ss2_enabled] = @w[:ss2_fetch_weapon] = @w[:ss2_weapon_noun] = nil
    end
    # ---- end Cleric/Empath section ----------------------------------------------

    scrolled(vb)
  end

  def self.rotation_add_dialog
    d = Gtk::Dialog.new("Add Rotation Step", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(500, 260)

    type_c = mk_combo_text(ROTATION_TYPES, 0)
    d.vbox.pack_start(lrow("Type:", type_c), false, false, 4)

    cmd_lbl = Gtk::Label.new("Spell # or verb:")
    cmd_lbl.xalign = 0.0
    cmd_e = Gtk::Entry.new
    cmd_row = lrow("Spell # or verb:", cmd_e)
    d.vbox.pack_start(cmd_row, false, false, 4)

    cond_c = mk_combo_text(ROTATION_CONDS, 0)
    val_sp = w_spin(:_rot_val_tmp, 50, 0, 9999)
    cond_box = mk_hbox(6)
    cond_box.pack_start(Gtk::Label.new("Condition:").tap { |l| l.xalign = 0.0 }, false, false, 0)
    cond_box.pack_start(cond_c, false, false, 0)
    cond_box.pack_start(Gtk::Label.new("N ="), false, false, 4)
    cond_box.pack_start(val_sp, false, false, 0)
    d.vbox.pack_start(cond_box, false, false, 4)

    type_c.signal_connect("changed") do
      type_key = ROTATION_TYPES[type_c.active].split.first rescue "attack"
      needs_cmd = %w[spell bolt cman].include?(type_key)
      cmd_row.visible = needs_cmd
    end

    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      type_key = ROTATION_TYPES[type_c.active].split.first rescue "attack"
      cmd_val  = cmd_e.text.strip
      cond_raw = ROTATION_CONDS[cond_c.active] rescue "always"
      cond_str = if cond_raw == "always"
        "always"
      else
        cond_raw.gsub("N", val_sp.value.to_i.to_s)
      end
      iter = @rotation_store.append
      @rotation_store.set_value(iter, 0, type_key)
      @rotation_store.set_value(iter, 1, cmd_val)
      @rotation_store.set_value(iter, 2, cond_str)
    end
    d.destroy
  end

  # Songs tab -- Bard only. Shows "not a bard" notice for other professions.
  SONG_RENEW_OPTS = ["Keep singing (auto-renew)", "Renew mode (cast then stop -- saves mana)"].freeze
  RENEW_ELIGIBLE  = [1003, 1006, 1007, 1010, 1019].freeze

  def self.pg_songs
    d    = @detected || {}
    prof = GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil
    vb   = mk_vbox(6)
    vb.border_width = 10

    unless prof =~ /Bard/i
      lbl = Gtk::Label.new("This tab is only used by Bards.\nYour detected profession is: #{prof || 'unknown'}.")
      lbl.xalign = 0.0; lbl.set_line_wrap(true)
      vb.pack_start(lbl, false, false, 8)
      return scrolled(vb)
    end

    saved_sonic = (@saved_config || {})["bard_sonic"] || {}

    # ---- Intro note ----
    intro = Gtk::Label.new(
      "The script will re-sing any enabled song automatically when it fades during hunting.\n" \
      "Renew mode: cast the song then immediately stop it. The effect persists for its full duration\n" \
      "but does not count toward your multi-song renewal cost -- useful when the renewal penalty\n" \
      "would exceed the cost of just re-singing it fresh. Eligible songs: Fortitude, Luck, Kai's Triumph, Valor, Mirrors."
    )
    intro.xalign = 0.0; intro.set_line_wrap(true)
    vb.pack_start(intro, false, false, 4)

    # ---- Sonic Equipment Songs ----
    seq_f, seq_b = frame_vbox("Sonic Equipment (weapons/armor/shield conjured by singing)")
    seq_b.pack_start(Gtk::Label.new(
      "These songs create magical gear that replaces your normal weapon or armor while active.\n" \
      "Weapon/armor settings in the Weapons and Defense tabs are overridden while sonic songs are running."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

    # Sonic Weapon (1012)
    knows_1012 = (Spell[1012].known? rescue false)
    @w[:sonic_wpn_enabled] = Gtk::CheckButton.new("Sonic Weapon Song (1012) -- conjured weapon#{knows_1012 ? '' : '  [not yet learned]'}")
    @w[:sonic_wpn_enabled].active    = knows_1012 && saved_sonic.fetch("weapon_enabled", false)
    @w[:sonic_wpn_enabled].sensitive = knows_1012
    @w[:sonic_wpn_num] = Gtk::SpinButton.new(
      Gtk::Adjustment.new((saved_sonic["weapon_spell"] || 1012).to_f, 1000.0, 1099.0, 1.0, 1.0, 0.0), 1, 0)
    saved_wpn_sing  = saved_sonic["weapon_sing"] || "longsword"
    saved_wpn_tidx  = SONIC_WPN_OPTS.index { |o| o[:sing] == saved_wpn_sing } || 0
    @w[:sonic_wpn_type] = mk_combo_text(SONIC_WPN_OPTS.map { |o| o[:label] }, saved_wpn_tidx)
    swf, swb = frame_vbox("Sonic Weapon")
    swb.pack_start(Gtk::Label.new(
      "Excluded: katana, naginata, claidhmore, all ranged weapons."
    ).tap { |l| l.xalign = 0.0 }, false, false, 2)
    swb.pack_start(@w[:sonic_wpn_enabled], false, false, 2)
    wpn_detail = [lrow("Spell #:", @w[:sonic_wpn_num]), lrow("Weapon type:", @w[:sonic_wpn_type])]
    wpn_detail.each { |r| swb.pack_start(r, false, false, 2); r.sensitive = @w[:sonic_wpn_enabled].active? }
    @w[:sonic_wpn_enabled].signal_connect("toggled") { wpn_detail.each { |r| r.sensitive = @w[:sonic_wpn_enabled].active? } }
    seq_b.pack_start(swf, false, false, 3)

    # Sonic Shield (1009)
    knows_1009 = (Spell[1009].known? rescue false)
    @w[:sonic_shld_enabled] = Gtk::CheckButton.new("Sonic Shield Song (1009) -- conjured shield#{knows_1009 ? '' : '  [not yet learned]'}")
    @w[:sonic_shld_enabled].active    = knows_1009 && saved_sonic.fetch("shield_enabled", false)
    @w[:sonic_shld_enabled].sensitive = knows_1009
    @w[:sonic_shld_num] = Gtk::SpinButton.new(
      Gtk::Adjustment.new((saved_sonic["shield_spell"] || 1009).to_f, 1000.0, 1099.0, 1.0, 1.0, 0.0), 1, 0)
    saved_shld_sing = saved_sonic["shield_sing"] || "buckler"
    saved_shld_idx  = SONIC_SHLD_OPTS.index { |o| o[:sing] == saved_shld_sing } || 0
    @w[:sonic_shld_type] = mk_combo_text(SONIC_SHLD_OPTS.map { |o| o[:label] }, saved_shld_idx)
    ssf, ssb2 = frame_vbox("Sonic Shield")
    ssb2.pack_start(@w[:sonic_shld_enabled], false, false, 2)
    shld_detail = [lrow("Spell #:", @w[:sonic_shld_num]), lrow("Shield type:", @w[:sonic_shld_type])]
    shld_detail.each { |r| ssb2.pack_start(r, false, false, 2); r.sensitive = @w[:sonic_shld_enabled].active? }
    @w[:sonic_shld_enabled].signal_connect("toggled") { shld_detail.each { |r| r.sensitive = @w[:sonic_shld_enabled].active? } }
    seq_b.pack_start(ssf, false, false, 3)

    # Sonic Armor (1014)
    knows_1014 = (Spell[1014].known? rescue false)
    @w[:sonic_arm_enabled] = Gtk::CheckButton.new("Sonic Armor Song (1014) -- conjured armor#{knows_1014 ? '' : '  [not yet learned]'}")
    @w[:sonic_arm_enabled].active    = knows_1014 && saved_sonic.fetch("armor_enabled", false)
    @w[:sonic_arm_enabled].sensitive = knows_1014
    @w[:sonic_arm_num] = Gtk::SpinButton.new(
      Gtk::Adjustment.new((saved_sonic["armor_spell"] || 1014).to_f, 1000.0, 1099.0, 1.0, 1.0, 0.0), 1, 0)
    saved_arm_idx = armor_asg_idx(saved_sonic["armor_asg"] || 0)
    @w[:sonic_arm_asg] = w_combo(:sonic_arm_asg, ARMOR_TYPES.map { |t| t[:label] }, saved_arm_idx)
    saf, sab = frame_vbox("Sonic Armor")
    sab.pack_start(@w[:sonic_arm_enabled], false, false, 2)
    arm_detail = [lrow("Spell #:", @w[:sonic_arm_num]), lrow("Armor type:", @w[:sonic_arm_asg])]
    arm_detail.each { |r| sab.pack_start(r, false, false, 2); r.sensitive = @w[:sonic_arm_enabled].active? }
    @w[:sonic_arm_enabled].signal_connect("toggled") { arm_detail.each { |r| r.sensitive = @w[:sonic_arm_enabled].active? } }
    seq_b.pack_start(saf, false, false, 3)

    # Singing Sword Song (1025)
    knows_1025 = (Spell[1025].known? rescue false)
    @w[:singing_sword_enabled] = Gtk::CheckButton.new("Singing Sword Song (1025) -- floating attacking sword#{knows_1025 ? '' : '  [not yet learned]'}")
    @w[:singing_sword_enabled].active    = knows_1025 && saved_sonic.fetch("singing_sword", false)
    @w[:singing_sword_enabled].sensitive = knows_1025
    saved_ss_sing = saved_sonic["singing_sword_type"] || "falchion"
    saved_ss_idx  = SINGING_SWORD_OPTS.index { |o| o[:sing] == saved_ss_sing } || 0
    @w[:singing_sword_type] = mk_combo_text(SINGING_SWORD_OPTS.map { |o| o[:label] }, saved_ss_idx)
    ssf2, ssb3 = frame_vbox("Singing Sword Song")
    ssb3.pack_start(Gtk::Label.new(
      "Creates a floating weapon that attacks enemies on its own. Re-sung when it fades.\n" \
      "Pick the weapon type to conjure -- the sword's damage and style varies by type."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)
    ssb3.pack_start(@w[:singing_sword_enabled], false, false, 2)
    ss_type_row = lrow("Weapon type:", @w[:singing_sword_type])
    ss_type_row.sensitive = @w[:singing_sword_enabled].active?
    ssb3.pack_start(ss_type_row, false, false, 2)
    @w[:singing_sword_enabled].signal_connect("toggled") { ss_type_row.sensitive = @w[:singing_sword_enabled].active? }
    seq_b.pack_start(ssf2, false, false, 3)

    vb.pack_start(seq_f, false, false, 5)

    # ---- Helper: build a song row with optional renew dropdown ----
    build_song_row = lambda do |parent_box, s, checked, saved_renew|
      known = (Spell[s[:num]].known? rescue false)
      hb = mk_hbox(4)
      label = known ? "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})" \
                    : "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})  [not yet learned]"
      cb = Gtk::CheckButton.new(label)
      cb.active    = known && checked
      cb.sensitive = known
      hb.pack_start(cb, true, true, 0)
      if RENEW_ELIGIBLE.include?(s[:num])
        renew_idx = saved_renew.include?(s[:num]) ? 1 : 0
        rc = mk_combo_text(SONG_RENEW_OPTS, renew_idx)
        rc.sensitive = known && cb.active?
        cb.signal_connect("toggled") { rc.sensitive = cb.active? } if known
        hb.pack_start(Gtk::Label.new("Mode:"), false, false, 4)
        hb.pack_start(rc, false, false, 0)
        [cb, rc]
      else
        [cb, nil]
      end.tap { parent_box.pack_start(hb, false, false, 2) }
    end

    # ---- Defensive Songs ----
    saved_def   = saved_sonic["defensive_songs"]  || []
    saved_renew = saved_sonic["renew_songs"]       || []
    @w[:bard_def_songs]   = {}
    @w[:bard_def_renew]   = {}
    dff, dfb = frame_vbox("Defensive Songs (kept active during hunting)")
    BARD_DEFENSIVE_SONGS.each do |s|
      cb, rc = build_song_row.call(dfb, s, saved_def.include?(s[:num]), saved_renew)
      @w[:bard_def_songs][s[:num]] = cb
      @w[:bard_def_renew][s[:num]] = rc
    end
    vb.pack_start(dff, false, false, 4)

    # ---- Utility / Support Songs ----
    saved_util = saved_sonic["utility_songs"] || []
    @w[:bard_util_songs]  = {}
    @w[:bard_util_renew]  = {}
    uf, ub = frame_vbox("Utility & Support Songs (kept active during hunting)")
    uf.pack_start(Gtk::Label.new(
      "Song of Power (1018): be aware that letting it auto-renew while low on mana can cause injuries.\n" \
      "Consider only enabling it if you have reliable mana regeneration."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3) rescue nil
    BARD_UTILITY_SONGS.each do |s|
      cb, rc = build_song_row.call(ub, s, saved_util.include?(s[:num]), saved_renew)
      @w[:bard_util_songs][s[:num]] = cb
      @w[:bard_util_renew][s[:num]] = rc
    end
    vb.pack_start(uf, false, false, 4)

    # ---- Cyclic Offensive Songs ----
    saved_cyc = saved_sonic["cyclic_songs"] || []
    @w[:bard_cyc_songs] = {}
    cf, cfb = frame_vbox("Cyclic / Offensive Songs (re-sung during combat)")
    cfb.pack_start(Gtk::Label.new(
      "Cyclic songs persist on targets and need periodic re-singing.\n" \
      "The script re-sings them between attacks when a target is present."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)
    BARD_CYCLIC_SONGS.each do |s|
      known = (Spell[s[:num]].known? rescue false)
      cb = Gtk::CheckButton.new(known ? "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})" \
                                       : "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})  [not yet learned]")
      cb.active    = known && saved_cyc.include?(s[:num])
      cb.sensitive = known
      @w[:bard_cyc_songs][s[:num]] = cb
      cfb.pack_start(cb, false, false, 2)
    end
    vb.pack_start(cf, false, false, 4)

    scrolled(vb)
  end

  def self.pg_rogue_guild
    vb = mk_vbox(8)
    vb.border_width = 10

    saved_rg = (@saved_config || {})["rogue_guild"] || {}

    # ---- Stun Maneuvers -------------------------------------------------------
    smf, smb = frame_vbox("Stun Maneuvers")
    smb.pack_start(Gtk::Label.new(
      "When you are stunned, Stun Maneuvers lets you act through it using your guild training.\n" \
      "Rank 3: Stand/recover stance.  Rank 4: Strike while stunned.  Rank 5: Slip into hiding.\n" \
      "Stamina is checked first -- the action is skipped if you would overextend."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:rg_stun_enabled] = Gtk::CheckButton.new("Use Stun Maneuvers when stunned")
    @w[:rg_stun_enabled].active = saved_rg.fetch("stun_enabled", false)

    stun_actions  = [
      "Attack (rank 4 -- strike while stunned)",
      "Hide   (rank 5 -- slip into shadows while stunned)",
      "Stand  (rank 3 -- recover stance/defense)",
    ]
    saved_act_idx = ["attack", "hide", "stand"].index(saved_rg["stun_action"] || "attack") || 0
    @w[:rg_stun_action] = mk_combo_text(stun_actions, saved_act_idx)

    saved_stamina = (saved_rg["stun_stamina"] || 10).to_f
    @w[:rg_stun_stamina] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_stamina, 0.0, 50.0, 1.0, 5.0, 0.0), 1, 0)

    rg_detail = [
      lrow("Action when stunned:", @w[:rg_stun_action]),
      lrow("Stamina cost (used for reserve check -- default 10):", @w[:rg_stun_stamina]),
    ]
    smb.pack_start(@w[:rg_stun_enabled], false, false, 3)
    rg_detail.each { |r| smb.pack_start(r, false, false, 2); r.sensitive = @w[:rg_stun_enabled].active? }
    @w[:rg_stun_enabled].signal_connect("toggled") { rg_detail.each { |r| r.sensitive = @w[:rg_stun_enabled].active? } }
    vb.pack_start(smf, false, false, 4)

    # ---- Silent Strike --------------------------------------------------------
    ssf, ssb = frame_vbox("Silent Strike  (FEAT SILENTSTRIKE)")
    ssb.pack_start(Gtk::Label.new(
      "Attack from the shadows using your rogue stealth training (requires level 25+, rank 1-5).\n" \
      "Costs 20 stamina. Must be hidden before firing -- the script will hide you first if needed.\n" \
      "On success the feat automatically re-hides you. Waylay is the most popular modifier:\n" \
      "it stuns the target, letting you follow up with a normal attack while they reel."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:rg_ss_enabled] = Gtk::CheckButton.new("Use Silent Strike instead of normal melee attack")
    @w[:rg_ss_enabled].active = saved_rg.fetch("ss_enabled", false)

    ss_modifiers = ["(none)", "waylay", "jab", "grapple", "punch", "kick"]
    saved_ss_mod_idx = ss_modifiers.index(saved_rg["ss_modifier"] || "(none)") || 0
    @w[:rg_ss_modifier] = mk_combo_text(ss_modifiers, saved_ss_mod_idx)

    ss_hide_methods = ["HIDE (standard)", "Vanish (CMAN -- hide in combat without penalty)"]
    saved_ss_hide_idx = ["hide", "vanish"].index(saved_rg["ss_hide_method"] || "hide") || 0
    @w[:rg_ss_hide_method] = mk_combo_text(ss_hide_methods, saved_ss_hide_idx)

    ss_detail = [
      lrow("Attack modifier:", @w[:rg_ss_modifier]),
      lrow("Hide method (if not already hidden):", @w[:rg_ss_hide_method]),
    ]
    ssb.pack_start(@w[:rg_ss_enabled], false, false, 3)
    ss_detail.each { |r| ssb.pack_start(r, false, false, 2); r.sensitive = @w[:rg_ss_enabled].active? }
    @w[:rg_ss_enabled].signal_connect("toggled") { ss_detail.each { |r| r.sensitive = @w[:rg_ss_enabled].active? } }
    vb.pack_start(ssf, false, false, 4)

    scrolled(vb)
  end

  # ---------------------------------------------------------------------------
  # Warrior Guild tab
  # ---------------------------------------------------------------------------
  # Maps guild checkbox widget keys to CMAN name patterns that share the same ability.
  # When a guild control is enabled, matching CMAN rows are grayed (and vice versa).
  WG_CMAN_OVERLAPS = {
    wg_berserk_enabled: /\bberserk\b/i,
    wg_feint_enabled:   /\bfeint\b/i,
  }.freeze

  WG_WARCRIES = [
    { key: "bellow",  rank: 1,  cmd: "bertrandt",  type: :offensive,  stamina_single: 10, stamina_aoe: 20, desc: "Bertrandt's Bellow -- Stagger target(s)" },
    { key: "growl",   rank: 30, cmd: "gerrelle",   type: :offensive,  stamina_single: 7,  stamina_aoe: 14, desc: "Gerrelle's Growl -- Force offensive stance + Demoralize" },
    { key: "cry",     rank: 50, cmd: "carn",        type: :offensive,  stamina_single: 15, stamina_aoe: 30, desc: "Carn's Cry -- Terrify and immobilize target(s)" },
    { key: "yowlp",   rank: 20, cmd: "yertie",      type: :supporting, stamina_single: 10, stamina_aoe: nil, desc: "Yertie's Yowlp -- Bolster party defense (rank 20)" },
    { key: "shout",   rank: 40, cmd: "seanette",    type: :supporting, stamina_single: 25, stamina_aoe: nil, desc: "Seanette's Shout -- Grant +20 AS to party (rank 40)" },
    { key: "holler",  rank: 60, cmd: "horland",     type: :supporting, stamina_single: 0,  stamina_aoe: nil, desc: "Horland's Holler -- Room taunt + Boost Health (rank 60)" },
  ].freeze

  WG_TRICK_LOCS = %w[chest back neck head right_arm left_arm right_hand left_hand right_leg left_leg].freeze

  # Lock/unlock CMAN store rows whose name matches pat.
  # locked=true grays and blocks them; locked=false restores them.
  def self.cman_set_row_lock(pat, locked)
    return unless @cman_store
    @cman_store.each do |_m, _p, it|
      if @cman_store.get_value(it, 1).to_s =~ pat
        @cman_store.set_value(it, 7, !locked)
      end
    end
  end

  # Set each guild overlap checkbox sensitive/insensitive based on whether
  # a matching enabled CMAN row exists (called after cman_store is populated).
  def self.refresh_guild_from_cman
    return unless @cman_store
    WG_CMAN_OVERLAPS.each do |wk, pat|
      cman_active = false
      @cman_store.each { |_m, _p, it| cman_active = true if @cman_store.get_value(it, 0) && @cman_store.get_value(it, 1).to_s =~ pat }
      @w[wk]&.sensitive = !cman_active
    end
  end

  def self.pg_warrior_guild
    vb = mk_vbox(8)
    vb.border_width = 10
    saved_wg = (@saved_config || {})["warrior_guild"] || {}

    # ---- Berserk --------------------------------------------------------------
    bsf, bsb = frame_vbox("Berserk")
    bsb.pack_start(Gtk::Label.new(
      "Enter a berserker rage, attacking every 5 seconds until stopped.\n" \
      "Costs 20 stamina to enter, then 10/round. While berserking the script suspends\n" \
      "normal attacks -- berserk handles combat automatically. Use the round limit to\n" \
      "auto-stop after N rounds (0 = keep going until no targets remain)."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:wg_berserk_enabled] = Gtk::CheckButton.new("Use Berserk in combat")
    @w[:wg_berserk_enabled].active = saved_wg.fetch("berserk_enabled", false)

    saved_bs_stam  = (saved_wg["berserk_stamina_min"] || 30).to_f
    saved_bs_rounds = (saved_wg["berserk_max_rounds"] || 0).to_f
    @w[:wg_berserk_stamina] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_bs_stam, 0.0, 100.0, 1.0, 5.0, 0.0), 1, 0)
    @w[:wg_berserk_rounds] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_bs_rounds, 0.0, 60.0, 1.0, 5.0, 0.0), 1, 0)

    bs_detail = [
      lrow("Minimum stamina before entering berserk:", @w[:wg_berserk_stamina]),
      lrow("Max rounds before auto-stopping (0 = unlimited):", @w[:wg_berserk_rounds]),
    ]
    bsb.pack_start(@w[:wg_berserk_enabled], false, false, 3)
    bs_detail.each { |r| bsb.pack_start(r, false, false, 2); r.sensitive = @w[:wg_berserk_enabled].active? }
    @w[:wg_berserk_enabled].signal_connect("toggled") do
      bs_detail.each { |r| r.sensitive = @w[:wg_berserk_enabled].active? }
      cman_set_row_lock(WG_CMAN_OVERLAPS[:wg_berserk_enabled], @w[:wg_berserk_enabled].active?)
    end
    vb.pack_start(bsf, false, false, 4)

    # ---- War Cries ------------------------------------------------------------
    wcf, wcb = frame_vbox("War Cries  (WARCRY command)")
    wcb.pack_start(Gtk::Label.new(
      "War Cries fire before each attack. Offensive cries target the current enemy.\n" \
      "Supporting cries bolster your party (fired when the buff is not already active).\n" \
      "Stamina is checked against your reserve before each cry fires."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:wg_warcry] = {}
    @w[:wg_warcry_aoe] = {}

    [[:offensive, "Offensive Cries"], [:supporting, "Supporting Cries"]].each do |cry_type, label|
      sub_f, sub_b = frame_vbox(label)
      WG_WARCRIES.select { |c| c[:type] == cry_type }.each do |cry|
        saved_cry = (saved_wg.dig("warcries", cry[:key]) || {})
        cb = Gtk::CheckButton.new(cry[:desc])
        cb.active = saved_cry.fetch("enabled", false)
        @w[:wg_warcry][cry[:key]] = cb
        row_widgets = [cb]

        if cry[:stamina_aoe]
          aoe_cb = Gtk::CheckButton.new("AoE")
          aoe_cb.active = saved_cry.fetch("aoe", false)
          aoe_cb.sensitive = cb.active?
          @w[:wg_warcry_aoe][cry[:key]] = aoe_cb
          hb = mk_hbox(6)
          hb.pack_start(cb, true, true, 0)
          hb.pack_start(aoe_cb, false, false, 0)
          sub_b.pack_start(hb, false, false, 2)
          cb.signal_connect("toggled") { aoe_cb.sensitive = cb.active? }
        else
          sub_b.pack_start(cb, false, false, 2)
        end
      end
      wcb.pack_start(sub_f, false, false, 4)
    end
    vb.pack_start(wcf, false, false, 4)

    # ---- Warrior Tricks (combat) -----------------------------------------------
    wtf, wtb = frame_vbox("Warrior Tricks (Combat)")
    wtb.pack_start(Gtk::Label.new(
      "FEINT (rank 10 via guild): create an opening before attacking (uses WTRICK FEINT).\n" \
      "SPIT (rank 8): targeted attack at a specific body location.\n" \
      "If Feint or Berserk also appear in Combat Abilities, enabling one side will gray\n" \
      "out the other to prevent double-firing. Disable the grayed one to switch sources."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    saved_feint = saved_wg.fetch("feint_enabled", false)
    @w[:wg_feint_enabled] = Gtk::CheckButton.new("Use FEINT before attacking -- guild version (WTRICK FEINT)")
    @w[:wg_feint_enabled].active = saved_feint
    @w[:wg_feint_enabled].signal_connect("toggled") do
      cman_set_row_lock(WG_CMAN_OVERLAPS[:wg_feint_enabled], @w[:wg_feint_enabled].active?)
    end

    saved_spit  = saved_wg.fetch("spit_enabled", false)
    saved_spit_loc_idx = WG_TRICK_LOCS.index(saved_wg["spit_location"] || "chest") || 0
    @w[:wg_spit_enabled] = Gtk::CheckButton.new("Use SPIT attack (rank 8 required)")
    @w[:wg_spit_enabled].active = saved_spit
    @w[:wg_spit_loc] = mk_combo_text(WG_TRICK_LOCS, saved_spit_loc_idx)

    spit_detail = [ lrow("Target location:", @w[:wg_spit_loc]) ]
    spit_detail.each { |r| r.sensitive = @w[:wg_spit_enabled].active? }
    @w[:wg_spit_enabled].signal_connect("toggled") { spit_detail.each { |r| r.sensitive = @w[:wg_spit_enabled].active? } }

    wtb.pack_start(@w[:wg_feint_enabled], false, false, 3)
    wtb.pack_start(@w[:wg_spit_enabled],  false, false, 3)
    spit_detail.each { |r| wtb.pack_start(r, false, false, 2) }
    vb.pack_start(wtf, false, false, 4)

    # Apply initial guild checkbox sensitivity based on current CMAN store state.
    # (pg_combat_abilities runs first so the store is already populated.)
    Gtk.queue { refresh_guild_from_cman }

    # ---- Note about CMAN-overlap abilities ------------------------------------
    nf = Gtk::Frame.new("Disarm Weapon & Tackle")
    nb2 = mk_vbox(4)
    nb2.border_width = 8
    nb2.pack_start(Gtk::Label.new(
      "Disarm Weapon and Tackle are learnable through both the Warrior Guild AND\n" \
      "Combat Maneuver points. Because the command is identical either way, configure them\n" \
      "in the Combat Abilities tab where all CMANs are managed."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 0)
    nf.add(nb2)
    vb.pack_start(nf, false, false, 4)

    scrolled(vb)
  end

  def self.pg_combat_abilities
    d  = @detected || {}
    vb = mk_vbox(8)
    vb.border_width = 10

    cm_professions = %w[Warrior Rogue Monk Paladin Ranger Bard]
    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""
    has_cm_prof    = cm_professions.any? { |p| prof =~ /#{p}/i }
    has_cm_data    = Array(d[:feats]).any? { |f| !(f.is_a?(Hash) ? f[:passive] : false) }
    has_saved_cm   = (@saved_config || {}).fetch("cmans", []).any?
    show_cmans     = has_cm_prof && (has_cm_data || has_saved_cm)

    # ---- CMANs & Feats -------------------------------------------------------
    if !show_cmans
      cf = Gtk::Frame.new("CMANs & Feats")
      msg = has_cm_prof ?
        "No Combat Maneuvers detected yet -- this section will appear once you train a CM.\nProfessions with CM lists: #{cm_professions.join(', ')}." :
        "#{prof.empty? ? 'This profession' : prof} does not have a Combat Maneuver list.\nProfessions with CM lists: #{cm_professions.join(', ')}."
      cf.add(Gtk::Label.new(msg).tap { |l| l.xalign = 0.0; l.wrap = true })
      @cman_store = nil
      vb.pack_start(cf, false, false, 0)
    else
    cf, cb = frame_vbox("CMANs & Feats")
    hint1 = Gtk::Label.new(
      "Active feats default to type 'attack' -- change to 'aoe', 'maintenance', or 'emergency' as needed.\n" \
      "Set Daily Limit to 1-3 for abilities with limited daily uses (0 = unlimited).\n" \
      "#TARGET in verb is replaced with the enemy ID at runtime."
    )
    hint1.xalign = 0.0; hint1.set_line_wrap(true)
    cb.pack_start(hint1, false, false, 3)

    # cols: enabled(bool), name, verb, type, stamina, cd, daily_limit
    # type values: attack, aoe, maintenance, emergency (passive feats shown separately below)
    # cols: 0=enabled, 1=name, 2=verb, 3=type, 4=stamina, 5=cd, 6=daily_limit, 7=row_sensitive, 8=grip
    @cman_store = Gtk::ListStore.new(TrueClass, String, String, String, String, String, String, TrueClass, String)

    passive_names = []
    Array(d[:feats]).each do |feat|
      name    = feat.is_a?(Hash) ? feat[:name].to_s    : feat.to_s
      stamina = feat.is_a?(Hash) ? feat[:stamina].to_i : 0
      cd      = feat.is_a?(Hash) ? feat[:cd].to_i      : 0
      is_pass = feat.is_a?(Hash) ? feat[:passive]       : false
      saved   = (@profile["cmans"] || []).find { |c| c["name"].to_s.casecmp(name) == 0 }
      # Passive check: hardcoded list takes priority, then auto-detect, then saved type
      name_lc = name.downcase
      is_known_passive = PASSIVE_CMANS.include?(name_lc) ||
                         PASSIVE_CMAN_PREFIXES.any? { |pre| name_lc.start_with?(pre) }
      if is_known_passive || is_pass || (saved && saved["type"].to_s == "passive")
        passive_names << name
        next
      end
      iter = @cman_store.append
      @cman_store.set_value(iter, 0, saved ? saved["enabled"] != false : true)
      @cman_store.set_value(iter, 1, name)
      @cman_store.set_value(iter, 2, saved ? saved["verb"].to_s    : "feat #{name.downcase}")
      @cman_store.set_value(iter, 3, saved ? saved["type"].to_s    : "attack")
      @cman_store.set_value(iter, 4, saved ? saved["stamina"].to_s    : stamina.to_s)
      @cman_store.set_value(iter, 5, saved ? saved["cd"].to_s         : cd.to_s)
      @cman_store.set_value(iter, 6, saved ? saved["daily_limit"].to_s : "0")
      @cman_store.set_value(iter, 7, true)
      @cman_store.set_value(iter, 8, saved ? saved["grip"].to_s : "")
    end

    # Apply initial lock state: if a guild checkbox is already enabled, gray matching rows.
    # This handles the case where the user opens the UI with saved guild settings active.
    WG_CMAN_OVERLAPS.each do |wk, pat|
      cman_set_row_lock(pat, true) if @w[wk]&.active?
    end

    cman_tv = Gtk::TreeView.new(@cman_store)
    # Toggle column -- col 7 (row_sensitive) guards both toggling and graying
    tog_r = Gtk::CellRendererToggle.new
    tog_r.activatable = true
    tog_r.signal_connect("toggled") do |_, path|
      it = @cman_store.get_iter(path)
      next unless it && @cman_store.get_value(it, 7)  # ignore clicks on locked rows
      new_val  = !@cman_store.get_value(it, 0)
      row_name = @cman_store.get_value(it, 1).to_s
      @cman_store.set_value(it, 0, new_val)
      # If this row matches a guild overlap, gray/restore the guild checkbox
      WG_CMAN_OVERLAPS.each do |wk, pat|
        next unless row_name =~ pat
        @w[wk]&.sensitive = !new_val
      end
    end
    cman_tv.append_column(Gtk::TreeViewColumn.new("Use", tog_r, "active" => 0, "sensitive" => 7))
    [["Name", 1], ["Verb", 2], ["Type (passive/attack/aoe/maintenance/emergency)", 3], ["Stamina", 4], ["CD(s)", 5], ["Daily Limit (0=none)", 6], ["Grip (one/two/blank)", 8]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @cman_store.get_iter(path); @cman_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i, "sensitive" => 7); c.resizable = true
      cman_tv.append_column(c)
    end
    @w[:cman_tv] = cman_tv

    cman_sw = Gtk::ScrolledWindow.new
    cman_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    cman_sw.add(cman_tv); cman_sw.set_size_request(-1, 150)
    cb.pack_start(cman_sw, true, true, 0)

    cman_btns = mk_hbox(6)
    cman_add = Gtk::Button.new("Add")
    cman_rem = Gtk::Button.new("Remove Selected")
    cman_add.signal_connect("clicked") { cman_add_dialog }
    cman_rem.signal_connect("clicked") { sel = cman_tv.selection.selected; @cman_store.remove(sel) if sel }
    cman_btns.pack_start(cman_add, false, false, 0)
    cman_btns.pack_start(cman_rem, false, false, 0)
    cb.pack_start(cman_btns, false, false, 3)

    unless passive_names.empty?
      pass_lbl = Gtk::Label.new("Always-on passive feats (no activation needed): #{passive_names.join(', ')}")
      pass_lbl.xalign = 0.0
      pass_lbl.set_line_wrap(true)
      cb.pack_start(pass_lbl, false, false, 4)
    end

    vb.pack_start(cf, true, true, 0)
    end # show_cmans

    # ---- Weapon Techniques ---------------------------------------------------
    has_saved_tech = (@saved_config || {}).fetch("techniques", []).any?
    has_any_tech   = Array(d[:techniques]).any? || has_saved_tech
    if !has_any_tech
      tf = Gtk::Frame.new("Weapon Techniques")
      tf.add(Gtk::Label.new("No weapon techniques trained yet -- this section will appear once you train one.").tap { |l| l.xalign = 0.0; l.wrap = true })
      @tech_store = nil
      vb.pack_start(tf, false, false, 0)
    else
    tf, tb = frame_vbox("Weapon Techniques")
    hint2 = Gtk::Label.new(
      "Check techniques you want the script to use. Assault and AoE default to checked; Reaction and Setup default to unchecked.\n" \
      "Grip: set to 'one' or 'two' if this technique requires a specific grip (e.g. Flurry on a katana trained 1HE needs 'one'). Leave blank if no grip switch is needed.\n" \
      "Reaction techniques fire instantly when the game signals the opportunity."
    )
    hint2.xalign = 0.0; hint2.set_line_wrap(true)
    tb.pack_start(hint2, false, false, 3)

    # cols: 0=enabled, 1=name, 2=verb, 3=tech_type, 4=trigger, 5=stamina,
    #        6=min_creatures, 7=min_rank, 8=grip, 9=mnemonic, 10=ranks, 11=category
    @tech_store = Gtk::ListStore.new(TrueClass, String, String, String, String, String, String, String, String, String, String, String)

    saved_techs    = (@saved_config || {}).fetch("techniques", nil)
    saved_tech_map = saved_techs&.each_with_object({}) { |t, h| h[t["name"].to_s.downcase] = t }

    Array(d[:techniques]).each do |tech|
      name          = tech.is_a?(Hash) ? tech[:name]          : tech.to_s
      tech_type     = tech.is_a?(Hash) ? tech[:tech_type]     : "unknown"
      verb          = tech.is_a?(Hash) ? tech[:verb]          : "weapon #{name.downcase.gsub(/\s+/, '')}"
      min_creatures = tech.is_a?(Hash) ? tech[:min_creatures] : (tech_type == "aoe" ? 3 : 1)
      mnemonic      = tech.is_a?(Hash) ? tech[:mnemonic].to_s : ""
      known_rank    = WEAPON_TECH_KNOWN[mnemonic]&.dig(:rank)
      min_rank      = tech.is_a?(Hash) ? (tech[:min_rank] || known_rank || "?").to_s : "?"
      ranks         = tech.is_a?(Hash) ? tech[:ranks].to_s    : ""
      category      = tech.is_a?(Hash) ? tech[:category].to_s : ""
      saved         = saved_tech_map&.delete(name.downcase)
      enabled       = saved ? saved["enabled"] != false : %w[assault aoe].include?(tech_type)
      trigger       = saved ? saved.fetch("trigger", "").to_s    : ""
      stamina       = saved ? saved.fetch("stamina", 0).to_s     : "0"
      min_creatures = saved ? saved.fetch("min_creatures", min_creatures).to_s : min_creatures.to_s
      min_rank      = saved ? saved.fetch("min_rank", min_rank).to_s : min_rank
      iter = @tech_store.append
      @tech_store.set_value(iter, 0, enabled)
      @tech_store.set_value(iter, 1, name)
      @tech_store.set_value(iter, 2, verb)
      @tech_store.set_value(iter, 3, tech_type)
      @tech_store.set_value(iter, 4, trigger)
      @tech_store.set_value(iter, 5, stamina)
      @tech_store.set_value(iter, 6, min_creatures)
      @tech_store.set_value(iter, 7, min_rank)
      default_grip = category =~ /two.hand|polearm/i ? "two" : "one"
      saved_grip   = saved ? saved.fetch("grip", nil).to_s : ""
      saved_grip   = default_grip if saved_grip.empty?
      @tech_store.set_value(iter, 8, saved_grip)
      @tech_store.set_value(iter, 9,  mnemonic)
      @tech_store.set_value(iter, 10, ranks)
      @tech_store.set_value(iter, 11, category)
    end

    # Re-add any user-added techniques that weren't in the detected list
    saved_tech_map&.each_value do |saved|
      next unless saved["name"].to_s =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/ && saved["name"].to_s.length >= 3
      mnemonic     = saved["mnemonic"].to_s
      saved_cat    = saved.fetch("category", "").to_s
      saved_dgflt  = saved_cat =~ /two.hand|polearm/i ? "two" : "one"
      saved_grip   = saved.fetch("grip", nil).to_s
      saved_grip   = saved_dgflt if saved_grip.empty?
      iter = @tech_store.append
      @tech_store.set_value(iter, 0, saved["enabled"] != false)
      @tech_store.set_value(iter, 1, saved["name"].to_s)
      @tech_store.set_value(iter, 2, saved["verb"].to_s)
      @tech_store.set_value(iter, 3, saved["tech_type"].to_s)
      @tech_store.set_value(iter, 4, saved.fetch("trigger", "").to_s)
      @tech_store.set_value(iter, 5, saved.fetch("stamina", 0).to_s)
      @tech_store.set_value(iter, 6, saved.fetch("min_creatures", 1).to_s)
      @tech_store.set_value(iter, 7, saved.fetch("min_rank", "?").to_s)
      @tech_store.set_value(iter, 8, saved_grip)
      @tech_store.set_value(iter, 9,  mnemonic)
      @tech_store.set_value(iter, 10, saved.fetch("ranks", "").to_s)
      @tech_store.set_value(iter, 11, saved_cat)
    end

    tech_tv = Gtk::TreeView.new(@tech_store)
    tog_r2 = Gtk::CellRendererToggle.new
    tog_r2.activatable = true
    tog_r2.signal_connect("toggled") do |_, path|
      it = @tech_store.get_iter(path)
      @tech_store.set_value(it, 0, !@tech_store.get_value(it, 0)) if it
    end
    tech_tv.append_column(Gtk::TreeViewColumn.new("Use", tog_r2, "active" => 0))
    # Read-only display columns matching game output
    [["Skill", 1], ["Mnemonic", 9], ["Ranks", 10], ["Type", 3], ["Category", 11]].each do |col, i|
      r = Gtk::CellRendererText.new
      c = Gtk::TreeViewColumn.new(col, r, "text" => i); c.resizable = true
      tech_tv.append_column(c)
    end
    # Grip is the only user-editable column
    grip_r = Gtk::CellRendererText.new; grip_r.editable = true
    grip_r.signal_connect("edited") { |_, path, val| it = @tech_store.get_iter(path); @tech_store.set_value(it, 8, val.strip.downcase) if it }
    grip_col = Gtk::TreeViewColumn.new("Grip (one/two)", grip_r, "text" => 8); grip_col.resizable = true
    tech_tv.append_column(grip_col)
    @w[:tech_tv] = tech_tv

    tech_sw = Gtk::ScrolledWindow.new
    tech_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    tech_sw.add(tech_tv); tech_sw.set_size_request(-1, 130)
    tb.pack_start(tech_sw, true, true, 0)

    tech_btns = mk_hbox(6)
    tech_add = Gtk::Button.new("Add")
    tech_rem = Gtk::Button.new("Remove Selected")
    tech_add.signal_connect("clicked") { tech_add_dialog }
    tech_rem.signal_connect("clicked") { sel = tech_tv.selection.selected; @tech_store.remove(sel) if sel }
    tech_btns.pack_start(tech_add, false, false, 0)
    tech_btns.pack_start(tech_rem, false, false, 0)
    tb.pack_start(tech_btns, false, false, 3)
    vb.pack_start(tf, true, true, 0)
    end # has_any_tech

    scrolled(vb)
  end

  def self.cman_add_dialog
    d = Gtk::Dialog.new("Add CMAN / Feat", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(460, 320)
    fields = {}
    [
      ["Name (e.g. Chastise):",              :name,    ""],
      ["Verb (e.g. feat chastise):",          :verb,    "feat "],
      ["Type (attack/aoe/maintenance):",      :type,    "attack"],
      ["Stamina cost:",                       :stamina, "0"],
      ["CD in seconds (0 = no CD):",          :cd,      "0"],
    ].each do |lbl, key, dv|
      e = Gtk::Entry.new; e.text = dv; fields[key] = e
      d.vbox.pack_start(lrow(lbl, e), false, false, 3)
    end
    grip_combo = mk_combo_text(["(none -- keep current grip)", "one (GRIP ONE before firing)", "two (GRIP TWO before firing)"], 0)
    fields[:grip] = grip_combo
    d.vbox.pack_start(lrow("Grip required:", grip_combo), false, false, 3)
    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      grip_val = ["", "one", "two"][grip_combo.active] || ""
      iter = @cman_store.append
      @cman_store.set_value(iter, 0, true)
      @cman_store.set_value(iter, 1, fields[:name].text.strip)
      @cman_store.set_value(iter, 2, fields[:verb].text.strip)
      @cman_store.set_value(iter, 3, fields[:type].text.strip.downcase)
      @cman_store.set_value(iter, 4, fields[:stamina].text.strip)
      @cman_store.set_value(iter, 5, fields[:cd].text.strip)
      @cman_store.set_value(iter, 6, "0")
      name_added = fields[:name].text.strip
      locked = WG_CMAN_OVERLAPS.any? { |wk, pat| name_added =~ pat && @w[wk]&.active? }
      @cman_store.set_value(iter, 7, !locked)
      @cman_store.set_value(iter, 8, grip_val)
    end
    d.destroy
  end

  def self.tech_add_dialog
    d = Gtk::Dialog.new("Add Technique", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(460, 240)
    fields = {}
    [
      ["Name (e.g. Overpower):",                           :name,      ""],
      ["Mnemonic (e.g. overpower):",                       :mnemonic,  ""],
      ["Type (assault/aoe/reaction/concentration/setup):", :tech_type, "assault"],
    ].each do |lbl, key, dv|
      e = Gtk::Entry.new; e.text = dv; fields[key] = e
      d.vbox.pack_start(lrow(lbl, e), false, false, 3)
    end
    grip_combo = mk_combo_text(["(none -- keep current grip)", "one (GRIP ONE before firing)", "two (GRIP TWO before firing)"], 0)
    fields[:grip] = grip_combo
    d.vbox.pack_start(lrow("Grip required:", grip_combo), false, false, 3)
    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      grip_val  = ["", "one", "two"][grip_combo.active] || ""
      name      = fields[:name].text.strip
      mnemonic  = fields[:mnemonic].text.strip.downcase
      tech_type = fields[:tech_type].text.strip.downcase
      verb      = mnemonic.empty? ? "weapon #{name.downcase.gsub(/\s+/, '')}" : "weapon #{mnemonic}"
      known     = WEAPON_TECH_KNOWN[mnemonic]
      min_creat = (tech_type == "aoe" ? 3 : 1).to_s
      iter = @tech_store.append
      @tech_store.set_value(iter, 0, false)
      @tech_store.set_value(iter, 1, name)
      @tech_store.set_value(iter, 2, verb)
      @tech_store.set_value(iter, 3, tech_type)
      @tech_store.set_value(iter, 4, "")
      @tech_store.set_value(iter, 5, "0")
      @tech_store.set_value(iter, 6, min_creat)
      @tech_store.set_value(iter, 7, known ? known[:rank].to_s : "?")
      @tech_store.set_value(iter, 8, grip_val)
      @tech_store.set_value(iter, 9,  mnemonic)
      @tech_store.set_value(iter, 10, "")
      @tech_store.set_value(iter, 11, "")
    end
    d.destroy
  end

  def self.pg_arcarium
    d   = @detected || {}
    vb  = mk_vbox(6)
    vb.border_width = 10
    hint = Gtk::Label.new(
      "Script analyzes each arcarium before activating -- only prods if currently inert.\n" \
      "Aversaris = offensive (attack boost). Vangaris = defensive (protection)."
    )
    hint.xalign = 0.0
    hint.set_line_wrap(true)
    vb.pack_start(hint, false, false, 5)

    build_arcarium_frame(vb, :aversaris, d[:aversaris], d[:aversaris_vissi])
    build_arcarium_frame(vb, :vangaris,  d[:vangaris],  d[:vangaris_vissi])

    scrolled(vb)
  end

  def self.build_arcarium_frame(container, key, item, vissi_list)
    label        = key == :aversaris ? "Aversaris Arcarium (offensive)" : "Vangaris Arcarium (defensive)"
    noun_default = "#{key} arcarium"
    af, ab = frame_vbox(label)

    if item
      dl = Gtk::Label.new("Detected in inventory: #{item.name}")
      dl.xalign = 0.0
      ab.pack_start(dl, false, false, 2)
    end

    enabled_cb = w_check(:"#{key}_enabled", "I have a #{key} arcarium", !item.nil?)
    ab.pack_start(enabled_cb, false, false, 3)
    add_row(ab, "Noun:", w_entry(:"#{key}_noun", noun_default))

    hint = Gtk::Label.new("")
    hint.xalign = 0.0; hint.set_line_wrap(true)
    hint.set_markup(
      "All vissi with activator verbs are listed. Passive (no-verb) vissi are excluded.\n" \
      "<b>Click the \"When\" cell to choose when each vissi fires:</b>\n" \
      "  <b>engagement</b> = once per fight start    <b>aoe</b> = multiple foes present\n" \
      "  <b>emergency</b> = low HP or stunned/webbed    <b>maintenance</b> = always (every loop)\n" \
      "  <b>skip</b> = disabled\n" \
      "<i>Note: vissi with a daily limit are always treated as emergency-only regardless of this setting.</i>"
    )
    ab.pack_start(hint, false, false, 3)

    # Per-vissi table: enabled, name, verb, when, daily_limit, cooldown_secs
    saved_vissi = ((@saved_config || {}).dig("arcarium", key.to_s, "vissi") || [])
                    .map { |v| [v["name"], v] }.to_h

    store_key = :"#{key}_vissi_store"
    @w[store_key] = Gtk::ListStore.new(TrueClass, String, String, String, String, String)
    store = @w[store_key]

    Array(vissi_list).each do |v|
      saved = saved_vissi[v[:name]]
      iter  = store.append
      store.set_value(iter, 0, saved ? (saved["enabled"] || false) : true)
      store.set_value(iter, 1, v[:name].to_s)
      store.set_value(iter, 2, saved ? (saved["verb"] || v[:verb].to_s) : v[:verb].to_s)
      store.set_value(iter, 3, saved ? (saved["when"] || "engagement") : "engagement")
      store.set_value(iter, 4, (saved ? saved["daily_limit"] : v[:daily_limit]).to_s)
      store.set_value(iter, 5, (saved ? saved["cooldown_secs"] : v[:cooldown_secs]).to_s)
    end
    # Restore any saved vissi not in current detection
    saved_vissi.each do |name, sv|
      next if Array(vissi_list).any? { |v| v[:name] == name }
      iter = store.append
      store.set_value(iter, 0, sv["enabled"] || false)
      store.set_value(iter, 1, sv["name"].to_s)
      store.set_value(iter, 2, sv["verb"].to_s)
      store.set_value(iter, 3, sv["when"] || "engagement")
      store.set_value(iter, 4, sv["daily_limit"].to_s)
      store.set_value(iter, 5, sv["cooldown_secs"].to_s)
    end

    tv = Gtk::TreeView.new(store)
    tog = Gtk::CellRendererToggle.new; tog.activatable = true
    tog.signal_connect("toggled") { |_, path| it = store.get_iter(path); store.set_value(it, 0, !store.get_value(it, 0)) if it }
    tv.append_column(Gtk::TreeViewColumn.new("Use", tog, "active" => 0))

    # Editable text columns
    [["Name", 1], ["Verb", 2], ["Daily Limit", 4], ["CD (secs)", 5]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = store.get_iter(path); store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i); c.resizable = true
      tv.append_column(c)
    end

    # "When" column -- dropdown combo
    when_r = Gtk::CellRendererCombo.new
    when_r.editable = true
    when_r.has_entry = false
    when_model = Gtk::ListStore.new(String)
    VISSI_WHEN_OPTS.each { |o| when_model.append.set_value(0, o) }
    when_r.model = when_model
    when_r.text_column = 0
    when_r.signal_connect("changed") { |_, path, new_iter| it = store.get_iter(path); store.set_value(it, 3, when_model.get_value(new_iter, 0)) if it }
    tv.append_column(Gtk::TreeViewColumn.new("When (click to change)", when_r, "text" => 3))

    sw = Gtk::ScrolledWindow.new
    sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    sw.add(tv); sw.set_size_request(-1, 140)
    ab.pack_start(sw, true, true, 0)

    if Array(vissi_list).empty? && saved_vissi.empty?
      ab.pack_start(Gtk::Label.new("No vissi with activators detected. Run setup while arcarium is in inventory.").tap { |l| l.xalign = 0.0 }, false, false, 3)
    end

    container.pack_start(af, false, false, 5)
  end

  def self.pg_hunting
    vb = mk_vbox(6)
    vb.border_width = 10
    saved_maint_only = (@saved_config || {}).dig("hunting", "maintenance_only") || false
    mo_cb = w_check(:maintenance_only, "Maintenance-only mode (no attack rotation -- upkeep, songs, and society only)", saved_maint_only)
    vb.pack_start(mo_cb, false, false, 3)
    vb.pack_start(Gtk::Label.new(
      "Use this if you want to hunt manually and only have the script handle spell/song upkeep,\n" \
      "society abilities, and companion maintenance. All targeting and attack rotation is disabled."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 2)
    vb.pack_start(mk_hsep, false, false, 4)
    vb.pack_start(w_check(:use_eloot, "Use ;eloot for automatic looting (recommended)", (@saved_config || {}).dig("hunting", "use_eloot") != false), false, false, 3)
    saved_retreat_pct = (@saved_config || {}).dig("hunting", "health_retreat_pct") || 35
    saved_return_pct  = (@saved_config || {}).dig("hunting", "health_return_pct")  || 65
    # Clamp in case an old profile had the values backwards
    saved_return_pct  = [saved_return_pct, saved_retreat_pct + 5].max
    add_row(vb, "Retreat when health below %:",        w_spin(:health_retreat_pct, saved_retreat_pct, 5, 90))
    add_row(vb, "Resume hunting when health above %:", w_spin(:health_return_pct,  saved_return_pct,  5, 100))
    # Retreat action (health low or on death)
    saved_death_action = (@saved_config || {}).dig("hunting", "death_action") || "retreat"
    death_opts = ["Retreat to safe room via go2", "Use Symbol of Return (Voln)", "Stop the script entirely"]
    death_idx  = { "retreat" => 0, "symbol_of_return" => 1, "stop" => 2 }.fetch(saved_death_action, 0)
    retreat_combo = w_combo(:death_action, death_opts, death_idx)
    add_row(vb, "When health is low or on death:", retreat_combo)

    saved_retreat_room = (@saved_config || {}).dig("hunting", "retreat_room")&.to_s || ""
    retreat_room_row = lrow("Safe room ID to retreat to (Lich room #):", w_entry(:retreat_room, saved_retreat_room))
    retreat_note = Gtk::Label.new("Find your room number with: ;room  (script stops after arriving)")
    retreat_note.xalign = 0.0
    retreat_note.set_line_wrap(true)
    retreat_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    sor_note = Gtk::Label.new("Symbol of Return teleports you to Voln monastery. Script stops after use.")
    sor_note.xalign = 0.0
    sor_note.set_line_wrap(true)
    sor_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))

    vb.pack_start(retreat_room_row, false, false, 2)
    vb.pack_start(retreat_note,     false, false, 2)
    vb.pack_start(sor_note,         false, false, 2)

    update_retreat_visibility = lambda do
      idx = @w[:death_action].active
      retreat_room_row.visible = (idx == 0)
      retreat_note.visible     = (idx == 0)
      sor_note.visible         = (idx == 1)
    end
    retreat_combo.signal_connect("changed") { update_retreat_visibility.call }
    update_retreat_visibility.call

    # Encumbrance retreat threshold
    saved_enc_thresh = (@saved_config || {}).dig("hunting", "encumbrance_retreat_pct") || 0
    enc_idx = ENCUMBRANCE_LEVELS.index { |_, v| v == saved_enc_thresh } || 0
    enc_note = Gtk::Label.new("Encumbrance reduces Dodge DS. Set a threshold to retreat before penalties become severe.\nLeave at None to disable.")
    enc_note.xalign = 0.0
    enc_note.set_line_wrap(true)
    enc_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    add_row(vb, "Retreat when encumbered at or above:", w_combo(:encumbrance_retreat, ENCUMBRANCE_LEVELS.map(&:first), enc_idx))
    vb.pack_start(enc_note, false, false, 2)
    vb.pack_start(mk_hsep, false, false, 4)
    # Enforce: return threshold must always be higher than retreat threshold
    @w[:health_retreat_pct].signal_connect("value-changed") do
      ret_sp = @w[:health_return_pct]
      if ret_sp && ret_sp.value.to_i <= @w[:health_retreat_pct].value.to_i
        ret_sp.value = @w[:health_retreat_pct].value.to_i + 5
      end
    end
    @w[:health_return_pct].signal_connect("value-changed") do
      ret_sp = @w[:health_retreat_pct]
      if ret_sp && ret_sp.value.to_i >= @w[:health_return_pct].value.to_i
        ret_sp.value = @w[:health_return_pct].value.to_i - 5
      end
    end
    saved_sta_floor = (@profile.dig("hunting", "stamina_floor_enabled") rescue false) || false
    saved_man_floor = (@profile.dig("hunting", "mana_floor_enabled")    rescue false) || false
    @w[:stamina_floor_enabled] = Gtk::CheckButton.new(
      "Enforce a stamina floor -- script won't use abilities that would drop stamina below this value")
    @w[:mana_floor_enabled] = Gtk::CheckButton.new(
      "Enforce a mana floor -- script won't cast if it would drop mana below this value")
    @w[:stamina_floor_enabled].active = saved_sta_floor
    @w[:mana_floor_enabled].active    = saved_man_floor
    sta_spin_row = lrow("Keep stamina above:", w_spin(:stamina_reserve, 50, 0, 999))
    man_spin_row = lrow("Keep mana above:",    w_spin(:mana_reserve,   100, 0, 9999))
    sta_spin_row.sensitive = saved_sta_floor
    man_spin_row.sensitive = saved_man_floor
    @w[:stamina_floor_enabled].signal_connect("toggled") { sta_spin_row.sensitive = @w[:stamina_floor_enabled].active? }
    @w[:mana_floor_enabled].signal_connect("toggled")    { man_spin_row.sensitive = @w[:mana_floor_enabled].active? }
    vb.pack_start(@w[:stamina_floor_enabled], false, false, 2)
    vb.pack_start(sta_spin_row,               false, false, 2)
    vb.pack_start(@w[:mana_floor_enabled],    false, false, 2)
    vb.pack_start(man_spin_row,               false, false, 2)
    add_row(vb, "AoE / multi-target threshold (also set in Spells tab):", w_spin(:aoe_threshold, 3, 2, 20))
    add_row(vb, "Engagement threshold (abilities that need multiple foes):", w_spin(:multi_threshold, 2, 1, 20))
    add_row(vb, "Target priority:", w_combo(:npc_priority, [
      "Casters first (conjurers, mages, shaman...)",
      "Lowest HP first",
      "First available",
    ], 0))

    pf, pb = frame_vbox("Priority Targets (always attacked first, even mid-fight)")
    pb.pack_start(Gtk::Label.new(
      "Enter creature nouns or name fragments, one per line.\n" \
      "Examples: warlock, shaman, mage, troll king\n" \
      "If a listed creature appears in the room, the script will finish its current swing then switch to it."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

    saved_pri = ((@saved_config || {}).dig("hunting", "priority_creatures") || []).join("\n")
    @w[:priority_creatures] = Gtk::TextView.new
    @w[:priority_creatures].buffer.text = saved_pri
    @w[:priority_creatures].set_size_request(-1, 90)
    sw = Gtk::ScrolledWindow.new
    sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    sw.add(@w[:priority_creatures])
    pb.pack_start(sw, true, true, 2)
    vb.pack_start(pf, false, false, 6)

    sf, sb = frame_vbox("Never Attack (friendly / town NPCs)")
    sb.pack_start(Gtk::Label.new(
      "Enter NPC nouns or name fragments to NEVER attack, one per line.\n" \
      "Common town authority NPCs are blocked automatically (guard, constable, sheriff,\n" \
      "marshal, deputy, watchman, etc.). Add any others you encounter here.\n" \
      "Examples: brigand chief, merchant, peddler, healer"
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

    saved_safe = ((@saved_config || {}).dig("hunting", "safe_npcs") || []).join("\n")
    @w[:safe_npcs] = Gtk::TextView.new
    @w[:safe_npcs].buffer.text = saved_safe
    @w[:safe_npcs].set_size_request(-1, 75)
    sw2 = Gtk::ScrolledWindow.new
    sw2.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    sw2.add(@w[:safe_npcs])
    sb.pack_start(sw2, true, true, 2)
    vb.pack_start(sf, false, false, 6)

    gf, gb = frame_vbox("Gigas Peace (Hinterwilds)")
    @w[:avoid_gigas] = Gtk::CheckButton.new("Never attack gigas (brawny gigas shield-maiden, flayed gigas disciple, grim gigas skald, tattooed gigas berserker)")
    @w[:avoid_gigas].active = ((@saved_config || {}).dig("hunting", "avoid_gigas") == true)
    gb.pack_start(@w[:avoid_gigas], false, false, 3)
    warn_lbl = Gtk::Label.new(
      "WARNING: If unchecked, the script will treat gigas as hostile and attack them freely.\n" \
      "When checked, the script also suppresses ALL AoE/multi-target abilities while any gigas are present in the room."
    )
    warn_lbl.xalign = 0.0
    warn_lbl.set_line_wrap(true)
    warn_lbl.override_color(:normal, Gdk::RGBA.new(0.75, 0.45, 0.0, 1.0))
    gb.pack_start(warn_lbl, false, false, 3)
    vb.pack_start(gf, false, false, 6)

    scrolled(vb)
  end

  # ---------------------------------------------------------------------------
  # Trinkets tab -- Energy Wings pin and Battle Standard (manually configured)
  # ---------------------------------------------------------------------------
  def self.pg_trinkets
    saved = (@saved_config || {})["trinkets"] || {}
    outer = mk_vbox(8)
    outer.border_width = 10

    intro = Gtk::Label.new(
      "Trinkets are worn scripted items that are never held in hand and cannot be auto-detected.\n" \
      "Check each one you own and fill in the details."
    )
    intro.xalign = 0.0
    intro.set_line_wrap(true)
    outer.pack_start(intro, false, false, 4)
    outer.pack_start(mk_hsep, false, false, 3)

    # ---- Energy Wings ----
    ew = saved["energy_wings"] || {}
    ewf, ewb = frame_vbox("Energy Wings (worn pin)")

    ew_chk = Gtk::CheckButton.new("I have Energy Wings")
    ew_chk.active = ew["enabled"] == true
    ewb.pack_start(ew_chk, false, false, 2)

    ew_noun_e  = Gtk::Entry.new; ew_noun_e.text = ew["noun"].to_s.empty? ? "wing pin" : ew["noun"].to_s
    ew_type_c  = mk_combo_text(ENERGY_WINGS_TYPES, ENERGY_WINGS_TYPES.index(ew["wing_type"]) || 0)
    ew_tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((ew["tier"] || 1).to_f, 1.0, 3.0, 1.0, 1.0, 0.0), 1, 0)

    saved_ew_abs = ew["abilities"] || {}
    ew_ab_checks = {}
    ew_ab_vbox   = mk_vbox(2)
    ew_ab_hdr    = Gtk::Label.new("Abilities (uncheck to disable):")
    ew_ab_hdr.xalign = 0.0

    build_ew_abilities = lambda do
      ew_ab_vbox.children.each { |c| ew_ab_vbox.remove(c) }
      wt = ENERGY_WINGS_TYPES[ew_type_c.active].to_s.downcase.to_sym
      t  = ew_tier_sp.value.to_i
      (SCRIPT_TEMPLATES.dig("Energy Wings", :weapon) || [])
        .reject { |a| a[:when] == "skip" }
        .select { |a| (a[:min_tier] || 1) <= t && (a[:type] == :both || a[:type] == wt) }
        .each do |a|
          key      = a[:key].to_s
          saved_ab = saved_ew_abs[key] || {}
          prev     = ew_ab_checks[key]
          checked  = ew["enabled"] == true && (prev ? prev[:enabled_cb].active? : saved_ab.fetch("enabled", true))
          w_str    = prev ? BS_WHEN_OPTS[prev[:when_c].active || 0] : (saved_ab["when"] || a[:when])
          w_idx    = BS_WHEN_OPTS.index(w_str) || BS_WHEN_OPTS.index(a[:when]) || 1
          cb       = Gtk::CheckButton.new("#{a[:key].upcase} -- #{a[:desc]}")
          cb.active = checked
          wc = mk_combo_text(BS_WHEN_OPTS, w_idx)
          ew_ab_checks[key] = { enabled_cb: cb, when_c: wc }
          hb = mk_hbox(4)
          hb.pack_start(cb, true, true, 0)
          hb.pack_start(Gtk::Label.new("When:"), false, false, 2)
          hb.pack_start(wc, false, false, 0)
          ew_ab_vbox.pack_start(hb, false, false, 2)
        end
      ew_ab_vbox.show_all
    end

    ew_type_c.signal_connect("changed")        { build_ew_abilities.call }
    ew_tier_sp.signal_connect("value-changed") { build_ew_abilities.call }
    build_ew_abilities.call

    ew_detail_rows = [
      lrow("Item noun:",  ew_noun_e),
      lrow("Wing type:",  ew_type_c),
      lrow("Tier:",       ew_tier_sp),
      ew_ab_hdr,
      ew_ab_vbox,
    ]
    ew_detail_rows.each { |r| r.sensitive = ew_chk.active?; ewb.pack_start(r, false, false, 2) }
    ew_chk.signal_connect("toggled") { on = ew_chk.active?; ew_detail_rows.each { |r| r.sensitive = on } }

    @w[:ew_enabled]   = ew_chk
    @w[:ew_noun]      = ew_noun_e
    @w[:ew_wing_type] = ew_type_c
    @w[:ew_tier]      = ew_tier_sp
    @w[:ew_ab_checks] = ew_ab_checks
    outer.pack_start(ewf, false, false, 4)

    # ---- Battle Standard ----
    bs       = saved["battle_standard"] || {}
    bs_ab_cfg = bs["abilities"] || {}
    bsf, bsb = frame_vbox("Battle Standard (Paladin wearable -- from spell 1620)")

    bs_chk = Gtk::CheckButton.new("I have a Battle Standard")
    bs_chk.active = bs["enabled"] == true
    bsb.pack_start(bs_chk, false, false, 2)

    bs_noun_e  = Gtk::Entry.new; bs_noun_e.text = bs["noun"].to_s.empty? ? "standard" : bs["noun"].to_s
    bs_tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((bs["tier"] || 1).to_f, 1.0, 6.0, 1.0, 1.0, 0.0), 1, 0)

    bs_detail_rows = [lrow("Item noun:", bs_noun_e), lrow("Tier:", bs_tier_sp)]

    # Per-ability enable checkbox + "when" dropdown
    @w[:bs_ability_when]    = {}
    @w[:bs_ability_enabled] = {}
    tmpl_abs = SCRIPT_TEMPLATES.dig("Battle Standard", :armor) || []
    tmpl_abs.reject { |a| a[:key] == "pray" }.each do |ab|
      key      = ab[:key].to_s
      saved_ab = bs_ab_cfg[key] || {}
      # Handle old format (plain string) and new format (hash with enabled+when)
      saved_when    = saved_ab.is_a?(Hash) ? (saved_ab["when"] || ab[:when]) : (saved_ab.to_s.empty? ? ab[:when] : saved_ab.to_s)
      saved_enabled = bs["enabled"] == true && (saved_ab.is_a?(Hash) ? saved_ab.fetch("enabled", true) : true)
      w_idx  = BS_WHEN_OPTS.index(saved_when) || BS_WHEN_OPTS.index(ab[:when]) || 1
      combo  = mk_combo_text(BS_WHEN_OPTS, w_idx)
      cb     = Gtk::CheckButton.new("")
      cb.active = saved_enabled
      @w[:bs_ability_when][key]    = combo
      @w[:bs_ability_enabled][key] = cb
      hb = mk_hbox(4)
      hb.pack_start(cb, false, false, 0)
      lbl = Gtk::Label.new("#{ab[:key].upcase} (#{ab[:cd]}s CD) -- [T#{ab[:min_tier] || 1}] #{ab[:desc]}:")
      lbl.xalign = 0.0
      hb.pack_start(lbl, true, true, 0)
      hb.pack_start(combo, false, false, 0)
      bs_detail_rows << hb
    end

    bs_detail_rows.each { |r| r.sensitive = bs_chk.active?; bsb.pack_start(r, false, false, 2) }
    bs_chk.signal_connect("toggled") { on = bs_chk.active?; bs_detail_rows.each { |r| r.sensitive = on } }

    @w[:bs_enabled] = bs_chk
    @w[:bs_noun]    = bs_noun_e
    @w[:bs_tier]    = bs_tier_sp
    outer.pack_start(bsf, false, false, 4)

    # ---- Generic scripted trinket builder ----
    # Builds a frame with enable checkbox, noun entry, optional tier spinbutton,
    # and per-ability enable+when rows. Stores widgets under @w[:"trinket_#{key}_*"].
    build_trinket_frame = lambda do |label, key, max_tier, abilities_tmpl|
      sv    = (saved[key.to_s] || {})
      f, fb = frame_vbox(label)
      chk   = Gtk::CheckButton.new("I have this item")
      chk.active = sv["enabled"] == true
      fb.pack_start(chk, false, false, 2)

      noun_e = Gtk::Entry.new
      noun_e.text = sv["noun"].to_s.empty? ? key.to_s.tr("_", " ") : sv["noun"].to_s
      detail_rows = [lrow("Item noun:", noun_e)]

      tier_sp = nil
      if max_tier && max_tier > 1
        tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((sv["tier"] || 1).to_f, 1.0, max_tier.to_f, 1.0, 1.0, 0.0), 1, 0)
        detail_rows << lrow("Tier:", tier_sp)
      end

      ab_cfg = sv["abilities"] || {}
      ab_widgets = {}
      abilities_tmpl.reject { |a| a[:when] == "skip" }.each do |a|
        k        = a[:key].to_s
        saved_ab = ab_cfg[k] || {}
        enabled  = sv["enabled"] == true && saved_ab.fetch("enabled", true)
        w_str    = saved_ab["when"] || a[:when]
        w_idx    = BS_WHEN_OPTS.index(w_str) || BS_WHEN_OPTS.index(a[:when]) || 1
        cb       = Gtk::CheckButton.new("#{a[:key].upcase} -- #{a[:desc]}")
        cb.active = enabled
        wc = mk_combo_text(BS_WHEN_OPTS, w_idx)
        ab_widgets[k] = { enabled_cb: cb, when_c: wc }
        hb = mk_hbox(4)
        hb.pack_start(cb, true, true, 0)
        hb.pack_start(Gtk::Label.new("When:"), false, false, 2)
        hb.pack_start(wc, false, false, 0)
        detail_rows << hb
      end

      detail_rows.each { |r| r.sensitive = chk.active?; fb.pack_start(r, false, false, 2) }
      chk.signal_connect("toggled") { on = chk.active?; detail_rows.each { |r| r.sensitive = on } }

      @w[:"trinket_#{key}_enabled"]    = chk
      @w[:"trinket_#{key}_noun"]       = noun_e
      @w[:"trinket_#{key}_tier"]       = tier_sp
      @w[:"trinket_#{key}_ab_widgets"] = ab_widgets
      f
    end

    # ---- Elemental Gloves ----
    outer.pack_start(build_trinket_frame.call("Elemental Gloves (worn gloves)", :elemental_gloves, nil, EG_ABILITIES), false, false, 4)

    # ---- Twisted Gloves ----
    outer.pack_start(build_trinket_frame.call("Twisted Gloves (worn gloves, T4+)", :twisted_gloves, 5, TG_ABILITIES), false, false, 4)

    # ---- Twisted Kicks (boots) ----
    outer.pack_start(build_trinket_frame.call("Twisted Kicks (worn boots, T4+)", :twisted_kicks, 5, TK_ABILITIES), false, false, 4)

    # ---- Mage's Gauntlet ----
    outer.pack_start(build_trinket_frame.call("Mage's Gauntlet (worn gloves)", :mages_gauntlet, nil, []), false, false, 4)

    # ---- Magic Gloves / Bazzelwyn ----
    outer.pack_start(build_trinket_frame.call("Magic Gloves / Bazzelwyn (worn gloves)", :magic_gloves, nil, []), false, false, 4)

    # ---- Mana Battery Jewelry ----
    outer.pack_start(build_trinket_frame.call("Mana Battery Jewelry (worn jewelry)", :mana_battery, nil, []), false, false, 4)

    scrolled(outer)
  end

  # ---------------------------------------------------------------------------
  # Gemstones tab -- up to 5 slots, passive properties noted, activated ones used
  # ---------------------------------------------------------------------------
