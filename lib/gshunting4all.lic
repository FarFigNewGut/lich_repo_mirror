# ===========================================================================
# STATE
# ===========================================================================
module GSH4AState
  @cooldowns      = {}
  @daily_uses     = {}
  @daily_resets   = {}
  @toggle_done    = {}
  @mounted        = false
  @mount_summoned = false
  @hunting        = true
  @paused         = false
  @last_warn_at   = {}
  @reaction_at       = 0
  @last_aoe_at       = 0
  @last_aoe_npcs     = []
  @uac_tier          = 1   # 1=decent, 2=good, 3=excellent
  @uac_next_attack   = nil # "jab"/"punch"/"kick"/"grapple" when vulnerability announced

  class << self
    attr_accessor :mounted, :mount_summoned, :hunting, :paused
    attr_accessor :reaction_at, :last_aoe_at, :last_aoe_npcs
    attr_accessor :crossbow_loaded, :ranged_kneeling, :stun_pending
    attr_accessor :uac_tier, :uac_next_attack
    attr_accessor :incarnation_expires
    attr_accessor :berserking, :berserk_rounds

    # Returns true if the cooldown for key has expired (or was never set).
    #
    # @param key [String, Symbol] cooldown identifier
    # @return [Boolean] true when the ability is off cooldown
    def cd_ready?(key)
      Time.now.to_f >= (@cooldowns[key] || 0)
    end

    # Records a cooldown expiry time for key.
    #
    # @param key [String, Symbol] cooldown identifier
    # @param seconds [Numeric] duration of the cooldown in seconds
    # @return [Float] absolute expiry time (epoch seconds)
    def set_cd(key, seconds)
      @cooldowns[key] = Time.now.to_f + seconds.to_f
    end

    # Returns true when the daily use count for key is below limit.
    # Resets the counter automatically at midnight.
    #
    # @param key [String, Symbol] daily-use identifier
    # @param limit [Integer] maximum uses allowed per day
    # @return [Boolean] true when another use is permitted today
    def daily_ok?(key, limit)
      reset_daily(key)
      (@daily_uses[key] || 0) < limit
    end

    # Increments the daily use counter for key and persists it to disk.
    #
    # @param key [String, Symbol] daily-use identifier
    # @return [void]
    def use_daily(key)
      reset_daily(key)
      @daily_uses[key] = (@daily_uses[key] || 0) + 1
      save_state
    end

    # Persists today's daily-use counters to disk so they survive script restarts.
    # Keyed to today's date -- a new day automatically gets a clean slate on load.
    def save_state
      return unless defined?(Char) && Char.name && !Char.name.empty?
      path = File.join(PROFILE_DIR, "#{Char.name}_state.yaml")
      data = { "date" => Time.now.strftime("%Y-%m-%d"), "daily_uses" => @daily_uses.dup }
      File.write(path, data.to_yaml)
    rescue StandardError
      nil
    end

    # Loads daily-use counters saved from a previous run today.
    # If the saved date is not today, starts fresh (new day = new charges).
    def load_state
      return unless defined?(Char) && Char.name && !Char.name.empty?
      path = File.join(PROFILE_DIR, "#{Char.name}_state.yaml")
      return unless File.exist?(path)
      data = YAML.safe_load(File.read(path)) rescue nil
      return unless data.is_a?(Hash) && data["date"] == Time.now.strftime("%Y-%m-%d")
      saved = data["daily_uses"]
      return unless saved.is_a?(Hash)
      saved.each { |k, v| @daily_uses[k] = v.to_i }
    rescue StandardError
      nil
    end

    def toggle_done?(key)
      @toggle_done[key]
    end

    def mark_toggle(key)
      @toggle_done[key] = true
    end

    def throttle_ok?(key, secs)
      return false if Time.now.to_f - (@last_warn_at[key] || 0) < secs
      @last_warn_at[key] = Time.now.to_f
      true
    end

    private

    def reset_daily(key)
      now = Time.now.to_f
      if (@daily_resets[key] || 0) < now
        next_midnight = Time.now.tap { |t| t = Time.mktime(t.year, t.month, t.day) + 86400 }.to_f rescue now + 86400
        @daily_resets[key] = next_midnight
        @daily_uses[key]   = 0
      end
    end
  end
end

# ===========================================================================
# SETUP WIZARD
# ===========================================================================
module SetupWizard
  PAGES = [
    "Character", "Hunting Preferences", "Hunting Preferences 2", "Society", "Spells", "Weapons",
    "Weapon Attack Rotation", "Spell Attack Rotation", "CMANs & Techniques", "Defense", "Songs",
    "Rogue Guild", "Warrior Guild",
    "Mount", "Scripts",
    "Trinkets", "Arcarium (Vissi)", "Gemstones"
  ].freeze

  # GTK2/GTK3 compatibility wrappers
  def self.mk_vbox(sp = 6)
    Gtk::VBox.new(false, sp) rescue Gtk::Box.new(Gtk::Orientation::VERTICAL, sp)
  end

  def self.mk_hbox(sp = 6)
    Gtk::HBox.new(false, sp) rescue Gtk::Box.new(Gtk::Orientation::HORIZONTAL, sp)
  end

  def self.mk_hsep
    Gtk::HSeparator.new rescue Gtk::Separator.new(Gtk::Orientation::HORIZONTAL)
  end

  def self.mk_combo_text(options, idx = 0)
    c = begin
      ct = Gtk::ComboBoxText.new
      options.each { |o| ct.append_text(o.to_s) }
      ct
    rescue
      cb = Gtk::ComboBox.new(true)
      options.each { |o| cb.append_text(o.to_s) }
      cb
    end
    c.active = idx
    c
  end

  # ===========================================================================
  # Entry point
  # ===========================================================================
  def self.run
    if Script.current.vars[1] =~ /reset/i
      char = XMLData.name rescue "unknown"
      path = File.join(PROFILE_DIR, "#{char.downcase}.yaml")
      File.delete(path) if File.exist?(path)
      respond "[setup] Profile reset -- starting fresh."
    end

    respond "[gsh4a] Gathering character info -- the setup window will appear in a moment, please wait..."
    @detected = auto_detect

    # Load existing profile so the wizard pre-fills saved values
    char         = XMLData.name rescue "unknown"
    profile_path = File.join(PROFILE_DIR, "#{char.downcase}.yaml")
    @saved_config = File.exist?(profile_path) ? (YAML.load_file(profile_path) rescue {}) : {}
    @profile      = @saved_config

    # Keep the script thread alive while the window is open.
    # Lich 5 drops the game connection when a script thread exits; we must block here.
    # ConditionVariable.wait sleeps the thread efficiently (no busy loop).
    @setup_mutex = Mutex.new
    @setup_cv    = ConditionVariable.new
    @setup_open  = true

    Gtk.queue { init_window }

    @setup_mutex.synchronize { @setup_cv.wait(@setup_mutex) while @setup_open }
  end

  def self.signal_setup_done
    return unless @setup_mutex
    @setup_mutex.synchronize { @setup_open = false; @setup_cv.signal }
  end

  WEAPON_HOLDER_NOUN = /scabbard|sheath|baldric|harness|quiver|sling|frog|swordbelt|belt|sash|vatanura/i

  # Inventory items from weapon-holder containers only (no cloaks, bags, pouches).
  # Top-level worn items are always included; recursion only enters weapon holders.
  def self.weapon_inv_items
    seen   = {}
    result = []
    cmap   = safe_containers
    # Scan both carried inventory and worn items -- weapon holders (scabbards, harnesses,
    # etc.) may be worn on the body rather than carried in a bag.
    (safe_inv_top + (GameObj.worn rescue []).to_a).each do |item|
      next if seen[item.id]
      seen[item.id] = true
      result << item
      next unless item.noun =~ WEAPON_HOLDER_NOUN
      (cmap[item.id.to_s] || cmap[item.id] || []).each do |sub|
        next if seen[sub.id]
        seen[sub.id] = true
        result << sub
        # Handle nested sub-containers (e.g. sash/vatanura inner scabbard slots)
        (cmap[sub.id.to_s] || cmap[sub.id] || []).each do |inner|
          next if seen[inner.id]
          seen[inner.id] = true
          result << inner
        end
      end
    end
    result
  rescue Exception
    safe_inv_top
  end

  # Recursive inventory flatten -- includes items inside harness, scabbard, cloak, etc.
  def self.all_inv_items
    seen   = {}
    result = []
    cmap   = safe_containers
    top    = safe_inv_top
    queue  = top.dup
    until queue.empty?
      item = queue.shift
      next if seen[item.id]
      seen[item.id] = true
      result << item
      contents = cmap[item.id.to_s] || cmap[item.id] || []
      queue.concat(contents.to_a)
    end
    result
  rescue Exception
    safe_inv_top
  end

  def self.safe_inv_top
    GameObj.inv.to_a
  rescue Exception
    []
  end

  def self.safe_containers
    GameObj.containers || {}
  rescue Exception
    {}
  end

  # ===========================================================================
  # Auto-detection (runs on script thread before GTK window opens)
  # ===========================================================================
  def self.auto_detect
    respond "[setup] Detecting character, society, weapons, armor, arcarium..."
    d = {}

    # Character -- try every known Lich 5 source, take first non-blank value
    d[:name]  = [-> { XMLData.name  }, -> { Char.name  }].lazy.map { |f| f.call rescue nil }.find { |v| v && !v.strip.empty? } || "Unknown"
    d[:race]  = [-> { XMLData.race  }, -> { Char.race  }, -> { Stats.race  }].lazy.map { |f| f.call rescue nil }.find { |v| v && !v.strip.empty? } || ""
    d[:prof]  = [-> { XMLData.prof  }, -> { Char.prof  }, -> { Stats.prof  }].lazy.map { |f| f.call rescue nil }.find { |v| v && !v.strip.empty? } || ""
    d[:level] = [-> { Stats.level   }, -> { XMLData.level }, -> { Char.level }].lazy.map { |f| f.call rescue nil }.find { |v| v && v.to_i > 0 }.to_i

    # Hands -- Lich returns a placeholder object named "Empty" when hands are bare; treat as nil
    rh = GameObj.right_hand rescue nil
    lh = GameObj.left_hand  rescue nil
    rh = nil if rh.nil? || rh.name.to_s =~ /\Aempty\z/i || rh.id.to_i <= 0
    lh = nil if lh.nil? || lh.name.to_s =~ /\Aempty\z/i || lh.id.to_i <= 0
    d[:right_hand] = rh
    d[:left_hand]  = lh

    # Classify left hand: shield, off-hand weapon, or empty
    if lh
      if lh.noun =~ SHIELD_NOUNS
        d[:has_shield]  = true
        d[:shield_noun] = lh.noun
        d[:shield_name] = lh.name
      elsif rh
        # Only dual-wield if BOTH hands have something
        d[:dual_wield] = true
      end
    end

    # Force Lich to populate its container cache for weapon holders so items inside them
    # appear in GameObj.containers for the recursive scan below.
    # Covers both inventory and worn weapon holders (scabbards, harnesses, etc. can be
    # either worn on the body or carried in inventory depending on the player's setup).
    holder_pat = /scabbard|sheath|baldric|harness|quiver|sling|frog|swordbelt|belt|sash|vatanura/i
    (GameObj.inv.to_a + (GameObj.worn rescue []).to_a).uniq { |c| c.id }.each do |container|
      next unless container.noun =~ holder_pat
      capture_detect("look in my #{container.noun}", 1.5)
    end rescue nil
    # Sash and vatanura use nested sub-container slots -- the game physically places two
    # invisible scabbards inside them. A plain "look in my sash" won't surface those weapons;
    # we must address each slot directly.
    (GameObj.inv.to_a + (GameObj.worn rescue []).to_a).uniq { |c| c.id }
      .select { |c| c.noun =~ /\A(?:sash|vatanura)\z/i }.each do |outer|
      ["first", "second"].each do |pos|
        capture_detect("look in #{pos} scabbard in my #{outer.noun}", 1.5)
      end
    end rescue nil

    # Weapon-holder-only scan -- excludes items cached in cloaks, bags, pouches, etc.
    inv = weapon_inv_items

    # Arcarium -- aversaris (offensive) and vangaris (defensive)
    d[:aversaris] = inv.find { |i| i.name =~ /aversaris/i }
    d[:vangaris]  = inv.find { |i| i.name =~ /vangaris/i }
    d[:aversaris_vissi] = analyze_arcarium_vissi("aversaris arcarium") if d[:aversaris]
    # Pause between the two analyze calls so any in-flight server output from the
    # aversaris response fully drains before we open the vangaris capture window.
    sleep 1.0 if d[:aversaris] && d[:vangaris]
    d[:vangaris_vissi]  = analyze_arcarium_vissi("vangaris arcarium")  if d[:vangaris]

    # Bards using Sonic Armor (1007): the conjured armor only exists as a worn item
    # while the song is active. Prompt them to sing it before detection scans for armor.
    if d[:prof].to_s =~ /bard/i
      has_armor = inv.any? { |i| i.noun =~ ARMOR_NOUNS } ||
                  (GameObj.worn rescue []).to_a.any? { |i| i.noun =~ ARMOR_NOUNS }
      unless has_armor
        respond "[setup] Bard detected with no armor found. If you use Sonic Armor (song 1007), sing it now -- detection will re-scan in 3 seconds."
        sleep 3
      end
    end

    # Armor -- prefer worn items (always the character's actual armor) over inventory
    # items in weapon holders, which could be a decorative coat or robe in a bag.
    d[:armor] = (GameObj.worn rescue []).to_a.find { |i| i.noun =~ ARMOR_NOUNS } ||
                inv.find { |i| i.noun =~ ARMOR_NOUNS }
    d[:armor_asg] = guess_armor_asg(d[:armor])

    # Weapon inventory scan -- for when nothing is in hand (still needed for pg_weapon picker)
    weapon_pat = WEAPON_NOUN_HINTS.map { |pat, _| pat }.reduce { |a, b| Regexp.union(a, b) }
    d[:inventory_weapons] = inv.select { |i|
      n = i.noun.to_s
      next false if n =~ /-haft$|\bhaft$/i
      next false if n =~ /-blade$/i && n !~ /whip.?blade/i
      n =~ weapon_pat
    }

    # Build the full candidate list for script detection -- everything in inventory
    weapon_pat = WEAPON_NOUN_HINTS.map { |pat, _| pat }.reduce { |a, b| Regexp.union(a, b) }
    candidates = []

    # Right hand = primary weapon slot
    candidates << { slot: :primary,   item: rh }                   if rh
    # Left hand = secondary or shield slot
    candidates << { slot: d[:has_shield] ? :shield : :secondary, item: lh } if lh
    # Armor -- already detected from inventory scan
    candidates << { slot: :armor,     item: d[:armor] }             if d[:armor]
    # All inventory weapons not already in hand -- use full recursive scan so weapons
    # inside backpacks and other non-holder containers are also found.
    seen_nouns = candidates.map { |c| c[:item].noun }.compact.to_set
    all_inv_items.each do |i|
      next if seen_nouns.include?(i.noun)
      # Skip forge components -- unfinished pieces like handaxe-haft, mace-blade, etc.
      # whip-blade is the one real weapon with "-blade" in its noun, so exclude it from the skip.
      noun_s = i.noun.to_s
      next if noun_s =~ /-haft$|\bhaft$/i
      next if noun_s =~ /-blade$/i && noun_s !~ /whip.?blade/i
      if i.noun =~ weapon_pat
        candidates << { slot: :primary, item: i }
        seen_nouns << i.noun
      elsif i.noun =~ SHIELD_NOUNS
        candidates << { slot: :shield, item: i }
        seen_nouns << i.noun
      elsif i.noun =~ ARMOR_NOUNS
        candidates << { slot: :armor, item: i }
        seen_nouns << i.noun
      elsif (i.noun =~ UAC_HAND_NOUNS || i.noun =~ UAC_FOOT_NOUNS) && i.name =~ /uac|unarmed/i
        candidates << { slot: :primary, item: i }
        seen_nouns << i.noun
      end
    end
    # Worn items (armor/shield worn directly on body, not in a holder)
    (GameObj.worn rescue []).to_a.each do |i|
      next if seen_nouns.include?(i.noun)
      if i.noun =~ ARMOR_NOUNS
        candidates << { slot: :armor, item: i }
        seen_nouns << i.noun
      elsif i.noun =~ SHIELD_NOUNS
        candidates << { slot: :shield, item: i }
        seen_nouns << i.noun
      end
    end

    # Analyze every candidate for combat scripts.
    d[:item_scripts] = []

    candidates.each do |c|
      noun = c[:item].noun.to_s.strip
      next if noun.empty?
      out  = capture_detect("analyze my #{noun}", 3.0)
      SCRIPT_TEMPLATES.each do |name, tmpl|
        next if name == "Energy Wings"  # handled by manual checkbox in Scripts tab
        pat = tmpl[:detect_pattern] || /#{Regexp.escape(name)}/i
        next unless out =~ pat
        next if d[:item_scripts].any? { |s| s[:name] == name && s[:slot] == c[:slot] }
        tier = if    out =~ /tier\s*(\d)/i then $1.to_i
                 elsif out =~ /\bT(\d)\b/   then $1.to_i
                 else 1 end
        d[:item_scripts] << { name: name, slot: c[:slot], noun: noun, tier: tier }
      end
    end

    # Known spells -- Lich caches spell knowledge from the XML stream; no game command needed
    d[:known_spells] = detect_known_spells

    # Lore ranks -- parse "skills" output for Spiritual Lore sub-skills
    skills_out = capture_detect("skills", 3.0)
    d[:lore_ranks] = parse_lore_ranks(skills_out)

    # CMANs / feats -- "cman info" lists all known CMANs/feats; "weapon info" shows weapon techniques
    raw_feats = parse_ability_list(capture_detect("cman info", 2.5))
    # Enrich each CMAN with stamina cost and cooldown from individual info pages.
    # passive flag comes from the Type column in "cman info" output (most reliable source).
    d[:feats] = raw_feats.map do |feat|
      name     = feat[:name]
      passive  = feat[:passive]
      mnemonic = feat[:mnemonic]
      rank     = feat[:rank]
      next { name: name, mnemonic: mnemonic, rank: rank, stamina: 0, cd: 0, passive: true } if passive
      sleep 0.3  # drain previous response before next capture to prevent bleed
      detail  = capture_detect("cman info #{name}", 3.0)
      stamina = detail =~ /stamina.*?(\d+)/i      ? $1.to_i : 0
      cd      = detail =~ /(\d+)\s+second.*cool/i ? $1.to_i : 0
      { name: name, mnemonic: mnemonic, rank: rank, stamina: stamina, cd: cd, passive: false }
    end
    raw_techniques = parse_technique_list(capture_detect("weapon info", 2.5))
    d[:techniques] = raw_techniques.select { |t| WEAPON_TECH_KNOWN.key?(t[:mnemonic].to_s.downcase) }
    tech_mnemonics = d[:techniques].map { |t| t[:mnemonic].to_s.downcase }.to_set
    feat_mnemonics = d[:feats].map      { |f| f[:mnemonic].to_s.downcase }.to_set
    raw_shield = parse_technique_list(capture_detect("shield info",  2.5))
    # Exclude weapon techniques AND CMans -- cman info detail calls just before this
    # can bleed their table rows into the shield info capture window.
    d[:shield_specs]  = raw_shield.reject { |s|
      m = s[:mnemonic].to_s.downcase
      tech_mnemonics.include?(m) || feat_mnemonics.include?(m)
    }

    raw_armor  = parse_technique_list(capture_detect("armor info",   2.5))
    shield_mnemonics = d[:shield_specs].map { |s| s[:mnemonic].to_s.downcase }.to_set
    d[:armor_specs]   = raw_armor.reject  { |s| tech_mnemonics.include?(s[:mnemonic].to_s.downcase) || shield_mnemonics.include?(s[:mnemonic].to_s.downcase) }
    d[:gem_slots]     = parse_gem_slots(capture_detect("gemstone slot", 3.0))

    # Society -- use Lich 5 Society API directly (no command send needed)
    soc_raw = (Society.membership rescue nil) || (XMLData.society rescue nil)
    d[:society] = case soc_raw.to_s
    when /order of voln/i               then "Voln"
    when /guardians of sunfist/i        then "Sunfist"
    when /council of light/i            then "CoL"
    else nil
    end
    d[:society_rank] = (Society.rank rescue nil) || (XMLData.society_rank rescue nil) || 1

    d
  end


  # Known always-on passive CMANs/feats -- no activation verb, excluded from the active list.
  # These are confirmed passive from gswiki.play.net/Combat_Maneuvers.
  # If you see an ability here that you CAN activate, remove it and re-run setup.
  PASSIVE_CMANS = [
    "Combat Focus",
    "Combat Toughness",
    "Cunning Defense",
    "Armor Skin",
    "Mobility",
    "Tainted Bond",
    "Specialization I",
    "Specialization II",
    "Specialization III",
    "Specialization IV",
    "Weapon Specialization",
  ].map(&:downcase).freeze

  # Passive check also covers any name starting with these prefixes (handles truncated GS4 output)
  PASSIVE_CMAN_PREFIXES = ["weapon spec", "weapon specializ"].freeze

  # GS4 spell circles and their number ranges (verified against gswiki.play.net/Spell_circle)
  # NOTE: Wizard Base is 901-950, NOT 601-649. Ranger Base is 601-650, NOT 801-849.
  #       801-899 is unused in current GS4. Monks use CMANs; no Monk Base circle.
  SPELL_CIRCLES = [
    { name: "Minor Spiritual",  range: 101..140 },
    { name: "Major Spiritual",  range: 201..240 },
    { name: "Cleric Base",      range: 301..350 },
    { name: "Minor Elemental",  range: 401..435 },
    { name: "Major Elemental",  range: 501..550 },
    { name: "Ranger Base",      range: 601..650 },
    { name: "Sorcerer Base",    range: 701..740 },
    { name: "Wizard Base",      range: 901..950 },
    { name: "Bard Base",        range: 1001..1040 },
    { name: "Empath Base",      range: 1101..1150 },
    { name: "Minor Mental",     range: 1201..1235 },
    { name: "Major Mental",     range: 1301..1320 },
    { name: "Savant Base",      range: 1401..1450 },
    { name: "Paladin Base",     range: 1601..1650 },
    { name: "Arcane",           range: 1700..1750 },
  ].freeze

  # Returns array of { num:, name:, circle: } for every spell the character knows.
  # Uses Lich's in-memory Spell cache -- accurate once the XML stream has been
  # fully parsed, but may be empty immediately after login before the stream settles.
  NON_SPELL_PROFS = %w[warrior rogue monk].freeze

  def self.detect_known_spells
    known = []
    SPELL_CIRCLES.each do |circle|
      circle[:range].each do |num|
        s = Spell[num] rescue nil
        next unless s
        next unless s.known? rescue false
        known << { num: num, name: s.name.to_s, circle: circle[:name] }
      end
    end
    if known.empty?
      prof = (Stats.prof rescue "").to_s.downcase
      unless NON_SPELL_PROFS.any? { |p| prof.include?(p) }
        respond "[setup] Warning: no known spells detected via Lich cache. " \
                "If you know spells, try re-running ;gshunting4all after the game " \
                "stream has fully settled (a few seconds after login)."
      end
    end
    known
  rescue Exception
    []
  end

  # Parse "skills" output to extract Spiritual Lore sub-skill ranks.
  # GS4 outputs lines like:   Spiritual Lore, Blessings         25       5
  # Returns hash like: { "Blessings" => 25, "Summoning" => 10, "Religion" => 0 }
  # Parses `gemstone slot` output into an array of slot hashes (index 0 = slot 1).
  # Each hash: { equipped: bool, name: str, properties: [str, ...] }
  #
  # Expected format:
  #   Slot 1: a square deep green jewel (Gemstone #2)
  #       * Flare Resonance (Rank 5 of 5)
  #       * Relentless Warder (Rank 2 of 5)
  def self.parse_gem_slots(out)
    slots   = Array.new(MAX_GEMSTONE_SLOTS) { { equipped: false, name: "", properties: [] } }
    current = nil
    return slots if out.strip.empty?
    out.each_line do |line|
      clean = line.gsub(/<[^>]+>/, "").rstrip
      if clean =~ /\bSlot\s+(\d+)\s*:/i
        idx = $1.to_i - 1
        next unless idx >= 0 && idx < MAX_GEMSTONE_SLOTS
        # Everything after "Slot N:" up to the first "(" is the gem description
        gem_desc = clean.sub(/\bSlot\s+\d+\s*:\s*/i, "")
                        .sub(/\s*\(Gemstone\s*#\d+\).*/i, "")
                        .strip.downcase
        slots[idx] = { equipped: !gem_desc.empty?, name: gem_desc, properties: [] }
        current = idx
      elsif current && clean =~ /\*\s+(.+)/
        # Property line: "    * Property Name (Rank X of Y)"
        prop = $1.strip.sub(/\s*\(Rank\s+\d+.*\)\s*\z/i, "").strip
        slots[current][:properties] << prop unless prop.empty?
      end
    end
    slots
  rescue
    Array.new(MAX_GEMSTONE_SLOTS) { { equipped: false, name: "", properties: [] } }
  end

  def self.parse_lore_ranks(out)
    ranks = {}
    # GS4 skills output format: "  Spiritual Lore - Blessings.........|     176      76"
    # Separator is " - " (dash), not a comma. The line has two numbers: bonus then ranks.
    # Use .last to get the ranks column, not .first (which would grab the bonus).
    out.each_line do |line|
      case line
      when /spirit\s+mana\s+control/i
        nums = line.scan(/\d+/)
        ranks["SMC"]       = nums.last.to_i
        ranks["SMC_bonus"] = nums.first.to_i
      when /spiritual\s+lore[\s,\-]+(blessings)/i    then ranks["Blessings"]     = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(summoning)/i    then ranks["Summoning"]     = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(religion)/i     then ranks["Religion"]      = line.scan(/\d+/).last.to_i
      when /spiritual\s+lore[\s,\-]+(mysticism)/i    then ranks["Mysticism"]     = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(earth)/i        then ranks["Earth"]         = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(air)/i          then ranks["Air"]           = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(fire)/i         then ranks["Fire"]          = line.scan(/\d+/).last.to_i
      when /elemental\s+lore[\s,\-]+(water)/i        then ranks["Water"]         = line.scan(/\d+/).last.to_i
      when /sorcerous\s+lore[\s,\-]+(demonology)/i   then ranks["Demonology"]    = line.scan(/\d+/).last.to_i
      when /sorcerous\s+lore[\s,\-]+(necromancy)/i   then ranks["Necromancy"]    = line.scan(/\d+/).last.to_i
      when /mental\s+lore[\s,\-]+(telepathy)/i       then ranks["Telepathy"]     = line.scan(/\d+/).last.to_i
      when /mental\s+lore[\s,\-]+(transference)/i    then ranks["Transference"]  = line.scan(/\d+/).last.to_i
      when /mental\s+lore[\s,\-]+(transformation)/i  then ranks["Transformation"] = line.scan(/\d+/).last.to_i
      when /ranger\s+lore/i                          then ranks["Ranger"]        = line.scan(/\d+/).last.to_i
      when /bard\s+lore/i                            then ranks["Bard"]          = line.scan(/\d+/).last.to_i
      end
    end
    ranks
  rescue Exception
    {}
  end

  def self.spell_offensive?(s)
    OFFENSIVE_SPELL_NUMS.include?(s[:num]) ||
      s[:name].to_s =~ OFFENSIVE_SPELL_PATTERN
  end

  # Parse "cman info" output.
  # GS4 outputs a columnar table with a header row containing "Skill" and "Mnemonic":
  #   Skill            Mnemonic         Ranks  Type      Category    Subcategory
  #   --------------------------------------------------------------------------
  #   Ambush           ambush             5    Passive   Combat      Stealth
  #   ...
  #   The output listed above was generated based on the following filters:
  #   Availability: profession   Type: all   ...
  #
  # We locate the header row, find the column offsets for Skill and Type,
  # then return hashes { name:, passive: } for each data row.
  def self.parse_ability_list(out)
    return [] if out.strip.empty?
    lines = out.each_line.map(&:rstrip)
    header_idx = lines.index { |l| l =~ /\bSkill\b/i && l =~ /\bMnemonic\b/i }
    return [] unless header_idx
    header = lines[header_idx]
    mnemonic_col = header =~ /\bMnemonic\b/i ? header.index(/\bMnemonic\b/i) : nil
    ranks_col    = header =~ /\bRanks\b/i    ? header.index(/\bRanks\b/i)    : nil
    type_col     = header =~ /\bType\b/i     ? header.index(/\bType\b/i)     : nil
    results = []
    lines[(header_idx + 1)..].each do |line|
      break if line =~ /\Athe output listed/i
      next  if line.strip.empty?
      next  if line.strip =~ /\A[-]+\z/
      next  if line.strip =~ /\A\*/
      next  if line =~ /\AAvailability:|Type:\s*all|Category:\s*all|Subcategory:\s*all/i
      name = line.lstrip.split(/\s{2,}/).first.to_s.strip
      next if name.empty? || name.length < 3 || name.length > 50
      next if name =~ /\A\d/ || name =~ /\A[-]+\z/ || name =~ /\A\*/
      next if name =~ /[,\.!?<>]/
      next if name =~ /\w{1,4}>/
      next if name =~ /\A\[/
      next if name =~ /:/
      next if name =~ /\A(you|the|a |an |also|there|it |he |she )/i
      next if name.split.length > 5
      next unless name =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/
      mnemonic  = (mnemonic_col && line.length > mnemonic_col) ? line[mnemonic_col..].split.first.to_s.downcase : ""
      ranks_str = (ranks_col   && line.length > ranks_col)    ? line[ranks_col..].split.first.to_s              : ""
      rank      = ranks_str =~ /(\d+)/ ? $1.to_i : nil
      type_str  = (type_col    && line.length > type_col)     ? line[type_col..].split.first.to_s.downcase      : ""
      passive   = type_str == "passive"
      results << { name: name, passive: passive, mnemonic: mnemonic, rank: rank }
    end
    results.uniq { |r| r[:name] }
  rescue Exception
    []
  end

  # All known weapon techniques from gswiki.play.net/Verb:WEAPON (verified 2026-06).
  # Used to supply accurate defaults even if "weapon info" output is ambiguous.
  # Keys are mnemonics (lowercase, no spaces) as GS4 uses them.
  WEAPON_TECH_KNOWN = {
    # Brawling (rank 10/25/50/75)
    "twinhammer"    => { name: "Twin Hammerfists",  tech_type: "setup",    min_creatures: 1, rank: 10, category: "Brawling"           },
    "fury"          => { name: "Fury",              tech_type: "assault",  min_creatures: 1, rank: 25, category: "Brawling"           },
    "clash"         => { name: "Clash",             tech_type: "aoe",      min_creatures: 3, rank: 50, category: "Brawling"           },
    "spinkick"      => { name: "Spin Kick",         tech_type: "reaction", min_creatures: 1, rank: 75, category: "Brawling"           },
    # Blunt Weapons (rank 10/25/50/75)
    "dizzyingswing" => { name: "Dizzying Swing",    tech_type: "setup",    min_creatures: 1, rank: 10, category: "Blunt Weapons"      },
    "clobber"       => { name: "Clobber",           tech_type: "reaction", min_creatures: 1, rank: 25, category: "Blunt Weapons"      },
    "pummel"        => { name: "Pummel",            tech_type: "assault",  min_creatures: 1, rank: 50, category: "Blunt Weapons"      },
    "pulverize"     => { name: "Pulverize",         tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Blunt Weapons"      },
    # Edged Weapons (rank 10/25/50/75)
    "cripple"       => { name: "Cripple",           tech_type: "setup",    min_creatures: 1, rank: 10, category: "Edged Weapons"      },
    "riposte"       => { name: "Riposte",           tech_type: "reaction", min_creatures: 1, rank: 25, category: "Edged Weapons"      },
    "flurry"        => { name: "Flurry",            tech_type: "assault",  min_creatures: 1, rank: 50, category: "Edged Weapons"      },
    "wblade"        => { name: "Whirling Blade",    tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Edged Weapons"      },
    # Polearm Weapons (rank 10/25/50/75)
    "charge"        => { name: "Charge",            tech_type: "setup",    min_creatures: 1, rank: 10, category: "Polearm Weapons"    },
    "gthrusts"      => { name: "Guardant Thrusts",  tech_type: "assault",  min_creatures: 1, rank: 25, category: "Polearm Weapons"    },
    "cyclone"       => { name: "Cyclone",           tech_type: "aoe",      min_creatures: 3, rank: 50, category: "Polearm Weapons"    },
    "radialsweep"   => { name: "Radial Sweep",      tech_type: "reaction", min_creatures: 1, rank: 75, category: "Polearm Weapons"    },
    # Ranged Weapons (rank 10/25/50/75)
    "reactiveshot"  => { name: "Reactive Shot",     tech_type: "reaction", min_creatures: 1, rank: 10, category: "Ranged Weapons"     },
    "pindown"       => { name: "Pin Down",          tech_type: "aoe",      min_creatures: 3, rank: 25, category: "Ranged Weapons"     },
    "barrage"       => { name: "Barrage",           tech_type: "assault",  min_creatures: 1, rank: 50, category: "Ranged Weapons"     },
    "volley"        => { name: "Volley",            tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Ranged Weapons"     },
    # Two-Handed Weapons (rank 10/25/50/75)
    "overpower"     => { name: "Overpower",         tech_type: "reaction", min_creatures: 1, rank: 10, category: "Two-Handed Weapons" },
    "thrash"        => { name: "Thrash",            tech_type: "assault",  min_creatures: 1, rank: 25, category: "Two-Handed Weapons" },
    "reversestrike" => { name: "Reverse Strike",    tech_type: "reaction", min_creatures: 1, rank: 50, category: "Two-Handed Weapons" },
    "whirlwind"     => { name: "Whirlwind",         tech_type: "aoe",      min_creatures: 3, rank: 75, category: "Two-Handed Weapons" },
  }.freeze

  # Parse "weapon info" output for weapon techniques.
  # Returns array of { name:, tech_type: } where tech_type is one of:
  #   "assault", "aoe", "reaction", "concentration", "setup", "unknown"
  # The "weapon info" table columns: Skill  Mnemonic  Ranks  Type  Category  Subcategory
  # We capture col[0] (name), col[1] (mnemonic), col[3] (type).
  TECH_TYPE_MAP = {
    /assault/i        => "assault",
    /area.of.effect/i => "aoe",
    /reaction/i       => "reaction",
    /concentration/i  => "concentration",
    /setup/i          => "setup",
  }.freeze

  # Output columns from "weapon info":
  #   Skill           Mnemonic       Ranks  Type             Category
  #   Overpower       overpower      5/5    Reaction         Two-Handed Weapons
  #   Reverse Strike  reversestrike  5/5    Reaction         Two-Handed Weapons
  #   Thrash          thrash         5/5    Assault          Two-Handed Weapons
  #   Whirlwind       whirlwind      5/5    Area of Effect   Two-Handed Weapons
  def self.parse_technique_list(out)
    return [] if out.strip.empty?
    lines = out.each_line.map(&:rstrip)
    header_idx = lines.index { |l| l =~ /\bSkill\b/i && l =~ /\bMnemonic\b/i }
    return [] unless header_idx
    results = []
    lines[(header_idx + 1)..].each do |line|
      break if line =~ /\Athe output listed/i
      next  if line.strip.empty?
      next  if line.strip =~ /\A[-]+\z/
      next  if line.strip =~ /\A\*/          # game notifications (* Player joins, etc.)
      next  if line =~ /\AAvailability:|Type:\s*all|Category:\s*all|Subcategory:\s*all/i
      cols     = line.lstrip.split(/\s{2,}/)
      name     = cols[0].to_s.strip
      mnemonic = cols[1].to_s.strip.downcase
      next if name.empty? || name.length < 3 || name.length > 50
      next if name =~ /\A\d/ || name =~ /\A[-]+\z/ || name =~ /\A\*/
      next if name =~ /[,\.!?<>]/                                   # prose, room descriptions, or Lich aliases
      next if name =~ /\w{1,4}>/                                    # Lich alias prompt (e.g. sj>)
      next if name =~ /\A\[/                                         # ESP / channel: [Merchants]: ...
      next if name =~ /:/                                            # any key:value or channel line
      next if name =~ /\A(the|a |an |you|also|there|it |he |she |some |gold |silver |black |white |red |blue |green |ora |veil |glaes |mithril )/i
      next if name.split.length > 5                                  # real skill names are short
      next unless name =~ /\A[A-Za-z][A-Za-z\s'\-]*\z/             # must be letters/spaces/apostrophe/hyphen only
      next if mnemonic =~ /[\.!?]|you |also |see |a packing|some /i # eloot/room-desc bleed-through

      # Cross-reference known table first -- most reliable source
      known = WEAPON_TECH_KNOWN[mnemonic]
      if known
        tech_type    = known[:tech_type]
        min_creatures = known[:min_creatures]
        name         = known[:name]   # canonical capitalisation
        min_rank     = known[:rank] || "?"
      else
        raw_type      = cols[3].to_s.strip
        tech_type     = TECH_TYPE_MAP.find { |pat, _| raw_type =~ pat }&.last || "unknown"
        min_creatures = tech_type == "aoe" ? 3 : 1
        raw_ranks     = cols[2].to_s.strip  # e.g. "5/5" from weapon info output
        min_rank      = raw_ranks =~ /\A(\d+)/ ? $1.to_i : "?"
      end

      verb = mnemonic.empty? ? "weapon #{name.downcase.gsub(/\s+/, '')}" : "weapon #{mnemonic}"
      ranks    = cols[2].to_s.strip
      category = cols[4].to_s.strip
      category = known[:category].to_s if category.empty? && known
      results << { name: name, mnemonic: mnemonic, verb: verb, tech_type: tech_type, min_creatures: min_creatures, min_rank: min_rank, ranks: ranks, category: category }
    end
    results.uniq { |r| r[:name] }
  rescue Exception
    []
  end

  def self.capture_detect(cmd, wait_secs = 2.0)
    lines    = []
    prompted = false
    hook     = "gsh4a_detect_#{Thread.current.object_id}"
    DownstreamHook.add(hook, proc { |txt|
      prompted = true if txt =~ /<prompt /
      lines << txt
      txt =~ /<prompt / ? txt : nil
    })
    UpstreamHook.add(hook, proc { |input| input == "#{cmd}\n" ? nil : input })
    fput cmd
    deadline = Time.now + wait_secs
    sleep 0.05 until prompted || Time.now >= deadline
    DownstreamHook.remove(hook)
    UpstreamHook.remove(hook)
    lines.map { |l| l.to_s.gsub(/<[^>]+>/, '').gsub(/&gt;/, '>').gsub(/&lt;/, '<').gsub(/&amp;/, '&') }
         .reject { |l| l.strip.empty? }
         .join("\n")
  rescue
    ""
  ensure
    DownstreamHook.remove(hook) rescue nil
    UpstreamHook.remove(hook)  rescue nil
  end

  ARCARIUM_VERBS = %w[rub push pull turn wave tap knock squeeze clench prod poke].freeze

  # Parses the "Slotted Vissi" table from `analyze my <noun>` output.
  # Returns an array of hashes for active vissi (recognized activator verb) and passive vissi
  # (no activator -- verb: "(passive)"). All categories included.
  #
  # Each hash: { name, category, activator, verb, tier, daily_limit, cooldown_secs, passive }
  def self.analyze_arcarium_vissi(noun)
    out = capture_detect("analyze my #{noun}", 7.0)
    return [] if out.strip.empty?

    lines = out.each_line.map(&:rstrip)

    # Guard against output bleed from the previous analyze command arriving inside
    # this capture window. Each analyze response opens with "You analyze the ...".
    # If two such lines appear, the earlier one is bleed -- only keep lines starting
    # from the LAST occurrence (which belongs to our command).
    analyze_starts = lines.each_with_index
                          .select { |l, _| l =~ /you analyze the/i }
                          .map    { |_, i| i }
    lines = lines[analyze_starts.last..] if analyze_starts.length > 1

    # Also stop at any second header table (belt-and-suspenders against partial bleed
    # where both responses share the same "You analyze" intro position).
    header_indices = lines.each_with_index
                          .select { |l, _| l =~ /\bName\b/i && l =~ /\bCategory\b/i && l =~ /\bActivator\b/i }
                          .map    { |_, i| i }
    lines = lines[0...header_indices[1]] if header_indices.length > 1

    # Find the column header row containing Name / Category / Activator
    header_idx = lines.index { |l| l =~ /\bName\b/i && l =~ /\bCategory\b/i && l =~ /\bActivator\b/i }
    return [] unless header_idx

    # Parse by splitting on 2+ whitespace. GS4 fixed-width tables use 2+ spaces between
    # columns; single spaces within a field (e.g. "Soul Harvester") are preserved.
    # This avoids column-position detection which breaks when the header label is indented
    # differently from the data rows.
    verb_set = ARCARIUM_VERBS.to_set
    results  = []
    current  = nil

    lines[(header_idx + 1)..].each do |line|
      next if line.strip.empty? || line.strip =~ /\A[-=*]+\z/

      parts = line.strip.split(/\s{2,}/)
      name_candidate = parts[0].to_s.strip

      # Determine if this line is a vissi data row vs a continuation/description line.
      is_row = parts.length >= 2 &&
               name_candidate.length >= 2 &&
               name_candidate =~ /\A[A-Za-z][\w\s'\-]*\z/ &&
               name_candidate !~ /\A(the |a |an |you |also |there |this |that |once |every |it |he |she |some )/i &&
               name_candidate.split.length <= 5

      if is_row
        # parts: [name, category, activator, tier]  (active)
        #     or [name, category, tier]              (passive, tier is numeric)
        #     or [name, category]                    (passive, no tier)
        activator = nil
        tier      = 0
        category  = parts[1].to_s.strip

        if parts.length >= 4 && verb_set.include?(parts[2].to_s.downcase)
          activator = parts[2].downcase
          tier      = parts[3].to_i
        elsif parts.length >= 3 && verb_set.include?(parts[2].to_s.downcase)
          activator = parts[2].downcase
          tier      = 0
        elsif parts.length >= 3 && parts[2] =~ /\A\d+\z/
          tier = parts[2].to_i
        end

        current = {
          name:          name_candidate,
          category:      category,
          activator:     activator,
          verb:          activator ? "#{activator} my #{noun}" : "(passive)",
          tier:          tier,
          daily_limit:   0,
          cooldown_secs: 0,
          passive:       activator.nil?,
        }
        results << current
      else
        next unless current
        current[:daily_limit]   = $1.to_i if line =~ /(\d+)\s+times?\s+per\s+day/i
        current[:cooldown_secs] = $1.to_i if line =~ /(\d+)\s+second\s+cooldown/i
      end
    end

    results
  rescue
    []
  end

  def self.guess_armor_asg(item)
    return nil unless item
    text = "#{item.noun} #{item.name}".downcase
    # Check from most-specific to least-specific
    ARMOR_TYPES.reverse.each do |at|
      return at[:asg] if text =~ at[:nouns]
    end
    nil
  end

  def self.armor_asg_idx(asg)
    ARMOR_TYPES.index { |at| at[:asg] == asg } || 0
  end

  # ===========================================================================
  # Window
  # ===========================================================================
  def self.init_window
    @w  = {}   # flat widget registry
    @ws = {}   # scripts widgets: slot_key -> script_name -> { enabled, tier, abilities }
    @cman_store = @tech_store = @shield_spec_store = @armor_spec_store = nil

    @win = Gtk::Window.new("GSHunting4All v#{SCRIPT_VERSION} -- Character Setup")
    @win.set_default_size(760, 620)
    @win.border_width = 10
    @win.signal_connect("destroy") { signal_setup_done }

    root = mk_vbox(6)

    @w[:nb] = Gtk::Notebook.new
    @w[:nb].show_tabs   = true
    @w[:nb].show_border = true
    PAGES.each_with_index do |title, i|
      @w[:nb].append_page(build_page(i), Gtk::Label.new(title))
    end
    root.pack_start(@w[:nb], true, true, 0)
    root.pack_start(mk_hsep, false, false, 2)

    nav = mk_hbox(8)
    @w[:btn_cancel] = Gtk::Button.new("Cancel")
    @w[:btn_save]   = Gtk::Button.new("Save and Exit")
    @w[:btn_cancel].signal_connect("clicked") { @win.destroy; signal_setup_done }
    @w[:btn_save].signal_connect("clicked")   { do_save }
    ver_lbl = Gtk::Label.new("v#{SCRIPT_VERSION}")
    begin; ver_lbl.override_color(:normal, Gdk::RGBA.new(0.55, 0.55, 0.55, 1.0)); rescue nil; end
    nav.pack_start(@w[:btn_cancel], false, false, 0)
    nav.pack_start(ver_lbl, true, true, 0)
    nav.pack_end(@w[:btn_save], false, false, 0)
    root.pack_start(nav, false, false, 0)

    @win.add(root)
    @win.show_all

    # Enforce mutual exclusion after all widgets are shown
    Gtk.queue do
      if @w[:soc_escape_enabled]&.active?
        @w[:use_safe_room]&.active    = false
        @w[:use_safe_room]&.sensitive = false
        @w[:retreat_room]&.sensitive  = false
      elsif @w[:use_safe_room]&.active?
        @w[:soc_escape_enabled]&.active    = false
        @w[:soc_escape_enabled]&.sensitive = false
        @w[:soc_escape_ignore_floors]&.sensitive = false
      end
    end

    update_profession_tabs = proc do
      prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue "") || ""
      songs_pg    = @w[:nb].get_nth_page(10)
      rogue_pg    = @w[:nb].get_nth_page(11)
      warrior_pg  = @w[:nb].get_nth_page(12)
      songs_pg.visible   = !!(prof =~ /Bard/i)     if songs_pg
      rogue_pg.visible   = !!(prof =~ /Rogue/i)    if rogue_pg
      warrior_pg.visible = !!(prof =~ /Warrior/i)  if warrior_pg
    end

    update_weapon_tabs = proc do
      pri_grip       = (WEAPON_TYPES[@w[:primary_type]&.active.to_i] || {})[:grip].to_s
      is_runestaff   = pri_grip == "runestaff"
      wpn_rot_pg     = @w[:nb].get_nth_page(6)
      spell_rot_pg   = @w[:nb].get_nth_page(7)
      wpn_rot_pg&.visible   = !is_runestaff
      spell_rot_pg&.visible = is_runestaff
    end

    Gtk.queue { update_profession_tabs.call; update_weapon_tabs.call }
    @w[:char_prof]&.signal_connect("changed")   { Gtk.queue { update_profession_tabs.call } }
    @w[:primary_type]&.signal_connect("changed") { Gtk.queue { update_weapon_tabs.call } }
  end

  def self.dual_wield?
    @w[:dual_wield]&.active? rescue false
  end

  # ===========================================================================
  # Page dispatch
  # ===========================================================================
  def self.build_page(idx)
    inner = case idx
    when 0  then pg_character
    when 1  then pg_hunting1
    when 2  then pg_hunting2
    when 3  then pg_society
    when 4  then pg_spells
    when 5  then pg_weapon
    when 6  then pg_combat_abilities
    when 7  then pg_spell_rotation
    when 8  then pg_cmans_techniques
    when 9  then pg_defense
    when 10 then pg_songs
    when 11 then pg_rogue_guild
    when 12 then pg_warrior_guild
    when 13 then pg_mount
    when 14 then pg_scripts
    when 15 then pg_trinkets
    when 16 then pg_arcarium
    when 17 then pg_gemstones
    else Gtk::Label.new("Unknown page #{idx}")
    end
    sw = Gtk::ScrolledWindow.new
    sw.set_policy(:never, :automatic)
    sw.add_with_viewport(inner)
    sw
  end

  # ===========================================================================
  # GTK helpers
  # ===========================================================================
  def self.scrolled(widget)
    s = Gtk::ScrolledWindow.new
    s.set_policy(Gtk::POLICY_NEVER, Gtk::POLICY_AUTOMATIC)
    s.add_with_viewport(widget)
    s
  end

  def self.lrow(label_str, widget)
    hb = mk_hbox(6)
    l  = Gtk::Label.new(label_str)
    l.xalign = 0.0
    hb.pack_start(l, false, false, 0)
    hb.pack_start(widget, true, true, 0)
    hb
  end

  def self.w_entry(key, default = "")
    e = Gtk::Entry.new
    e.text = default.to_s
    @w[key] = e
    e
  end

  def self.w_spin(key, val, lo, hi)
    adj = Gtk::Adjustment.new(val.to_f, lo.to_f, hi.to_f, 1.0, 5.0, 0.0)
    s   = Gtk::SpinButton.new(adj, 1, 0)
    @w[key] = s
    s
  end

  def self.w_combo(key, opts, idx = 0)
    c = mk_combo_text(opts, idx)
    @w[key] = c
    c
  end

  def self.w_check(key, lbl, default = false)
    cb = Gtk::CheckButton.new(lbl)
    cb.active = default
    @w[key] = cb
    cb
  end

  def self.frame_vbox(title)
    f = Gtk::Frame.new(title)
    b = mk_vbox(3)
    b.border_width = 6
    f.add(b)
    [f, b]
  end

  def self.add_row(vb, label, widget)
    vb.pack_start(lrow(label, widget), false, false, 3)
  end

  # ===========================================================================
  # Pages
  # ===========================================================================

  def self.fuzzy_idx(list, raw)
    return 0 if raw.nil? || raw.strip.empty?
    q = raw.strip.downcase
    # exact match first
    i = list.index { |e| e.downcase == q }
    return i if i
    # list entry starts with query (e.g. "Sylvankind" matches "Sylvan")
    i = list.index { |e| e.downcase.start_with?(q) }
    return i if i
    # query starts with list entry (e.g. "Sylvan" is prefix of query "Sylvankind" -- unlikely but safe)
    i = list.index { |e| q.start_with?(e.downcase) }
    return i if i
    # substring in either direction
    i = list.index { |e| e.downcase.include?(q) || q.include?(e.downcase) }
    i || 0
  end

  GS_RACES = %w[
    Aelotoi Dark\ Elf Dwarf Elf Erithian Giantman Gnome Half-Elf
    Halfling Human Krolvin Sylvankind
  ].freeze

  GS_PROFESSIONS = %w[
    Bard Cleric Empath Monk Paladin Ranger
    Rogue Savant Sorcerer Warrior Wizard
  ].freeze

  GS_LEVELS = (120).downto(1).map(&:to_s).freeze

  def self.pg_character
    d     = @detected || {}
    vb    = mk_vbox(6)
    vb.border_width = 10
    lbl   = Gtk::Label.new("Auto-detected from your current login. Change any field if needed.")
    lbl.xalign = 0.0
    vb.pack_start(lbl, false, false, 5)

    race_idx = fuzzy_idx(GS_RACES,        d[:race].to_s)
    prof_idx = fuzzy_idx(GS_PROFESSIONS,  d[:prof].to_s)
    lvl_idx  = GS_LEVELS.index(d[:level].to_s) || 0

    add_row(vb, "Name:",       w_entry(:char_name, d[:name] || "Unknown"))
    add_row(vb, "Race:",       w_combo(:char_race, GS_RACES,        race_idx))
    add_row(vb, "Profession:", w_combo(:char_prof, GS_PROFESSIONS,  prof_idx))
    add_row(vb, "Level:",      w_combo(:char_level, GS_LEVELS,      lvl_idx))

    vb.pack_start(mk_hsep, false, false, 6)
    note = Gtk::Label.new("")
    note.xalign = 0.0
    note.set_line_wrap(true)
    note.set_markup(
      "<i><span foreground='#888888'>" \
      "Settings save per character. Run <b>;gshunting4all setup</b> any time to update.\n\n" \
      "<b>Quick-start checklist</b>\n" \
      "  1. Weapons tab -- set weapon noun, type, and grip\n" \
      "  2. Defense tab -- set armor noun; shield noun if applicable\n" \
      "  3. Society tab -- choose society and pick symbols/sigils to maintain\n" \
      "  4. Spells tab -- check off spells to keep maintained during hunts\n" \
      "  5. Rotation tab (see below) -- build your attack sequence\n" \
      "  6. Hunting Preferences -- set at least one escape option before your first hunt\n\n" \
      "<b>Tab guide</b>\n\n" \
      "<b>Hunting Preferences / Hunting Preferences 2</b>\n" \
      "Health/mana/wound retreat thresholds, stamina and mana floors, dread settings, " \
      "AoE threshold, NPC priority, eloot mode, and escape options. Set an escape option here before hunting.\n\n" \
      "<b>Society</b>\n" \
      "Select your society and rank. Choose maintained passives and on-demand abilities. " \
      "Offensive society abilities are slotted in the Weapon Attack Rotation tab.\n\n" \
      "<b>Spells</b>\n" \
      "Check off every spell you want maintained between fights. " \
      "Profession-specific emergency spells (e.g. 1635 BESEECH, 1650 Incarnation) are configured here too.\n\n" \
      "<b>Weapons</b>\n" \
      "Set your weapon noun, type, grip, and any weapon scripts (Valence, Animalistic Spirit, etc.). " \
      "Dual-wield and ambush settings are here. The script equips your weapon at hunt start automatically.\n\n" \
      "<b>Weapon Attack Rotation</b>  <i>(hidden for runestaff users)</i>\n" \
      "Build your single-target and AoE attack cycle. Slots can hold CMans, weapon techniques, " \
      "feats, society attacks, vissi, trinket abilities, spells, and more. " \
      "Melee and hybrid classes (e.g. Paladin, Ranger) use this tab. " \
      "Adding a slot type here grays it out on its own tab to prevent double-firing.\n\n" \
      "<b>Spell Attack Rotation</b>  <i>(runestaff users only)</i>\n" \
      "Pure casters set their single-target and AoE spell cast order here. " \
      "Hidden unless your primary weapon is a runestaff.\n\n" \
      "<b>CMANs &amp; Techniques</b>\n" \
      "View your detected combat maneuvers and weapon techniques. " \
      "Enable/disable each one and configure its verb, stamina cost, and cooldown. " \
      "Non-passive CMans and techniques can be slotted into the Weapon Attack Rotation.\n\n" \
      "<b>Defense</b>\n" \
      "Set armor noun and ASG, shield noun, and shield/armor specializations.\n\n" \
      "<b>Songs</b>  <i>(Bards only)</i>\n" \
      "Configure sonic weapon, sonic shield, and sonic armor. Set defensive and utility song maintenance.\n\n" \
      "<b>Rogue Guild</b>  <i>(Rogues only)</i>\n" \
      "Configure guild stun response and Silent Strike behavior.\n\n" \
      "<b>Warrior Guild</b>  <i>(Warriors only)</i>\n" \
      "Enable berserk, warcries, FEINT, and SPIT. Warcries enabled here appear in the Weapon Attack Rotation dropdown.\n\n" \
      "<b>Mount</b>\n" \
      "Enable mount charge and trample if you have a combat mount. Configure charge distance and stamina limits.\n\n" \
      "<b>Scripts</b>\n" \
      "View detected weapon/armor scripts (Valence, etc.) and configure which abilities fire and when.\n\n" \
      "<b>Trinkets</b>\n" \
      "Configure energy wings, battle standard, elemental/twisted gloves, and other activated trinkets.\n\n" \
      "<b>Arcarium (Vissi)</b>\n" \
      "Configure aversaris and vangaris arcarium vissi -- enable each, set when it fires, daily limits, and cooldowns.\n\n" \
      "<b>Gemstones</b>\n" \
      "Register your enhancive gemstones. Activated gemstone abilities can be slotted in the Weapon Attack Rotation.\n\n" \
      "<b>Grouping</b>\n" \
      "Group membership is auto-detected -- no setup needed. Retreat triggers (health, mana, dread, encumbrance) " \
      "are suppressed while grouped. The <b>Grouped mode</b> toggle on Hunting Preferences controls " \
      "wound retreat suppression only. Anti-poaching is always active." \
      "</span></i>"
    )
    vb.pack_start(note, false, false, 4)

    scrolled(vb)
  end

  def self.pg_society
    d   = @detected || {}
    soc = d[:society]
    vb  = mk_vbox(6)
    vb.border_width = 10

    if soc
      det_lbl = Gtk::Label.new("Detected: #{soc}  (rank #{d[:society_rank] || '?'})")
      det_lbl.xalign = 0.0
      rank_note = Gtk::Label.new("Abilities you have not yet learned are shown grayed out and cannot be selected.")
      rank_note.xalign = 0.0
      rank_note.wrap   = true
      vb.pack_start(det_lbl,    false, false, 4)
      vb.pack_start(rank_note,  false, false, 2)
      @w[:society_name_val] = soc
      @w[:society_rank_val] = d[:society_rank] || 1
      build_society_options(vb, soc, d[:society_rank] || 1)
    else
      none_lbl = Gtk::Label.new("Society not detected. Select yours:")
      none_lbl.xalign = 0.0
      vb.pack_start(none_lbl, false, false, 4)

      soc_combo = w_combo(:society_picker, ["None", "Voln", "Sunfist", "CoL"], 0)
      rank_sp   = w_spin(:society_rank_sp, 1, 1, 300)
      add_row(vb, "Society:", soc_combo)
      add_row(vb, "Rank:",    rank_sp)
      @w[:society_name_val] = nil
      @w[:society_rank_val] = 1

      @w[:society_options_box] = mk_vbox(4)
      vb.pack_start(@w[:society_options_box], false, false, 4)

      soc_combo.signal_connect("changed") do
        sel = ["None", "Voln", "Sunfist", "CoL"][soc_combo.active] rescue "None"
        @w[:society_name_val] = sel == "None" ? nil : sel
        @w[:society_options_box].children.each { |c| @w[:society_options_box].remove(c) }
        build_society_options(@w[:society_options_box], sel, rank_sp.value.to_i) unless sel == "None"
        @w[:society_options_box].show_all
      end
    end

    scrolled(vb)
  end

  def self.build_society_options(container, soc, rank)
    data = SOCIETY_DATA[soc]
    return unless data

    saved_soc     = (@profile.dig("society") || {}) rescue {}
    saved_maintain  = (saved_soc["maintain"]  || []).map { |e| e["name"] }
    saved_ondemand  = (saved_soc["on_demand"] || []).map { |e| e["name"] }
    has_saved = saved_soc["name"] == soc && (!saved_maintain.empty? || !saved_ondemand.empty?)

    mf, mb = frame_vbox("Maintain between fights (buffs)")
    @w[:"#{soc.downcase}_maintain"] = {}
    data[:maintain].each do |e|
      required_rank = e[:rank] || 1
      unlocked = rank >= required_rank
      label = unlocked ? "#{e[:name]}  --  #{e[:desc]}" : "#{e[:name]}  [requires rank #{required_rank}]"
      cb = Gtk::CheckButton.new(label)
      cb.active    = unlocked && (has_saved ? saved_maintain.include?(e[:name]) : true)
      cb.sensitive = unlocked
      @w[:"#{soc.downcase}_maintain"][e[:name]] = cb
      mb.pack_start(cb, false, false, 1)
    end
    container.pack_start(mf, false, false, 4)

    odf, odb = frame_vbox("On-Demand Abilities")
    od_note = Gtk::Label.new
    od_note.markup = "<i><span foreground='#888888'>These abilities fire automatically when their condition is met (e.g. mana restoration fires when mana is low). " \
                     "Offensive/attack abilities have been moved to the Weapon Attack Rotation tab -- slot them there to control when and in what order they fire.</span></i>"
    od_note.wrap = true; od_note.xalign = 0.0
    odb.pack_start(od_note, false, false, 3)
    @w[:"#{soc.downcase}_ondemand"] = {}
    default_on_demand = %w[Symbol\ of\ Mana Sign\ of\ Healing Sign\ of\ Wracking]
    data[:on_demand].each do |e|
      next if e[:name] == "Symbol of Restoration"
      required_rank = e[:rank] || 1
      unlocked = rank >= required_rank
      label = unlocked ? "#{e[:name]}  --  #{e[:desc]}" : "#{e[:name]}  [requires rank #{required_rank}]"
      cb = Gtk::CheckButton.new(label)
      if unlocked
        cb.active = has_saved ? saved_ondemand.include?(e[:name]) : default_on_demand.include?(e[:name])
      else
        cb.active    = false
        cb.sensitive = false
      end
      @w[:"#{soc.downcase}_ondemand"][e[:name]] = cb
      odb.pack_start(cb, false, false, 1)
    end


    container.pack_start(odf, false, false, 4)

    # Voln rank 10+: note about Symbol of Restoration auto-healing via priority list
    if soc == "Voln" && rank >= 10
      rf, rb = frame_vbox("Automatic Healing -- Symbol of Restoration")
      rdesc = Gtk::Label.new(
        "Symbol of Restoration restores up to half your lost HP. Add it to the Low Health Priority\n" \
        "list (Hunting Preferences tab) to control when it fires and in what order. It is NOT listed\n" \
        "in On-Demand Abilities -- the Low Health Priority list is the sole trigger."
      )
      rdesc.xalign = 0.0; rdesc.set_line_wrap(true)
      rb.pack_start(rdesc, false, false, 3)
      container.pack_start(rf, false, false, 4)
    end
  end

  # Build the fields for one weapon slot (noun + type + sub-panels).
  # Always loads from saved profile -- no inventory auto-detection.
  def self.build_weapon_fields(which, offhand: false)
    saved_wpn  = (@profile.dig("weapons", which) || {}) rescue {}
    noun       = saved_wpn["noun"] || ""
    saved_type = saved_wpn["type"] || "1he"
    # Off-hand (secondary) can only be 1HE or 1HB -- hard restriction
    type_list  = offhand ? WEAPON_TYPES.select { |t| %w[1he 1hb].include?(t[:code]) } : WEAPON_TYPES
    tidx       = type_list.index { |t| t[:code] == saved_type } || 0
    enabled    = saved_wpn.fetch("enabled", which == "primary")
    vb         = mk_vbox(4)

    enabled_cb = w_check(:"#{which}_enabled", "I am using a #{which} weapon", enabled)
    vb.pack_start(enabled_cb, false, false, 2)

    # Bard-only: sonic weapon option inside the primary slot
    is_bard = ((GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "")) =~ /Bard/i
    if which == "primary" && is_bard
      saved_sonic_wpn = saved_wpn.fetch("sonic_weapon", false)
      @w[:sonic_weapon_primary] = Gtk::CheckButton.new("I am fighting with a Sonic Weapon (spell 1012) -- weapon type comes from the Songs tab")
      @w[:sonic_weapon_primary].active = saved_sonic_wpn
      vb.pack_start(@w[:sonic_weapon_primary], false, false, 2)
    end

    fields_box = mk_vbox(4)
    fields_box.sensitive = enabled

    enabled_cb.signal_connect("toggled") { fields_box.sensitive = enabled_cb.active? }

    # When sonic weapon is active, physical noun/type fields are irrelevant
    if which == "primary" && is_bard
      sonic_note = Gtk::Label.new("Sonic Weapon active -- weapon noun and type are set in the Songs tab.")
      sonic_note.xalign = 0.0
      sonic_note.wrap   = true
    end

    type_combo = w_combo(:"#{which}_type", type_list.map { |t| t[:label] }, tidx)

    if which == "primary" && is_bard
      noun_row = lrow("Weapon noun:", w_entry(:"#{which}_noun", noun))
      type_row = lrow("Weapon type:", type_combo)
      fields_box.pack_start(noun_row,    false, false, 3)
      fields_box.pack_start(type_row,    false, false, 3)
      fields_box.pack_start(sonic_note,  false, false, 2)
      sonic_on = @w[:sonic_weapon_primary].active?
      Gtk.queue do
        sonic_note.visible = sonic_on
        noun_row.visible   = !sonic_on
        type_row.visible   = !sonic_on
      end
      @w[:sonic_weapon_primary].signal_connect("toggled") do
        on = @w[:sonic_weapon_primary].active?
        sonic_note.visible = on
        noun_row.visible   = !on
        type_row.visible   = !on
      end
    else
      add_row(fields_box, "Weapon noun:", w_entry(:"#{which}_noun", noun))
      add_row(fields_box, "Weapon type:", type_combo)
    end

    saved_loc = saved_wpn["target_location"].to_s.strip
    loc_labels = ["(none -- center mass)"] + AIM_LOCATIONS.map(&:capitalize)
    loc_idx = saved_loc.empty? ? 0 : (AIM_LOCATIONS.index(saved_loc.downcase).to_i + 1)
    add_row(fields_box, "Aim body part:", w_combo(:"#{which}_target_loc", loc_labels, loc_idx))

    unless offhand
      # ---- Polearm sub-panel (one-handed with shield vs two-handed) ----
      pol_frame, pol_fb = frame_vbox("Polearm Grip")
      saved_pol_shield  = saved_wpn.fetch("polearm_with_shield", false)
      @w[:"#{which}_pol_shield"] = mk_combo_text(
        ["Two-handed (no shield)", "One-handed with shield"],
        saved_pol_shield ? 1 : 0
      )
      pol_fb.pack_start(lrow("How are you using this polearm?", @w[:"#{which}_pol_shield"]), false, false, 2)
      polearm_type_idx = type_list.index { |t| t[:code] == "polearm" }
      fields_box.pack_start(pol_frame, false, false, 4)
      Gtk.queue { pol_frame.visible = (tidx == polearm_type_idx) }

      # ---- Ranged sub-panel (shown only when type == Ranged) ----
      rng_noun      = saved_wpn["ranged_noun"] || ""
      rng_subtype   = saved_wpn["ranged_subtype"] || "bow"
      rng_container = saved_wpn["ammo_container"] || "quiver"
      rng_aim       = saved_wpn.fetch("aim_first", true)
      rng_warn      = (saved_wpn["ammo_warn_at"] || 10).to_f
      rng_sub_idx   = RANGED_SUBTYPES.index(rng_subtype) || 0

      rng_frame, rng_fb = frame_vbox("Ranged Settings")
      @w[:"#{which}_ranged_noun"] = Gtk::Entry.new.tap { |e| e.text = rng_noun }
      @w[:"#{which}_ranged_sub"]  = mk_combo_text(
        ["Bow (long bow, short bow, composite bow)",
         "Crossbow (light, heavy -- must LOAD between shots)",
         "Sling (bullets/stones in container)",
         "Thrown (bola, dart, discus, etc -- items land on ground)"],
        rng_sub_idx)
      @w[:"#{which}_ammo_cont"]  = Gtk::Entry.new.tap { |e| e.text = rng_container }
      @w[:"#{which}_aim_first"]  = Gtk::CheckButton.new("Use AIM before shooting (longer RT, better accuracy)")
      @w[:"#{which}_aim_first"].active = rng_aim
      @w[:"#{which}_ammo_warn"]  = Gtk::SpinButton.new(
        Gtk::Adjustment.new(rng_warn, 0.0, 999.0, 1.0, 5.0, 0.0), 1, 0)

      rnoun_row = lrow("Ranged weapon noun:", @w[:"#{which}_ranged_noun"])
      ammo_row  = lrow("Ammo container noun:", @w[:"#{which}_ammo_cont"])
      warn_row  = lrow("Warn / stop hunting when ammo falls below:", @w[:"#{which}_ammo_warn"])
      aim_row   = @w[:"#{which}_aim_first"]

      rng_fb.pack_start(rnoun_row, false, false, 2)
      rng_fb.pack_start(lrow("Sub-type:", @w[:"#{which}_ranged_sub"]), false, false, 2)
      rng_fb.pack_start(ammo_row, false, false, 2)
      rng_fb.pack_start(Gtk::Label.new(
        "Enter the noun of the container holding your arrows/bolts/stones.\n" \
        "Examples: quiver, case, pouch, satchel"
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 0)
      rng_fb.pack_start(aim_row,  false, false, 2)
      rng_fb.pack_start(warn_row, false, false, 2)
      rng_fb.pack_start(Gtk::Label.new(
        "Set to 0 to disable the ammo check. Script will stop hunting and alert you when count drops to this threshold."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 2)

      rng_hide   = saved_wpn.fetch("hide_to_shoot", false)
      rng_608    = saved_wpn.fetch("use_608_hide",  false)
      rng_kneel  = saved_wpn.fetch("kneel_crossbow", false)
      rng_stay   = saved_wpn.fetch("stay_kneeling",  false)
      is_ranger  = ((GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "")) =~ /Ranger/i

      @w[:"#{which}_hide_to_shoot"]  = Gtk::CheckButton.new("Hide before each shot (open ambush -- Rangers/Rogues with Hiding skill)")
      @w[:"#{which}_hide_to_shoot"].active = rng_hide
      @w[:"#{which}_use_608_hide"]   = Gtk::CheckButton.new("Use Camouflage (608) to enter stealth instead of HIDE (Rangers only -- costs mana; skipped if mana is low)")
      @w[:"#{which}_use_608_hide"].active    = rng_608
      @w[:"#{which}_use_608_hide"].sensitive = rng_hide && is_ranger
      @w[:"#{which}_hide_to_shoot"].signal_connect("toggled") {
        @w[:"#{which}_use_608_hide"].sensitive = @w[:"#{which}_hide_to_shoot"].active? && is_ranger
      }
      @w[:"#{which}_kneel_crossbow"] = Gtk::CheckButton.new("Kneel before firing crossbow (+AS bonus; crossbow only)")
      @w[:"#{which}_kneel_crossbow"].active = rng_kneel
      @w[:"#{which}_stay_kneeling"]  = Gtk::CheckButton.new("Stay kneeling between shots (stand to move/loot)")
      @w[:"#{which}_stay_kneeling"].active  = rng_stay
      @w[:"#{which}_stay_kneeling"].sensitive = rng_kneel
      @w[:"#{which}_kneel_crossbow"].signal_connect("toggled") {
        @w[:"#{which}_stay_kneeling"].sensitive = @w[:"#{which}_kneel_crossbow"].active?
      }
      rng_fb.pack_start(mk_hsep, false, false, 3)
      rng_fb.pack_start(@w[:"#{which}_hide_to_shoot"],  false, false, 2)
      rng_fb.pack_start(@w[:"#{which}_use_608_hide"],   false, false, 2)
      rng_fb.pack_start(@w[:"#{which}_kneel_crossbow"], false, false, 2)
      rng_fb.pack_start(@w[:"#{which}_stay_kneeling"],  false, false, 2)

      update_ranged_sensitivity = proc {
        is_thrown = @w[:"#{which}_ranged_sub"].active == 3
        is_xbow   = @w[:"#{which}_ranged_sub"].active == 1
        ammo_row.sensitive  = !is_thrown
        warn_row.sensitive  = !is_thrown
        aim_row.sensitive   = !is_thrown
        rnoun_row.sensitive = !is_thrown
        @w[:"#{which}_kneel_crossbow"].sensitive = is_xbow
        @w[:"#{which}_stay_kneeling"].sensitive  = is_xbow && @w[:"#{which}_kneel_crossbow"].active?
      }
      @w[:"#{which}_ranged_sub"].signal_connect("changed") { update_ranged_sensitivity.call }
      update_ranged_sensitivity.call

      ranged_type_idx = type_list.index { |t| t[:code] == "ranged" }
      fields_box.pack_start(rng_frame, false, false, 4)
      Gtk.queue { rng_frame.visible = (tidx == ranged_type_idx) }
    end

    type_combo.signal_connect("changed") do
      next if offhand  # offhand combo only has 1HE/1HB -- no sub-panels to toggle
      pol_frame.visible = (type_combo.active == polearm_type_idx)
      rng_frame.visible = (type_combo.active == ranged_type_idx)
    end

    vb.pack_start(fields_box, false, false, 0)
    vb
  end

  def self.pg_weapon
    saved_dual = @profile.dig("weapons", "dual_wield") || false
    vb = mk_vbox(6)
    vb.border_width = 10

    note = Gtk::Label.new
    note.markup = "<i>Weapon attack rotation (single-target and AoE) is configured in the <b>Weapon Attack Rotation</b> tab.</i>"
    note.wrap = true
    note.xalign = 0.0
    vb.pack_start(note, false, false, 4)

    dual_cb = w_check(:dual_wield, "I am dual-wielding (two weapons simultaneously)", saved_dual)
    vb.pack_start(dual_cb, false, false, 3)

    dw_note = Gtk::Label.new("")
    dw_note.wrap = true
    dw_note.xalign = 0.0
    dw_note.set_markup(
      "<small><i><span foreground='#888888'>" \
      "Main hand: if using a katana, the script will automatically verify its grip is set to 1-handed before combat. " \
      "Off-hand type list is restricted to 1HE/1HB weapons. " \
      "Note: old katanas with a longsword or falchion base are valid off-hand choices." \
      "</span></i></small>"
    )
    vb.pack_start(dw_note, false, false, 0)
    Gtk.queue { dw_note.visible = saved_dual }
    dual_cb.signal_connect("toggled") { dw_note.visible = dual_cb.active? }

    vb.pack_start(mk_hsep, false, false, 2)

    pri_frame, pri_fb = frame_vbox("Primary (right hand)")
    pri_fb.pack_start(build_weapon_fields("primary"), false, false, 0)
    vb.pack_start(pri_frame, false, false, 4)

    # Warn when dual-wield is on but primary type is incompatible (2hw or polearm)
    dw_invalid_types = %w[2hw polearm]
    dw_warn = Gtk::Label.new("")
    dw_warn.set_markup("<b><span foreground='red'>Invalid dual-wield main hand: cannot use a Two-Handed or Polearm weapon in dual wield. Change weapon type above.</span></b>")
    dw_warn.wrap = true
    dw_warn.xalign = 0.0
    vb.pack_start(dw_warn, false, false, 0)
    check_dw_warn = proc {
      pri_type_code = (WEAPON_TYPES[@w[:primary_type]&.active.to_i] || {})[:code].to_s
      dw_warn.visible = dual_cb.active? && dw_invalid_types.include?(pri_type_code)
    }
    Gtk.queue { check_dw_warn.call }
    dual_cb.signal_connect("toggled") { check_dw_warn.call }
    @w[:primary_type]&.signal_connect("changed") { check_dw_warn.call }

    sec_frame, sec_fb = frame_vbox("Secondary (left hand / off-hand) -- 1HE/1HB weapons only")
    sec_fb.pack_start(build_weapon_fields("secondary", offhand: true), false, false, 0)
    vb.pack_start(sec_frame, false, false, 4)
    Gtk.queue { sec_frame.visible = saved_dual }

    dual_cb.signal_connect("toggled") { sec_frame.visible = dual_cb.active? }

    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""
    if prof =~ /Rogue|Ranger/i
      saved_amb = (@profile.dig("weapons", "ambush") || {}) rescue {}
      amb_frame, amb_fb = frame_vbox("Ambush Settings")
      @w[:ambush_enabled] = Gtk::CheckButton.new("Use AMBUSH instead of ATTACK when attacking")
      @w[:ambush_enabled].active = saved_amb.fetch("enabled", false)
      @w[:ambush_hide] = Gtk::CheckButton.new("Attempt to HIDE before each ambush (requires hiding skill)")
      @w[:ambush_hide].active = saved_amb.fetch("hide_first", false)
      @w[:ambush_hide].sensitive = @w[:ambush_enabled].active?
      @w[:ambush_enabled].signal_connect("toggled") { @w[:ambush_hide].sensitive = @w[:ambush_enabled].active? }
      amb_fb.pack_start(@w[:ambush_enabled], false, false, 2)
      amb_fb.pack_start(@w[:ambush_hide],    false, false, 2)
      vb.pack_start(amb_frame, false, false, 4)
    end

    if prof =~ /Paladin/i
      saved_hw   = (@profile.dig("weapons", "holy_weapon") || {}) rescue {}
      saved_lore = (@saved_config || {}).fetch("lore_ranks", {})
      smc_ranks  = (@detected || {}).dig(:lore_ranks, "SMC").to_i
      smc_ranks  = saved_lore["SMC"].to_i  if smc_ranks == 0
      summ_ranks = (@detected || {}).dig(:lore_ranks, "Summoning").to_i
      summ_ranks = saved_lore["Summoning"].to_i if summ_ranks == 0

      hw_frame, hw_fb = frame_vbox("Holy Weapon (1625) -- Paladin Only")

      @w[:hw_enabled] = Gtk::CheckButton.new("Enable Holy Weapon management")
      @w[:hw_enabled].active = saved_hw.fetch("enabled", false)

      # Build offensive spell list from Lich's live spell data.
      # Paladin has Minor Spiritual (100-140) and Paladin Base (1600-1635).
      # Include spells whose type contains "attack" or "offense" and are known.
      hw_spell_nums    = (100..140).to_a + (1600..1629).to_a
      hw_spell_exclude = [1609, 1617, 1618].to_set
      hw_spell_list = hw_spell_nums.filter_map do |n|
        next if hw_spell_exclude.include?(n)
        s = Spell[n] rescue nil
        next unless s && (s.known? rescue false)
        next unless s.type.to_s =~ /attack|offense/i
        [n.to_s, "#{n} - #{s.name}"]
      end
      hw_spell_list = [["1615", "1615 - Repentance"]] if hw_spell_list.empty?
      saved_spell  = saved_hw.fetch("spell", "1615").to_s
      spell_idx    = hw_spell_list.index { |k, _| k == saved_spell } || 0

      sp_row = mk_hbox(4)
      sp_row.pack_start(Gtk::Label.new("Spell to infuse:").tap { |l| l.xalign = 0.0 }, false, false, 0)
      @w[:hw_spell] = mk_combo_text(hw_spell_list.map { |_, lbl| lbl }, spell_idx)
      @w[:hw_spell_keys] = hw_spell_list.map { |k, _| k }
      sp_row.pack_start(@w[:hw_spell], false, false, 4)

      mode_row = mk_hbox(4)
      mode_row.pack_start(Gtk::Label.new("When to BESEECH:").tap { |l| l.xalign = 0.0 }, false, false, 0)
      hw_modes   = ["Before every attack (BESEECH IGNITE -- fires on every swing until depleted)",
                    "Once per target (BESEECH CONSERVE -- rearms on each new target)",
                    "Once at hunt start (BESEECH -- arms once, stays active until depleted)"]
      mode_keys  = ["per_attack", "per_target", "once"]
      mode_saved = mode_keys.index(saved_hw.fetch("mode", "per_target")) || 1
      @w[:hw_mode] = mk_combo_text(hw_modes, mode_saved)
      @w[:hw_mode_keys] = mode_keys
      mode_row.pack_start(@w[:hw_mode], false, false, 4)

      @w[:hw_autorefill] = Gtk::CheckButton.new("Auto-refill spell when charges run out")
      @w[:hw_autorefill].active = saved_hw.fetch("autorefill", true)

      smc_bonus   = (@detected || {}).dig(:lore_ranks, "SMC_bonus").to_i
      smc_bonus   = saved_lore["SMC_bonus"].to_i if smc_bonus == 0
      hw_capacity = 30 + (smc_bonus / 2)
      @w[:hw_info] = Gtk::Label.new("")
      @w[:hw_info].xalign = 0.0

      hw_update_info = proc {
        spell_num = (@w[:hw_spell_keys][@w[:hw_spell].active] rescue nil).to_i
        spell_num = saved_hw.fetch("spell", hw_spell_list.first&.first || "1615").to_i if spell_num == 0
        lvl  = spell_num >= 1600 ? spell_num - 1600 : spell_num - 100
        mult = (spell_num >= 1600 || (spell_num >= 101 && spell_num <= 140)) ? 1.0 : 1.25
        ch   = lvl > 0 ? (hw_capacity.to_f / (lvl * mult)).floor : 0
        @w[:hw_info].text = "Capacity: #{ch} charges (#{hw_capacity} mana)  |  SMC: #{smc_ranks} ranks  |  Summoning: #{summ_ranks} ranks"
      }
      hw_update_info.call
      @w[:hw_spell].signal_connect("changed") { hw_update_info.call }

      hw_sensitive = [sp_row, mode_row, @w[:hw_autorefill], @w[:hw_info]]
      hw_sensitive.each { |w| w.sensitive = @w[:hw_enabled].active? }
      @w[:hw_enabled].signal_connect("toggled") do
        on = @w[:hw_enabled].active?
        hw_sensitive.each { |w| w.sensitive = on }
      end

      hw_fb.pack_start(@w[:hw_enabled],    false, false, 2)
      hw_fb.pack_start(sp_row,             false, false, 2)
      hw_fb.pack_start(mode_row,           false, false, 2)
      hw_fb.pack_start(@w[:hw_autorefill], false, false, 2)
      hw_fb.pack_start(@w[:hw_info],       false, false, 2)
      vb.pack_start(hw_frame, false, false, 4)
    else
      @w[:hw_enabled] = nil
    end

    # ---- Weapon Recovery -------------------------------------------------------
    saved_wr = (@saved_config || {}).dig("weapons", "recovery") || {}
    rf, rb = frame_vbox("Weapon Recovery")
    rb.pack_start(Gtk::Label.new(
      "When your primary weapon leaves your hand, the script can attempt to recover it.\n" \
      "Uses the primary weapon noun configured above."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true)
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0)) }, false, false, 3)
    @w[:wr_use_119] = Gtk::CheckButton.new("Flying Weapon Recovery: cast Telekinesis (119) to retrieve weapon in mid-air (GET fallback if spell not known)")
    @w[:wr_use_119].active = saved_wr.fetch("use_119", false)
    rb.pack_start(@w[:wr_use_119], false, false, 2)
    @w[:wr_use_recover] = Gtk::CheckButton.new("Normal Disarm Recovery: use RECOVER ITEM when weapon is knocked to the ground")
    @w[:wr_use_recover].active = saved_wr.fetch("use_recover", false)
    rb.pack_start(@w[:wr_use_recover], false, false, 2)
    rb.pack_start(Gtk::Label.new(
      "Normal recovery sequence: stow both hands, kneel, RECOVER ITEM, stand.\n" \
      "Servant/demon fetch (configured in their tabs) fires first if available.\n" \
      "For Warrior/Paladin with bond auto-return: script waits 5s before attempting recovery."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true)
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0)) }, false, false, 2)
    vb.pack_start(rf, false, false, 4)

    scrolled(vb)
  end

  SCRIPT_SLOTS     = ["Primary Weapon", "Secondary Weapon", "Armor", "Shield"].freeze
  SCRIPT_SLOT_KEYS = [:primary, :secondary, :armor, :shield].freeze
  SCRIPT_WHEN_OPTS = ["per_attack", "aoe", "swarm", "CC'd", "maintenance", "target_vulnerable", "boss"].freeze

  def self.pg_scripts
    @script_entries = {}
    @scripts_vbox   = mk_vbox(6)
    outer = mk_vbox(8)
    outer.border_width = 10

    outer.pack_start(mk_hsep, false, false, 3)

    detected = (@detected || {})[:item_scripts] || []

    if detected.empty?
      hint = Gtk::Label.new(
        "No scripted items detected.\n" \
        "Items must be in hand or worn when setup runs for auto-detection.\n" \
        "Use 'Add Script' to add any scripted items manually."
      )
      hint.xalign = 0.0
      hint.set_line_wrap(true)
      outer.pack_start(hint, false, false, 5)
    else
      hint = Gtk::Label.new("Detected scripted items. Add more below if any were missed.")
      hint.xalign = 0.0
      outer.pack_start(hint, false, false, 5)
    end

    saved_disabled = (@profile["script_disabled"] || {}) rescue {}
    saved_when_all = {}
    saved_slot_for = {}
    saved_noun_for = {}
    saved_tier_for = {}
    [
      [@profile.dig("weapons", "primary",   "scripts"), :primary,   @profile.dig("weapons", "primary",   "noun").to_s],
      [@profile.dig("weapons", "secondary", "scripts"), :secondary, @profile.dig("weapons", "secondary", "noun").to_s],
      [@profile.dig("armor",   "scripts"),              :armor,     @profile.dig("armor",   "noun").to_s],
      [@profile.dig("shield",  "scripts"),              :shield,    @profile.dig("shield",  "noun").to_s],
    ].each do |scripts, slot_key, slot_noun|
      (scripts || []).each do |sc|
        nm = sc["name"].to_s
        ek = "#{nm}::#{slot_key}"
        saved_when_all[ek] ||= {}
        saved_slot_for[nm] ||= slot_key
        saved_noun_for[nm] ||= slot_noun
        saved_tier_for[nm] ||= sc["tier"].to_i
        (sc["abilities"] || []).each do |ab|
          saved_when_all[ek][ab["key"].to_s] = ab["when"].to_s if ab["when"]
        end
      end
    end

    detected.each { |s| add_script_entry(s[:name], s[:slot], s[:noun], s[:tier], s[:wing_type] || "Light", saved_disabled[s[:name]] || [], saved_when_all["#{s[:name]}::#{s[:slot]}"] || {}) }

    when_legend = Gtk::Label.new
    when_legend.set_markup(
      "<i><span foreground='#888888'>" \
      "<b>When options:</b>  " \
      "per_attack = fires every attack round  |  " \
      "aoe = multiple foes present (&gt;= your AoE threshold in Hunting Prefs)  |  " \
      "swarm = large group (&gt;= swarm threshold in Hunting Prefs)  |  " \
      "CC'd = while stunned / webbed / bound  |  " \
      "maintenance = between fights (out of combat, every loop)  |  " \
      "target_vulnerable = current target is stunned / webbed / prone  |  " \
      "boss = target matches a name on the Boss List (Hunting Preferences 2)" \
      "</span></i>"
    )
    when_legend.xalign = 0.0
    when_legend.wrap = true
    outer.pack_start(mk_hsep, false, false, 3)
    outer.pack_start(when_legend, false, false, 3)
    outer.pack_start(@scripts_vbox, false, false, 0)

    add_btn = Gtk::Button.new("+ Add Script")
    add_btn.signal_connect("clicked") { script_add_dialog }
    outer.pack_start(add_btn, false, false, 6)

    note = Gtk::Label.new
    note.markup = "<i>Script abilities added to the Weapon Attack Rotation are grayed out here -- they fire from the rotation and are suppressed in standalone mode to prevent double-firing.</i>"
    note.wrap = true; note.xalign = 0.0
    outer.pack_start(note, false, false, 4)

    @sync_cman_grayouts&.call
    scrolled(outer)
  end

  def self.add_script_entry(name, slot_key = :primary, noun = "", tier = 1, wing_type_str = "Light", disabled_keys = [], saved_when = {}, stale: false)
    slots_data = SCRIPT_TEMPLATES[name] || {}
    sf, sb = frame_vbox(name)

    if stale
      stale_lbl = Gtk::Label.new(
        "Not detected this session -- item may not be equipped.\n" \
        "If you no longer own this item, click Remove to clear it from your profile."
      )
      stale_lbl.xalign = 0.0
      stale_lbl.set_line_wrap(true)
      begin stale_lbl.override_color(:normal, Gdk::RGBA.new(0.75, 0.45, 0.0, 1.0)) rescue nil end
      sb.pack_start(stale_lbl, false, false, 4)
    end

    slot_idx = SCRIPT_SLOT_KEYS.index(slot_key) || 0
    slot_c   = mk_combo_text(SCRIPT_SLOTS, slot_idx)
    hint     = slots_data[:noun_hint].to_s
    noun_e   = Gtk::Entry.new
    noun_e.text = noun.to_s.empty? ? hint : noun.to_s
    noun_e.placeholder_text = hint unless hint.empty? rescue nil
    max_tier = (slots_data[:max_tier] || 6).to_f
    tier_adj = Gtk::Adjustment.new(tier.to_f, 1.0, max_tier, 1.0, 1.0, 0.0)
    tier_sp  = Gtk::SpinButton.new(tier_adj, 1, 0)
    detect_b = Gtk::Button.new("Detect Tier")
    rem_b    = Gtk::Button.new("Remove")

    sb.pack_start(lrow("Item slot:", slot_c), false, false, 3)
    sb.pack_start(lrow("Item noun:", noun_e), false, false, 3)

    # Energy Wings: Light vs Dark type selector
    wing_type_c = nil
    if name == "Energy Wings"
      wt_idx      = ENERGY_WINGS_TYPES.index(wing_type_str) || 0
      wing_type_c = mk_combo_text(ENERGY_WINGS_TYPES, wt_idx)
      sb.pack_start(lrow("Wing type:", wing_type_c), false, false, 3)
    end

    tier_hb = mk_hbox(6)
    tier_hb.pack_start(Gtk::Label.new("Tier:"), false, false, 0)
    tier_hb.pack_start(tier_sp,  false, false, 0)
    tier_hb.pack_start(detect_b, false, false, 6)
    tier_hb.pack_start(rem_b,    false, false, 6)
    sb.pack_start(tier_hb, false, false, 3)

    # Per-ability checkboxes + When dropdowns
    ability_checks = {}
    when_combos    = {}
    ab_vbox = mk_vbox(1)
    ab_hdr  = Gtk::Label.new("Abilities (uncheck to disable; choose when to fire):")
    ab_hdr.xalign = 0.0
    sb.pack_start(ab_hdr, false, false, 4)

    build_ability_checks = lambda do
      ab_vbox.children.each { |c| ab_vbox.remove(c) }
      wt_sym   = wing_type_c ? ENERGY_WINGS_TYPES[wing_type_c.active].to_s.downcase.to_sym : nil
      cur_tier = tier_sp.value.to_i
      slot_key_raw = SCRIPT_SLOT_KEYS[slot_c.active] rescue nil
      active_slot = { primary: :weapon, secondary: :weapon, armor: :armor, shield: :shield }[slot_key_raw]
      slots_to_show = active_slot && slots_data.key?(active_slot) ? [active_slot] : slots_data.keys
      slots_to_show.each do |slot_sym|
        abilities = slots_data[slot_sym] || []
        abilities.reject { |a| a[:when] == "skip" || a[:when] == "toggle_startup" }.each do |a|
          next if a[:min_tier] && a[:min_tier] > cur_tier
          next if wt_sym && a[:type] && a[:type] != :both && a[:type] != wt_sym
          key = "#{slot_sym}:#{a[:key]}"

          prev_cb = ability_checks[key]
          checked = prev_cb ? prev_cb.active? : !disabled_keys.include?(key)
          cb = Gtk::CheckButton.new("#{a[:key].upcase} -- #{a[:desc]}")
          cb.active = checked
          ability_checks[key] = cb

          default_when = saved_when[a[:key].to_s]
          default_when = a[:when].to_s if default_when.nil? || default_when.empty?
          default_when = "CC'd" if default_when == "emergency"
          prev_wc = when_combos[key]
          prev_idx = prev_wc ? prev_wc.active : nil
          when_idx = SCRIPT_WHEN_OPTS.index(default_when) || 1
          when_idx = prev_idx if prev_idx
          when_c = mk_combo_text(SCRIPT_WHEN_OPTS, when_idx)
          when_combos[key] = when_c

          row_hb = mk_hbox(4)
          row_hb.pack_start(cb,                         true,  true,  0)
          row_hb.pack_start(Gtk::Label.new("When:"),    false, false, 4)
          row_hb.pack_start(when_c,                     false, false, 0)
          ab_vbox.pack_start(row_hb, false, false, 2)
        end
      end
      ab_vbox.show_all
      # Store widget refs for grayout by rotation
      @w[:script_wpn_widgets] ||= {}
      @w[:script_arm_widgets] ||= {}
      ability_checks.each do |key, cb|
        # key format is "slot_sym:ab_key" e.g. "weapon:wave" or "armor:knock"
        ab_key = key.split(":", 2).last
        slot_sk = SCRIPT_SLOT_KEYS[slot_c.active] rescue nil
        if [:primary, :secondary].include?(slot_sk)
          @w[:script_wpn_widgets][ab_key] = [cb, when_combos[key]].compact
        elsif slot_sk == :armor
          @w[:script_arm_widgets][ab_key] = [cb, when_combos[key]].compact
        end
      end
      @sync_cman_grayouts&.call
    end

    build_ability_checks.call
    slot_c.signal_connect("changed")           { build_ability_checks.call }
    wing_type_c.signal_connect("changed")      { build_ability_checks.call } if wing_type_c
    tier_sp.signal_connect("value-changed")    { build_ability_checks.call }
    sb.pack_start(ab_vbox, false, false, 2)

    detect_b.signal_connect("clicked") do
      n = noun_e.text.strip
      next if n.empty?
      detect_b.label     = "Detecting..."
      detect_b.sensitive = false
      Thread.new do
        out  = capture_detect("analyze my #{n}", 3.0)
        tier = if    out =~ /tier\s*(\d)/i then $1.to_i
                 elsif out =~ /\bT(\d)\b/   then $1.to_i
                 else nil end
        Gtk.queue do
          tier ? (tier_sp.value = tier.to_f; detect_b.label = "Detected: T#{tier}") \
               : (detect_b.label = "Not found")
          detect_b.sensitive = true
        end
      end
    end

    entry_key = "#{name}::#{slot_key}"
    rem_b.signal_connect("clicked") do
      @script_entries.delete(entry_key)
      @scripts_vbox.remove(sf)
    end

    @scripts_vbox.pack_start(sf, false, false, 4)
    @scripts_vbox.show_all
    @script_entries[entry_key] = { name: name, slot: slot_c, noun: noun_e, tier: tier_sp, wing_type: wing_type_c, ability_checks: ability_checks, when_combos: when_combos }
  end

  def self.script_add_dialog
    d = Gtk::Dialog.new("Add Script", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(400, 160)
    name_c = mk_combo_text(SCRIPT_TEMPLATES.keys.sort, 0)
    d.vbox.pack_start(lrow("Script:", name_c), false, false, 6)
    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      name = SCRIPT_TEMPLATES.keys.sort[name_c.active]
      add_script_entry(name) unless @script_entries.any? { |_, e| e[:name] == name }
    end
    d.destroy
  end

  def self.pg_defense
    d    = @detected || {}
    vb   = mk_vbox(8)
    vb.border_width = 10

    # Armor frame
    af, ab = frame_vbox("Armor")
    armor_item = d[:armor]
    if armor_item
      dl = Gtk::Label.new("Detected: #{armor_item.name}")
      dl.xalign = 0.0
      ab.pack_start(dl, false, false, 2)
    end
    aidx = d[:armor_asg] ? armor_asg_idx(d[:armor_asg]) : 0
    armor_noun_row = lrow("Noun:", w_entry(:armor_noun, armor_item&.noun || "armor"))
    armor_type_row = lrow("Type:", w_combo(:armor_asg, ARMOR_TYPES.map { |t| t[:label] }, aidx))
    ab.pack_start(armor_noun_row, false, false, 3)
    ab.pack_start(armor_type_row, false, false, 3)
    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""
    if prof =~ /Bard/i
      saved_sonic_arm = @profile.dig("armor", "sonic_armor") || false
      @w[:sonic_armor_primary] = Gtk::CheckButton.new("I am wearing Sonic Armor (spell 1014) instead of physical armor")
      @w[:sonic_armor_primary].active = saved_sonic_arm
      bard_arm_note = Gtk::Label.new("Sonic Armor active -- armor noun and type are set in the Songs tab.")
      bard_arm_note.xalign = 0.0; bard_arm_note.wrap = true
      ab.pack_start(@w[:sonic_armor_primary], false, false, 2)
      ab.pack_start(bard_arm_note,            false, false, 2)
      sonic_on = saved_sonic_arm
      Gtk.queue do
        armor_noun_row.visible = !sonic_on
        armor_type_row.visible = !sonic_on
        bard_arm_note.visible  = sonic_on
      end
      @w[:sonic_armor_primary].signal_connect("toggled") do
        on = @w[:sonic_armor_primary].active?
        armor_noun_row.visible = !on
        armor_type_row.visible = !on
        bard_arm_note.visible  = on
      end
    end
    vb.pack_start(af, false, false, 4)

    # Shield frame
    sf, sb = frame_vbox("Shield")
    if d[:shield_name]
      dl = Gtk::Label.new("Detected in left hand: #{d[:shield_name]}")
      dl.xalign = 0.0
      sb.pack_start(dl, false, false, 2)
    end
    sb.pack_start(w_check(:shield_enabled, "I use a shield", d[:has_shield] || false), false, false, 3)
    shield_noun_row = lrow("Noun:", w_entry(:shield_noun, d[:shield_noun] || ""))
    sb.pack_start(shield_noun_row, false, false, 3)
    if prof =~ /Bard/i
      saved_sonic_shld = @profile.dig("shield", "sonic_shield") || false
      @w[:sonic_shield_primary] = Gtk::CheckButton.new("I am using a Sonic Shield (spell 1009) instead of a physical shield")
      @w[:sonic_shield_primary].active = saved_sonic_shld
      bard_shld_note = Gtk::Label.new("Sonic Shield active -- shield noun is set in the Songs tab. READY SHIELD is skipped automatically.")
      bard_shld_note.xalign = 0.0; bard_shld_note.wrap = true
      sb.pack_start(@w[:sonic_shield_primary], false, false, 2)
      sb.pack_start(bard_shld_note,            false, false, 2)
      sonic_on = saved_sonic_shld
      Gtk.queue do
        shield_noun_row.visible = !sonic_on
        bard_shld_note.visible  = sonic_on
      end
      @w[:shield_enabled].sensitive = !sonic_on
      @w[:sonic_shield_primary].signal_connect("toggled") do
        on = @w[:sonic_shield_primary].active?
        shield_noun_row.visible = !on
        bard_shld_note.visible  = on
        @w[:shield_enabled].sensitive = !on
      end
    end
    vb.pack_start(sf, false, false, 4)

    # ---- Shield Specializations -----------------------------------------------
    has_any_ss   = Array(d[:shield_specs]).any?
    if !has_any_ss
      ssf = Gtk::Frame.new("Shield Specializations")
      ssf.add(Gtk::Label.new("No shield specializations trained yet -- section will appear once you train one.").tap { |l| l.xalign = 0.0; l.wrap = true })
      @shield_spec_store = nil
      vb.pack_start(ssf, false, false, 4)
    else
    ssf, ssb = frame_vbox("Shield Specializations (from SHIELD INFO)")
    ss_hint = Gtk::Label.new(
      "Detected shield specializations. Non-passive types (setup/assault/aoe) can be added to\n" \
      "the Weapon Attack Rotation -- if selected there they are grayed out here to prevent double-firing.\n" \
      "Check 'Use' to fire at engagement start; leave unchecked for passive/ignored abilities."
    )
    ss_hint.xalign = 0.0; ss_hint.set_line_wrap(true)
    ssb.pack_start(ss_hint, false, false, 3)
    ss_rot_note = Gtk::Label.new
    ss_rot_note.markup = "<i><span foreground='#b06000'>Grayed-out rows are in the Weapon Attack Rotation -- they fire from there and are suppressed here to prevent double-firing.</span></i>"
    ss_rot_note.xalign = 0.0; ss_rot_note.set_line_wrap(true)
    ssb.pack_start(ss_rot_note, false, false, 2)

    saved_ss = (@profile["shield_specs"] || []).map { |r| [r["name"], r] }.to_h
    # cols: enabled(bool), name, verb, type, min_creatures, row_sensitive(bool)
    @shield_spec_store = Gtk::ListStore.new(TrueClass, String, String, String, String, TrueClass)
    Array(d[:shield_specs]).each do |spec|
      name      = spec[:name]
      verb      = "shield #{spec[:mnemonic]}"
      tech_type = spec[:tech_type] || "setup"
      saved     = saved_ss[name]
      enabled   = saved ? saved["enabled"] : false
      iter = @shield_spec_store.append
      @shield_spec_store.set_value(iter, 0, enabled)
      @shield_spec_store.set_value(iter, 1, name)
      @shield_spec_store.set_value(iter, 2, verb)
      @shield_spec_store.set_value(iter, 3, tech_type)
      @shield_spec_store.set_value(iter, 4, spec[:min_creatures].to_s)
      @shield_spec_store.set_value(iter, 5, true)
    end

    ss_tv = Gtk::TreeView.new(@shield_spec_store)
    ss_tog = Gtk::CellRendererToggle.new; ss_tog.activatable = true
    ss_tog.signal_connect("toggled") do |_, path|
      it = @shield_spec_store.get_iter(path)
      @shield_spec_store.set_value(it, 0, !@shield_spec_store.get_value(it, 0)) if it && @shield_spec_store.get_value(it, 5)
    end
    ss_tv.append_column(Gtk::TreeViewColumn.new("Use", ss_tog, "active" => 0, "sensitive" => 5))
    [["Name", 1], ["Verb", 2], ["Type", 3]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @shield_spec_store.get_iter(path); @shield_spec_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i, "sensitive" => 5); c.resizable = true
      ss_tv.append_column(c)
    end
    ss_sw = Gtk::ScrolledWindow.new
    ss_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    ss_sw.add(ss_tv); ss_sw.set_size_request(-1, 120)
    ssb.pack_start(ss_sw, true, true, 0)
    vb.pack_start(ssf, true, true, 4)
    end # has_any_ss

    # ---- Armor Specializations ------------------------------------------------
    asf, asb = frame_vbox("Armor Specializations (from ARMOR INFO)")
    as_hint = Gtk::Label.new(
      "Detected armor specializations. Check 'Use' only for Buff-type specs (Support, Evasion, etc.).\n" \
      "The script re-applies them when the 4-hour buff expires, and skips firing when already active.\n" \
      "Passive specs (Spike Mastery, Crush/Puncture/Slash Protection) need no activation -- leave unchecked."
    )
    as_hint.xalign = 0.0; as_hint.set_line_wrap(true)
    asb.pack_start(as_hint, false, false, 3)

    saved_as = (@profile["armor_specs"] || []).map { |r| [r["name"], r] }.to_h
    # cols: enabled(bool), name, verb, type, min_creatures
    @armor_spec_store = Gtk::ListStore.new(TrueClass, String, String, String, String)
    Array(d[:armor_specs]).each do |spec|
      name      = spec[:name]
      verb      = "armor #{spec[:mnemonic]}"
      tech_type = spec[:tech_type] || "buff"
      saved     = saved_as[name]
      enabled   = saved ? saved["enabled"] : false  # Buff types are passive by default
      iter = @armor_spec_store.append
      @armor_spec_store.set_value(iter, 0, enabled)
      @armor_spec_store.set_value(iter, 1, name)
      @armor_spec_store.set_value(iter, 2, verb)
      @armor_spec_store.set_value(iter, 3, tech_type)
      @armor_spec_store.set_value(iter, 4, spec[:min_creatures].to_s)
    end

    as_tv = Gtk::TreeView.new(@armor_spec_store)
    as_tog = Gtk::CellRendererToggle.new; as_tog.activatable = true
    as_tog.signal_connect("toggled") { |_, path| it = @armor_spec_store.get_iter(path); @armor_spec_store.set_value(it, 0, !@armor_spec_store.get_value(it, 0)) if it }
    as_tv.append_column(Gtk::TreeViewColumn.new("Use", as_tog, "active" => 0))
    [["Name", 1], ["Verb", 2], ["Type", 3]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @armor_spec_store.get_iter(path); @armor_spec_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i); c.resizable = true
      as_tv.append_column(c)
    end
    as_sw = Gtk::ScrolledWindow.new
    as_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    as_sw.add(as_tv); as_sw.set_size_request(-1, 120)
    asb.pack_start(as_sw, true, true, 0)
    vb.pack_start(asf, true, true, 4)

    @sync_cman_grayouts&.call
    scrolled(vb)
  end

  def self.pg_mount
    vb  = mk_vbox(6)
    vb.border_width = 10
    sm         = (@saved_config || {})["mount"] || {}
    mount_on   = sm.fetch("enabled", false)
    enabled_cb = w_check(:mount_enabled, "I use mount combat", mount_on)
    vb.pack_start(enabled_cb, false, false, 3)

    # All dependent fields live in this container -- gray out when disabled
    mount_details = mk_vbox(4)

    @w[:mount_noun]  = Gtk::Entry.new.tap { |e| e.text = sm.fetch("noun",        "") }
    @w[:mount_sitem] = Gtk::Entry.new.tap { |e| e.text = sm.fetch("summon_item", "reins") }
    @w[:mount_sverb] = Gtk::Entry.new.tap { |e| e.text = sm.fetch("summon_verb", "wave") }
    add_row(mount_details, "Mount noun:",   @w[:mount_noun])
    add_row(mount_details, "Summon item:",  @w[:mount_sitem])
    add_row(mount_details, "Summon verb:",  @w[:mount_sverb])

    # Mount Charge row: checkbox + when dropdown
    charge_hb = mk_hbox(6)
    charge_hb.pack_start(w_check(:mount_charge, "Supports MOUNT CHARGE -- fires when:", sm.fetch("has_charge", false)), false, false, 0)
    @w[:mount_charge_when] = Gtk::ComboBoxText.new
    MOUNT_CHARGE_WHEN_OPTS.each { |o| @w[:mount_charge_when].append_text(o) }
    saved_cw = sm.fetch("charge_when", "aoe")
    @w[:mount_charge_when].active = MOUNT_CHARGE_WHEN_OPTS.index(saved_cw) || 0
    charge_hb.pack_start(@w[:mount_charge_when], false, false, 0)
    mount_details.pack_start(charge_hb, false, false, 2)

    # Mount Trample row: checkbox + when dropdown
    trample_hb = mk_hbox(6)
    trample_hb.pack_start(w_check(:mount_trample, "Supports MOUNT TRAMPLE -- fires when:", sm.fetch("has_trample", false)), false, false, 0)
    @w[:mount_trample_when] = Gtk::ComboBoxText.new
    MOUNT_TRAMPLE_WHEN_OPTS.each { |o| @w[:mount_trample_when].append_text(o) }
    saved_tw = sm.fetch("trample_when", "aoe")
    @w[:mount_trample_when].active = MOUNT_TRAMPLE_WHEN_OPTS.index(saved_tw) || 1
    trample_hb.pack_start(@w[:mount_trample_when], false, false, 0)
    mount_details.pack_start(trample_hb, false, false, 2)

    @w[:mount_charge_row_widgets]  = [@w[:mount_charge],  @w[:mount_charge_when]]
    @w[:mount_trample_row_widgets] = [@w[:mount_trample], @w[:mount_trample_when]]
    @w[:mount_details_container]   = mount_details

    mount_rot_note = Gtk::Label.new
    mount_rot_note.markup = "<i>If Mount Charge or Trample is added to the Weapon Attack Rotation, that row is grayed out here automatically -- it fires from the rotation instead and these settings are suppressed to prevent double-firing.</i>"
    mount_rot_note.wrap = true
    mount_rot_note.xalign = 0.0
    mount_details.pack_start(mount_rot_note, false, false, 4)

    mount_req_note = Gtk::Label.new(
      "Required when using the rotation: if Mount Charge or Trample is in your Weapon Attack Rotation, " \
      "'I use mount combat' is locked on automatically and a mount noun is required -- " \
      "the script needs it to remount you if you get knocked off."
    )
    mount_req_note.xalign = 0.0; mount_req_note.set_line_wrap(true)
    mount_req_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    mount_details.pack_start(mount_req_note, false, false, 2)

    vb.pack_start(mount_details, false, false, 0)
    mount_details.sensitive = mount_on

    enabled_cb.signal_connect("toggled") do |cb|
      mount_details.sensitive = cb.active?
      @sync_cman_grayouts&.call
    end
    @sync_cman_grayouts&.call
    scrolled(vb)
  end

  # Offensive spells eligible for the weapon rotation spell slot.
  # Filtered at build time to only spells the character knows (Spell[num].known?).
  # cmd: use "cast" for spells whose AoE only triggers via CAST, "incant" otherwise.
  OFFENSIVE_SPELLS = [
    # --- Paladin (1600s) ---
    {num: 1602, label: "1602 - Pray (undead AS debuff)",           cmd: "incant 1602"},
    {num: 1610, label: "1610 - Arm of the Arkati (attack)",       cmd: "incant 1610"},
    {num: 1614, label: "1614 - Aura of the Arkati (AoE)",         cmd: "cast 1614"},
    {num: 1616, label: "1616 - Smite/Bane (undead attack)",       cmd: "incant 1616"},
    {num: 1628, label: "1628 - Judgment (attack)",                 cmd: "incant 1628"},
    {num: 1630, label: "1630 - Divine Wrath (AoE)",               cmd: "cast 1630"},
    # --- Cleric Base (300s) ---
    {num: 302,  label: "302 - Smite (attack)",                    cmd: "incant 302"},
    {num: 306,  label: "306 - Holy Bolt (attack)",                cmd: "incant 306"},
    {num: 317,  label: "317 - Sounds (AoE attack)",               cmd: "incant 317"},
    {num: 325,  label: "325 - Harm Evil (undead attack)",         cmd: "incant 325"},
    {num: 330,  label: "330 - Divine Wrath (AoE)",               cmd: "cast 330"},
    # --- Empath Base (1100s) ---
    {num: 1109, label: "1109 - Empathic Assault (attack)",        cmd: "incant 1109"},
    {num: 1130, label: "1130 - Sympathy (AoE attack)",            cmd: "cast 1130"},
    # --- Wizard Base (900s) ---
    {num: 901,  label: "901 - Magic Missile (attack)",            cmd: "incant 901"},
    {num: 903,  label: "903 - Major E-Bolt (attack)",             cmd: "incant 903"},
    {num: 908,  label: "908 - Tremors (AoE knockdown)",           cmd: "incant 908"},
    {num: 910,  label: "910 - E-Bolt (attack)",                   cmd: "incant 910"},
    {num: 918,  label: "918 - Immolation (fire attack)",          cmd: "incant 918"},
    {num: 920,  label: "920 - Shock Wave (AoE attack)",           cmd: "cast 920"},
    # --- Sorcerer Base (700s) ---
    {num: 700,  label: "700 - Sorcerer's Curse (attack)",         cmd: "incant 700"},
    {num: 702,  label: "702 - Mana Disruption (attack)",          cmd: "incant 702"},
    {num: 710,  label: "710 - Curse (attack)",                    cmd: "incant 710"},
    {num: 720,  label: "720 - Dark Catalyst (AoE)",               cmd: "cast 720"},
    {num: 730,  label: "730 - Corrupt Essence (attack)",          cmd: "incant 730"},
    # --- Bard Base (1000s) ---
    {num: 1001, label: "1001 - Sonic Blast (attack)",             cmd: "incant 1001"},
    {num: 1015, label: "1015 - Sonic Strike (attack)",            cmd: "incant 1015"},
    {num: 1018, label: "1018 - Song of Rage (AoE attack)",        cmd: "cast 1018"},
    # --- Ranger Base (600s) ---
    {num: 610,  label: "610 - Tangle Weed (AoE snare)",          cmd: "incant 610"},
    {num: 635,  label: "635 - Whispering Willow (attack)",        cmd: "incant 635"},
    {num: 640,  label: "640 - Nature's Fury (AoE)",              cmd: "cast 640"},
    # --- Minor Elemental (400s) ---
    {num: 410,  label: "410 - Elemental Wave (AoE)",             cmd: "incant 410"},
    # --- Major Elemental (500s) ---
    {num: 510,  label: "510 - Elemental Blast (attack)",         cmd: "incant 510"},
    {num: 519,  label: "519 - Elemental Dispel (attack)",        cmd: "incant 519"},
  ].freeze

  def self.pg_spells
    d         = @detected || {}
    vb        = mk_vbox(6)
    vb.border_width = 10

    known     = Array(d[:known_spells])
    prof      = GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil
    is_bard   = prof =~ /Bard/i
    is_caster = CASTER_PROFESSIONS.include?(prof)
    # Spells managed elsewhere or handled specially -- exclude from the maintain list:
    #   1001-1040: Bard Base managed in Songs tab
    #   1607: Rejuvenation -- reactive HP/stamina heal, fired by check_rejuvenation on low health; not a persistent buff
    #   1635: Divine Intervention (BESEECH) -- emergency-only, opt-in in Paladin Spells section
    #   1650: Divine Incarnation -- complex multi-ability system, configured in Paladin Spells section
    # 1604: Holy Receptacle (utility), 1620: Prayer of the Devout (utility),
    # 1625: Arm of the Arkati (utility), 1640: Sanctify (utility)
    # Excluded from maintain: Bard Base (Songs tab), Paladin specials, reactive/utility spells
    # 108=Stun Relief (targets others), 114=Unpoison (reactive cure),
    # 116=Locate Person (utility), 130=Spirit Guide (travel utility)
    maintain_known = known.reject { |s|
      (is_bard && s[:num].between?(1001, 1040)) ||
        [108, 114, 116, 130, 1604, 1607, 1620, 1625, 1635, 1640, 1650].include?(s[:num])
    }
    offensive, other = maintain_known.partition { |s| spell_offensive?(s) }

    # Rotation dropdowns show offensive spells only -- Bard Base (1001-1040) always excluded (Songs tab owns those)
    # 1635/1650 also excluded: handled in the Paladin Spells section, not the rotation
    all_offensive = known.reject { |s| s[:num].between?(1001, 1040) || [1604, 1620, 1625, 1635, 1640, 1650].include?(s[:num]) }.select { |s| spell_offensive?(s) }
    spell_opts = ["-- None --"] +
      all_offensive.sort_by { |s| s[:num] }.map { |s| "#{s[:num]} -- #{s[:name]}" }

    # ---- Paladin Emergency Spells (1635 + 1650) --------------------------------
    if prof == "Paladin"
      saved_pal = (@saved_config || {})["paladin_spells"] || {}
      lore_ranks = (@detected || {})[:lore_ranks] || {}
      lore_ranks = ((@saved_config || {})["lore_ranks"] || {}).merge(lore_ranks) if lore_ranks.empty?
      bless_ranks = lore_ranks["Blessings"].to_i

      # 1635 -- Divine Intervention BESEECH
      has_1635 = known.any? { |s| s[:num] == 1635 }
      pf1, pb1 = frame_vbox("Spell 1635 -- Divine Intervention (BESEECH)")
      if has_1635
        desc1 = Gtk::Label.new(
          "BESEECH removes one status effect (stun, web, bind, poison, disease, curse) at no mana cost.\n" \
          "The script fires this automatically when you are stunned, webbed, or bound during a hunt."
        )
        desc1.xalign = 0.0; desc1.set_line_wrap(true)
        pb1.pack_start(desc1, false, false, 3)
        @w[:pal_1635_enabled] = Gtk::CheckButton.new("Enable BESEECH (1635) as emergency status removal")
        @w[:pal_1635_enabled].active = saved_pal.fetch("beseech_enabled", true)
        pb1.pack_start(@w[:pal_1635_enabled], false, false, 2)
      else
        pb1.pack_start(Gtk::Label.new("Spell 1635 not detected -- train it to unlock this option.").tap { |l| l.xalign = 0.0 }, false, false, 3)
        @w[:pal_1635_enabled] = nil
      end
      vb.pack_start(pf1, false, false, 5)

      # 1607 -- Rejuvenation: add to Hunting Preferences low_health priority list to control when it fires
      has_1607 = known.any? { |s| s[:num] == 1607 }
      if has_1607
        pf7, pb7 = frame_vbox("Spell 1607 -- Rejuvenation")
        desc7 = Gtk::Label.new(
          "Rejuvenation restores HP and stamina. Add it to the Low Health Priority list\n" \
          "in Hunting Preferences to control when it fires and in what order relative to\n" \
          "your other low-health responses. Has a 5-minute cooldown after each use."
        )
        desc7.xalign = 0.0; desc7.set_line_wrap(true)
        pb7.pack_start(desc7, false, false, 3)
        vb.pack_start(pf7, false, false, 5)
      end

      # 140 -- Wall of Force: cast when Feeble debuff is active (halves evasion/block/parry)
      has_140 = known.any? { |s| s[:num] == 140 }
      pf140, pb140 = frame_vbox("Spell 140 -- Wall of Force (Feeble response)")
      if has_140
        desc140 = Gtk::Label.new(
          "Wall of Force provides a powerful DS boost. The script can cast it automatically when\n" \
          "the Feeble debuff is active (cuts evasion/block/parry by 50%), provided it is not already\n" \
          "active and you have enough mana."
        )
        desc140.xalign = 0.0; desc140.set_line_wrap(true)
        pb140.pack_start(desc140, false, false, 3)
        @w[:wof_feeble_enabled] = Gtk::CheckButton.new("Cast Wall of Force (140) when Feeble is active")
        @w[:wof_feeble_enabled].active = saved_pal.fetch("wof_feeble_enabled", false)
        pb140.pack_start(@w[:wof_feeble_enabled], false, false, 2)
      else
        pb140.pack_start(Gtk::Label.new("Spell 140 not detected -- train it to unlock this option.").tap { |l| l.xalign = 0.0 }, false, false, 3)
        @w[:wof_feeble_enabled] = nil
      end
      vb.pack_start(pf140, false, false, 5)

      # 1650 -- Divine Incarnation INCARNATE abilities
      has_1650 = known.any? { |s| s[:num] == 1650 }
      pf2, pb2 = frame_vbox("Spell 1650 -- Divine Incarnation (INCARNATE abilities)")
      if has_1650
        # Armor emergency uses: base 1/day; +1 at 50 bless ranks, +1 at 125 bless ranks
        armor_uses = 1 + (bless_ranks >= 50 ? 1 : 0) + (bless_ranks >= 125 ? 1 : 0)

        desc2 = Gtk::Label.new(
          "Divine Incarnation gives 30 Divine Energy. Spell lasts 5 min (10 min cooldown).\n" \
          "Spiritual Lore, Blessings (#{bless_ranks} ranks detected) -- Armor emergency uses per day: #{armor_uses}.\n" \
          "Choose which abilities the script may use and in what situations."
        )
        desc2.xalign = 0.0; desc2.set_line_wrap(true)
        pb2.pack_start(desc2, false, false, 3)

        @w[:pal_incarn_armor_emerg]  = Gtk::CheckButton.new("INCARNATE ARMOR in emergencies (50% damage resist 30s, #{armor_uses}x/day max)")
        @w[:pal_incarn_zeal]         = Gtk::CheckButton.new("INCARNATE ZEAL per attack (deity flares on next 5 hits, 5 DE)")
        @w[:pal_incarn_smite]        = Gtk::CheckButton.new("INCARNATE SMITE per attack (divine bolt + plasma crit, 5 DE)")
        @w[:pal_incarn_onslaught]       = Gtk::CheckButton.new("INCARNATE ONSLAUGHT for AoE (multi-target, ignores 50%+ stance, 10 DE)")
        @w[:pal_incarn_onslaught_swarm] = Gtk::CheckButton.new("INCARNATE ONSLAUGHT for Swarm (same ability, fires at swarm threshold instead of AoE threshold)")

        @w[:pal_incarn_armor_emerg].active      = saved_pal.fetch("incarn_armor_emergency", true)
        @w[:pal_incarn_zeal].active             = saved_pal.fetch("incarn_zeal", false)
        @w[:pal_incarn_smite].active            = saved_pal.fetch("incarn_smite", true)
        @w[:pal_incarn_onslaught].active        = saved_pal.fetch("incarn_onslaught", true)
        @w[:pal_incarn_onslaught_swarm].active  = saved_pal.fetch("incarn_onslaught_swarm", false)

        # Mutual exclusion: AoE and Swarm Onslaught can't both be active
        @w[:pal_incarn_onslaught].signal_connect("toggled") do
          if @w[:pal_incarn_onslaught].active?
            @w[:pal_incarn_onslaught_swarm].active = false
            @w[:pal_incarn_onslaught_swarm].sensitive = false
          else
            @w[:pal_incarn_onslaught_swarm].sensitive = true
          end
        end
        @w[:pal_incarn_onslaught_swarm].signal_connect("toggled") do
          if @w[:pal_incarn_onslaught_swarm].active?
            @w[:pal_incarn_onslaught].active = false
            @w[:pal_incarn_onslaught].sensitive = false
          else
            @w[:pal_incarn_onslaught].sensitive = true
          end
        end
        # Set initial gray-out state
        @w[:pal_incarn_onslaught_swarm].sensitive = !@w[:pal_incarn_onslaught].active?
        @w[:pal_incarn_onslaught].sensitive       = !@w[:pal_incarn_onslaught_swarm].active?

        [
          @w[:pal_incarn_armor_emerg],
          @w[:pal_incarn_zeal],
          @w[:pal_incarn_smite],
          @w[:pal_incarn_onslaught],
          @w[:pal_incarn_onslaught_swarm],
        ].each { |cb| pb2.pack_start(cb, false, false, 2) }

        # ARMOR RT threshold -- only meaningful when ARMOR emergency is checked
        armor_rt_thresh = saved_pal.fetch("incarn_armor_rt_threshold", 8)
        @w[:pal_incarn_armor_rt] = Gtk::SpinButton.new(
          Gtk::Adjustment.new(armor_rt_thresh.to_f, 1.0, 30.0, 1.0, 1.0, 0.0), 1, 0)
        rt_row = lrow(
          "Use INCARNATE ARMOR when stunned AND roundtime >=  seconds:",
          @w[:pal_incarn_armor_rt]
        )
        rt_row.sensitive = @w[:pal_incarn_armor_emerg].active?
        pb2.pack_start(rt_row, false, false, 2)
        @w[:pal_incarn_armor_emerg].signal_connect("toggled") { rt_row.sensitive = @w[:pal_incarn_armor_emerg].active? }

        rt_note = Gtk::Label.new(
          "ARMOR fires only when: (1) you are stunned, AND (2) your current roundtime is at or above the threshold.\n" \
          "Set lower (e.g. 5s) to fire sooner; higher (e.g. 12s) to conserve daily uses for longer stuns only."
        )
        rt_note.xalign = 0.0; rt_note.set_line_wrap(true)
        pb2.pack_start(rt_note, false, false, 2)

        note2 = Gtk::Label.new(
          "Note: ARMOR emergency mode fires without an active Incarnation -- it is a standalone daily ability.\n" \
          "ZEAL/SMITE/ONSLAUGHT require an active Incarnation (script will cast 1650 first if not active)."
        )
        note2.xalign = 0.0; note2.set_line_wrap(true)
        pb2.pack_start(note2, false, false, 4)
      else
        pb2.pack_start(Gtk::Label.new("Spell 1650 not detected -- train it to unlock this option.").tap { |l| l.xalign = 0.0 }, false, false, 3)
        @w[:pal_incarn_armor_emerg] = @w[:pal_incarn_zeal] = @w[:pal_incarn_smite] = @w[:pal_incarn_onslaught] = @w[:pal_incarn_onslaught_swarm] = nil
        @w[:pal_incarn_armor_rt] = nil
      end
      vb.pack_start(pf2, false, false, 5)
    end
    # ---- end Paladin section ---------------------------------------------------

    # ---- Maintain Spells (merged detected spells + maintain list) --------------
    saved_maintain_nums = ((@saved_config || {}).dig("spells", "maintain") || []).map { |s| s["num"].to_i }.to_set
    mf, mb = frame_vbox("Maintain Spells#{is_bard ? ' (Bard songs managed in Songs tab)' : ''}")

    warn_lbl = Gtk::Label.new(
      "Check any spell you want kept active during hunting. The script maintains spells by casting INCANT <num> whenever the spell is not active.\n\n" \
      "This works for any self-cast buff -- including mana node/regeneration spells that casters use to recover mana faster.\n\n" \
      "Do NOT check spells that require a target, special components, or a non-standard casting procedure -- those will fail or produce errors.\n" \
      "Examples of spells that will NOT work here: Consecrate (targets a weapon), Magic Item Creation, Holy Weapon enhancements, or any spell that prompts for input."
    )
    warn_lbl.xalign = 0.0; warn_lbl.set_line_wrap(true)
    mb.pack_start(warn_lbl, false, false, 4)

    if maintain_known.empty?
      mb.pack_start(Gtk::Label.new(
        "No spells detected -- Lich may not have received spell data yet.\n" \
        "Try re-running setup after casting a spell or logging spells."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 4)
    else
      circles = prof ? (PROFESSION_SPELL_CIRCLES[prof] || []) : []
      unless circles.empty?
        cl = Gtk::Label.new("#{prof} spell circles: #{circles.join(", ")}")
        cl.xalign = 0.0
        mb.pack_start(cl, false, false, 2)
      end
      if is_caster
        cl2 = Gtk::Label.new("#{prof}s hunt primarily with spells -- set your attack rotation below. Check buffs here to keep them maintained.")
        cl2.xalign = 0.0; cl2.set_line_wrap(true)
        mb.pack_start(cl2, false, false, 2)
      end

      @known_spell_checks = {}
      spell_scroll = Gtk::ScrolledWindow.new
      spell_scroll.set_policy(Gtk::POLICY_NEVER, Gtk::POLICY_AUTOMATIC)
      spell_scroll.set_size_request(-1, 180)
      spell_vb = mk_vbox(2)
      spell_vb.border_width = 4

      render_section = lambda do |title, spells|
        next if spells.empty?
        hdr = Gtk::Label.new("<b>#{title}</b>")
        hdr.use_markup = true; hdr.xalign = 0.0
        spell_vb.pack_start(hdr, false, false, 3)
        by_circle = spells.group_by { |s| s[:circle] }
        by_circle.each do |circle, cspells|
          clbl = Gtk::Label.new("  <i>#{circle}</i>")
          clbl.use_markup = true; clbl.xalign = 0.0
          spell_vb.pack_start(clbl, false, false, 1)
          spell_hints = { 1609 => "Divine Shield (aura)", 1617 => "Zealot (aura)", 1618 => "Fervor (aura)" }
          if circle == "Paladin Base" && prof == "Paladin"
            aura_note = Gtk::Label.new("  Note: only one aura (Divine Shield / Zealot / Fervor) can be active at a time -- selecting one will uncheck and gray the others.")
            aura_note.xalign = 0.0; aura_note.set_line_wrap(true)
            aura_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
            spell_vb.pack_start(aura_note, false, false, 2)
          end
          cspells.sort_by { |s| s[:num] }.each do |s|
            display_name = spell_hints[s[:num]] || s[:name]
            cb = Gtk::CheckButton.new("#{s[:num]} -- #{display_name}")
            cb.active = saved_maintain_nums.include?(s[:num])
            @known_spell_checks[s[:num]] = { cb: cb, spell: s }
            spell_vb.pack_start(cb, false, false, 1)
          end
        end
      end
      render_section.call("Defensive Spells", other)

      # Paladin aura mutual exclusivity: only one of 1609/1617/1618 can be active.
      # Checking one unchecks and grays the others; unchecking re-enables the others.
      if prof == "Paladin"
        aura_cbs = [1609, 1617, 1618].map { |n| @known_spell_checks.dig(n, :cb) }.compact
        if aura_cbs.length > 1
          aura_cbs.each do |cb|
            cb.signal_connect("toggled") do |btn|
              if btn.active?
                aura_cbs.each do |other|
                  next if other.equal?(btn)
                  other.active    = false
                  other.sensitive = false
                end
              else
                aura_cbs.each { |other| other.sensitive = true }
              end
            end
          end
          # Apply initial state based on saved config
          checked = aura_cbs.find(&:active?)
          if checked
            aura_cbs.each { |other| other.sensitive = other.equal?(checked) }
          end
        end
      end

      spell_scroll.add_with_viewport(spell_vb)
      mb.pack_start(spell_scroll, true, true, 0)
    end
    _spell_mf = mf

    # ---- Bard songs are configured in the Songs tab ----------------------------

    # ---- Ranger Animal Companion ------------------------------------------------
    if prof =~ /Ranger/i
      saved_rc = (@saved_config || {})["ranger_companion"] || {}
      rcf, rcb = frame_vbox("Ranger Animal Companion (spell 630)")
      rcb.pack_start(Gtk::Label.new(
        "If you have bonded with an Animal Companion (spell 630), the script will set its behavior at hunt start\n" \
        "and optionally direct it to attack your current target each engagement.\n\n" \
        "Behavior modes:\n" \
        "  Offensive -- companion auto-attacks after you attack (no manual directive sent)\n" \
        "  Defensive -- companion guards you for +DS bonus; does not attack\n" \
        "  Neutral   -- companion is idle; script sends TELL COMPANION TO ATTACK each new target"
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

      @w[:rc_enabled] = Gtk::CheckButton.new("I have a bonded Animal Companion")
      @w[:rc_enabled].active = saved_rc.fetch("enabled", false)

      saved_type_idx = RANGER_COMPANION_TYPES.index(saved_rc["companion_type"] || "canine") || 0
      @w[:rc_type] = mk_combo_text(RANGER_COMPANION_TYPES.map(&:capitalize), saved_type_idx)

      saved_beh_idx = RANGER_COMPANION_BEHAVIORS.index(saved_rc["behavior"] || "offensive") || 0
      @w[:rc_behavior] = mk_combo_text(RANGER_COMPANION_BEHAVIORS.map(&:capitalize), saved_beh_idx)

      @w[:rc_attack] = Gtk::CheckButton.new("Direct companion to attack my target each engagement (Neutral mode only; auto in Offensive)")
      @w[:rc_attack].active = saved_rc.fetch("attack_target", true)

      @w[:rc_resummon] = Gtk::CheckButton.new("Re-summon companion if not present in room at hunt start")
      @w[:rc_resummon].active = saved_rc.fetch("resummon", true)

      rc_detail = [
        lrow("Companion type:", @w[:rc_type]),
        lrow("Behavior mode:", @w[:rc_behavior]),
        @w[:rc_attack],
        @w[:rc_resummon],
      ]
      rcb.pack_start(@w[:rc_enabled], false, false, 2)
      rc_detail.each { |r| rcb.pack_start(r, false, false, 2); r.sensitive = @w[:rc_enabled].active? }
      @w[:rc_enabled].signal_connect("toggled") { rc_detail.each { |r| r.sensitive = @w[:rc_enabled].active? } }
      vb.pack_start(rcf, false, false, 5)
    else
      @w[:rc_enabled] = @w[:rc_type] = @w[:rc_behavior] = @w[:rc_attack] = @w[:rc_resummon] = nil
    end
    # ---- end Ranger section -----------------------------------------------------

    # ---- Sorcerer Demon (Minor Summoning 725) -----------------------------------
    if prof =~ /Sorcerer/i
      saved_sd = (@saved_config || {})["sorcerer_demon"] || {}
      sdf, sdb = frame_vbox("Sorcerer Demon (Minor Summoning 725)")
      sdb.pack_start(Gtk::Label.new(
        "Demons summoned via spell 725 cannot fight, but can pick up dropped items.\n" \
        "The script can command your active demon to retrieve your weapon if it is dropped in an emergency."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

      @w[:sd_enabled] = Gtk::CheckButton.new("I keep a Minor Summoning demon active (spell 725)")
      @w[:sd_enabled].active = saved_sd.fetch("enabled", false)

      @w[:sd_fetch_weapon] = Gtk::CheckButton.new("Command demon to fetch my weapon if dropped (emergency)")
      @w[:sd_fetch_weapon].active = saved_sd.fetch("fetch_weapon", false)

      @w[:sd_weapon_noun] = Gtk::Entry.new
      @w[:sd_weapon_noun].text = saved_sd["weapon_noun"].to_s

      sd_detail = [
        @w[:sd_fetch_weapon],
        lrow("Weapon noun (e.g. sword):", @w[:sd_weapon_noun]),
      ]
      sdb.pack_start(@w[:sd_enabled], false, false, 2)
      sd_detail.each { |r| sdb.pack_start(r, false, false, 2); r.sensitive = @w[:sd_enabled].active? }
      @w[:sd_enabled].signal_connect("toggled") { sd_detail.each { |r| r.sensitive = @w[:sd_enabled].active? } }
      vb.pack_start(sdf, false, false, 5)
    else
      @w[:sd_enabled] = @w[:sd_fetch_weapon] = @w[:sd_weapon_noun] = nil
    end
    # ---- end Sorcerer section ---------------------------------------------------

    # ---- Cleric / Empath Spirit Servant (218) -----------------------------------
    if prof =~ /Cleric|Empath/i
      saved_ss2 = (@saved_config || {})["spirit_servant"] || {}
      ssf3, ssb3 = frame_vbox("Spirit Servant (spell 218)")
      ssb3.pack_start(Gtk::Label.new(
        "The Spirit Servant (spell 218) cannot fight, but can carry and retrieve items.\n" \
        "Enable below to have the script command it to fetch your weapon if it is dropped in an emergency."
      ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

      @w[:ss2_enabled] = Gtk::CheckButton.new("I keep a Spirit Servant active (spell 218)")
      @w[:ss2_enabled].active = saved_ss2.fetch("enabled", false)

      @w[:ss2_fetch_weapon] = Gtk::CheckButton.new("Command servant to fetch my weapon if dropped (emergency)")
      @w[:ss2_fetch_weapon].active = saved_ss2.fetch("fetch_weapon", false)

      @w[:ss2_weapon_noun] = Gtk::Entry.new
      @w[:ss2_weapon_noun].text = saved_ss2["weapon_noun"].to_s

      ss2_detail = [
        @w[:ss2_fetch_weapon],
        lrow("Weapon noun (e.g. sword):", @w[:ss2_weapon_noun]),
      ]
      ssb3.pack_start(@w[:ss2_enabled], false, false, 2)
      ss2_detail.each { |r| ssb3.pack_start(r, false, false, 2); r.sensitive = @w[:ss2_enabled].active? }
      @w[:ss2_enabled].signal_connect("toggled") { ss2_detail.each { |r| r.sensitive = @w[:ss2_enabled].active? } }
      vb.pack_start(ssf3, false, false, 5)
    else
      @w[:ss2_enabled] = @w[:ss2_fetch_weapon] = @w[:ss2_weapon_noun] = nil
    end
    # ---- end Cleric/Empath section ----------------------------------------------

    # Maintain Spells -- packed last so rotations appear at the top of the page
    vb.pack_start(_spell_mf, true, true, 5)

    scrolled(vb)
  end

  # Songs tab -- Bard only. Shows "not a bard" notice for other professions.
  SONG_RENEW_OPTS = ["Keep singing (auto-renew)", "Renew mode (cast then stop -- saves mana)"].freeze
  RENEW_ELIGIBLE  = [1003, 1006, 1007, 1010, 1019].freeze

  def self.pg_songs
    d    = @detected || {}
    prof = GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil
    vb   = mk_vbox(6)
    vb.border_width = 10

    unless prof =~ /Bard/i
      lbl = Gtk::Label.new("This tab is only used by Bards.\nYour detected profession is: #{prof || 'unknown'}.")
      lbl.xalign = 0.0; lbl.set_line_wrap(true)
      vb.pack_start(lbl, false, false, 8)
      return scrolled(vb)
    end

    saved_sonic = (@saved_config || {})["bard_sonic"] || {}

    # ---- Intro note ----
    intro = Gtk::Label.new(
      "The script will re-sing any enabled song automatically when it fades during hunting.\n" \
      "Renew mode: cast the song then immediately stop it. The effect persists for its full duration\n" \
      "but does not count toward your multi-song renewal cost -- useful when the renewal penalty\n" \
      "would exceed the cost of just re-singing it fresh. Eligible songs: Fortitude, Luck, Kai's Triumph, Valor, Mirrors."
    )
    intro.xalign = 0.0; intro.set_line_wrap(true)
    vb.pack_start(intro, false, false, 4)

    # ---- Sonic Equipment Songs ----
    seq_f, seq_b = frame_vbox("Sonic Equipment (weapons/armor/shield conjured by singing)")
    seq_b.pack_start(Gtk::Label.new(
      "These songs create magical gear that replaces your normal weapon or armor while active.\n" \
      "Weapon/armor settings in the Weapons and Defense tabs are overridden while sonic songs are running."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)

    # Sonic Weapon (1012)
    knows_1012 = (Spell[1012].known? rescue false)
    @w[:sonic_wpn_enabled] = Gtk::CheckButton.new("Sonic Weapon Song (1012) -- conjured weapon#{knows_1012 ? '' : '  [not yet learned]'}")
    @w[:sonic_wpn_enabled].active    = knows_1012 && saved_sonic.fetch("weapon_enabled", false)
    @w[:sonic_wpn_enabled].sensitive = knows_1012
    @w[:sonic_wpn_num] = Gtk::SpinButton.new(
      Gtk::Adjustment.new((saved_sonic["weapon_spell"] || 1012).to_f, 1000.0, 1099.0, 1.0, 1.0, 0.0), 1, 0)
    saved_wpn_sing  = saved_sonic["weapon_sing"] || "longsword"
    saved_wpn_tidx  = SONIC_WPN_OPTS.index { |o| o[:sing] == saved_wpn_sing } || 0
    @w[:sonic_wpn_type] = mk_combo_text(SONIC_WPN_OPTS.map { |o| o[:label] }, saved_wpn_tidx)
    swf, swb = frame_vbox("Sonic Weapon")
    swb.pack_start(Gtk::Label.new(
      "Excluded: katana, naginata, claidhmore, all ranged weapons."
    ).tap { |l| l.xalign = 0.0 }, false, false, 2)
    swb.pack_start(@w[:sonic_wpn_enabled], false, false, 2)
    wpn_detail = [lrow("Spell #:", @w[:sonic_wpn_num]), lrow("Weapon type:", @w[:sonic_wpn_type])]
    wpn_detail.each { |r| swb.pack_start(r, false, false, 2); r.sensitive = @w[:sonic_wpn_enabled].active? }
    @w[:sonic_wpn_enabled].signal_connect("toggled") { wpn_detail.each { |r| r.sensitive = @w[:sonic_wpn_enabled].active? } }
    seq_b.pack_start(swf, false, false, 3)

    # Sonic Shield (1009)
    knows_1009 = (Spell[1009].known? rescue false)
    @w[:sonic_shld_enabled] = Gtk::CheckButton.new("Sonic Shield Song (1009) -- conjured shield#{knows_1009 ? '' : '  [not yet learned]'}")
    @w[:sonic_shld_enabled].active    = knows_1009 && saved_sonic.fetch("shield_enabled", false)
    @w[:sonic_shld_enabled].sensitive = knows_1009
    @w[:sonic_shld_num] = Gtk::SpinButton.new(
      Gtk::Adjustment.new((saved_sonic["shield_spell"] || 1009).to_f, 1000.0, 1099.0, 1.0, 1.0, 0.0), 1, 0)
    saved_shld_sing = saved_sonic["shield_sing"] || "buckler"
    saved_shld_idx  = SONIC_SHLD_OPTS.index { |o| o[:sing] == saved_shld_sing } || 0
    @w[:sonic_shld_type] = mk_combo_text(SONIC_SHLD_OPTS.map { |o| o[:label] }, saved_shld_idx)
    ssf, ssb2 = frame_vbox("Sonic Shield")
    ssb2.pack_start(@w[:sonic_shld_enabled], false, false, 2)
    shld_detail = [lrow("Spell #:", @w[:sonic_shld_num]), lrow("Shield type:", @w[:sonic_shld_type])]
    shld_detail.each { |r| ssb2.pack_start(r, false, false, 2); r.sensitive = @w[:sonic_shld_enabled].active? }
    @w[:sonic_shld_enabled].signal_connect("toggled") { shld_detail.each { |r| r.sensitive = @w[:sonic_shld_enabled].active? } }
    seq_b.pack_start(ssf, false, false, 3)

    # Sonic Armor (1014)
    knows_1014 = (Spell[1014].known? rescue false)
    @w[:sonic_arm_enabled] = Gtk::CheckButton.new("Sonic Armor Song (1014) -- conjured armor#{knows_1014 ? '' : '  [not yet learned]'}")
    @w[:sonic_arm_enabled].active    = knows_1014 && saved_sonic.fetch("armor_enabled", false)
    @w[:sonic_arm_enabled].sensitive = knows_1014
    @w[:sonic_arm_num] = Gtk::SpinButton.new(
      Gtk::Adjustment.new((saved_sonic["armor_spell"] || 1014).to_f, 1000.0, 1099.0, 1.0, 1.0, 0.0), 1, 0)
    saved_arm_idx = armor_asg_idx(saved_sonic["armor_asg"] || 0)
    @w[:sonic_arm_asg] = w_combo(:sonic_arm_asg, ARMOR_TYPES.map { |t| t[:label] }, saved_arm_idx)
    saf, sab = frame_vbox("Sonic Armor")
    sab.pack_start(@w[:sonic_arm_enabled], false, false, 2)
    arm_detail = [lrow("Spell #:", @w[:sonic_arm_num]), lrow("Armor type:", @w[:sonic_arm_asg])]
    arm_detail.each { |r| sab.pack_start(r, false, false, 2); r.sensitive = @w[:sonic_arm_enabled].active? }
    @w[:sonic_arm_enabled].signal_connect("toggled") { arm_detail.each { |r| r.sensitive = @w[:sonic_arm_enabled].active? } }
    seq_b.pack_start(saf, false, false, 3)

    # Singing Sword Song (1025)
    knows_1025 = (Spell[1025].known? rescue false)
    @w[:singing_sword_enabled] = Gtk::CheckButton.new("Singing Sword Song (1025) -- floating attacking sword#{knows_1025 ? '' : '  [not yet learned]'}")
    @w[:singing_sword_enabled].active    = knows_1025 && saved_sonic.fetch("singing_sword", false)
    @w[:singing_sword_enabled].sensitive = knows_1025
    saved_ss_sing = saved_sonic["singing_sword_type"] || "falchion"
    saved_ss_idx  = SINGING_SWORD_OPTS.index { |o| o[:sing] == saved_ss_sing } || 0
    @w[:singing_sword_type] = mk_combo_text(SINGING_SWORD_OPTS.map { |o| o[:label] }, saved_ss_idx)
    ssf2, ssb3 = frame_vbox("Singing Sword Song")
    ssb3.pack_start(Gtk::Label.new(
      "Creates a floating weapon that attacks enemies on its own. Re-sung when it fades.\n" \
      "Pick the weapon type to conjure -- the sword's damage and style varies by type."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)
    ssb3.pack_start(@w[:singing_sword_enabled], false, false, 2)
    ss_type_row = lrow("Weapon type:", @w[:singing_sword_type])
    ss_type_row.sensitive = @w[:singing_sword_enabled].active?
    ssb3.pack_start(ss_type_row, false, false, 2)
    @w[:singing_sword_enabled].signal_connect("toggled") { ss_type_row.sensitive = @w[:singing_sword_enabled].active? }
    seq_b.pack_start(ssf2, false, false, 3)

    vb.pack_start(seq_f, false, false, 5)

    # ---- Helper: build a song row with optional renew dropdown ----
    build_song_row = lambda do |parent_box, s, checked, saved_renew|
      known = (Spell[s[:num]].known? rescue false)
      hb = mk_hbox(4)
      label = known ? "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})" \
                    : "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})  [not yet learned]"
      cb = Gtk::CheckButton.new(label)
      cb.active    = known && checked
      cb.sensitive = known
      hb.pack_start(cb, true, true, 0)
      if RENEW_ELIGIBLE.include?(s[:num])
        renew_idx = saved_renew.include?(s[:num]) ? 1 : 0
        rc = mk_combo_text(SONG_RENEW_OPTS, renew_idx)
        rc.sensitive = known && cb.active?
        cb.signal_connect("toggled") { rc.sensitive = cb.active? } if known
        hb.pack_start(Gtk::Label.new("Mode:"), false, false, 4)
        hb.pack_start(rc, false, false, 0)
        [cb, rc]
      else
        [cb, nil]
      end.tap { parent_box.pack_start(hb, false, false, 2) }
    end

    # ---- Defensive Songs ----
    saved_def   = saved_sonic["defensive_songs"]  || []
    saved_renew = saved_sonic["renew_songs"]       || []
    @w[:bard_def_songs]   = {}
    @w[:bard_def_renew]   = {}
    dff, dfb = frame_vbox("Defensive Songs (kept active during hunting)")
    BARD_DEFENSIVE_SONGS.each do |s|
      cb, rc = build_song_row.call(dfb, s, saved_def.include?(s[:num]), saved_renew)
      @w[:bard_def_songs][s[:num]] = cb
      @w[:bard_def_renew][s[:num]] = rc
    end
    vb.pack_start(dff, false, false, 4)

    # ---- Utility / Support Songs ----
    saved_util = saved_sonic["utility_songs"] || []
    @w[:bard_util_songs]  = {}
    @w[:bard_util_renew]  = {}
    uf, ub = frame_vbox("Utility & Support Songs (kept active during hunting)")
    uf.pack_start(Gtk::Label.new(
      "Song of Power (1018): be aware that letting it auto-renew while low on mana can cause injuries.\n" \
      "Consider only enabling it if you have reliable mana regeneration."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3) rescue nil
    BARD_UTILITY_SONGS.each do |s|
      cb, rc = build_song_row.call(ub, s, saved_util.include?(s[:num]), saved_renew)
      @w[:bard_util_songs][s[:num]] = cb
      @w[:bard_util_renew][s[:num]] = rc
    end
    vb.pack_start(uf, false, false, 4)

    # ---- Cyclic Offensive Songs ----
    saved_cyc = saved_sonic["cyclic_songs"] || []
    @w[:bard_cyc_songs] = {}
    cf, cfb = frame_vbox("Cyclic / Offensive Songs (re-sung during combat)")
    cfb.pack_start(Gtk::Label.new(
      "Cyclic songs persist on targets and need periodic re-singing.\n" \
      "The script re-sings them between attacks when a target is present."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)
    BARD_CYCLIC_SONGS.each do |s|
      known = (Spell[s[:num]].known? rescue false)
      cb = Gtk::CheckButton.new(known ? "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})" \
                                       : "#{s[:num]} -- #{s[:name]}  (#{s[:desc]})  [not yet learned]")
      cb.active    = known && saved_cyc.include?(s[:num])
      cb.sensitive = known
      @w[:bard_cyc_songs][s[:num]] = cb
      cfb.pack_start(cb, false, false, 2)
    end
    vb.pack_start(cf, false, false, 4)

    scrolled(vb)
  end

  def self.pg_rogue_guild
    vb = mk_vbox(8)
    vb.border_width = 10

    saved_rg = (@saved_config || {})["rogue_guild"] || {}

    # ---- Stun Maneuvers -------------------------------------------------------
    smf, smb = frame_vbox("Stun Maneuvers")
    smb.pack_start(Gtk::Label.new(
      "When you are stunned, Stun Maneuvers lets you act through it using your guild training.\n" \
      "Rank 3: Stand/recover stance.  Rank 4: Strike while stunned.  Rank 5: Slip into hiding.\n" \
      "Stamina is checked first -- the action is skipped if you would overextend."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:rg_stun_enabled] = Gtk::CheckButton.new("Use Stun Maneuvers when stunned")
    @w[:rg_stun_enabled].active = saved_rg.fetch("stun_enabled", false)

    stun_actions  = [
      "Attack (rank 4 -- strike while stunned)",
      "Hide   (rank 5 -- slip into shadows while stunned)",
      "Stand  (rank 3 -- recover stance/defense)",
    ]
    saved_act_idx = ["attack", "hide", "stand"].index(saved_rg["stun_action"] || "attack") || 0
    @w[:rg_stun_action] = mk_combo_text(stun_actions, saved_act_idx)

    saved_stamina = (saved_rg["stun_stamina"] || 10).to_f
    @w[:rg_stun_stamina] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_stamina, 0.0, 50.0, 1.0, 5.0, 0.0), 1, 0)

    rg_detail = [
      lrow("Action when stunned:", @w[:rg_stun_action]),
      lrow("Stamina cost (used for reserve check -- default 10):", @w[:rg_stun_stamina]),
    ]
    smb.pack_start(@w[:rg_stun_enabled], false, false, 3)
    rg_detail.each { |r| smb.pack_start(r, false, false, 2); r.sensitive = @w[:rg_stun_enabled].active? }
    @w[:rg_stun_enabled].signal_connect("toggled") { rg_detail.each { |r| r.sensitive = @w[:rg_stun_enabled].active? } }
    vb.pack_start(smf, false, false, 4)

    # ---- Silent Strike --------------------------------------------------------
    ssf, ssb = frame_vbox("Silent Strike  (FEAT SILENTSTRIKE)")
    ssb.pack_start(Gtk::Label.new(
      "Attack from the shadows using your rogue stealth training (requires level 25+, rank 1-5).\n" \
      "Costs 20 stamina. Must be hidden before firing -- the script will hide you first if needed.\n" \
      "On success the feat automatically re-hides you. Waylay is the most popular modifier:\n" \
      "it stuns the target, letting you follow up with a normal attack while they reel."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:rg_ss_enabled] = Gtk::CheckButton.new("Use Silent Strike instead of normal melee attack")
    @w[:rg_ss_enabled].active = saved_rg.fetch("ss_enabled", false)

    ss_modifiers = ["(none)", "waylay", "jab", "grapple", "punch", "kick"]
    saved_ss_mod_idx = ss_modifiers.index(saved_rg["ss_modifier"] || "(none)") || 0
    @w[:rg_ss_modifier] = mk_combo_text(ss_modifiers, saved_ss_mod_idx)

    ss_hide_methods = ["HIDE (standard)", "Vanish (CMAN -- hide in combat without penalty)"]
    saved_ss_hide_idx = ["hide", "vanish"].index(saved_rg["ss_hide_method"] || "hide") || 0
    @w[:rg_ss_hide_method] = mk_combo_text(ss_hide_methods, saved_ss_hide_idx)

    ss_detail = [
      lrow("Attack modifier:", @w[:rg_ss_modifier]),
      lrow("Hide method (if not already hidden):", @w[:rg_ss_hide_method]),
    ]
    ssb.pack_start(@w[:rg_ss_enabled], false, false, 3)
    ss_detail.each { |r| ssb.pack_start(r, false, false, 2); r.sensitive = @w[:rg_ss_enabled].active? }
    @w[:rg_ss_enabled].signal_connect("toggled") { ss_detail.each { |r| r.sensitive = @w[:rg_ss_enabled].active? } }
    vb.pack_start(ssf, false, false, 4)

    scrolled(vb)
  end

  # ---------------------------------------------------------------------------
  # Warrior Guild tab
  # ---------------------------------------------------------------------------
  # Maps guild checkbox widget keys to CMAN name patterns that share the same ability.
  # When a guild control is enabled, matching CMAN rows are grayed (and vice versa).
  WG_CMAN_OVERLAPS = {
    wg_berserk_enabled: /\bberserk\b/i,
    wg_feint_enabled:   /\bfeint\b/i,
  }.freeze

  WG_WARCRIES = [
    { key: "bellow",  rank: 1,  cmd: "bertrandt",  type: :offensive,  stamina_single: 10, stamina_aoe: 20, desc: "Bertrandt's Bellow -- Stagger target(s)" },
    { key: "growl",   rank: 30, cmd: "gerrelle",   type: :offensive,  stamina_single: 7,  stamina_aoe: 14, desc: "Gerrelle's Growl -- Force offensive stance + Demoralize" },
    { key: "cry",     rank: 50, cmd: "carn",        type: :offensive,  stamina_single: 15, stamina_aoe: 30, desc: "Carn's Cry -- Terrify and immobilize target(s)" },
    { key: "yowlp",   rank: 20, cmd: "yertie",      type: :supporting, stamina_single: 10, stamina_aoe: nil, desc: "Yertie's Yowlp -- Bolster party defense (rank 20)" },
    { key: "shout",   rank: 40, cmd: "seanette",    type: :supporting, stamina_single: 25, stamina_aoe: nil, desc: "Seanette's Shout -- Grant +20 AS to party (rank 40)" },
    { key: "holler",  rank: 60, cmd: "horland",     type: :supporting, stamina_single: 0,  stamina_aoe: nil, desc: "Horland's Holler -- Room taunt + Boost Health (rank 60)" },
  ].freeze

  WG_TRICK_LOCS = %w[chest back neck head right_arm left_arm right_hand left_hand right_leg left_leg].freeze

  # Lock/unlock CMAN store rows whose name matches pat.
  # locked=true grays and blocks them; locked=false restores them.
  def self.cman_set_row_lock(pat, locked)
    return unless @cman_store
    @cman_store.each do |_m, _p, it|
      if @cman_store.get_value(it, 1).to_s =~ pat
        @cman_store.set_value(it, 7, !locked)
      end
    end
  end

  # Set each guild overlap checkbox sensitive/insensitive based on whether
  # a matching enabled CMAN row exists (called after cman_store is populated).
  def self.refresh_guild_from_cman
    return unless @cman_store
    WG_CMAN_OVERLAPS.each do |wk, pat|
      cman_active = false
      @cman_store.each { |_m, _p, it| cman_active = true if @cman_store.get_value(it, 0) && @cman_store.get_value(it, 1).to_s =~ pat }
      @w[wk]&.sensitive = !cman_active
    end
  end

  def self.pg_warrior_guild
    vb = mk_vbox(8)
    vb.border_width = 10
    saved_wg = (@saved_config || {})["warrior_guild"] || {}

    # ---- Berserk --------------------------------------------------------------
    bsf, bsb = frame_vbox("Berserk")
    bsb.pack_start(Gtk::Label.new(
      "Enter a berserker rage, attacking every 5 seconds until stopped.\n" \
      "Costs 20 stamina to enter, then 10/round. While berserking the script suspends\n" \
      "normal attacks -- berserk handles combat automatically. Use the round limit to\n" \
      "auto-stop after N rounds (0 = keep going until no targets remain)."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:wg_berserk_enabled] = Gtk::CheckButton.new("Use Berserk in combat")
    @w[:wg_berserk_enabled].active = saved_wg.fetch("berserk_enabled", false)

    saved_bs_stam  = (saved_wg["berserk_stamina_min"] || 30).to_f
    saved_bs_rounds = (saved_wg["berserk_max_rounds"] || 0).to_f
    @w[:wg_berserk_stamina] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_bs_stam, 0.0, 100.0, 1.0, 5.0, 0.0), 1, 0)
    @w[:wg_berserk_rounds] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_bs_rounds, 0.0, 60.0, 1.0, 5.0, 0.0), 1, 0)

    bs_detail = [
      lrow("Minimum stamina before entering berserk:", @w[:wg_berserk_stamina]),
      lrow("Max rounds before auto-stopping (0 = unlimited):", @w[:wg_berserk_rounds]),
    ]
    bsb.pack_start(@w[:wg_berserk_enabled], false, false, 3)
    bs_detail.each { |r| bsb.pack_start(r, false, false, 2); r.sensitive = @w[:wg_berserk_enabled].active? }
    @w[:wg_berserk_enabled].signal_connect("toggled") do
      bs_detail.each { |r| r.sensitive = @w[:wg_berserk_enabled].active? }
      cman_set_row_lock(WG_CMAN_OVERLAPS[:wg_berserk_enabled], @w[:wg_berserk_enabled].active?)
    end
    vb.pack_start(bsf, false, false, 4)

    # ---- War Cries ------------------------------------------------------------
    wcf, wcb = frame_vbox("War Cries  (WARCRY command)")
    wcb.pack_start(Gtk::Label.new(
      "War Cries fire before each attack. Offensive cries target the current enemy.\n" \
      "Supporting cries bolster your party (fired when the buff is not already active).\n" \
      "Stamina is checked against your reserve before each cry fires."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    @w[:wg_warcry] = {}
    @w[:wg_warcry_aoe] = {}

    [[:offensive, "Offensive Cries"], [:supporting, "Supporting Cries"]].each do |cry_type, label|
      sub_f, sub_b = frame_vbox(label)
      WG_WARCRIES.select { |c| c[:type] == cry_type }.each do |cry|
        saved_cry = (saved_wg.dig("warcries", cry[:key]) || {})
        cb = Gtk::CheckButton.new(cry[:desc])
        cb.active = saved_cry.fetch("enabled", false)
        @w[:wg_warcry][cry[:key]] = cb
        row_widgets = [cb]

        if cry[:stamina_aoe]
          aoe_cb = Gtk::CheckButton.new("AoE")
          aoe_cb.active = saved_cry.fetch("aoe", false)
          aoe_cb.sensitive = cb.active?
          @w[:wg_warcry_aoe][cry[:key]] = aoe_cb
          hb = mk_hbox(6)
          hb.pack_start(cb, true, true, 0)
          hb.pack_start(aoe_cb, false, false, 0)
          sub_b.pack_start(hb, false, false, 2)
          cb.signal_connect("toggled") { aoe_cb.sensitive = cb.active? }
        else
          sub_b.pack_start(cb, false, false, 2)
        end
      end
      wcb.pack_start(sub_f, false, false, 4)
    end
    vb.pack_start(wcf, false, false, 4)

    # ---- Warrior Tricks (combat) -----------------------------------------------
    wtf, wtb = frame_vbox("Warrior Tricks (Combat)")
    wtb.pack_start(Gtk::Label.new(
      "FEINT (rank 10 via guild): create an opening before attacking (uses WTRICK FEINT).\n" \
      "SPIT (rank 8): targeted attack at a specific body location.\n" \
      "If Feint or Berserk also appear in Weapon Attack Rotation, enabling one side will gray\n" \
      "out the other to prevent double-firing. Disable the grayed one to switch sources."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 4)

    saved_feint = saved_wg.fetch("feint_enabled", false)
    @w[:wg_feint_enabled] = Gtk::CheckButton.new("Use FEINT before attacking -- guild version (WTRICK FEINT)")
    @w[:wg_feint_enabled].active = saved_feint
    @w[:wg_feint_enabled].signal_connect("toggled") do
      cman_set_row_lock(WG_CMAN_OVERLAPS[:wg_feint_enabled], @w[:wg_feint_enabled].active?)
    end

    saved_spit  = saved_wg.fetch("spit_enabled", false)
    saved_spit_loc_idx = WG_TRICK_LOCS.index(saved_wg["spit_location"] || "chest") || 0
    @w[:wg_spit_enabled] = Gtk::CheckButton.new("Use SPIT attack (rank 8 required)")
    @w[:wg_spit_enabled].active = saved_spit
    @w[:wg_spit_loc] = mk_combo_text(WG_TRICK_LOCS, saved_spit_loc_idx)

    spit_detail = [ lrow("Target location:", @w[:wg_spit_loc]) ]
    spit_detail.each { |r| r.sensitive = @w[:wg_spit_enabled].active? }
    @w[:wg_spit_enabled].signal_connect("toggled") { spit_detail.each { |r| r.sensitive = @w[:wg_spit_enabled].active? } }

    wtb.pack_start(@w[:wg_feint_enabled], false, false, 3)
    wtb.pack_start(@w[:wg_spit_enabled],  false, false, 3)
    spit_detail.each { |r| wtb.pack_start(r, false, false, 2) }
    vb.pack_start(wtf, false, false, 4)

    # Apply initial guild checkbox sensitivity based on current CMAN store state.
    # (pg_combat_abilities runs first so the store is already populated.)
    Gtk.queue { refresh_guild_from_cman }

    # ---- Note about CMAN-overlap abilities ------------------------------------
    nf = Gtk::Frame.new("Disarm Weapon & Tackle")
    nb2 = mk_vbox(4)
    nb2.border_width = 8
    nb2.pack_start(Gtk::Label.new(
      "Disarm Weapon and Tackle are learnable through both the Warrior Guild AND\n" \
      "Combat Maneuver points. Because the command is identical either way, configure them\n" \
      "in the Weapon Attack Rotation tab where all CMANs are managed."
    ).tap { |l| l.xalign = 0.0; l.wrap = true }, false, false, 0)
    nf.add(nb2)
    vb.pack_start(nf, false, false, 4)

    scrolled(vb)
  end

  def self.pg_cmans_techniques
    d    = @detected || {}
    vb   = mk_vbox(8)
    vb.border_width = 10

    cm_professions = %w[Warrior Rogue Monk Paladin Ranger Bard]
    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""
    has_cm_prof    = cm_professions.any? { |p| prof =~ /#{p}/i }
    has_cm_data    = Array(d[:feats]).any? { |f| !(f.is_a?(Hash) ? f[:passive] : false) }
    has_saved_cm   = (@saved_config || {}).fetch("cmans", []).any?
    show_cmans     = has_cm_prof && (has_cm_data || has_saved_cm)

    # ---- CMANs & Feats -------------------------------------------------------
    if !show_cmans
      cf = Gtk::Frame.new("CMANs & Feats")
      msg = has_cm_prof ?
        "No Combat Maneuvers detected yet -- this section will appear once you train a CM.\nProfessions with CM lists: #{cm_professions.join(', ')}." :
        "#{prof.empty? ? 'This profession' : prof} does not have a Combat Maneuver list.\nProfessions with CM lists: #{cm_professions.join(', ')}."
      cf.add(Gtk::Label.new(msg).tap { |l| l.xalign = 0.0; l.wrap = true })
      @cman_store = nil
      _cman_widget = cf; _cman_expand = false
    else
    cf, cb = frame_vbox("CMANs & Feats")
    hint1 = Gtk::Label.new(
      "Types:  attack = every attack round  |  aoe = multiple foes (>= AoE threshold)  |  swarm = large group (>= swarm threshold)  |  " \
      "CC'd = while stunned/webbed/bound  |  maintenance = between fights (out of combat, every loop)  |  " \
      "target_vulnerable = target is stunned/webbed/prone  |  boss = target matches Boss List  |  emergency = low HP\n" \
      "Set Daily Limit to 1-3 for abilities with limited daily uses (0 = unlimited).  #TARGET in verb is replaced with the enemy ID at runtime."
    )
    hint1.xalign = 0.0; hint1.set_line_wrap(true)
    cb.pack_start(hint1, false, false, 3)

    # cols: enabled(bool), name, verb, type, stamina, cd, daily_limit
    # type values: attack, aoe, maintenance, emergency (passive feats shown separately below)
    # cols: 0=enabled, 1=name, 2=verb, 3=type, 4=stamina, 5=cd, 6=daily_limit, 7=row_sensitive, 8=grip
    @cman_store = Gtk::ListStore.new(TrueClass, String, String, String, String, String, String, TrueClass, String)

    passive_names = []
    Array(d[:feats]).each do |feat|
      name     = feat.is_a?(Hash) ? feat[:name].to_s     : feat.to_s
      mnemonic = feat.is_a?(Hash) ? feat[:mnemonic].to_s : ""
      stamina  = feat.is_a?(Hash) ? feat[:stamina].to_i  : 0
      cd       = feat.is_a?(Hash) ? feat[:cd].to_i       : 0
      is_pass  = feat.is_a?(Hash) ? feat[:passive]        : false
      saved   = (@profile["cmans"] || []).find { |c| c["name"].to_s.casecmp(name) == 0 }
      # Passive check: hardcoded list takes priority, then auto-detect, then saved type
      name_lc = name.downcase
      is_known_passive = PASSIVE_CMANS.include?(name_lc) ||
                         PASSIVE_CMAN_PREFIXES.any? { |pre| name_lc.start_with?(pre) }
      if is_known_passive || is_pass || (saved && saved["type"].to_s == "passive")
        passive_names << name
        next
      end
      iter = @cman_store.append
      @cman_store.set_value(iter, 0, saved ? saved["enabled"] != false : false)
      @cman_store.set_value(iter, 1, name)
      name_slug    = name.gsub(/\s+/, "").downcase
      default_verb = mnemonic.empty? ? "CMAN #{name_slug}" : "CMAN #{mnemonic}"
      saved_verb   = saved ? saved["verb"].to_s : nil
      # If saved verb used the name-derived fallback but we now have a real mnemonic, upgrade it
      if saved_verb && !mnemonic.empty? && ["CMAN #{name_slug}", "CM #{name_slug}"].include?(saved_verb)
        saved_verb = "CMAN #{mnemonic}"
      end
      @cman_store.set_value(iter, 2, saved_verb || default_verb)
      @cman_store.set_value(iter, 3, saved ? saved["type"].to_s    : "attack")
      @cman_store.set_value(iter, 4, saved ? saved["stamina"].to_s    : stamina.to_s)
      @cman_store.set_value(iter, 5, saved ? saved["cd"].to_s         : cd.to_s)
      @cman_store.set_value(iter, 6, saved ? saved["daily_limit"].to_s : "0")
      @cman_store.set_value(iter, 7, true)
      @cman_store.set_value(iter, 8, saved ? saved["grip"].to_s : "")
    end

    # Apply initial lock state: if a guild checkbox is already enabled, gray matching rows.
    # This handles the case where the user opens the UI with saved guild settings active.
    WG_CMAN_OVERLAPS.each do |wk, pat|
      cman_set_row_lock(pat, true) if @w[wk]&.active?
    end

    cman_tv = Gtk::TreeView.new(@cman_store)
    # Toggle column -- col 7 (row_sensitive) guards both toggling and graying
    tog_r = Gtk::CellRendererToggle.new
    tog_r.activatable = true
    tog_r.signal_connect("toggled") do |_, path|
      it = @cman_store.get_iter(path)
      next unless it && @cman_store.get_value(it, 7)  # ignore clicks on locked rows
      new_val  = !@cman_store.get_value(it, 0)
      row_name = @cman_store.get_value(it, 1).to_s
      @cman_store.set_value(it, 0, new_val)
      # If this row matches a guild overlap, gray/restore the guild checkbox
      WG_CMAN_OVERLAPS.each do |wk, pat|
        next unless row_name =~ pat
        @w[wk]&.sensitive = !new_val
      end
    end
    cman_tv.append_column(Gtk::TreeViewColumn.new("Use", tog_r, "active" => 0, "sensitive" => 7))
    [["Name", 1], ["Verb", 2]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @cman_store.get_iter(path); @cman_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i, "sensitive" => 7); c.resizable = true
      cman_tv.append_column(c)
    end
    # Type is read-only -- set by detection or the Add dialog, not hand-editable
    type_r = Gtk::CellRendererText.new; type_r.editable = false
    cman_tv.append_column(Gtk::TreeViewColumn.new("Type", type_r, "text" => 3, "sensitive" => 7).tap { |c| c.resizable = true })
    [["Stamina", 4], ["CD(s)", 5], ["Daily Limit (0=none)", 6], ["Grip (one/two/blank)", 8]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = @cman_store.get_iter(path); @cman_store.set_value(it, i, val) if it }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i, "sensitive" => 7); c.resizable = true
      cman_tv.append_column(c)
    end
    @w[:cman_tv] = cman_tv

    cman_sw = Gtk::ScrolledWindow.new
    cman_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    cman_sw.add(cman_tv); cman_sw.set_size_request(-1, 150)
    cb.pack_start(cman_sw, true, true, 0)

    cman_btns = mk_hbox(6)
    cman_add = Gtk::Button.new("Add")
    cman_rem = Gtk::Button.new("Remove Selected")
    cman_add.signal_connect("clicked") { cman_add_dialog }
    cman_rem.signal_connect("clicked") { sel = cman_tv.selection.selected; @cman_store.remove(sel) if sel }
    cman_btns.pack_start(cman_add, false, false, 0)
    cman_btns.pack_start(cman_rem, false, false, 0)
    cb.pack_start(cman_btns, false, false, 3)

    unless passive_names.empty?
      pass_lbl = Gtk::Label.new("Always-on passive feats (no activation needed): #{passive_names.join(', ')}")
      pass_lbl.xalign = 0.0
      pass_lbl.set_line_wrap(true)
      cb.pack_start(pass_lbl, false, false, 4)
    end

    _cman_widget = cf; _cman_expand = true
    end # show_cmans

    # ---- Weapon Techniques ---------------------------------------------------
    has_saved_tech = (@saved_config || {}).fetch("techniques", []).any?
    has_any_tech   = Array(d[:techniques]).any? || has_saved_tech
    if !has_any_tech
      tf = Gtk::Frame.new("Weapon Techniques")
      tf.add(Gtk::Label.new("No weapon techniques trained yet -- this section will appear once you train one.").tap { |l| l.xalign = 0.0; l.wrap = true })
      @tech_store = nil
      _tech_widget = tf; _tech_expand = false
    else
    tf, tb = frame_vbox("Weapon Techniques")
    hint2 = Gtk::Label.new(
      "Check techniques you want the script to use. Assault and AoE default to checked; Reaction and Setup default to unchecked.\n" \
      "Grip: set to 'one' or 'two' if this technique requires a specific grip (e.g. Flurry on a katana trained 1HE needs 'one'). Leave blank if no grip switch is needed.\n" \
      "Reaction techniques fire instantly when the game signals the opportunity."
    )
    hint2.xalign = 0.0; hint2.set_line_wrap(true)
    tb.pack_start(hint2, false, false, 3)

    # cols: 0=enabled, 1=name, 2=verb, 3=tech_type, 4=trigger, 5=stamina,
    #        6=min_creatures, 7=min_rank, 8=grip, 9=mnemonic, 10=ranks, 11=category, 12=row_sensitive
    @tech_store = Gtk::ListStore.new(TrueClass, String, String, String, String, String, String, String, String, String, String, String, TrueClass)

    saved_techs    = (@saved_config || {}).fetch("techniques", nil)
    saved_tech_map = saved_techs&.each_with_object({}) { |t, h| h[t["name"].to_s.downcase] = t }

    Array(d[:techniques]).each do |tech|
      name          = tech.is_a?(Hash) ? tech[:name]          : tech.to_s
      tech_type     = tech.is_a?(Hash) ? tech[:tech_type]     : "unknown"
      verb          = tech.is_a?(Hash) ? tech[:verb]          : "weapon #{name.downcase.gsub(/\s+/, '')}"
      min_creatures = tech.is_a?(Hash) ? tech[:min_creatures] : (tech_type == "aoe" ? 3 : 1)
      mnemonic      = tech.is_a?(Hash) ? tech[:mnemonic].to_s : ""
      known_rank    = WEAPON_TECH_KNOWN[mnemonic]&.dig(:rank)
      min_rank      = tech.is_a?(Hash) ? (tech[:min_rank] || known_rank || "?").to_s : "?"
      ranks         = tech.is_a?(Hash) ? tech[:ranks].to_s    : ""
      category      = tech.is_a?(Hash) ? tech[:category].to_s : ""
      saved         = saved_tech_map&.delete(name.downcase)
      enabled       = saved ? saved["enabled"] != false : false
      trigger       = saved ? saved.fetch("trigger", "").to_s    : ""
      stamina       = saved ? saved.fetch("stamina", 0).to_s     : "0"
      min_creatures = saved ? saved.fetch("min_creatures", min_creatures).to_s : min_creatures.to_s
      min_rank      = saved ? saved.fetch("min_rank", min_rank).to_s : min_rank
      iter = @tech_store.append
      @tech_store.set_value(iter, 0, enabled)
      @tech_store.set_value(iter, 1, name)
      @tech_store.set_value(iter, 2, verb)
      @tech_store.set_value(iter, 3, tech_type)
      @tech_store.set_value(iter, 4, trigger)
      @tech_store.set_value(iter, 5, stamina)
      @tech_store.set_value(iter, 6, min_creatures)
      @tech_store.set_value(iter, 7, min_rank)
      default_grip = category =~ /two.hand|polearm/i ? "two" : "one"
      saved_grip   = saved ? saved.fetch("grip", nil).to_s : ""
      saved_grip   = default_grip if saved_grip.empty?
      @tech_store.set_value(iter, 8, saved_grip)
      @tech_store.set_value(iter, 9,  mnemonic)
      @tech_store.set_value(iter, 10, ranks)
      @tech_store.set_value(iter, 11, category)
      @tech_store.set_value(iter, 12, true)
    end
    # Restore saved techniques that were not returned by live detect
    (saved_tech_map || {}).each_value do |sv|
      iter = @tech_store.append
      @tech_store.set_value(iter, 0,  sv["enabled"] != false)
      @tech_store.set_value(iter, 1,  sv["name"].to_s)
      @tech_store.set_value(iter, 2,  sv["verb"].to_s)
      @tech_store.set_value(iter, 3,  sv["tech_type"].to_s)
      @tech_store.set_value(iter, 4,  sv.fetch("trigger", "").to_s)
      @tech_store.set_value(iter, 5,  sv.fetch("stamina", 0).to_s)
      @tech_store.set_value(iter, 6,  sv.fetch("min_creatures", 1).to_s)
      @tech_store.set_value(iter, 7,  sv.fetch("min_rank", "?").to_s)
      @tech_store.set_value(iter, 8,  sv.fetch("grip", "").to_s)
      @tech_store.set_value(iter, 9,  sv.fetch("mnemonic", "").to_s)
      @tech_store.set_value(iter, 10, sv.fetch("ranks", "").to_s)
      @tech_store.set_value(iter, 11, sv.fetch("category", "").to_s)
      @tech_store.set_value(iter, 12, true)
    end

    tech_tv = Gtk::TreeView.new(@tech_store)
    tog_r2 = Gtk::CellRendererToggle.new
    tog_r2.activatable = true
    tog_r2.signal_connect("toggled") do |_, path|
      it = @tech_store.get_iter(path)
      @tech_store.set_value(it, 0, !@tech_store.get_value(it, 0)) if it
    end
    tech_tv.append_column(Gtk::TreeViewColumn.new("Use", tog_r2, "active" => 0, "sensitive" => 12))
    # Read-only display columns matching game output
    [["Skill", 1], ["Mnemonic", 9], ["Ranks", 10], ["Type", 3], ["Category", 11]].each do |col, i|
      r = Gtk::CellRendererText.new
      c = Gtk::TreeViewColumn.new(col, r, "text" => i, "sensitive" => 12); c.resizable = true
      tech_tv.append_column(c)
    end
    # Grip is the only user-editable column
    grip_r = Gtk::CellRendererText.new; grip_r.editable = true
    grip_r.signal_connect("edited") { |_, path, val| it = @tech_store.get_iter(path); @tech_store.set_value(it, 8, val.strip.downcase) if it }
    grip_col = Gtk::TreeViewColumn.new("Grip (one/two)", grip_r, "text" => 8, "sensitive" => 12); grip_col.resizable = true
    tech_tv.append_column(grip_col)
    @w[:tech_tv] = tech_tv

    tech_sw = Gtk::ScrolledWindow.new
    tech_sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    tech_sw.add(tech_tv); tech_sw.set_size_request(-1, 130)
    tb.pack_start(tech_sw, true, true, 0)

    tech_btns = mk_hbox(6)
    tech_add = Gtk::Button.new("Add")
    tech_rem = Gtk::Button.new("Remove Selected")
    tech_add.signal_connect("clicked") { tech_add_dialog }
    tech_rem.signal_connect("clicked") { sel = tech_tv.selection.selected; @tech_store.remove(sel) if sel }
    tech_btns.pack_start(tech_add, false, false, 0)
    tech_btns.pack_start(tech_rem, false, false, 0)
    tb.pack_start(tech_btns, false, false, 3)
    _tech_widget = tf; _tech_expand = true
    end # has_any_tech

    vb.pack_start(_cman_widget, _cman_expand, _cman_expand, 0)
    vb.pack_start(_tech_widget, _tech_expand, _tech_expand, 0)
    scrolled(vb)
  end

  def self.pg_combat_abilities
    d    = @detected || {}
    vb   = mk_vbox(8)
    vb.border_width = 10
    prof = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue nil) || (XMLData.profession rescue "") || ""

    # ---- Weapon Attack Rotation -----------------------------------------------
    # Builds the items list for weapon rotation dropdowns.
    # Each item: {key: String, label: String}
    # key format: "normal_attack", "feat:chastise", "feat:excoriate",
    #             "mount_charge", "mount_trample",
    #             "cman:<Name>", "technique:<Name>"
    build_weapon_rot_items = lambda do |include_trample, aoe_mode = false|
      items = if aoe_mode
                [{key: "skip", label: "-- Skip (unused slot) --"}]
              else
                [{key: "skip", label: "-- Skip (unused slot) --"}, {key: "normal_attack", label: "-- Normal Attack --"}]
              end
      if prof =~ /Paladin/i
        items << {key: "feat:chastise",  label: "FEAT: Chastise (15s CD, 10 stamina)"}
        items << {key: "feat:excoriate", label: "FEAT: Excoriate (15s CD, 10 mana)"}
      end
      items << {key: "mount_charge",  label: "Mount: Charge"}
      items << {key: "mount_trample", label: "Mount: Trample"} if include_trample
      soc_name = (@saved_config || {}).dig("society", "name").to_s
      soc_rank = (@saved_config || {}).dig("society", "rank").to_i
      (SOCIETY_ATTACKS[soc_name] || []).each do |sa|
        next if soc_rank < sa[:rank]
        items << {key: "society_attack:#{sa[:cmd]}", label: "#{soc_name}: #{sa[:name]}"}
      end
      wg_saved = (@saved_config || {})["warrior_guild"] || {}
      wg_cries = wg_saved["warcries"] || {}
      WG_WARCRIES.each do |cry|
        next unless (wg_cries[cry[:key]] || {})["enabled"]
        items << {key: "warcry:#{cry[:key]}", label: "Warcry: #{cry[:desc].split(' -- ').first}"}
      end
      if wg_saved["feint_enabled"]
        items << {key: "warrior_feint", label: "Warrior Feint (WTRICK FEINT)"}
      end
      if wg_saved["spit_enabled"]
        items << {key: "warrior_spit", label: "Warrior Spit (WTRICK SPIT)"}
      end
      rg_saved = (@saved_config || {})["rogue_guild"] || {}
      if rg_saved["ss_enabled"]
        items << {key: "rogue_ss", label: "Rogue: Silent Strike"}
      end
      # Vissi assigned to emergency priorities are not available for rotation use.
      ep_vissi_keys = ((@saved_config || {})["emergency_priorities"] || {}).each_value.flat_map do |entries|
        Array(entries).select { |e| e.is_a?(Hash) && e["type"] == "vissi" }
                      .map    { |e| "vissi:#{e['arcarium']}:#{e['name']}" }
      end.to_set
      (@saved_config || {})["arcarium"]&.each do |arc_key, arc_cfg|
        next unless arc_cfg.is_a?(Hash) && arc_cfg["enabled"]
        noun = arc_cfg["noun"].to_s
        (arc_cfg["vissi"] || []).each do |v|
          next unless v.is_a?(Hash)
          next if v["verb"].to_s.strip == "(passive)"
          vkey = "vissi:#{arc_key}:#{v['name']}"
          next if ep_vissi_keys.include?(vkey)
          items << {key: vkey, label: "Arcarium (#{noun}): #{v['name']}"}
        end
      end
      trinket_defs = [
        ["energy_wings",    SCRIPT_TEMPLATES.dig("Energy Wings",    :weapon) || [], "Energy Wings"],
        ["battle_standard", SCRIPT_TEMPLATES.dig("Battle Standard", :armor)  || [], "Battle Standard"],
        ["elemental_gloves", EG_ABILITIES, "Elemental Gloves"],
        ["twisted_gloves",   TG_ABILITIES, "Twisted Gloves"],
        ["twisted_kicks",    TK_ABILITIES, "Twisted Kicks"],
      ]
      trinket_defs.each do |slot, tmpl, display|
        cfg = (@saved_config || {}).dig("trinkets", slot)
        next unless cfg.is_a?(Hash) && cfg["enabled"]
        noun    = cfg["noun"].to_s.strip
        ab_cfg  = cfg["abilities"] || {}
        tier    = cfg["tier"].to_i
        wing_type = cfg["wing_type"].to_s.downcase  # "light", "dark", or ""
        tmpl.each do |ab|
          next if ab[:min_tier] && ab[:min_tier] > tier
          next if ab[:when].to_s == "skip"
          # Filter Light/Dark split abilities by the configured wing type
          if ab[:type] && ab[:type] != :both && !wing_type.empty?
            next unless ab[:type].to_s == wing_type
          end
          key = ab[:key].to_s
          label_noun = noun.empty? ? display : "#{display} (#{noun})"
          items << {
            key:   "trinket:#{slot}:#{key}",
            label: "#{label_noun}: #{key}"
          }
        end
      end
      # Gemstone activated abilities
      Array(@profile.dig("gemstones", "slots")).each do |slot|
        next unless slot.is_a?(Hash) && slot["enabled"]
        next if slot["activated_property"].to_s.strip.empty?
        slot_num = slot["slot_num"].to_i
        gem_name = slot["name"].to_s.strip
        prop     = slot["activated_property"].to_s.strip
        key      = "gemstone:#{slot_num}"
        label    = "Gemstone #{slot_num}: #{gem_name.empty? ? prop : gem_name} (#{prop})"
        items << {key: key, label: label}
      end
      # Weapon script abilities
      Array(@profile.dig("weapons","primary","scripts")).each do |sc|
        Array(sc["abilities"]).each do |ab|
          key   = "script_wpn:#{ab['key']}"
          label = "Script (weapon/#{sc['name']}): #{ab['key']} -- #{ab['desc'].to_s.split('--').first.strip}"
          items << {key: key, label: label}
        end
      end
      # Armor script abilities
      Array(@profile.dig("armor","scripts")).each do |sc|
        Array(sc["abilities"]).each do |ab|
          key   = "script_arm:#{ab['key']}"
          label = "Script (armor/#{sc['name']}): #{ab['key']} -- #{ab['desc'].to_s.split('--').first.strip}"
          items << {key: key, label: label}
        end
      end
      (@saved_config || {}).fetch("cmans", []).each do |cm|
        next unless cm.is_a?(Hash)
        name = cm["name"].to_s
        next if name.empty?
        next if cm["type"].to_s == "passive"
        next if cm["verb"].to_s =~ /\bsurge\b/i
        items << {key: "cman:#{name}", label: "CMan: #{name}"}
      end
      (@saved_config || {}).fetch("techniques", []).each do |tech|
        next unless tech.is_a?(Hash)
        name = tech["name"].to_s
        next if name.empty?
        next if tech["tech_type"].to_s == "reaction"
        items << {key: "technique:#{name}", label: "Technique: #{name}"}
      end
      @shield_spec_store&.each do |_m, _p, iter|
        name      = @shield_spec_store.get_value(iter, 1).to_s
        verb      = @shield_spec_store.get_value(iter, 2).to_s
        tech_type = @shield_spec_store.get_value(iter, 3).to_s
        next if name.empty? || %w[buff passive].include?(tech_type)
        items << {key: "shield_spec:#{name}", label: "Shield Spec: #{name} (#{verb})"}
      end
      items << {key: "spell", label: "Spell"}
      items
    end

    st_items  = build_weapon_rot_items.call(true, false)
    aoe_items = build_weapon_rot_items.call(true, true)

    # Returns the combo index for a saved entry hash, defaulting to 0 (Normal Attack).
    rot_entry_to_idx = lambda do |entry, items|
      return 0 unless entry.is_a?(Hash)
      key = case entry["type"].to_s
            when "normal_attack" then "normal_attack"
            when "feat"          then "feat:#{entry['name']}"
            when "mount_charge"  then "mount_charge"
            when "mount_trample" then "mount_trample"
            when "cman"          then "cman:#{entry['name']}"
            when "technique"     then "technique:#{entry['name']}"
            when "warcry"        then "warcry:#{entry['key']}"
            when "warrior_feint" then "warrior_feint"
            when "warrior_spit"  then "warrior_spit"
            when "rogue_ss"      then "rogue_ss"
            when "vissi" then "vissi:#{entry['arcarium']}:#{entry['name']}"
            when "trinket"  then "trinket:#{entry['slot']}:#{entry['ability_key']}"
            when "gemstone" then "gemstone:#{entry['slot_num']}"
            when "script_wpn"     then "script_wpn:#{entry['key']}"
            when "script_arm"     then "script_arm:#{entry['key']}"
            when "society_attack" then "society_attack:#{entry['cmd']}"
            when "shield_spec"   then "shield_spec:#{entry['name']}"
            when "spell" then "spell"
            when "skip" then "skip"
            else "normal_attack"
            end
      items.index { |it| it[:key] == key } || 0
    end

    # Gray-out any CMan row whose name is selected in any rotation combo.
    @weapon_rot_combos_st  = []
    @weapon_rot_combos_aoe = []

    @sync_cman_grayouts = sync_cman_grayouts = lambda do
      selected_cmans = Set.new
      (@weapon_rot_combos_st + @weapon_rot_combos_aoe).each do |combo_pair|
        items_arr, combo, _ent = combo_pair
        key = combo.active_id.to_s
        selected_cmans.add(key.sub("cman:", "")) if key.start_with?("cman:")
      end
      @cman_store&.each do |_m, _p, iter|
        name   = @cman_store.get_value(iter, 1).to_s
        in_rot = selected_cmans.include?(name)
        @cman_store.set_value(iter, 7, !in_rot)
        @cman_store.set_value(iter, 0, false) if in_rot
      end

      # Gray out technique rows whose name is selected in any rotation combo
      if @tech_store
        selected_techs = Set.new
        (@weapon_rot_combos_st + @weapon_rot_combos_aoe).each do |combo_pair|
          items_arr, combo, _ent = combo_pair
          key = combo.active_id.to_s
          selected_techs.add(key.sub("technique:", "")) if key.start_with?("technique:")
        end
        @tech_store.each do |_m, _p, iter|
          name   = @tech_store.get_value(iter, 1).to_s
          in_rot = selected_techs.include?(name)
          @tech_store.set_value(iter, 0, false) if in_rot
          @tech_store.set_value(iter, 12, !in_rot)
        end
      end

      # Gray out Mount Charge row on Mount tab if mount_charge is in ST rotation
      charge_in_rot = (@rot_st_pairs || []).any? do |items_arr, combo, _ent|
        combo.active_id.to_s == "mount_charge"
      end
      @w[:mount_charge_row_widgets]&.each { |ww| ww.sensitive = !charge_in_rot }
      if charge_in_rot
        @w[:mount_charge_when_saved] ||= @w[:mount_charge_when]&.active
        @w[:mount_charge_when]&.active = -1
      elsif (sv = @w.delete(:mount_charge_when_saved))
        @w[:mount_charge_when]&.active = sv
      end

      # Gray out Mount Trample row on Mount tab if mount_trample is in AoE rotation
      trample_in_rot = (@rot_aoe_pairs || []).any? do |items_arr, combo, _ent|
        combo.active_id.to_s == "mount_trample"
      end
      @w[:mount_trample_row_widgets]&.each { |ww| ww.sensitive = !trample_in_rot }
      if trample_in_rot
        @w[:mount_trample_when_saved] ||= @w[:mount_trample_when]&.active
        @w[:mount_trample_when]&.active = -1
      elsif (sv = @w.delete(:mount_trample_when_saved))
        @w[:mount_trample_when]&.active = sv
      end

      # Lock 'I use mount combat' on when any mount ability is in the rotation
      if @w[:mount_enabled]
        mount_in_rot = charge_in_rot || trample_in_rot
        if mount_in_rot
          @w[:mount_enabled].active    = true
          @w[:mount_enabled].sensitive = false
        else
          @w[:mount_enabled].sensitive = true
        end
      end

      # Gray out vissi rows whose vissi is in the ST/AoE rotation OR Emergency Priorities.
      # Rotation key format: "vissi:arc_key:vissi_name"; EP store: col0=type, col2=arcarium, col3=name.
      vissi_in_rot = Set.new
      ((@rot_st_pairs || []) + (@rot_aoe_pairs || [])).each do |items_arr, combo, _ent|
        key = combo.active_id.to_s
        vissi_in_rot << key.sub("vissi:", "") if key.start_with?("vissi:")
      end
      [:ep_low_health_store, :ep_cc_store].each do |ep_sym|
        (@w[ep_sym] || nil)&.each do |_, _, iter|
          next unless (@w[ep_sym].get_value(iter, 0).to_s == "vissi")
          arc_k = @w[ep_sym].get_value(iter, 2).to_s
          name  = @w[ep_sym].get_value(iter, 3).to_s
          vissi_in_rot << "#{arc_k}:#{name}" unless arc_k.empty? || name.empty?
        end
      end
      (@w[:vissi_stores] || {}).each do |arc_k, s|
        next unless s
        s.each do |_, _, iter|
          name    = s.get_value(iter, 1).to_s
          passive = s.get_value(iter, 2).to_s.strip == "(passive)"
          next if passive
          in_rot = vissi_in_rot.include?("#{arc_k}:#{name}")
          s.set_value(iter, 0, false) if in_rot
          s.set_value(iter, 6, !in_rot)
        end
      end

      # Gray out gemstone activated slots when the slot is in either rotation
      gem_slots_in_rot = Set.new
      ((@rot_st_pairs || []) + (@rot_aoe_pairs || [])).each do |items_arr, combo, _ent|
        key = combo.active_id.to_s
        gem_slots_in_rot << $1.to_i if key =~ /\Agemstone:(\d+)/
      end
      (@w[:gem_slot_widgets] || {}).each do |sn, widgets|
        sensitive = !gem_slots_in_rot.include?(sn)
        widgets.each { |ww| ww.sensitive = sensitive rescue nil }
      end

      # Script ability grayout
      wpn_scripts_in_rot = Set.new
      arm_scripts_in_rot = Set.new
      ((@rot_st_pairs || []) + (@rot_aoe_pairs || [])).each do |items_arr, combo, _|
        key = combo.active_id.to_s
        wpn_scripts_in_rot << $1 if key =~ /\Ascript_wpn:(.+)/
        arm_scripts_in_rot << $1 if key =~ /\Ascript_arm:(.+)/
      end
      (@w[:script_wpn_widgets] || {}).each do |k, widgets|
        s = !wpn_scripts_in_rot.include?(k)
        widgets.each { |w| w.sensitive = s rescue nil }
      end
      (@w[:script_arm_widgets] || {}).each do |k, widgets|
        s = !arm_scripts_in_rot.include?(k)
        widgets.each { |w| w.sensitive = s rescue nil }
      end

      # Trinket ability grayout
      trinkets_in_rot = Set.new
      ((@rot_st_pairs || []) + (@rot_aoe_pairs || [])).each do |items_arr, combo, _|
        key = combo.active_id.to_s
        trinkets_in_rot << $1 if key =~ /\Atrinket:(.+)/
      end
      (@w[:trinket_ability_widgets] || {}).each do |k, widgets|
        in_rot = trinkets_in_rot.include?(k)
        widgets.each do |ww|
          (ww.sensitive = !in_rot) rescue nil
          next unless in_rot
          if ww.is_a?(Gtk::ToggleButton)
            ww.active = false rescue nil
          elsif ww.is_a?(Gtk::ComboBox)
            ww.active = -1 rescue nil
          end
        end
      end

      # Shield spec grayout -- non-passive specs selected in rotation gray out here
      if @shield_spec_store
        ss_in_rot = Set.new
        ((@rot_st_pairs || []) + (@rot_aoe_pairs || [])).each do |items_arr, combo, _|
          key = combo.active_id.to_s
          ss_in_rot << $1 if key =~ /\Ashield_spec:(.+)/
        end
        @shield_spec_store.each do |_m, _p, iter|
          name   = @shield_spec_store.get_value(iter, 1).to_s
          in_rot = ss_in_rot.include?(name)
          @shield_spec_store.set_value(iter, 5, !in_rot)
          @shield_spec_store.set_value(iter, 0, false) if in_rot
        end
      end

      # CC'd Priority grayout -- abilities in the CC'd list are suppressed in Trinkets tab
      if @w[:ep_cc_store]
        cc_ability_keys = Set.new
        @w[:ep_cc_store].each do |_m, _p, iter|
          next unless @w[:ep_cc_store].get_value(iter, 0) == "ability"
          slot = @w[:ep_cc_store].get_value(iter, 2).to_s
          key  = @w[:ep_cc_store].get_value(iter, 3).to_s
          cc_ability_keys << "#{slot}:#{key}"
        end
        (@w[:trinket_ability_widgets] || {}).each do |k, widgets|
          next if trinkets_in_rot.include?(k) # already handled above
          in_cc = cc_ability_keys.include?(k)
          widgets.each do |ww|
            (ww.sensitive = !in_cc) rescue nil
            next unless in_cc
            if ww.is_a?(Gtk::ToggleButton)
              ww.active = false rescue nil
            elsif ww.is_a?(Gtk::ComboBox)
              ww.active = -1 rescue nil
            end
          end
        end
      end
    end

    build_weapon_rot_frame = lambda do |frame_title, hint_text, saved_rot, items, combos_arr, keys|
      rf, rb = frame_vbox(frame_title)
      rl = Gtk::Label.new(hint_text)
      rl.xalign = 0.0; rl.set_line_wrap(true)
      rl.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
      rb.pack_start(rl, false, false, 3)

      ["1st:", "2nd:", "3rd:", "4th:", "5th:", "6th:", "7th:", "8th:"].each_with_index do |lbl, i|
        combo = Gtk::ComboBoxText.new
        items.each { |it| combo.append(it[:key].to_s, it[:label]) }
        combo.active = 0

        spell_combo = Gtk::ComboBoxText.new
        spell_combo.append("", "-- select spell --")
        # Build cmd lookup from hardcoded list (preserves cast vs incant decisions)
        rot_spell_cmd = OFFENSIVE_SPELLS.map { |s| [s[:num], s[:cmd]] }.to_h
        # Use detected known spells filtered by spell_offensive? -- same logic as Spells tab
        rot_known_off = Array((@detected || {})[:known_spells])
          .reject { |s| s[:num].between?(1001, 1040) || [1604, 1607, 1609, 1615, 1617, 1618, 1620, 1625, 1635, 1640, 1650].include?(s[:num]) }
          .select { |s| spell_offensive?(s) }
          .sort_by { |s| s[:num] }
        if rot_known_off.any?
          rot_known_off.each do |s|
            cmd = rot_spell_cmd[s[:num]] || "incant #{s[:num]}"
            spell_combo.append(cmd, "#{s[:num]} - #{s[:name]}")
          end
        else
          # Fallback when detection has not run: use hardcoded list with Spell[] availability check
          OFFENSIVE_SPELLS.select { |s| Spell[s[:num]].known? rescue false }
                          .each   { |s| spell_combo.append(s[:cmd], s[:label]) }
        end
        spell_combo.active = 0
        spell_combo.visible = false
        spell_combo.no_show_all = true

        saved_val = Array(saved_rot)[i]
        saved_key = items[rot_entry_to_idx.call(saved_val, items)]&.fetch(:key, nil).to_s
        combo.active_id = saved_key
        combo.active = 0 if combo.active < 0
        # Pre-populate spell combo if saved entry is a spell
        if saved_val.is_a?(Hash) && saved_val["type"] == "spell"
          saved_cmd = saved_val["cmd"].to_s
          spell_combo.active_id = saved_cmd unless saved_cmd.empty?
          spell_combo.active = 0 if spell_combo.active < 0
          spell_combo.visible = true
        end

        combo.signal_connect("changed") do
          k = combo.active_id.to_s
          spell_combo.visible = (k == "spell")
          # Vissi dedup: if this slot just picked a vissi, clear it from any other slot
          # that already had it. No model manipulation -- just reset the other combo's
          # active index (GTK ComboBoxText model APIs crash on this Ruby-GNOME2/Windows build).
          if k.start_with?("vissi:")
            combos_arr.each do |_, c, _|
              next if c.equal?(combo)
              c.active = 0 if c.active_id.to_s == k
            end
          end
          sync_cman_grayouts.call
          update_rotation_sensitivity.call if defined?(update_rotation_sensitivity)
        end

        combos_arr << [items, combo, spell_combo]
        @w[keys[i]] = combo

        row_hbox = Gtk::HBox.new(false, 4)
        row_hbox.pack_start(combo, false, false, 0)
        row_hbox.pack_start(spell_combo, false, false, 0)
        rb.pack_start(lrow(lbl, row_hbox), false, false, 2)
      end


      rf
    end

    saved_st_rot  = (@saved_config || {}).dig("weapons", "weapon_rotation")  || []
    saved_aoe_rot = (@saved_config || {}).dig("weapons", "weapon_aoe_rotation") || []

    caster_note = Gtk::Label.new(
      "Note: Weapon rotation applies to melee and mixed characters. " \
      "Pure casters using a runestaff use the Spell Attack Rotation tab instead -- " \
      "this tab is hidden when a runestaff is selected as your primary weapon. " \
      "If a CMan appears in your rotation, it will be grayed out in the list above to prevent double-firing."
    )
    caster_note.xalign = 0.0; caster_note.set_line_wrap(true)
    caster_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    _rot_hsep = mk_hsep

    hybrid_note = Gtk::Label.new
    hybrid_note.markup = "<i>Hybrid classes: add spells here using the Spell type. When this rotation is active, the Spells tab rotation is disabled.</i>"
    hybrid_note.wrap = true
    hybrid_note.xalign = 0.0

    # update_rotation_sensitivity: cross-tab live grayout between weapon rotation and spell rotation.
    # Defined here so it can be referenced from combo changed signals.
    update_rotation_sensitivity = lambda do
      weapon_st_active = @rot_st_pairs&.any? do |_items_arr, combo, _ent|
        k = combo.active_id.to_s
        !k.empty? && k != "skip" && k != "normal_attack"
      end
      weapon_aoe_active = @rot_aoe_pairs&.any? do |_items_arr, combo, _ent|
        k = combo.active_id.to_s
        !k.empty? && k != "skip"
      end
      spell_st_active  = Array(@profile&.dig("spells", "rotation")).any?  { |e| e.is_a?(Hash) }
      spell_aoe_active = Array(@profile&.dig("spells", "aoe_rotation")).any? { |e| e.is_a?(Hash) }

      @w[:spell_rot_st_box]&.sensitive  = !weapon_st_active
      @w[:spell_rot_aoe_box]&.sensitive = !weapon_aoe_active

      unless weapon_st_active
        @rot_st_pairs&.each { |_ia, c, e| c.sensitive = !spell_st_active; e.sensitive = !spell_st_active }
      end
      unless weapon_aoe_active
        @rot_aoe_pairs&.each { |_ia, c, e| c.sensitive = !spell_aoe_active; e.sensitive = !spell_aoe_active }
      end
    end

    _rot_st_frame = build_weapon_rot_frame.call(
      "Single Target Attack Rotation",
      "Cycles through each slot in order. If a slotted ability is on cooldown or unavailable, the script automatically falls back to a Normal Attack for that round -- you do not need to add Normal Attack to the rotation. Resets at the start of each new target engagement.",
      saved_st_rot, st_items, @weapon_rot_combos_st,
      [:wrot_st_1, :wrot_st_2, :wrot_st_3, :wrot_st_4, :wrot_st_5, :wrot_st_6, :wrot_st_7, :wrot_st_8]
    )
    @rot_st_pairs = @weapon_rot_combos_st

    _rot_aoe_frame = build_weapon_rot_frame.call(
      "AoE / Multi-Target Attack Rotation",
      "Each round, when creature count meets the AoE threshold, one slot from this list fires first -- then one slot from the Single Target rotation fires in the same round. Both cycle independently. Set the threshold in Hunting Preferences 2.",
      saved_aoe_rot, aoe_items, @weapon_rot_combos_aoe,
      [:wrot_aoe_1, :wrot_aoe_2, :wrot_aoe_3, :wrot_aoe_4, :wrot_aoe_5, :wrot_aoe_6, :wrot_aoe_7, :wrot_aoe_8]
    )
    @rot_aoe_pairs = @weapon_rot_combos_aoe

    sync_cman_grayouts.call
    update_rotation_sensitivity.call

    # Pack in display order: notes at top, then ST and AoE rotation frames
    vb.pack_start(caster_note,    false, false, 3)
    vb.pack_start(hybrid_note,    false, false, 3)
    vb.pack_start(_rot_hsep,      false, false, 4)
    vb.pack_start(_rot_st_frame,  false, false, 5)
    vb.pack_start(_rot_aoe_frame, false, false, 5)

    scrolled(vb)
  end

  # ===========================================================================
  # Spell Attack Rotation tab (runestaff / pure-caster rotation)
  # Hidden when primary weapon is not a runestaff; shown when it is.
  # ===========================================================================
  def self.pg_spell_rotation
    d    = @detected || {}
    vb   = mk_vbox(8)
    vb.border_width = 10

    known = Array(d[:known_spells])

    intro = Gtk::Label.new(
      "Configure your attack sequence for each round. " \
      "This tab is for pure casters using a runestaff -- " \
      "hybrid classes that also melee should use the Weapon Attack Rotation tab instead, " \
      "which supports spell slots alongside melee abilities."
    )
    intro.xalign = 0.0
    intro.set_line_wrap(true)
    vb.pack_start(intro, false, false, 4)

    # ---------- items list (no melee-specific types) ----------------------------
    items = [{key: "skip", label: "-- Skip (unused slot) --"},
             {key: "spell", label: "Spell (select below)"}]

    mount_cfg = (@saved_config || {})["mount"] || {}
    if mount_cfg["enabled"]
      items << {key: "mount_charge",  label: "Mount: Charge"}
      items << {key: "mount_trample", label: "Mount: Trample"}
    end

    ep_vissi_keys = ((@saved_config || {})["emergency_priorities"] || {}).each_value.flat_map do |entries|
      Array(entries).select { |e| e.is_a?(Hash) && e["type"] == "vissi" }
                    .map    { |e| "vissi:#{e['arcarium']}:#{e['name']}" }
    end.to_set
    (@saved_config || {})["arcarium"]&.each do |arc_key, arc_cfg|
      next unless arc_cfg.is_a?(Hash) && arc_cfg["enabled"]
      noun = arc_cfg["noun"].to_s
      (arc_cfg["vissi"] || []).each do |v|
        next unless v.is_a?(Hash)
        next if v["verb"].to_s.strip == "(passive)"
        vkey = "vissi:#{arc_key}:#{v['name']}"
        next if ep_vissi_keys.include?(vkey)
        items << {key: vkey, label: "Arcarium (#{noun}): #{v['name']}"}
      end
    end

    trinket_defs = [
      ["energy_wings",     SCRIPT_TEMPLATES.dig("Energy Wings",    :weapon) || [], "Energy Wings"],
      ["battle_standard",  SCRIPT_TEMPLATES.dig("Battle Standard", :armor)  || [], "Battle Standard"],
      ["elemental_gloves", EG_ABILITIES, "Elemental Gloves"],
      ["twisted_gloves",   TG_ABILITIES, "Twisted Gloves"],
      ["twisted_kicks",    TK_ABILITIES, "Twisted Kicks"],
    ]
    trinket_defs.each do |slot, tmpl, display|
      cfg = (@saved_config || {}).dig("trinkets", slot)
      next unless cfg.is_a?(Hash) && cfg["enabled"]
      noun      = cfg["noun"].to_s.strip
      tier      = cfg["tier"].to_i
      wing_type = cfg["wing_type"].to_s.downcase
      tmpl.each do |ab|
        next if ab[:min_tier] && ab[:min_tier] > tier
        next if ab[:when].to_s == "skip"
        if ab[:type] && ab[:type] != :both && !wing_type.empty?
          next unless ab[:type].to_s == wing_type
        end
        label_noun = noun.empty? ? display : "#{display} (#{noun})"
        items << {key: "trinket:#{slot}:#{ab[:key]}", label: "#{label_noun}: #{ab[:key]}"}
      end
    end

    Array(@profile.dig("gemstones", "slots")).each do |slot|
      next unless slot.is_a?(Hash) && slot["enabled"]
      next if slot["activated_property"].to_s.strip.empty?
      slot_num = slot["slot_num"].to_i
      gem_name = slot["name"].to_s.strip
      prop     = slot["activated_property"].to_s.strip
      items << {key: "gemstone:#{slot_num}", label: "Gemstone #{slot_num}: #{gem_name.empty? ? prop : gem_name} (#{prop})"}
    end

    Array(@profile.dig("weapons", "primary", "scripts")).each do |sc|
      Array(sc["abilities"]).each do |ab|
        items << {key: "script_wpn:#{ab['key']}", label: "Script (weapon/#{sc['name']}): #{ab['key']} -- #{ab['desc'].to_s.split('--').first.strip}"}
      end
    end
    Array(@profile.dig("armor", "scripts")).each do |sc|
      Array(sc["abilities"]).each do |ab|
        items << {key: "script_arm:#{ab['key']}", label: "Script (armor/#{sc['name']}): #{ab['key']} -- #{ab['desc'].to_s.split('--').first.strip}"}
      end
    end

    # ---------- spell sub-combo (shown when type = spell) -----------------------
    rot_spell_cmd = OFFENSIVE_SPELLS.map { |s| [s[:num], s[:cmd]] }.to_h
    rot_known_off = known
      .reject { |s| s[:num].between?(1001, 1040) || [1604, 1607, 1609, 1615, 1617, 1618, 1620, 1625, 1635, 1640, 1650].include?(s[:num]) }
      .select  { |s| spell_offensive?(s) }
      .sort_by { |s| s[:num] }

    # ---------- helper to map a saved entry back to combo active_id key ---------
    entry_to_key = lambda do |entry|
      return nil unless entry.is_a?(Hash)
      case entry["type"].to_s
      when "spell"         then "spell"
      when "mount_charge"  then "mount_charge"
      when "mount_trample" then "mount_trample"
      when "vissi"         then "vissi:#{entry['arcarium']}:#{entry['name']}"
      when "trinket"       then "trinket:#{entry['slot']}:#{entry['ability_key']}"
      when "gemstone"      then "gemstone:#{entry['slot_num']}"
      when "script_wpn"    then "script_wpn:#{entry['key']}"
      when "script_arm"    then "script_arm:#{entry['key']}"
      end
    end

    # ---------- frame builder ---------------------------------------------------
    @spell_rot_combos_st  = []
    @spell_rot_combos_aoe = []

    build_spell_rot_frame = lambda do |frame_title, hint_text, saved_rot, combos_arr|
      rf, rb = frame_vbox(frame_title)
      hl = Gtk::Label.new(hint_text)
      hl.xalign = 0.0; hl.set_line_wrap(true)
      rb.pack_start(hl, false, false, 3)

      ["1st:", "2nd:", "3rd:", "4th:", "5th:", "6th:", "7th:", "8th:"].each_with_index do |lbl, i|
        combo = Gtk::ComboBoxText.new
        items.each { |it| combo.append(it[:key].to_s, it[:label]) }
        combo.active = 0

        spell_combo = Gtk::ComboBoxText.new
        spell_combo.append("", "-- select spell --")
        if rot_known_off.any?
          rot_known_off.each { |s| spell_combo.append(rot_spell_cmd[s[:num]] || "incant #{s[:num]}", "#{s[:num]} - #{s[:name]}") }
        else
          OFFENSIVE_SPELLS.select { |s| Spell[s[:num]].known? rescue false }
                          .each   { |s| spell_combo.append(s[:cmd], s[:label]) }
        end
        spell_combo.active    = 0
        spell_combo.visible   = false
        spell_combo.no_show_all = true

        saved_entry = Array(saved_rot)[i]
        saved_key   = entry_to_key.call(saved_entry)
        if saved_key
          combo.active_id = saved_key
          combo.active    = 0 if combo.active < 0
          if saved_entry["type"] == "spell"
            spell_combo.active_id = saved_entry["cmd"].to_s
            spell_combo.active    = 0 if spell_combo.active < 0
            spell_combo.visible   = true
          end
        end

        combo.signal_connect("changed") { spell_combo.visible = (combo.active_id.to_s == "spell") }

        combos_arr << [items, combo, spell_combo]
        row_hbox = Gtk::HBox.new(false, 4)
        row_hbox.pack_start(combo, false, false, 0)
        row_hbox.pack_start(spell_combo, false, false, 0)
        rb.pack_start(lrow(lbl, row_hbox), false, false, 2)
      end
      rf
    end

    saved_st  = (@saved_config || {}).dig("spells", "rotation")     || []
    saved_aoe = (@saved_config || {}).dig("spells", "aoe_rotation") || []

    spell_st_frame = build_spell_rot_frame.call(
      "Single Target Rotation (always fires)",
      "Cycles through each slot in order every attack round. If a slot is on cooldown or unavailable, it is skipped.",
      saved_st, @spell_rot_combos_st
    )
    @w[:spell_rot_st_box] = spell_st_frame
    vb.pack_start(spell_st_frame, false, false, 5)

    spell_aoe_frame = build_spell_rot_frame.call(
      "AoE / Multi-Target Rotation (fires in addition to single-target when threshold is met)",
      "Fires every round alongside single-target when creature count meets the AoE threshold. AoE threshold is set in Hunting Preferences 2.",
      saved_aoe, @spell_rot_combos_aoe
    )
    @w[:spell_rot_aoe_box] = spell_aoe_frame
    vb.pack_start(spell_aoe_frame, false, false, 5)

    scrolled(vb)
  end

  def self.cman_add_dialog
    d = Gtk::Dialog.new("Add CMAN / Feat", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(460, 320)
    fields = {}
    [
      ["Name (e.g. Chastise):",              :name,    ""],
      ["Verb (e.g. CMAN chastise):",           :verb,    "CMAN "],
      ["Type (attack/engagement/aoe/swarm/CC'd/maintenance):", :type, "attack"],
      ["Stamina cost:",                       :stamina, "0"],
      ["CD in seconds (0 = no CD):",          :cd,      "0"],
    ].each do |lbl, key, dv|
      e = Gtk::Entry.new; e.text = dv; fields[key] = e
      d.vbox.pack_start(lrow(lbl, e), false, false, 3)
    end
    grip_combo = mk_combo_text(["(none -- keep current grip)", "one (GRIP ONE before firing)", "two (GRIP TWO before firing)"], 0)
    fields[:grip] = grip_combo
    d.vbox.pack_start(lrow("Grip required:", grip_combo), false, false, 3)
    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      grip_val = ["", "one", "two"][grip_combo.active] || ""
      iter = @cman_store.append
      @cman_store.set_value(iter, 0, true)
      @cman_store.set_value(iter, 1, fields[:name].text.strip)
      @cman_store.set_value(iter, 2, fields[:verb].text.strip)
      @cman_store.set_value(iter, 3, fields[:type].text.strip.downcase)
      @cman_store.set_value(iter, 4, fields[:stamina].text.strip)
      @cman_store.set_value(iter, 5, fields[:cd].text.strip)
      @cman_store.set_value(iter, 6, "0")
      name_added = fields[:name].text.strip
      locked = WG_CMAN_OVERLAPS.any? { |wk, pat| name_added =~ pat && @w[wk]&.active? }
      @cman_store.set_value(iter, 7, !locked)
      @cman_store.set_value(iter, 8, grip_val)
    end
    d.destroy
  end

  def self.tech_add_dialog
    d = Gtk::Dialog.new("Add Technique", @win,
      Gtk::Dialog::MODAL | Gtk::Dialog::DESTROY_WITH_PARENT,
      ["Add", Gtk::Dialog::RESPONSE_OK],
      ["Cancel", Gtk::Dialog::RESPONSE_CANCEL])
    d.set_default_size(460, 240)
    fields = {}
    [
      ["Name (e.g. Overpower):",                           :name,      ""],
      ["Mnemonic (e.g. overpower):",                       :mnemonic,  ""],
      ["Type (assault/aoe/reaction/concentration/setup):", :tech_type, "assault"],
    ].each do |lbl, key, dv|
      e = Gtk::Entry.new; e.text = dv; fields[key] = e
      d.vbox.pack_start(lrow(lbl, e), false, false, 3)
    end
    grip_combo = mk_combo_text(["(none -- keep current grip)", "one (GRIP ONE before firing)", "two (GRIP TWO before firing)"], 0)
    fields[:grip] = grip_combo
    d.vbox.pack_start(lrow("Grip required:", grip_combo), false, false, 3)
    d.show_all
    if d.run == Gtk::Dialog::RESPONSE_OK
      grip_val  = ["", "one", "two"][grip_combo.active] || ""
      name      = fields[:name].text.strip
      mnemonic  = fields[:mnemonic].text.strip.downcase
      tech_type = fields[:tech_type].text.strip.downcase
      verb      = mnemonic.empty? ? "weapon #{name.downcase.gsub(/\s+/, '')}" : "weapon #{mnemonic}"
      known     = WEAPON_TECH_KNOWN[mnemonic]
      min_creat = (tech_type == "aoe" ? 3 : 1).to_s
      iter = @tech_store.append
      @tech_store.set_value(iter, 0, false)
      @tech_store.set_value(iter, 1, name)
      @tech_store.set_value(iter, 2, verb)
      @tech_store.set_value(iter, 3, tech_type)
      @tech_store.set_value(iter, 4, "")
      @tech_store.set_value(iter, 5, "0")
      @tech_store.set_value(iter, 6, min_creat)
      @tech_store.set_value(iter, 7, known ? known[:rank].to_s : "?")
      @tech_store.set_value(iter, 8, grip_val)
      @tech_store.set_value(iter, 9,  mnemonic)
      @tech_store.set_value(iter, 10, "")
      @tech_store.set_value(iter, 11, "")
      @tech_store.set_value(iter, 12, true)
    end
    d.destroy
  end

  def self.pg_arcarium
    d   = @detected || {}
    vb  = mk_vbox(6)
    vb.border_width = 10
    hint = Gtk::Label.new(
      "Script analyzes each arcarium before activating -- only prods if currently inert.\n" \
      "Aversaris = offensive (attack boost). Vangaris = defensive (protection)."
    )
    hint.xalign = 0.0
    hint.set_line_wrap(true)
    vb.pack_start(hint, false, false, 5)

    build_arcarium_frame(vb, :aversaris, d[:aversaris], Array(d[:aversaris_vissi]), Array(d[:vangaris_vissi]))
    build_arcarium_frame(vb, :vangaris,  d[:vangaris],  Array(d[:vangaris_vissi]),  Array(d[:aversaris_vissi]))

    @sync_cman_grayouts&.call
    scrolled(vb)
  end

  def self.build_arcarium_frame(container, key, item, vissi_list, other_detected = [])
    label        = key == :aversaris ? "Aversaris Arcarium (offensive)" : "Vangaris Arcarium (defensive)"
    noun_default = "#{key} arcarium"
    af, ab = frame_vbox(label)

    if item
      dl = Gtk::Label.new("Detected in inventory: #{item.name}")
      dl.xalign = 0.0
      ab.pack_start(dl, false, false, 2)
    end

    enabled_cb = w_check(:"#{key}_enabled", "I have a #{key} arcarium", !item.nil?)
    ab.pack_start(enabled_cb, false, false, 3)
    add_row(ab, "Noun:", w_entry(:"#{key}_noun", noun_default))

    hint = Gtk::Label.new("")
    hint.xalign = 0.0; hint.set_line_wrap(true)
    hint.set_markup(
      "Passive vissi (no activator verb) are greyed out -- they fire automatically and cannot be configured.\n" \
      "<b>Click the \"When\" cell to choose when each vissi fires:</b>\n" \
      "  <b>(blank)</b> = disabled / handled by Emergency Priorities    <b>aoe</b> = multiple foes present    <b>swarm</b> = large group\n" \
      "  <b>maintenance</b> = out of combat (every loop)    <b>target_vulnerable</b> = target stunned/webbed/prone\n" \
      "  <b>boss</b> = target matches Boss List    <b>emergency</b> = low HP or CC'd (use Emergency Priorities instead)\n" \
      "<i>Note: vissi with a daily limit are always treated as emergency-only regardless of this setting.</i>"
    )
    ab.pack_start(hint, false, false, 3)

    # Per-vissi table: enabled, name, verb, when, daily_limit, cooldown_secs
    saved_vissi = ((@saved_config || {}).dig("arcarium", key.to_s, "vissi") || [])
                    .map { |v| [v["name"], v] }.to_h

    store_key = :"#{key}_vissi_store"
    # Columns: 0=enabled, 1=name, 2=verb, 3=when, 4=daily_limit, 5=cd_secs, 6=row_sensitive
    @w[store_key] = Gtk::ListStore.new(TrueClass, String, String, String, String, String, TrueClass)
    store = @w[store_key]

    Array(vissi_list).each do |v|
      passive = v[:passive] || false
      saved   = passive ? nil : saved_vissi[v[:name]]
      iter    = store.append
      store.set_value(iter, 0, passive ? true : (saved ? (saved["enabled"] || false) : false))
      store.set_value(iter, 1, v[:name].to_s)
      store.set_value(iter, 2, passive ? "(passive)" : (saved ? (saved["verb"] || v[:verb].to_s) : v[:verb].to_s))
      store.set_value(iter, 3, passive ? "" : (saved ? (saved["when"].to_s == "skip" ? "" : (saved["when"] || "aoe")) : "aoe"))
      store.set_value(iter, 4, passive ? "" : (saved ? saved["daily_limit"] : v[:daily_limit]).to_s)
      store.set_value(iter, 5, passive ? "" : (saved ? saved["cooldown_secs"] : v[:cooldown_secs]).to_s)
      store.set_value(iter, 6, !passive)
    end
    other_names = other_detected.map { |v| v[:name] }.to_set
    saved_vissi.each do |name, sv|
      next if Array(vissi_list).any? { |v| v[:name] == name }
      sv_verb = sv["verb"].to_s.strip
      sv_belongs_here = sv_verb == "(passive)" || sv_verb.include?("#{key} arcarium")
      next if other_names.include?(name) && !sv_belongs_here
      sv_passive = sv["verb"].to_s.strip == "(passive)"
      iter = store.append
      store.set_value(iter, 0, sv_passive ? true : (sv["enabled"] || false))
      store.set_value(iter, 1, sv["name"].to_s)
      store.set_value(iter, 2, sv["verb"].to_s)
      store.set_value(iter, 3, sv_passive ? "" : (sv["when"].to_s == "skip" ? "" : (sv["when"] || "")))
      store.set_value(iter, 4, sv_passive ? "" : sv["daily_limit"].to_s)
      store.set_value(iter, 5, sv_passive ? "" : sv["cooldown_secs"].to_s)
      store.set_value(iter, 6, !sv_passive)
    end

    # Final enforcement pass: any row whose verb is "(passive)" is locked non-interactive.
    # col 0 = true  (checked -- passive vissi always fire, show as "on")
    # col 6 = false (greyed -- non-interactive, same visual as rotation-greyed rows)
    store.each do |_, _, iter|
      if store.get_value(iter, 2).to_s.strip == "(passive)"
        store.set_value(iter, 0, true)
        store.set_value(iter, 6, false)
      end
    end

    tv = Gtk::TreeView.new(store)
    # Disable row selection entirely. No row ever highlights blue on click.
    # Cell interactions (toggle, When combo, text edit) all work without row selection.
    # This means Soul Harvester (col 6 = false) permanently shows as grey/insensitive
    # with nothing ever overriding that appearance.
    tv.selection.mode = Gtk::SELECTION_NONE
    tog = Gtk::CellRendererToggle.new; tog.activatable = true
    tog.signal_connect("toggled") { |_, path| it = store.get_iter(path); store.set_value(it, 0, !store.get_value(it, 0)) if it && store.get_value(it, 6) }
    tv.append_column(Gtk::TreeViewColumn.new("Use", tog, "active" => 0, "sensitive" => 6))

    # Editable text columns
    [["Name", 1], ["Verb", 2], ["Daily Limit", 4], ["CD (secs)", 5]].each do |col, i|
      r = Gtk::CellRendererText.new; r.editable = true
      r.signal_connect("edited") { |_, path, val| it = store.get_iter(path); store.set_value(it, i, val) if it && store.get_value(it, 6) }
      c = Gtk::TreeViewColumn.new(col, r, "text" => i, "sensitive" => 6); c.resizable = true
      tv.append_column(c)
    end

    # "When" column -- dropdown combo
    when_r = Gtk::CellRendererCombo.new
    when_r.editable = true
    when_r.has_entry = false
    when_model = Gtk::ListStore.new(String)
    VISSI_WHEN_OPTS.each { |o| when_model.append.set_value(0, o) }
    when_r.model = when_model
    when_r.text_column = 0
    when_r.signal_connect("changed") { |_, path, new_iter| it = store.get_iter(path); store.set_value(it, 3, when_model.get_value(new_iter, 0)) if it && store.get_value(it, 6) }
    tv.append_column(Gtk::TreeViewColumn.new("When (click to change)", when_r, "text" => 3, "sensitive" => 6))

    arc_rot_note = Gtk::Label.new
    arc_rot_note.markup = "<i><span foreground='#b06000'>Grayed-out rows are in the Weapon Attack Rotation -- they fire from there and are suppressed here to prevent double-firing.</span></i>"
    arc_rot_note.wrap = true
    arc_rot_note.xalign = 0.0
    ab.pack_start(arc_rot_note, false, false, 2)

    sw = Gtk::ScrolledWindow.new
    sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    sw.add(tv); sw.set_size_request(-1, 140)
    ab.pack_start(sw, true, true, 0)

    # Register this arcarium's store so sync_cman_grayouts can iterate it directly.
    @w[:vissi_stores] ||= {}
    @w[:vissi_stores][key.to_s] = store

    vissi_when_note = Gtk::Label.new("")
    vissi_when_note.xalign = 0.0
    vissi_when_note.set_line_wrap(true)
    vissi_when_note.set_markup(
      "<i><span foreground='#888888'>" \
      "aoe = creature count >= your AoE threshold  |  " \
      "swarm = creature count >= your swarm threshold (Hunting Prefs)  |  " \
      "maintenance = fires out of combat  |  skip = never fires  |  " \
      "boss = fires when target matches Boss List (Hunting Preferences 2)  |  " \
      "CC'd / low_health: use Emergency Priorities in Hunting Preferences instead" \
      "</span></i>"
    )
    ab.pack_start(vissi_when_note, false, false, 2)

    if Array(vissi_list).empty? && saved_vissi.empty?
      ab.pack_start(Gtk::Label.new("No vissi with activators detected. Run setup while arcarium is in inventory.").tap { |l| l.xalign = 0.0 }, false, false, 3)
    end

    container.pack_start(af, false, false, 5)
  end

  def self.pg_hunting1
    vb = mk_vbox(6)
    vb.border_width = 10
    saved_grouped_mode = (@saved_config || {}).dig("hunting", "grouped_mode") || false
    vb.pack_start(Gtk::Label.new(
      "Group membership is detected automatically -- no toggle needed for most behavior. " \
      "This toggle controls only wound retreat suppression: when ON, per-part and combo wound thresholds " \
      "are ignored while you are grouped (you stay and fight). When OFF, wound retreat fires normally " \
      "even if you are in a group. All other retreat suppression (health, mana, dread, encumbrance) " \
      "and grouped eloot behavior use auto-detected group membership regardless of this toggle."
    ).tap { |l|
      l.xalign = 0.0; l.set_line_wrap(true)
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    }, false, false, 2)
    gm_cb = w_check(:grouped_mode, "Grouped mode", saved_grouped_mode)
    vb.pack_start(gm_cb, false, false, 3)
    saved_pause_dead = ((@saved_config || {}).dig("hunting", "pause_on_dead_player") == true)
    @w[:pause_on_dead_player] = Gtk::CheckButton.new(
      "Pause script when a dead player is detected in the room " \
      "(type RESUME to continue -- leave unchecked during invasions or events)"
    )
    @w[:pause_on_dead_player].active = saved_pause_dead
    vb.pack_start(@w[:pause_on_dead_player], false, false, 3)
    vb.pack_start(mk_hsep, false, false, 4)

    # --- Combat Start Room ---
    saved_csr = (@saved_config || {}).dig("hunting", "combat_start_room").to_s.strip
    csrf, csrb = frame_vbox("Combat Start Room")
    csr_note = Gtk::Label.new(
      "The script uses ;go2 <room #> to travel to your hunting area and holds all attacks " \
      "until it arrives at this room. Once the destination is reached, combat starts and " \
      "stays active for the rest of the session. Leave blank to attack immediately on start."
    )
    csr_note.xalign = 0.0; csr_note.set_line_wrap(true)
    csr_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    csrb.pack_start(csr_note, false, false, 2)
    @w[:combat_start_room] = Gtk::Entry.new
    @w[:combat_start_room].text = saved_csr
    @w[:combat_start_room].placeholder_text = "e.g. 12345" rescue nil
    csrb.pack_start(lrow("Hold combat until room #:", @w[:combat_start_room]), false, false, 2)
    vb.pack_start(csrf, false, false, 4)
    vb.pack_start(mk_hsep, false, false, 4)

    saved_run_ecleanse = (@saved_config || {}).dig("hunting", "run_ecleanse") || false
    vb.pack_start(Gtk::Label.new(
      "Run Ecleanse alongside this script: Ecleanse handles weapon disarm recovery, " \
      "Sanctum of the Scales interactions, dispels, poison/disease cleansing, and more. " \
      "It is a community script (;repos download ecleanse) that complements this one well. " \
      "IMPORTANT: If you enable Ecleanse, disable Divine Intervention (1635) in Ecleanse -- " \
      "this script has its own more detailed 1635 Beseech logic and both firing at once will conflict."
    ).tap { |l|
      l.xalign = 0.0; l.set_line_wrap(true)
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    }, false, false, 2)
    ec_cb = w_check(:run_ecleanse, "Run Ecleanse alongside this script", saved_run_ecleanse)
    vb.pack_start(ec_cb, false, false, 3)
    vb.pack_start(mk_hsep, false, false, 4)

    saved_maint_only = (@saved_config || {}).dig("hunting", "maintenance_only") || false
    mo_cb = w_check(:maintenance_only, "Maintenance-only mode", saved_maint_only)
    vb.pack_start(mo_cb, false, false, 3)
    vb.pack_start(Gtk::Label.new(
      "When checked: the script keeps your buffs and society abilities running but does NOT attack anything. " \
      "Use this if you are hunting manually or grouped and only want the script to handle " \
      "spell/song upkeep, society symbols, and mount maintenance. " \
      "All targeting and attack rotation is disabled -- the script will not swing, cast offensively, or pick targets."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 2)
    vb.pack_start(mk_hsep, false, false, 4)

    # --- Health + Escape Methods ---
    saved_retreat_pct   = (@saved_config || {}).dig("hunting", "health_retreat_pct") || 35
    saved_low_health_pct = (@saved_config || {}).dig("hunting", "low_health_pct") || 65
    saved_mana_ret_pct  = (@saved_config || {}).dig("hunting", "mana_retreat_pct")   || 0
    saved_mana_ret_on   = saved_mana_ret_pct > 0
    saved_retreat_room  = (@saved_config || {}).dig("hunting", "retreat_room")&.to_s || ""
    saved_use_safe_room = !saved_retreat_room.empty?

    soc_name        = (@profile.dig("society", "name") rescue nil)
    soc_rank        = (@profile.dig("society", "rank") rescue 0).to_i
    soc_escape_def  = SOCIETY_DATA.dig(soc_name, :escape)&.first rescue nil
    soc_esc_unlocked = soc_escape_def && soc_rank >= (soc_escape_def[:rank] || 1)
    saved_esc_cfg   = ((@profile.dig("society", "escape") || @profile.dig("society", "symbol_return")) rescue {}) || {}
    esc_enabled     = saved_esc_cfg.fetch("enabled", false)

    hf, hb2 = frame_vbox("Low Health")
    add_row(hb2, "Use abilities/arcarium/trinkets when HP drops below %:", w_spin(:low_health_pct, saved_low_health_pct, 10, 95))
    lh_note = Gtk::Label.new(
      "Fires any ability, arcarium vissi, or trinket tagged 'low_health'. " \
      "Must be set higher than the Escape threshold below so these fire first. Default 65%."
    )
    lh_note.xalign = 0.0; lh_note.set_line_wrap(true)
    lh_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    hb2.pack_start(lh_note, false, false, 2)
    hb2.pack_start(mk_hsep, false, false, 4)
    health_note = Gtk::Label.new(
      "When HP falls below this value, the script fires your Escape options in priority order " \
      "(configured below). Enable at least one or the script stops in place. Default 50%. " \
      "Suppressed while grouped -- use the Grouped mode toggle at the top of this tab to control that."
    )
    health_note.xalign = 0.0; health_note.set_line_wrap(true)
    health_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    hb2.pack_start(health_note, false, false, 2)
    add_row(hb2, "Escape when HP drops below %:", w_spin(:health_retreat_pct, saved_retreat_pct, 5, 90))
    hb2.pack_start(mk_hsep, false, false, 4)

    vb.pack_start(hf, false, false, 4)

    # Wound Retreat -- per-body-part grid
    saved_wr = (@saved_config || {}).dig("hunting", "wound_retreat") || {}
    wrf, wrb = frame_vbox("Wound Retreat")
    wrb.pack_start(Gtk::Label.new(
      "Set the wound rank that triggers retreat for each body part. " \
      "0 = disabled (never retreat for that part). 1=Light, 2=Moderate, 3=Severe. " \
      "Retreat fires immediately regardless of current HP. " \
      "Suppressed while grouped -- use the Grouped mode toggle at the top of this tab to control that."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 2)

    grid = Gtk::Grid.new
    grid.column_spacing    = 12
    grid.row_spacing       = 6
    grid.column_homogeneous = true
    @w[:wound_part_spinners] = {}
    WOUND_BODY_PARTS.each_with_index do |(key, _meth, label, default_thresh), idx|
      col = (idx % 5) * 2
      row = idx / 5
      saved_thresh = saved_wr.fetch(key, default_thresh).to_i
      lbl = Gtk::Label.new("#{label}:")
      lbl.xalign = 1.0
      spn = Gtk::SpinButton.new(
        Gtk::Adjustment.new(saved_thresh.to_f, 0.0, 3.0, 1.0, 1.0, 0.0), 1, 0)
      @w[:wound_part_spinners][key] = spn
      grid.attach(lbl, col,     row, 1, 1)
      grid.attach(spn, col + 1, row, 1, 1)
    end
    wrb.pack_start(grid, false, false, 4)

    wrb.pack_start(mk_hsep, false, false, 4)
    combo_note = Gtk::Label.new(
      "Wound Score Retreat: each wound tier on a body part adds points to a running total " \
      "(Tier 1 = 1 pt, Tier 2 = 2 pts, Tier 3 = 3 pts). When the total reaches your threshold " \
      "the script retreats, regardless of which body parts are hurt or what tier they are. " \
      "Example: 3 Tier 1 wounds + 2 Tier 2 wounds = 7 pts. Suppressed while grouped."
    )
    combo_note.xalign = 0.0; combo_note.set_line_wrap(true)
    combo_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    wrb.pack_start(combo_note, false, false, 2)

    # Combo threshold: weighted wound score (T1=1pt, T2=2pts, T3=3pts), solo only
    saved_combo_enabled = saved_wr.fetch("combo_enabled", false)
    saved_combo_score   = saved_wr.fetch("combo_score",   7).to_i

    combo_hb = Gtk::Box.new(:horizontal, 6)
    combo_cb = w_check(:wound_combo_enabled, "Also retreat when wound score reaches", saved_combo_enabled)
    @w[:wound_combo_score] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_combo_score.to_f, 1.0, 42.0, 1.0, 5.0, 0.0), 1, 0)
    combo_hb.pack_start(combo_cb,                false, false, 0)
    combo_hb.pack_start(@w[:wound_combo_score],  false, false, 0)
    combo_hb.pack_start(Gtk::Label.new("  (Tier 1 = 1 pt, Tier 2 = 2 pts, Tier 3 = 3 pts -- solo only)"), false, false, 4)
    wrb.pack_start(combo_hb, false, false, 4)

    combo_note = Gtk::Label.new(
      "Note: per-part thresholds above and the score system are independent -- both can trigger an escape.\n" \
      "If you only want the score to decide, set all per-part thresholds to 0 (or leave them unchecked)."
    )
    combo_note.set_xalign(0.0)
    combo_note.wrap = true
    wrb.pack_start(combo_note, false, false, 4)

    vb.pack_start(wrf, false, false, 4)

    # Escape Priority Order
    sg_known_spells = Array((@detected || {})[:known_spells])
    sg_known = sg_known_spells.any? { |s| s[:num] == 130 } || (Spell[130].known? rescue false)

    esc_hint = Gtk::Label.new(
      "Escape options -- tried top-to-bottom whenever the script needs to escape (low health, " \
      "severe wounds, or high encumbrance). The first option that succeeds stops the sequence."
    )
    esc_hint.xalign = 0.0; esc_hint.set_line_wrap(true)
    esc_hint.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    hb2.pack_start(esc_hint, false, false, 3)

    # Load saved priority; migrate from old individual keys if not yet converted
    saved_prio = (@saved_config || {}).dig("hunting", "escape_priority")
    if saved_prio.nil?
      old_sg   = (@saved_config || {}).dig("hunting", "spirit_guide_escape") || {}
      old_esc  = ((@profile.dig("society", "escape") rescue {}) || {})
      old_room = (@saved_config || {}).dig("hunting", "retreat_room").to_s
      saved_prio = []
      saved_prio << {"type" => "spirit_guide", "enabled" => old_sg.fetch("enabled", false)} if sg_known
      saved_prio << {"type" => "society",      "enabled" => old_esc.fetch("enabled", esc_enabled)}
      saved_prio << {"type" => "saferoom",     "enabled" => !old_room.empty?, "room" => old_room}
    end

    avail_types = []
    avail_types << "spirit_guide" if sg_known
    avail_types << "society"      if soc_name && soc_esc_unlocked
    avail_types << "saferoom"

    ordered_types = saved_prio.map { |e| e["type"] }.select { |t| avail_types.include?(t) }
    avail_types.each { |t| ordered_types << t unless ordered_types.include?(t) }

    @esc_prio_order   = ordered_types.dup
    @esc_prio_widgets = {}
    @w[:esc_room_entry]    = nil
    @w[:esc_ignore_floors] = nil

    esc_rows_vbox = Gtk::Box.new(:vertical, 4)

    esc_rebuild = lambda do
      esc_rows_vbox.children.each { |c| esc_rows_vbox.remove(c) }
      @esc_prio_order.each_with_index do |type, idx|
        d = @esc_prio_widgets[type]
        d[:rank_lbl].text    = "#{idx + 1}."
        d[:up_btn].sensitive = idx > 0
        d[:dn_btn].sensitive = idx < @esc_prio_order.length - 1
        esc_rows_vbox.pack_start(d[:row_vbox], false, false, 0)
      end
      esc_rows_vbox.show_all
    end

    ordered_types.each do |type|
      saved   = saved_prio.find { |e| e["type"] == type } || {}
      enabled = saved.fetch("enabled", false)

      row_vbox = Gtk::Box.new(:vertical, 1)
      row_hb   = Gtk::Box.new(:horizontal, 6)
      rank_lbl = Gtk::Label.new("1."); rank_lbl.width_chars = 3

      lbl_text = case type
                 when "spirit_guide" then "Spirit Guide (spell 130)"
                 when "society"      then soc_escape_def ? soc_escape_def[:name] : "Society Escape"
                 when "saferoom"     then "Safe Room (Lich room #):"
                 end
      cb = Gtk::CheckButton.new(lbl_text)
      cb.active = enabled

      up_btn = Gtk::Button.new; up_btn.relief = :none
      up_btn.image = Gtk::Image.new(icon_name: "go-up", icon_size: :button)
      dn_btn = Gtk::Button.new; dn_btn.relief = :none
      dn_btn.image = Gtk::Image.new(icon_name: "go-down", icon_size: :button)

      row_hb.pack_start(rank_lbl, false, false, 0)
      row_hb.pack_start(up_btn,   false, false, 2)
      row_hb.pack_start(dn_btn,   false, false, 2)
      row_hb.pack_start(cb,       false, false, 6)

      if type == "saferoom"
        room_entry = Gtk::Entry.new
        room_entry.text        = saved.fetch("room", "").to_s
        room_entry.width_chars = 8
        room_entry.sensitive   = enabled
        @w[:esc_room_entry] = room_entry
        cb.signal_connect("toggled") { room_entry.sensitive = cb.active? }
        row_hb.pack_start(room_entry, false, false, 4)
      end
      row_vbox.pack_start(row_hb, false, false, 0)

      if type == "society" && soc_name == "Sunfist"
        saved_floors = saved.fetch("ignore_floors", false)
        floors_cb = Gtk::CheckButton.new("Override: ignore mana/stamina reserve floors in an emergency")
        floors_cb.active    = saved_floors
        floors_cb.sensitive = enabled
        cb.signal_connect("toggled") { floors_cb.sensitive = cb.active? }
        @w[:esc_ignore_floors] = floors_cb
        floors_hb = Gtk::Box.new(:horizontal, 0)
        floors_hb.pack_start(Gtk::Label.new("     "), false, false, 0)
        floors_hb.pack_start(floors_cb, false, false, 0)
        row_vbox.pack_start(floors_hb, false, false, 0)
      end

      up_btn.signal_connect("clicked") do
        i = @esc_prio_order.index(type)
        next if i.nil? || i == 0
        @esc_prio_order[i], @esc_prio_order[i - 1] = @esc_prio_order[i - 1], @esc_prio_order[i]
        esc_rebuild.call
      end
      dn_btn.signal_connect("clicked") do
        i = @esc_prio_order.index(type)
        next if i.nil? || i >= @esc_prio_order.length - 1
        @esc_prio_order[i], @esc_prio_order[i + 1] = @esc_prio_order[i + 1], @esc_prio_order[i]
        esc_rebuild.call
      end

      @esc_prio_widgets[type] = {row_vbox: row_vbox, rank_lbl: rank_lbl, cb: cb,
                                  up_btn: up_btn, dn_btn: dn_btn}
    end

    esc_rebuild.call
    hb2.pack_start(esc_rows_vbox, false, false, 2)

    safe_note = Gtk::Label.new(
      "Find your Lich room number with: ;room -- script stops after arriving.\n" \
      "If no escape options are enabled, the script stops hunting in place."
    )
    safe_note.xalign = 0.0; safe_note.set_line_wrap(true)
    safe_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    hb2.pack_start(safe_note, false, false, 2)

    # --- Encumbrance ---
    saved_enc_thresh  = (@saved_config || {}).dig("hunting", "encumbrance_retreat_pct") || 0
    saved_enc_ignore  = (@saved_config || {}).dig("hunting", "encumbrance_ignore") || false
    enc_idx = ENCUMBRANCE_LEVELS.index { |_, v| v == saved_enc_thresh } || 0
    encf, encb = frame_vbox("Encumbrance")
    enc_note = Gtk::Label.new(
      "Escape threshold -- when encumbrance reaches this level, the script fires your Escape options " \
      "(listed above) in priority order. Encumbrance reduces Dodge DS, so escaping before it becomes " \
      "severe keeps you safer. " \
      "Encumbrance retreat is always suppressed while grouped so you do not abandon your group."
    )
    enc_note.xalign = 0.0; enc_note.set_line_wrap(true)
    enc_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    encb.pack_start(enc_note, false, false, 2)
    @w[:encumbrance_ignore] = Gtk::CheckButton.new("Ignore encumbrance entirely (never retreat or check, regardless of level)")
    @w[:encumbrance_ignore].active = saved_enc_ignore
    encb.pack_start(@w[:encumbrance_ignore], false, false, 2)
    enc_thresh_row = add_row(encb, "Escape when encumbered at or above:", w_combo(:encumbrance_retreat, ENCUMBRANCE_LEVELS.map(&:first), enc_idx))
    enc_thresh_row.sensitive = !saved_enc_ignore
    @w[:encumbrance_ignore].signal_connect("toggled") { enc_thresh_row.sensitive = !@w[:encumbrance_ignore].active? }
    vb.pack_start(encf, false, false, 4)

    # --- Mana ---
    mf2, mb2 = frame_vbox("Mana")
    mana_ret_cb = Gtk::CheckButton.new("Escape / retreat when mana drops below:")
    mb2.pack_start(Gtk::Label.new(
      "Retreat when mana drops below this percentage. " \
      "Suppressed while grouped -- use the Grouped mode toggle at the top of this tab to control that."
    ).tap { |l|
      l.xalign = 0.0; l.set_line_wrap(true)
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    }, false, false, 2)
    mana_ret_cb.active = saved_mana_ret_on
    @w[:mana_retreat_enabled] = mana_ret_cb
    adj_mr = Gtk::Adjustment.new([saved_mana_ret_pct, 5].max, 5, 90, 1, 5, 0)
    @w[:mana_retreat_pct] = Gtk::SpinButton.new(adj_mr, 1, 0)
    @w[:mana_retreat_pct].sensitive = saved_mana_ret_on
    mana_ret_cb.signal_connect("toggled") { @w[:mana_retreat_pct].sensitive = mana_ret_cb.active? }
    mana_hb = Gtk::Box.new(:horizontal, 4)
    mana_hb.pack_start(mana_ret_cb,           false, false, 0)
    mana_hb.pack_start(@w[:mana_retreat_pct],  false, false, 0)
    mana_hb.pack_start(Gtk::Label.new("%"),    false, false, 2)
    mb2.pack_start(mana_hb, false, false, 2)
    vb.pack_start(mf2, false, false, 4)

    # --- Dread Management (Moonsedge-specific) ---
    saved_dread = (@saved_config || {}).dig("hunting", "dread") || {}
    df, db = frame_vbox("Dread Management (Moonsedge Castle)")
    db.pack_start(Gtk::Label.new(
      "Moonsedge Castle inflicts Creeping Dread and Crushing Dread as stacking debuffs. " \
      "Retreat triggers when EITHER type reaches its threshold -- both do not need to be high at the same time. " \
      "When a threshold is hit, the script retreats to the library (room 32469) where dread decays naturally. " \
      "Restart the script when ready to resume hunting. " \
      "Suppressed while grouped -- use the Grouped mode toggle at the top of this tab to control that."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 2)

    @w[:dread_enabled] = Gtk::CheckButton.new("Enable dread management (Moonsedge Castle)")
    @w[:dread_enabled].active = saved_dread.fetch("enabled", false)
    db.pack_start(@w[:dread_enabled], false, false, 2)

    saved_creep_thresh = saved_dread.fetch("creeping_threshold", 20)
    saved_crush_thresh = saved_dread.fetch("crushing_threshold", 15)

    creep_row = Gtk::Box.new(:horizontal, 4)
    creep_row.pack_start(Gtk::Label.new("Retreat when Creeping Dread reaches:"), false, false, 0)
    @w[:creeping_dread_threshold] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_creep_thresh.to_f, 1.0, 99.0, 1.0, 5.0, 0.0), 1, 0)
    @w[:creeping_dread_threshold].sensitive = @w[:dread_enabled].active?
    creep_row.pack_start(@w[:creeping_dread_threshold], false, false, 4)
    creep_row.pack_start(Gtk::Label.new("stacks"), false, false, 0)
    db.pack_start(creep_row, false, false, 2)

    crush_row = Gtk::Box.new(:horizontal, 4)
    crush_row.pack_start(Gtk::Label.new("Retreat when Crushing Dread reaches:"), false, false, 0)
    @w[:crushing_dread_threshold] = Gtk::SpinButton.new(
      Gtk::Adjustment.new(saved_crush_thresh.to_f, 1.0, 99.0, 1.0, 5.0, 0.0), 1, 0)
    @w[:crushing_dread_threshold].sensitive = @w[:dread_enabled].active?
    crush_row.pack_start(@w[:crushing_dread_threshold], false, false, 4)
    crush_row.pack_start(Gtk::Label.new("stacks"), false, false, 0)
    db.pack_start(crush_row, false, false, 2)

    @w[:dread_enabled].signal_connect("toggled") do
      on = @w[:dread_enabled].active?
      @w[:creeping_dread_threshold].sensitive = on
      @w[:crushing_dread_threshold].sensitive = on
    end

    vb.pack_start(df, false, false, 4)

    # --- Emergency Priorities ---
    vb.pack_start(mk_hsep, false, false, 4)
    ep_saved = (@saved_config || {})["emergency_priorities"] || {}

    ep_intro = Gtk::Label.new(
      "Emergency Priorities: when a debuff or low-health condition fires, the script tries each entry " \
      "in order and stops after the first one that succeeds. Built-in responses (1635 Beseech, " \
      "Incarnate Armor) fire automatically before this list.\n" \
      "Add arcarium vissi, trinket abilities, or built-in heals (1607 Rejuvenation, society healing " \
      "symbols) here to control their order. Items that were previously set to CC'd or low_health " \
      "in the Arcarium / Trinkets tabs are migrated here automatically."
    )
    ep_intro.xalign = 0.0
    ep_intro.set_line_wrap(true)
    ep_intro.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    vb.pack_start(ep_intro, false, false, 3)

    build_ep_frame = lambda do |frame_label, store_sym, saved_list|
      pf, pb = frame_vbox(frame_label)

      ep_entry_label = lambda do |entry|
        type = entry[:type]
        case type
        when "vissi"   then "Arcarium #{entry[:col2]} -- #{entry[:col3]}"
        when "ability" then "#{entry[:col2]} / #{entry[:col3]}"
        when "builtin"
          case entry[:col3]
          when "rejuvenation"          then "Spell 1607 -- Rejuvenation (Paladin)"
          when "society_heal"          then "Society heal (Symbol of Restoration / Sign of Healing)"
          when "bloodstone_vivacity"   then "Bloodstone Jewelry -- Vivacity (BESEECH for HP/stamina/mana)"
          when "bloodstone_sanguine_swap" then "Bloodstone Jewelry -- Sanguine Swap (SPIN, stores wounds)"
          else entry[:col3]
          end
        else entry[:col3]
        end
      end

      ep_entries = []
      Array(saved_list).each do |entry|
        next unless entry.is_a?(Hash)
        type = entry["type"].to_s
        case type
        when "vissi"
          ep_entries << {type: "vissi",   col2: entry["arcarium"].to_s, col3: entry["name"].to_s}
        when "ability"
          ep_entries << {type: "ability", col2: entry["slot"].to_s,     col3: entry["key"].to_s}
        when "builtin"
          ep_entries << {type: "builtin", col2: "builtin",              col3: entry["id"].to_s}
        end
      end

      ep_rows_vbox = Gtk::Box.new(:vertical, 2)

      ep_sync_store = lambda do
        ls = Gtk::ListStore.new(String, String, String, String)
        ep_entries.each do |e|
          it = ls.append
          it.set_value(0, e[:type])
          it.set_value(1, ep_entry_label.call(e))
          it.set_value(2, e[:col2])
          it.set_value(3, e[:col3])
        end
        @w[store_sym] = ls
      end

      ep_rebuild = lambda do
        ep_rows_vbox.children.each { |c| ep_rows_vbox.remove(c) }
        ep_entries.each_with_index do |entry, idx|
          row_hb = Gtk::Box.new(:horizontal, 4)

          up_btn = Gtk::Button.new; up_btn.relief = :none
          up_btn.image = Gtk::Image.new(icon_name: "go-up", icon_size: :button)
          up_btn.sensitive = idx > 0
          up_btn.signal_connect("clicked") do
            ep_entries[idx], ep_entries[idx - 1] = ep_entries[idx - 1], ep_entries[idx]
            ep_rebuild.call
          end

          dn_btn = Gtk::Button.new; dn_btn.relief = :none
          dn_btn.image = Gtk::Image.new(icon_name: "go-down", icon_size: :button)
          dn_btn.sensitive = idx < ep_entries.length - 1
          dn_btn.signal_connect("clicked") do
            ep_entries[idx], ep_entries[idx + 1] = ep_entries[idx + 1], ep_entries[idx]
            ep_rebuild.call
          end

          rm_btn = Gtk::Button.new(label: "X"); rm_btn.relief = :none
          rm_btn.signal_connect("clicked") do
            ep_entries.delete_at(idx)
            ep_rebuild.call
            @sync_cman_grayouts&.call
          end

          lbl = Gtk::Label.new(ep_entry_label.call(entry))
          lbl.xalign = 0.0

          row_hb.pack_start(up_btn, false, false, 0)
          row_hb.pack_start(dn_btn, false, false, 0)
          row_hb.pack_start(lbl,    true,  true,  6)
          row_hb.pack_end(rm_btn,   false, false, 0)
          ep_rows_vbox.pack_start(row_hb, false, false, 1)
        end
        ep_rows_vbox.show_all
        ep_sync_store.call
      end

      ep_rebuild.call
      pb.pack_start(ep_rows_vbox, false, false, 2)

      ord_note = Gtk::Label.new("Priority order: top fires first. Use the arrows on each row to reorder.")
      ord_note.xalign = 0.0; ord_note.set_line_wrap(true)
      ord_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
      pb.pack_start(ord_note, false, false, 2)

      add_btn = Gtk::Button.new(label: "Add...")
      add_btn.signal_connect("clicked") do
        items = []
        d_ep = @detected || {}
        ep_prof    = GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue d_ep[:profession]
        ep_soc     = d_ep[:society].to_s
        ep_soc_rank = d_ep[:society_rank].to_i
        ep_known   = Array(d_ep[:known_spells])
        if ep_prof == "Paladin" && ep_known.any? { |s| s[:num] == 1607 }
          items << {type: "builtin", label: "Spell 1607 -- Rejuvenation (Paladin)", col2: "builtin", col3: "rejuvenation"}
        end
        soc_heal_unlocked = case ep_soc
          when "Voln"    then ep_soc_rank >= 10
          when "CoL"     then ep_soc_rank >= 9
          when "Sunfist" then false
          else false
        end
        if soc_heal_unlocked
          soc_heal_label = case ep_soc
            when "Voln" then "Voln -- Symbol of Restoration (auto-heal when HP low)"
            when "CoL"  then "CoL -- Sign of Healing (auto-heal when HP low)"
            else "#{ep_soc} -- society heal"
          end
          items << {type: "builtin", label: soc_heal_label, col2: "builtin", col3: "society_heal"}
        end
        bsj_ep = (@saved_config || {}).dig("trinkets", "bloodstone_jewelry") || {}
        if bsj_ep["enabled"]
          bsj_tier_ep = bsj_ep["tier"].to_i
          if bsj_tier_ep >= 3 && bsj_ep.dig("abilities", "vivacity", "enabled") != false
            viv_tgt = bsj_ep.dig("abilities", "vivacity", "target") || "HEALTH"
            items << {type: "builtin", label: "Bloodstone Jewelry -- Vivacity (BESEECH #{viv_tgt})", col2: "builtin", col3: "bloodstone_vivacity"}
          end
          if bsj_tier_ep >= 4 && bsj_ep.dig("abilities", "sanguine_swap", "enabled") != false
            items << {type: "builtin", label: "Bloodstone Jewelry -- Sanguine Swap (SPIN, [!] wounds reappear)", col2: "builtin", col3: "bloodstone_sanguine_swap"}
          end
        end
        %w[aversaris vangaris].each do |arc_key|
          arc_cfg = (@saved_config || {}).dig("arcarium", arc_key) || {}
          next unless arc_cfg["enabled"]
          Array(arc_cfg["vissi"]).each do |v|
            next unless v.is_a?(Hash) && v["name"]
            items << {type: "vissi", label: "Arcarium #{arc_key} -- #{v['name']}", col2: arc_key, col3: v["name"]}
          end
        end
        TRINKET_KEYS.each do |tk|
          tc = (@saved_config || {}).dig("trinkets", tk) || {}
          next unless tc["enabled"]
          (tc["abilities"] || {}).each_key do |ab_key|
            items << {type: "ability", label: "#{tk} / #{ab_key}", col2: tk, col3: ab_key.to_s}
          end
        end

        if items.empty?
          dlg = Gtk::MessageDialog.new(@win, :modal, :info, :ok, "No arcarium or trinket items found. Save your profile first, then reopen setup.")
          dlg.run; dlg.destroy
          next
        end

        dlg = Gtk::Dialog.new(title: "Add Priority Entry", parent: @win, flags: :modal)
        dlg.add_button("Add",    :ok)
        dlg.add_button("Cancel", :cancel)
        combo = mk_combo_text(items.map { |i| i[:label] }, 0)
        dlg.content_area.pack_start(combo, false, false, 8)
        dlg.content_area.show_all

        if dlg.run == :ok && !items.empty?
          chosen = items[combo.active] || items[0]
          ep_entries << {type: chosen[:type], col2: chosen[:col2], col3: chosen[:col3]}
          ep_rebuild.call
          @sync_cman_grayouts&.call
        end
        dlg.destroy
      end

      btn_row = mk_hbox(4)
      btn_row.pack_start(add_btn, false, false, 2)
      pb.pack_start(btn_row, false, false, 4)
      vb.pack_start(pf, false, false, 6)
    end

    build_ep_frame.call(
      "Low Health Priority (fires in order when HP < low_health %; stops after first success)",
      :ep_low_health_store,
      ep_saved["low_health"]
    )
    build_ep_frame.call(
      "CC'd Priority (fires in order when stunned/webbed/bound/silenced/crippled; stops after first success)",
      :ep_cc_store,
      ep_saved["cc"]
    )

    cc_beseech_note = Gtk::Label.new(
      "Note: spell 1635 Beseech (Paladin) is its own separate system configured in the Spells tab -- " \
      "it fires automatically when the script detects a recoverable state and is not listed here. " \
      "The 'battle_standard / beseech' entry above is the Battle Standard trinket BESEECH ability."
    )
    cc_beseech_note.xalign = 0.0; cc_beseech_note.set_line_wrap(true)
    cc_beseech_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    vb.pack_start(cc_beseech_note, false, false, 3)

    scrolled(vb)
  end

  # ---------------------------------------------------------------------------
  # Hunting Preferences 2 tab -- eloot, encumbrance, floors, thresholds, targets
  # ---------------------------------------------------------------------------
  def self.pg_hunting2
    vb = mk_vbox(6)
    vb.border_width = 10

    stance_prefs   = ["offensive", "guarded", "defensive", "none"]
    saved_stance   = (@saved_config || {}).dig("hunting", "stance_preference") || "offensive"
    saved_stance_i = stance_prefs.index(saved_stance) || 0
    add_row(vb, "Resting stance:", w_combo(:stance_preference, [
      "Offensive -- stay offensive; no stance dancing",
      "Guarded -- go offensive to attack, return to guarded after each swing",
      "Defensive -- go offensive to attack, return to defensive after each swing",
      "Don't manage -- script never changes stance",
    ], saved_stance_i))
    stance_note = Gtk::Label.new(
      "Melee and bolt attacks fire from Offensive for full AS, then restore to your resting stance. " \
      "Warding spells always use Guarded regardless of this setting. " \
      "Note: during soft RT (cast roundtime) the game caps stance at Guarded -- pure casters " \
      "effectively stay guarded between spells and should set Guarded as their resting stance."
    )
    stance_note.xalign = 0.0; stance_note.set_line_wrap(true)
    stance_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    vb.pack_start(stance_note, false, false, 1)
    vb.pack_start(mk_hsep, false, false, 4)

    vb.pack_start(w_check(:use_eloot, "Use ;eloot for automatic looting (recommended)", (@saved_config || {}).dig("hunting", "use_eloot") != false), false, false, 3)

    saved_eloot_grouped = (@saved_config || {}).dig("hunting", "eloot_grouped") || "skip"
    eg_run_val  = saved_eloot_grouped == "run"
    eg_skip_val = saved_eloot_grouped != "run"

    eloot_gf, eloot_gb = frame_vbox("Eloot when Grouped")
    eg_note = Gtk::Label.new("When the script detects you are in a group or are the group leader, eloot behavior is controlled here instead of the solo setting above.")
    eg_note.xalign = 0.0; eg_note.set_line_wrap(true)
    eg_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    eloot_gb.pack_start(eg_note, false, false, 2)

    @w[:eloot_grouped_run]  = Gtk::CheckButton.new("Run eloot when grouped (I am the lotter / group lead)")
    @w[:eloot_grouped_skip] = Gtk::CheckButton.new("Skip eloot when grouped (default -- you loot manually or somebody else loots)")
    @w[:eloot_grouped_run].active  = eg_run_val
    @w[:eloot_grouped_skip].active = eg_skip_val
    @w[:eloot_grouped_skip].sensitive = !eg_run_val
    @w[:eloot_grouped_run].sensitive  = !eg_skip_val

    @w[:eloot_grouped_run].signal_connect("toggled") do |btn|
      if btn.active?
        @w[:eloot_grouped_skip].active    = false
        @w[:eloot_grouped_skip].sensitive = false
        @w[:eloot_grouped_run].sensitive  = true
      else
        @w[:eloot_grouped_skip].sensitive = true
      end
    end
    @w[:eloot_grouped_skip].signal_connect("toggled") do |btn|
      if btn.active?
        @w[:eloot_grouped_run].active    = false
        @w[:eloot_grouped_run].sensitive = false
        @w[:eloot_grouped_skip].sensitive = true
      else
        @w[:eloot_grouped_run].sensitive = true
      end
    end

    eloot_gb.pack_start(@w[:eloot_grouped_run],  false, false, 2)
    eloot_gb.pack_start(@w[:eloot_grouped_skip], false, false, 2)
    vb.pack_start(eloot_gf, false, false, 4)

    saved_sta_floor = (@profile.dig("hunting", "stamina_floor_enabled") rescue false) || false
    saved_man_floor = (@profile.dig("hunting", "mana_floor_enabled")    rescue false) || false
    @w[:stamina_floor_enabled] = Gtk::CheckButton.new(
      "Enforce a stamina floor -- script won't use abilities that would drop stamina below this value")
    @w[:mana_floor_enabled] = Gtk::CheckButton.new(
      "Enforce a mana floor -- script won't cast if it would drop mana below this value")
    @w[:stamina_floor_enabled].active = saved_sta_floor
    @w[:mana_floor_enabled].active    = saved_man_floor
    sta_spin_row = lrow("Keep stamina above:", w_spin(:stamina_reserve, 50, 0, 999))
    man_spin_row = lrow("Keep mana above:",    w_spin(:mana_reserve,   100, 0, 9999))
    sta_spin_row.sensitive = saved_sta_floor
    man_spin_row.sensitive = saved_man_floor
    @w[:stamina_floor_enabled].signal_connect("toggled") { sta_spin_row.sensitive = @w[:stamina_floor_enabled].active? }
    @w[:mana_floor_enabled].signal_connect("toggled")    { man_spin_row.sensitive = @w[:mana_floor_enabled].active? }
    vb.pack_start(@w[:stamina_floor_enabled], false, false, 2)
    vb.pack_start(sta_spin_row,               false, false, 2)
    vb.pack_start(@w[:mana_floor_enabled],    false, false, 2)
    vb.pack_start(man_spin_row,               false, false, 2)
    saved_aoe_thresh = (@saved_config || {}).dig("hunting", "aoe_threshold") || 3
    saved_swarm = (@saved_config || {}).dig("hunting", "swarm_threshold") || SWARM_THRESHOLD_DEFAULT
    aoe_tf, aoe_tb = frame_vbox("Creature Count Thresholds")
    aoe_thresh_lbl = Gtk::Label.new(
      "\"aoe\" and \"swarm\" fire when creature count meets the thresholds below."
    )
    aoe_thresh_lbl.xalign = 0.0; aoe_thresh_lbl.set_line_wrap(true)
    aoe_thresh_lbl.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))
    aoe_tb.pack_start(aoe_thresh_lbl, false, false, 3)
    aoe_tb.pack_start(lrow("Fire AoE rotation + \"aoe\" abilities when creatures >=", w_spin(:aoe_threshold, saved_aoe_thresh, 2, 20)), false, false, 2)
    aoe_tb.pack_start(lrow("Fire \"swarm\" abilities when creatures >=", w_spin(:swarm_threshold, saved_swarm, 2, 30)), false, false, 2)
    vb.pack_start(aoe_tf, false, false, 5)
    saved_npc_pri_idx = ["caster_first", "lowest_hp", "first_available", "priority_list"]
      .index((@saved_config || {}).dig("hunting", "npc_priority")) || 0
    add_row(vb, "Target priority:", w_combo(:npc_priority, [
      "Casters first (conjurers, mages, shaman...)",
      "Lowest HP first",
      "First available",
      "Priority list (use my list below; first available as fallback)",
    ], saved_npc_pri_idx))

    pf, pb = frame_vbox("Priority Targets (always attacked first, even mid-fight)")
    pb.pack_start(Gtk::Label.new(
      "Enter creature nouns or name fragments, one per line.\n" \
      "Examples: warlock, shaman, mage, troll king\n" \
      "If a listed creature appears in the room, the script will finish its current swing then switch to it."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)
    pb.pack_start(Gtk::Label.new("  v Click in the box below and type -- one entry per line v").tap { |l|
      l.xalign = 0.5
      l.override_color(:normal, Gdk::RGBA.new(0.3, 0.55, 0.85, 1.0))
    }, false, false, 1)
    saved_pri = ((@saved_config || {}).dig("hunting", "priority_creatures") || []).join("\n")
    @w[:priority_creatures] = Gtk::TextView.new
    @w[:priority_creatures].buffer.text = saved_pri
    @w[:priority_creatures].set_size_request(-1, 90)
    sw = Gtk::ScrolledWindow.new
    sw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    sw.shadow_type = Gtk::SHADOW_IN
    sw.add(@w[:priority_creatures])
    pb.pack_start(sw, true, true, 2)
    vb.pack_start(pf, false, false, 6)

    bf, bb = frame_vbox("Boss List")
    bb.pack_start(Gtk::Label.new(
      "Creatures matching any boss entry are targeted first (above Priority Targets) and trigger\n" \
      "trinket, script, and arcarium abilities with When set to \"boss\"."
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true);
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0)) }, false, false, 3)

    reim_hb = Gtk::HBox.new(false, 12)
    @w[:empress_first] = Gtk::CheckButton.new("Kill Empress first (Reim -- prevents enrage)")
    @w[:empress_first].active = (@saved_config || {}).dig("hunting", "empress_first") || false
    @w[:emperor_first] = Gtk::CheckButton.new("Kill Emperor first (Reim -- prevents enrage)")
    @w[:emperor_first].active = (@saved_config || {}).dig("hunting", "emperor_first") || false
    @w[:empress_first].signal_connect("toggled") {
      @w[:emperor_first].active = false
      @w[:emperor_first].sensitive = !@w[:empress_first].active?
    }
    @w[:emperor_first].signal_connect("toggled") {
      @w[:empress_first].active = false
      @w[:empress_first].sensitive = !@w[:emperor_first].active?
    }
    @w[:emperor_first].sensitive = !@w[:empress_first].active?
    @w[:empress_first].sensitive = !@w[:emperor_first].active?
    reim_hb.pack_start(@w[:empress_first], false, false, 0)
    reim_hb.pack_start(@w[:emperor_first], false, false, 0)
    bb.pack_start(reim_hb, false, false, 4)

    @w[:miniboss_mode] = Gtk::CheckButton.new("Reim rares + Mini Bosses count as bosses (all Reim Castle/Fortress rares + wiki-listed named rare spawns)")
    @w[:miniboss_mode].active = (@saved_config || {}).dig("hunting", "miniboss_mode") || false
    bb.pack_start(@w[:miniboss_mode], false, false, 2)

    bb.pack_start(Gtk::Label.new(
      "Use this box for world bosses or anything else not covered above -- partial match, use enough to be unique.\n" \
      "Known world bosses:  empyrean captain  |  cold wyrm  |  chthonian sybil"
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true);
      l.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0)) }, false, false, 3)
    bb.pack_start(Gtk::Label.new("  v Click in the box below and type -- one entry per line v").tap { |l|
      l.xalign = 0.5
      l.override_color(:normal, Gdk::RGBA.new(0.3, 0.55, 0.85, 1.0))
    }, false, false, 1)
    saved_boss = ((@saved_config || {}).dig("hunting", "boss_list") || []).join("\n")
    @w[:boss_list] = Gtk::TextView.new
    @w[:boss_list].buffer.text = saved_boss
    @w[:boss_list].set_size_request(-1, 75)
    bsw = Gtk::ScrolledWindow.new
    bsw.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    bsw.shadow_type = Gtk::SHADOW_IN
    bsw.add(@w[:boss_list])
    bb.pack_start(bsw, true, true, 2)
    vb.pack_start(bf, false, false, 6)

    sf, sb = frame_vbox("Never Attack (friendly / town NPCs)")
    sb.pack_start(Gtk::Label.new(
      "The script uses the game's hostile target list so it will never attack non-hostile NPCs " \
      "by default. This list is a safety net for edge cases -- invasions or scenarios where " \
      "a creature is flagged hostile but you still want to skip it.\n" \
      "Common town authority NPCs are also blocked automatically (guard, constable, sheriff, etc.).\n" \
      "Examples: brigand chief, merchant, peddler, healer"
    ).tap { |l| l.xalign = 0.0; l.set_line_wrap(true) }, false, false, 3)
    sb.pack_start(Gtk::Label.new("  v Click in the box below and type -- one entry per line v").tap { |l|
      l.xalign = 0.5
      l.override_color(:normal, Gdk::RGBA.new(0.3, 0.55, 0.85, 1.0))
    }, false, false, 1)
    saved_safe = ((@saved_config || {}).dig("hunting", "safe_npcs") || []).join("\n")
    @w[:safe_npcs] = Gtk::TextView.new
    @w[:safe_npcs].buffer.text = saved_safe
    @w[:safe_npcs].set_size_request(-1, 75)
    sw2 = Gtk::ScrolledWindow.new
    sw2.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC)
    sw2.shadow_type = Gtk::SHADOW_IN
    sw2.add(@w[:safe_npcs])
    sb.pack_start(sw2, true, true, 2)
    sb.pack_start(mk_hsep, false, false, 6)
    @w[:avoid_gigas] = Gtk::CheckButton.new("Gigas Peace (Hinterwilds) -- never attack gigas (brawny gigas shield-maiden, flayed gigas disciple, grim gigas skald, tattooed gigas berserker)")
    @w[:avoid_gigas].active = ((@saved_config || {}).dig("hunting", "avoid_gigas") == true)
    sb.pack_start(@w[:avoid_gigas], false, false, 3)
    warn_lbl = Gtk::Label.new(
      "WARNING: If unchecked, the script will treat gigas as hostile and attack them freely.\n" \
      "When checked, the script also suppresses ALL AoE/multi-target abilities while any gigas are present in the room."
    )
    warn_lbl.xalign = 0.0
    warn_lbl.set_line_wrap(true)
    warn_lbl.override_color(:normal, Gdk::RGBA.new(0.75, 0.45, 0.0, 1.0))
    sb.pack_start(warn_lbl, false, false, 3)
    vb.pack_start(sf, false, false, 6)

    scrolled(vb)
  end

  # ---------------------------------------------------------------------------
  # Trinkets tab -- Energy Wings pin and Battle Standard (manually configured)
  # ---------------------------------------------------------------------------
  def self.pg_trinkets
    saved = (@saved_config || {})["trinkets"] || {}
    outer = mk_vbox(8)
    outer.border_width = 10

    intro = Gtk::Label.new(
      "Trinkets are worn scripted items that are never held in hand and cannot be auto-detected.\n" \
      "Check each one you own and fill in the details."
    )
    intro.xalign = 0.0
    intro.set_line_wrap(true)
    outer.pack_start(intro, false, false, 4)

    rot_note = Gtk::Label.new("")
    rot_note.markup = "<i>Abilities added to the Weapon Attack Rotation are grayed out here -- they fire from the rotation and cannot be configured separately.</i>"
    rot_note.xalign = 0.0
    rot_note.wrap = true
    outer.pack_start(rot_note, false, false, 2)

    when_note = Gtk::Label.new("")
    when_note.xalign = 0.0
    when_note.set_line_wrap(true)
    when_note.set_markup(
      "<i><span foreground='#888888'>" \
      "<b>When options:</b>  " \
      "aoe = when creature count >= your AoE threshold (Hunting Prefs)  |  " \
      "swarm = when creatures >= your swarm threshold (set in Hunting Prefs; default 5)  |  " \
      "CC'd = any impairing debuff: stunned/webbed/bound/Mystic Impedance/Crippled; fires at any HP  |  " \
      "low_health = HP below your low_health % (Hunting Prefs, default 65%); fires regardless of CC; safe for arcarium/trinkets  |  " \
      "maintenance = out of combat  |  " \
      "target_vulnerable = when current target has a vulnerable status  |  " \
      "boss = when current target matches a name on the Boss List (Hunting Preferences 2)" \
      "</span></i>"
    )
    outer.pack_start(when_note, false, false, 2)
    outer.pack_start(mk_hsep, false, false, 3)

    # ---- Energy Wings ----
    ew = saved["energy_wings"] || {}
    ewf, ewb = frame_vbox("Energy Wings (worn pin)")

    ew_chk = Gtk::CheckButton.new("I have Energy Wings")
    ew_chk.active = ew["enabled"] == true
    ewb.pack_start(ew_chk, false, false, 2)

    ew_noun_e  = Gtk::Entry.new; ew_noun_e.text = ew["noun"].to_s.empty? ? "wing pin" : ew["noun"].to_s
    ew_type_c  = mk_combo_text(ENERGY_WINGS_TYPES, ENERGY_WINGS_TYPES.index(ew["wing_type"]) || 0)
    ew_tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((ew["tier"] || 1).to_f, 1.0, 3.0, 1.0, 1.0, 0.0), 1, 0)

    saved_ew_abs = ew["abilities"] || {}
    ew_ab_checks = {}
    ew_ab_vbox   = mk_vbox(2)
    ew_ab_hdr    = Gtk::Label.new("Abilities (uncheck to disable):")
    ew_ab_hdr.xalign = 0.0

    build_ew_abilities = lambda do
      ew_ab_vbox.children.each { |c| ew_ab_vbox.remove(c) }
      wt = ENERGY_WINGS_TYPES[ew_type_c.active].to_s.downcase.to_sym
      t  = ew_tier_sp.value.to_i
      (SCRIPT_TEMPLATES.dig("Energy Wings", :weapon) || [])
        .reject { |a| a[:when] == "skip" }
        .select { |a| (a[:min_tier] || 1) <= t && (a[:type] == :both || a[:type] == wt) }
        .each do |a|
          key      = a[:key].to_s
          saved_ab = saved_ew_abs[key] || {}
          prev     = ew_ab_checks[key]
          checked  = ew["enabled"] == true && (prev ? prev[:enabled_cb].active? : saved_ab.fetch("enabled", true))
          w_str    = prev ? BS_WHEN_OPTS[prev[:when_c].active || 0] : (saved_ab["when"] || a[:when])
          w_str    = "CC'd" if w_str == "emergency"
          w_idx    = BS_WHEN_OPTS.index(w_str) || BS_WHEN_OPTS.index(a[:when]) || 0
          cb       = Gtk::CheckButton.new("#{a[:key].upcase} -- #{a[:desc]}")
          cb.active = checked
          wc = mk_combo_text(BS_WHEN_OPTS, w_idx)
          hb = mk_hbox(4)
          hb.pack_start(cb, true, true, 0)
          hb.pack_start(Gtk::Label.new("When:"), false, false, 2)
          hb.pack_start(wc, false, false, 0)
          ew_ab_checks[key] = { enabled_cb: cb, when_c: wc, row: hb }
          ew_ab_vbox.pack_start(hb, false, false, 2)
        end
      ew_ab_vbox.show_all
      # Store widget refs for rotation grayout -- include row so label text grays too
      @w[:trinket_ability_widgets] ||= {}
      ew_ab_checks.each do |k, h|
        @w[:trinket_ability_widgets]["energy_wings:#{k}"] = [h[:row], h[:enabled_cb], h[:when_c]].compact
      end
    end

    ew_type_c.signal_connect("changed")        { build_ew_abilities.call }
    ew_tier_sp.signal_connect("value-changed") { build_ew_abilities.call }
    build_ew_abilities.call

    ew_detail_rows = [
      lrow("Item noun:",  ew_noun_e),
      lrow("Wing type:",  ew_type_c),
      lrow("Tier:",       ew_tier_sp),
      ew_ab_hdr,
      ew_ab_vbox,
    ]
    ew_detail_rows.each { |r| r.sensitive = ew_chk.active?; ewb.pack_start(r, false, false, 2) }
    ew_chk.signal_connect("toggled") { on = ew_chk.active?; ew_detail_rows.each { |r| r.sensitive = on } }

    @w[:ew_enabled]   = ew_chk
    @w[:ew_noun]      = ew_noun_e
    @w[:ew_wing_type] = ew_type_c
    @w[:ew_tier]      = ew_tier_sp
    @w[:ew_ab_checks] = ew_ab_checks
    outer.pack_start(ewf, false, false, 4)

    # ---- Battle Standard ----
    bs       = saved["battle_standard"] || {}
    bs_ab_cfg = bs["abilities"] || {}
    bsf, bsb = frame_vbox("Battle Standard (Paladin wearable -- from spell 1620)")

    bs_chk = Gtk::CheckButton.new("I have a Battle Standard")
    bs_chk.active = bs["enabled"] == true
    bsb.pack_start(bs_chk, false, false, 2)

    bs_noun_e  = Gtk::Entry.new; bs_noun_e.text = bs["noun"].to_s.empty? ? "standard" : bs["noun"].to_s
    bs_tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((bs["tier"] || 1).to_f, 1.0, 6.0, 1.0, 1.0, 0.0), 1, 0)

    bs_detail_rows = [lrow("Item noun:", bs_noun_e), lrow("Tier:", bs_tier_sp)]

    # Per-ability enable checkbox + "when" dropdown
    @w[:bs_ability_when]    = {}
    @w[:bs_ability_enabled] = {}
    @w[:bs_ability_rows]    = {}
    tmpl_abs = SCRIPT_TEMPLATES.dig("Battle Standard", :armor) || []
    tmpl_abs.reject { |a| a[:key] == "pray" }.each do |ab|
      key      = ab[:key].to_s
      saved_ab = bs_ab_cfg[key] || {}
      # Handle old format (plain string) and new format (hash with enabled+when)
      saved_when    = saved_ab.is_a?(Hash) ? (saved_ab["when"] || ab[:when]) : (saved_ab.to_s.empty? ? ab[:when] : saved_ab.to_s)
      saved_when    = "CC'd" if saved_when == "emergency"
      saved_enabled = bs["enabled"] == true && (saved_ab.is_a?(Hash) ? saved_ab.fetch("enabled", true) : true)
      w_idx  = BS_WHEN_OPTS.index(saved_when) || BS_WHEN_OPTS.index(ab[:when]) || 0
      combo  = mk_combo_text(BS_WHEN_OPTS, w_idx)
      cb     = Gtk::CheckButton.new("")
      cb.active = saved_enabled
      @w[:bs_ability_when][key]    = combo
      @w[:bs_ability_enabled][key] = cb
      hb = mk_hbox(4)
      hb.pack_start(cb, false, false, 0)
      lbl = Gtk::Label.new("#{ab[:key].upcase} (#{ab[:cd]}s CD) -- [T#{ab[:min_tier] || 1}] #{ab[:desc]}:")
      lbl.xalign = 0.0
      hb.pack_start(lbl, true, true, 0)
      hb.pack_start(combo, false, false, 0)
      @w[:bs_ability_rows][key] = hb
      bs_detail_rows << hb
    end

    bs_detail_rows.each { |r| r.sensitive = bs_chk.active?; bsb.pack_start(r, false, false, 2) }
    bs_chk.signal_connect("toggled") { on = bs_chk.active?; bs_detail_rows.each { |r| r.sensitive = on } }

    @w[:bs_enabled] = bs_chk
    @w[:bs_noun]    = bs_noun_e
    @w[:bs_tier]    = bs_tier_sp
    # Store widget refs for rotation grayout
    @w[:trinket_ability_widgets] ||= {}
    (@w[:bs_ability_enabled] || {}).each do |k, cb|
      @w[:trinket_ability_widgets]["battle_standard:#{k}"] = [@w[:bs_ability_rows][k], cb, @w[:bs_ability_when][k]].compact
    end
    outer.pack_start(bsf, false, false, 4)

    # ---- Bloodstone Jewelry ----
    bsj       = saved["bloodstone_jewelry"] || {}
    bsjf, bsjb = frame_vbox("Bloodstone Jewelry (Empath healing item -- Bloodsmith 1135)")

    bsj_chk = Gtk::CheckButton.new("I have Bloodstone Jewelry")
    bsj_chk.active = bsj["enabled"] == true
    bsjb.pack_start(bsj_chk, false, false, 2)

    bsj_noun_e  = Gtk::Entry.new; bsj_noun_e.text = bsj["noun"].to_s.empty? ? "bloodstone" : bsj["noun"].to_s
    bsj_tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((bsj["tier"] || 3).to_f, 1.0, 5.0, 1.0, 1.0, 0.0), 1, 0)

    # Tier 3 -- Vivacity: BESEECH <noun> HEALTH/STAMINA/MANA
    bsj_ab_cfg         = bsj["abilities"] || {}
    saved_viv          = bsj_ab_cfg["vivacity"] || {}
    bsj_viv_enabled    = Gtk::CheckButton.new("Enable Vivacity (T3+) -- BESEECH for HP/stamina/mana recovery  (CD: 60/45/30 min at T3/T4/T5)")
    bsj_viv_enabled.active = saved_viv.fetch("enabled", true)
    saved_viv_target   = saved_viv["target"] || "HEALTH"
    bsj_viv_target     = mk_combo_text(BLOODSTONE_VIVACITY_TARGETS, BLOODSTONE_VIVACITY_TARGETS.index(saved_viv_target) || 0)
    viv_hb = mk_hbox(6)
    viv_hb.pack_start(bsj_viv_enabled, true, true, 0)
    viv_hb.pack_start(Gtk::Label.new("Target:"), false, false, 2)
    viv_hb.pack_start(bsj_viv_target, false, false, 0)

    # Tier 4 -- Sanguine Swap: SPIN <noun>
    saved_swap         = bsj_ab_cfg["sanguine_swap"] || {}
    bsj_swap_enabled   = Gtk::CheckButton.new("Enable Sanguine Swap (T4+) -- SPIN stores all wounds for 10 minutes  (CD: 30 min)")
    bsj_swap_enabled.active = saved_swap.fetch("enabled", false)
    swap_warn = Gtk::Label.new(
      "WARNING: Stored wounds reappear after 10 minutes and WILL STACK with any new wounds acquired.\n" \
      "This CAN KILL YOU. Only add to your priority list if you can manage wounds before they return."
    )
    swap_warn.xalign = 0.0
    swap_warn.set_line_wrap(true)
    swap_warn.override_color(:normal, Gdk::RGBA.new(0.75, 0.2, 0.2, 1.0))

    # Note pointing to Hunting Preferences
    bsj_note = Gtk::Label.new(
      "Add Vivacity and/or Sanguine Swap to the Low Health Priority list in Hunting Preferences\n" \
      "to control when they fire and in what order."
    )
    bsj_note.xalign = 0.0
    bsj_note.set_line_wrap(true)
    bsj_note.override_color(:normal, Gdk::RGBA.new(0.5, 0.5, 0.5, 1.0))

    bsj_detail_rows = [
      lrow("Item noun:", bsj_noun_e),
      lrow("Tier:",      bsj_tier_sp),
      viv_hb,
      bsj_swap_enabled,
      swap_warn,
      bsj_note,
    ]

    # Gray abilities below their tier requirement (also respects the enabled checkbox)
    refresh_bsj_tiers = lambda do
      t = bsj_chk.active? ? bsj_tier_sp.value.to_i : 0
      viv_hb.sensitive           = t >= 3
      bsj_swap_enabled.sensitive = t >= 4
      swap_warn.sensitive        = t >= 4
    end
    bsj_tier_sp.signal_connect("value-changed") { refresh_bsj_tiers.call }

    bsj_detail_rows.each { |r| r.sensitive = bsj_chk.active?; bsjb.pack_start(r, false, false, 2) }
    bsj_chk.signal_connect("toggled") do
      on = bsj_chk.active?
      bsj_detail_rows.each { |r| r.sensitive = on }
      refresh_bsj_tiers.call
    end

    refresh_bsj_tiers.call

    @w[:bsj_enabled]          = bsj_chk
    @w[:bsj_noun]             = bsj_noun_e
    @w[:bsj_tier]             = bsj_tier_sp
    @w[:bsj_viv_enabled]      = bsj_viv_enabled
    @w[:bsj_viv_target]       = bsj_viv_target
    @w[:bsj_swap_enabled]     = bsj_swap_enabled
    outer.pack_start(bsjf, false, false, 4)

    # ---- Generic scripted trinket builder ----
    # Builds a frame with enable checkbox, noun entry, optional tier spinbutton,
    # and per-ability enable+when rows. Stores widgets under @w[:"trinket_#{key}_*"].
    build_trinket_frame = lambda do |label, key, max_tier, abilities_tmpl|
      sv    = (saved[key.to_s] || {})
      f, fb = frame_vbox(label)
      chk   = Gtk::CheckButton.new("I have this item")
      chk.active = sv["enabled"] == true
      fb.pack_start(chk, false, false, 2)

      noun_e = Gtk::Entry.new
      noun_e.text = sv["noun"].to_s.empty? ? key.to_s.tr("_", " ") : sv["noun"].to_s
      detail_rows = [lrow("Item noun:", noun_e)]

      tier_sp = nil
      if max_tier && max_tier > 1
        tier_sp = Gtk::SpinButton.new(Gtk::Adjustment.new((sv["tier"] || 1).to_f, 1.0, max_tier.to_f, 1.0, 1.0, 0.0), 1, 0)
        detail_rows << lrow("Tier:", tier_sp)
      end

      ab_cfg = sv["abilities"] || {}
      ab_widgets = {}
      abilities_tmpl.reject { |a| a[:when] == "skip" }.each do |a|
        k        = a[:key].to_s
        saved_ab = ab_cfg[k] || {}
        enabled  = sv["enabled"] == true && saved_ab.fetch("enabled", true)
        w_str    = saved_ab["when"] || a[:when]
        w_str    = "CC'd" if w_str == "emergency"
        w_idx    = BS_WHEN_OPTS.index(w_str) || BS_WHEN_OPTS.index(a[:when]) || 0
        cb       = Gtk::CheckButton.new("#{a[:key].upcase} -- #{a[:desc]}")
        cb.active = enabled
        wc = mk_combo_text(BS_WHEN_OPTS, w_idx)
        ab_widgets[k] = { enabled_cb: cb, when_c: wc }
        hb = mk_hbox(4)
        hb.pack_start(cb, true, true, 0)
        hb.pack_start(Gtk::Label.new("When:"), false, false, 2)
        hb.pack_start(wc, false, false, 0)
        detail_rows << hb
      end

      detail_rows.each { |r| r.sensitive = chk.active?; fb.pack_start(r, false, false, 2) }
      chk.signal_connect("toggled") { on = chk.active?; detail_rows.each { |r| r.sensitive = on } }

      @w[:"trinket_#{key}_enabled"]    = chk
      @w[:"trinket_#{key}_noun"]       = noun_e
      @w[:"trinket_#{key}_tier"]       = tier_sp
      @w[:"trinket_#{key}_ab_widgets"] = ab_widgets
      # Store widget refs for rotation grayout
      @w[:trinket_ability_widgets] ||= {}
      ab_widgets.each do |k2, h|
        @w[:trinket_ability_widgets]["#{key}:#{k2}"] = [h[:enabled_cb], h[:when_c]].compact
      end
      f
    end

    # ---- Elemental Gloves ----
    outer.pack_start(build_trinket_frame.call("Elemental Gloves (worn gloves)", :elemental_gloves, nil, EG_ABILITIES), false, false, 4)

    # ---- Twisted Gloves ----
    outer.pack_start(build_trinket_frame.call("Twisted Gloves (worn gloves, T4+)", :twisted_gloves, 5, TG_ABILITIES), false, false, 4)

    # ---- Twisted Kicks (boots) ----
    outer.pack_start(build_trinket_frame.call("Twisted Kicks (worn boots, T4+)", :twisted_kicks, 5, TK_ABILITIES), false, false, 4)

    # ---- Mage's Gauntlet ----
    outer.pack_start(build_trinket_frame.call("Mage's Gauntlet (worn gloves)", :mages_gauntlet, nil, []), false, false, 4)

    # ---- Magic Gloves / Bazzelwyn ----
    outer.pack_start(build_trinket_frame.call("Magic Gloves / Bazzelwyn (worn gloves)", :magic_gloves, nil, []), false, false, 4)

    # ---- Mana Battery Jewelry ----
    outer.pack_start(build_trinket_frame.call("Mana Battery Jewelry (worn jewelry)", :mana_battery, nil, []), false, false, 4)

    note = Gtk::Label.new
    note.markup = "<i>Trinket abilities added to the Weapon Attack Rotation are grayed out here -- they fire from the rotation and are suppressed in standalone mode to prevent double-firing.</i>"
    note.wrap = true; note.xalign = 0.0
    outer.pack_start(note, false, false, 4)

    @sync_cman_grayouts&.call
    scrolled(outer)
  end

  # ---------------------------------------------------------------------------
  # Gemstones tab -- up to 5 slots, passive properties noted, activated ones used
  # ---------------------------------------------------------------------------
  GEMSTONE_ACTIVATED_PROPS = [
    # -- Common --
    { name: "Force of Will",            cd: 86400, when: "emergency",   desc: "Removes debilitating effects (calmed, confused, etc.) -- CD varies by tier (24h/18h/12h/6h/1h)" },
    { name: "Geomancer's Spite",        cd: 180,   when: "aoe",         desc: "Ground erupts -- AoE grapple + immobilize SMR" },
    { name: "High Tolerance",           cd: 3600,  when: "aoe",  desc: "Triggered by alcohol -- stat modification buff for 1 hour" },
    # -- Rare --
    { name: "Advanced Spell Shielding", cd: 3600,  when: "emergency",   desc: "Dispel resistance -- CD varies by tier (60/30/10 min)" },
    { name: "Arcane Opus",              cd: 60,    when: "per_attack",  desc: "Next bolt spell gains +25% damage factor" },
    { name: "Blood Boil",               cd: 60,    when: "per_attack",  desc: "Deals 20% of target HP per tick (5 ticks)" },
    { name: "Blood Siphon",             cd: 900,   when: "aoe",  desc: "Vampiric aura -- SMR vs 5 enemies, 5-25% dmg restored as HP" },
    { name: "Blood Wellspring",         cd: 3600,  when: "emergency",   desc: "Instantly restore all health -- CD varies by tier (60/40/20 min)" },
    { name: "Evanescent Possession",    cd: 300,   when: "aoe",  desc: "Inflicts sympathy on an enemy -- 5 min cooldown" },
    { name: "Mana Wellspring",          cd: 3600,  when: "emergency",   desc: "Instantly restore all mana -- CD varies by tier (60/40/20 min)" },
    { name: "Spirit Wellspring",        cd: 3600,  when: "emergency",   desc: "Instantly restore all spirit -- CD varies by tier (60/40/20 min)" },
    { name: "Stamina Wellspring",       cd: 3600,  when: "emergency",   desc: "Instantly restore all stamina -- CD varies by tier (60/40/20 min)" },
    { name: "Terror's Tribute",         cd: 600,   when: "aoe",  desc: "Summons ethereal undead wall -- pulls and immobilizes enemies -- CD varies by tier (10/5/3 min)" },
    # -- Legendary --
    { name: "Arcane Aegis",             cd: 180,   when: "emergency",   desc: "Mana-draining critical padding shield -- 3 min cooldown" },
    { name: "Arcanist's Ascendancy",    cd: 180,   when: "aoe",  desc: "30s: Casting/Magical SMR = 30% enemy DS -- 3 min cooldown" },
    { name: "Arcanist's Blade",         cd: 180,   when: "aoe",  desc: "30s: +5-25 AS, +3-15% DF; costs 5 mana/stamina per attack -- 3 min cooldown" },
    { name: "Arcanist's Will",          cd: 180,   when: "aoe",  desc: "30s: +3-15 CS, +2-10 endroll; costs 5 mana/stamina -- 3 min cooldown" },
    { name: "Imaera's Balm",            cd: 86400, when: "emergency",   desc: "Instantly heals all wounds and scars -- once per day" },
    { name: "Mana Shield",              cd: 180,   when: "emergency",   desc: "Mana-draining damage padding -- 3 min cooldown" },
    { name: "Reckless Precision",       cd: 90,    when: "aoe",  desc: "30s: -50 DS, attacks 5% less evadable, +5% DF -- 90s cooldown" },
    { name: "Spellblade's Fury",        cd: 180,   when: "aoe",  desc: "60s: +3-15% AS from Spell Aim ranks; costs 10 mana/attack -- 3 min cooldown" },
    { name: "Unearthly Chains",         cd: 180,   when: "aoe",  desc: "Summons ghostly chains to pull and immobilize enemies -- 3 min cooldown" },
    { name: "Witchhunter's Ascendancy", cd: 180,   when: "aoe",  desc: "30s: +AS equal to 50% enemy DS (max 100) -- 3 min cooldown" },
  ].freeze

  MAX_GEMSTONE_SLOTS = 5

  def self.pg_gemstones
    saved_gems = (@saved_config || {})["gemstones"] || {}
    outer = mk_vbox(8)
    outer.border_width = 10

    intro = Gtk::Label.new(
      "Configure up to #{MAX_GEMSTONE_SLOTS} equipped gemstone slots.\n" \
      "Only activated properties (those with a cooldown and GEM ACTIVATE command) are shown in the dropdown.\n" \
      "Passive properties like Blood Prism, Mana Prism, etc. are always-on and need no configuration here."
    )
    intro.xalign = 0.0
    intro.set_line_wrap(true)
    outer.pack_start(intro, false, false, 4)

    gem_rot_note = Gtk::Label.new
    gem_rot_note.markup = "<i>Activated gemstone slots added to the Weapon Attack Rotation are grayed out here -- they fire from the rotation and are suppressed in standalone mode to prevent double-firing.</i>"
    gem_rot_note.wrap = true
    gem_rot_note.xalign = 0.0
    outer.pack_start(gem_rot_note, false, false, 2)

    outer.pack_start(mk_hsep, false, false, 3)

    detected_slots = (@detected || {})[:gem_slots] || Array.new(MAX_GEMSTONE_SLOTS) { { equipped: false, name: "" } }

    MAX_GEMSTONE_SLOTS.times do |i|
      slot_num = i + 1
      sg       = (saved_gems["slots"] || [])[i] || {}
      det      = detected_slots[i] || { equipped: false, name: "" }
      gf, gb   = frame_vbox("Gemstone Slot #{slot_num}")

      g_chk = Gtk::CheckButton.new("I have a gemstone in slot #{slot_num}")
      g_chk.active = sg["enabled"] == true || det[:equipped]
      gb.pack_start(g_chk, false, false, 2)

      g_name_e = Gtk::Entry.new
      g_name_e.text = sg["name"].to_s.empty? ? det[:name].to_s : sg["name"].to_s
      g_name_e.placeholder_text = "e.g. alexandrite" rescue nil

      g_passive_e = Gtk::Entry.new; g_passive_e.text = sg["passive_note"].to_s
      g_passive_e.placeholder_text = "e.g. Blood Prism, Mana Prism (just for your notes)" rescue nil

      det_props = det[:properties] || []
      avail_props = if det_props.any?
                      GEMSTONE_ACTIVATED_PROPS.select { |p| det_props.any? { |d| d.casecmp(p[:name]) == 0 } }
                    else
                      GEMSTONE_ACTIVATED_PROPS
                    end
      act_names = ["-- None --"] + avail_props.map { |p| p[:name] }
      saved_act    = (sg["enabled"] == true) ? sg["activated_property"].to_s : ""
      found_idx    = avail_props.index { |p| p[:name] == saved_act }
      act_idx      = found_idx ? found_idx + 1 : 0
      g_act_c   = mk_combo_text(act_names, act_idx)

      g_act_lbl = Gtk::Label.new(""); g_act_lbl.xalign = 0.0; g_act_lbl.set_line_wrap(true)
      refresh_act = lambda do
        idx = g_act_c.active - 1
        if idx >= 0 && idx < avail_props.size
          p = avail_props[idx]
          g_act_lbl.text = "  When: #{p[:when]}  |  CD: #{p[:cd]}s\n  #{p[:desc]}"
        else
          g_act_lbl.text = "  No activated ability selected."
        end
      end
      g_act_c.signal_connect("changed") { refresh_act.call }
      refresh_act.call

      g_detail_rows = [
        lrow("Gemstone name:", g_name_e),
        lrow("Passive notes:", g_passive_e),
        lrow("Activated property:", g_act_c),
        g_act_lbl,
      ]
      g_detail_rows.each { |r| r.sensitive = g_chk.active?; gb.pack_start(r, false, false, 2) }
      g_chk.signal_connect("toggled") { on = g_chk.active?; g_detail_rows.each { |r| r.sensitive = on } }

      @w[:"gem#{slot_num}_enabled"] = g_chk
      @w[:"gem#{slot_num}_name"]    = g_name_e
      @w[:"gem#{slot_num}_passive"] = g_passive_e
      @w[:"gem#{slot_num}_act"]     = g_act_c
      @w[:gem_slot_widgets] ||= {}
      @w[:gem_slot_widgets][slot_num] = [g_act_c].compact
      outer.pack_start(gf, false, false, 4)
    end

    @sync_cman_grayouts&.call
    scrolled(outer)
  end

  def self.scripts_for_slot(slot_key, slot_sym, noun)
    return [] unless @script_entries
    @script_entries.filter_map do |_entry_key, e|
      entry_slot = SCRIPT_SLOT_KEYS[e[:slot].active] rescue :primary
      next unless entry_slot == slot_key
      name     = e[:name].to_s
      tier     = e[:tier].value.to_i
      template = (SCRIPT_TEMPLATES[name] || {})[slot_sym] || []
      next if template.empty?
      wt_sym = if e[:wing_type] && name == "Energy Wings"
                 ENERGY_WINGS_TYPES[e[:wing_type].active].to_s.downcase.to_sym
               else
                 nil
               end
      ab_checks  = e[:ability_checks] || {}
      wc_combos  = e[:when_combos]   || {}
      effective_noun = noun
      abilities = template.reject { |ab| ab[:when] == "skip" || ab[:when] == "toggle_startup" }.select do |ab|
        next false if ab[:min_tier] && ab[:min_tier] > tier
        if wt_sym && ab[:type] && ab[:type] != :both
          next false if ab[:type] != wt_sym
        end
        ab_checks["#{slot_sym}:#{ab[:key]}"]&.active? != false
      end.map do |ab|
        row = ab.reject { |k, _| [:type, :min_tier].include?(k) }.transform_keys(&:to_s).dup
        row["verb"] = row["verb"].gsub("#NOUN", effective_noun)
        combo_key = "#{slot_sym}:#{ab[:key]}"
        if (wc = wc_combos[combo_key])
          user_when = SCRIPT_WHEN_OPTS[wc.active]
          row["when"] = user_when if user_when
        end
        row
      end
      { "name" => name, "tier" => tier, "wing_type" => wt_sym&.to_s, "abilities" => abilities }
    end
  end

  # ===========================================================================
  # Save
  # ===========================================================================
  def self.do_save
    profile = nil
    begin
      profile = collect_profile
    rescue => e
      respond "[gsh4a] ERROR saving profile: #{e.message}"
      respond e.backtrace.first(3).join("\n")
      return  # leave window open so user can try again
    end
    begin
      save_profile(profile)
    rescue => e
      respond "[gsh4a] ERROR writing profile to disk: #{e.message}"
    end
    @win.destroy
    signal_setup_done
  end

  def self.collect_profile
    p = { "version" => "1.0" }
    p["character"] = {
      "name"       => @w[:char_name].text.strip,
      "race"       => GS_RACES[       @w[:char_race].active  ] || "",
      "profession" => GS_PROFESSIONS[ @w[:char_prof].active  ] || "",
      "level"      => GS_LEVELS[      @w[:char_level].active ].to_i,
    }
    p["society"]    = collect_society
    disabled_by_name = {}
    (@script_entries || {}).each do |_entry_key, e|
      nm = e[:name].to_s
      next if nm.empty?
      disabled_by_name[nm] ||= []
      disabled_by_name[nm] += (e[:ability_checks] || {}).select { |_k, cb| !cb.active? }.keys
    end
    p["script_disabled"] = disabled_by_name
    p["weapons"]    = collect_weapons
    p["armor"]      = collect_item(:armor_noun, :armor, :armor)
    p["shield"]     = collect_shield
    p["mount"]      = collect_mount
    p["spells"]     = collect_spells
    detected_lore = (@detected || {})[:lore_ranks] || {}
    saved_lore_p  = (@saved_config || {})["lore_ranks"] || {}
    p["lore_ranks"] = detected_lore.empty? ? saved_lore_p : saved_lore_p.merge(detected_lore)
    bless_ranks = p["lore_ranks"]["Blessings"].to_i
    # Match the thresholds shown in the UI (50 ranks = 2/day, 125 ranks = 3/day)
    armor_daily_limit = 1 + (bless_ranks >= 50 ? 1 : 0) + (bless_ranks >= 125 ? 1 : 0)
    p["paladin_spells"] = {
      "beseech_enabled"            => @w[:pal_1635_enabled]&.active? || false,
      "wof_feeble_enabled"         => @w[:wof_feeble_enabled]&.active? || false,
      "incarn_armor_emergency"     => @w[:pal_incarn_armor_emerg]&.active? || false,
      "incarn_armor_rt_threshold"  => @w[:pal_incarn_armor_rt]&.value&.to_i || 8,
      "incarn_armor_daily_limit"   => armor_daily_limit,
      "incarn_zeal"                => @w[:pal_incarn_zeal]&.active? || false,
      "incarn_smite"               => @w[:pal_incarn_smite]&.active? || false,
      "incarn_onslaught"           => @w[:pal_incarn_onslaught]&.active? || false,
      "incarn_onslaught_swarm"     => @w[:pal_incarn_onslaught_swarm]&.active? || false,
    }
    p["bard_sonic"]          = collect_bard_sonic
    p["ranger_companion"]    = collect_ranger_companion
    p["sorcerer_demon"]      = collect_sorcerer_demon
    p["spirit_servant"]      = collect_spirit_servant
    cmans = []
    @cman_store&.each do |_m, _p, iter|
      next if iter[3].to_s == "passive"
      cmans << {
        "enabled"     => iter[0] == true,
        "name"        => iter[1].to_s,
        "verb"        => iter[2].to_s,
        "type"        => iter[3].to_s,
        "stamina"     => iter[4].to_i,
        "cd"          => iter[5].to_i,
        "daily_limit" => iter[6].to_i,
        # col 7 is the internal editable-sensitive boolean -- skip it
        "grip"        => iter[8].to_s,
      }
    end
    p["cmans"] = cmans
    p["techniques"]   = collect_enabled_store(@tech_store, %w[name verb tech_type trigger stamina min_creatures min_rank grip mnemonic ranks category])
                          .each { |r| r["stamina"] = r["stamina"].to_i; r["min_creatures"] = r["min_creatures"].to_i }
    p["shield_specs"] = collect_enabled_store(@shield_spec_store, %w[name verb tech_type min_creatures])
                          .each { |r| r["min_creatures"] = r["min_creatures"].to_i }
    p["armor_specs"]  = collect_enabled_store(@armor_spec_store, %w[name verb tech_type min_creatures])
                          .each { |r| r["min_creatures"] = r["min_creatures"].to_i }
    ss_mods = ["(none)", "waylay", "jab", "grapple", "punch", "kick"]
    ss_hide = ["hide", "vanish"]
    p["rogue_guild"] = {
      "stun_enabled"   => @w[:rg_stun_enabled]&.active? || false,
      "stun_action"    => ["attack", "hide", "stand"][@w[:rg_stun_action]&.active || 0] || "attack",
      "stun_stamina"   => @w[:rg_stun_stamina]&.value&.to_i || 10,
      "ss_enabled"     => @w[:rg_ss_enabled]&.active? || false,
      "ss_modifier"    => ss_mods[@w[:rg_ss_modifier]&.active || 0] || "(none)",
      "ss_hide_method" => ss_hide[@w[:rg_ss_hide_method]&.active || 0] || "hide",
    }
    warcries_save = {}
    WG_WARCRIES.each do |cry|
      warcries_save[cry[:key]] = {
        "enabled" => @w.dig(:wg_warcry, cry[:key])&.active? || false,
        "aoe"     => @w.dig(:wg_warcry_aoe, cry[:key])&.active? || false,
      }
    end
    p["warrior_guild"] = {
      "berserk_enabled"     => @w[:wg_berserk_enabled]&.active? || false,
      "berserk_stamina_min" => @w[:wg_berserk_stamina]&.value&.to_i || 30,
      "berserk_max_rounds"  => @w[:wg_berserk_rounds]&.value&.to_i || 0,
      "warcries"            => warcries_save,
      "feint_enabled"       => @w[:wg_feint_enabled]&.active? || false,
      "spit_enabled"        => @w[:wg_spit_enabled]&.active? || false,
      "spit_location"       => WG_TRICK_LOCS[@w[:wg_spit_loc]&.active || 0] || "chest",
    }
    p["arcarium"]   = {
      "aversaris" => collect_arcarium(:aversaris),
      "vangaris"  => collect_arcarium(:vangaris),
    }
    collect_generic_trinket = lambda do |key|
      {
        "enabled"   => @w[:"trinket_#{key}_enabled"]&.active? || false,
        "noun"      => @w[:"trinket_#{key}_noun"]&.text&.strip || "",
        "tier"      => @w[:"trinket_#{key}_tier"]&.value&.to_i || 1,
        "abilities" => (@w[:"trinket_#{key}_ab_widgets"] || {}).transform_values { |r|
          { "enabled" => r[:enabled_cb]&.active? != false,
            "when"    => BS_WHEN_OPTS[r[:when_c]&.active || 0] || "aoe" }
        },
      }
    end
    p["trinkets"] = {
      "energy_wings" => {
        "enabled"   => @w[:ew_enabled]&.active? || false,
        "noun"      => @w[:ew_noun]&.text&.strip || "wing pin",
        "tier"      => @w[:ew_tier]&.value&.to_i || 1,
        "wing_type" => ENERGY_WINGS_TYPES[@w[:ew_wing_type]&.active.to_i] || "Light",
        "abilities" => (@w[:ew_ab_checks] || {}).transform_values { |r|
          { "enabled" => r[:enabled_cb]&.active? != false,
            "when"    => BS_WHEN_OPTS[r[:when_c]&.active || 0] || "aoe" }
        },
      },
      "battle_standard" => {
        "enabled"    => @w[:bs_enabled]&.active? || false,
        "noun"       => @w[:bs_noun]&.text&.strip || "standard",
        "tier"       => @w[:bs_tier]&.value&.to_i || 1,
        "abilities"  => (@w[:bs_ability_when] || {}).each_with_object({}) { |(k, c), h|
          h[k] = { "enabled" => @w[:bs_ability_enabled][k]&.active? != false,
                   "when"    => BS_WHEN_OPTS[c.active] || "aoe" }
        },
      },
      "elemental_gloves" => collect_generic_trinket.call(:elemental_gloves),
      "twisted_gloves"   => collect_generic_trinket.call(:twisted_gloves),
      "twisted_kicks"    => collect_generic_trinket.call(:twisted_kicks),
      "mages_gauntlet"      => collect_generic_trinket.call(:mages_gauntlet),
      "magic_gloves"        => collect_generic_trinket.call(:magic_gloves),
      "mana_battery"        => collect_generic_trinket.call(:mana_battery),
      "bloodstone_jewelry"  => {
        "enabled" => @w[:bsj_enabled]&.active? || false,
        "noun"    => @w[:bsj_noun]&.text&.strip || "bloodstone",
        "tier"    => @w[:bsj_tier]&.value&.to_i || 3,
        "abilities" => {
          "vivacity"      => {
            "enabled" => @w[:bsj_viv_enabled]&.active? || false,
            "target"  => BLOODSTONE_VIVACITY_TARGETS[@w[:bsj_viv_target]&.active || 0] || "HEALTH",
          },
          "sanguine_swap" => {
            "enabled" => @w[:bsj_swap_enabled]&.active? || false,
          },
        },
      },
    }
    slots = (1..MAX_GEMSTONE_SLOTS).map do |i|
      act_idx = @w[:"gem#{i}_act"]&.active.to_i - 1
      act_prop = act_idx >= 0 ? GEMSTONE_ACTIVATED_PROPS[act_idx] : nil
      {
        "enabled"             => @w[:"gem#{i}_enabled"]&.active? || false,
        "name"                => @w[:"gem#{i}_name"]&.text&.strip || "",
        "passive_note"        => @w[:"gem#{i}_passive"]&.text&.strip || "",
        "activated_property"  => (@w[:"gem#{i}_enabled"]&.active? && act_prop) ? act_prop[:name] : nil,
        "activated_when"      => act_prop ? act_prop[:when] : nil,
        "activated_cd"        => act_prop ? act_prop[:cd]   : nil,
        "slot_num"            => i,
      }
    end
    p["gemstones"]            = { "slots" => slots }
    p["emergency_priorities"] = {
      "low_health" => collect_priority_list(@w[:ep_low_health_store]),
      "cc"         => collect_priority_list(@w[:ep_cc_store]),
    }
    p["hunting"]    = {
      "grouped_mode"        => @w[:grouped_mode]&.active? || false,
      "maintenance_only"    => @w[:maintenance_only].active?,
      "use_eloot"           => @w[:use_eloot]&.active? != false,
      "eloot_grouped"       => (@w[:eloot_grouped_run]&.active? ? "run" : "skip"),
      "low_health_pct"      => @w[:low_health_pct].value.to_i,
      "health_retreat_pct"          => @w[:health_retreat_pct].value.to_i,
      "wound_retreat" => WOUND_BODY_PARTS.each_with_object(
        {
          "retreat_when_grouped" => @w[:wound_retreat_grouped]&.active? || false,
          "combo_enabled"        => @w[:wound_combo_enabled]&.active? || false,
          "combo_score"          => @w[:wound_combo_score]&.value&.to_i || 7,
        }
      ) { |(key, _m, _l, default_thresh), h|
        h[key] = (@w[:wound_part_spinners] || {})[key]&.value&.to_i || default_thresh
      },
      "mana_retreat_pct"            => (@w[:mana_retreat_enabled]&.active? ? @w[:mana_retreat_pct].value.to_i : 0),
      "mana_retreat_when_grouped"   => @w[:mana_retreat_grouped]&.active? || false,
      "stamina_floor_enabled" => @w[:stamina_floor_enabled]&.active? || false,
      "mana_floor_enabled"    => @w[:mana_floor_enabled]&.active?    || false,
      "stamina_min_reserve"   => @w[:stamina_floor_enabled]&.active? ? @w[:stamina_reserve].value.to_i : 0,
      "mana_min_reserve"      => @w[:mana_floor_enabled]&.active?    ? @w[:mana_reserve].value.to_i    : 0,
      "aoe_threshold"       => @w[:aoe_threshold]&.value&.to_i || (@saved_config || {}).dig("hunting", "aoe_threshold") || 3,
      "swarm_threshold"     => @w[:swarm_threshold]&.value&.to_i || (@saved_config || {}).dig("hunting", "swarm_threshold") || 4,
      "escape_priority" => (@esc_prio_order || []).map do |type|
        d     = (@esc_prio_widgets || {})[type]
        entry = {"type" => type, "enabled" => d ? d[:cb].active? : false}
        entry["room"] = @w[:esc_room_entry]&.text&.strip.to_s if type == "saferoom"
        entry["ignore_floors"] = @w[:esc_ignore_floors]&.active? || false if type == "society"
        entry
      end,
      "encumbrance_ignore"      => @w[:encumbrance_ignore]&.active? || false,
      "encumbrance_retreat_pct" => (ENCUMBRANCE_LEVELS[@w[:encumbrance_retreat]&.active || 0]&.last || 0),
      "dread" => {
        "enabled"              => @w[:dread_enabled]&.active? || false,
        "creeping_threshold"   => @w[:creeping_dread_threshold]&.value&.to_i || 20,
        "crushing_threshold"   => @w[:crushing_dread_threshold]&.value&.to_i || 15,
        "retreat_when_grouped" => @w[:dread_retreat_grouped]&.active? || false,
      },
      "stance_preference"   => ["offensive", "guarded", "defensive", "none"][@w[:stance_preference]&.active || 0] || "offensive",
      "npc_priority"        => ["caster_first", "lowest_hp", "first_available", "priority_list"][@w[:npc_priority]&.active || 0] || "caster_first",
      "priority_creatures"  => (@w[:priority_creatures]&.buffer&.text || "")
                                 .split(/[\n,]+/).map(&:strip).reject(&:empty?),
      "safe_npcs"           => (@w[:safe_npcs]&.buffer&.text || "")
                                 .split(/[\n,]+/).map(&:strip).reject(&:empty?),
      "avoid_gigas"         => (@w[:avoid_gigas]&.active? || false),
      "pause_on_dead_player" => (@w[:pause_on_dead_player]&.active? || false),
      "run_ecleanse"         => @w[:run_ecleanse]&.active? || false,
      "empress_first"        => @w[:empress_first]&.active? || false,
      "emperor_first"        => @w[:emperor_first]&.active? || false,
      "miniboss_mode"        => @w[:miniboss_mode]&.active? || false,
      "boss_list"            => (@w[:boss_list]&.buffer&.text || "")
                                  .split(/[\n,]+/).map(&:strip).reject(&:empty?),
      "combat_start_room"    => @w[:combat_start_room]&.text&.strip.to_s,
    }
    p
  end

  def self.collect_priority_list(store)
    return [] unless store
    list = []
    store.each do |_m, _p, iter|
      type        = iter[0].to_s
      slot_or_arc = iter[2].to_s
      key_or_name = iter[3].to_s
      next if type.empty? || slot_or_arc.empty? || key_or_name.empty?
      if type == "vissi"
        list << {"type" => "vissi", "arcarium" => slot_or_arc, "name" => key_or_name}
      elsif type == "ability"
        list << {"type" => "ability", "slot" => slot_or_arc, "key" => key_or_name}
      elsif type == "builtin"
        list << {"type" => "builtin", "id" => key_or_name}
      end
    end
    list
  end

  def self.collect_society
    name = @w[:society_name_val]
    return { "name" => nil } if name.nil? || name == "None"
    rank = (@w[:society_rank_val] || @w[:society_rank_sp]&.value || 1).to_i
    data = SOCIETY_DATA[name]
    return { "name" => name, "rank" => rank, "maintain" => [], "on_demand" => [] } unless data
    maintain = data[:maintain].select { |e| @w[:"#{name.downcase}_maintain"]&.[](e[:name])&.active? }
                              .map { |e| { "name" => e[:name], "cmd" => e[:cmd], "buff" => e[:buff], "spell_id" => e[:spell_id] }.compact }
    on_demand = data[:on_demand].select { |e| @w[:"#{name.downcase}_ondemand"]&.[](e[:name])&.active? }
                                .map { |e| { "name" => e[:name], "cmd" => e[:cmd] } }
    # Derive society escape state from the priority list widget (new design)
    escape = if @esc_prio_widgets && @esc_prio_widgets["society"]
      d = @esc_prio_widgets["society"]
      h = {"enabled" => d[:cb].active?}
      h["ignore_floors"] = @w[:esc_ignore_floors]&.active? || false if @w[:esc_ignore_floors]
      h
    else
      ((@profile.dig("society", "escape") ||
        @profile.dig("society", "symbol_return") rescue nil) || {})
    end
    { "name" => name, "rank" => rank, "maintain" => maintain, "on_demand" => on_demand,
      "escape" => escape }
  end

  def self.collect_weapons
    dual = dual_wield?
    collect_weapon_rot = lambda do |combos_arr|
      combos_arr.filter_map do |items_arr, combo, spell_combo|
        key = combo.active_id.to_s
        next nil if key.empty? || key == "normal_attack"
        case key
        when "skip" then nil
        when "spell"
          cmd = spell_combo&.active_id.to_s.strip
          next nil if cmd.empty?
          {"type" => "spell", "cmd" => cmd}
        when "mount_charge"   then {"type" => "mount_charge"}
        when "mount_trample"  then {"type" => "mount_trample"}
        when /\Afeat:(.+)/    then {"type" => "feat", "name" => $1}
        when /\Acman:(.+)/    then {"type" => "cman", "name" => $1}
        when /\Atechnique:(.+)/ then {"type" => "technique", "name" => $1}
        when /\Awarcry:(.+)/     then {"type" => "warcry",        "key" => $1}
        when "warrior_feint"     then {"type" => "warrior_feint"}
        when "warrior_spit"      then {"type" => "warrior_spit"}
        when "rogue_ss"          then {"type" => "rogue_ss"}
        when /\Avissi:(\w+):(.+)/
          {"type" => "vissi", "key" => "#{$1}:#{$2}", "arcarium" => $1, "name" => $2}
        when /\Atrinket:(\w+):(.+)/
          {"type" => "trinket", "key" => "#{$1}:#{$2}", "slot" => $1, "ability_key" => $2}
        when /\Agemstone:(\d+)/
          {"type" => "gemstone", "slot_num" => $1.to_i}
        when /\Ascript_wpn:(.+)/     then {"type" => "script_wpn",     "key" => $1}
        when /\Ascript_arm:(.+)/     then {"type" => "script_arm",     "key" => $1}
        when /\Asociety_attack:(.+)/ then {"type" => "society_attack", "cmd" => $1}
        when /\Ashield_spec:(.+)/
          name = $1
          verb = @shield_spec_store ? begin
            v = nil
            @shield_spec_store.each { |_m, _p, it| v = @shield_spec_store.get_value(it, 2) if @shield_spec_store.get_value(it, 1) == name }
            v
          end : nil
          {"type" => "shield_spec", "name" => name, "verb" => (verb || "shield #{name.downcase}")}
        else nil
        end
      end
    end
    { "dual_wield"        => dual,
      "primary"           => collect_weapon("primary"),
      "secondary"         => dual ? collect_weapon("secondary") : nil,
      "ambush"            => {
        "enabled"    => @w[:ambush_enabled]&.active? || false,
        "hide_first" => @w[:ambush_hide]&.active?    || false,
      },
      "holy_weapon"         => collect_holy_weapon,
      "weapon_rotation"     => collect_weapon_rot.call(@weapon_rot_combos_st  || []),
      "weapon_aoe_rotation" => collect_weapon_rot.call(@weapon_rot_combos_aoe || []),
      "recovery"            => {
        "use_119"     => @w[:wr_use_119]&.active?    || false,
        "use_recover" => @w[:wr_use_recover]&.active? || false,
      } }
  end

  def self.collect_holy_weapon
    return { "enabled" => false } unless @w[:hw_enabled]
    spell_keys = @w[:hw_spell_keys] || ["106","125","1607","1615","1619"]
    mode_keys  = @w[:hw_mode_keys]  || ["per_attack","per_target","once"]
    spell_key  = spell_keys[@w[:hw_spell]&.active || 0] || "1615"
    mode_key   = mode_keys[@w[:hw_mode]&.active  || 1] || "per_target"
    { "enabled"    => @w[:hw_enabled].active?,
      "spell"      => spell_key,
      "mode"       => mode_key,
      "autorefill" => (@w[:hw_autorefill]&.active? != false) }
  end

  def self.collect_weapon(which)
    noun     = @w[:"#{which}_noun"].text.strip
    type_idx = @w[:"#{which}_type"].active rescue 0
    type_d   = WEAPON_TYPES[type_idx] || WEAPON_TYPES[0]
    slot_key = which == "primary" ? :primary : :secondary
    loc_idx = @w[:"#{which}_target_loc"]&.active || 0
    loc_val = loc_idx > 0 ? AIM_LOCATIONS[loc_idx - 1] : ""
    h = { "enabled"         => @w[:"#{which}_enabled"]&.active? != false,
          "noun"            => noun,
          "type"            => type_d[:code],
          "grip"            => type_d[:grip],
          "target_location" => loc_val,
          "scripts"         => scripts_for_slot(slot_key, :weapon, noun) }
    if type_d[:code] == "polearm"
      h["polearm_with_shield"] = (@w[:"#{which}_pol_shield"]&.active || 0) == 1
    end
    if type_d[:grip] == "ranged"
      sub_idx = @w[:"#{which}_ranged_sub"]&.active || 0
      h["ranged_noun"]     = @w[:"#{which}_ranged_noun"]&.text&.strip || ""
      h["ranged_subtype"]  = RANGED_SUBTYPES[sub_idx] || "bow"
      h["ammo_container"]  = @w[:"#{which}_ammo_cont"]&.text&.strip || "quiver"
      h["aim_first"]       = @w[:"#{which}_aim_first"]&.active? || false
      h["ammo_warn_at"]    = @w[:"#{which}_ammo_warn"]&.value&.to_i || 10
      h["hide_to_shoot"]   = @w[:"#{which}_hide_to_shoot"]&.active?  || false
      h["use_608_hide"]    = @w[:"#{which}_use_608_hide"]&.active?   || false
      h["kneel_crossbow"]  = @w[:"#{which}_kneel_crossbow"]&.active? || false
      h["stay_kneeling"]   = @w[:"#{which}_stay_kneeling"]&.active?  || false
    end
    if which == "primary" && @w[:sonic_weapon_primary]
      h["sonic_weapon"] = @w[:sonic_weapon_primary].active?
    end
    h
  end

  def self.collect_item(noun_key, slot_key, slot_sym)
    noun = @w[noun_key].text.strip
    asg_widget = @w[:armor_asg]
    asg = asg_widget ? (ARMOR_TYPES[asg_widget.active]&.dig(:asg) || nil) : nil
    h = { "noun" => noun, "scripts" => scripts_for_slot(slot_key, slot_sym, noun) }
    h["asg"] = asg if asg
    h["sonic_armor"] = @w[:sonic_armor_primary].active? if slot_sym == :armor && @w[:sonic_armor_primary]
    h
  end

  def self.collect_spirit_servant
    {
      "enabled"      => @w[:ss2_enabled]&.active?      || false,
      "fetch_weapon" => @w[:ss2_fetch_weapon]&.active? || false,
      "weapon_noun"  => @w[:ss2_weapon_noun]&.text&.strip || "",
    }
  end

  def self.collect_sorcerer_demon
    {
      "enabled"       => @w[:sd_enabled]&.active?      || false,
      "fetch_weapon"  => @w[:sd_fetch_weapon]&.active? || false,
      "weapon_noun"   => @w[:sd_weapon_noun]&.text&.strip || "",
    }
  end

  def self.collect_ranger_companion
    {
      "enabled"        => @w[:rc_enabled]&.active?  || false,
      "companion_type" => RANGER_COMPANION_TYPES[@w[:rc_type]&.active || 0] || "canine",
      "behavior"       => RANGER_COMPANION_BEHAVIORS[@w[:rc_behavior]&.active || 0] || "offensive",
      "attack_target"  => @w[:rc_attack]&.active?   || false,
      "resummon"       => @w[:rc_resummon]&.active?  || false,
    }
  end

  def self.collect_bard_sonic
    wpn_on  = @w[:sonic_wpn_enabled]&.active?  || false
    shld_on = @w[:sonic_shld_enabled]&.active? || false
    arm_on  = @w[:sonic_arm_enabled]&.active?  || false
    wpn_idx = @w[:sonic_wpn_type]&.active || 0
    wpn_opt = SONIC_WPN_OPTS[wpn_idx] || SONIC_WPN_OPTS[0]
    arm_asg = ARMOR_TYPES[@w[:sonic_arm_asg]&.active || 0]&.dig(:asg) || 0
    sword_on   = @w[:singing_sword_enabled]&.active? || false
    sword_type = SINGING_SWORD_OPTS[@w[:singing_sword_type]&.active || 0]&.dig(:sing) || "falchion"
    def_songs  = (@w[:bard_def_songs]  || {}).select { |_, cb| cb.active? }.keys
    util_songs = (@w[:bard_util_songs] || {}).select { |_, cb| cb.active? }.keys
    cyc_songs  = (@w[:bard_cyc_songs]  || {}).select { |_, cb| cb.active? }.keys
    # Collect renew mode: any song whose renew combo is set to index 1
    renew_songs = []
    [(@w[:bard_def_renew] || {}), (@w[:bard_util_renew] || {})].each do |map|
      map.each do |num, rc|
        renew_songs << num if rc && rc.active == 1
      end
    end
    {
      "weapon_enabled"   => wpn_on,
      "weapon_spell"     => @w[:sonic_wpn_num]&.value&.to_i || 1012,
      "weapon_sing"      => wpn_opt[:sing],
      "weapon_type"      => wpn_opt[:type],
      "weapon_grip"      => wpn_opt[:grip] || "two",
      "shield_enabled"   => shld_on,
      "shield_spell"     => @w[:sonic_shld_num]&.value&.to_i || 1009,
      "shield_sing"      => SONIC_SHLD_OPTS[@w[:sonic_shld_type]&.active || 0]&.dig(:sing) || "buckler",
      "armor_enabled"    => arm_on,
      "armor_spell"      => @w[:sonic_arm_num]&.value&.to_i || 1014,
      "armor_asg"        => arm_asg,
      "singing_sword"    => sword_on,
      "singing_sword_type" => sword_type,
      "defensive_songs"  => def_songs,
      "utility_songs"    => util_songs,
      "cyclic_songs"     => cyc_songs,
      "renew_songs"      => renew_songs,
    }
  end

  def self.collect_shield
    sonic = @w[:sonic_shield_primary]&.active? || false
    return { "enabled" => false, "sonic_shield" => sonic } unless @w[:shield_enabled]&.active?
    noun = @w[:shield_noun].text.strip
    { "enabled"      => true,
      "noun"         => noun,
      "sonic_shield" => sonic,
      "scripts"      => scripts_for_slot(:shield, :shield, noun) }
  end

  def self.collect_mount
    return { "enabled" => false } unless @w[:mount_enabled]&.active?
    { "enabled"     => true,
      "noun"        => @w[:mount_noun].text.strip,
      "summon_item" => @w[:mount_sitem].text.strip,
      "summon_verb" => @w[:mount_sverb].text.strip,
      "has_charge"    => @w[:mount_charge].active?,
      "charge_when"   => MOUNT_CHARGE_WHEN_OPTS[@w[:mount_charge_when]&.active.to_i] || "aoe",
      "has_trample"   => @w[:mount_trample].active?,
      "trample_when"  => MOUNT_TRAMPLE_WHEN_OPTS[@w[:mount_trample_when]&.active.to_i] || "aoe" }
  end

  def self.collect_spells
    # Reads the rich spell rotation combo pairs (same format as weapon rotation entries).
    collect_spell_rot = lambda do |combos_arr|
      (combos_arr || []).filter_map do |_items_arr, combo, spell_combo|
        key = combo.active_id.to_s
        next nil if key.empty? || key == "skip"
        case key
        when "spell"
          cmd = spell_combo&.active_id.to_s.strip
          next nil if cmd.empty?
          {"type" => "spell", "cmd" => cmd}
        when "mount_charge"  then {"type" => "mount_charge"}
        when "mount_trample" then {"type" => "mount_trample"}
        when /\Avissi:(\w+):(.+)/
          {"type" => "vissi", "key" => "#{$1}:#{$2}", "arcarium" => $1, "name" => $2}
        when /\Atrinket:(\w+):(.+)/
          {"type" => "trinket", "key" => "#{$1}:#{$2}", "slot" => $1, "ability_key" => $2}
        when /\Agemstone:(\d+)/
          {"type" => "gemstone", "slot_num" => $1.to_i}
        when /\Ascript_wpn:(.+)/ then {"type" => "script_wpn", "key" => $1}
        when /\Ascript_arm:(.+)/ then {"type" => "script_arm", "key" => $1}
        else nil
        end
      end
    end

    checked_nums  = (@known_spell_checks || {}).select { |_, h| h[:cb].active? }.keys
    bard_def_nums = (@w[:bard_def_songs]  || {}).select { |_, cb| cb.active? }.keys
    bard_util_nums= (@w[:bard_util_songs] || {}).select { |_, cb| cb.active? }.keys
    bard_cyc_nums = (@w[:bard_cyc_songs]  || {}).select { |_, cb| cb.active? }.keys
    all_maintain  = (checked_nums + bard_def_nums + bard_util_nums + bard_cyc_nums).uniq
    spell_names   = (@known_spell_checks || {}).transform_values { |h| h[:spell][:name] }
    song_names    = (BARD_DEFENSIVE_SONGS + BARD_UTILITY_SONGS + BARD_CYCLIC_SONGS).map { |s| [s[:num], s[:name]] }.to_h
    all_names     = song_names.merge(spell_names)
    { "rotation"     => collect_spell_rot.call(@spell_rot_combos_st),
      "aoe_rotation" => collect_spell_rot.call(@spell_rot_combos_aoe),
      "maintain"     => all_maintain.map { |n| { "num" => n, "label" => all_names[n] || "Spell #{n}" } } }
  end

  # Collect only rows where column 0 (enabled toggle) is true; data starts at column 1
  def self.collect_enabled_store(store, cols)
    return [] unless store
    rows = []
    store.each do |_m, _p, iter|
      row = { "enabled" => iter[0] == true }
      cols.each_with_index { |col, i| row[col] = iter[i + 1].to_s }
      rows << row
    end
    rows
  end

  def self.collect_arcarium(key)
    store         = @w[:"#{key}_vissi_store"]
    saved_by_name = ((@saved_config || {}).dig("arcarium", key.to_s, "vissi") || [])
                      .map { |v| [v["name"].to_s, v] }.to_h
    vissi = []
    if store
      store.each do |_, path, iter|
        name = store.get_value(iter, 1).to_s
        next if store.get_value(iter, 2).to_s.strip == "(passive)"
        saved = saved_by_name[name] || {}
        entry = {
          "enabled"       => store.get_value(iter, 0) == true,
          "name"          => name,
          "verb"          => store.get_value(iter, 2).to_s,
          "when"          => store.get_value(iter, 3).to_s,
          "daily_limit"   => store.get_value(iter, 4).to_i,
          "cooldown_secs" => store.get_value(iter, 5).to_i,
        }
        saved.each { |k, v| entry[k] ||= v }
        vissi << entry
      end
    end
    {
      "enabled" => @w[:"#{key}_enabled"]&.active? || false,
      "noun"    => @w[:"#{key}_noun"]&.text&.strip || "#{key} arcarium",
      "vissi"   => vissi,
    }
  end

  def self.save_profile(profile)
    char     = profile.dig("character", "name") || (XMLData.name rescue "unknown")
    FileUtils.mkdir_p(PROFILE_DIR)
    filename = File.join(PROFILE_DIR, "#{char.downcase}.yaml")
    File.write(filename, profile.to_yaml)
    respond "[setup] Profile saved to: #{filename}"
    respond "[setup] Run ;gshunting4all to start hunting."
    respond "[setup] Run ;gshunting4all setup to update settings any time."
  end
end

# ===========================================================================
# HUNTING ENGINE
# ===========================================================================
module Engine
  @profile = {}

  def self.load_profile
    name = XMLData.name rescue nil
    if name.nil? || name.empty?
      echo "[gsh4a] ERROR: Could not read character name. Are you logged in?"
      exit
    end
    path = File.join(PROFILE_DIR, "#{name.downcase}.yaml")
    unless File.exist?(path)
      echo "[gsh4a] No profile found for #{name}."
      echo "[gsh4a] Run ;gshunting4all setup to create one."
      exit
    end
    @profile = YAML.load_file(path)
    @_priority_patterns = nil  # clear cache so new profile patterns take effect
    migrate_profile(path)
    echo "[gsh4a] Profile loaded for #{name} (#{prof} #{race}, level #{level})."
  end

  # Applies one-time forward migrations to profiles saved by older script versions.
  # Rewrites the profile file in place so the fix persists across restarts.
  def self.migrate_profile(path)
    changed = false

    # v1.4.3: arcarium vissi with when: CC'd -> low_health
    # Arcarium requires physical movement and cannot fire while stunned/webbed/bound.
    # CC'd on any arcarium vissi was always wrong; low_health is the correct trigger.
    %w[aversaris vangaris].each do |key|
      Array(@profile.dig("arcarium", key, "vissi")).each do |v|
        next unless v.is_a?(Hash) && v["when"].to_s == "CC'd"
        v["when"] = "low_health"
        changed = true
        log "Migrated #{key} vissi '#{v['name']}': when CC'd -> low_health (arcarium cannot fire while immobilized)"
      end
    end

    # v1.5.0: CC'd and low_health removed from when dropdowns -- move entries to emergency_priorities.
    # Arcarium vissi with when: low_health -> emergency_priorities.low_health, set when: skip.
    # Arcarium vissi with when: CC'd (shouldn't exist after 1.4.3 but guard anyway) -> emergency_priorities.cc.
    # Trinket abilities with when: CC'd -> emergency_priorities.cc, set when: skip.
    ep = (@profile["emergency_priorities"] ||= {"low_health" => [], "cc" => []})
    ep["low_health"] ||= []
    ep["cc"]         ||= []

    %w[aversaris vangaris].each do |arc_key|
      Array(@profile.dig("arcarium", arc_key, "vissi")).each do |v|
        next unless v.is_a?(Hash)
        target_list = case v["when"].to_s
                      when "low_health"          then ep["low_health"]
                      when "CC'd", "emergency"   then ep["cc"]
                      else nil
                      end
        next unless target_list
        entry = {"type" => "vissi", "arcarium" => arc_key, "name" => v["name"].to_s}
        unless target_list.any? { |e| e["type"] == "vissi" && e["arcarium"] == arc_key && e["name"] == v["name"].to_s }
          target_list << entry
          log "Migrated arcarium #{arc_key} '#{v['name']}' (when: #{v['when']}) -> emergency_priorities.#{target_list.equal?(ep['low_health']) ? 'low_health' : 'cc'}"
        end
        v["when"] = ""
        changed = true
      end
    end

    # v1.x: Symbol of Restoration moved to Low Health Priority only -- remove from on_demand
    if @profile.dig("society", "on_demand").is_a?(Array)
      before = @profile["society"]["on_demand"].length
      @profile["society"]["on_demand"].reject! { |e| e.is_a?(Hash) && e["name"] == "Symbol of Restoration" }
      if @profile["society"]["on_demand"].length < before
        changed = true
        log "Migrated: removed Symbol of Restoration from society.on_demand (now fires via Low Health Priority only)"
      end
    end

    # v1.7.4+: Offensive society abilities moved to Attack Rotation -- strip from on_demand
    moved_to_rotation = %w[
      Symbol\ of\ Holiness Symbol\ of\ Sleep Symbol\ of\ Turning
      Sigil\ of\ Minor\ Bane Sigil\ of\ Major\ Bane Sigil\ of\ Intimidation
      Sign\ of\ Madness
    ]
    if @profile.dig("society", "on_demand").is_a?(Array)
      before = @profile["society"]["on_demand"].length
      @profile["society"]["on_demand"].reject! { |e| e.is_a?(Hash) && moved_to_rotation.include?(e["name"].to_s) }
      if @profile["society"]["on_demand"].length < before
        changed = true
        log "Migrated: removed offensive society abilities from society.on_demand (now slottable in Attack Rotation)"
      end
    end

    # Convert "skip" When values to "" (blank) -- "skip" no longer shown in UI.
    %w[aversaris vangaris].each do |arc_key|
      Array(@profile.dig("arcarium", arc_key, "vissi")).each do |v|
        next unless v.is_a?(Hash) && v["when"].to_s == "skip"
        v["when"] = ""
        changed = true
      end
    end

    # Drop "engagement" When option -- migrate all saved when: "engagement" to "aoe".
    engagement_targets = []
    %w[aversaris vangaris].each do |arc_key|
      Array(@profile.dig("arcarium", arc_key, "vissi")).each do |v|
        next unless v.is_a?(Hash) && v["when"].to_s == "engagement"
        v["when"] = ""
        engagement_targets << "arcarium #{arc_key} '#{v['name']}'"
        changed = true
      end
    end
    TRINKET_KEYS.each do |tk|
      ((@profile.dig("trinkets", tk) || {})["abilities"] || {}).each do |ab_key, ab_cfg|
        next unless ab_cfg.is_a?(Hash) && ab_cfg["when"].to_s == "engagement"
        ab_cfg["when"] = ""
        engagement_targets << "trinket #{tk}[#{ab_key}]"
        changed = true
      end
    end
    Array(@profile["scripts"]).each do |s|
      next unless s.is_a?(Hash) && s["when"].to_s == "engagement"
      s["when"] = ""
      engagement_targets << "script '#{s['name']}'"
      changed = true
    end
    unless engagement_targets.empty?
      log "Migrated when: engagement -> blank (disabled) for: #{engagement_targets.join(', ')}"
    end

    # Strip bogus technique/shield/armor spec entries that leaked in from eloot or room
    # descriptions running concurrently during setup (fixed in v1.8.2 parser).
    bogus_verb = /you |also |see |a packing|[\.!?]/i
    bogus_name = /\A(the |a |an |some |gold |silver |black |white |red |blue |green |ora |veil |glaes |mithril )/i
    %w[techniques shield_specs armor_specs].each do |key|
      next unless @profile[key].is_a?(Array)
      before = @profile[key].length
      @profile[key].reject! do |e|
        next false unless e.is_a?(Hash)
        verb = e["verb"].to_s
        name = e["name"].to_s
        verb =~ bogus_verb || name =~ bogus_name
      end
      if @profile[key].length < before
        changed = true
        log "Migrated: removed #{before - @profile[key].length} bogus #{key} entries (eloot bleed-through from setup)"
      end
    end

    # v1.8.7: CMAN verb prefix was "CM" instead of "CMAN" -- fix all saved cmans
    Array(@profile["cmans"]).each do |c|
      next unless c.is_a?(Hash) && c["verb"].to_s =~ /\ACM\s+/i && c["verb"].to_s !~ /\ACMAN\s+/i
      c["verb"] = "CMAN #{c['verb'].sub(/\ACM\s+/i, '')}"
      changed = true
      log "Migrated cman '#{c['name']}' verb: CM -> CMAN"
    end

    if changed
      File.write(path, @profile.to_yaml)
      log "Profile auto-migrated and saved."
    end
  end

  def self.prof  = @profile.dig("character", "profession") || "Unknown"
  def self.race  = @profile.dig("character", "race")       || "Unknown"
  def self.level = @profile.dig("character", "level")      || 0
  def self.pref(key) = @profile.dig("hunting", key)

  # Bards SING their own circle (1001-1040); all other circles use INCANT even for Bards.
  def self.spell_verb(num = 0)
    prof =~ /Bard/i && num.to_i.between?(1001, 1040) ? "sing" : "incant"
  end

  def self.log(msg)  = respond("[gsh4a] #{msg}")
  def self.warn(msg) = respond("[WARN gsh4a] #{msg}")

  # ---------------------------------------------------------------------------
  # Helpers
  # ---------------------------------------------------------------------------
  def self.stamina_ok?(cost)
    checkstamina >= (cost.to_i + pref("stamina_min_reserve").to_i)
  end

  def self.mana_ok?(cost)
    checkmana >= (cost.to_i + pref("mana_min_reserve").to_i)
  end

  def self.rt_ok?
    checkrt < 6
  end

  # Returns true when a debuff is preventing spellcasting.
  # Add new debuff strings here as they are confirmed.
  # @return [Boolean]
  def self.casting_blocked?
    debuffs = Effects::Debuffs rescue nil
    return false unless debuffs
    debuffs.active?("Mystic Impedance") ||
      debuffs.active?("Silenced")
  rescue
    false
  end

  # Returns true when a debuff is preventing physical movement.
  # Blocks movement-requiring techniques (Thrash, Whirlwind, Mount Charge).
  # @return [Boolean]
  def self.movement_blocked?
    debuffs = Effects::Debuffs rescue nil
    return false unless debuffs
    debuffs.active?("Crippled - Right Limb") ||
      debuffs.active?("Crippled - Left Limb") ||
      debuffs.active?("Rooted")
  rescue
    false
  end

  # Returns true when the Sympathy debuff is active (charmed by a vampire --
  # character cannot attack and will defend the charmed target).
  # @return [Boolean]
  def self.sympathy_active?
    (Effects::Debuffs.active?("Sympathy") rescue false)
  end

  # Returns true when the Feeble debuff is active (evasion/block/parry halved).
  # @return [Boolean]
  def self.feeble_active?
    (Effects::Debuffs.active?("Feeble") rescue false)
  end

  # Returns true when the Overexerted debuff is active (stamina depleted).
  # @return [Boolean]
  def self.overexerted?
    (Effects::Debuffs.active?("Overexerted") rescue false)
  end

  # Casts Rejuvenation (1607) when HP is low, spell is known, not on 5-min cooldown,
  # and not casting-blocked. Fires before low_health abilities so HP is restored first.
  # @return [Boolean] true if cast was attempted
  def self.check_rejuvenation
    return false unless (Spell[1607].known? rescue false)
    return false if casting_blocked?
    return false unless mana_ok?(7)
    return false unless GSH4AState.cd_ready?("pal_1607_rejuv")
    log "Low health -- casting Rejuvenation (1607)"
    fput "incant 1607"
    waitcastrt?
    GSH4AState.set_cd("pal_1607_rejuv", 300)
    true
  rescue => e
    warn "check_rejuvenation error: #{e.message}"
    false
  end

  # Casts Wall of Force (140) if the Feeble debuff is active, opt-in is enabled,
  # spell is known, not already active, and not casting-blocked.
  # @return [void]
  def self.check_wof_feeble
    return unless (@profile.dig("paladin_spells", "wof_feeble_enabled") rescue false)
    return unless feeble_active?
    return if casting_blocked?
    return unless (Spell[140].known? rescue false)
    return if (Spell[140].active? rescue false)
    return unless mana_ok?(15)
    log "Feeble detected -- casting Wall of Force (140)"
    fput "incant 140"
    waitrt?
  rescue => e
    warn "check_wof_feeble error: #{e.message}"
  end

  # Sends a command and backs off if the game signals rejection.
  # Matches a short list of rejection phrases plus any caller-supplied hints.
  # On rejection, sets a cooldown of backoff_secs on cd_key and returns false.
  #
  # @param cmd [String] the command string to send to the game
  # @param cd_key [String, Symbol] cooldown key set on rejection
  # @param backoff_secs [Numeric] cooldown duration in seconds when rejected
  # @param success_hints [Array<String>] additional match strings (checked against REJECT_PATTERN too)
  # @return [Boolean] false if the command was rejected, true otherwise
  def self.fput_guarded(cmd, cd_key, backoff_secs, success_hints = [])
    fput cmd
    all_hints = Array(success_hints) + ["recently", "cannot", "not yet", "too soon",
                                        "does not respond", "no effect",
                                        "Roundtime", "roundtime"]
    result = matchtimeout(3, *all_hints)
    if result && result =~ REJECT_PATTERN
      warn "#{cmd} rejected (#{result.strip}) -- backing off #{backoff_secs}s"
      GSH4AState.set_cd(cd_key, backoff_secs)
      return false
    end
    true
  end

  # ---------------------------------------------------------------------------
  # NPC helpers
  # ---------------------------------------------------------------------------
  # Returns the combined list of NPC name/noun patterns to skip attacking.
  # Merges the built-in SAFE_NPC_PATTERN with any user-defined entries from the profile.
  #
  # @return [Array<Regexp>] patterns matching NPCs that must not be attacked
  def self.safe_npc_patterns
    user_safe = (pref("safe_npcs") || []).filter_map do |entry|
      Regexp.new(Regexp.escape(entry.strip), Regexp::IGNORECASE) rescue nil
    end
    [SAFE_NPC_PATTERN] + user_safe
  end

  # Returns true when at least one gigas is alive in the room and avoid_gigas is enabled.
  # Used to suppress AoE attacks that would break gigas peace.
  #
  # @return [Boolean] true when a living gigas is present and avoidance is on
  def self.gigas_present?
    return false unless pref("avoid_gigas")
    (GameObj.npcs || []).any? do |n|
      n.status !~ /dead|gone|decaying/i &&
        (n.noun =~ GIGAS_PATTERN || n.name =~ GIGAS_PATTERN)
    end
  end

  # Returns the list of living hostile NPCs in the room that are valid attack targets.
  # Filters by safe-NPC patterns, gigas avoidance, and the game's own hostile flag.
  #
  # @return [Array<GameObj>] attackable hostile NPCs
  def self.hostile_npcs
    safe    = safe_npc_patterns
    avoid_g = pref("avoid_gigas")
    filter = ->(n) {
      n.status !~ /dead|gone|decaying/i &&
        safe.none? { |pat| n.noun =~ pat || n.name =~ pat } &&
        !(avoid_g && (n.noun =~ GIGAS_PATTERN || n.name =~ GIGAS_PATTERN))
    }
    # Game-confirmed hostile targets, cross-referenced to current-room NPCs to
    # drop stale entries from previous rooms (targets list doesn't clear
    # instantly on room transitions).
    room_npc_ids = (GameObj.npcs || []).map(&:id).to_set
    from_targets = (GameObj.targets || []).select { |n| room_npc_ids.include?(n.id) && filter.call(n) }
    # Boss-listed creatures present in the room are always included, regardless
    # of GameObj.targets state -- bosses that open with AOE/MDR never get a
    # <target> XML tag and would otherwise be invisible to the combat loop.
    # Town NPCs not on the boss list are never pulled in by this path.
    from_boss = (GameObj.npcs || []).select { |n| filter.call(n) && boss_target?(n.id) }
    (from_targets + from_boss).uniq(&:id)
  end

  def self.npc_count = hostile_npcs.length

  def self.boss_target?(id)
    return false unless id
    npc = GameObj[id] rescue nil
    return false unless npc
    name = npc.name.to_s.downcase
    return true if pref("empress_first") && name.include?("empress")
    return true if pref("emperor_first") && name.include?("emperor")
    return true if pref("miniboss_mode") && MINIBOSS_NAMES.any? { |b| name.include?(b) }
    bosses = Array(pref("boss_list")).map(&:strip).reject(&:empty?)
    bosses.any? { |b| name.include?(b.downcase) }
  rescue; false; end

  def self.target_alive?(npc)
    return false unless npc
    obj = GameObj[npc.id] rescue nil
    return false unless obj
    obj.status !~ /dead|gone|decaying/i
  rescue
    false
  end

  def self.priority_patterns
    @_priority_patterns ||= begin
      (pref("priority_creatures") || []).map { |p| Regexp.new(Regexp.escape(p.strip), Regexp::IGNORECASE) rescue nil }.compact
    end
  end

  def self.priority_npc?(npc)
    pats = priority_patterns
    return false if pats.empty?
    pats.any? { |pat| npc.noun =~ pat || npc.name =~ pat }
  end

  def self.priority_npcs
    hostile_npcs.select { |n| priority_npc?(n) }
  end

  def self.select_target
    npcs = hostile_npcs
    return nil if npcs.empty?
    # Boss list takes top priority -- named checkboxes (empress/emperor) break ties when both are present
    boss_npcs = npcs.select { |n| boss_target?(n.id) }
    if boss_npcs.size > 1
      if pref("empress_first")
        pri = boss_npcs.find { |n| (GameObj[n.id] rescue n)&.name.to_s.downcase.include?("empress") }
        return pri if pri
      end
      if pref("emperor_first")
        pri = boss_npcs.find { |n| (GameObj[n.id] rescue n)&.name.to_s.downcase.include?("emperor") }
        return pri if pri
      end
    end
    return boss_npcs.first unless boss_npcs.empty?
    # User-defined priority creatures next
    pri = priority_npcs
    return pri.first unless pri.empty?
    case pref("npc_priority") || "caster_first"
    when "caster_first"
      npcs.find { |n| CASTER_NOUNS.any? { |c| n.noun =~ /#{c}/i } } || npcs.first
    when "lowest_hp"
      npcs.min_by { |n| n.status.to_s =~ /bleeding|injured/ ? 0 : 1 } || npcs.first
    else
      # "first_available" and "priority_list" both fall back to first available
      # when no priority creatures are present (priority_npcs already handled above)
      npcs.first
    end
  end

  def self.dead_player_present?
    (GameObj.pcs || []).any? do |pc|
      next false if pc.name =~ /#{Regexp.escape(checkname)}/i
      pc.status.to_s =~ /dead/i
    end
  rescue
    false
  end

  def self.refresh_group_members
    lines = []
    hook  = "gsh4a_group_detect"
    DownstreamHook.add(hook, proc { |l|
      lines << l.gsub(/<[^>]+>/, "").strip
      l
    })
    fput "group"
    sleep 0.5
    DownstreamHook.remove(hook) rescue nil
    out = lines.join("\n")

    members = []
    out.each_line do |line|
      line = line.strip
      if line =~ /grouped with (.+)/i
        raw = $1.gsub(/\.\s*$/, "")
              .gsub(/\s+who is leading\.?/i, "")
              .gsub(/\s+and is leading\.?/i, "")
              .gsub(/\s+who is hid(?:ing|den)\.?/i, "")
        raw.split(/,\s*|\s+and\s+/).each do |part|
          name = pc_first_name(part.strip)
          members << name unless name.empty?
        end
      elsif line =~ /^(.+?) (?:is|are) (?:also )?in your group/i
        name = pc_first_name($1.strip)
        members << name unless name.empty?
      end
    end
    members.uniq!
    @group_members_cache = members
    log "Group members cache: #{members.empty? ? 'none (solo)' : members.join(', ')}"
  rescue => e
    warn "refresh_group_members error: #{e.message}"
  ensure
    DownstreamHook.remove("gsh4a_group_detect") rescue nil
  end

  # Extract the character's first name from a GameObj pc name.
  # GemStone titles always precede the name ("Noble Opalina", "Jurist of Claw Citan")
  # so the real name is normally the last word -- but hidden players append " who is hiding",
  # so strip that suffix first.
  def self.pc_first_name(full_name)
    cleaned = full_name.to_s.strip.gsub(/\s+who\s+is\s+hid(?:ing|den)\s*$/i, "")
    cleaned.split(/\s+/).last.to_s.gsub(/[^A-Za-z]/, "")
  end

  def self.in_my_group?(pc_full_name)
    name = pc_first_name(pc_full_name).downcase
    return true if name.empty?
    my_name = (checkname rescue "").downcase
    return true if name == my_name
    xml_members = (XMLData.group_members rescue []) || []
    cached      = @group_members_cache || []
    all = (xml_members + cached).map { |m| pc_first_name(m).downcase }.reject(&:empty?)
    all.include?(name)
  end

  # Returns true when an UNKNOWN hidden player is in the room.
  # GS4 renders hiding players as loot-category objects ("obvious signs of someone hiding").
  # If all named players visible in GameObj.pcs are group members (or self), any hider must
  # also be a group member -- no unknown hider is present regardless of sign count.
  def self.hidden_player_present?
    signs = (GameObj.loot || []).count { |obj| obj.name.to_s =~ /\bsigns?\b.*\bhiding\b/i }
    return false if signs == 0
    my_name = (checkname rescue "").downcase
    all_named_are_group = (GameObj.pcs || []).all? { |pc|
      pc.name.to_s.downcase =~ /\b#{Regexp.escape(my_name)}\b/ || in_my_group?(pc.name)
    }
    !all_named_are_group
  rescue
    false
  end

  # Returns true if no non-grouped or hidden players are in the room.
  # Dead/unconscious PCs are ignored -- a corpse in the room should not block attacks.
  def self.room_clear?
    return false if hidden_player_present?
    pcs = GameObj.pcs rescue []
    (pcs || []).each do |pc|
      next if pc.name =~ /#{Regexp.escape(checkname)}/i
      next if in_my_group?(pc.name)
      next if pc.status =~ /dead|unconscious/i rescue false
      return false
    end
    true
  rescue
    true
  end

  # ---------------------------------------------------------------------------
  # Stance
  # ---------------------------------------------------------------------------
  def self.stance_guarded
    return if (checkstance =~ /guarded/i rescue false)
    fput "stance guarded"
  end

  # Force a specific stance by name. Used internally; also used for bolt spells
  # which must always fire from offensive stance regardless of resting preference.
  def self.set_stance(which)
    return if (checkstance.to_s =~ /#{which}/i rescue false)
    fput "stance #{which}"
  end

  # Go offensive before attacking. Always offensive -- that is where AS lives.
  # Skipped only when stance management is fully disabled ("none").
  def self.stance_offensive
    return if (@profile.dig("hunting", "stance_preference") || "offensive").to_s.downcase == "none"
    return if (checkstance =~ /offensive/i rescue false)
    fput "stance offensive"
  end

  # After an attack lands, restore to the player's configured resting stance.
  # If resting stance is "offensive" this is a no-op -- they never leave.
  # If resting stance is "guarded" or "defensive" this is what makes stance dancing work.
  def self.stance_restore
    pref = (@profile.dig("hunting", "stance_preference") || "offensive").to_s.downcase
    return if pref == "none" || pref == "offensive"
    return if (checkstance.to_s =~ /#{pref}/i rescue false)
    fput "stance #{pref}"
  end

  # ---------------------------------------------------------------------------
  # Stand / prone
  # ---------------------------------------------------------------------------

  # Normal stand -- waits for RT first (safe for the main attack loop).
  # Returns false if a movement debuff is blocking the stand attempt.
  def self.stand_if_prone
    return true if standing?
    return false if dead?
    return false if !GSH4AState.cd_ready?(:cant_stand)
    log "Prone -- standing up"
    waitrt?
    fput "stand"
    pause 0.5
    true
  end

  # Emergency stand -- fires STAND immediately without waiting for RT.
  # Used when stunned/webbed/bound so we try to get up the instant we can,
  # even if the game rejects it (it will re-fire next monitor cycle).
  def self.emergency_stand
    return if standing?
    return if dead?
    log "Emergency: attempting to stand (prone/kneeling)"
    fput "stand"
    pause 0.3
  end

  # ---------------------------------------------------------------------------
  # Mount
  # ---------------------------------------------------------------------------
  def self.mount_cfg = @profile["mount"] || {}
  def self.has_mount? = mount_cfg["enabled"]

  def self.already_riding?
    # XMLData.riding is populated in Lich 5 when mounted
    r = XMLData.riding rescue nil
    return true if r && !r.to_s.strip.empty?
    # Fall back to checking Char status for riding indicator
    begin
      return true if (Char.riding rescue nil)
    rescue; end
    false
  end

  def self.sync_mount_state
    # Set to true if we can positively confirm riding; never force false from here
    # (dismount events handle clearing GSH4AState.mounted via the dismount watcher).
    GSH4AState.mounted = true if already_riding?
  end

  def self.remount
    return if GSH4AState.mounted
    stand_if_prone
    return unless standing?
    noun = mount_cfg["noun"] || "mount"
    log "Mounting #{noun}"
    result = dothistimeout("mount #{noun}", 5, /spring|settle|climb|already riding|cannot|can't|unable/i)
    GSH4AState.mounted = !!(result =~ /spring|settle|climb|already riding/i)
    pause 0.5
  end

  def self.summon_mount
    noun = mount_cfg["noun"] || "mount"

    # Already riding -- nothing to do
    if already_riding?
      log "Already riding #{noun} -- skipping summon"
      GSH4AState.mount_summoned = true
      GSH4AState.mounted        = true
      @mount_fail_count         = 0
      return
    end

    return if GSH4AState.mount_summoned && GSH4AState.mounted

    verb = mount_cfg["summon_verb"] || "wave"
    item = mount_cfg["summon_item"] || "reins"

    # Mount already in room (dismounted but present)
    if (GameObj.npcs || []).any? { |n| n.noun =~ /#{Regexp.escape(noun)}/i }
      GSH4AState.mount_summoned = true
      remount unless GSH4AState.mounted
      return
    end

    log "Summoning #{noun}"
    # Capture the game's response during fput -- the arrival message comes before the
    # prompt that fput waits on, so matchtimeout would always miss it.
    summon_result = nil
    hook = "gsh4a_summon_tmp"
    DownstreamHook.add(hook, proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      summon_result ||= clean if clean =~ /arrives|already here|What were you|cannot|inside/i
      line
    })
    fput "#{verb} my #{item}"
    DownstreamHook.remove(hook) rescue nil
    result = summon_result
    # "What were you referring to?" means item not in hand -- mount likely already present
    already = result =~ /arrives|already here|What were you/i
    GSH4AState.mount_summoned = !!already
    unless GSH4AState.mount_summoned
      @mount_fail_count = (@mount_fail_count || 0) + 1
      log "Summon failed (#{result&.strip || 'timeout'}) -- attempt #{@mount_fail_count}"
      if @mount_fail_count >= 3
        warn "Mount failed 3 times -- disabling mount for this session. Fix your mount and re-run setup."
        GSH4AState.instance_variable_set(:@mount_enabled, false)
        @profile["mount"] ||= {}
        @profile["mount"]["enabled"] = false
        return
      end
    else
      @mount_fail_count = 0
    end
    pause 1
    remount if GSH4AState.mount_summoned
  end

  def self.ensure_mounted
    return unless has_mount?
    sync_mount_state
    return if GSH4AState.mounted
    GSH4AState.mount_summoned ? remount : summon_mount
  end

  # Attempts a mounted charge attack against target_id.
  # No-ops when unmounted, on cooldown, low stamina, or in roundtime.
  #
  # @param target_id [String, Integer] the game object ID of the attack target
  # @return [Boolean] true if the charge was executed, false otherwise
  def self.mount_charge(target_id)
    return false unless has_mount? && mount_cfg["has_charge"]
    return false if movement_blocked?
    sync_mount_state
    return false unless GSH4AState.mounted
    return false unless GSH4AState.cd_ready?(:mount_charge)
    return false unless stamina_ok?(15)
    return false unless rt_ok?
    case mount_cfg["charge_when"].to_s
    when "aoe"               then return false unless aoe_needed?
    when "swarm"             then return false unless !gigas_present? && npc_count >= (pref("swarm_threshold") || SWARM_THRESHOLD_DEFAULT).to_i
    when "target_vulnerable" then return false unless target_vulnerable?(target_id)
    end
    log "Mount Charge"
    waitrt?; waitcastrt?
    stance_offensive
    fput "mount charge ##{target_id}"
    waitrt?
    GSH4AState.set_cd(:mount_charge, 60)
    true
  end

  # Attempts a mounted trample AoE attack against all room targets.
  # No-ops when unmounted, gigas are present, below aoe_threshold, on cooldown,
  # low stamina, or in roundtime.
  #
  # @return [Boolean] true if the trample was executed, false otherwise
  def self.mount_trample
    return false unless has_mount? && mount_cfg["has_trample"]
    sync_mount_state
    return false unless GSH4AState.mounted
    return false if gigas_present?
    case mount_cfg["trample_when"].to_s
    when "aoe"   then return false unless npc_count >= pref("aoe_threshold").to_i
    when "swarm" then return false unless npc_count >= (pref("swarm_threshold") || SWARM_THRESHOLD_DEFAULT).to_i
    end
    return false unless GSH4AState.cd_ready?(:mount_trample)
    return false unless stamina_ok?(15)
    return false unless rt_ok?
    log "Mount Trample (#{npc_count} targets)"
    waitrt?; waitcastrt?
    stance_offensive
    fput "mount trample"
    waitrt?
    GSH4AState.set_cd(:mount_trample, 60)
    true
  end

  # ---------------------------------------------------------------------------
  # Arcarium vissi activation (per-vissi, respects when/daily_limit/cooldown)
  # ---------------------------------------------------------------------------
  VULNERABLE_STATUS = /sleeping|webbed|stunned|kneeling|sitting|lying|prone|frozen|held in place|entangled|rooted/i

  def self.target_vulnerable?(target_id)
    return false unless target_id
    npc = (GameObj.npcs || []).find { |n| n.id.to_s == target_id.to_s }
    npc && npc.status.to_s =~ VULNERABLE_STATUS
  rescue
    false
  end

  # Fires a single arcarium vissi by its config hash.
  # Caller is responsible for when/moment matching; this handles CD/daily checks and the actual fput.
  # Returns true if the vissi fired (including after silver-check failure, which sets a 5m CD).
  # @param arc_key [String] "aversaris" or "vangaris"
  # @param v [Hash] the vissi config hash from profile
  # @return [Boolean]
  def self.fire_single_vissi(arc_key, v)
    return false unless v.is_a?(Hash) && v["enabled"]
    verb = v["verb"].to_s.strip
    return false if verb.empty?
    dl_key = "arcarium_#{arc_key}_#{v['name'].downcase.gsub(/\s+/, '_')}"
    dl = v["daily_limit"].to_i
    cd = v["cooldown_secs"].to_i
    if dl > 0 && !GSH4AState.daily_ok?(dl_key, dl)
      log "#{v['name']} daily limit reached (#{dl}/day) -- skipping"
      return false
    end
    return false if cd > 0 && !GSH4AState.cd_ready?(dl_key)
    log "Arcarium vissi: #{v['name']} (#{verb})"
    waitrt?
    waitcastrt?
    arc_response = nil
    arc_hook = "gsh4a_arc_tmp"
    DownstreamHook.add(arc_hook, proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      arc_response ||= clean if clean =~ /not enough silver|cannot|no longer|already active|whispers in your mind/i
      line
    })
    fput verb
    DownstreamHook.remove(arc_hook) rescue nil
    waitcastrt?
    pause 0.3
    if arc_response =~ /not enough silver/i
      log "#{v['name']} skipped -- not enough silver (cooling down 5 min)"
      GSH4AState.set_cd(dl_key, 300)
      return false
    end
    GSH4AState.use_daily(dl_key) if dl > 0
    GSH4AState.set_cd(dl_key, cd) if cd > 0
    true
  rescue => e
    warn "fire_single_vissi error: #{e.message}"
    false
  end

  def self.activate_arcarium(key, noun, moment, target_id = nil)
    cfg = @profile.dig("arcarium", key) || {}
    return false unless cfg["enabled"]
    Array(cfg["vissi"]).each do |v|
      next unless v["enabled"]
      next if weapon_rot_has_type?("vissi", "#{key}:#{v['name']}")
      saved_v_when = v["when"].to_s == "emergency" ? "CC'd" : v["when"].to_s
      next unless saved_v_when == moment.to_s
      # Per-vissi vulnerability gate: if require_vulnerable is set, the target must
      # be vulnerable regardless of which moment is firing (engagement, aoe, swarm, etc.)
      next if v["require_vulnerable"] && !target_vulnerable?(target_id)

      if moment.to_s == "target_vulnerable"
        next unless target_vulnerable?(target_id)
        begin
          dl_key = "arcarium_#{key}_#{v['name'].downcase.gsub(/\s+/, '_')}"
          next if Effects::Cooldowns.active?(v["name"].to_s)
        rescue
          next unless GSH4AState.cd_ready?(dl_key)
        end
      end

      return true if fire_single_vissi(key, v)
    end
    false
  end

  def self.run_arcarium_moment(moment, target_id = nil)
    %i[aversaris vangaris].each do |key|
      cfg = @profile.dig("arcarium", key.to_s) || {}
      next unless cfg["enabled"]
      noun = cfg["noun"].to_s.strip
      next if noun.empty?
      return if activate_arcarium(key.to_s, noun, moment, target_id)
    end
  end

  # Looks up a trinket ability from SCRIPT_TEMPLATES bypassing the 'enabled' profile gate.
  # Used by emergency priorities to fire abilities that are disabled for normal rotation.
  # @param slot [String] trinket slot key (e.g. "battle_standard", "energy_wings")
  # @param key  [String] ability key (e.g. "beseech", "clench")
  # @return [Hash, nil] ability hash (string-keyed) or nil if not available
  def self.find_emergency_ability(slot, key)
    slot_map = {
      "battle_standard" => ["Battle Standard", :armor],
      "energy_wings"    => ["Energy Wings",    :weapon],
    }
    tmpl_key, tmpl_type = slot_map[slot]
    return nil unless tmpl_key
    cfg = @profile.dig("trinkets", slot)
    return nil unless cfg.is_a?(Hash) && cfg["enabled"]
    noun = cfg["noun"].to_s.strip
    tier = cfg["tier"].to_i
    tmpl = SCRIPT_TEMPLATES.dig(tmpl_key, tmpl_type) || []
    ab   = tmpl.find { |t| t[:key].to_s == key }
    return nil unless ab
    return nil if ab[:min_tier] && ab[:min_tier] > tier
    ab.transform_keys(&:to_s).merge(
      "verb"    => ab[:verb].to_s.gsub("#NOUN", noun),
      "cd"      => ab[:cd].to_i,
      "when"    => ab[:when].to_s,
      "_slot"   => slot,
      "_script" => tmpl_key
    )
  end

  # Fires a single emergency priority entry (vissi or trinket/script ability).
  # Stops and returns true on first successful fire.
  # @param entry [Hash] {type:, arcarium:, name:} for vissi or {type:, slot:, key:} for ability
  # @return [Boolean]
  def self.fire_priority_entry(entry)
    return false unless entry.is_a?(Hash)
    case entry["type"]
    when "vissi"
      arc_key  = entry["arcarium"].to_s
      vis_name = entry["name"].to_s
      cfg = @profile.dig("arcarium", arc_key) || {}
      return false unless cfg["enabled"]
      v = Array(cfg["vissi"]).find { |x| x["name"].to_s == vis_name }
      return false unless v
      fire_single_vissi(arc_key, v)
    when "ability"
      slot = entry["slot"].to_s
      key  = entry["key"].to_s
      # all_abilities builds with string keys (transform_keys(&:to_s)) -- use string lookup.
      # If not found (ability disabled in profile), fall back to template lookup so emergency
      # priorities can fire abilities that are disabled for normal rotation.
      ab = all_abilities.find { |a| a["_slot"].to_s == slot && a["key"].to_s == key }
      ab ||= find_emergency_ability(slot, key)
      return false unless ab
      fire_ability(ab, nil, emergency: true)
    when "builtin"
      case entry["id"].to_s
      when "rejuvenation"             then check_rejuvenation
      when "society_heal"             then check_society_restoration
      when "bloodstone_vivacity"      then check_bloodstone_vivacity
      when "bloodstone_sanguine_swap" then check_bloodstone_sanguine_swap
      else false
      end
    else
      false
    end
  rescue => e
    warn "fire_priority_entry error: #{e.message}"
    false
  end

  # Fires the first ready entry from the low_health emergency priority list.
  def self.run_low_health_priorities
    Array(@profile.dig("emergency_priorities", "low_health")).each do |entry|
      return if fire_priority_entry(entry)
    end
  end

  # Fires the first ready entry from the CC'd emergency priority list.
  def self.run_cc_priorities
    Array(@profile.dig("emergency_priorities", "cc")).each do |entry|
      return if fire_priority_entry(entry)
    end
  end

  # ---------------------------------------------------------------------------
  # Generic ability engine
  # ---------------------------------------------------------------------------
  def self.all_abilities
    @_all_abilities ||= begin
      list = []
      [
        ["primary_weapon",   @profile.dig("weapons", "primary")],
        ["secondary_weapon", @profile.dig("weapons", "secondary")],
        ["armor",            @profile["armor"]],
        ["shield",           @profile["shield"]],
      ].each do |slot_name, item_cfg|
        next unless item_cfg.is_a?(Hash)
        (item_cfg["scripts"] || []).each do |script|
          (script["abilities"] || []).each do |ab|
            next if ab["when"] == "skip"
            list << ab.merge("_slot" => slot_name, "_script" => script["name"])
          end
        end
      end

      # Energy Wings -- worn pin, manually configured in Trinkets tab
      ew = @profile.dig("trinkets", "energy_wings")
      if ew.is_a?(Hash) && ew["enabled"]
        noun     = ew["noun"].to_s.strip
        tier     = ew["tier"].to_i
        wt_sym   = ew["wing_type"].to_s.downcase.to_sym
        tmpl     = SCRIPT_TEMPLATES.dig("Energy Wings", :weapon) || []
        ab_cfg   = ew["abilities"] || {}
        tmpl.each do |ab|
          next if ab[:min_tier] && ab[:min_tier] > tier
          next if ab[:type] != :both && ab[:type] != wt_sym
          key     = ab[:key].to_s
          user_ab = ab_cfg[key] || {}
          user_enabled = user_ab.is_a?(Hash) ? user_ab.fetch("enabled", true) : true
          next unless user_enabled
          user_when = user_ab.is_a?(Hash) ? (user_ab["when"] || ab[:when]) : ab[:when]
          next if user_when == "skip"
          verb = ab[:verb].gsub("#NOUN", noun)
          list << ab.transform_keys(&:to_s).merge(
            "verb"    => verb,
            "cd"      => ab[:cd].to_i,
            "when"    => user_when,
            "_slot"   => "energy_wings",
            "_script" => "Energy Wings"
          )
        end
      end

      # Battle Standard -- Paladin wearable from spell 1620, configured in Trinkets tab
      bs = @profile.dig("trinkets", "battle_standard")
      if bs.is_a?(Hash) && bs["enabled"]
        noun     = bs["noun"].to_s.strip
        tier     = bs["tier"].to_i
        ab_cfg   = bs["abilities"] || {}
        tmpl     = SCRIPT_TEMPLATES.dig("Battle Standard", :armor) || []
        tmpl.each do |ab|
          key     = ab[:key].to_s
          user_ab = ab_cfg[key] || {}
          user_enabled = user_ab.is_a?(Hash) ? user_ab.fetch("enabled", true) : true
          next unless user_enabled
          user_when = user_ab.is_a?(Hash) ? (user_ab["when"] || ab[:when]) : (user_ab.to_s.empty? ? ab[:when] : user_ab.to_s)
          next if user_when == "skip"
          next if ab[:min_tier] && ab[:min_tier] > tier
          verb = ab[:verb].gsub("#NOUN", noun)
          list << ab.transform_keys(&:to_s).merge(
            "verb"    => verb,
            "cd"      => ab[:cd].to_i,
            "when"    => user_when,
            "_slot"   => "battle_standard",
            "_script" => "Battle Standard"
          )
        end
      end

      # Generic scripted trinkets (gloves, boots, etc.)
      [
        [:elemental_gloves, "elemental_gloves", EG_ABILITIES],
        [:twisted_gloves,   "twisted_gloves",   TG_ABILITIES],
        [:twisted_kicks,    "twisted_kicks",    TK_ABILITIES],
      ].each do |slot_sym, key, tmpl|
        cfg = @profile.dig("trinkets", key)
        next unless cfg.is_a?(Hash) && cfg["enabled"]
        noun   = cfg["noun"].to_s.strip
        tier   = cfg["tier"].to_i
        ab_cfg = cfg["abilities"] || {}
        tmpl.each do |ab|
          next if ab[:min_tier] && ab[:min_tier] > tier
          k        = ab[:key].to_s
          user_ab  = ab_cfg[k] || {}
          next unless user_ab.fetch("enabled", true)
          user_when = user_ab["when"] || ab[:when]
          next if user_when == "skip"
          verb = ab[:verb] ? ab[:verb].gsub("#NOUN", noun) : "#{ab[:key]} my #{noun}"
          list << ab.transform_keys(&:to_s).merge(
            "verb"    => verb,
            "cd"      => ab[:cd].to_i,
            "when"    => user_when,
            "_slot"   => key,
            "_script" => key.tr("_", " ").split.map(&:capitalize).join(" ")
          )
        end
      end

      # Paladin spell 1635 -- Divine Intervention: BESEECH removes status effects
      pal = @profile["paladin_spells"] || {}
      if pal["beseech_enabled"]
        list << {
          "key"       => "pal_1635_beseech",
          "verb"      => "beseech",
          "cd"        => 0,
          "mana_cost" => 0,
          "when"      => "emergency_status",
          "desc"      => "1635 Divine Intervention -- BESEECH removes stun/web/bind/poison/curse (no mana cost)",
          "_slot"  => "paladin_spells",
          "_script"=> ""
        }
      end

      # Paladin spell 1650 -- Divine Incarnation: INCARNATE abilities
      if pal["incarn_armor_emergency"]
        bless_r = (@profile.dig("lore_ranks", "Blessings") || 0).to_i
        armor_daily = 1 + (bless_r >= 50 ? 1 : 0) + (bless_r >= 125 ? 1 : 0)
        list << {
          "key"        => "pal_1650_armor_emerg",
          "verb"       => "incarnate armor",
          "cd"         => 300,
          "daily_limit"=> armor_daily,
          "when"       => "emergency",
          "desc"       => "1650 Incarnation ARMOR (emergency) -- 50% damage resist 30s, #{armor_daily}x/day",
          "_slot"      => "paladin_spells",
          "_script"    => "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_smite"]
        list << {
          "key"    => "pal_1650_smite",
          "verb"   => "incarnate smite",
          "cd"     => 0,
          "when"   => "per_attack",
          "desc"   => "1650 Incarnation SMITE -- divine bolt + plasma crit (5 DE, requires active Incarnation)",
          "_slot"  => "paladin_spells",
          "_script"=> "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_zeal"]
        list << {
          "key"    => "pal_1650_zeal",
          "verb"   => "incarnate zeal",
          "cd"     => 60,
          "when"   => "per_attack",
          "desc"   => "1650 Incarnation ZEAL -- deity flares on next 5 hits (5 DE, 60s CD)",
          "_slot"  => "paladin_spells",
          "_script"=> "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_onslaught"]
        list << {
          "key"         => "pal_1650_onslaught",
          "verb"        => "incarnate onslaught",
          "cd"          => 0,
          "when"        => "aoe",
          "min_creatures"=> 2,
          "desc"        => "1650 Incarnation ONSLAUGHT -- multi-target, ignores 50%+ stance (10 DE)",
          "_slot"       => "paladin_spells",
          "_script"     => "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_onslaught_swarm"]
        list << {
          "key"         => "pal_1650_onslaught",
          "verb"        => "incarnate onslaught",
          "cd"          => 0,
          "when"        => "swarm",
          "min_creatures"=> 2,
          "desc"        => "1650 Incarnation ONSLAUGHT -- multi-target, ignores 50%+ stance (10 DE)",
          "_slot"       => "paladin_spells",
          "_script"     => "Divine Incarnation (1650)"
        }
      end

      # Gemstone activated properties -- command is "GEM ACTIVATE <slot#>"
      (@profile.dig("gemstones", "slots") || []).each do |gs|
        next unless gs.is_a?(Hash) && gs["enabled"] && gs["activated_property"]
        slot_num = gs["slot_num"].to_i
        next unless slot_num > 0
        prop = SetupWizard::GEMSTONE_ACTIVATED_PROPS.find { |p| p[:name] == gs["activated_property"] }
        next unless prop
        list << {
          "key"          => "gem_activate_#{slot_num}",
          "verb"         => "gem activate #{slot_num}",
          "cd"           => prop[:cd].to_i,
          "when"         => prop[:when],
          "min_creatures"=> prop[:min_creatures],
          "desc"         => "#{gs['name']} -- #{prop[:name]}: #{prop[:desc]}",
          "_slot"        => "gemstone_#{slot_num}",
          "_script"      => "Gemstone"
        }
      end

      list
    end
  end

  def self.ability_key(ab)
    "#{ab['_slot']}_#{ab['key']}"
  end

  # Returns true when all guards for an ability entry pass.
  # Guards checked: cooldown, daily limit, min_creatures, health window (max/min),
  # stamina reserve, mana reserve, and optional spell_req known check.
  #
  # @param ab [Hash] ability entry (from all_abilities)
  # @param target_count [Integer] number of hostile NPCs currently in the room
  # @param health_pct [Integer] current player health percentage (0-100)
  # @return [Boolean] true when the ability may fire
  def self.ability_ready?(ab, target_count, health_pct)
    key = ability_key(ab)
    cd  = ab["cd"].to_i
    return false if cd > 0 && !GSH4AState.cd_ready?(key)
    dl = ab["daily_limit"]
    return false if dl && !GSH4AState.daily_ok?(key, dl)
    min_c = ab["min_creatures"].to_i
    return false if min_c > 0 && target_count < min_c
    max_hp = ab["max_health_pct"]
    return false if max_hp && health_pct > max_hp.to_i
    min_hp = ab["min_health_pct"]
    return false if min_hp && health_pct < min_hp.to_i
    # Stamina guard -- skip if firing would drop us below the configured reserve
    stamina_cost = ab["stamina"].to_i
    return false if stamina_cost > 0 && !stamina_ok?(stamina_cost)
    # Mana guard -- skip if firing a spell/incant would drop us below the configured reserve
    mana_cost = ab["mana_cost"].to_i
    return false if mana_cost > 0 && !mana_ok?(mana_cost)
    # If the verb involves casting, apply the general mana reserve guard too
    verb = ab["verb"].to_s
    return false if verb =~ /\b(incant|sing|cast|prep)\b/i && !mana_ok?(pref("mana_min_reserve").to_i)
    return false if verb =~ /\b(incant|sing|cast|prep)\b/i && casting_blocked?
    # Some item abilities require a specific spell to be known (e.g. Battle Standard beseech needs 1635)
    spell_req = ab["spell_req"]
    return false if spell_req && !(Spell[spell_req].known? rescue false)
    true
  end

  # Executes a single ability entry (trinket, arcarium, gemstone, or script ability).
  # Handles Paladin INCARNATE pre-cast, dead guard, cast wait, cooldown and daily
  # tracking, and optional fput_guarded rejection backoff for cooldown-tracked abilities.
  #
  # @param ab [Hash] ability entry hash (keys: verb, cd, daily_limit, _script, key, when, ...)
  # @param primary_id [String, Integer, nil] target game object ID for #TARGET substitution
  # @param emergency [Boolean] when true, bypasses the combat_injured? guard so emergency
  #   priority abilities fire even when wounds would normally halt combat actions
  # @return [Boolean] false if any guard failed or the command was rejected; true on success
  def self.fire_ability(ab, primary_id = nil, emergency: false)
    cmd = ab["verb"].dup
    cmd.gsub!("#TARGET", "##{primary_id}") if primary_id

    # INCARNATE abilities require Divine Incarnation (1650) to be active first.
    # Check Effects::Buffs for the Incarnation buff; cast 1650 if not up.
    if cmd =~ /\bincarnate\b/i && cmd !~ /armor/i
      unless incarnation_active?
        pal = @profile["paladin_spells"] || {}
        spell_1650 = (Spell[1650] rescue nil)
        if spell_1650&.known?
          log "Casting 1650 to activate Divine Incarnation before #{cmd}"
          waitrt?; waitcastrt?
          # Release any prepared spell before casting 1650 so "different spell readied" doesn't block.
          # Use bare "prepare 1650" here (not incant) so we don't accidentally cast and then
          # fire a redundant second incant at line below.
          if (checkcastrt rescue 0) == 0
            pre = dothistimeout("prepare 1650", 3, /your spell is ready|release your current|different spell|roundtime/i)
            if pre =~ /release your current|different spell/i
              fput "release"
              waitcastrt?
              fput "prepare 1650"
              waitcastrt?
            end
          end
          result = dothistimeout("cast", 5, /cast roundtime|already incarnated|hindrance|armor prevents|insufficient mana/i)
          if result =~ /already incarnated/i
            # Buff is active but Lich didn't track it -- mark it manually
            GSH4AState.incarnation_expires = Time.now + 300
          elsif result =~ /cast roundtime/i && result !~ /armor prevents|hindrance/i
            GSH4AState.incarnation_expires = Time.now + 300
          else
            log "1650 cast failed (#{result.to_s.lines.first&.strip}) -- skipping #{cmd}"
            return false
          end
          waitcastrt?
          unless incarnation_active?
            log "1650 not active after cast -- skipping #{cmd}"
            return false
          end
        else
          log "1650 not known -- cannot use #{cmd}"
          return false
        end
      end
    end

    if ab["key"] == "pal_1635_beseech"
    end
    return false if !emergency && combat_injured?
    # If the ability belongs to a running Lich script (e.g. Valence), skip if that
    # script is no longer active -- the connection/enchantment will be gone.
    script_name = ab["_script"].to_s
    if !script_name.empty? && !["Battle Standard", "Energy Wings", "Elemental Gloves",
                                 "Twisted Gloves", "Twisted Kicks"].include?(script_name)
      unless (Script.running?(script_name) rescue false)
        return false
      end
    end
    log "#{ab['_script']} #{ab['key']} (#{ab['when']})"
    waitrt?
    return false if dead?
    waitcastrt? if cmd =~ /incant|sing|cast|prep/i

    key = ability_key(ab)
    cd  = ab["cd"].to_i

    if cd > 0
      return false unless GSH4AState.cd_ready?(key)
      backoff = [[cd / 5, 60].max, 300].min
      result  = fput_guarded(cmd, key, backoff)
      return false unless result
    else
      fput cmd
    end

    if cmd =~ /incant|sing|cast|prep/i
      waitcastrt?
    else
      waitrt?
    end

    GSH4AState.set_cd(key, cd) if cd > 0
    dl = ab["daily_limit"].to_i
    GSH4AState.use_daily(key) if dl > 0
    true
  end

  def self.incarnation_active?
    return true if GSH4AState.incarnation_expires && Time.now < GSH4AState.incarnation_expires
    (Spell[1650].active? rescue false) || (Effects::Buffs.active?("Divine Incarnation") rescue false)
  rescue
    false
  end

  # Fires all ability entries whose "when" field matches trigger.
  # Skips daily-limited abilities when trigger is not "CC'd"/"emergency",
  # and skips multi-target abilities when gigas peace is active.
  #
  # @param trigger [String] the "when" value to match (e.g. "maintenance", "aoe", "CC'd")
  # @param primary_id [String, Integer, nil] passed through to fire_ability for targeting
  # @return [Boolean] true if any ability fired
  def self.run_abilities_when(trigger, primary_id = nil)
    count   = npc_count
    health  = percenthealth rescue 100
    gigas_g = gigas_present?
    fired   = false
    # Emergency triggers bypass the combat_injured? guard inside fire_ability so that
    # abilities like 1635 Beseech can fire even when the character has rank 2+ wounds.
    emg = ["emergency_status", "CC'd", "emergency", "low_health"].include?(trigger)
    _raw_selected = all_abilities.select { |ab|
      saved = ab["when"] == "emergency" ? "CC'd" : ab["when"]
      saved == trigger
    }
    _raw_selected.each do |ab|
      # Daily-limited abilities only fire on CC'd, low_health, or boss triggers
      next if ab["daily_limit"].to_i > 0 && !["CC'd", "emergency", "low_health", "boss"].include?(trigger)
      next if weapon_rot_has_type?("trinket", "#{ab['_slot']}:#{ab['key']}")
      if ab["_slot"].to_s =~ /\Agemstone_(\d+)/
        gem_sn = $1.to_i
        next if [
          Array(@profile.dig("weapons", "weapon_rotation")),
          Array(@profile.dig("weapons", "weapon_aoe_rotation"))
        ].flatten.any? { |e| e.is_a?(Hash) && e["type"] == "gemstone" && e["slot_num"].to_i == gem_sn }
      end
      # Suppress weapon/armor script abilities that are slotted in the rotation
      if ab["_slot"].to_s == "primary_weapon"
        next if weapon_rot_has_type?("script_wpn", ab["key"].to_s)
      end
      if ab["_slot"].to_s == "armor"
        next if weapon_rot_has_type?("script_arm", ab["key"].to_s)
      end
      # If gigas are present and avoid_gigas is on, skip any multi-target abilities
      next if gigas_g && ab["min_creatures"].to_i > 1
      next unless ability_ready?(ab, count, health)
      if fire_ability(ab, primary_id, emergency: emg)
        fired = true
        break
      end
    end
    fired
  end

  def self.run_toggle_startups
    all_abilities.select { |ab| ab["when"] == "toggle_startup" }.each do |ab|
      key = ability_key(ab)
      next if GSH4AState.toggle_done?(key)
      log "Toggle ON: #{ab['_script']} #{ab['key'].upcase}"
      fput ab["verb"]
      pause 1
      GSH4AState.mark_toggle(key)
    end
  end

  # ---------------------------------------------------------------------------
  # Society
  # ---------------------------------------------------------------------------
  def self.society_cfg = @profile["society"] || {}

  def self.society_symbol_active?(entry)
    sid = entry["spell_id"]
    if sid
      begin
        return true if (Spell[sid.to_i].active? rescue false)
        return true if (Spell[sid.to_s].active? rescue false)
      rescue; end
    end
    buff = entry["buff"]
    return false unless buff
    begin
      Effects::Buffs.active?(buff)
    rescue
      false
    end
  end

  def self.apply_society_maintain_startup
    name = society_cfg["name"]
    return unless name
    (society_cfg["maintain"] || []).each do |entry|
      cmd = entry["cmd"]
      next unless cmd
      next if society_symbol_active?(entry)
      log "Applying #{entry['name']}"
      waitrt?
      waitcastrt?
      put cmd
      sleep 0.5
      GSH4AState.set_cd("soc_maintain_#{cmd}", 30)
    end
  end

  def self.check_society_maintain
    return if dead?
    name = society_cfg["name"]
    return unless name
    (society_cfg["maintain"] || []).each do |entry|
      cmd = entry["cmd"]
      next unless cmd
      next unless entry["buff"] || entry["spell_id"]
      next if society_symbol_active?(entry)
      next unless GSH4AState.cd_ready?("soc_maintain_#{cmd}")
      log "Reapplying #{entry['name']}"
      fput cmd
      pause 0.3
      GSH4AState.set_cd("soc_maintain_#{cmd}", 30)
    end
  end

  def self.check_society_mana
    return if dead?
    name = society_cfg["name"]
    return unless name
    mana_entry = (society_cfg["on_demand"] || []).find { |e| e["cmd"] =~ /mana/i }
    return unless mana_entry
    return unless (checkmana <= maxmana - 50 rescue false)
    return unless GSH4AState.cd_ready?("soc_mana")
    return if (Effects::Cooldowns.active?(mana_entry["name"]) rescue false)
    log "#{mana_entry['name']} -- restoring mana"
    waitrt?
    fput mana_entry["cmd"]
    pause 0.3
    GSH4AState.set_cd("soc_mana", 62)
  end

  # Fires the society healing symbol/sign when health is below the configured threshold.
  # Supports Voln (Symbol of Restoration), Sunfist (Sign of Healing), and CoL (Sign of Wracking).
  # Enforces a 300-second cooldown to prevent double-fire.
  # @return [Boolean] true if the healing ability fired, false otherwise
  def self.check_society_restoration
    return false if dead?
    name = society_cfg["name"]
    return false unless name
    restore_threshold = (pref("society_restore_pct") || 75).to_i
    return false unless (percenthealth < restore_threshold rescue false)
    return false unless GSH4AState.cd_ready?("soc_restoration")
    cmd = case name
          when "Voln"    then "symbol of restoration"
          when "Sunfist" then "sign of healing"
          when "CoL"     then "sign of wracking"
          else return false
          end
    log "#{name} heal -- #{cmd}"
    waitrt?
    fput cmd
    pause 0.3
    GSH4AState.set_cd("soc_restoration", 300)
    true
  end

  # Fires the Bloodstone Jewelry Vivacity ability (BESEECH for HP/stamina/mana).
  # Requires tier >= 3, a configured noun, and the vivacity ability enabled.
  # Cooldown is tier-dependent: T3=60 min, T4=45 min, T5=30 min.
  # @return [Boolean] true if the ability fired successfully
  def self.check_bloodstone_vivacity
    bsj = @profile.dig("trinkets", "bloodstone_jewelry")
    return false unless bsj.is_a?(Hash) && bsj["enabled"]
    return false unless bsj["tier"].to_i >= 3
    return false unless bsj.dig("abilities", "vivacity", "enabled") != false
    noun = bsj["noun"].to_s.strip
    return false if noun.empty?
    return false unless GSH4AState.cd_ready?("bloodstone_vivacity")
    target = bsj.dig("abilities", "vivacity", "target") || "HEALTH"
    log "Bloodstone Jewelry -- Vivacity BESEECH #{target}"
    waitrt?
    return false if dead?
    fput "beseech my #{noun} #{target}"
    pause 0.3
    cd = case bsj["tier"].to_i
         when 5 then 1800
         when 4 then 2700
         else        3600
         end
    GSH4AState.set_cd("bloodstone_vivacity", cd)
    true
  rescue => e
    warn "check_bloodstone_vivacity error: #{e.message}"
    false
  end

  # Fires the Bloodstone Jewelry Sanguine Swap ability (SPIN to store wounds for 10 min).
  # Requires tier >= 4 and the sanguine_swap ability enabled. CD: 30 min.
  # WARNING: wounds reappear after 10 minutes and can stack with new wounds.
  # @return [Boolean] true if the ability fired successfully
  def self.check_bloodstone_sanguine_swap
    bsj = @profile.dig("trinkets", "bloodstone_jewelry")
    return false unless bsj.is_a?(Hash) && bsj["enabled"]
    return false unless bsj["tier"].to_i >= 4
    return false unless bsj.dig("abilities", "sanguine_swap", "enabled") != false
    noun = bsj["noun"].to_s.strip
    return false if noun.empty?
    return false unless GSH4AState.cd_ready?("bloodstone_sanguine_swap")
    log "Bloodstone Jewelry -- Sanguine Swap SPIN (wounds stored 10 min)"
    waitrt?
    return false if dead?
    fput "spin my #{noun}"
    pause 0.3
    GSH4AState.set_cd("bloodstone_sanguine_swap", 1800)
    true
  rescue => e
    warn "check_bloodstone_sanguine_swap error: #{e.message}"
    false
  end

  # Unified escape: tries each configured escape option in priority order.
  # Handles stunned deferral and stops the script when all options are exhausted.
  def self.attempt_escape(reason = "health")
    return if dead?
    GSH4AState.hunting = false

    if (stunned? rescue false) || (webbed? rescue false) || (bound? rescue false)
      # Attempt CC break before deferring -- fires 1635 Beseech for Paladins (or any
      # configured emergency_status ability); gracefully no-ops for everyone else.
      run_abilities_when("emergency_status")
      @deferred_escape = true
      return
    end

    hp = percenthealth rescue 100
    Array(pref("escape_priority")).each do |entry|
      next unless entry.is_a?(Hash) && entry["enabled"]
      if fire_escape_entry(entry, reason, hp)
        @deferred_escape = false
        return
      end
    end

    # All escape options failed. If charm (Sympathy) is active it is blocking all
    # actions -- keep deferred so the watcher thread retries every 0.3s until charm
    # clears, rather than stopping the script and abandoning the character.
    if sympathy_active?
      @deferred_escape = true
      return
    end

    @deferred_escape = false
    warn "#{reason} -- no escape option available; stopped hunting"
    stop_script "gshunting4all" rescue nil
  end

  # Fires a single escape entry. Returns true if the escape was successfully dispatched.
  def self.fire_escape_entry(entry, reason, hp)
    case entry["type"]
    when "spirit_guide"
      return false unless (Spell[130].known? rescue false)
      return false if (stunned? rescue false) || (webbed? rescue false) || (bound? rescue false)
      return false if (checkmana rescue 0) < 10
      return false if sympathy_active?
      severe = begin
        Wounds.chest >= 3 || Wounds.head >= 3 || Wounds.rightArm >= 3 || Wounds.leftArm >= 3
      rescue; false; end
      return false if severe
      log "#{reason} -- Spirit Guide (130)"
      waitrt?; fput "incant 130"; pause 1
      true
    when "society"
      return false if (stunned? rescue false) || (webbed? rescue false) || (bound? rescue false)
      return false if sympathy_active?
      return false unless GSH4AState.cd_ready?(:soc_escape)
      case society_cfg["name"]
      when "Voln"
        log "#{reason} -- Symbol of Return"
        waitrt?
        fput "symbol of return"
        pause 4  # teleport fires 1-2s after the command; wait for blur before script exits
      when "Sunfist"
        return false if (checkmana rescue 0) < 15 || (checkstamina rescue 0) < 75
        log "#{reason} -- Sigil of Escape"
        fput "sigil of escape"
      when "CoL"
        return false if (checkspirit rescue 0) < 6
        log "#{reason} -- Sign of Darkness"
        fput "sign of darkness"
      else
        return false
      end
      GSH4AState.set_cd(:soc_escape, 300)
      pause 1
      true
    when "saferoom"
      room = entry["room"].to_s.strip
      return false if room.empty?
      log "#{reason} -- running to safe room #{room}"
      waitrt?
      fput "stance defensive"
      start_script "go2", [room]
      sleep 0.5 while Script.running?("go2")
      log "Arrived at safe room. Restart when ready."
      stop_script "gshunting4all" rescue nil
      true
    else
      false
    end
  rescue => e
    warn "fire_escape_entry (#{entry['type']}): #{e.message}"
    false
  end

  def self.check_society_escape
    hp = percenthealth rescue 100
    return if hp >= pref("health_retreat_pct").to_i
    attempt_escape("Health at #{hp}%")
  end

  # ---------------------------------------------------------------------------
  # Spell maintenance
  # ---------------------------------------------------------------------------
  def self.cast_maintain_spells
    return if casting_blocked?
    return if combat_injured?
    ((@profile["spells"] || {})["maintain"] || []).each do |sp|
      num   = sp["num"].to_i
      label = sp["label"] || "Spell #{num}"
      next if num == 0
      next if (Spell[num].active? rescue false)
      next unless mana_ok?(pref("mana_min_reserve").to_i)
      log "Casting maintain spell: #{label} (#{num})"
      waitrt?; waitcastrt?
      fput "#{spell_verb(num)} #{num}"
      waitcastrt?
      pause 0.5
    rescue; end
  end

  def self.warn_missing_spells
    ((@profile["spells"] || {})["maintain"] || []).each do |sp|
      num   = sp["num"].to_i
      label = sp["label"] || "Spell #{num}"
      begin
        warn "#{label} (#{num}) is NOT active -- spell up before confirming" unless Spell[num].active?
      rescue; end
    end
  end

  # Re-sing sonic songs (weapon/shield/armor) if they have faded.
  def self.maintain_sonic_songs
    sonic = @profile["bard_sonic"] || {}
    return if sonic.empty?
    renew_nums = (sonic["renew_songs"] || []).map(&:to_i).to_set

    mana_reserve = pref("mana_min_reserve").to_i

    # Helper: prepare a sonic equipment spell then sing the type to cast+set form in one step.
    # GS4 workflow: PREPARE {num} -> wait for "spellsong is ready" -> SING {type}
    # Skips if mana is below reserve to prevent overextension.
    cast_sonic = proc do |num, type_arg|
      unless mana_ok?(mana_reserve)
        log "Sonic song #{num}: skipping re-sing -- mana below reserve (#{mana_reserve})"
        next
      end
      waitrt?; waitcastrt?
      fput "prepare #{num}"
      matchtimeout(10, "spellsong is ready")
      pause 0.3
      fput "sing #{type_arg}"
      waitcastrt?; pause 0.5
    end

    # Sonic Weapon (1012)
    if sonic["weapon_enabled"]
      num = sonic["weapon_spell"].to_i
      unless num == 0 || (Spell[num].active? rescue false)
        wpn_sing = sonic["weapon_sing"].to_s.strip
        wpn_sing = "longsword" if wpn_sing.empty?
        log "Sonic Weapon (#{num}) has faded -- re-singing (#{wpn_sing})"
        cast_sonic.call(num, wpn_sing)
        if sonic["weapon_type"] == "polearm" && sonic["weapon_grip"] == "one"
          waitrt?
          log "Sonic polearm: switching to 1H grip (GRIP ONE)"
          fput "grip one"
          pause 0.5
        end
      end
    end

    # Sonic Shield (1009) -- skipped if weapon is a 2H polearm (can't hold a shield)
    sonic_wpn_2h_polearm = sonic["weapon_enabled"] &&
                           sonic["weapon_type"] == "polearm" &&
                           sonic["weapon_grip"] == "two"
    if sonic["shield_enabled"] && !sonic_wpn_2h_polearm
      num = sonic["shield_spell"].to_i
      unless num == 0 || (Spell[num].active? rescue false)
        shld_sing = sonic["shield_sing"] || "buckler"
        log "Sonic Shield (#{num}) has faded -- re-singing (#{shld_sing})"
        cast_sonic.call(num, shld_sing)
      end
    end

    # Sonic Armor (1014)
    if sonic["armor_enabled"]
      num = sonic["armor_spell"].to_i
      unless num == 0 || (Spell[num].active? rescue false)
        asg = sonic["armor_asg"].to_i
        log "Sonic Armor (#{num}) has faded -- re-singing (ASG #{asg})"
        cast_sonic.call(num, asg.to_s) if asg > 0
      end
    end

    # Singing Sword Song (1025)
    if sonic["singing_sword"]
      unless (Spell[1025].active? rescue false)
        sword_sing = sonic["singing_sword_type"].to_s.strip
        sword_sing = "falchion" if sword_sing.empty?
        log "Singing Sword Song has faded -- re-singing (#{sword_sing})"
        cast_sonic.call(1025, sword_sing)
      end
    end

    # Defensive and utility songs -- prepare+sing; stop immediately if renew mode
    ((sonic["defensive_songs"] || []) + (sonic["utility_songs"] || [])).each do |num|
      num = num.to_i
      next if (Spell[num].active? rescue false)
      unless mana_ok?(mana_reserve)
        log "Song #{num}: skipping re-sing -- mana below reserve (#{mana_reserve})"
        next
      end
      log "Song #{num} has faded -- re-singing#{renew_nums.include?(num) ? ' (renew mode)' : ''}"
      waitrt?; waitcastrt?
      fput "prepare #{num}"
      matchtimeout(10, "spellsong is ready")
      pause 0.3
      fput "sing"
      waitcastrt?; pause 0.5
      if renew_nums.include?(num)
        fput "stop #{num}"
        pause 0.3
      end
    end
  rescue; end

  # Summon / prepare the Ranger animal companion at hunt start.
  # Returns true if the animal companion is present in the current room.
  # Animal companions appear as NPCs with "companion" or the bonded animal name.
  def self.ranger_companion_present?
    (GameObj.npcs rescue []).any? { |n|
      n.noun.to_s =~ /companion|canine|feline|avian|rodent|wolf|dog|cat|hawk|falcon|rat|weasel/i
    }
  end

  def self.maintain_ranger_companion
    rc = @profile["ranger_companion"] || {}
    return unless rc["enabled"]
    @companion_last_target_id = nil  # reset per-hunt so first engage always sends attack cmd

    # Re-summon if companion is absent and user wants auto-resummon.
    # Spell[630].active? doesn't track the Animal Companion bond -- check room presence instead.
    if rc["resummon"] && !ranger_companion_present?
      log "Animal Companion not present -- casting spell 630 to summon"
      waitrt?; waitcastrt?
      comp_type = rc["companion_type"].to_s.downcase
      comp_type = "canine" if comp_type.empty?
      fput "prepare 630"
      matchtimeout(10, /ready to be cast|not enough mana/i)
      pause 0.3
      fput "summon #{comp_type}"
      pause 3
    end

    # Set behavior mode: TELL COMPANION TO BEHAVE {OFFENSIVE|DEFENSIVE|NEUTRAL}
    beh = rc["behavior"].to_s.downcase
    beh = "offensive" if beh.empty?
    fput "tell companion to behave #{beh}"
    pause 1
  rescue; end

  # Direct the animal companion to attack the current target.
  # Skipped if behavior is offensive (companion auto-attacks after ranger) or defensive (companion guards).
  # Only sends command when target changes to avoid spamming every loop iteration.
  def self.companion_attack(target_id)
    rc = @profile["ranger_companion"] || {}
    return unless rc["enabled"] && rc["attack_target"]
    beh = rc["behavior"].to_s.downcase
    return if beh == "offensive"   # auto-attacks after ranger; no manual directive needed
    return if beh == "defensive"   # companion is guarding; don't override with attack cmd
    return if @companion_last_target_id == target_id  # already directed at this target
    @companion_last_target_id = target_id
    fput "tell companion to attack ##{target_id}"
  rescue; end

  # Returns true if the primary weapon hand is empty.
  def self.weapon_hand_empty?
    rh = GameObj.right_hand rescue nil
    rh.nil? || rh.noun.to_s =~ /\A(empty)?\z/i
  end

  # Issue READY commands at hunt start based on weapon config.
  # Skips if the appropriate hand(s) already have gear in them.
  def self.ready_weapons
    primary_type = @profile.dig("weapons", "primary", "type").to_s
    primary_grip = @profile.dig("weapons", "primary", "grip").to_s
    if primary_type == "uac" && primary_grip == "none"
      log "UAC (no held brawling weapon) -- skipping READY"
      return
    end
    if @profile.dig("weapons", "primary", "sonic_weapon")
      log "Sonic Weapon active -- skipping physical weapon READY"
      return
    end

    rh = GameObj.right_hand rescue nil
    lh = GameObj.left_hand  rescue nil
    rh_empty = rh.nil? || rh.name.to_s =~ /\Aempty\z/i || rh.id.to_i <= 0
    lh_empty = lh.nil? || lh.name.to_s =~ /\Aempty\z/i || lh.id.to_i <= 0

    dual     = @profile.dig("weapons", "dual_wield")
    shield   = @profile.dig("shield", "enabled")
    wpn_noun = @profile.dig("weapons", "primary", "noun").to_s.strip
    sh_noun  = @profile.dig("shield", "noun").to_s.strip

    if dual
      if rh_empty || lh_empty
        log "Readying dual weapons (READY 2WEAPON)"
        fput "ready 2weapon"
      else
        log "Dual weapons already in hand -- skipping READY"
      end
    else
      if rh_empty
        log "Readying primary weapon (READY WEAPON)"
        fput "ready weapon"
      else
        log "Primary weapon already in hand -- skipping READY"
      end
      if shield
        if @profile.dig("shield", "sonic_shield") || @profile.dig("bard_sonic", "shield_enabled")
          log "Sonic Shield active -- skipping physical shield READY"
        elsif lh_empty
          log "Readying shield (READY SHIELD)"
          fput "ready shield"
        else
          log "Shield already in hand -- skipping READY"
        end
      end
    end
    waitrt?
  rescue => e
    warn "ready_weapons error: #{e.message} -- continuing"
  end

  # Command the sorcerer demon to fetch the primary weapon if it has been dropped.
  def self.demon_fetch_weapon
    sd = @profile["sorcerer_demon"] || {}
    return unless sd["enabled"] && sd["fetch_weapon"]
    noun = sd["weapon_noun"].to_s.strip
    return if noun.empty? || !weapon_hand_empty?
    log "Weapon not in hand -- commanding demon to fetch #{noun}"
    fput "tell mdemon get #{noun}"
    pause 2
  rescue; end

  # Command the Spirit Servant to fetch the primary weapon if it has been dropped.
  def self.servant_fetch_weapon
    ss = @profile["spirit_servant"] || {}
    return unless ss["enabled"] && ss["fetch_weapon"]
    noun = ss["weapon_noun"].to_s.strip
    return if noun.empty? || !weapon_hand_empty?
    log "Weapon not in hand -- commanding Spirit Servant to fetch #{noun}"
    fput "tell servant to get #{noun}"
    pause 2
  rescue; end

  # ---------------------------------------------------------------------------
  # Weapon technique engine -- Reaction, Assault, AoE
  # ---------------------------------------------------------------------------

  # Builds per-type lists once from the profile for fast access.
  def self.techniques_by_type
    @_techniques_by_type ||= begin
      all = (@profile["techniques"] || []).select { |t| t["enabled"] != false }
      {
        reaction: all.select { |t| t["tech_type"] == "reaction" },
        assault:  all.select { |t| t["tech_type"] == "assault" },
        aoe:      all.select { |t| t["tech_type"] == "aoe" },
      }
    end
  end

  # Shield specs: setup types fire once per engagement (CD tracked by key).
  def self.fire_shield_specs
    (@profile["shield_specs"] || []).each do |spec|
      next unless spec["enabled"]
      key = "shield_spec_#{spec['name'].downcase.gsub(/\s+/, '_')}"
      next unless GSH4AState.cd_ready?(key)
      next unless rt_ok?
      log "Shield spec: #{spec['name']}"
      waitrt?
      fput spec["verb"]
      waitrt?
      GSH4AState.set_cd(key, 30)
    end
  end

  # Armor Specialization types per GS4 wiki:
  #   Buff    -- activated, 4-hour duration (Armor Support, Evasion, Fluidity, etc.)
  #             Only one Buff spec can be active at a time; script re-applies on expiry.
  #   Passive -- no activation needed (Armor Spike Mastery) or fitting-based (Crush/
  #             Puncture/Slash Protection). No verb fires for these.
  #
  # Buff specs are skipped when already active in Effects::Spells or Effects::Buffs.
  # Passive specs produce no game effect when verbed and should not be fired.
  ARMOR_SPEC_PASSIVE_MNEMONICS = %w[spikemastery crush puncture slash].freeze

  # Surge of Strength: total CD = 90s buff duration + recovery period per rank.
  # Rank => seconds before the ability is safely re-usable at normal stamina cost.
  SURGE_CD_BY_RANK = { 1 => 390, 2 => 330, 3 => 270, 4 => 240, 5 => 210 }.freeze

  def self.fire_armor_specs
    (@profile["armor_specs"] || []).each do |spec|
      next unless spec["enabled"]
      name     = spec["name"].to_s
      mnemonic = spec["verb"].to_s.split.last.to_s.downcase
      # Passive specs have no activation verb -- skip entirely
      next if ARMOR_SPEC_PASSIVE_MNEMONICS.include?(mnemonic)
      # Buff specs: skip if already active as a spell or buff effect
      already_active = (Effects::Spells.active?(name) rescue false) ||
                       (Effects::Buffs.active?(name)  rescue false)
      next if already_active
      key = "armor_spec_#{name.downcase.gsub(/\s+/, '_')}"
      next unless GSH4AState.cd_ready?(key)
      next unless rt_ok?
      log "Armor spec: #{name}"
      waitrt?
      fput spec["verb"]
      waitrt?
      GSH4AState.set_cd(key, 30)
    end
  end

  # DownstreamHook watches the game stream for reaction trigger text.
  # Sets @reaction_pending[name] = true when the trigger fires.
  # Watches combat output for UAC tier and vulnerability messaging.
  # Updates GSH4AState.uac_tier and uac_next_attack so the attack loop can respond.
  def self.start_uac_watcher
    return unless @profile.dig("weapons", "primary", "grip") == "uac"
    hook = "gsh4a_uac_watcher"
    DownstreamHook.remove(hook) rescue nil
    DownstreamHook.add(hook, proc { |line|
      clean = line.to_s.gsub(/<[^>]+>/, '')
      case clean
      when /excellent positioning/i
        GSH4AState.uac_tier = 3
      when /good positioning/i
        GSH4AState.uac_tier = 2
      when /decent positioning/i
        GSH4AState.uac_tier = 1
      end
      if clean =~ /vulnerable to a followup (\w+) attack/i
        atk = $1.downcase
        GSH4AState.uac_next_attack = atk if UAC_ATTACKS.include?(atk)
      end
      line
    })
  end

  def self.stop_uac_watcher
    DownstreamHook.remove("gsh4a_uac_watcher")   rescue nil
    DownstreamHook.remove("gsh4a_mount_cd_watcher") rescue nil
    GSH4AState.uac_tier        = 1
    GSH4AState.uac_next_attack = nil
  end

  def self.start_mount_cd_watcher
    DownstreamHook.remove("gsh4a_mount_cd_watcher") rescue nil
    DownstreamHook.add("gsh4a_mount_cd_watcher", proc { |line|
      stripped = line.gsub(/<[^>]+>/, "").strip
      # Cooldown detection
      if stripped =~ /not yet ready|still recover|cannot.*charge|cannot.*trample/i
        if stripped =~ /charge/i
          GSH4AState.set_cd(:mount_charge,  30)
          log "Mount charge still on cooldown -- extending 30s"
        elsif stripped =~ /trample/i
          GSH4AState.set_cd(:mount_trample, 30)
          log "Mount trample still on cooldown -- extending 30s"
        end
      end
      # Dismount detection
      if stripped =~ /dismount|thrown from|knocked from|you fall from|trample.*area|maneuver.*room/i
        GSH4AState.mounted = false
        GSH4AState.mount_summoned = true
      end
      line
    })
  end

  def self.stop_mount_cd_watcher
    DownstreamHook.remove("gsh4a_mount_cd_watcher") rescue nil
  end

  # Returns the best UAC attack to fire given current positioning state.
  # Consumes uac_next_attack once used so the next cycle reverts to rotation order.
  def self.uac_smart_pick(preferred)
    pending = GSH4AState.uac_next_attack
    if pending && pending != preferred
      GSH4AState.uac_next_attack = nil
      return pending
    end
    GSH4AState.uac_next_attack = nil
    preferred
  end

  def self.start_reaction_watcher
    techs = techniques_by_type[:reaction]
    return if techs.empty?

    _tg = Thread.current.group
    @reaction_thread&.kill rescue nil
    @reaction_thread = nil
    DownstreamHook.remove("gsh4a_reaction_watcher") rescue nil

    # DownstreamHook with a regex captures the full skill name including multi-word
    # names like "Reverse Strike". matchfind("...?!") only captures one word and
    # silently drops two-word technique opportunities.
    DownstreamHook.add("gsh4a_reaction_watcher", proc { |line|
      begin
        if GSH4AState.hunting
          clean = line.gsub(/<[^>]+>/, "").strip
          if clean =~ /You could use this opportunity to (.+?)!/i
            skill_name = $1.strip
            tech = techs.find { |t| t["enabled"] && t["name"].to_s.casecmp?(skill_name) }
            if tech && technique_ready?(tech) && stamina_ok?(tech["stamina"].to_i)
              t = Thread.new do
                begin
                  (_tg.add(Thread.current) rescue nil)
                  # Reactive techniques fire during RT in GS4 -- no RT wait needed.
                  # Only true CC (stun/web/bind) or death/disarm blocks them.
                  next if dead? || (stunned? rescue false) || (webbed? rescue false) || (bound? rescue false)
                  if npc_count > 0 && GSH4AState.hunting && weapon_in_hand?
                    log "Reaction: #{tech["name"]}"
                    switched_grip = switch_grip_for_ability(tech)
                    fput "weapon #{tech["mnemonic"]}"
                    waitrt?
                    restore_default_grip unless switched_grip.empty?
                  end
                rescue => e
                  log "Reaction error: #{e.message}"
                end
              end
              t
            end
          end
        end
      rescue => e
        log "Reaction watcher error: #{e.message}"
      end
      line
    })
  end

  def self.stop_reaction_watcher
    @reaction_thread&.kill rescue nil
    @reaction_thread = nil
    DownstreamHook.remove("gsh4a_reaction_watcher") rescue nil
    DownstreamHook.remove("gsh4a_tech_cd_watcher")  rescue nil
    @technique_on_cd = {}
  end

  # Watches for stun messages and sets GSH4AState.stun_pending so the attack loop
  # can fire a Stun Maneuver action (attack/hide/stand) through the stun.
  def self.start_stun_watcher
    rg = @profile["rogue_guild"] || {}
    return unless rg["stun_enabled"]
    GSH4AState.stun_pending = false
    DownstreamHook.remove("gsh4a_stun_watcher") rescue nil
    DownstreamHook.add("gsh4a_stun_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      # GS4 stun onset messages
      if clean =~ /you are (stunned|left reeling|dazed)|roundtime.*stun|you reel|your vision blurs/i
        GSH4AState.stun_pending = true
      end
      # Clear flag once we're no longer stunned
      if clean =~ /you shake off|stun.*wears? off|you recover|no longer stunned/i
        GSH4AState.stun_pending = false
      end
      line
    })
  end

  def self.stop_stun_watcher
    DownstreamHook.remove("gsh4a_stun_watcher") rescue nil
    GSH4AState.stun_pending = false
  end

  # Watches for berserk onset/end messages so the attack loop knows to step aside.
  def self.start_berserk_watcher
    wg = @profile["warrior_guild"] || {}
    return unless wg["berserk_enabled"]
    GSH4AState.berserking    = false
    GSH4AState.berserk_rounds = 0
    DownstreamHook.remove("gsh4a_berserk_watcher") rescue nil
    DownstreamHook.add("gsh4a_berserk_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      if clean =~ /you enter a berserker rage|you go berserk|a red haze descends/i
        GSH4AState.berserking     = true
        GSH4AState.berserk_rounds = 0
      end
      if GSH4AState.berserking && clean =~ /you (attack|slash|strike|swing|bash|lunge)/i
        GSH4AState.berserk_rounds = (GSH4AState.berserk_rounds || 0) + 1
      end
      if clean =~ /your berserker rage (fades|ends|subsides)|you regain control|berserk.*wears? off/i
        GSH4AState.berserking     = false
        GSH4AState.berserk_rounds = 0
      end
      line
    })
  end

  def self.stop_berserk_watcher
    DownstreamHook.remove("gsh4a_berserk_watcher") rescue nil
    if GSH4AState.berserking
      waitrt?
      fput "stop berserk"
      pause 1
    end
    GSH4AState.berserking     = false
    GSH4AState.berserk_rounds = 0
  end

  # Enter berserk if enabled, stamina allows, and not already berserking.
  # Returns true while berserking so the attack loop skips its normal attack.
  def self.check_berserk(target_id)
    wg = @profile["warrior_guild"] || {}
    return false unless wg["berserk_enabled"]
    if GSH4AState.berserking
      max_rounds = wg["berserk_max_rounds"].to_i
      if max_rounds > 0 && (GSH4AState.berserk_rounds || 0) >= max_rounds
        log "Berserk: stopping after #{GSH4AState.berserk_rounds} rounds"
        waitrt?
        fput "stop berserk"
        pause 1
        GSH4AState.berserking = false
        return false
      end
      return true
    end
    stam_min = wg["berserk_stamina_min"].to_i
    unless stamina_ok?(stam_min + 20)
      log "Berserk: skipping -- stamina below threshold (need #{stam_min + 20})"
      return false
    end
    log "Berserk: entering rage"
    waitrt?; waitcastrt?
    fput "cman berserk"
    pause 1.0
    GSH4AState.berserking     = true
    GSH4AState.berserk_rounds = 0
    true
  rescue
    false
  end

  # Fire enabled war cries before each attack against the given target.
  def self.fire_war_cries(target_id)
    wg = @profile["warrior_guild"] || {}
    cries = wg["warcries"] || {}
    target_noun = (GameObj[target_id]&.noun rescue nil) || "opponent"
    WG_WARCRIES.each do |cry|
      saved = cries[cry[:key]] || {}
      next unless saved["enabled"]
      next if weapon_rot_has_type?("warcry", cry[:key])
      use_aoe   = cry[:stamina_aoe] && saved["aoe"]
      stam_cost = use_aoe ? cry[:stamina_aoe] : cry[:stamina_single]
      next unless stam_cost.nil? || stam_cost == 0 || stamina_ok?(stam_cost)
      log "War Cry: #{cry[:cmd]}"
      waitrt?
      if cry[:type] == :supporting
        fput "warcry #{cry[:cmd]}"
      elsif use_aoe
        fput "warcry #{cry[:cmd]}"
      else
        fput "warcry #{cry[:cmd]} ##{target_id}"
      end
      waitrt?
      pause 0.3
    end
  rescue
  end

  # Fire warrior trick combos before the attack.
  def self.check_warrior_tricks(target_id)
    wg = @profile["warrior_guild"] || {}
    if wg["feint_enabled"] && !weapon_rot_has_type?("warrior_feint")
      waitrt?
      fput "wtrick feint ##{target_id}"
      waitrt?
      pause 0.2
    end
    if wg["spit_enabled"] && !weapon_rot_has_type?("warrior_spit")
      loc = wg["spit_location"].to_s.gsub("_", " ")
      waitrt?
      fput "wtrick spit ##{target_id} #{loc}"
      waitrt?
      pause 0.2
    end
  rescue
  end

  # Called each attack loop iteration. If the rogue is stunned and stamina allows,
  # fires the configured Stun Maneuver action and clears the pending flag.
  def self.check_stun_maneuver
    rg = @profile["rogue_guild"] || {}
    return false unless rg["stun_enabled"] && GSH4AState.stun_pending
    stamina_cost = rg["stun_stamina"].to_i
    unless stamina_ok?(stamina_cost)
      log "Stun Maneuver: skipping -- stamina below reserve (cost #{stamina_cost})"
      return false
    end
    action = rg["stun_action"].to_s
    log "Stun Maneuver: firing '#{action}' through stun"
    GSH4AState.stun_pending = false
    case action
    when "attack"
      # Use the standard attack verb for the primary weapon while stunned
      target_noun = (GameObj.targets&.first&.noun rescue nil) || "opponent"
      fput "cman stunman attack #{target_noun}"
    when "hide"
      fput "cman stunman hide"
    when "stand"
      fput "cman stunman stand"
    end
    pause 0.5
    true
  rescue
    false
  end

  # @return [Boolean] true when the single-target weapon rotation has at least one non-Normal-Attack slot configured
  def self.weapon_rotation_active?
    Array(@profile.dig("weapons", "weapon_rotation")).any? { |e| e.is_a?(Hash) && !%w[normal_attack skip].include?(e["type"].to_s) }
  end

  def self.spell_rotation_active?
    Array(@profile.dig("spells", "rotation")).any? { |e| e.is_a?(Hash) && e["type"].to_s != "skip" }
  end

  # Returns true when any slot in either weapon rotation contains an entry of the given type (and optional key).
  # Used to suppress standalone guild/arcarium/trinket firing when the rotation owns that ability.
  # @param type [String] entry type to match ("warcry", "vissi", "trinket", "warrior_feint", etc.)
  # @param key [String, nil] optional secondary key to match (e.g. "bellow" for warcry, "aversaris:Parasite" for vissi)
  # @return [Boolean]
  def self.weapon_rot_has_type?(type, key = nil)
    [
      Array(@profile.dig("weapons", "weapon_rotation")),
      Array(@profile.dig("weapons", "weapon_aoe_rotation"))
    ].flatten.any? do |e|
      next unless e.is_a?(Hash)
      e["type"].to_s == type && (key.nil? || e["key"].to_s == key)
    end
  end

  # Fires the current single-target weapon rotation slot, then advances the index.
  # Falls back to a normal attack if the chosen ability is on cooldown or unavailable.
  # Resets @weapon_rot_idx to 0 at the start of each new engagement (caller's responsibility).
  # @param target_id [String, Integer] game object ID of the current target
  # @return [Boolean] always true (either the rotation slot fired or the fallback attack fired)
  def self.execute_weapon_rotation_step(target_id)
    rot = Array(@profile.dig("weapons", "weapon_rotation")).select { |e| e.is_a?(Hash) && e["type"].to_s != "skip" }
    return false if rot.empty?
    entry    = rot[@weapon_rot_idx % rot.length]
    @weapon_rot_idx = (@weapon_rot_idx + 1) % rot.length
    fired    = fire_weapon_rot_entry(entry, target_id)
    unless fired
      wpn_cfg = @profile.dig("weapons", "primary") || {}
      loc     = wpn_cfg["target_location"].to_s.strip
      stance_offensive
      waitrt?
      fput loc.empty? ? "attack ##{target_id}" : "attack ##{target_id} #{loc}"
      waitrt?
      stance_restore
    end
    true
  end

  # Fires the current AoE weapon rotation slot and advances the AoE index.
  # Called when aoe_needed? is true and weapon_rotation_active? is true.
  # @param target_id [String, Integer] game object ID of the primary target
  # @return [Boolean] true if the slot fired, false if rotation is empty or ability unavailable
  def self.execute_weapon_aoe_step(target_id)
    rot = Array(@profile.dig("weapons", "weapon_aoe_rotation")).select { |e| e.is_a?(Hash) && e["type"].to_s != "skip" }
    return false if rot.empty?
    entry = rot[@weapon_aoe_rot_idx % rot.length]
    @weapon_aoe_rot_idx = (@weapon_aoe_rot_idx + 1) % rot.length
    fire_weapon_rot_entry(entry, target_id)
  end

  # Dispatches a single weapon rotation entry to the appropriate firing path.
  # Handles: normal_attack, feat, mount_charge, mount_trample, cman, technique,
  #          warcry, warrior_feint, warrior_spit, rogue_ss, vissi, trinket, gemstone.
  # @param entry [Hash] rotation entry hash with at minimum "type" key
  # @param target_id [String, Integer] game object ID of the current target
  # @return [Boolean] true if the ability fired, false if unavailable or on cooldown
  def self.fire_weapon_rot_entry(entry, target_id)
    return false unless entry.is_a?(Hash)
    type = entry["type"].to_s
    case type
    when "normal_attack"
      false  # caller handles fallback

    when "skip"
      false

    when "spell"
      cmd = entry["cmd"].to_s.strip
      return false if cmd.empty?
      if cmd =~ /\Acast\s+(\d+)/i
        # "cast <num>" in the rotation means room-wide AoE: prepare then bare cast
        # (no target) so the spell hits the whole room. Use this for spells like
        # Aura of the Arkati (1614). For targeted spells, set cmd to "incant <num>"
        # in the rotation so Lich auto-targets the current enemy.
        num = $1
        return false unless (Spell[num.to_i].known? rescue false)
        waitrt?; waitcastrt?
        prep_result = dothistimeout("prepare #{num}", 5,
          /your spell is ready|can't seem to recall|golden light|already have a spell/i)
        if prep_result.to_s =~ /can't seem to recall|golden light/i
          # Mystic Impedance or other casting block -- skip cleanly
          return false
        end
        if prep_result.to_s =~ /already have a spell/i
          fput "release"
          waitcastrt?
          return false
        end
        waitcastrt?
        waitrt?
        if (bound? || stunned? || webbed? rescue false)
          fput "release" rescue nil
          return false
        end
        fput "cast"
        waitrt?
      elsif cmd =~ /\Aincant\s+(\d+)/i
        # "incant <num>" -- let Lich handle prepare+target+cast in one step
        return false unless (Spell[$1.to_i].known? rescue false)
        waitrt?; waitcastrt?
        fput "incant #{$1}"
        waitcastrt?
        waitrt?
      else
        waitrt?
        fput cmd
        waitrt?
      end
      true

    when "feat"
      name = entry["name"].to_s.downcase
      cd_key = "feat_#{name}"
      return false unless GSH4AState.cd_ready?(cd_key)
      case name
      when "chastise"
        return false unless stamina_ok?(10)
        cd_secs = 15
      when "excoriate"
        return false unless mana_ok?(10)
        cd_secs = 15
      else
        cd_secs = 15
      end
      stance_offensive
      waitrt?
      return false if dead?
      fput "feat #{name}"
      waitrt?
      GSH4AState.set_cd(cd_key, cd_secs)
      stance_restore
      true

    when "mount_charge"
      return false unless GSH4AState.mounted
      mount_charge(target_id)

    when "mount_trample"
      return false unless GSH4AState.mounted
      mount_trample

    when "cman"
      cman_name = entry["name"].to_s
      c = (@profile["cmans"] || []).find { |x| x["name"].to_s == cman_name }
      return false unless c
      fire_cman(c, target_id)

    when "technique"
      tech_name = entry["name"].to_s
      tech = (@profile["techniques"] || []).find { |t| t["name"].to_s == tech_name }
      return false unless tech
      return false unless technique_ready?(tech)
      return false unless stamina_ok?(tech["stamina"].to_i)
      log "Rotation technique: #{tech['name']}"
      switched_grip = switch_grip_for_ability(tech)
      stance_offensive
      waitrt?
      return false if dead?
      fput tech["verb"].to_s
      waitrt?
      @technique_on_cd[tech_name.downcase] = true
      restore_default_grip unless switched_grip.empty?
      stance_restore
      true

    when "warcry"
      wg = @profile["warrior_guild"] || {}
      cry_key  = entry["key"].to_s
      cry_def  = WG_WARCRIES.find { |c| c[:key] == cry_key }
      return false unless cry_def
      saved = (wg["warcries"] || {})[cry_key] || {}
      return false unless saved["enabled"]
      use_aoe   = cry_def[:stamina_aoe] && saved["aoe"]
      stam_cost = use_aoe ? cry_def[:stamina_aoe] : cry_def[:stamina_single]
      return false if stam_cost && stam_cost > 0 && !stamina_ok?(stam_cost)
      log "War Cry: #{cry_def[:cmd]} (rotation)"
      waitrt?
      if cry_def[:type] == :supporting || use_aoe
        fput "warcry #{cry_def[:cmd]}"
      else
        fput "warcry #{cry_def[:cmd]} ##{target_id}"
      end
      waitrt?
      pause 0.3
      true

    when "warrior_feint"
      wg = @profile["warrior_guild"] || {}
      return false unless wg["feint_enabled"]
      waitrt?
      fput "wtrick feint ##{target_id}"
      waitrt?
      pause 0.2
      true

    when "warrior_spit"
      wg = @profile["warrior_guild"] || {}
      return false unless wg["spit_enabled"]
      loc = wg["spit_location"].to_s.gsub("_", " ")
      waitrt?
      fput "wtrick spit ##{target_id} #{loc}"
      waitrt?
      pause 0.2
      true

    when "rogue_ss"
      check_silent_strike(target_id)

    when "vissi"
      arc_key  = entry["arcarium"].to_s
      vis_name = entry["name"].to_s
      arc_cfg  = (@profile["arcarium"] || {})[arc_key] || {}
      return false unless arc_cfg["enabled"]
      v = (arc_cfg["vissi"] || []).find { |x| x.is_a?(Hash) && x["name"].to_s == vis_name }
      return false unless v
      fire_single_vissi(arc_key, v)

    when "trinket"
      slot    = entry["slot"].to_s
      ab_key  = entry["ability_key"].to_s
      ab_obj  = all_abilities.find { |a| a["_slot"].to_s == slot && a["key"].to_s == ab_key }
      return false unless ab_obj
      fire_ability(ab_obj, target_id)

    when "gemstone"
      slot_num = entry["slot_num"].to_i
      slot = Array(@profile.dig("gemstones", "slots")).find { |s| s.is_a?(Hash) && s["slot_num"].to_i == slot_num }
      return false unless slot && slot["enabled"] && !slot["activated_property"].to_s.strip.empty?
      gem_name = slot["name"].to_s.strip
      return false if gem_name.empty?
      waitrt?
      fput "gem activate my #{gem_name}"
      waitrt?
      true

    when "script_wpn"
      ab_key = entry["key"].to_s
      ab = Array(@profile.dig("weapons","primary","scripts")).flat_map { |s| s["abilities"] || [] }
             .find { |a| a["key"].to_s == ab_key }
      return false unless ab
      verb = ab["verb"].to_s.gsub("#TARGET", "##{target_id}")
      waitrt?; fput verb; waitrt?
      true

    when "script_arm"
      ab_key = entry["key"].to_s
      ab = Array(@profile.dig("armor","scripts")).flat_map { |s| s["abilities"] || [] }
             .find { |a| a["key"].to_s == ab_key }
      return false unless ab
      verb = ab["verb"].to_s.gsub("#TARGET", "##{target_id}")
      waitrt?; fput verb; waitrt?
      true

    when "society_attack"
      cmd = entry["cmd"].to_s
      return false if cmd.empty?
      log "Society attack: #{cmd}"
      waitrt?
      fput cmd
      waitrt?
      true

    when "shield_spec"
      verb = entry["verb"].to_s
      return false if verb.empty?
      log "Shield spec: #{entry['name']} (#{verb})"
      waitrt?
      fput verb
      waitrt?
      true

    else
      false
    end
  rescue => e
    warn "fire_weapon_rot_entry error: #{e.message}"
    false
  end

  # Fires Silent Strike from stealth in place of a normal melee swing.
  # Hides first if needed (HIDE or Vanish), then fires FEAT SILENTSTRIKE [mod] #id.
  # Returns true if the attack was handled so the loop skips the normal swing.
  def self.check_silent_strike(target_id)
    rg = @profile["rogue_guild"] || {}
    return false unless rg["ss_enabled"]
    return false if weapon_rot_has_type?("rogue_ss")
    unless stamina_ok?(20)
      log "Silent Strike: skipping -- stamina below reserve (cost 20)"
      return false
    end
    # Ensure hidden before attempting
    unless (checkhidden rescue false)
      waitrt?
      if rg["ss_hide_method"] == "vanish"
        fput "cman vanish"
      else
        fput "hide"
      end
      pause 0.8
      unless (checkhidden rescue false)
        log "Silent Strike: failed to hide -- falling through to normal attack"
        return false
      end
    end
    mod = rg["ss_modifier"].to_s
    mod = nil if mod.empty? || mod == "(none)"
    cmd = mod ? "feat silentstrike #{mod} ##{target_id}" : "feat silentstrike ##{target_id}"
    log "Silent Strike: #{cmd}"
    waitrt?; waitcastrt?
    fput cmd
    waitrt?
    true
  rescue
    false
  end

  # Watches GS4 output for technique cooldown and ready messages.
  # "Thrash is still in cooldown." -> mark blocked
  # "ready to perform the Thrash technique" -> clear blocked
  def self.start_technique_cd_watcher
    @technique_on_cd = {}
    DownstreamHook.remove("gsh4a_tech_cd_watcher") rescue nil
    DownstreamHook.add("gsh4a_tech_cd_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      if clean =~ /\b(.+?)\s+is still in cooldown/i
        @technique_on_cd[$1.strip.downcase] = true
      end
      if clean =~ /feel ready to perform the\s+(.+?)\s+technique/i
        @technique_on_cd.delete($1.strip.downcase)
      end
      if clean =~ /\b(.+?)\s+is ready for use/i
        @technique_on_cd.delete($1.strip.downcase)
      end
      line
    })
  end

  def self.stop_technique_cd_watcher
    DownstreamHook.remove("gsh4a_tech_cd_watcher") rescue nil
    @technique_on_cd = {}
  end

  def self.technique_ready?(tech)
    !@technique_on_cd&.dig(tech["name"].to_s.downcase)
  end


  # Switches the primary weapon grip if the ability requires it.
  # Pass a hash with a "grip" key ("one" or "two"; legacy "one-handed"/"two-handed" also accepted).
  # Returns the grip keyword that was applied (empty string = no change needed).
  def self.switch_grip_for_ability(ability)
    raw      = ability["grip"].to_s.strip.downcase
    required = raw.start_with?("one") ? "one" : raw.start_with?("two") ? "two" : raw
    return "" unless %w[one two].include?(required)
    type_code    = @profile.dig("weapons", "primary", "type").to_s
    weapon_default = %w[2hw polearm].include?(type_code) ? "two" : "one"
    return "" if required == weapon_default
    waitrt?
    log "Grip switch: GRIP #{required.upcase}"
    fput "grip #{required}"
    pause 0.5
    required
  end

  # Restores primary weapon to its profile default grip.
  # Default: two-handed for 2hw/polearm, one-handed for everything else.
  def self.restore_default_grip
    type_code = @profile.dig("weapons", "primary", "type").to_s
    default   = %w[2hw polearm].include?(type_code) ? "two" : "one"
    waitrt?
    log "Grip restore: GRIP #{default.upcase}"
    fput "grip #{default}"
    pause 0.5
  end

  # Assault techniques: single-target, fire freely during attack loop.
  def self.fire_assault_techniques
    return false unless weapon_in_hand?
    return false if movement_blocked?
    techniques_by_type[:assault].each do |tech|
      next unless technique_ready?(tech)
      next unless stamina_ok?(tech["stamina"].to_i)
      log "Assault: #{tech['name']}"
      stance_offensive
      switched_grip = switch_grip_for_ability(tech)
      waitrt?
      fput tech["verb"]
      waitrt?
      @technique_on_cd[tech["name"].downcase] = true
      restore_default_grip unless switched_grip.empty?
      stance_restore
      return true
    end
    false
  end

  # AoE techniques: fire when creature count meets min_creatures.
  def self.fire_aoe_techniques(creature_count)
    return false unless weapon_in_hand?
    return false if movement_blocked?
    techniques_by_type[:aoe].each do |tech|
      next unless technique_ready?(tech)
      min_c = tech["min_creatures"].to_i
      min_c = 3 if min_c <= 1
      next unless creature_count >= min_c
      next unless stamina_ok?(tech["stamina"].to_i)
      log "AoE technique: #{tech['name']} (#{creature_count} foes >= #{min_c})"
      stance_offensive
      switched_grip = switch_grip_for_ability(tech)
      waitrt?
      fput tech["verb"]
      waitrt?
      @technique_on_cd[tech["name"].downcase] = true
      restore_default_grip unless switched_grip.empty?
      stance_restore
      return true
    end
    false
  end

  # ---------------------------------------------------------------------------
  # Attack spell
  # ---------------------------------------------------------------------------
  def self.cast_attack_spell(target_id = nil)
    sp_cfg = @profile["spells"] || {}
    num    = sp_cfg["attack"].to_i
    return false if num == 0
    return false unless mana_ok?(15)
    type = sp_cfg["attack_type"] || "warding"
    return false if type == "bolt" && !rt_ok?
    waitrt?; waitcastrt?
    set_stance("offensive") if type == "bolt"  # after cast RT clears; can't go offensive during soft RT
    target_id ? fput("#{spell_verb(num)} #{num} ##{target_id}") : fput("#{spell_verb(num)} #{num}")
    waitcastrt?
    stance_restore if type == "bolt"  # restore to resting stance after bolt
    true
  end

  # ---------------------------------------------------------------------------
  # Ranged & thrown attacks
  # ---------------------------------------------------------------------------

  # Returns the ammo count from the container, or nil if it can't be determined.
  def self.check_ammo_count(wpn_cfg)
    container = wpn_cfg["ammo_container"].to_s.strip
    return nil if container.empty?
    out = dothistimeout("count my #{container}", 3, /you count|there are|contains? \d+|\d+ (arrow|bolt|stone|bullet|shot)/i)
    out&.scan(/\d+/)&.first&.to_i
  rescue
    nil
  end

  # Returns true and fires the shot; returns false if ammo is gone or unavailable.
  def self.ranged_attack(target_id)
    wpn = @profile.dig("weapons", "primary")
    return false unless wpn && wpn["grip"] == "ranged" && wpn["enabled"] != false

    sub       = wpn["ranged_subtype"].to_s   # bow, crossbow, sling, thrown
    warn_at   = wpn["ammo_warn_at"].to_i

    if warn_at > 0 && sub != "thrown"
      count = check_ammo_count(wpn)
      if count && count <= 0
        log "RANGED: No ammo left in #{wpn['ammo_container']} -- stopping hunt."
        GSH4AState.hunting = false
        return false
      elsif count && count <= warn_at
        log "RANGED: Low ammo warning -- #{count} remaining in #{wpn['ammo_container']}."
      end
    end

    # ---- Load crossbow if needed ------------------------------------------------
    if sub == "crossbow"
      unless GSH4AState.crossbow_loaded
        xbow_noun = (wpn["ranged_noun"] || wpn["noun"]).to_s.strip
        if xbow_noun.empty?
          log "RANGED: Crossbow noun is blank -- skipping load. Set your ranged weapon noun in setup."
          return false
        end
        waitrt?
        fput "load my #{xbow_noun}"
        waitrt?
        GSH4AState.crossbow_loaded = true
      end
    end

    # ---- Hide before shooting (open ambush for Rangers/Rogues) ------------------
    if wpn["hide_to_shoot"] && sub != "thrown"
      unless (checkhidden rescue false)
        waitrt?
        spell608_cost = (Spell[608].cost rescue 15)
        if wpn["use_608_hide"] && (Spell[608].known? rescue false) && mana_ok?(spell608_cost)
          # Camouflage (608): instant forced stealth for Rangers; gated by mana reserve
          waitcastrt?
          fput "incant 608"
          waitcastrt?
        else
          fput "hide"
        end
        pause 0.5
      end
    end

    # ---- Kneel before firing crossbow (+AS bonus) -------------------------------
    should_kneel = sub == "crossbow" && wpn["kneel_crossbow"]
    if should_kneel && !GSH4AState.ranged_kneeling
      waitrt?
      fput "kneel"
      GSH4AState.ranged_kneeling = true
      pause 0.3
    end

    stance_offensive
    waitrt?; waitcastrt?

    loc      = wpn["target_location"].to_s.strip
    rng_noun = wpn["ranged_noun"].to_s.strip
    # Use FIRE when hidden (triggers sniping/hidden-check mechanic); SHOOT otherwise.
    # FIRE does NOT automatically reveal -- the game rolls Stalking+Hiding to stay hidden.
    currently_hidden = wpn["hide_to_shoot"] && (checkhidden rescue false)
    fire_verb = currently_hidden ? "fire" : "shoot"

    if sub == "thrown"
      throw_cmd = rng_noun.empty? ? "throw ##{target_id}" : "throw my #{rng_noun} at ##{target_id}"
      fput throw_cmd
    elsif wpn["aim_first"]
      fput loc.empty? ? "aim ##{target_id}" : "aim ##{target_id} #{loc}"
      waitrt?
      fput fire_verb
    else
      fput loc.empty? ? "#{fire_verb} ##{target_id}" : "#{fire_verb} ##{target_id} #{loc}"
    end

    waitrt?
    GSH4AState.crossbow_loaded = false if sub == "crossbow"

    # ---- Stand after shot if not staying kneeling -------------------------------
    if GSH4AState.ranged_kneeling && !wpn["stay_kneeling"]
      waitrt?
      fput "stand"
      GSH4AState.ranged_kneeling = false
    end

    stance_restore
    true
  end

  # ---------------------------------------------------------------------------
  # Attack rotation (profile-driven, replaces single attack spell + CMAN logic)
  # ---------------------------------------------------------------------------
  def self.walk_rotation(target_id)
    return false if casting_blocked?
    return false if weapon_rotation_active?
    (@profile.dig("spells", "rotation") || []).each do |entry|
      next unless entry.is_a?(Hash)
      cond = entry["condition"].to_s.strip
      next unless rotation_condition_met?(cond)
      return true if fire_weapon_rot_entry(entry, target_id)
    end
    false
  end

  def self.rotation_condition_met?(cond)
    return true if cond.nil? || cond.strip.empty? || cond.strip == "always"
    case cond.strip
    when /mana\s*>\s*(\d+)%?/i
      pct_mana > $1.to_f
    when /mana\s*<\s*(\d+)%?/i
      pct_mana < $1.to_f
    when /stamina\s*>\s*(\d+)/i
      checkstamina.to_i > $1.to_i
    when /stamina\s*<\s*(\d+)/i
      checkstamina.to_i < $1.to_i
    when /creatures\s*>=?\s*(\d+)/i
      npc_count >= $1.to_i
    else
      true
    end
  end

  def self.pct_mana
    max = maxmana.to_f
    max > 0 ? (checkmana.to_f / max * 100.0) : 0.0
  end

  # ---------------------------------------------------------------------------
  # CMAN / feat rotation
  # ---------------------------------------------------------------------------
  def self.cmans_of_type(type_str)
    (@profile["cmans"] || []).select { |c| c["type"] == type_str && c["enabled"] != false }
  end

  # Executes a single CMAN or technique entry from the profile.
  # Checks stamina, cooldown, and roundtime before firing.
  # Handles optional grip switch and records cooldown on success.
  #
  # @param cman [Hash] CMAN entry from the profile (keys: name, verb, cd, stamina, ...)
  # @param target_id [String, Integer, nil] game object ID to embed in the command, or nil
  # @return [Boolean] true if the command was sent, false if any guard failed
  def self.fire_cman(cman, target_id = nil)
    return false if movement_blocked?
    return false unless stamina_ok?(cman["stamina"].to_i)
    key = "cman_#{cman['name'].gsub(/\s+/, '_').downcase}"
    cd  = cman["cd"].to_i
    # For Surge of Strength, override the profile CD with the rank-correct total cycle
    # (90s buff + rank-based recovery period), regardless of what the profile says.
    if cman["verb"].to_s =~ /\bsurge\b/i || cman["name"].to_s =~ /surge of strength/i
      surge_feat = Array((@detected || {})[:feats]).find { |f| f[:mnemonic].to_s.downcase == "surge" }
      surge_rank = surge_feat ? (surge_feat[:rank] || 5).to_i : 5
      surge_rank = surge_rank.clamp(1, 5)
      cd = SURGE_CD_BY_RANK[surge_rank]
    end
    return false if cd > 0 && !GSH4AState.cd_ready?(key)
    return false unless rt_ok?
    cmd = cman["verb"].dup
    cmd.gsub!("#TARGET", "##{target_id}") if target_id
    log cman["name"]
    switched_grip = switch_grip_for_ability(cman)
    waitrt?; waitcastrt?
    return false if dead?
    result = fput cmd
    waitrt?
    restore_default_grip unless switched_grip.empty?
    # If the game warns the ability is still active or stamina is depleted,
    # back off for the full CD duration regardless of what's configured.
    if result.to_s =~ /not yet exhausted|ache much too badly/i
      GSH4AState.set_cd(key, [cd, 60].max)
      return false
    end
    GSH4AState.set_cd(key, cd) if cd > 0
    true
  end

  # ---------------------------------------------------------------------------
  # AoE phase
  # ---------------------------------------------------------------------------
  def self.aoe_needed?
    return false if gigas_present?
    npc_count >= pref("aoe_threshold").to_i
  end

  # Fires all configured AoE abilities and/or AoE spell/cman rotation entries.
  # No-ops when the room has fewer NPCs than aoe_threshold or gigas are present.
  #
  # @param primary_id [String, Integer] ID of the current primary target (for targeted AoE commands)
  # @return [void]
  def self.run_aoe_phase(primary_id)
    return unless aoe_needed?
    run_abilities_when("aoe", primary_id)
    weapon_aoe_rot_active = Array(@profile.dig("weapons", "weapon_aoe_rotation")).any? { |e| e.is_a?(Hash) && !%w[skip].include?(e["type"].to_s) }
    aoe_rot = weapon_aoe_rot_active ? [] : (@profile.dig("spells", "aoe_rotation") || [])
    if aoe_rot.empty?
      # legacy: fire aoe CMANs from the cmans list
      cmans_of_type("aoe").each { |c| fire_cman(c, primary_id) }
    else
      aoe_rot.each do |entry|
        next unless entry.is_a?(Hash)
        next unless rotation_condition_met?(entry["condition"])
        fire_weapon_rot_entry(entry, primary_id)
      end
    end
  end

  # ---------------------------------------------------------------------------
  # Holy Weapon (1625) -- Paladin-only infusion and activation management
  # ---------------------------------------------------------------------------
  def self.holy_weapon_cfg
    @profile.dig("weapons", "holy_weapon") || {}
  end

  def self.holy_weapon_enabled?
    holy_weapon_cfg.fetch("enabled", false) &&
      @profile.dig("character", "profession").to_s =~ /Paladin/i
  end

  def self.holy_weapon_noun
    @profile.dig("weapons", "primary", "noun").to_s.strip
  end

  # Infuse spell into the holy weapon until full (or until timeout).
  def self.infuse_holy_weapon
    cfg  = holy_weapon_cfg
    noun = holy_weapon_noun
    return unless noun && !noun.empty?
    spell = cfg["spell"].to_s.strip
    return if spell.empty?

    smc_bonus = (@detected || {}).dig(:lore_ranks, "SMC_bonus").to_i
    smc_bonus = @profile.dig("lore_ranks", "SMC_bonus").to_i if smc_bonus == 0
    capacity  = 30 + (smc_bonus / 2)

    respond "[gsh4a] Infusing holy weapon (#{noun}) with spell #{spell} -- capacity #{capacity} mana"

    loop do
      charges = sense_holy_weapon_charges(noun)
      break if charges >= capacity || charges < 0

      waitcastrt?
      fput "prep #{spell}"
      waitcastrt?
      result = dothistimeout("infuse my #{noun}", 8,
        /infused|no room|cannot|prepare a spell|not enough/)
      case result
      when /no room|cannot/
        break
      when nil
        break
      end
      pause 0.5
    end
    respond "[gsh4a] Holy weapon infusion complete"
  end

  # Proactive between-fight charge check. Refills if autorefill is on and charges
  # are zero. Called in the maintenance loop BEFORE society symbols so the weapon
  # is ready before the next fight starts.
  def self.check_holy_weapon_charges
    # No-op: refill only happens at hunt start now. Mid-combat depletion sets
    # @hw_depleted and the weapon stays disarmed until the next hunt.
  end

  # Query charges via BESEECH SENSE. Returns integer charge count or -1 on failure.
  def self.sense_holy_weapon_charges(noun = nil)
    noun ||= holy_weapon_noun
    return -1 unless noun && !noun.empty?
    line = dothistimeout("beseech my #{noun} sense", 5,
      /holding\s+(\d+)|no charges|not infused|not blessed|nothing happens/i)
    return 0 if line =~ /no charges|not infused|nothing happens/i
    return -1 if line.nil?
    line =~ /(\d+)/ ? $1.to_i : -1
  end

  # Arm the holy weapon by beseeching it before an attack.
  # Mode controls WHEN this is called -- the command is always the same.
  # "once"       -- only on the very first target of the hunt session
  # "per_target" -- before each new target
  # "per_attack" -- before every single swing (called in inner combat loop)
  def self.beseech_holy_weapon
    return unless holy_weapon_enabled?
    return if @hw_depleted
    cfg  = holy_weapon_cfg
    noun = holy_weapon_noun
    return unless noun && !noun.empty?

    mode = cfg.fetch("mode", "per_target")
    # Skip if already armed -- watcher resets this when the weapon fires or depletes.
    return if GSH4AState.instance_variable_get(:@hw_activated)

    # Back off 30 s after a confirmed beseech failure (not a warded-spell "nothing happens").
    return unless GSH4AState.cd_ready?("holy_weapon_beseech_backoff")

    cmd = case mode
          when "per_attack" then "beseech my #{noun} ignite"
          when "per_target" then "beseech my #{noun} conserve"
          else                   "beseech my #{noun}"
          end
    # Do NOT include "nothing happens" here -- warded spell output can bleed into this
    # capture window and falsely trigger the backoff. Depletion is handled by the watcher.
    result = dothistimeout(cmd, 5, /ignit|conserv|bless|already armed|arming|weapon glows|beseech.*fail|cannot/i)
    if result.nil?
      # Timeout -- server may be slow; don't back off, just skip this cycle.
      return
    end
    if result =~ /beseech.*fail|cannot/i
      log "Holy weapon beseech failed -- backing off 30s"
      GSH4AState.set_cd("holy_weapon_beseech_backoff", 30)
      return
    end
    GSH4AState.instance_variable_set(:@hw_activated, true)
  end

  def self.start_holy_weapon_watcher
    return unless holy_weapon_enabled?
    return if @holy_weapon_watcher_active

    @holy_weapon_watcher_active = true
    depletion_pattern = /no longer infused|glows faintly and then darkens|charges have been expended|try to draw on the power of/i
    fired_pattern     = /leaping tongues of holy fire|holy fire.*damage|bursts alight.*holy/i

    DownstreamHook.add("gsh4a_holy_weapon_watcher", proc { |line|
      stripped = line.gsub(/<[^>]+>/, "")
      if stripped =~ depletion_pattern
        GSH4AState.instance_variable_set(:@hw_activated, false)
        unless @hw_depleted
          @hw_depleted = true
          respond "[gsh4a] Holy weapon depleted -- will refill at next hunt start"
        end
      elsif stripped =~ fired_pattern
        # Weapon fired -- needs re-arming before next swing (per_attack mode).
        GSH4AState.instance_variable_set(:@hw_activated, false)
      end
      line
    })
  end

  def self.stop_holy_weapon_watcher
    @holy_weapon_watcher_active = false
    DownstreamHook.remove("gsh4a_holy_weapon_watcher") rescue nil
  end

  # ---------------------------------------------------------------------------
  # Emergency handler
  # ---------------------------------------------------------------------------
  # Handles all mid-combat emergencies: standing, status removal, low health retreat,
  # and low mana retreat. Called every iteration of the main and inner combat loops.
  # May set GSH4AState.hunting = false and stop the script if retreat is triggered.
  #
  # @return [void]
  def self.monitor_emergencies
    # Stand up immediately -- no RT wait; re-fires next cycle if still rejected
    emergency_stand unless standing?

    stunned  = stunned?
    webbed   = webbed?
    bound    = bound?
    in_rt    = (checkrt rescue 0).to_i

    hp_pct        = percenthealth rescue 100
    retreat_pct   = pref("health_retreat_pct").to_i
    low_health_pct = pref("low_health_pct").to_i
    low_health_pct = [low_health_pct, retreat_pct + 5].max  # must be above retreat threshold

    # CC'd: physical stun/web/bind, movement roots, or immobile prompt.
    # Casting debuffs (Mystic Impedance, Silence) do NOT trigger -- Beseech can't remove them.
    # XMLData.prompt includes "I" for ANY source of immobility (monster entangle, fear effects,
    # etc.) that doesn't match the specific webbed?/bound? debuff names Lich tracks.
    # 1635 BESEECH (emergency_status) fires for removable CC (stun/web/bind) and roots.
    # Casting debuffs (Mystic Impedance, Silence) are intentionally excluded -- Beseech
    # can't remove them and triggering the CC block for them wastes the response.
    # Battle standard fires only if 1635 is unavailable (mana, cooldown, etc.).
    # Response fires ONCE per debuff occurrence then retries every 5s in case the first attempt
    # was silently rejected (e.g. "can't move to activate item" while entangled).
    immobile_prompt = (XMLData.prompt.to_s.include?("I") rescue false)
    cc_removable = stunned || webbed || bound
    cc_active    = cc_removable || movement_blocked? || immobile_prompt
    if cc_active
      if @cc_responded && (Time.now.to_i - (@cc_responded_at ||= 0)) > 5
        @cc_responded = false
      end
      unless @cc_responded
        # When charmed (Sympathy), all actions fail -- skip but don't set @cc_responded
        # so the response fires once charm clears and we're still CC'd.
        unless sympathy_active?
          builtin_handled = run_abilities_when("emergency_status")
          run_cc_priorities unless builtin_handled
          demon_fetch_weapon
          servant_fetch_weapon
          # Only use Incarnate Armor if beseech didn't fire -- beseech breaks CC directly.
          check_incarnate_armor_emergency(stunned, in_rt) unless builtin_handled
          @cc_responded = true
          @cc_responded_at = Time.now.to_i
        end
      end
    else
      @cc_responded = false
      @cc_responded_at = 0
    end

    # Wound-triggered retreat: checked FIRST so a pending escape suppresses all healing below.
    # attempt_escape sets hunting=false; the return below then skips low_health/feeble/etc.
    if wound_retreat_triggered?
      unless @wound_retreat_responded
        log "Wound threshold reached -- stopping combat and retreating"
        attempt_escape("Injury (wound threshold)")
        @wound_retreat_responded = true
      end
    else
      @wound_retreat_responded = false
    end
    return unless GSH4AState.hunting

    # low_health: fires once per dip below threshold; resets when HP recovers above it
    if hp_pct < low_health_pct
      unless @low_health_responded
        run_low_health_priorities
        @low_health_responded = true
      end
    else
      @low_health_responded = false
    end

    # Feeble: cast Wall of Force once per occurrence; resets when debuff clears
    if feeble_active?
      check_wof_feeble unless @feeble_responded
      @feeble_responded = true
    else
      @feeble_responded = false
    end

    # Overexerted: stamina fully depleted -- escape to saferoom immediately (solo only)
    # In grouped mode, stay and fight through it -- the group keeps you alive.
    if overexerted? && !(@group_members_cache&.any? || (XMLData.group_members rescue []).any?)
      unless @overexerted_responded
        log "Overexerted -- stopping combat and retreating to safe room"
        attempt_escape("Overexerted")
        @overexerted_responded = true
      end
    else
      @overexerted_responded = false
    end
    return unless GSH4AState.hunting

    check_society_escape  # society escape ability; fires if health < user-set threshold
    return unless GSH4AState.hunting

    pct = percenthealth rescue 100
    if pct < retreat_pct
      demon_fetch_weapon
      servant_fetch_weapon
      handle_health_retreat(pct)
    end

    mana_ret_pct = (pref("mana_retreat_pct") || 0).to_i
    if mana_ret_pct > 0
      mana_pct = begin
        mm = maxmana.to_f
        mm > 0 ? (checkmana.to_f / mm * 100).to_i : 100
      rescue
        100
      end
      if mana_pct < mana_ret_pct
        if @group_members_cache&.any? || (XMLData.group_members rescue []).any?
          log "Mana at #{mana_pct}% -- threshold reached but grouped; skipping retreat"
        else
          do_retreat("Mana at #{mana_pct}% (below #{mana_ret_pct}% threshold)")
        end
      end
    end
    return unless GSH4AState.hunting

    dread_cfg = pref("dread") rescue {}
    if dread_cfg.is_a?(Hash) && dread_cfg.fetch("enabled", false)
      creep_thresh = dread_cfg.fetch("creeping_threshold", 20).to_i
      crush_thresh = dread_cfg.fetch("crushing_threshold", 15).to_i
      creep = @creeping_dread.to_i
      crush = @crushing_dread.to_i
      if (creep >= creep_thresh || crush >= crush_thresh) && !(@group_members_cache&.any? || (XMLData.group_members rescue []).any?)
        unless @dread_retreat_responded
          @dread_retreat_responded = true
          attempt_dread_escape
        end
      else
        @dread_retreat_responded = false
      end
    end
  end

  def self.check_incarnate_armor_emergency(stunned, in_rt)
    pal = @profile["paladin_spells"] || {}
    return unless pal["incarn_armor_emergency"]
    return if sympathy_active?
    rt_thresh = pal["incarn_armor_rt_threshold"].to_i
    return unless stunned && in_rt >= rt_thresh && rt_thresh > 0
    key = "pal_1650_armor_emerg"
    dl  = pal["incarn_armor_daily_limit"].to_i
    return unless dl == 0 || GSH4AState.daily_ok?(key, dl)
    return unless GSH4AState.cd_ready?(key)
    log "Paladin INCARNATE ARMOR: stunned + RT #{in_rt}s >= threshold #{rt_thresh}s -- firing"
    fput "incarnate armor"
    GSH4AState.set_cd(key, 300)
    GSH4AState.use_daily(key) if dl > 0
  end

  def self.do_retreat(reason)
    # Thin fallback used by mana watcher; escape_priority is authoritative for room
    warn "#{reason} -- stopping script"
    GSH4AState.hunting = false
    room = (Array(pref("escape_priority")).find { |e| e.is_a?(Hash) && e["type"] == "saferoom" } || {})["room"].to_s.strip
    room = pref("retreat_room").to_s.strip if room.empty?
    unless room.empty?
      start_script "go2", [room]
      sleep 0.5 while Script.running?("go2")
      log "Arrived at safe room. Restart the script when ready to resume."
    end
    stop_script "gshunting4all" rescue nil
  end

  def self.handle_health_retreat(pct)
    if @group_members_cache&.any? || (XMLData.group_members rescue []).any?
      log "Health at #{pct}% -- threshold reached but grouped; skipping retreat"
      return
    end
    attempt_escape("Health at #{pct}%")
  end

  # ---------------------------------------------------------------------------
  # Background watchers
  # ---------------------------------------------------------------------------
  def self.start_movement_debuff_watcher
    DownstreamHook.remove("gsh4a_movement_debuff_watcher") rescue nil
    DownstreamHook.add("gsh4a_movement_debuff_watcher", proc { |line|
      if line.gsub(/<[^>]+>/, "") =~ /don't seem to be able to move your legs/i
        GSH4AState.set_cd(:cant_stand, 3)
      end
      line
    })
  end

  def self.start_prone_watcher
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          unless standing?
            if GSH4AState.cd_ready?(:cant_stand)
              waitrt?
              fput "stand" rescue nil
              pause 0.5
            end
          end
        rescue; end
        pause 0.2
      end
    end
  end

  def self.start_mount_watcher
    return unless has_mount?
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          GSH4AState.mounted = !!XMLData.riding
        rescue; end
        pause 1
      end
    end
  end

  def self.start_group_watcher
    # GemStone sends messages when group status changes -- refresh our cache on any of them
    DownstreamHook.remove("gsh4a_group_watcher") rescue nil
    DownstreamHook.add("gsh4a_group_watcher", proc { |line|
      stripped = line.gsub(/<[^>]+>/, "").strip
      if stripped =~ /joins your group|has joined your group|leaves your group|left your group|you join|you leave/i
        script = Script.current
        Thread.new { Thread.current[:script] = script; refresh_group_members }
      end
      line
    })
  end

  def self.start_death_watcher
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          if (XMLData.dead rescue false)
            warn "You have died -- stopping script"
            GSH4AState.hunting = false
            stop_script "gshunting4all" rescue nil
            break
          end
        rescue; end
        pause 3
      end
    end
  end

  def self.start_encumbrance_watcher
    return if pref("encumbrance_ignore")
    threshold = pref("encumbrance_retreat_pct").to_i
    return if threshold <= 0
    Thread.new do
      pause 30  # let startup complete before first encumbrance check
      loop do
        break unless GSH4AState.hunting
        begin
          actually_grouped = (@group_members_cache&.any? || (XMLData.group_members rescue []).any?)
          unless actually_grouped
            enc_line = ""
            DownstreamHook.remove("gsh4a_enc_tmp") rescue nil
            DownstreamHook.add("gsh4a_enc_tmp", proc { |line|
              enc_line += line.gsub(/<[^>]+>/, "")
              line
            })
            fput "encumbrance"
            sleep 1.5
            DownstreamHook.remove("gsh4a_enc_tmp") rescue nil
            if enc_line =~ /(\d+)%/
              pct = $1.to_i
              if pct >= threshold
                warn "Encumbrance at #{pct}% -- exceeds threshold of #{threshold}%"
                attempt_escape("Encumbrance too high (#{pct}%)")
                break
              end
            end
          end
        rescue; end
        pause 300
      end
    end
  end

  # ---------------------------------------------------------------------------
  # Injury watcher -- detects when wounds prevent combat actions
  # ---------------------------------------------------------------------------

  # Returns true when @injury_blocked is set by the downstream watcher, OR when any
  # body part has a wound at level 2+ (moderate or worse). Level 2 = heavy bleeding /
  # serious wound; we retreat rather than fight through it regardless of location.
  # checkwounds: 0=none, 1=minor, 2=moderate, 3=severe. Indices 0-10 cover all standard
  # body parts (head, neck, chest, abdomen, back, arms, legs, eyes).
  # @return [Boolean]
  def self.combat_injured?
    return true if @injury_blocked
    [
      Wounds.head, Wounds.neck, Wounds.rightEye, Wounds.leftEye,
      Wounds.chest, Wounds.back, Wounds.abdomen,
      Wounds.rightArm, Wounds.leftArm, Wounds.rightHand, Wounds.leftHand,
      Wounds.rightLeg, Wounds.leftLeg, Wounds.nerves
    ].any? { |w| w >= 2 }
  rescue
    false
  end

  # True only when the Grouped mode master toggle is enabled on Hunting Preferences.
  # Controls wound retreat suppression only -- all other grouped behavior (health/mana/dread/
  # encumbrance retreat suppression, eloot mode, go2 suppression) uses group_members_cache.
  def self.effectively_grouped?
    pref("grouped_mode") rescue false
  end

  # Returns true if per-body-part wound retreat config says we should escape.
  # Respects the "retreat_when_grouped" opt-in -- returns false if grouped and opt-in is off.
  def self.wound_retreat_triggered?
    return false if effectively_grouped?
    return true if @injury_blocked
    wr = pref("wound_retreat") rescue {}
    return false unless wr.is_a?(Hash)
    return true if WOUND_BODY_PARTS.any? { |key, meth, _l, _d|
      thresh = wr.fetch(key, 0).to_i
      thresh > 0 && (Wounds.send(meth) rescue 0) >= thresh
    }

    if wr.fetch("combo_enabled", false)
      combo_score  = wr.fetch("combo_score", 7).to_i
      wound_total  = WOUND_BODY_PARTS.sum { |_k, meth, _l, _d| (Wounds.send(meth) rescue 0) }
      return true if wound_total >= combo_score
    end

    false
  rescue
    false
  end

  # Watches downstream for messages indicating wounds are blocking attacks or spells.
  # When detected: sets @injury_blocked, stops all offense, and triggers emergency escape.
  # The escape runs in a Thread to avoid deadlocking the DownstreamHook.
  def self.start_injury_watcher
    @injury_blocked = false
    DownstreamHook.remove("gsh4a_injury_watcher") rescue nil
    DownstreamHook.add("gsh4a_injury_watcher", proc { |line|
      next line if @injury_blocked
      clean = line.gsub(/<[^>]+>/, "").strip
      if clean =~ /too injured to|wounds? prevent|your .+? (?:arm|hand) is (?:too injured|useless)|
                   unable to (?:gesture|concentrate|focus) (?:properly |effectively )?(?:due to|because of|with) (?:your )?(?:wounds?|injur)/ix
        # Only retreat when a limb wound is rank 3 (Severe/Useless -- max in Lich API).
        severe = begin
          Wounds.rightArm >= 3 || Wounds.leftArm >= 3 ||
          Wounds.rightHand >= 3 || Wounds.leftHand >= 3
        rescue; false; end
        next line unless severe
        @injury_blocked = true
        Thread.new do
          begin
            log "Wounds are blocking combat actions -- retreating immediately"
            GSH4AState.hunting = false
            pause 0.5
            check_society_escape_by_injury
          rescue => e
            warn "Injury retreat error: #{e.message}"
          end
        end
      end
      line
    })
  end

  # Like check_society_escape but fires unconditionally on health -- used when
  # wounds prevent combat regardless of current HP percentage.
  def self.check_society_escape_by_injury
    return if dead?
    attempt_escape("Wounds preventing combat")
  end

  # @return [void]
  def self.stop_injury_watcher
    DownstreamHook.remove("gsh4a_injury_watcher") rescue nil
    @injury_blocked = false
  end

  # ---------------------------------------------------------------------------
  # Disarm watcher -- recovers a flying weapon with spell 119 (Telekinesis)
  # ---------------------------------------------------------------------------

  # Watches for weapon-disarm messages and casts spell 119 to recover the weapon.
  # Only fires if Spell[119] is known and mana is available.
  # @return [Boolean] true if the primary weapon noun is in either hand
  def self.weapon_in_hand?
    noun = @profile.dig("weapons", "primary", "noun").to_s.downcase.strip
    return true if noun.empty?
    rh = (GameObj.right_hand rescue nil)
    lh = (GameObj.left_hand  rescue nil)
    [rh, lh].compact.any? { |obj| obj.name.to_s.downcase.include?(noun) }
  end

  # Watches downstream for Creeping Dread / Crushing Dread stack updates.
  # GS4 sends debuff component lines containing e.g. "Creeping Dread (24)".
  # Counts are stored in @creeping_dread / @crushing_dread and checked in monitor_emergencies.
  def self.start_dread_watcher
    @creeping_dread = 0
    @crushing_dread = 0
    @dread_retreat_responded = false
    DownstreamHook.remove("gsh4a_dread_watcher") rescue nil
    DownstreamHook.add("gsh4a_dread_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      if clean =~ /creeping dread \((\d+)\)/i
        @creeping_dread = $1.to_i
      end
      if clean =~ /crushing dread \((\d+)\)/i
        @crushing_dread = $1.to_i
      end
      # Reset counts when debuff lines no longer appear (component cleared)
      if clean =~ /<component id=['"]exp Debuffs['"]/i
        @creeping_dread = 0 unless clean =~ /creeping dread/i
        @crushing_dread = 0 unless clean =~ /crushing dread/i
      end
      line
    })
  end

  def self.stop_dread_watcher
    DownstreamHook.remove("gsh4a_dread_watcher") rescue nil
    @creeping_dread = 0
    @crushing_dread = 0
    @dread_retreat_responded = false
  end

  def self.attempt_dread_escape
    return if dead?
    creep = @creeping_dread.to_i
    crush = @crushing_dread.to_i
    log "Dread too high (Creeping: #{creep}, Crushing: #{crush}) -- retreating to library (room 32469). Restart when ready."
    GSH4AState.hunting = false
    waitrt?
    fput "stance defensive"
    start_script "go2", ["32469"]
    sleep 0.5 while Script.running?("go2")
  end

  # ---------------------------------------------------------------------------
  # Health escape watcher -- fires society escape even during roundtime
  # ---------------------------------------------------------------------------

  # Polls health every 0.3s and fires the society escape ability the moment
  # health drops below the configured threshold, regardless of main loop state.
  # This catches rapid burst damage that kills faster than the loop can cycle.
  def self.start_health_escape_watcher
    @health_escape_thread&.kill rescue nil
    @deferred_escape = false
    @health_escape_thread = Thread.new do
      loop do
        # Keep running while hunting OR while a deferred escape is pending --
        # hunting is cleared by check_society_escape immediately on health drop,
        # but we must keep retrying until the hard-RT incapacitation clears.
        break unless GSH4AState.hunting || @deferred_escape
        begin
          break if dead?
          hp = percenthealth rescue 100
          if @deferred_escape
            # A prior escape attempt was blocked (stun, charm, etc.) -- bypass the HP
            # gate and retry directly so wound-triggered escapes fire once the block clears,
            # even if HP has since recovered above the retreat threshold.
            attempt_escape("Deferred escape")
          elsif hp < pref("health_retreat_pct").to_i
            check_society_escape
          end
        rescue; end
        pause 0.3
      end
    end
  end

  # @return [void]
  def self.stop_health_escape_watcher
    @health_escape_thread&.kill rescue nil
    @health_escape_thread = nil
    @deferred_escape = false
  end

  # ---------------------------------------------------------------------------
  # Disarm watcher -- flying weapon (spell 119 / GET) and normal disarm (RECOVER ITEM)
  # ---------------------------------------------------------------------------

  def self.start_disarm_watcher
    @disarm_thread&.kill rescue nil
    @disarm_thread = nil
    @weapon_disarmed = false
    DownstreamHook.remove("gsh4a_disarm_watcher") rescue nil

    wr          = @profile.dig("weapons", "recovery") || {}
    use_119     = wr.fetch("use_119",     false)
    use_recover = wr.fetch("use_recover", false)
    return unless use_119 || use_recover

    noun = @profile.dig("weapons", "primary", "noun").to_s.strip.downcase
    return if noun.empty?

    DownstreamHook.add("gsh4a_disarm_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "").strip
      if use_119 && clean =~ /Your (.+?) tears free from your hands and floats/i
        flying_noun = $1.to_s.split.last
        if @disarm_thread.nil? || !@disarm_thread.alive?
          @weapon_disarmed = true
          @disarm_thread = Thread.new { recover_flying_weapon(flying_noun) }
        end
      elsif use_recover && clean =~ /knocked from your grasp and out of sight/i
        if @disarm_thread.nil? || !@disarm_thread.alive?
          @disarm_thread = Thread.new { recover_normal_disarm(noun) }
        end
      end
      line
    })
  end

  def self.stop_disarm_watcher
    DownstreamHook.remove("gsh4a_disarm_watcher") rescue nil
    @disarm_thread&.kill rescue nil
    @disarm_thread = nil
    @weapon_disarmed = false
  end

  # ---------------------------------------------------------------------------
  # Ecleanse yield watcher -- pauses attack cycle while ecleanse is casting
  # ---------------------------------------------------------------------------

  def self.start_ecleanse_yield_watcher
    @ecleanse_busy_until = 0.0
    DownstreamHook.remove("gsh4a_ecleanse_yield") rescue nil
    DownstreamHook.add("gsh4a_ecleanse_yield", proc { |line|
      @ecleanse_busy_until = Time.now.to_f + 3.0 if line =~ /\[ecleanse\]>/
      line
    })
  end

  def self.stop_ecleanse_yield_watcher
    DownstreamHook.remove("gsh4a_ecleanse_yield") rescue nil
    @ecleanse_busy_until = 0.0
  end

  def self.ecleanse_busy?
    Time.now.to_f < @ecleanse_busy_until.to_f
  end

  def self.recover_flying_weapon(noun)
    begin
      unless (Spell[119].known? rescue false)
        log "Spell 119 not known -- cannot recover flying #{noun}; attempting re-ready"
        sleep 0.1 while (checkrt rescue 0) > 0
        put "ready weapon"
        return
      end
      return if dead?
      return unless (mana rescue 0) >= 10
      log "Weapon flying -- casting 119 to recover #{noun}"
      # Use put+sleep instead of fput: fput calls waitfor internally which requires
      # the main script fiber and raises "Unable to identify calling script" in threads.
      sleep 0.1 while (checkrt rescue 0) > 0
      return if dead?
      put "prep 119"
      sleep 0.5  # give the server time to register the prep before polling castrt
      sleep 0.1 while (checkcastrt rescue 0) > 0
      return if dead?
      put "cast #{noun}"
      sleep 3    # weapon return takes ~1-2s; wait for animation + ready
      put "ready weapon" unless weapon_in_hand?
    rescue => e
      warn "Flying weapon recovery error: #{e.message}"
    ensure
      @weapon_disarmed = false
    end
  end

  def self.recover_normal_disarm(noun)
    pause 5.0  # bond tier 5 auto-return window
    return if weapon_in_hand?
    log "Weapon disarmed -- attempting recovery"
    servant_fetch_weapon
    demon_fetch_weapon
    return if weapon_in_hand?
    pause 0.1 while (checkrt rescue 0) > 0
    fput "stow"
    fput "stow left"
    pause 0.1 while (checkrt rescue 0) > 0
    fput "kneel"
    pause 0.1 while (checkrt rescue 0) > 0
    fput "recover #{noun}"
    pause 0.1 while (checkrt rescue 0) > 0
    fput "stand"
    pause 0.5
  rescue; end

  # ---------------------------------------------------------------------------
  # Single-target rotation
  # ---------------------------------------------------------------------------
  # Runs the full combat loop against a single target until it dies or a break condition fires.
  # Handles stance, mount, AoE check, berserk, stun maneuver, assault techniques,
  # ranged/melee/runestaff rotation, and all emergency/pause guards per swing.
  #
  # @param target [GameObj] the hostile NPC to attack
  # @return [void]
  def self.single_target_rotation(target)
    return unless target
    id = target.id
    @weapon_rot_idx = 0
    @weapon_aoe_rot_idx = 0

    stand_if_prone
    ensure_mounted
    mount_charge(id) unless weapon_rotation_active? || spell_rotation_active?
    return unless hostile_npcs.any? { |n| n.id == id }
    # per_attack mode fires beseech inside the loop before every swing -- skip here
    # to avoid a double-beseech on the first iteration.
    beseech_holy_weapon unless holy_weapon_cfg.fetch("mode", "per_target") == "per_attack"

    while target_alive?(target)
      break unless GSH4AState.hunting
      break if dead?
      # Break immediately if target left the room (moved or died out of sight)
      break unless hostile_npcs.any? { |n| n.id == id }
      # If a priority creature appeared and we're not already on one, finish this
      # swing then switch -- break so the main loop re-runs select_target.
      unless priority_npc?(target)
        better = priority_npcs.first
        if better && better.id != target.id
          log "Priority target spotted (#{better.noun}) -- switching after this swing"
          break
        end
      end

      if GSH4AState.paused
        monitor_emergencies
        check_holy_weapon_charges
        check_society_maintain
        pause 1
        next
      end

      # monitor_emergencies runs every inner loop iteration so wounds, health, and
      # CC are all caught mid-fight without waiting for the outer loop to resume.
      monitor_emergencies
      break unless GSH4AState.hunting  # retreat may have been triggered above

      # Sympathy (charm) blocks all combat actions -- hold until it clears.
      if sympathy_active?
        pause 0.5
        next
      end

      # Bound/immobile (black ora proc, banshee entangle, etc.) -- CC handler already
      # fired; don't spam rejected attack commands while waiting for the bind to lift.
      if (XMLData.prompt.to_s.include?("I") rescue false)
        pause 0.5
        next
      end

      unless standing?
        if GSH4AState.cd_ready?(:cant_stand)
          stand_if_prone
          next  # wait for standing to take effect
        end
        # movement debuff blocking stand -- attack prone rather than spinning
      end
      ensure_mounted unless GSH4AState.mounted

      unless rt_ok?
        # Health/emergency checks during RT-wait -- without this, retreats and pauses
        # never fire during long knockdown RT since the outer loop doesn't run.
        check_society_escape
        break unless GSH4AState.hunting  # society escape sets hunting=false
        hp_pct = percenthealth rescue 100
        handle_health_retreat(hp_pct) if hp_pct < pref("health_retreat_pct").to_i
        break if dead?
        break unless GSH4AState.hunting
        if dead_player_present? && !GSH4AState.paused
          GSH4AState.paused = true
          respond "[gsh4a] PAUSED -- dead player detected in room. Type RESUME when ready to continue."
        end
        stance_guarded
        pause 0.5
        next
      end

      count = npc_count

      # Stun Maneuver fires first -- rogue acts through the stun before anything else
      next if check_stun_maneuver

      # Warrior berserk: suspend normal attacks while raging; enter berserk if enabled
      next if prof =~ /Warrior/i && check_berserk(id)

      primary_wpn  = @profile.dig("weapons", "primary") || {}
      primary_grip = primary_wpn["grip"].to_s
      next if primary_wpn["enabled"] == false
      is_runestaff = primary_grip == "runestaff"

      # AoE techniques when enough foes are present.
      # Runestaff casters skip weapon technique firing entirely -- no melee techniques.
      if weapon_rotation_active?
        execute_weapon_aoe_step(id) if aoe_needed?
      elsif !is_runestaff
        next if fire_aoe_techniques(count)
      end

      run_arcarium_moment("aoe", id) if aoe_needed?
      if !gigas_present? && npc_count >= (pref("swarm_threshold") || SWARM_THRESHOLD_DEFAULT).to_i
        run_arcarium_moment("swarm", id)
        run_abilities_when("swarm", id)
      end
      run_arcarium_moment("target_vulnerable", id)
      run_abilities_when("per_attack", id)
      run_abilities_when("boss", id) if boss_target?(id)
      # Runestaff casters do not fire attack CMans -- they have no melee attack cycle.
      cmans_of_type("attack").each { |c| fire_cman(c, id) } unless is_runestaff
      beseech_holy_weapon if holy_weapon_cfg.fetch("mode", "per_target") == "per_attack"
      companion_attack(id)

      if primary_grip == "ranged" || primary_grip == "thrown"
        # Ranged/thrown weapons: no assault techniques, no melee rotation
        ranged_attack(id)
      elsif is_runestaff
        # Runestaff/caster: stay guarded, spell rotation handles all attacks.
        # No melee swing fallback -- if rotation is empty the character simply waits.
        walk_rotation(id)
        waitrt? unless rt_ok?
      else
        # Melee: always go offensive before any attack action
        p = prof

        # Flying weapon recovery in progress -- block ALL combat commands, not just
        # weapon-based ones, to prevent attacks from cancelling the 119 prep.
        # Checked before weapon_in_hand? because that value may be stale for 1-2
        # iterations right after the disarm event fires.
        if @weapon_disarmed
          pause 0.5
          next
        end

        # Skip all weapon-based actions if primary weapon is not in hand
        unless weapon_in_hand?
          log "Weapon not in hand -- re-readying"
          fput "ready weapon"
          pause 1
          next
        end

        if p =~ /Warrior/i
          fire_war_cries(id)
          check_warrior_tricks(id)
        end
        next if p =~ /Rogue/i && check_silent_strike(id)
        if weapon_rotation_active?
          execute_weapon_rotation_step(id)
        else
          stance_offensive
          unless fire_assault_techniques
            spell_fired = walk_rotation(id)
          waitcastrt? if spell_fired
          unless spell_fired
              sync_mount_state
              waitrt?; waitcastrt?
              wpn_cfg = @profile.dig("weapons", "primary") || {}
              loc     = wpn_cfg["target_location"].to_s.strip
              amb     = @profile.dig("weapons", "ambush") || {}
              if amb["enabled"]
                if amb["hide_first"]
                  fput "hide"
                  pause 1
                end
                target_noun = (GameObj[id]&.noun rescue nil) || id.to_s
                fput loc.empty? ? "ambush #{target_noun}" : "ambush #{target_noun} #{loc}"
              else
                fput loc.empty? ? "attack ##{id}" : "attack ##{id} #{loc}"
              end
              waitrt?
            end
          end
        end
      end
    end

    # reaction thread discards naturally when npc_count == 0 check fires
    @companion_last_target_id = nil  # companion will need new attack directive for next target
    sync_mount_state
    if GSH4AState.hunting
      fire_shield_specs
      fire_armor_specs
      mount_trample if GSH4AState.mounted && !weapon_rotation_active?
      stance_restore
    end
  end

  # ---------------------------------------------------------------------------
  # Eloot
  # ---------------------------------------------------------------------------
  def self.run_eloot
    # Use the grouped eloot setting whenever actually in a group, regardless of the
    # Grouped Mode master toggle (which controls hunting/retreat behavior, not looting).
    actually_grouped = (@group_members_cache&.any? || (XMLData.group_members rescue []).any?)
    if actually_grouped
      return unless pref("eloot_grouped") == "run"
    else
      return unless pref("use_eloot")
    end
    strangers = (GameObj.pcs || []).reject { |pc| in_my_group?(pc_first_name(pc.name)) rescue false }
    if strangers.any?
      log "Skipping eloot -- non-group player(s) in room: #{strangers.map(&:name).join(', ')}"
      return
    end
    start_script "eloot"
    pause 0.1 while Script.running?("eloot") rescue nil
  rescue; end

  def self.loot_dead_npcs
    dead = (GameObj.npcs || []).select { |n| n.status =~ /dead|decaying/i rescue false }
    return if dead.empty?
    run_eloot
  end

  # ---------------------------------------------------------------------------
  # Status display
  # ---------------------------------------------------------------------------
  def self.show_status
    log "=== GSHunting4All Status ==="
    all_abilities.each do |ab|
      key   = ability_key(ab)
      cd    = ab["cd"].to_i
      ready = cd == 0 ? "always" : (GSH4AState.cd_ready?(key) ? "READY" : "cooling down")
      log "  #{ab['_script']} #{ab['key'].upcase} (#{ab['when']}) -- #{ready}"
    end
    log "  Mounted: #{GSH4AState.mounted}"
    log "  Paused:  #{GSH4AState.paused}"
  end

  # ---------------------------------------------------------------------------
  # Main run
  # ---------------------------------------------------------------------------
  def self.run
    load_profile
    GSH4AState.load_state

    UpstreamHook.add("gsh4a_pause", proc { |input|
      begin
        bare = input.to_s.chomp.strip.sub(/\A<c>/i, "").downcase
        if bare == "pause"
          GSH4AState.paused = true
          echo "[gsh4a] PAUSED -- type RESUME to continue"
          nil
        elsif bare == "resume"
          GSH4AState.paused = false
          echo "[gsh4a] RESUMED"
          nil
        else
          input
        end
      rescue => _e
        input
      end
    })

    # Detect gemstones
    if @profile.dig("gemstones", "auto_detect")
      log "Detecting gemstones..."
      fput "gemstone slot"
      pause 1
    end

    # Activate arcarium vissi tagged as "maintenance" (fire once at hunt start)
    run_arcarium_moment("maintenance")

    GSH4AState.crossbow_loaded  = false
    GSH4AState.ranged_kneeling  = false
    maintain_sonic_songs
    maintain_ranger_companion
    cast_maintain_spells
    run_toggle_startups
    run_abilities_when("maintenance")
    fput "look" if has_mount?
    summon_mount if has_mount?
    ready_weapons

    apply_society_maintain_startup
    warn_missing_spells

    if holy_weapon_enabled?
      @hw_depleted = false
      infuse_holy_weapon
      beseech_holy_weapon unless holy_weapon_cfg.fetch("mode", "per_target") == "per_attack"
    end

    start_reaction_watcher
    start_technique_cd_watcher
    start_uac_watcher
    start_mount_cd_watcher
    start_stun_watcher
    start_berserk_watcher
    start_holy_weapon_watcher
    start_mount_watcher
    start_movement_debuff_watcher
    start_prone_watcher
    start_death_watcher
    start_encumbrance_watcher
    start_group_watcher
    start_dread_watcher
    start_health_escape_watcher
    start_disarm_watcher
    start_ecleanse_yield_watcher
    start_injury_watcher

    # Room title tracker -- captures the trailing number from room title lines
    # (e.g. "[Moonsedge Castle, Chapel - 32464]") for areas where XMLData.room_id is nil.
    @detected_room_num = nil
    DownstreamHook.remove("gsh4a_room_title_tracker") rescue nil
    DownstreamHook.add("gsh4a_room_title_tracker", proc { |line|
      stripped = line.gsub(/<[^>]+>/, "")
      @detected_room_num = $1 if stripped =~ /\[.*?[-\s](\d{4,6})\s*\]/
      line
    })

    # Pause gsh4a whenever eloot pauses for a storage failure so the player
    # can handle it manually before typing RESUME to continue.
    DownstreamHook.remove("gsh4a_eloot_pause_watcher") rescue nil
    DownstreamHook.add("gsh4a_eloot_pause_watcher", proc { |line|
      if line.gsub(/<[^>]+>/, "") =~ /Lich: eloot paused|Pausing the script to handle it yourself/i
        unless GSH4AState.paused
          GSH4AState.paused = true
          echo "[gsh4a] PAUSED -- eloot needs attention. Type RESUME when done."
        end
      end
      line
    })

    refresh_group_members

    @cc_responded           = false
    @low_health_responded   = false
    @feeble_responded       = false
    @overexerted_responded  = false
    @wound_retreat_responded = false
    @weapon_rot_idx       = 0
    @weapon_aoe_rot_idx   = 0
    @combat_start_unlocked = pref("combat_start_room").to_s.strip.empty?

    if pref("run_ecleanse")
      unless Script.running?("ecleanse")
        start_script "ecleanse"
        log "Ecleanse started."
      end
    end

    group_info = @group_members_cache&.any? ? "Grouped with: #{@group_members_cache.join(', ')}" : "Solo"
    log "Ready -- #{GSH4AState.mounted ? 'mounted' : 'unmounted'} | #{group_info}"

    csr = pref("combat_start_room").to_s.strip
    unless csr.empty?
      current = [(XMLData.room_id rescue nil).to_s, @detected_room_num.to_s]
      unless current.include?(csr)
        if @group_members_cache&.any? || (XMLData.group_members rescue []).any?
          # In a group, follow the leader -- don't navigate independently.
          # Combat stays locked until the group arrives at the CSR naturally.
          log "Grouped -- waiting for group leader to reach combat start room #{csr} before entering combat loop"
        else
          log "Navigating to combat start room #{csr} via go2..."
          start_script "go2", [csr]
          pause 1
          pause 0.5 while Script.running?("go2") && GSH4AState.hunting
          log "Arrived at combat start room -- entering combat loop"
          @combat_start_unlocked = true
          @last_room_id = nil
        end
      end
    end

    log "Entering combat loop"

    loop do
      break unless GSH4AState.hunting
      break if Script.current.nil? rescue false
      break if dead?

      monitor_emergencies
      break unless GSH4AState.hunting  # handle_health_retreat may have set this false
      break if dead?

      # Hold combat while go2 is navigating (in case go2 is started after hunt begins)
      if Script.running?("go2")
        log "go2 started mid-hunt -- holding combat until travel completes" unless @go2_hold_logged
        @go2_hold_logged = true
        pause 0.5
        next
      elsif @go2_hold_logged
        @go2_hold_logged = false
        log "go2 finished -- resuming combat at current room"
        @last_room_id = nil  # force fresh room-entry snapshot
        next
      end

      # Auto-pause if a dead player is present so the user can assist them
      if pref("pause_on_dead_player") && dead_player_present? && !GSH4AState.paused
        GSH4AState.paused = true
        respond "[gsh4a] PAUSED -- dead player detected in room. Type RESUME when ready to continue."
      end

      if GSH4AState.paused
        pause 1
        next
      end

      if sympathy_active?
        pause 1
        next
      end

      if ecleanse_busy?
        pause 0.2
        next
      end

      npcs = hostile_npcs

      # Snapshot stranger presence on room entry only -- players who walk in after
      # we arrive do not trigger the hold (we were here first).
      current_room_id = XMLData.room_id rescue nil
      if current_room_id && current_room_id != @last_room_id
        @last_room_id        = current_room_id
        @holding_for_player  = false
        @combat_engaged      = false
        # Wait for room description XML to finish streaming so GameObj.pcs is
        # populated before we decide whether a stranger was here first.
        pause 0.5
        @stranger_on_arrival = !room_clear?
        if @stranger_on_arrival
          reason = hidden_player_present? ? "hidden player" : "non-grouped player"
          log "#{reason.capitalize} already in room on arrival -- holding attacks"
        end
      end

      if @stranger_on_arrival
        unless room_clear?
          pause 2
          next
        end
        log "Room clear -- resuming attacks"
        @stranger_on_arrival = false
      end

      if SANCTUARY_ROOMS.include?(XMLData.room_id)
        pause 2
        next
      end

      # Combat start room -- hold all attacks until this room is first entered
      unless @combat_start_unlocked
        csr = pref("combat_start_room").to_s.strip
        if csr.empty?
          @combat_start_unlocked = true
        elsif [(XMLData.room_id rescue nil).to_s, @detected_room_num.to_s].include?(csr)
          @combat_start_unlocked = true
          log "Entered combat start room #{csr} -- combat unlocked"
        else
          pause 2
          next
        end
      end

      loot_dead_npcs

      # Maintenance-only mode: skip all targeting and combat
      if pref("maintenance_only")
        ensure_mounted
        pause 2
        next
      end

      if npcs.empty?
        @combat_engaged = false
        ensure_mounted
        cmans_of_type("maintenance").each { |c| fire_cman(c) }
        pause 1
        next
      end

      @combat_engaged = true
      count     = npcs.length
      target    = select_target
      target_id = target&.id

      cmans_of_type("maintenance").each  { |c| fire_cman(c) }

      run_aoe_phase(target_id) if target_id
      single_target_rotation(target) if target

      run_eloot

      # Stop immediately if hunting was cancelled mid-fight (e.g. wound retreat fired
      # Symbol of Return -- don't reapply buffs after teleporting to the saferoom).
      break unless GSH4AState.hunting

      # Only do maintenance when the room is clear -- skip if a new hostile
      # has already arrived so we loop back to attack immediately.
      if hostile_npcs.empty?
        check_holy_weapon_charges
        check_society_maintain
        check_society_mana
        maintain_sonic_songs
        cast_maintain_spells
        run_abilities_when("maintenance")
      end

      pause 0.5
    rescue => e
      warn "Error in main loop: #{e.message}"
      pause 1
    end

    GSH4AState.hunting = false
    log "Hunt stopped."
  ensure
    if Script.running?("ecleanse")
      Script.kill("ecleanse") rescue nil
      log "Ecleanse stopped."
    end
    UpstreamHook.remove("gsh4a_pause") rescue nil
    stop_reaction_watcher
    stop_uac_watcher
    stop_stun_watcher
    stop_berserk_watcher
    stop_holy_weapon_watcher
    stop_mount_cd_watcher
    stop_technique_cd_watcher
    stop_dread_watcher
    # If a deferred escape is still pending (wound retreat fired while character was
    # bound/immobile -- attempt_escape returned early and set @deferred_escape), give
    # the watcher thread time to retry and fire Symbol of Return now that the bind has
    # cleared. Without this wait, stop_health_escape_watcher kills the thread and the
    # character is left stranded in the combat room.
    if @deferred_escape
      log "Deferred escape pending -- waiting for Symbol of Return to fire..."
      deadline = Time.now + 30
      sleep 0.3 while @deferred_escape && Time.now < deadline
      warn "Deferred escape did not complete within 30s -- may need manual Symbol of Return" if @deferred_escape
    end
    stop_health_escape_watcher
    stop_disarm_watcher
    stop_ecleanse_yield_watcher
    stop_injury_watcher
    # Stand up if we stopped hunting while kneeling (crossbow kneel mode)
    if GSH4AState.ranged_kneeling
      waitrt? rescue nil
      fput "stand" rescue nil
      GSH4AState.ranged_kneeling = false
    end
  end
end

end # module GSH4A

# ===========================================================================
# ENTRY POINT
# ===========================================================================
before_dying do
  GSH4A::GSH4AState.save_state                         rescue nil
  UpstreamHook.remove("gsh4a_pause")                   rescue nil
  GSH4A::Engine.stop_reaction_watcher                  rescue nil
  GSH4A::Engine.stop_uac_watcher                       rescue nil
  GSH4A::Engine.stop_stun_watcher                      rescue nil
  GSH4A::Engine.stop_berserk_watcher                   rescue nil
  GSH4A::Engine.stop_holy_weapon_watcher               rescue nil
  GSH4A::Engine.stop_mount_cd_watcher                  rescue nil
  GSH4A::Engine.stop_technique_cd_watcher              rescue nil
  GSH4A::Engine.stop_dread_watcher                     rescue nil
  GSH4A::Engine.stop_health_escape_watcher             rescue nil
  GSH4A::Engine.stop_disarm_watcher                    rescue nil
  GSH4A::Engine.stop_ecleanse_yield_watcher            rescue nil
  GSH4A::Engine.stop_injury_watcher                    rescue nil
  DownstreamHook.remove("gsh4a_group_watcher")         rescue nil
  DownstreamHook.remove("gsh4a_eloot_pause_watcher")   rescue nil
  DownstreamHook.remove("gsh4a_room_title_tracker")    rescue nil
  UpstreamHook.remove("gsh4a_setup")                   rescue nil
  Script.kill("ecleanse") rescue nil
end

case Script.current.vars[1].to_s.strip.downcase
when /^(setup|reset)$/
  GSH4A::SetupWizard.run
when /^stop$/
  kill_script "gshunting4all"
when /^status$/
  GSH4A::Engine.load_profile rescue nil
  GSH4A::Engine.show_status
else
  GSH4A::Engine.run
end

