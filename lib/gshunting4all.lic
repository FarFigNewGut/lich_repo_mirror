    { name: "Advanced Spell Shielding", cd: 3600,  when: "emergency",   desc: "Dispel resistance -- CD varies by tier (60/30/10 min)" },
    { name: "Arcane Opus",              cd: 60,    when: "per_attack",  desc: "Next bolt spell gains +25% damage factor" },
    { name: "Blood Boil",               cd: 60,    when: "per_attack",  desc: "Deals 20% of target HP per tick (5 ticks)" },
    { name: "Blood Siphon",             cd: 900,   when: "engagement",  desc: "Vampiric aura -- SMR vs 5 enemies, 5-25% dmg restored as HP" },
    { name: "Blood Wellspring",         cd: 3600,  when: "emergency",   desc: "Instantly restore all health -- CD varies by tier (60/40/20 min)" },
