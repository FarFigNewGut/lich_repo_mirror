    { name: "Spirit Wellspring",        cd: 3600,  when: "emergency",   desc: "Instantly restore all spirit -- CD varies by tier (60/40/20 min)" },
    { name: "Stamina Wellspring",       cd: 3600,  when: "emergency",   desc: "Instantly restore all stamina -- CD varies by tier (60/40/20 min)" },
    { name: "Terror's Tribute",         cd: 600,   when: "engagement",  desc: "Summons ethereal undead wall -- pulls and immobilizes enemies -- CD varies by tier (10/5/3 min)" },
    # -- Legendary --
    { name: "Arcane Aegis",             cd: 180,   when: "emergency",   desc: "Mana-draining critical padding shield -- 3 min cooldown" },
    { name: "Arcanist's Ascendancy",    cd: 180,   when: "engagement",  desc: "30s: Casting/Magical SMR = 30% enemy DS -- 3 min cooldown" },
    { name: "Arcanist's Blade",         cd: 180,   when: "engagement",  desc: "30s: +5-25 AS, +3-15% DF; costs 5 mana/stamina per attack -- 3 min cooldown" },
    { name: "Arcanist's Will",          cd: 180,   when: "engagement",  desc: "30s: +3-15 CS, +2-10 endroll; costs 5 mana/stamina -- 3 min cooldown" },
    { name: "Imaera's Balm",            cd: 86400, when: "emergency",   desc: "Instantly heals all wounds and scars -- once per day" },
    { name: "Mana Shield",              cd: 180,   when: "emergency",   desc: "Mana-draining damage padding -- 3 min cooldown" },
    { name: "Reckless Precision",       cd: 90,    when: "engagement",  desc: "30s: -50 DS, attacks 5% less evadable, +5% DF -- 90s cooldown" },
    { name: "Spellblade's Fury",        cd: 180,   when: "engagement",  desc: "60s: +3-15% AS from Spell Aim ranks; costs 10 mana/attack -- 3 min cooldown" },
    { name: "Unearthly Chains",         cd: 180,   when: "engagement",  desc: "Summons ghostly chains to pull and immobilize enemies -- 3 min cooldown" },
    { name: "Witchhunter's Ascendancy", cd: 180,   when: "engagement",  desc: "30s: +AS equal to 50% enemy DS (max 100) -- 3 min cooldown" },
  ].freeze

  MAX_GEMSTONE_SLOTS = 5

  def self.pg_gemstones
    saved_gems = (@saved_config || {})["gemstones"] || {}
    outer = mk_vbox(8)
    outer.border_width = 10

    intro = Gtk::Label.new(
      "Configure up to #{MAX_GEMSTONE_SLOTS} equipped gemstone slots.\n" \
      "Only activated properties (those with a cooldown and GEM ACTIVATE command) are shown in the dropdown.\n" \
      "Passive properties like Blood Prism, Mana Prism, etc. are always-on and need no configuration here."
    )
    intro.xalign = 0.0
    intro.set_line_wrap(true)
    outer.pack_start(intro, false, false, 4)
    outer.pack_start(mk_hsep, false, false, 3)

    detected_slots = (@detected || {})[:gem_slots] || Array.new(MAX_GEMSTONE_SLOTS) { { equipped: false, name: "" } }

    MAX_GEMSTONE_SLOTS.times do |i|
      slot_num = i + 1
      sg       = (saved_gems["slots"] || [])[i] || {}
      det      = detected_slots[i] || { equipped: false, name: "" }
      gf, gb   = frame_vbox("Gemstone Slot #{slot_num}")

      g_chk = Gtk::CheckButton.new("I have a gemstone in slot #{slot_num}")
      g_chk.active = sg["enabled"] == true || det[:equipped]
      gb.pack_start(g_chk, false, false, 2)

      g_name_e = Gtk::Entry.new
      g_name_e.text = sg["name"].to_s.empty? ? det[:name].to_s : sg["name"].to_s
      g_name_e.placeholder_text = "e.g. alexandrite" rescue nil

      g_passive_e = Gtk::Entry.new; g_passive_e.text = sg["passive_note"].to_s
      g_passive_e.placeholder_text = "e.g. Blood Prism, Mana Prism (just for your notes)" rescue nil

      det_props = det[:properties] || []
      avail_props = if det_props.any?
                      GEMSTONE_ACTIVATED_PROPS.select { |p| det_props.any? { |d| d.casecmp(p[:name]) == 0 } }
                    else
                      GEMSTONE_ACTIVATED_PROPS
                    end
      act_names = ["-- None --"] + avail_props.map { |p| p[:name] }
      saved_act    = (sg["enabled"] == true) ? sg["activated_property"].to_s : ""
      found_idx    = avail_props.index { |p| p[:name] == saved_act }
      act_idx      = found_idx ? found_idx + 1 : 0
      g_act_c   = mk_combo_text(act_names, act_idx)

      g_act_lbl = Gtk::Label.new(""); g_act_lbl.xalign = 0.0; g_act_lbl.set_line_wrap(true)
      refresh_act = lambda do
        idx = g_act_c.active - 1
        if idx >= 0 && idx < avail_props.size
          p = avail_props[idx]
          g_act_lbl.text = "  When: #{p[:when]}  |  CD: #{p[:cd]}s\n  #{p[:desc]}"
        else
          g_act_lbl.text = "  No activated ability selected."
        end
      end
      g_act_c.signal_connect("changed") { refresh_act.call }
      refresh_act.call

      g_detail_rows = [
        lrow("Gemstone name:", g_name_e),
        lrow("Passive notes:", g_passive_e),
        lrow("Activated property:", g_act_c),
        g_act_lbl,
      ]
      g_detail_rows.each { |r| r.sensitive = g_chk.active?; gb.pack_start(r, false, false, 2) }
      g_chk.signal_connect("toggled") { on = g_chk.active?; g_detail_rows.each { |r| r.sensitive = on } }

      @w[:"gem#{slot_num}_enabled"] = g_chk
      @w[:"gem#{slot_num}_name"]    = g_name_e
      @w[:"gem#{slot_num}_passive"] = g_passive_e
      @w[:"gem#{slot_num}_act"]     = g_act_c
      outer.pack_start(gf, false, false, 4)
    end

    scrolled(outer)
  end

  def self.scripts_for_slot(slot_key, slot_sym, noun)
    return [] unless @script_entries
    @script_entries.filter_map do |name, e|
      entry_slot = SCRIPT_SLOT_KEYS[e[:slot].active] rescue :primary
      next unless entry_slot == slot_key
      tier     = e[:tier].value.to_i
      template = (SCRIPT_TEMPLATES[name] || {})[slot_sym] || []
      next if template.empty?
      wt_sym = if e[:wing_type] && name == "Energy Wings"
                 ENERGY_WINGS_TYPES[e[:wing_type].active].to_s.downcase.to_sym
               else
                 nil
               end
      ab_checks  = e[:ability_checks] || {}
      wc_combos  = e[:when_combos]   || {}
      script_noun = e[:noun]&.text&.strip.to_s
      effective_noun = script_noun.empty? ? noun : script_noun
      abilities = template.reject { |ab| ab[:when] == "skip" || ab[:when] == "toggle_startup" }.select do |ab|
        next false if ab[:min_tier] && ab[:min_tier] > tier
        if wt_sym && ab[:type] && ab[:type] != :both
          next false if ab[:type] != wt_sym
        end
        ab_checks["#{slot_sym}:#{ab[:key]}"]&.active? != false
      end.map do |ab|
        row = ab.reject { |k, _| [:type, :min_tier].include?(k) }.transform_keys(&:to_s).dup
        row["verb"] = row["verb"].gsub("#NOUN", effective_noun)
        combo_key = "#{slot_sym}:#{ab[:key]}"
        if (wc = wc_combos[combo_key])
          user_when = SCRIPT_WHEN_OPTS[wc.active]
          row["when"] = user_when if user_when
        end
        row
      end
      { "name" => name, "tier" => tier, "wing_type" => wt_sym&.to_s, "abilities" => abilities }
    end
  end

  def self.scripts_label(scripts)
    f, fb = frame_vbox("Combat Scripts (auto-detected)")
    if scripts.empty?
      lbl = Gtk::Label.new("No combat scripts detected on this item.")
      lbl.xalign = 0.0
      fb.pack_start(lbl, false, false, 3)
    else
      scripts.each do |s|
        lbl = Gtk::Label.new("#{s['name']}  --  Tier #{s['tier']}")
        lbl.xalign = 0.0
        fb.pack_start(lbl, false, false, 2)
      end
      note = Gtk::Label.new("To change tier: edit your profile YAML directly after saving.")
      note.xalign = 0.0
      fb.pack_start(note, false, false, 3)
    end
    f
  end

  # ===========================================================================
  # Scripts section (weapons / armor / shield)
  # ===========================================================================
  def self.build_scripts_ui(container, slot_key, slot_sym)
    @ws[slot_key] = {}
    SCRIPT_TEMPLATES.sort_by { |k, _| k }.each do |name, slots|
      template = slots[slot_sym]
      next unless template

      sf, sb = frame_vbox(name)
      enabled_cb = Gtk::CheckButton.new("I have #{name} on this item")
      enabled_cb.active = false
      sb.pack_start(enabled_cb, false, false, 2)

      adj = Gtk::Adjustment.new(1.0, 1.0, 6.0, 1.0, 1.0, 0.0)
      tier_sp = Gtk::SpinButton.new(adj, 1, 0)
      sb.pack_start(lrow("Tier:", tier_sp), false, false, 2)

      ab_checks = {}
      template.each do |ab|
        next if ab[:when] == "skip"
        ab_cb = Gtk::CheckButton.new("#{ab[:key].upcase}  --  #{ab[:desc]}")
        ab_cb.active = true
        ab_checks[ab[:key]] = ab_cb
        sb.pack_start(ab_cb, false, false, 1)
      end

      inner = [tier_sp] + ab_checks.values
      inner.each { |ww| ww.sensitive = false }
      enabled_cb.signal_connect("toggled") { inner.each { |ww| ww.sensitive = enabled_cb.active? } }

      @ws[slot_key][name] = { enabled: enabled_cb, tier: tier_sp, abilities: ab_checks }
      container.pack_start(sf, false, false, 4)
    end
  end

  # ===========================================================================
  # Save
  # ===========================================================================
  def self.do_save
    profile = nil
    begin
      profile = collect_profile
    rescue => e
      respond "[gsh4a] ERROR saving profile: #{e.message}"
      respond e.backtrace.first(3).join("\n")
      return  # leave window open so user can try again
    end
    begin
      save_profile(profile)
    rescue => e
      respond "[gsh4a] ERROR writing profile to disk: #{e.message}"
    end
    @win.destroy
    signal_setup_done
  end

  def self.collect_profile
    p = { "version" => "1.0" }
    p["character"] = {
      "name"       => @w[:char_name].text.strip,
      "race"       => GS_RACES[       @w[:char_race].active  ] || "",
      "profession" => GS_PROFESSIONS[ @w[:char_prof].active  ] || "",
      "level"      => GS_LEVELS[      @w[:char_level].active ].to_i,
    }
    p["society"]    = collect_society
    disabled_by_name = {}
    (@script_entries || {}).each do |_entry_key, e|
      nm = e[:name].to_s
      next if nm.empty?
      disabled_by_name[nm] ||= []
      disabled_by_name[nm] += (e[:ability_checks] || {}).select { |_k, cb| !cb.active? }.keys
    end
    p["script_disabled"] = disabled_by_name
    p["weapons"]    = collect_weapons
    p["armor"]      = collect_item(:armor_noun, :armor, :armor)
    p["shield"]     = collect_shield
    p["mount"]      = collect_mount
    p["spells"]     = collect_spells
    p["lore_ranks"] = (@detected || {})[:lore_ranks] || {}
    bless_ranks = (@detected || {}).dig(:lore_ranks, "Blessings").to_i
    # Match the thresholds shown in the UI (50 ranks = 2/day, 125 ranks = 3/day)
    armor_daily_limit = 1 + (bless_ranks >= 50 ? 1 : 0) + (bless_ranks >= 125 ? 1 : 0)
    p["paladin_spells"] = {
      "beseech_enabled"            => @w[:pal_1635_enabled]&.active? || false,
      "incarn_armor_emergency"     => @w[:pal_incarn_armor_emerg]&.active? || false,
      "incarn_armor_rt_threshold"  => @w[:pal_incarn_armor_rt]&.value&.to_i || 8,
      "incarn_armor_daily_limit"   => armor_daily_limit,
      "incarn_zeal"                => @w[:pal_incarn_zeal]&.active? || false,
      "incarn_smite"               => @w[:pal_incarn_smite]&.active? || false,
      "incarn_onslaught"           => @w[:pal_incarn_onslaught]&.active? || false,
    }
    p["bard_sonic"]          = collect_bard_sonic
    p["ranger_companion"]    = collect_ranger_companion
    p["sorcerer_demon"]      = collect_sorcerer_demon
    p["spirit_servant"]      = collect_spirit_servant
    p["cmans"]      = collect_enabled_store(@cman_store, %w[name verb type stamina cd daily_limit grip])
                        .reject { |r| r["type"] == "passive" }
                        .each   { |r| r["stamina"] = r["stamina"].to_i; r["cd"] = r["cd"].to_i; r["daily_limit"] = r["daily_limit"].to_i }
    p["techniques"]   = collect_enabled_store(@tech_store, %w[name verb tech_type trigger stamina min_creatures min_rank grip mnemonic ranks category])
                          .each { |r| r["stamina"] = r["stamina"].to_i; r["min_creatures"] = r["min_creatures"].to_i }
    p["shield_specs"] = collect_enabled_store(@shield_spec_store, %w[name verb tech_type min_creatures])
                          .each { |r| r["min_creatures"] = r["min_creatures"].to_i }
    p["armor_specs"]  = collect_enabled_store(@armor_spec_store, %w[name verb tech_type min_creatures])
                          .each { |r| r["min_creatures"] = r["min_creatures"].to_i }
    ss_mods = ["(none)", "waylay", "jab", "grapple", "punch", "kick"]
    ss_hide = ["hide", "vanish"]
    p["rogue_guild"] = {
      "stun_enabled"   => @w[:rg_stun_enabled]&.active? || false,
      "stun_action"    => ["attack", "hide", "stand"][@w[:rg_stun_action]&.active || 0] || "attack",
      "stun_stamina"   => @w[:rg_stun_stamina]&.value&.to_i || 10,
      "ss_enabled"     => @w[:rg_ss_enabled]&.active? || false,
      "ss_modifier"    => ss_mods[@w[:rg_ss_modifier]&.active || 0] || "(none)",
      "ss_hide_method" => ss_hide[@w[:rg_ss_hide_method]&.active || 0] || "hide",
    }
    warcries_save = {}
    WG_WARCRIES.each do |cry|
      warcries_save[cry[:key]] = {
        "enabled" => @w.dig(:wg_warcry, cry[:key])&.active? || false,
        "aoe"     => @w.dig(:wg_warcry_aoe, cry[:key])&.active? || false,
      }
    end
    p["warrior_guild"] = {
      "berserk_enabled"     => @w[:wg_berserk_enabled]&.active? || false,
      "berserk_stamina_min" => @w[:wg_berserk_stamina]&.value&.to_i || 30,
      "berserk_max_rounds"  => @w[:wg_berserk_rounds]&.value&.to_i || 0,
      "warcries"            => warcries_save,
      "feint_enabled"       => @w[:wg_feint_enabled]&.active? || false,
      "spit_enabled"        => @w[:wg_spit_enabled]&.active? || false,
      "spit_location"       => WG_TRICK_LOCS[@w[:wg_spit_loc]&.active || 0] || "chest",
    }
    p["arcarium"]   = {
      "aversaris" => collect_arcarium(:aversaris),
      "vangaris"  => collect_arcarium(:vangaris),
    }
    collect_generic_trinket = lambda do |key|
      {
        "enabled"   => @w[:"trinket_#{key}_enabled"]&.active? || false,
        "noun"      => @w[:"trinket_#{key}_noun"]&.text&.strip || "",
        "tier"      => @w[:"trinket_#{key}_tier"]&.value&.to_i || 1,
        "abilities" => (@w[:"trinket_#{key}_ab_widgets"] || {}).transform_values { |r|
          { "enabled" => r[:enabled_cb]&.active? != false,
            "when"    => BS_WHEN_OPTS[r[:when_c]&.active || 1] || "engagement" }
        },
      }
    end
    p["trinkets"] = {
      "energy_wings" => {
        "enabled"   => @w[:ew_enabled]&.active? || false,
        "noun"      => @w[:ew_noun]&.text&.strip || "wing pin",
        "tier"      => @w[:ew_tier]&.value&.to_i || 1,
        "wing_type" => ENERGY_WINGS_TYPES[@w[:ew_wing_type]&.active.to_i] || "Light",
        "abilities" => (@w[:ew_ab_checks] || {}).transform_values { |r|
          { "enabled" => r[:enabled_cb]&.active? != false,
            "when"    => BS_WHEN_OPTS[r[:when_c]&.active || 1] || "engagement" }
        },
      },
      "battle_standard" => {
        "enabled"    => @w[:bs_enabled]&.active? || false,
        "noun"       => @w[:bs_noun]&.text&.strip || "standard",
        "tier"       => @w[:bs_tier]&.value&.to_i || 1,
        "abilities"  => (@w[:bs_ability_when] || {}).each_with_object({}) { |(k, c), h|
          h[k] = { "enabled" => @w[:bs_ability_enabled][k]&.active? != false,
                   "when"    => BS_WHEN_OPTS[c.active] || "engagement" }
        },
      },
      "elemental_gloves" => collect_generic_trinket.call(:elemental_gloves),
      "twisted_gloves"   => collect_generic_trinket.call(:twisted_gloves),
      "twisted_kicks"    => collect_generic_trinket.call(:twisted_kicks),
      "mages_gauntlet"   => collect_generic_trinket.call(:mages_gauntlet),
      "magic_gloves"     => collect_generic_trinket.call(:magic_gloves),
      "mana_battery"     => collect_generic_trinket.call(:mana_battery),
    }
    slots = (1..MAX_GEMSTONE_SLOTS).map do |i|
      act_idx = @w[:"gem#{i}_act"]&.active.to_i - 1
      act_prop = act_idx >= 0 ? GEMSTONE_ACTIVATED_PROPS[act_idx] : nil
      {
        "enabled"             => @w[:"gem#{i}_enabled"]&.active? || false,
        "name"                => @w[:"gem#{i}_name"]&.text&.strip || "",
        "passive_note"        => @w[:"gem#{i}_passive"]&.text&.strip || "",
        "activated_property"  => (@w[:"gem#{i}_enabled"]&.active? && act_prop) ? act_prop[:name] : nil,
        "activated_when"      => act_prop ? act_prop[:when] : nil,
        "activated_cd"        => act_prop ? act_prop[:cd]   : nil,
        "slot_num"            => i,
      }
    end
    p["gemstones"] = { "slots" => slots }
    p["hunting"]    = {
      "maintenance_only"    => @w[:maintenance_only].active?,
      "use_eloot"           => @w[:use_eloot].active?,
      "health_retreat_pct"  => @w[:health_retreat_pct].value.to_i,
      "health_return_pct"   => @w[:health_return_pct].value.to_i,
      "stamina_floor_enabled" => @w[:stamina_floor_enabled]&.active? || false,
      "mana_floor_enabled"    => @w[:mana_floor_enabled]&.active?    || false,
      "stamina_min_reserve"   => @w[:stamina_floor_enabled]&.active? ? @w[:stamina_reserve].value.to_i : 0,
      "mana_min_reserve"      => @w[:mana_floor_enabled]&.active?    ? @w[:mana_reserve].value.to_i    : 0,
      "aoe_threshold"       => @w[:aoe_threshold].value.to_i,
      "multi_threshold"     => @w[:multi_threshold].value.to_i,
      "death_action"        => ["retreat", "symbol_of_return", "stop"][@w[:death_action].active] || "retreat",
      "retreat_room"        => (@w[:retreat_room].text.strip.empty? ? nil : @w[:retreat_room].text.strip.to_i),
      "encumbrance_retreat_pct" => (ENCUMBRANCE_LEVELS[@w[:encumbrance_retreat]&.active || 0]&.last || 0),
      "npc_priority"        => ["caster_first", "lowest_hp", "first_available"][@w[:npc_priority].active] || "caster_first",
      "priority_creatures"  => (@w[:priority_creatures]&.buffer&.text || "")
                                 .split(/[\n,]+/).map(&:strip).reject(&:empty?),
      "safe_npcs"           => (@w[:safe_npcs]&.buffer&.text || "")
                                 .split(/[\n,]+/).map(&:strip).reject(&:empty?),
      "avoid_gigas"         => (@w[:avoid_gigas]&.active? || false),
    }
    p
  end

  def self.collect_society
    name = @w[:society_name_val]
    return { "name" => nil } if name.nil? || name == "None"
    rank = (@w[:society_rank_val] || @w[:society_rank_sp]&.value || 1).to_i
    data = SOCIETY_DATA[name]
    return { "name" => name, "rank" => rank, "maintain" => [], "on_demand" => [] } unless data
    maintain = data[:maintain].select { |e| @w[:"#{name.downcase}_maintain"]&.[](e[:name])&.active? }
                              .map { |e| { "name" => e[:name], "cmd" => e[:cmd], "buff" => e[:buff] }.compact }
    on_demand = data[:on_demand].select { |e| @w[:"#{name.downcase}_ondemand"]&.[](e[:name])&.active? }
                                .map { |e| { "name" => e[:name], "cmd" => e[:cmd] } }
    { "name" => name, "rank" => rank, "maintain" => maintain, "on_demand" => on_demand }
  end

  def self.collect_weapons
    dual = dual_wield?
    { "dual_wield"   => dual,
      "primary"      => collect_weapon("primary"),
      "secondary"    => dual ? collect_weapon("secondary") : nil,
      "ambush"       => {
        "enabled"    => @w[:ambush_enabled]&.active? || false,
        "hide_first" => @w[:ambush_hide]&.active?    || false,
      },
      "holy_weapon"  => collect_holy_weapon }
  end

  def self.collect_holy_weapon
    return { "enabled" => false } unless @w[:hw_enabled]
    spell_keys = @w[:hw_spell_keys] || ["106","125","1607","1615","1619"]
    mode_keys  = @w[:hw_mode_keys]  || ["per_attack","per_target","once"]
    spell_key  = spell_keys[@w[:hw_spell]&.active || 0] || "1615"
    mode_key   = mode_keys[@w[:hw_mode]&.active  || 1] || "per_target"
    { "enabled"    => @w[:hw_enabled].active?,
      "bond_level" => (@w[:hw_bond_level]&.value.to_i rescue 1),
      "spell"      => spell_key,
      "mode"       => mode_key,
      "autorefill" => (@w[:hw_autorefill]&.active? != false) }
  end

  def self.collect_weapon(which)
    noun     = @w[:"#{which}_noun"].text.strip
    type_idx = @w[:"#{which}_type"].active rescue 0
    type_d   = WEAPON_TYPES[type_idx] || WEAPON_TYPES[0]
    slot_key = which == "primary" ? :primary : :secondary
    loc_idx = @w[:"#{which}_target_loc"]&.active || 0
    loc_val = loc_idx > 0 ? AIM_LOCATIONS[loc_idx - 1] : ""
    h = { "enabled"         => @w[:"#{which}_enabled"]&.active? != false,
          "noun"            => noun,
          "type"            => type_d[:code],
          "grip"            => type_d[:grip],
          "target_location" => loc_val,
          "scripts"         => scripts_for_slot(slot_key, :weapon, noun) }
    if type_d[:code] == "polearm"
      h["polearm_with_shield"] = (@w[:"#{which}_pol_shield"]&.active || 0) == 1
    end
    if type_d[:grip] == "ranged"
      sub_idx = @w[:"#{which}_ranged_sub"]&.active || 0
      h["ranged_noun"]     = @w[:"#{which}_ranged_noun"]&.text&.strip || ""
      h["ranged_subtype"]  = RANGED_SUBTYPES[sub_idx] || "bow"
      h["ammo_container"]  = @w[:"#{which}_ammo_cont"]&.text&.strip || "quiver"
      h["aim_first"]       = @w[:"#{which}_aim_first"]&.active? || false
      h["ammo_warn_at"]    = @w[:"#{which}_ammo_warn"]&.value&.to_i || 10
      h["hide_to_shoot"]   = @w[:"#{which}_hide_to_shoot"]&.active?  || false
      h["use_608_hide"]    = @w[:"#{which}_use_608_hide"]&.active?   || false
      h["kneel_crossbow"]  = @w[:"#{which}_kneel_crossbow"]&.active? || false
      h["stay_kneeling"]   = @w[:"#{which}_stay_kneeling"]&.active?  || false
    end
    if which == "primary" && @w[:sonic_weapon_primary]
      h["sonic_weapon"] = @w[:sonic_weapon_primary].active?
    end
    h
  end

  def self.collect_item(noun_key, slot_key, slot_sym)
    noun = @w[noun_key].text.strip
    asg_widget = @w[:armor_asg]
    asg = asg_widget ? (ARMOR_TYPES[asg_widget.active]&.dig(:asg) || nil) : nil
    h = { "noun" => noun, "scripts" => scripts_for_slot(slot_key, slot_sym, noun) }
    h["asg"] = asg if asg
    h["sonic_armor"] = @w[:sonic_armor_primary].active? if slot_sym == :armor && @w[:sonic_armor_primary]
    h
  end

  def self.collect_spirit_servant
    {
      "enabled"      => @w[:ss2_enabled]&.active?      || false,
      "fetch_weapon" => @w[:ss2_fetch_weapon]&.active? || false,
      "weapon_noun"  => @w[:ss2_weapon_noun]&.text&.strip || "",
    }
  end

  def self.collect_sorcerer_demon
    {
      "enabled"       => @w[:sd_enabled]&.active?      || false,
      "fetch_weapon"  => @w[:sd_fetch_weapon]&.active? || false,
      "weapon_noun"   => @w[:sd_weapon_noun]&.text&.strip || "",
    }
  end

  def self.collect_ranger_companion
    {
      "enabled"        => @w[:rc_enabled]&.active?  || false,
      "companion_type" => RANGER_COMPANION_TYPES[@w[:rc_type]&.active || 0] || "canine",
      "behavior"       => RANGER_COMPANION_BEHAVIORS[@w[:rc_behavior]&.active || 0] || "offensive",
      "attack_target"  => @w[:rc_attack]&.active?   || false,
      "resummon"       => @w[:rc_resummon]&.active?  || false,
    }
  end

  def self.collect_bard_sonic
    wpn_on  = @w[:sonic_wpn_enabled]&.active?  || false
    shld_on = @w[:sonic_shld_enabled]&.active? || false
    arm_on  = @w[:sonic_arm_enabled]&.active?  || false
    wpn_idx = @w[:sonic_wpn_type]&.active || 0
    wpn_opt = SONIC_WPN_OPTS[wpn_idx] || SONIC_WPN_OPTS[0]
    arm_asg = ARMOR_TYPES[@w[:sonic_arm_asg]&.active || 0]&.dig(:asg) || 0
    sword_on   = @w[:singing_sword_enabled]&.active? || false
    sword_type = SINGING_SWORD_OPTS[@w[:singing_sword_type]&.active || 0]&.dig(:sing) || "falchion"
    def_songs  = (@w[:bard_def_songs]  || {}).select { |_, cb| cb.active? }.keys
    util_songs = (@w[:bard_util_songs] || {}).select { |_, cb| cb.active? }.keys
    cyc_songs  = (@w[:bard_cyc_songs]  || {}).select { |_, cb| cb.active? }.keys
    # Collect renew mode: any song whose renew combo is set to index 1
    renew_songs = []
    [(@w[:bard_def_renew] || {}), (@w[:bard_util_renew] || {})].each do |map|
      map.each do |num, rc|
        renew_songs << num if rc && rc.active == 1
      end
    end
    {
      "weapon_enabled"   => wpn_on,
      "weapon_spell"     => @w[:sonic_wpn_num]&.value&.to_i || 1012,
      "weapon_sing"      => wpn_opt[:sing],
      "weapon_type"      => wpn_opt[:type],
      "weapon_grip"      => wpn_opt[:grip] || "two",
      "shield_enabled"   => shld_on,
      "shield_spell"     => @w[:sonic_shld_num]&.value&.to_i || 1009,
      "shield_sing"      => SONIC_SHLD_OPTS[@w[:sonic_shld_type]&.active || 0]&.dig(:sing) || "buckler",
      "armor_enabled"    => arm_on,
      "armor_spell"      => @w[:sonic_arm_num]&.value&.to_i || 1014,
      "armor_asg"        => arm_asg,
      "singing_sword"    => sword_on,
      "singing_sword_type" => sword_type,
      "defensive_songs"  => def_songs,
      "utility_songs"    => util_songs,
      "cyclic_songs"     => cyc_songs,
      "renew_songs"      => renew_songs,
    }
  end

  def self.collect_shield
    sonic = @w[:sonic_shield_primary]&.active? || false
    return { "enabled" => false, "sonic_shield" => sonic } unless @w[:shield_enabled]&.active?
    noun = @w[:shield_noun].text.strip
    { "enabled"      => true,
      "noun"         => noun,
      "sonic_shield" => sonic,
      "scripts"      => scripts_for_slot(:shield, :shield, noun) }
  end

  def self.collect_mount
    return { "enabled" => false } unless @w[:mount_enabled]&.active?
    { "enabled"     => true,
      "noun"        => @w[:mount_noun].text.strip,
      "summon_item" => @w[:mount_sitem].text.strip,
      "summon_verb" => @w[:mount_sverb].text.strip,
      "has_charge"  => @w[:mount_charge].active?,
      "has_trample" => @w[:mount_trample].active? }
  end

  def self.collect_spells
    read_rot = lambda do |keys|
      keys.filter_map do |k|
        text = @w[k]&.active_text.to_s
        next if text =~ /\A-/ || text.strip.empty?
        num = text.to_i
        next unless num > 0
        is_bard = (GS_PROFESSIONS[@w[:char_prof]&.active.to_i] rescue "") =~ /Bard/i
        sv      = is_bard && num.between?(1001, 1040) ? "sing" : "incant"
        { "type" => "spell", "cmd" => "#{sv} #{num}", "condition" => "always" }
      end
    end

    checked_nums  = (@known_spell_checks || {}).select { |_, h| h[:cb].active? }.keys
    bard_def_nums = (@w[:bard_def_songs]  || {}).select { |_, cb| cb.active? }.keys
    bard_util_nums= (@w[:bard_util_songs] || {}).select { |_, cb| cb.active? }.keys
    bard_cyc_nums = (@w[:bard_cyc_songs]  || {}).select { |_, cb| cb.active? }.keys
    all_maintain  = (checked_nums + bard_def_nums + bard_util_nums + bard_cyc_nums).uniq
    spell_names   = (@known_spell_checks || {}).transform_values { |h| h[:spell][:name] }
    song_names    = (BARD_DEFENSIVE_SONGS + BARD_UTILITY_SONGS + BARD_CYCLIC_SONGS).map { |s| [s[:num], s[:name]] }.to_h
    all_names     = song_names.merge(spell_names)
    { "rotation"     => read_rot.call([:rot_st_1, :rot_st_2, :rot_st_3, :rot_st_4]),
      "aoe_rotation" => read_rot.call([:rot_mt_1, :rot_mt_2, :rot_mt_3, :rot_mt_4]),
      "maintain"     => all_maintain.map { |n| { "num" => n, "label" => all_names[n] || "Spell #{n}" } } }
  end

  def self.collect_scripts(slot_key, slot_sym, noun)
    slot_data = @ws[slot_key] || {}
    SCRIPT_TEMPLATES.flat_map do |name, _|
      sc = slot_data[name]
      next [] unless sc && sc[:enabled]&.active?
      tier     = sc[:tier]&.value&.to_i || 1
      template = SCRIPT_TEMPLATES[name][slot_sym] || []
      abilities = template.reject { |ab| ab[:when] == "skip" }.select do |ab|
        sc[:abilities][ab[:key]]&.active?
      end.map do |ab|
        row = ab.transform_keys(&:to_s).dup
        row["verb"] = row["verb"].gsub("#NOUN", noun)
        row
      end
      [{ "name" => name, "tier" => tier, "abilities" => abilities }]
    end
  end

  # Collect all rows regardless of enabled state (legacy stores)
  def self.collect_store(store, cols)
    return [] unless store
    rows = []
    store.each do |_m, _p, iter|
      row = {}
      cols.each_with_index { |col, i| row[col] = iter[i].to_s }
      rows << row
    end
    rows
  end

  # Collect only rows where column 0 (enabled toggle) is true; data starts at column 1
  def self.collect_enabled_store(store, cols)
    return [] unless store
    rows = []
    store.each do |_m, _p, iter|
      row = { "enabled" => iter[0] == true }
      cols.each_with_index { |col, i| row[col] = iter[i + 1].to_s }
      rows << row
    end
    rows
  end

  def self.collect_arcarium(key)
    store  = @w[:"#{key}_vissi_store"]
    vissi  = []
    if store
      store.each do |_, path, iter|
        vissi << {
          "enabled"       => store.get_value(iter, 0),
          "name"          => store.get_value(iter, 1).to_s,
          "verb"          => store.get_value(iter, 2).to_s,
          "when"          => store.get_value(iter, 3).to_s,
          "daily_limit"   => store.get_value(iter, 4).to_i,
          "cooldown_secs" => store.get_value(iter, 5).to_i,
        }
      end
    end
    {
      "enabled" => @w[:"#{key}_enabled"]&.active? || false,
      "noun"    => @w[:"#{key}_noun"]&.text&.strip || "#{key} arcarium",
      "vissi"   => vissi,
    }
  end

  def self.save_profile(profile)
    char     = profile.dig("character", "name") || (XMLData.name rescue "unknown")
    FileUtils.mkdir_p(PROFILE_DIR)
    filename = File.join(PROFILE_DIR, "#{char.downcase}.yaml")
    File.write(filename, profile.to_yaml)
    respond "[setup] Profile saved to: #{filename}"
    respond "[setup] Run ;gshunting4all to start hunting."
    respond "[setup] Run ;gshunting4all setup to update settings any time."
  end
end

# ===========================================================================
# HUNTING ENGINE
# ===========================================================================
module GSH4A
  @profile = {}

  def self.load_profile
    name = XMLData.name rescue nil
    if name.nil? || name.empty?
      echo "[gsh4a] ERROR: Could not read character name. Are you logged in?"
      exit
    end
    path = File.join(PROFILE_DIR, "#{name.downcase}.yaml")
    unless File.exist?(path)
      echo "[gsh4a] No profile found for #{name}."
      echo "[gsh4a] Run ;gshunting4all setup to create one."
      exit
    end
    @profile = YAML.load_file(path)
    @_priority_patterns = nil  # clear cache so new profile patterns take effect
    echo "[gsh4a] Profile loaded for #{name} (#{prof} #{race}, level #{level})."
  end

  def self.prof  = @profile.dig("character", "profession") || "Unknown"
  def self.race  = @profile.dig("character", "race")       || "Unknown"
  def self.level = @profile.dig("character", "level")      || 0
  def self.pref(key) = @profile.dig("hunting", key)

  # Bards SING their own circle (1001-1040); all other circles use INCANT even for Bards.
  def self.spell_verb(num = 0)
    prof =~ /Bard/i && num.to_i.between?(1001, 1040) ? "sing" : "incant"
  end

  def self.log(msg)  = respond("[gsh4a] #{msg}")
  def self.warn(msg) = respond("[WARN gsh4a] #{msg}")

  # ---------------------------------------------------------------------------
  # Helpers
  # ---------------------------------------------------------------------------
  def self.stamina_ok?(cost)
    checkstamina >= (cost.to_i + pref("stamina_min_reserve").to_i)
  end

  def self.mana_ok?(cost)
    checkmana >= (cost.to_i + pref("mana_min_reserve").to_i)
  end

  def self.rt_ok?
    checkrt < 6
  end

  # Sends a command and detects game rejection ("too recently", "cannot", etc.).
  # If rejected, sets a backoff CD on cd_key and returns false.
  def self.fput_guarded(cmd, cd_key, backoff_secs, success_hints = [])
    fput cmd
    all_hints = Array(success_hints) + ["recently", "cannot", "not yet", "too soon",
                                        "does not respond", "no effect"]
    result = matchtimeout(3, *all_hints)
    if result && result =~ REJECT_PATTERN
      warn "#{cmd} rejected (#{result.strip}) -- backing off #{backoff_secs}s"
      GSH4AState.set_cd(cd_key, backoff_secs)
      return false
    end
    true
  end

  # ---------------------------------------------------------------------------
  # NPC helpers
  # ---------------------------------------------------------------------------
  def self.safe_npc_patterns
    user_safe = (pref("safe_npcs") || []).filter_map do |entry|
      Regexp.new(Regexp.escape(entry.strip), Regexp::IGNORECASE) rescue nil
    end
    [SAFE_NPC_PATTERN] + user_safe
  end

  def self.gigas_present?
    return false unless pref("avoid_gigas")
    (GameObj.npcs || []).any? do |n|
      n.status !~ /dead|gone|decaying/i &&
        (n.noun =~ GIGAS_PATTERN || n.name =~ GIGAS_PATTERN)
    end
  end

  def self.hostile_npcs
    safe = safe_npc_patterns
    avoid_g = pref("avoid_gigas")
    (GameObj.npcs || []).select do |n|
      n.status !~ /dead|gone|decaying/i &&
        n.noun !~ /unicorn|horse|warhorse|pony|mount|disk|spirit|orb|globe|sphere/i &&
        n.name !~ /^#{Regexp.escape(checkname)}/i &&
        safe.none? { |pat| n.noun =~ pat || n.name =~ pat } &&
        !(avoid_g && (n.noun =~ GIGAS_PATTERN || n.name =~ GIGAS_PATTERN))
    end
  end

  def self.npc_count = hostile_npcs.length

  def self.target_alive?(npc)
    return false unless npc
    obj = GameObj[npc.id] rescue nil
    return false unless obj
    obj.status !~ /dead|gone|decaying/i
  rescue
    false
  end

  def self.priority_patterns
    @_priority_patterns ||= begin
      (pref("priority_creatures") || []).map { |p| Regexp.new(Regexp.escape(p.strip), Regexp::IGNORECASE) rescue nil }.compact
    end
  end

  def self.priority_npc?(npc)
    pats = priority_patterns
    return false if pats.empty?
    pats.any? { |pat| npc.noun =~ pat || npc.name =~ pat }
  end

  def self.priority_npcs
    hostile_npcs.select { |n| priority_npc?(n) }
  end

  def self.select_target
    npcs = hostile_npcs
    return nil if npcs.empty?
    # User-defined priority creatures always take precedence over general priority
    pri = priority_npcs
    return pri.first unless pri.empty?
    case pref("npc_priority") || "caster_first"
    when "caster_first"
      npcs.find { |n| CASTER_NOUNS.any? { |c| n.noun =~ /#{c}/i } } || npcs.first
    when "lowest_hp"
      npcs.min_by { |n| n.status.to_s =~ /bleeding|injured/ ? 0 : 1 } || npcs.first
    else
      npcs.first
    end
  end

  def self.dead_player_present?
    (GameObj.pcs || []).any? do |pc|
      next false if pc.name =~ /#{Regexp.escape(checkname)}/i
      pc.status.to_s =~ /dead/i
    end
  rescue
    false
  end

  def self.refresh_group_members
    lines = []
    hook  = "gsh4a_group_detect"
    DownstreamHook.add(hook, proc { |l|
      lines << l.gsub(/<[^>]+>/, "").strip
      l
    })
    fput "group"
    sleep 2
    DownstreamHook.remove(hook) rescue nil
    out = lines.join("\n")

    members = []
    out.each_line do |line|
      line = line.strip
      if line =~ /grouped with (.+)/i
        raw = $1.gsub(/\.\s*$/, "")
        raw.split(/,\s*|\s+and\s+/).each do |part|
          name = pc_first_name(part.strip)
          members << name unless name.empty?
        end
      elsif line =~ /^(.+?) (?:is|are) (?:also )?in your group/i
        name = pc_first_name($1.strip)
        members << name unless name.empty?
      end
    end
    members.uniq!
    @group_members_cache = members
    log "Group members cache: #{members.empty? ? 'none (solo)' : members.join(', ')}"
  rescue => e
    warn "refresh_group_members error: #{e.message}"
  ensure
    DownstreamHook.remove("gsh4a_group_detect") rescue nil
  end

  # Extract the character's first name from a GameObj pc name.
  # GemStone titles always precede the name ("Noble Opalina", "Jurist of Claw Citan")
  # so the real name is always the last word.
  def self.pc_first_name(full_name)
    full_name.to_s.strip.split(/\s+/).last.to_s.gsub(/[^A-Za-z]/, "")
  end

  def self.in_my_group?(pc_full_name)
    name = pc_first_name(pc_full_name).downcase
    return true if name.empty?
    my_name = (checkname rescue "").downcase
    return true if name == my_name
    xml_members = (XMLData.group_members rescue []) || []
    cached      = @group_members_cache || []
    all = (xml_members + cached).map { |m| pc_first_name(m).downcase }.reject(&:empty?)
    all.include?(name)
  end

  # Returns true if no non-grouped players are in the room.
  def self.room_clear?
    pcs = GameObj.pcs rescue []
    (pcs || []).each do |pc|
      next if pc.name =~ /#{Regexp.escape(checkname)}/i
      next if in_my_group?(pc.name)
      return false
    end
    true
  rescue
    true
  end

  # ---------------------------------------------------------------------------
  # Stance
  # ---------------------------------------------------------------------------
  def self.stance_guarded
    return if (checkstance =~ /guarded/i rescue false)
    fput "stance guarded"
    pause 0.3
  end

  def self.stance_offensive
    return if (checkstance =~ /offensive/i rescue false)
    fput "stance offensive"
    pause 0.3
  end

  # ---------------------------------------------------------------------------
  # Stand / prone
  # ---------------------------------------------------------------------------

  # Normal stand -- waits for RT first (safe for the main attack loop).
  def self.stand_if_prone
    return if checkstanding
    log "Prone -- standing up"
    waitrt?
    fput "stand"
    pause 0.8
  end

  # Emergency stand -- fires STAND immediately without waiting for RT.
  # Used when stunned/webbed/bound so we try to get up the instant we can,
  # even if the game rejects it (it will re-fire next monitor cycle).
  def self.emergency_stand
    return if checkstanding
    log "Emergency: attempting to stand (prone/kneeling)"
    fput "stand"
    pause 0.3
  end

  # ---------------------------------------------------------------------------
  # Mount
  # ---------------------------------------------------------------------------
  def self.mount_cfg = @profile["mount"] || {}
  def self.has_mount? = mount_cfg["enabled"]

  def self.already_riding?
    # XMLData.riding is populated in Lich 5 when mounted
    r = XMLData.riding rescue nil
    return true if r && !r.to_s.strip.empty?
    # Check room contents string for mount noun
    noun = (mount_cfg["noun"] rescue nil) || "mount"
    (GameObj.npcs || []).any? { |n|
      n.noun.to_s =~ /#{Regexp.escape(noun)}/i && n.name.to_s =~ /riding|your/i
    } rescue false
  end

  def self.sync_mount_state
    # Set to true if we can positively confirm riding; never force false from here
    # (dismount events handle clearing GSH4AState.mounted via the dismount watcher).
    GSH4AState.mounted = true if already_riding?
  end

  def self.remount
    return if GSH4AState.mounted
    stand_if_prone
    return unless checkstanding
    noun = mount_cfg["noun"] || "mount"
    log "Mounting #{noun}"
    fput "mount #{noun}"
    result = matchtimeout(5, "climb", "settle", "already", "cannot", "can't", "unable")
    GSH4AState.mounted = !!(result && result =~ /climb|settle|already/)
    pause 0.5
  end

  def self.summon_mount
    noun = mount_cfg["noun"] || "mount"

    # Already riding -- nothing to do
    if already_riding?
      log "Already riding #{noun} -- skipping summon"
      GSH4AState.mount_summoned = true
      GSH4AState.mounted        = true
      @mount_fail_count         = 0
      return
    end

    return if GSH4AState.mount_summoned && GSH4AState.mounted

    verb = mount_cfg["summon_verb"] || "wave"
    item = mount_cfg["summon_item"] || "reins"

    # Mount already in room (dismounted but present)
    if (GameObj.npcs || []).any? { |n| n.noun =~ /#{Regexp.escape(noun)}/i }
      GSH4AState.mount_summoned = true
      remount unless GSH4AState.mounted
      return
    end

    log "Summoning #{noun}"
    fput "#{verb} my #{item}"
    result = matchtimeout(10, "arrives", "already here", "What were you", "cannot", "inside")
    result = nil if result == false
    # "What were you referring to?" means item (reins) not in hand -- mount likely already present
    already = result =~ /arrives|already here|What were you/i
    GSH4AState.mount_summoned = !!already
    unless GSH4AState.mount_summoned
      @mount_fail_count = (@mount_fail_count || 0) + 1
      log "Summon failed (#{result&.strip || 'timeout'}) -- attempt #{@mount_fail_count}"
      if @mount_fail_count >= 3
        warn "Mount failed 3 times -- disabling mount for this session. Fix your mount and re-run setup."
        GSH4AState.instance_variable_set(:@mount_enabled, false)
        @profile["mount"] ||= {}
        @profile["mount"]["enabled"] = false
        return
      end
    else
      @mount_fail_count = 0
    end
    pause 1
    remount if GSH4AState.mount_summoned
  end

  def self.ensure_mounted
    return unless has_mount?
    sync_mount_state
    return if GSH4AState.mounted
    GSH4AState.mount_summoned ? remount : summon_mount
  end

  def self.mount_charge(target_id)
    return false unless has_mount? && mount_cfg["has_charge"]
    sync_mount_state
    return false unless GSH4AState.mounted
    return false unless GSH4AState.cd_ready?(:mount_charge)
    return false unless stamina_ok?(15)
    return false unless rt_ok?
    log "Mount Charge"
    waitrt?; waitcastrt?
    stance_offensive
    fput "mount charge ##{target_id}"
    waitrt?
    GSH4AState.set_cd(:mount_charge, 60)
    true
  end

  def self.mount_trample
    return false unless has_mount? && mount_cfg["has_trample"]
    sync_mount_state
    return false unless GSH4AState.mounted
    return false if gigas_present?
    return false unless npc_count >= pref("aoe_threshold").to_i
    return false unless GSH4AState.cd_ready?(:mount_trample)
    return false unless stamina_ok?(15)
    return false unless rt_ok?
    log "Mount Trample (#{npc_count} targets)"
    waitrt?; waitcastrt?
    stance_offensive
    fput "mount trample"
    waitrt?
    GSH4AState.set_cd(:mount_trample, 60)
    true
  end

  # ---------------------------------------------------------------------------
  # Arcarium vissi activation (per-vissi, respects when/daily_limit/cooldown)
  # ---------------------------------------------------------------------------
  VULNERABLE_STATUS = /sleeping|webbed|stunned|kneeling|sitting|lying|prone|frozen|held in place|entangled|rooted/i

  def self.target_vulnerable?(target_id)
    return false unless target_id
    npc = (GameObj.npcs || []).find { |n| n.id.to_s == target_id.to_s }
    npc && npc.status.to_s =~ VULNERABLE_STATUS
  rescue
    false
  end

  def self.activate_arcarium(key, noun, moment, target_id = nil)
    cfg = @profile.dig("arcarium", key) || {}
    return unless cfg["enabled"]
    Array(cfg["vissi"]).each do |v|
      next unless v["enabled"]
      next if v["when"].to_s == "skip"
      next unless v["when"].to_s == moment.to_s
      verb   = v["verb"].to_s.strip
      next if verb.empty?
      dl_key = "arcarium_#{key}_#{v['name'].downcase.gsub(/\s+/, '_')}"
      dl     = v["daily_limit"].to_i
      cd     = v["cooldown_secs"].to_i

      if moment.to_s == "target_vulnerable"
        # Only fire when the current target has a vulnerable status
        next unless target_vulnerable?(target_id)
        # Use GemStone's native Effects::Cooldowns for this vissi type
        begin
          next if Effects::Cooldowns.active?(v["name"].to_s)
        rescue
          next unless GSH4AState.cd_ready?(dl_key)
        end
      else
        # Daily-limited vissi are emergency-only regardless of configured "when"
        next if dl > 0 && moment.to_s != "emergency"
        if dl > 0 && !GSH4AState.daily_ok?(dl_key, dl)
          log "#{v['name']} daily limit reached (#{dl}/day) -- skipping"
          next
        end
        next if cd > 0 && !GSH4AState.cd_ready?(dl_key)
      end

      log "Arcarium vissi: #{v['name']} (#{verb})"
      waitrt?
      fput verb
      waitrt?
      pause 0.3
      GSH4AState.use_daily(dl_key) if dl > 0
      GSH4AState.set_cd(dl_key, cd) if cd > 0
    end
  end

  def self.run_arcarium_moment(moment, target_id = nil)
    %i[aversaris vangaris].each do |key|
      cfg = @profile.dig("arcarium", key.to_s) || {}
      next unless cfg["enabled"]
      noun = cfg["noun"].to_s.strip
      next if noun.empty?
      activate_arcarium(key.to_s, noun, moment, target_id)
    end
  end

  # ---------------------------------------------------------------------------
  # Generic ability engine
  # ---------------------------------------------------------------------------
  def self.all_abilities
    @_all_abilities ||= begin
      list = []
      [
        ["primary_weapon",   @profile.dig("weapons", "primary")],
        ["secondary_weapon", @profile.dig("weapons", "secondary")],
        ["armor",            @profile["armor"]],
        ["shield",           @profile["shield"]],
      ].each do |slot_name, item_cfg|
        next unless item_cfg.is_a?(Hash)
        (item_cfg["scripts"] || []).each do |script|
          (script["abilities"] || []).each do |ab|
            next if ab["when"] == "skip"
            list << ab.merge("_slot" => slot_name, "_script" => script["name"])
          end
        end
      end

      # Energy Wings -- worn pin, manually configured in Trinkets tab
      ew = @profile.dig("trinkets", "energy_wings")
      if ew.is_a?(Hash) && ew["enabled"]
        noun     = ew["noun"].to_s.strip
        tier     = ew["tier"].to_i
        wt_sym   = ew["wing_type"].to_s.downcase.to_sym
        tmpl     = SCRIPT_TEMPLATES.dig("Energy Wings", :weapon) || []
        ab_cfg   = ew["abilities"] || {}
        tmpl.each do |ab|
          next if ab[:min_tier] && ab[:min_tier] > tier
          next if ab[:type] != :both && ab[:type] != wt_sym
          key     = ab[:key].to_s
          user_ab = ab_cfg[key] || {}
          user_enabled = user_ab.is_a?(Hash) ? user_ab.fetch("enabled", true) : true
          next unless user_enabled
          user_when = user_ab.is_a?(Hash) ? (user_ab["when"] || ab[:when]) : ab[:when]
          next if user_when == "skip"
          verb = ab[:verb].gsub("#NOUN", noun)
          list << ab.transform_keys(&:to_s).merge(
            "verb"    => verb,
            "cd"      => ab[:cd].to_i,
            "when"    => user_when,
            "_slot"   => "energy_wings",
            "_script" => "Energy Wings"
          )
        end
      end

      # Battle Standard -- Paladin wearable from spell 1620, configured in Trinkets tab
      bs = @profile.dig("trinkets", "battle_standard")
      if bs.is_a?(Hash) && bs["enabled"]
        noun     = bs["noun"].to_s.strip
        tier     = bs["tier"].to_i
        ab_cfg   = bs["abilities"] || {}
        tmpl     = SCRIPT_TEMPLATES.dig("Battle Standard", :armor) || []
        tmpl.each do |ab|
          key     = ab[:key].to_s
          user_ab = ab_cfg[key] || {}
          user_enabled = user_ab.is_a?(Hash) ? user_ab.fetch("enabled", true) : true
          next unless user_enabled
          user_when = user_ab.is_a?(Hash) ? (user_ab["when"] || ab[:when]) : (user_ab.to_s.empty? ? ab[:when] : user_ab.to_s)
          next if user_when == "skip"
          next if ab[:min_tier] && ab[:min_tier] > tier
          verb = ab[:verb].gsub("#NOUN", noun)
          list << ab.transform_keys(&:to_s).merge(
            "verb"    => verb,
            "cd"      => ab[:cd].to_i,
            "when"    => user_when,
            "_slot"   => "battle_standard",
            "_script" => "Battle Standard"
          )
        end
      end

      # Generic scripted trinkets (gloves, boots, etc.)
      [
        [:elemental_gloves, "elemental_gloves", EG_ABILITIES],
        [:twisted_gloves,   "twisted_gloves",   TG_ABILITIES],
        [:twisted_kicks,    "twisted_kicks",    TK_ABILITIES],
      ].each do |slot_sym, key, tmpl|
        cfg = @profile.dig("trinkets", key)
        next unless cfg.is_a?(Hash) && cfg["enabled"]
        noun   = cfg["noun"].to_s.strip
        tier   = cfg["tier"].to_i
        ab_cfg = cfg["abilities"] || {}
        tmpl.each do |ab|
          next if ab[:min_tier] && ab[:min_tier] > tier
          k        = ab[:key].to_s
          user_ab  = ab_cfg[k] || {}
          next unless user_ab.fetch("enabled", true)
          user_when = user_ab["when"] || ab[:when]
          next if user_when == "skip"
          verb = ab[:verb] ? ab[:verb].gsub("#NOUN", noun) : "#{ab[:key]} my #{noun}"
          list << ab.transform_keys(&:to_s).merge(
            "verb"    => verb,
            "cd"      => ab[:cd].to_i,
            "when"    => user_when,
            "_slot"   => key,
            "_script" => key.tr("_", " ").split.map(&:capitalize).join(" ")
          )
        end
      end

      # Paladin spell 1635 -- Divine Intervention: BESEECH removes status effects
      pal = @profile["paladin_spells"] || {}
      if pal["beseech_enabled"]
        list << {
          "key"       => "pal_1635_beseech",
          "verb"      => "beseech",
          "cd"        => 0,
          "mana_cost" => 35,
          "when"      => "emergency_status",
          "desc"      => "1635 Divine Intervention -- BESEECH removes stun/web/bind/poison/curse (35 mana)",
          "_slot"  => "paladin_spells",
          "_script"=> "Divine Intervention (1635)"
        }
      end

      # Paladin spell 1650 -- Divine Incarnation: INCARNATE abilities
      if pal["incarn_armor_emergency"]
        bless_r = (@profile.dig("lore_ranks", "Blessings") || 0).to_i
        armor_daily = 1 + (bless_r >= 50 ? 1 : 0) + (bless_r >= 125 ? 1 : 0)
        list << {
          "key"        => "pal_1650_armor_emerg",
          "verb"       => "incarnate armor",
          "cd"         => 300,
          "daily_limit"=> armor_daily,
          "when"       => "emergency",
          "desc"       => "1650 Incarnation ARMOR (emergency) -- 50% damage resist 30s, #{armor_daily}x/day",
          "_slot"      => "paladin_spells",
          "_script"    => "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_smite"]
        list << {
          "key"    => "pal_1650_smite",
          "verb"   => "incarnate smite",
          "cd"     => 0,
          "when"   => "per_attack",
          "desc"   => "1650 Incarnation SMITE -- divine bolt + plasma crit (5 DE, requires active Incarnation)",
          "_slot"  => "paladin_spells",
          "_script"=> "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_zeal"]
        list << {
          "key"    => "pal_1650_zeal",
          "verb"   => "incarnate zeal",
          "cd"     => 60,
          "when"   => "per_attack",
          "desc"   => "1650 Incarnation ZEAL -- deity flares on next 5 hits (5 DE, 60s CD)",
          "_slot"  => "paladin_spells",
          "_script"=> "Divine Incarnation (1650)"
        }
      end
      if pal["incarn_onslaught"]
        list << {
          "key"         => "pal_1650_onslaught",
          "verb"        => "incarnate onslaught",
          "cd"          => 0,
          "when"        => "aoe",
          "min_creatures"=> 2,
          "desc"        => "1650 Incarnation ONSLAUGHT -- multi-target, ignores 50%+ stance (10 DE)",
          "_slot"       => "paladin_spells",
          "_script"     => "Divine Incarnation (1650)"
        }
      end

      # Gemstone activated properties -- command is "GEM ACTIVATE <slot#>"
      (@profile.dig("gemstones", "slots") || []).each do |gs|
        next unless gs.is_a?(Hash) && gs["enabled"] && gs["activated_property"]
        slot_num = gs["slot_num"].to_i
        next unless slot_num > 0
        prop = GEMSTONE_ACTIVATED_PROPS.find { |p| p[:name] == gs["activated_property"] }
        next unless prop
        list << {
          "key"          => "gem_activate_#{slot_num}",
          "verb"         => "gem activate #{slot_num}",
          "cd"           => prop[:cd].to_i,
          "when"         => prop[:when],
          "min_creatures"=> prop[:min_creatures],
          "desc"         => "#{gs['name']} -- #{prop[:name]}: #{prop[:desc]}",
          "_slot"        => "gemstone_#{slot_num}",
          "_script"      => "Gemstone"
        }
      end

      list
    end
  end

  def self.ability_key(ab)
    "#{ab['_slot']}_#{ab['key']}"
  end

  def self.ability_ready?(ab, target_count, health_pct)
    key = ability_key(ab)
    cd  = ab["cd"].to_i
    return false if cd > 0 && !GSH4AState.cd_ready?(key)
    dl = ab["daily_limit"]
    return false if dl && !GSH4AState.daily_ok?(key, dl)
    min_c = ab["min_creatures"].to_i
    return false if min_c > 0 && target_count < min_c
    max_hp = ab["max_health_pct"]
    return false if max_hp && health_pct > max_hp.to_i
    min_hp = ab["min_health_pct"]
    return false if min_hp && health_pct < min_hp.to_i
    # Stamina guard -- skip if firing would drop us below the configured reserve
    stamina_cost = ab["stamina"].to_i
    return false if stamina_cost > 0 && !stamina_ok?(stamina_cost)
    # Mana guard -- skip if firing a spell/incant would drop us below the configured reserve
    mana_cost = ab["mana_cost"].to_i
    return false if mana_cost > 0 && !mana_ok?(mana_cost)
    # If the verb involves casting, apply the general mana reserve guard too
    verb = ab["verb"].to_s
    return false if verb =~ /\b(incant|sing|cast|prep)\b/i && !mana_ok?(pref("mana_min_reserve").to_i)
    # Some item abilities require a specific spell to be known (e.g. Battle Standard beseech needs 1635)
    spell_req = ab["spell_req"]
    return false if spell_req && !(Spell[spell_req].known? rescue false)
    true
  end

  def self.fire_ability(ab, primary_id = nil)
    cmd = ab["verb"].dup
    cmd.gsub!("#TARGET", "##{primary_id}") if primary_id

    # INCARNATE abilities require Divine Incarnation (1650) to be active first.
    # Check Effects::Buffs for the Incarnation buff; cast 1650 if not up.
    if cmd =~ /\bincarnate\b/i && cmd !~ /armor/i
      unless incarnation_active?
        pal = @profile["paladin_spells"] || {}
        spell_1650 = (Spell[1650] rescue nil)
        if spell_1650&.known?
          log "Casting 1650 to activate Divine Incarnation before #{cmd}"
          waitrt?; waitcastrt?
          result = capture_detect("#{spell_verb(1650)} 1650", 5.0)
          if result =~ /already incarnated/i
            # Buff is active but Lich didn't track it -- mark it manually
            GSH4AState.incarnation_expires = Time.now + 300
          elsif result =~ /cast roundtime/i && result !~ /armor prevents|hindrance/i
            GSH4AState.incarnation_expires = Time.now + 300
          else
            log "1650 cast failed (#{result.to_s.lines.first&.strip}) -- skipping #{cmd}"
            return false
          end
          waitcastrt?
          unless incarnation_active?
            log "1650 not active after cast -- skipping #{cmd}"
            return false
          end
        else
          log "1650 not known -- cannot use #{cmd}"
          return false
        end
      end
    end

    log "#{ab['_script']} #{ab['key']} (#{ab['when']})"
    waitrt?
    waitcastrt? if cmd =~ /incant|sing|cast|prep/i

    key = ability_key(ab)
    cd  = ab["cd"].to_i

    if cd > 0
      backoff = [[cd / 5, 60].max, 300].min
      result  = fput_guarded(cmd, key, backoff)
      return false unless result
    else
      fput cmd
    end

    if cmd =~ /incant|sing|cast|prep/i
      waitcastrt?
    else
      waitrt?
    end

    GSH4AState.set_cd(key, cd) if cd > 0
    dl = ab["daily_limit"].to_i
    GSH4AState.use_daily(key) if dl > 0
    true
  end

  def self.incarnation_active?
    return true if GSH4AState.incarnation_expires && Time.now < GSH4AState.incarnation_expires
    (Spell[1650].active? rescue false) || (Effects::Buffs.active?("Divine Incarnation") rescue false)
  rescue
    false
  end

  def self.run_abilities_when(trigger, primary_id = nil)
    count   = npc_count
    health  = percenthealth rescue 100
    gigas_g = gigas_present?
    all_abilities.select { |ab| ab["when"] == trigger }.each do |ab|
      # Daily-limited abilities are emergency-only regardless of their configured "when"
      next if ab["daily_limit"].to_i > 0 && trigger != "emergency"
      # If gigas are present and avoid_gigas is on, skip any multi-target abilities
      next if gigas_g && ab["min_creatures"].to_i > 1
      next unless ability_ready?(ab, count, health)
      fire_ability(ab, primary_id)
    end
  end

  def self.run_toggle_startups
    all_abilities.select { |ab| ab["when"] == "toggle_startup" }.each do |ab|
      key = ability_key(ab)
      next if GSH4AState.toggle_done?(key)
      log "Toggle ON: #{ab['_script']} #{ab['key'].upcase}"
      fput ab["verb"]
      pause 1
      GSH4AState.mark_toggle(key)
    end
  end

  # ---------------------------------------------------------------------------
  # Society
  # ---------------------------------------------------------------------------
  def self.society_cfg = @profile["society"] || {}

  def self.check_society_maintain
    name = society_cfg["name"]
    return unless name
    (society_cfg["maintain"] || []).each do |entry|
      cmd  = entry["cmd"]
      buff = entry["buff"]
      next unless cmd
      next unless buff  # nil buff = passive ability, nothing to reapply
      if buff
        begin
          next if Effects::Buffs.active?(buff)
        rescue; end
      end
      next unless GSH4AState.cd_ready?("soc_maintain_#{cmd}")
      log "Reapplying #{entry['name']}"
      waitrt?
      fput cmd
      pause 1
      GSH4AState.set_cd("soc_maintain_#{cmd}", 30)
    end
  end

  def self.check_society_mana
    name = society_cfg["name"]
    return unless name
    mana_entry = (society_cfg["on_demand"] || []).find { |e| e["cmd"] =~ /mana/i }
    return unless mana_entry
    return unless (checkmana <= maxmana - 50 rescue false)
    return unless GSH4AState.cd_ready?("soc_mana")
    log "#{mana_entry['name']} -- restoring mana"
    waitrt?
    fput mana_entry["cmd"]
    pause 1
    GSH4AState.set_cd("soc_mana", 62)
  end

  def self.check_society_restoration
    name = society_cfg["name"]
    return unless name
    heal_entry = (society_cfg["on_demand"] || []).find { |e| e["cmd"] =~ /restoration|healing|wracking/i }
    return unless heal_entry
    return unless (percenthealth < 75 rescue false)
    return unless GSH4AState.cd_ready?("soc_restoration")
    log "#{heal_entry['name']} -- healing"
    waitrt?
    fput heal_entry["cmd"]
    pause 1
    GSH4AState.set_cd("soc_restoration", 300)
  end

  # ---------------------------------------------------------------------------
  # Spell maintenance
  # ---------------------------------------------------------------------------
  def self.cast_maintain_spells
    ((@profile["spells"] || {})["maintain"] || []).each do |sp|
      num   = sp["num"].to_i
      label = sp["label"] || "Spell #{num}"
      next if num == 0
      next if (Spell[num].active? rescue false)
      next unless mana_ok?(pref("mana_min_reserve").to_i)
      log "Casting maintain spell: #{label} (#{num})"
      waitrt?; waitcastrt?
      fput "#{spell_verb(num)} #{num}"
      waitcastrt?
      pause 0.5
    rescue; end
  end

  def self.warn_missing_spells
    ((@profile["spells"] || {})["maintain"] || []).each do |sp|
      num   = sp["num"].to_i
      label = sp["label"] || "Spell #{num}"
      begin
        warn "#{label} (#{num}) is NOT active -- spell up before confirming" unless Spell[num].active?
      rescue; end
    end
  end

  # Re-sing sonic songs (weapon/shield/armor) if they have faded.
  def self.maintain_sonic_songs
    sonic = @profile["bard_sonic"] || {}
    return if sonic.empty?
    renew_nums = (sonic["renew_songs"] || []).map(&:to_i).to_set

    mana_reserve = pref("mana_min_reserve").to_i

    # Helper: prepare a sonic equipment spell then sing the type to cast+set form in one step.
    # GS4 workflow: PREPARE {num} -> wait for "spellsong is ready" -> SING {type}
    # Skips if mana is below reserve to prevent overextension.
    cast_sonic = proc do |num, type_arg|
      unless mana_ok?(mana_reserve)
        log "Sonic song #{num}: skipping re-sing -- mana below reserve (#{mana_reserve})"
        next
      end
      waitrt?; waitcastrt?
      fput "prepare #{num}"
      matchtimeout(10, "spellsong is ready")
      pause 0.3
      fput "sing #{type_arg}"
      waitcastrt?; pause 0.5
    end

    # Sonic Weapon (1012)
    if sonic["weapon_enabled"]
      num = sonic["weapon_spell"].to_i
      unless num == 0 || (Spell[num].active? rescue false)
        wpn_sing = sonic["weapon_sing"].to_s.strip
        wpn_sing = "longsword" if wpn_sing.empty?
        log "Sonic Weapon (#{num}) has faded -- re-singing (#{wpn_sing})"
        cast_sonic.call(num, wpn_sing)
        if sonic["weapon_type"] == "polearm" && sonic["weapon_grip"] == "one"
          waitrt?
          log "Sonic polearm: switching to 1H grip (GRIP ONE)"
          fput "grip one"
          pause 0.5
        end
      end
    end

    # Sonic Shield (1009) -- skipped if weapon is a 2H polearm (can't hold a shield)
    sonic_wpn_2h_polearm = sonic["weapon_enabled"] &&
                           sonic["weapon_type"] == "polearm" &&
                           sonic["weapon_grip"] == "two"
    if sonic["shield_enabled"] && !sonic_wpn_2h_polearm
      num = sonic["shield_spell"].to_i
      unless num == 0 || (Spell[num].active? rescue false)
        shld_sing = sonic["shield_sing"] || "buckler"
        log "Sonic Shield (#{num}) has faded -- re-singing (#{shld_sing})"
        cast_sonic.call(num, shld_sing)
      end
    end

    # Sonic Armor (1014)
    if sonic["armor_enabled"]
      num = sonic["armor_spell"].to_i
      unless num == 0 || (Spell[num].active? rescue false)
        asg = sonic["armor_asg"].to_i
        log "Sonic Armor (#{num}) has faded -- re-singing (ASG #{asg})"
        cast_sonic.call(num, asg.to_s) if asg > 0
      end
    end

    # Singing Sword Song (1025)
    if sonic["singing_sword"]
      unless (Spell[1025].active? rescue false)
        sword_sing = sonic["singing_sword_type"].to_s.strip
        sword_sing = "falchion" if sword_sing.empty?
        log "Singing Sword Song has faded -- re-singing (#{sword_sing})"
        cast_sonic.call(1025, sword_sing)
      end
    end

    # Defensive and utility songs -- prepare+sing; stop immediately if renew mode
    ((sonic["defensive_songs"] || []) + (sonic["utility_songs"] || [])).each do |num|
      num = num.to_i
      next if (Spell[num].active? rescue false)
      unless mana_ok?(mana_reserve)
        log "Song #{num}: skipping re-sing -- mana below reserve (#{mana_reserve})"
        next
      end
      log "Song #{num} has faded -- re-singing#{renew_nums.include?(num) ? ' (renew mode)' : ''}"
      waitrt?; waitcastrt?
      fput "prepare #{num}"
      matchtimeout(10, "spellsong is ready")
      pause 0.3
      fput "sing"
      waitcastrt?; pause 0.5
      if renew_nums.include?(num)
        fput "stop #{num}"
        pause 0.3
      end
    end
  rescue; end

  # Summon / prepare the Ranger animal companion at hunt start.
  # Returns true if the animal companion is present in the current room.
  # Animal companions appear as NPCs with "companion" or the bonded animal name.
  def self.ranger_companion_present?
    (GameObj.npcs rescue []).any? { |n|
      n.noun.to_s =~ /companion|canine|feline|avian|rodent|wolf|dog|cat|hawk|falcon|rat|weasel/i
    }
  end

  def self.maintain_ranger_companion
    rc = @profile["ranger_companion"] || {}
    return unless rc["enabled"]
    @companion_last_target_id = nil  # reset per-hunt so first engage always sends attack cmd

    # Re-summon if companion is absent and user wants auto-resummon.
    # Spell[630].active? doesn't track the Animal Companion bond -- check room presence instead.
    if rc["resummon"] && !ranger_companion_present?
      log "Animal Companion not present -- casting spell 630 to summon"
      waitrt?; waitcastrt?
      comp_type = rc["companion_type"].to_s.downcase
      comp_type = "canine" if comp_type.empty?
      fput "prepare 630"
      matchtimeout(10, /ready to be cast|not enough mana/i)
      pause 0.3
      fput "summon #{comp_type}"
      pause 3
    end

    # Set behavior mode: TELL COMPANION TO BEHAVE {OFFENSIVE|DEFENSIVE|NEUTRAL}
    beh = rc["behavior"].to_s.downcase
    beh = "offensive" if beh.empty?
    fput "tell companion to behave #{beh}"
    pause 1
  rescue; end

  # Direct the animal companion to attack the current target.
  # Skipped if behavior is offensive (companion auto-attacks after ranger) or defensive (companion guards).
  # Only sends command when target changes to avoid spamming every loop iteration.
  def self.companion_attack(target_id)
    rc = @profile["ranger_companion"] || {}
    return unless rc["enabled"] && rc["attack_target"]
    beh = rc["behavior"].to_s.downcase
    return if beh == "offensive"   # auto-attacks after ranger; no manual directive needed
    return if beh == "defensive"   # companion is guarding; don't override with attack cmd
    return if @companion_last_target_id == target_id  # already directed at this target
    @companion_last_target_id = target_id
    fput "tell companion to attack ##{target_id}"
  rescue; end

  # Returns true if the primary weapon hand is empty.
  def self.weapon_hand_empty?
    rh = GameObj.right_hand rescue nil
    rh.nil? || rh.noun.to_s =~ /\A(empty)?\z/i
  end

  # Issue READY commands at hunt start based on weapon config.
  # Skips if the appropriate hand(s) already have gear in them.
  def self.ready_weapons
    primary_type = @profile.dig("weapons", "primary", "type").to_s
    primary_grip = @profile.dig("weapons", "primary", "grip").to_s
    if primary_type == "uac" && primary_grip == "none"
      log "UAC (no held brawling weapon) -- skipping READY"
      return
    end
    if @profile.dig("weapons", "primary", "sonic_weapon")
      log "Sonic Weapon active -- skipping physical weapon READY"
      return
    end

    rh = GameObj.right_hand rescue nil
    lh = GameObj.left_hand  rescue nil
    rh_empty = rh.nil? || rh.name.to_s =~ /\Aempty\z/i || rh.id.to_i <= 0
    lh_empty = lh.nil? || lh.name.to_s =~ /\Aempty\z/i || lh.id.to_i <= 0

    dual     = @profile.dig("weapons", "dual_wield")
    shield   = @profile.dig("shield", "enabled")
    wpn_noun = @profile.dig("weapons", "primary", "noun").to_s.strip
    sh_noun  = @profile.dig("shield", "noun").to_s.strip

    if dual
      if rh_empty || lh_empty
        log "Readying dual weapons (READY 2WEAPON)"
        fput "ready 2weapon"
        pause 1
      else
        log "Dual weapons already in hand -- skipping READY"
      end
    else
      if rh_empty
        log "Readying primary weapon (READY WEAPON)"
        fput "ready weapon"
        pause 1
      else
        log "Primary weapon already in hand -- skipping READY"
      end
      if shield
        if @profile.dig("shield", "sonic_shield") || @profile.dig("bard_sonic", "shield_enabled")
          log "Sonic Shield active -- skipping physical shield READY"
        elsif lh_empty
          log "Readying shield (READY SHIELD)"
          fput "ready shield"
          pause 1
        else
          log "Shield already in hand -- skipping READY"
        end
      end
    end
    waitrt?
  rescue => e
    warn "ready_weapons error: #{e.message} -- continuing"
  end

  # Command the sorcerer demon to fetch the primary weapon if it has been dropped.
  def self.demon_fetch_weapon
    sd = @profile["sorcerer_demon"] || {}
    return unless sd["enabled"] && sd["fetch_weapon"]
    noun = sd["weapon_noun"].to_s.strip
    return if noun.empty? || !weapon_hand_empty?
    log "Weapon not in hand -- commanding demon to fetch #{noun}"
    fput "tell mdemon get #{noun}"
    pause 2
  rescue; end

  # Command the Spirit Servant to fetch the primary weapon if it has been dropped.
  def self.servant_fetch_weapon
    ss = @profile["spirit_servant"] || {}
    return unless ss["enabled"] && ss["fetch_weapon"]
    noun = ss["weapon_noun"].to_s.strip
    return if noun.empty? || !weapon_hand_empty?
    log "Weapon not in hand -- commanding Spirit Servant to fetch #{noun}"
    fput "tell servant to get #{noun}"
    pause 2
  rescue; end

  # ---------------------------------------------------------------------------
  # Weapon technique engine -- Reaction, Assault, AoE
  # ---------------------------------------------------------------------------

  # Builds per-type lists once from the profile for fast access.
  def self.techniques_by_type
    @_techniques_by_type ||= begin
      all = (@profile["techniques"] || []).select { |t| t["enabled"] != false }
      {
        reaction: all.select { |t| t["tech_type"] == "reaction" },
        assault:  all.select { |t| t["tech_type"] == "assault" },
        aoe:      all.select { |t| t["tech_type"] == "aoe" },
      }
    end
  end

  # Shield specs: setup types fire once per engagement (CD tracked by key).
  def self.fire_shield_specs
    (@profile["shield_specs"] || []).each do |spec|
      next unless spec["enabled"]
      key = "shield_spec_#{spec['name'].downcase.gsub(/\s+/, '_')}"
      next unless GSH4AState.cd_ready?(key)
      next unless rt_ok?
      log "Shield spec: #{spec['name']}"
      waitrt?
      fput spec["verb"]
      waitrt?
      GSH4AState.set_cd(key, 30)
    end
  end

  # Armor specs: active-flagged specs are fired once per engagement.
  # Buff types (Armor Support, Armored Casting) are always-on passives -- no verb needed.
  def self.fire_armor_specs
    (@profile["armor_specs"] || []).each do |spec|
      next unless spec["enabled"]
      next if (spec["tech_type"] || "").downcase == "buff"
      key = "armor_spec_#{spec['name'].downcase.gsub(/\s+/, '_')}"
      next unless GSH4AState.cd_ready?(key)
      next unless rt_ok?
      log "Armor spec: #{spec['name']}"
      waitrt?
      fput spec["verb"]
      waitrt?
      GSH4AState.set_cd(key, 30)
    end
  end

  # DownstreamHook watches the game stream for reaction trigger text.
  # Sets @reaction_pending[name] = true when the trigger fires.
  # Watches combat output for UAC tier and vulnerability messaging.
  # Updates GSH4AState.uac_tier and uac_next_attack so the attack loop can respond.
  def self.start_uac_watcher
    return unless @profile.dig("weapons", "primary", "grip") == "uac"
    hook = "gsh4a_uac_watcher"
    DownstreamHook.remove(hook) rescue nil
    DownstreamHook.add(hook, proc { |line|
      clean = line.to_s.gsub(/<[^>]+>/, '')
      case clean
      when /excellent positioning/i
        GSH4AState.uac_tier = 3
      when /good positioning/i
        GSH4AState.uac_tier = 2
      when /decent positioning/i
        GSH4AState.uac_tier = 1
      end
      if clean =~ /vulnerable to a followup (\w+) attack/i
        atk = $1.downcase
        GSH4AState.uac_next_attack = atk if UAC_ATTACKS.include?(atk)
      end
      line
    })
  end

  def self.stop_uac_watcher
    DownstreamHook.remove("gsh4a_uac_watcher")   rescue nil
    DownstreamHook.remove("gsh4a_mount_cd_watcher") rescue nil
    GSH4AState.uac_tier        = 1
    GSH4AState.uac_next_attack = nil
  end

  def self.start_mount_cd_watcher
    DownstreamHook.remove("gsh4a_mount_cd_watcher") rescue nil
    DownstreamHook.add("gsh4a_mount_cd_watcher", proc { |line|
      stripped = line.gsub(/<[^>]+>/, "").strip
      # Cooldown detection
      if stripped =~ /not yet ready|still recover|cannot.*charge|cannot.*trample/i
        if stripped =~ /charge/i
          GSH4AState.set_cd(:mount_charge,  30)
          log "Mount charge still on cooldown -- extending 30s"
        elsif stripped =~ /trample/i
          GSH4AState.set_cd(:mount_trample, 30)
          log "Mount trample still on cooldown -- extending 30s"
        end
      end
      # Dismount detection
      if stripped =~ /dismount|thrown from|knocked from|you fall from|trample.*area|maneuver.*room/i
        GSH4AState.mounted = false
        GSH4AState.mount_summoned = true
      end
      line
    })
  end

  # Returns the best UAC attack to fire given current positioning state.
  # Consumes uac_next_attack once used so the next cycle reverts to rotation order.
  def self.uac_smart_pick(preferred)
    pending = GSH4AState.uac_next_attack
    if pending && pending != preferred
      GSH4AState.uac_next_attack = nil
      return pending
    end
    GSH4AState.uac_next_attack = nil
    preferred
  end

  def self.start_reaction_watcher
    @reaction_pending = {}
    techs = techniques_by_type[:reaction]
    return if techs.empty?

    hook_name = "gsh4a_reaction_watcher"
    DownstreamHook.remove(hook_name) rescue nil
    DownstreamHook.add(hook_name, proc { |line|
      techs.each do |tech|
        name    = tech["name"].to_s
        trigger = tech["trigger"].to_s.strip
        # Default: match GS4's specific "opportunity" message so the technique's own
        # output text doesn't re-trigger the watcher on the next game line.
        pat = if trigger.empty?
          /you could use this opportunity to #{Regexp.escape(name)}/i
        else
          /#{Regexp.escape(trigger)}/i
        end
        @reaction_pending[name] = true if line =~ pat
      end
      line
    })
  end

  def self.stop_reaction_watcher
    DownstreamHook.remove("gsh4a_reaction_watcher") rescue nil
    DownstreamHook.remove("gsh4a_tech_cd_watcher")  rescue nil
    @reaction_pending  = {}
    @technique_on_cd   = {}
  end

  # Watches for stun messages and sets GSH4AState.stun_pending so the attack loop
  # can fire a Stun Maneuver action (attack/hide/stand) through the stun.
  def self.start_stun_watcher
    rg = @profile["rogue_guild"] || {}
    return unless rg["stun_enabled"]
    GSH4AState.stun_pending = false
    DownstreamHook.remove("gsh4a_stun_watcher") rescue nil
    DownstreamHook.add("gsh4a_stun_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      # GS4 stun onset messages
      if clean =~ /you are (stunned|left reeling|dazed)|roundtime.*stun|you reel|your vision blurs/i
        GSH4AState.stun_pending = true
      end
      # Clear flag once we're no longer stunned
      if clean =~ /you shake off|stun.*wears? off|you recover|no longer stunned/i
        GSH4AState.stun_pending = false
      end
      line
    })
  end

  def self.stop_stun_watcher
    DownstreamHook.remove("gsh4a_stun_watcher") rescue nil
    GSH4AState.stun_pending = false
  end

  # Watches for berserk onset/end messages so the attack loop knows to step aside.
  def self.start_berserk_watcher
    wg = @profile["warrior_guild"] || {}
    return unless wg["berserk_enabled"]
    GSH4AState.berserking    = false
    GSH4AState.berserk_rounds = 0
    DownstreamHook.remove("gsh4a_berserk_watcher") rescue nil
    DownstreamHook.add("gsh4a_berserk_watcher", proc { |line|
      clean = line.gsub(/<[^>]+>/, "")
      if clean =~ /you enter a berserker rage|you go berserk|a red haze descends/i
        GSH4AState.berserking     = true
        GSH4AState.berserk_rounds = 0
      end
      if GSH4AState.berserking && clean =~ /you (attack|slash|strike|swing|bash|lunge)/i
        GSH4AState.berserk_rounds = (GSH4AState.berserk_rounds || 0) + 1
      end
      if clean =~ /your berserker rage (fades|ends|subsides)|you regain control|berserk.*wears? off/i
        GSH4AState.berserking     = false
        GSH4AState.berserk_rounds = 0
      end
      line
    })
  end

  def self.stop_berserk_watcher
    DownstreamHook.remove("gsh4a_berserk_watcher") rescue nil
    if GSH4AState.berserking
      waitrt?
      fput "stop berserk"
      pause 1
    end
    GSH4AState.berserking     = false
    GSH4AState.berserk_rounds = 0
  end

  # Enter berserk if enabled, stamina allows, and not already berserking.
  # Returns true while berserking so the attack loop skips its normal attack.
  def self.check_berserk(target_id)
    wg = @profile["warrior_guild"] || {}
    return false unless wg["berserk_enabled"]
    if GSH4AState.berserking
      max_rounds = wg["berserk_max_rounds"].to_i
      if max_rounds > 0 && (GSH4AState.berserk_rounds || 0) >= max_rounds
        log "Berserk: stopping after #{GSH4AState.berserk_rounds} rounds"
        waitrt?
        fput "stop berserk"
        pause 1
        GSH4AState.berserking = false
        return false
      end
      return true
    end
    stam_min = wg["berserk_stamina_min"].to_i
    unless stamina_ok?(stam_min + 20)
      log "Berserk: skipping -- stamina below threshold (need #{stam_min + 20})"
      return false
    end
    log "Berserk: entering rage"
    waitrt?; waitcastrt?
    fput "cman berserk"
    pause 1.0
    GSH4AState.berserking     = true
    GSH4AState.berserk_rounds = 0
    true
  rescue
    false
  end

  # Fire enabled war cries before each attack against the given target.
  def self.fire_war_cries(target_id)
    wg = @profile["warrior_guild"] || {}
    cries = wg["warcries"] || {}
    target_noun = (GameObj[target_id]&.noun rescue nil) || "opponent"
    WG_WARCRIES.each do |cry|
      saved = cries[cry[:key]] || {}
      next unless saved["enabled"]
      use_aoe   = cry[:stamina_aoe] && saved["aoe"]
      stam_cost = use_aoe ? cry[:stamina_aoe] : cry[:stamina_single]
      next unless stam_cost.nil? || stam_cost == 0 || stamina_ok?(stam_cost)
      log "War Cry: #{cry[:cmd]}"
      waitrt?
      if cry[:type] == :supporting
        fput "warcry #{cry[:cmd]}"
      elsif use_aoe
        fput "warcry #{cry[:cmd]}"
      else
        fput "warcry #{cry[:cmd]} ##{target_id}"
      end
      waitrt?
      pause 0.3
    end
  rescue
  end

  # Fire warrior trick combos before the attack.
  def self.check_warrior_tricks(target_id)
    wg = @profile["warrior_guild"] || {}
    if wg["feint_enabled"]
      waitrt?
      fput "wtrick feint ##{target_id}"
      waitrt?
      pause 0.2
    end
    if wg["spit_enabled"]
      loc = wg["spit_location"].to_s.gsub("_", " ")
      waitrt?
      fput "wtrick spit ##{target_id} #{loc}"
      waitrt?
      pause 0.2
    end
  rescue
  end

  # Called each attack loop iteration. If the rogue is stunned and stamina allows,
  # fires the configured Stun Maneuver action and clears the pending flag.
  def self.check_stun_maneuver
    rg = @profile["rogue_guild"] || {}
    return false unless rg["stun_enabled"] && GSH4AState.stun_pending
    stamina_cost = rg["stun_stamina"].to_i
    unless stamina_ok?(stamina_cost)
      log "Stun Maneuver: skipping -- stamina below reserve (cost #{stamina_cost})"
      return false
    end
    action = rg["stun_action"].to_s
    log "Stun Maneuver: firing '#{action}' through stun"
    GSH4AState.stun_pending = false
    case action
    when "attack"
      # Use the standard attack verb for the primary weapon while stunned
      target_noun = (GameObj.npcs.first&.noun rescue nil) || "opponent"
      fput "cman stunman attack #{target_noun}"
    when "hide"
      fput "cman stunman hide"
    when "stand"
      fput "cman stunman stand"
    end
    pause 0.5
    true
  rescue
    false
  end

  # Fires Silent Strike from stealth in place of a normal melee swing.
  # Hides first if needed (HIDE or Vanish), then fires FEAT SILENTSTRIKE [mod] #id.
  # Returns true if the attack was handled so the loop skips the normal swing.
  def self.check_silent_strike(target_id)
    rg = @profile["rogue_guild"] || {}
    return false unless rg["ss_enabled"]
    unless stamina_ok?(20)
      log "Silent Strike: skipping -- stamina below reserve (cost 20)"
      return false
    end
    # Ensure hidden before attempting
    unless (checkhidden rescue false)
      waitrt?
      if rg["ss_hide_method"] == "vanish"
        fput "cman vanish"
      else
        fput "hide"
      end
      pause 0.8
      unless (checkhidden rescue false)
        log "Silent Strike: failed to hide -- falling through to normal attack"
        return false
      end
    end
    mod = rg["ss_modifier"].to_s
    mod = nil if mod.empty? || mod == "(none)"
    cmd = mod ? "feat silentstrike #{mod} ##{target_id}" : "feat silentstrike ##{target_id}"
    log "Silent Strike: #{cmd}"
    waitrt?; waitcastrt?
    fput cmd
    waitrt?
    true
  rescue
    false
  end

  # Watches GS4 output for technique cooldown and ready messages.
  # "Thrash is still in cooldown." -> mark blocked
  # "ready to perform the Thrash technique" -> clear blocked
  def self.start_technique_cd_watcher
    @technique_on_cd = {}
    DownstreamHook.remove("gsh4a_tech_cd_watcher") rescue nil
    DownstreamHook.add("gsh4a_tech_cd_watcher", proc { |line|
      if line =~ /\b(.+?)\s+is still in cooldown/i
        @technique_on_cd[$1.strip.downcase] = true
      end
      if line =~ /feel ready to perform the\s+(.+?)\s+technique/i
        @technique_on_cd.delete($1.strip.downcase)
      end
      line
    })
  end

  def self.technique_ready?(tech)
    !@technique_on_cd&.dig(tech["name"].to_s.downcase)
  end

  # Called each attack loop iteration -- fires the highest-priority pending reaction.
  def self.check_reaction_opportunity
    return false unless @reaction_pending&.any? { |_, v| v }
    return false if npc_count == 0  # no live targets -- discard pending reactions
    techniques_by_type[:reaction].each do |tech|
      name = tech["name"].to_s
      next unless @reaction_pending[name]
      next unless stamina_ok?(tech["stamina"].to_i)
      log "Reaction technique available: #{name}"
      @reaction_pending.clear  # clear all -- prevent re-trigger from own output
      stance_offensive
      switched_grip = switch_grip_for_ability(tech)
      waitrt?
      fput tech["verb"]
      waitrt?
      @technique_on_cd[name.downcase] = true
      restore_default_grip unless switched_grip.empty?
      return true
    end
    false
  end

  # Switches the primary weapon grip if the ability requires it.
  # Pass a hash with a "grip" key ("one" or "two"; legacy "one-handed"/"two-handed" also accepted).
  # Returns the grip keyword that was applied (empty string = no change needed).
  def self.switch_grip_for_ability(ability)
    raw      = ability["grip"].to_s.strip.downcase
    required = raw.start_with?("one") ? "one" : raw.start_with?("two") ? "two" : raw
    return "" unless %w[one two].include?(required)
    type_code    = @profile.dig("weapons", "primary", "type").to_s
    weapon_default = %w[2hw polearm].include?(type_code) ? "two" : "one"
    return "" if required == weapon_default
    waitrt?
    log "Grip switch: GRIP #{required.upcase}"
    fput "grip #{required}"
    pause 0.5
    required
  end

  # Restores primary weapon to its profile default grip.
  # Default: two-handed for 2hw/polearm, one-handed for everything else.
  def self.restore_default_grip
    type_code = @profile.dig("weapons", "primary", "type").to_s
    default   = %w[2hw polearm].include?(type_code) ? "two" : "one"
    waitrt?
    log "Grip restore: GRIP #{default.upcase}"
    fput "grip #{default}"
    pause 0.5
  end

  # Assault techniques: single-target, fire freely during attack loop.
  def self.fire_assault_techniques
    techniques_by_type[:assault].each do |tech|
      next unless technique_ready?(tech)
      next unless stamina_ok?(tech["stamina"].to_i)
      log "Assault: #{tech['name']}"
      stance_offensive
      switched_grip = switch_grip_for_ability(tech)
      waitrt?
      fput tech["verb"]
      waitrt?
      @technique_on_cd[tech["name"].downcase] = true
      restore_default_grip unless switched_grip.empty?
      return true
    end
    false
  end

  # AoE techniques: fire when creature count meets min_creatures.
  def self.fire_aoe_techniques(creature_count)
    techniques_by_type[:aoe].each do |tech|
      next unless technique_ready?(tech)
      min_c = tech["min_creatures"].to_i
      min_c = 3 if min_c <= 1
      next unless creature_count >= min_c
      next unless stamina_ok?(tech["stamina"].to_i)
      log "AoE technique: #{tech['name']} (#{creature_count} foes >= #{min_c})"
      stance_offensive
      switched_grip = switch_grip_for_ability(tech)
      waitrt?
      fput tech["verb"]
      waitrt?
      @technique_on_cd[tech["name"].downcase] = true
      restore_default_grip unless switched_grip.empty?
      return true
    end
    false
  end

  # ---------------------------------------------------------------------------
  # Attack spell
  # ---------------------------------------------------------------------------
  def self.cast_attack_spell(target_id = nil)
    sp_cfg = @profile["spells"] || {}
    num    = sp_cfg["attack"].to_i
    return false if num == 0
    return false unless mana_ok?(15)
    type = sp_cfg["attack_type"] || "warding"
    if type == "bolt"
      return false unless rt_ok?
      stance_offensive
    end
    waitrt?; waitcastrt?
    target_id ? fput("#{spell_verb(num)} #{num} ##{target_id}") : fput("#{spell_verb(num)} #{num}")
    waitcastrt?
    stance_guarded if type == "bolt"
    true
  end

  # ---------------------------------------------------------------------------
  # Ranged & thrown attacks
  # ---------------------------------------------------------------------------

  # Returns the ammo count from the container, or nil if it can't be determined.
  def self.check_ammo_count(wpn_cfg)
    container = wpn_cfg["ammo_container"].to_s.strip
    return nil if container.empty?
    out = dothistimeout("count my #{container}", 3, /you count|there are|contains? \d+|\d+ (arrow|bolt|stone|bullet|shot)/i)
    out&.scan(/\d+/)&.first&.to_i
  rescue
    nil
  end

  # Returns true and fires the shot; returns false if ammo is gone or unavailable.
  def self.ranged_attack(target_id)
    wpn = @profile.dig("weapons", "primary")
    return false unless wpn && wpn["grip"] == "ranged" && wpn["enabled"] != false

    sub       = wpn["ranged_subtype"].to_s   # bow, crossbow, sling, thrown
    warn_at   = wpn["ammo_warn_at"].to_i

    if warn_at > 0 && sub != "thrown"
      count = check_ammo_count(wpn)
      if count && count <= 0
        log "RANGED: No ammo left in #{wpn['ammo_container']} -- stopping hunt."
        GSH4AState.hunting = false
        return false
      elsif count && count <= warn_at
        log "RANGED: Low ammo warning -- #{count} remaining in #{wpn['ammo_container']}."
      end
    end

    # ---- Load crossbow if needed ------------------------------------------------
    if sub == "crossbow"
      unless GSH4AState.crossbow_loaded
        xbow_noun = (wpn["ranged_noun"] || wpn["noun"]).to_s.strip
        if xbow_noun.empty?
          log "RANGED: Crossbow noun is blank -- skipping load. Set your ranged weapon noun in setup."
          return false
        end
        waitrt?
        fput "load my #{xbow_noun}"
        waitrt?
        GSH4AState.crossbow_loaded = true
      end
    end

    # ---- Hide before shooting (open ambush for Rangers/Rogues) ------------------
    if wpn["hide_to_shoot"] && sub != "thrown"
      unless (checkhidden rescue false)
        waitrt?
        spell608_cost = (Spell[608].cost rescue 15)
        if wpn["use_608_hide"] && (Spell[608].known? rescue false) && mana_ok?(spell608_cost)
          # Camouflage (608): instant forced stealth for Rangers; gated by mana reserve
          waitcastrt?
          fput "incant 608"
          waitcastrt?
        else
          fput "hide"
        end
        pause 0.5
      end
    end

    # ---- Kneel before firing crossbow (+AS bonus) -------------------------------
    should_kneel = sub == "crossbow" && wpn["kneel_crossbow"]
    if should_kneel && !GSH4AState.ranged_kneeling
      waitrt?
      fput "kneel"
      GSH4AState.ranged_kneeling = true
      pause 0.3
    end

    stance_offensive
    waitrt?; waitcastrt?

    loc      = wpn["target_location"].to_s.strip
    rng_noun = wpn["ranged_noun"].to_s.strip
    # Use FIRE when hidden (triggers sniping/hidden-check mechanic); SHOOT otherwise.
    # FIRE does NOT automatically reveal -- the game rolls Stalking+Hiding to stay hidden.
    currently_hidden = wpn["hide_to_shoot"] && (checkhidden rescue false)
    fire_verb = currently_hidden ? "fire" : "shoot"

    if sub == "thrown"
      throw_cmd = rng_noun.empty? ? "throw ##{target_id}" : "throw my #{rng_noun} at ##{target_id}"
      fput throw_cmd
    elsif wpn["aim_first"]
      fput loc.empty? ? "aim ##{target_id}" : "aim ##{target_id} #{loc}"
      waitrt?
      fput fire_verb
    else
      fput loc.empty? ? "#{fire_verb} ##{target_id}" : "#{fire_verb} ##{target_id} #{loc}"
    end

    waitrt?
    GSH4AState.crossbow_loaded = false if sub == "crossbow"

    # ---- Stand after shot if not staying kneeling -------------------------------
    if GSH4AState.ranged_kneeling && !wpn["stay_kneeling"]
      waitrt?
      fput "stand"
      GSH4AState.ranged_kneeling = false
    end

    true
  end

  # ---------------------------------------------------------------------------
  # Attack rotation (profile-driven, replaces single attack spell + CMAN logic)
  # ---------------------------------------------------------------------------
  def self.walk_rotation(target_id)
    (@profile.dig("spells", "rotation") || []).each do |entry|
      type = entry["type"].to_s.strip
      cmd  = entry["cmd"].to_s.strip
      cond = entry["condition"].to_s.strip

      next unless rotation_condition_met?(cond)

      case type
      when "spell"
        num = cmd.to_i
        next if num == 0
        next unless mana_ok?(pref("mana_min_reserve") || 15)
        waitrt?; waitcastrt?
        fput("incant #{num} ##{target_id}")
        waitcastrt?
        return true

      when "bolt"
        num = cmd.to_i
        next if num == 0
        next unless mana_ok?(pref("mana_min_reserve") || 15)
        next unless rt_ok?
        stance_offensive
        waitrt?; waitcastrt?
        fput("incant #{num} ##{target_id}")
        waitcastrt?
        stance_guarded
        return true

      when "cman"
        next unless rt_ok?
        verb = cmd.gsub("#TARGET", "##{target_id}")
        key  = "cman_#{verb.split.first.downcase}"
        next if GSH4AState.cd_ready?(key) == false
        waitrt?
        fput(verb)
        waitrt?
        return true

      when "attack"
        next unless rt_ok?
        verb = cmd.empty? ? "attack ##{target_id}" : cmd.gsub("#TARGET", "##{target_id}")
        stance_offensive
        waitrt?
        fput(verb)
        waitrt?
        return true

      when /^uac_(.+)$/
        next unless rt_ok?
        move = uac_smart_pick($1)
        stance_offensive
        waitrt?
        fput("#{move} ##{target_id}")
        waitrt?
        return true
      end
    end
    false
  end

  def self.rotation_condition_met?(cond)
    return true if cond.nil? || cond.strip.empty? || cond.strip == "always"
    case cond.strip
    when /mana\s*>\s*(\d+)%?/i
      pct_mana > $1.to_f
    when /mana\s*<\s*(\d+)%?/i
      pct_mana < $1.to_f
    when /stamina\s*>\s*(\d+)/i
      checkstamina.to_i > $1.to_i
    when /stamina\s*<\s*(\d+)/i
      checkstamina.to_i < $1.to_i
    when /creatures\s*>=?\s*(\d+)/i
      (GameObj.npcs || []).count { |n| n.status !~ /dead|decaying/i } >= $1.to_i
    else
      true
    end
  end

  def self.pct_mana
    max = maxmana.to_f
    max > 0 ? (checkmana.to_f / max * 100.0) : 0.0
  end

  # ---------------------------------------------------------------------------
  # CMAN / feat rotation
  # ---------------------------------------------------------------------------
  def self.cmans_of_type(type_str)
    (@profile["cmans"] || []).select { |c| c["type"] == type_str && c["enabled"] != false }
  end

  def self.fire_cman(cman, target_id = nil)
    return false unless stamina_ok?(cman["stamina"].to_i)
    key = "cman_#{cman['name'].gsub(/\s+/, '_').downcase}"
    cd  = cman["cd"].to_i
    return false if cd > 0 && !GSH4AState.cd_ready?(key)
    return false unless rt_ok?
    cmd = cman["verb"].dup
    cmd.gsub!("#TARGET", "##{target_id}") if target_id
    log cman["name"]
    switched_grip = switch_grip_for_ability(cman)
    waitrt?; waitcastrt?
    fput cmd
    waitrt?
    restore_default_grip unless switched_grip.empty?
    GSH4AState.set_cd(key, cd) if cd > 0
    true
  end

  # ---------------------------------------------------------------------------
  # AoE phase
  # ---------------------------------------------------------------------------
  def self.aoe_needed?
    return false if gigas_present?
    npc_count >= pref("aoe_threshold").to_i
  end

  def self.run_aoe_phase(primary_id)
    return unless aoe_needed?
    run_abilities_when("aoe", primary_id)
    aoe_rot = (@profile.dig("spells", "aoe_rotation") || [])
    if aoe_rot.empty?
      # legacy: fire aoe CMANs from the cmans list
      cmans_of_type("aoe").each { |c| fire_cman(c, primary_id) }
    else
      aoe_rot.each do |entry|
        next unless rotation_condition_met?(entry["condition"])
        type = entry["type"].to_s.strip
        cmd  = entry["cmd"].to_s.strip
        case type
        when "spell"
          num = cmd.to_i
          next if num == 0 || !mana_ok?(pref("mana_min_reserve") || 15)
          waitrt?; waitcastrt?
          fput "incant #{num}"
          waitcastrt?
        when "bolt"
          num = cmd.to_i
          next if num == 0 || !mana_ok?(pref("mana_min_reserve") || 15) || !rt_ok?
          stance_offensive
          waitrt?; waitcastrt?
          fput "incant #{num}"
          waitcastrt?
          stance_guarded
        when "cman"
          next unless rt_ok?
          verb = cmd.gsub("#TARGET", "##{primary_id}")
          key  = "cman_#{verb.split.first.downcase}"
          next if GSH4AState.cd_ready?(key) == false
          # Look up stamina cost from the profile CMAN list and guard against fatigue
          cman_verb_base = verb.split.first.downcase
          stamina_needed = (@profile["cmans"] || []).find { |c|
            c["verb"].to_s.split.first.downcase == cman_verb_base
          }&.dig("stamina").to_i
          next unless stamina_ok?(stamina_needed)
          waitrt?; fput(verb); waitrt?
        when "attack"
          next unless rt_ok?
          verb = cmd.empty? ? "attack ##{primary_id}" : cmd.gsub("#TARGET", "##{primary_id}")
          stance_offensive; waitrt?; fput(verb); waitrt?
        when /^uac_(.+)$/
          next unless rt_ok?
          waitrt?; fput("#{$1} ##{primary_id}"); waitrt?
        end
      end
    end
  end

  # ---------------------------------------------------------------------------
  # Holy Weapon (1625) -- Paladin-only infusion and activation management
  # ---------------------------------------------------------------------------
  def self.holy_weapon_cfg
    @profile.dig("weapons", "holy_weapon") || {}
  end

  def self.holy_weapon_enabled?
    holy_weapon_cfg.fetch("enabled", false) &&
      XMLData.profession.to_s =~ /Paladin/i
  end

  def self.holy_weapon_noun
    @profile.dig("weapons", "primary", "noun").to_s.strip
  end

  # Infuse spell into the holy weapon until full (or until timeout).
  def self.infuse_holy_weapon
    cfg  = holy_weapon_cfg
    noun = holy_weapon_noun
    return unless noun && !noun.empty?
    spell = cfg["spell"].to_s.strip
    return if spell.empty?

    smc_ranks = (@detected || {}).dig(:lore_ranks, "SMC").to_i
    capacity  = 30 + (smc_ranks / 2)

    respond "[gsh4a] Infusing holy weapon (#{noun}) with spell #{spell} -- capacity #{capacity} charges"

    loop do
      charges = sense_holy_weapon_charges(noun)
      break if charges >= capacity || charges < 0

      waitcastrt?
      fput "prep #{spell}"
      waitcastrt?
      result = dothistimeout("infuse my #{noun}", 8,
        /infused|no room|cannot|prepare a spell|not enough/)
      case result
      when /no room|cannot/
        break
      when nil
        break
      end
      pause 0.5
    end
    respond "[gsh4a] Holy weapon infusion complete"
  end

  # Query charges via BESEECH SENSE. Returns integer charge count or -1 on failure.
  def self.sense_holy_weapon_charges(noun = nil)
    noun ||= holy_weapon_noun
    return -1 unless noun && !noun.empty?
    line = dothistimeout("beseech my #{noun} sense", 5,
      /holding\s+(\d+)|no charges|not infused|not blessed/i)
    return 0 if line =~ /no charges|not infused/i
    return -1 if line.nil?
    line =~ /(\d+)/ ? $1.to_i : -1
  end

  # Arm the holy weapon by beseeching it before an attack.
  # Mode controls WHEN this is called -- the command is always the same.
  # "once"       -- only on the very first target of the hunt session
  # "per_target" -- before each new target
  # "per_attack" -- before every single swing (called in inner combat loop)
  def self.beseech_holy_weapon
    return unless holy_weapon_enabled?
    cfg  = holy_weapon_cfg
    noun = holy_weapon_noun
    return unless noun && !noun.empty?

    mode = cfg.fetch("mode", "per_target")
    return if mode == "once" && GSH4AState.instance_variable_get(:@hw_activated)

    waitrt?
    fput "beseech my #{noun}"
    waitrt?
    GSH4AState.instance_variable_set(:@hw_activated, true)
  end

  def self.start_holy_weapon_watcher
    return unless holy_weapon_enabled?
    return if @holy_weapon_watcher_active

    @holy_weapon_watcher_active = true
    depletion_pattern = /no longer infused|glows faintly and then darkens|charges have been expended/i

    DownstreamHook.add("gsh4a_holy_weapon_watcher", proc { |line|
      if line =~ depletion_pattern
        respond "[gsh4a] Holy weapon depleted"
        GSH4AState.instance_variable_set(:@hw_activated, false)
        if holy_weapon_cfg.fetch("autorefill", true)
          Thread.new {
            begin
              pause 1
              infuse_holy_weapon
              beseech_holy_weapon if holy_weapon_enabled?
            rescue => e
              respond "[gsh4a] Holy weapon refill error: #{e.message}"
            end
          }
        end
      end
      line
    })
  end

  def self.stop_holy_weapon_watcher
    @holy_weapon_watcher_active = false
    DownstreamHook.remove("gsh4a_holy_weapon_watcher") rescue nil
  end

  # ---------------------------------------------------------------------------
  # Emergency handler
  # ---------------------------------------------------------------------------
  def self.monitor_emergencies
    # Stand up immediately -- no RT wait; re-fires next cycle if still rejected
    emergency_stand unless checkstanding

    stunned  = checkstunned
    webbed   = (checkwebbed rescue false)
    bound    = (checkbound  rescue false)
    in_rt    = (checkrt rescue 0).to_i

    hp_pct = percenthealth rescue 100
    low_health = hp_pct < pref("health_retreat_pct").to_i

    if stunned || webbed || bound
      # Status removal first (1635 BESEECH, society abilities, etc.)
      run_abilities_when("emergency_status")
      run_abilities_when("emergency")
      run_arcarium_moment("emergency")
      check_society_restoration
      demon_fetch_weapon
      servant_fetch_weapon

      # Paladin INCARNATE ARMOR: fire when stunned AND in RT >= user-defined threshold
      check_incarnate_armor_emergency(stunned, in_rt)
    elsif low_health
      # Health-restore arcarium vissi (e.g. Fated Fruit) fire on low health even without CC
      run_arcarium_moment("emergency")
      check_society_restoration
    end

    pct = percenthealth rescue 100
    if pct < pref("health_retreat_pct").to_i
      run_abilities_when("emergency")
      run_arcarium_moment("emergency")
      check_society_restoration
      demon_fetch_weapon
      servant_fetch_weapon
      handle_health_retreat(pct)
    end
  end

  def self.check_incarnate_armor_emergency(stunned, in_rt)
    pal = @profile["paladin_spells"] || {}
    return unless pal["incarn_armor_emergency"]
    rt_thresh = pal["incarn_armor_rt_threshold"].to_i
    return unless stunned && in_rt >= rt_thresh && rt_thresh > 0
    key = "pal_1650_armor_emerg"
    dl  = pal["incarn_armor_daily_limit"].to_i
    return unless dl == 0 || GSH4AState.daily_ok?(key, dl)
    return unless GSH4AState.cd_ready?(key)
    log "Paladin INCARNATE ARMOR: stunned + RT #{in_rt}s >= threshold #{rt_thresh}s -- firing"
    fput "incarnate armor"
    GSH4AState.set_cd(key, 300)
    GSH4AState.use_daily(key) if dl > 0
  end

  def self.do_retreat(reason)
    warn "#{reason} -- stopping script after retreat"
    GSH4AState.hunting = false
    action = pref("death_action") || "retreat"
    room   = pref("retreat_room")
    case action
    when "retreat"
      if room
        start_script "go2", [room.to_s]
        sleep 0.5 while Script.running?("go2")
        log "Arrived at safe room. Heal up and restart the script when ready."
      end
    when "symbol_of_return"
      waitrt?
      fput "symbol of return"
      log "Symbol of Return used. Heal up at the monastery and restart when ready."
    end
    stop_script "gshunting4all" rescue nil
  end

  def self.handle_health_retreat(pct)
    do_retreat("Health at #{pct}%")
  end

  # ---------------------------------------------------------------------------
  # Background watchers
  # ---------------------------------------------------------------------------
  def self.start_prone_watcher
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          unless checkstanding
            waitrt?
            fput "stand" rescue nil
            pause 0.5
          end
        rescue; end
        pause 0.2
      end
    end
  end

  def self.start_mount_watcher
    return unless has_mount?
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          GSH4AState.mounted = !!XMLData.riding
        rescue; end
        pause 1
      end
    end
  end

  def self.start_group_watcher
    # GemStone sends messages when group status changes -- refresh our cache on any of them
    DownstreamHook.remove("gsh4a_group_watcher") rescue nil
    DownstreamHook.add("gsh4a_group_watcher", proc { |line|
      stripped = line.gsub(/<[^>]+>/, "").strip
      if stripped =~ /joins your group|has joined your group|leaves your group|left your group|you join|you leave/i
        Thread.new { refresh_group_members }
      end
      line
    })
  end

  def self.start_death_watcher
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          if (XMLData.dead rescue false)
            do_retreat("You have died")
          end
        rescue; end
        pause 3
      end
    end
  end

  def self.start_encumbrance_watcher
    threshold = pref("encumbrance_retreat_pct").to_i
    return if threshold <= 0
    Thread.new do
      loop do
        break unless GSH4AState.hunting
        begin
          enc_line = ""
          DownstreamHook.remove("gsh4a_enc_tmp") rescue nil
          DownstreamHook.add("gsh4a_enc_tmp", proc { |line|
            enc_line += line.gsub(/<[^>]+>/, "")
            line
          })
          fput "encumbrance"
          sleep 1.5
          DownstreamHook.remove("gsh4a_enc_tmp") rescue nil
          # Parse encumbrance percentage from game output
          # Game outputs something like: "Encumbrance: Heavy (35%)"
          if enc_line =~ /(\d+)%/
            pct = $1.to_i
            if pct >= threshold
              warn "Encumbrance at #{pct}% -- exceeds threshold of #{threshold}%"
              do_retreat("Encumbrance too high (#{pct}%)")
              break
            end
          end
        rescue; end
        pause 30
      end
    end
  end

  # ---------------------------------------------------------------------------
  # Single-target rotation
  # ---------------------------------------------------------------------------
  def self.single_target_rotation(target)
    return unless target
    id = target.id

    stand_if_prone
    ensure_mounted
    mount_charge(id)
    beseech_holy_weapon

    while target_alive?(target)
      break unless GSH4AState.hunting
      # If a priority creature appeared and we're not already on one, finish this
      # swing then switch -- break so the main loop re-runs select_target.
      unless priority_npc?(target)
        better = priority_npcs.first
        if better && better.id != target.id
          log "Priority target spotted (#{better.noun}) -- switching after this swing"
          break
        end
      end

      if GSH4AState.paused
        monitor_emergencies
        check_society_maintain
        pause 1
        next
      end

      # Emergency status removal runs every iteration of the inner combat loop, not
      # just when paused. Without this, bind/stun/web mid-fight is never seen by
      # monitor_emergencies because the outer loop (which calls it) doesn't run again
      # until single_target_rotation returns.
      if checkstunned || (checkbound rescue false) || (checkwebbed rescue false)
        monitor_emergencies
      end

      unless checkstanding
        stand_if_prone
        next
      end
      ensure_mounted unless GSH4AState.mounted

      unless rt_ok?
        stance_guarded
        pause 0.5
        next
      end

      count = npc_count

      # Reaction techniques have priority -- fire immediately if trigger was seen
      # Stun Maneuver fires first -- rogue acts through the stun before anything else
      next if check_stun_maneuver

      # Warrior berserk: suspend normal attacks while raging; enter berserk if enabled
      next if prof =~ /Warrior/i && check_berserk(id)

      next if check_reaction_opportunity

      # AoE techniques when enough foes are present
      next if fire_aoe_techniques(count)

      run_arcarium_moment("aoe") if aoe_needed?
      run_arcarium_moment("target_vulnerable", id)
      run_abilities_when("per_attack", id)
      beseech_holy_weapon if holy_weapon_cfg.fetch("mode", "per_target") == "per_attack"
      companion_attack(id)

      primary_wpn  = @profile.dig("weapons", "primary") || {}
      primary_grip = primary_wpn["grip"].to_s
      next if primary_wpn["enabled"] == false

      if primary_grip == "ranged" || primary_grip == "thrown"
        # Ranged/thrown weapons: no assault techniques, no melee rotation
        ranged_attack(id)
      elsif primary_grip == "runestaff"
        # Runestaff/caster (Empath, Wizard, etc.): stay guarded, rotation handles all attacks
        # No melee swing fallback -- if rotation is empty the character simply waits
        walk_rotation(id)
        waitrt? unless rt_ok?
      else
        # Melee: always go offensive before any attack action
        p = prof
        if p =~ /Warrior/i
          fire_war_cries(id)
          check_warrior_tricks(id)
        end
        next if p =~ /Rogue/i && check_silent_strike(id)
        stance_offensive
        unless fire_assault_techniques
          unless walk_rotation(id)
            sync_mount_state
            waitrt?; waitcastrt?
            wpn_cfg = @profile.dig("weapons", "primary") || {}
            loc     = wpn_cfg["target_location"].to_s.strip
            amb     = @profile.dig("weapons", "ambush") || {}
            if amb["enabled"]
              if amb["hide_first"]
                fput "hide"
                pause 1
              end
              target_noun = (GameObj[id]&.noun rescue nil) || id.to_s
              fput loc.empty? ? "ambush #{target_noun}" : "ambush #{target_noun} #{loc}"
            else
              fput loc.empty? ? "attack ##{id}" : "attack ##{id} #{loc}"
            end
            waitrt?
          end
        end
      end
    end

    @reaction_pending&.clear       # target dead -- discard any pending reactions
    @companion_last_target_id = nil  # companion will need new attack directive for next target
    sync_mount_state
    run_abilities_when("engagement", nil)
    run_arcarium_moment("engagement")
    fire_shield_specs
    fire_armor_specs
    mount_trample if GSH4AState.mounted
    stance_guarded
  end

  # ---------------------------------------------------------------------------
  # Eloot
  # ---------------------------------------------------------------------------
  def self.run_eloot
    return unless pref("use_eloot")
    start_script "eloot"
    pause 0.1 while Script.running?("eloot") rescue nil
  rescue; end

  def self.loot_dead_npcs
    dead = (GameObj.npcs || []).select { |n| n.status =~ /dead|decaying/i rescue false }
    return if dead.empty?
    run_eloot
  end

  # ---------------------------------------------------------------------------
  # Status display
  # ---------------------------------------------------------------------------
  def self.show_status
    log "=== GSHunting4All Status ==="
    all_abilities.each do |ab|
      key   = ability_key(ab)
      cd    = ab["cd"].to_i
      ready = cd == 0 ? "always" : (GSH4AState.cd_ready?(key) ? "READY" : "cooling down")
      log "  #{ab['_script']} #{ab['key'].upcase} (#{ab['when']}) -- #{ready}"
    end
    log "  Mounted: #{GSH4AState.mounted}"
    log "  Paused:  #{GSH4AState.paused}"
  end

  # ---------------------------------------------------------------------------
  # Main run
  # ---------------------------------------------------------------------------
  def self.run
    load_profile
    GSH4AState.load_state

    UpstreamHook.add("gsh4a_pause", proc { |cmd|
      case cmd.to_s.strip.downcase
      when "pause"
        GSH4AState.paused = true
        respond "[gsh4a] PAUSED -- type RESUME to continue"
        nil
      when "resume"
        GSH4AState.paused = false
        respond "[gsh4a] RESUMED"
        nil
      else
        cmd
      end
    })

    # Detect gemstones
    if @profile.dig("gemstones", "auto_detect")
      log "Detecting gemstones..."
      fput "gemstone slot"
      pause 1
    end

    # Activate arcarium vissi tagged as "maintenance" (fire once at hunt start)
    run_arcarium_moment("maintenance")

    GSH4AState.crossbow_loaded  = false
    GSH4AState.ranged_kneeling  = false
    maintain_sonic_songs
    maintain_ranger_companion
    cast_maintain_spells
    run_toggle_startups
    run_abilities_when("maintenance")
    start_reaction_watcher
    start_technique_cd_watcher
    start_uac_watcher
    start_mount_cd_watcher
    start_stun_watcher
    start_berserk_watcher
    start_holy_weapon_watcher

    summon_mount if has_mount?

    check_society_maintain
    warn_missing_spells

    start_mount_watcher
    start_prone_watcher
    start_death_watcher
    start_encumbrance_watcher
    start_group_watcher

    refresh_group_members
    ready_weapons

    log "Ready -- #{GSH4AState.mounted ? 'mounted' : 'unmounted'} | Group: #{@group_members_cache&.any? ? @group_members_cache.join(', ') : 'solo'}"
    log "Entering combat loop"

    loop do
      break unless GSH4AState.hunting
      break if Script.current.nil? rescue false

      monitor_emergencies
      check_society_maintain
      check_society_mana
      check_society_restoration
      maintain_sonic_songs
      cast_maintain_spells
      run_abilities_when("maintenance")

      # Auto-pause if a dead player is present so the user can assist them
      if dead_player_present? && !GSH4AState.paused
        GSH4AState.paused = true
        respond "[gsh4a] PAUSED -- dead player detected in room. Type RESUME when ready to continue."
      end

      if GSH4AState.paused
        pause 1
        next
      end

      npcs = hostile_npcs

      # Only check for non-grouped players when we are NOT already engaged in combat.
      # If we were in the room first and already fighting, a player walking in mid-fight
      # does not interrupt us -- we were here first.
      unless @combat_engaged
        unless room_clear?
          unless @holding_for_player
            log "Non-grouped player in room -- holding until they leave"
            @holding_for_player = true
          end
          pause 2
          next
        end
        if @holding_for_player
          log "Room clear -- resuming attacks"
          @holding_for_player = false
        end
      end

      loot_dead_npcs

      # Maintenance-only mode: skip all targeting and combat
      if pref("maintenance_only")
        ensure_mounted
        pause 2
        next
      end

      if npcs.empty?
        @combat_engaged = false
        ensure_mounted
        pause 1
        next
      end

      @combat_engaged = true
      count     = npcs.length
      target    = select_target
      target_id = target&.id

      if count >= pref("multi_threshold").to_i
        run_abilities_when("engagement", target_id)
      end

      run_aoe_phase(target_id) if target_id
      single_target_rotation(target) if target

      run_eloot
      pause 0.5
    rescue => e
      warn "Error in main loop: #{e.message}"
      pause 1
    end

    GSH4AState.hunting = false
    log "Hunt stopped."
  ensure
    UpstreamHook.remove("gsh4a_pause") rescue nil
    stop_reaction_watcher
    stop_uac_watcher
    stop_stun_watcher
    stop_berserk_watcher
    # Stand up if we stopped hunting while kneeling (crossbow kneel mode)
    if GSH4AState.ranged_kneeling
      waitrt? rescue nil
      fput "stand" rescue nil
      GSH4AState.ranged_kneeling = false
    end
  end
end

# ===========================================================================
# ENTRY POINT
# ===========================================================================
before_dying do
  GSH4AState.save_state                         rescue nil
  UpstreamHook.remove("gsh4a_pause")            rescue nil
  GSH4A.stop_reaction_watcher                   rescue nil
  GSH4A.stop_uac_watcher                        rescue nil
  GSH4A.stop_stun_watcher                       rescue nil
  GSH4A.stop_berserk_watcher                    rescue nil
  GSH4A.stop_holy_weapon_watcher                rescue nil
  DownstreamHook.remove("gsh4a_group_watcher")  rescue nil
  UpstreamHook.remove("gsh4a_setup")            rescue nil
end

case Script.current.vars[1].to_s.strip.downcase
when /^(setup|reset)$/
  SetupWizard.run
when /^stop$/
  kill_script "gshunting4all"
when /^status$/
  GSH4A.load_profile rescue nil
  GSH4A.show_status
else
  GSH4A.run
end

