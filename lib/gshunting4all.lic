  # Source: https://gswiki.play.net/Duskbringer_weapons
  # Daybringer: fire flares vs living, plasma vs undead. Nightbringer: disintegrate vs living, cold vs undead.
  # T4 Duskbringer form: TURN swaps between Daybringer/Nightbringer -- manage manually.
  "Duskbringer" => {
    max_tier: 4,
    weapon: [
      { key: "push",  verb: "push my #NOUN",     cd: nil,  when: "toggle_startup", desc: "Activate sprite (materialize weapon)" },
      { key: "prod",  verb: "prod my #NOUN",     cd: nil,  when: "toggle_startup", desc: "Toggle flares ON (Daybringer: fire/plasma; Nightbringer: disintegrate/cold)" },
      { key: "raise", verb: "raise my #NOUN",    cd: 120,  when: "maintenance",    desc: "Charge weapon with sun/moon energy (2 min CD)" },
      { key: "rub",   verb: "rub my #NOUN",      cd: 900,  when: "emergency",      desc: "Cauterize bleeding wound (15 min CD)" },
      { key: "lower", min_tier: 2, verb: "lower my #NOUN",    cd: 3600, when: "maintenance", desc: "[T2] Anomaly companion: +15 HP/+10 mana/+5 stamina every 30s (1x/hr)" },
      { key: "touch", min_tier: 3, verb: "touch my #NOUN",    cd: 1800, when: "emergency",   desc: "[T3] Infusion: heal via stored energy (25 energy cost, 30 min CD)" },
      { key: "pray",  min_tier: 4, verb: "pray at my #NOUN",  cd: 3600, when: "aoe",         min_creatures: 2, desc: "[T4] Consecrate: AoE holy effect (100 energy cost, 1x/hr)" },
    ]
  },
  # Source: https://gswiki.play.net/Energy_Weapon
  # All combat damage is via passive flares. PUSH/PULL toggle surge/drain modes -- manage manually.
  "Energy Weapon" => {
    weapon: [
      { key: "prod", verb: "prod my #NOUN", cd: nil, when: "toggle_startup", desc: "Toggle Energy Flares ON" },
      { key: "push", verb: "push my #NOUN", cd: nil, when: "skip",           desc: "Surged Flares (enhanced, drains mana) -- manage manually" },
      { key: "pull", verb: "pull my #NOUN", cd: nil, when: "skip",           desc: "Drained Flares (weaker, stores energy) -- manage manually" },
    ]
  },
  # Source: https://gswiki.play.net/Energy_Shield
  # Reverb/Barrier/Wave are auto-triggered passives. PUSH/PULL toggle surge/drain modes.
  "Energy Shield" => {
    shield: [
      { key: "prod", verb: "prod my #NOUN", cd: nil, when: "toggle_startup", desc: "Toggle Energy Flares ON" },
      { key: "push", verb: "push my #NOUN", cd: nil, when: "skip",           desc: "Surged Flares -- manage manually" },
      { key: "pull", verb: "pull my #NOUN", cd: nil, when: "skip",           desc: "Drained Flares -- manage manually" },
    ]
  },
  # Source: https://gswiki.play.net/Elemental_Runestaff
  # Wizards only (matching elemental attunement required). WAVE replaces normal attacks.
  # Use TURN before hunting to set the desired spell. GAZE confirms current spell.
  "Elemental Runestaff" => {
    noun_hint: "runestaff",
    weapon: [
      { key: "wave", verb: "wave my #NOUN at #TARGET", cd: 3, when: "per_attack", desc: "Cast set elemental spell at target (3s RT; Wizard only -- replaces normal attack)" },
    ]
  },
  # Source: https://gswiki.play.net/Mana-Infused_Armor
  "Sigil Set: Mana-Infused Armor" => {
    detect_pattern: /mana.infused armor/i,
    max_tier: 5,
    armor: [
      { key: "rub",   min_tier: 3, verb: "rub my #NOUN",   cd: 3600, when: "emergency",  desc: "[T3] Arcane Aegis: 120s critical + damage padding (1x/hr)" },
      { key: "tap",   min_tier: 4, verb: "tap my #NOUN",   cd: 900,  when: "aoe", desc: "[T4] +25 AS/+15 CS for 3 min (15 min CD)" },
      { key: "sigil", min_tier: 5, verb: "sigil my #NOUN", cd: 0,    when: "emergency",  daily_limit: 2, desc: "[T5] SIGIL: forcibly move all creatures from room (2x/day; only while incapacitated)" },
    ]
  },
  # Source: https://gswiki.play.net/Manaweave_Cloak -- use Armor slot
  "Manaweave Cloak" => {
    noun_hint: "cloak",
    max_tier: 3,
    armor: [
      { key: "clench", min_tier: 1, verb: "clench my #NOUN",          cd: 1800, when: "maintenance",  desc: "[T1] Mana Flare: 25% chance to strip attacker spell (30 min CD)" },
      { key: "wave",   min_tier: 1, verb: "wave my #NOUN at #TARGET", cd: 360,  when: "aoe",   desc: "[T1] Mana Hold: SMR immobilize target (6 min CD; -1 min/tier)" },
      { key: "rub",    min_tier: 2, verb: "rub my #NOUN",             cd: 900,  when: "maintenance",  desc: "[T2] Mana Wall: block mana spent on spells for 2 min (15 min CD)" },
      { key: "point",  min_tier: 2, verb: "point my #NOUN at #TARGET",cd: 1200, when: "aoe",   desc: "[T2] Mana Burn: fire damage + immolation SMR (20 min CD; -5 min/tier)" },
      { key: "tap",    min_tier: 3, verb: "tap my #NOUN",             cd: 3600, when: "maintenance",  desc: "[T3] Mana Siphon: +15 mana recovery for 15 min (1x/hr)" },
      { key: "pull",   min_tier: 3, verb: "pull my #NOUN",            cd: 180,  when: "aoe",          min_creatures: 3, desc: "[T3] Mana Tangle: AoE SMR immobilize up to 5 targets (3 min CD)" },
    ]
  },
  # Source: https://gswiki.play.net/Twisted_Armor
  "Twisted Armor" => {
    max_tier: 5,
    armor: [
      { key: "prod",  min_tier: 2, verb: "prod my #NOUN",  cd: nil, when: "toggle_startup", desc: "[T2+] Toggle Twisted Retaliation ON (acid reactive flares on evade/hit in aggressive stance)" },
      { key: "touch", min_tier: 4, verb: "touch my #NOUN", cd: 300, when: "aoe",     desc: "[T4+] Twisted Synergy: 30s flare rate boost for all Twisted items (5 min CD; requires Retaliation ON)" },
    ]
  },
  # Source: https://gswiki.play.net/Twisted_Weapon
  "Twisted Weapon" => {
    max_tier: 5,
    weapon: [
      { key: "raise", min_tier: 3, verb: "raise my #NOUN",            cd: nil, when: "toggle_startup", desc: "[T3+] Toggle scintillating mode ON (required for Twisted Flares)" },
      { key: "point", min_tier: 4, verb: "point my #NOUN at #TARGET", cd: 180, when: "aoe",     desc: "[T4+] Twisted Potency: SMRv2 damage + Weakened Armament debuff 30s (3 min CD)" },
    ]
  },
  # Source: https://gswiki.play.net/Twisted_Shield
  "Twisted Shield" => {
    max_tier: 5,
    shield: [
      { key: "point", min_tier: 4, verb: "point my #NOUN at #TARGET", cd: 180, when: "aoe", desc: "[T4+] SMRv2 damage + +10 TD buff 60s (3 min CD; shared CD across all Twisted Shields)" },
    ]
  },
  # Source: https://gswiki.play.net/Greater_Rhimar_Weapon
  # CLENCH (Blizzard) and EXHALE (Rime) use daily charges, not time CDs.
  "Greater Rhimar Weapon" => {
    max_tier: 4,
    weapon: [
      { key: "clench", min_tier: 3, verb: "clench my #NOUN",    cd: 0, when: "aoe",        daily_limit: 40, min_creatures: 2, desc: "[T3] Blizzard: AoE cold+knockdown like Major Elemental Wave (40 charges/day)" },
      { key: "exhale", min_tier: 4, verb: "exhale my #NOUN",    cd: 0, when: "aoe", daily_limit: 10,                   desc: "[T4] Rime: all attacks double-flare for 30s (10 charges/day)" },
    ]
  },
  # Source: https://gswiki.play.net/Parasitic_Weapon
  "Parasitic Weapon" => {
    max_tier: 3,
    weapon: [
      { key: "prod",  verb: "prod my #NOUN",  cd: nil,  when: "toggle_startup", desc: "Toggle Blood Flares messaging (flares always active; PROD is display-only toggle)" },
      { key: "raise", min_tier: 2, verb: "raise my #NOUN", cd: 600,  when: "aoe",  desc: "[T2/L4+] Parasitic Bond: drain target HP, heal self (10 min CD)" },
      { key: "kiss",  min_tier: 3, verb: "kiss my #NOUN",  cd: 3600, when: "aoe",  desc: "[T3/L9] Perfect Host: +10 AS/DS/Str/Con/Dex/damage padding (1x/hr)" },
    ]
  },
  # Source: https://gswiki.play.net/Blink_weapon
  # CAST infuses a spell before hunting (manages flare type) -- do manually.
  # POKE teleports to adjacent room; use as emergency escape (6 charges/day, no CD between uses).
  "Blink Weapon" => {
    weapon: [
      { key: "poke", verb: "poke my #NOUN", cd: 0, when: "emergency", daily_limit: 6, desc: "Teleport to adjacent room (6 charges/day, no inter-use CD -- emergency escape)" },
    ]
  },
  # Source: https://gswiki.play.net/Chaos_weapon
  # OLD STYLE: properties change randomly each hit -- no useful script verb.
  # NEW STYLE: CLUTCH attempts to lock current properties for normal flare rate.
  "Chaos Weapon (New Style)" => {
    weapon: [
      { key: "clutch", verb: "clutch my #NOUN", cd: 300, when: "aoe", desc: "Lock current random properties for normal flare rate (variable CD; skip if currently drained)" },
    ]
  },
  # Source: https://gswiki.play.net/Nerve_staff
  # BERSERK daily limit increases with tier: T4=1/day, T5=2/day, T6=3/day.
  # RAISE consumes Muscle Memory (auto-flare) for +25/+50 AS or +15/+30 CS.
  "Nerve Staff" => {
    noun_hint: "staff",
    max_tier: 6,
    weapon: [
      { key: "berserk", min_tier: 4, verb: "berserk my #NOUN", cd: 0,   when: "emergency",  daily_limit: 1, desc: "[T4+] Break webs/stuns/binds + stand up (1/day T4, 2/day T5, 3/day T6)" },
      { key: "raise",   min_tier: 5, verb: "raise my #NOUN",   cd: 10,  when: "per_attack", desc: "[T5+] Consume Muscle Memory for +25/+50 AS or +15/+30 CS (10s CD)" },
      { key: "wave",    min_tier: 6, verb: "wave my #NOUN",    cd: 180, when: "aoe",         min_creatures: 2, desc: "[T6] AoE Misery Flares: pain/paralyze/shock (3 min CD)" },
    ]
  },
  # Source: https://gswiki.play.net/Glyph-incised_dark_veil_iron_maul + https://gswiki.play.net/V%27tull%27s_Fury_(1718)
  # RAISE triggers V'tull's Fury: +30 AS + instant MSTRIKE-style melee vs all targets in room (1x/hr).
  "V'tull's Fury Maul" => {
    noun_hint: "maul",
    weapon: [
      { key: "raise", verb: "raise my #NOUN", cd: 3600, when: "aoe", min_creatures: 2, desc: "V'tull's Fury: +30 AS + instant MSTRIKE-style attack on all room targets (1x/hr)" },
    ]
  },
  # Source: https://gswiki.play.net/Mechanical_ranged_weapon
  # SPIN discharges all loaded bolts in volley targeting different enemies (T2+ only, 30 min CD).
  "Mechanical Ranged Weapon" => {
    max_tier: 4,
    weapon: [
      { key: "spin", min_tier: 2, verb: "spin my #NOUN", cd: 1800, when: "aoe", min_creatures: 2, desc: "[T2+] SPIN: discharge all loaded bolts, each targeting different enemies (30 min CD)" },
    ]
  },
  # Source: https://gswiki.play.net/Hand-held_Pylon -- use Primary Weapon slot (held in main hand)
  # POINT fires essence blast at target (2 min CD). Tier 4 can be worn on arm instead.
  "Hand-held Pylon" => {
    noun_hint: "pylon",
    max_tier: 4,
    weapon: [
      { key: "point", verb: "point my #NOUN at #TARGET", cd: 120, when: "per_attack", desc: "Fire essence blast at target (2 min CD; requires Magic Item Use ranks)" },
    ]
  },
  # Source: https://gswiki.play.net/Fighting_Fan -- hybrid Edged/Brawling weapon
  # Active attack verbs (Gust/Thunder) are not documented on the wiki -- add manually when known.
  # Reactive flares (T2+) and stance transitions are passive auto-triggers.
  "Fighting Fan" => {
    noun_hint: "fan",
    max_tier: 5,
    weapon: []
  },
  # Source: https://gswiki.play.net/Fighting_Knife -- dagger-type only
  # All abilities (Slasher/Stabber/Jugular/Rematch/Shanker) are passive auto-procs.
  # JAB/SLASH/STAB are manual combat stance selectors, not timed script abilities.
  "Fighting Knife" => {
    noun_hint: "knife",
    weapon: []
  },
  # Source: https://gswiki.play.net/Lirion_bow
  # Passive: auto-generates own arrows/bolts with +1 to +30 random enchant per shot.
  # No active combat verbs needed -- FIRE/COCK function as normal ranged.
  "Lirion Bow" => {
    noun_hint: "bow",
    weapon: []
  },
  # Source: https://gswiki.play.net/Sigil_Staff
  # Part of the Sigil Set (with Mana-Infused Armor, Dramatic Drapery).
  # Set bonus (2+ items): SMRv2 Sigil of Binding root flare (+1%/tier, max 15% at T5 all items) -- passive auto.
  # T2+ passive: dispel flare before spell attacks (1/2/3 spells by tier), or disruption damage if no spells up.
  # T5 passive: multicasts last spell as standard flare after combat actions.
  # WAVE requires 500 mana spent casting to fuel; RAISE requires 5000 mana spent.
  "Sigil Set: Sigil Staff" => {
    detect_pattern: /sigil staff/i,
    noun_hint: "staff",
    max_tier: 5,
    weapon: [
      { key: "wave",  min_tier: 3, verb: "wave my #NOUN at #TARGET", cd: 300,  when: "aoe", desc: "[T3] Dispel 1-3 spells from target (5 min CD; requires 500 mana spent to fuel)" },
      { key: "raise", min_tier: 4, verb: "raise my #NOUN",           cd: 3600, when: "maintenance", desc: "[T4] -50% mana cost for 30s or 10 casts (1x/hr; requires 5000 mana spent to fuel)" },
    ]
  },
  # Source: https://gswiki.play.net/Dramatic_Drapery -- use Armor slot
  # Part of the Sigil Set (with Mana-Infused Armor, Sigil Staff).
  # Set bonus (2+ items): SMRv2 Sigil of Binding root flare (+1%/tier, max 15% at T5 all items) -- passive auto.
  # T5 passive: flat +20 defense vs incoming SMRv2 attacks on standard flare chance (20%).
  # SIGIL creates a sigil on the ground (no direct documented combat damage/debuff) -- skip.
  # RAISE CD: 20 min base, -5 min/tier, minimum 5 min.
  # PINCH CD: 15 min base, -5 min/tier, minimum 5 min.
  "Sigil Set: Dramatic Drapery" => {
    detect_pattern: /dramatic drapery/i,
    noun_hint: "drapery",
    max_tier: 5,
    armor: [
      { key: "raise", min_tier: 2, verb: "raise my #NOUN", cd: 1200, when: "emergency",   desc: "[T2+] 10s invisibility -- breaks combat targeting (20 min CD base, -5 min/tier, min 5 min)" },
      { key: "pinch", min_tier: 3, verb: "pinch my #NOUN", cd: 900,  when: "maintenance", desc: "[T3+] Confound Dispel -- forces enemy dispels to strip least valuable spell (15 min CD base, -5 min/tier, min 5 min)" },
      { key: "sigil", min_tier: 1, verb: "sigil my #NOUN", cd: 360,  when: "skip",        desc: "Sigil on ground -- no direct combat damage documented; manage manually" },
    ]
  },
}.freeze

