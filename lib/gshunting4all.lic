OFFENSIVE_SPELL_PATTERN = /\b(strike|blast|wave|fury|bolt|carnage|smite|bane|
  cone|flare|disruption|disjunction|tempest|dispel|
  catalyst|wither|torment|pestilence|shockwave|disintegrate|
  corrupt|nether|assault|immolation|frenzy|maelstrom|pain|unbalance|
  burst|implosion|quake|firestorm|combustion|barrage)\b/ix.freeze

# Polearm is ALWAYS its own category -- never treated as a two-handed weapon.
# UAC grip is "none" (worn equipment, not wielded).
# ranged/thrown/runestaff grips signal the hunting script NOT to use swing.
WEAPON_TYPES = [
  { label: "One-Handed Edged -- backsword, bastard sword*, broadsword, dagger, estoc, falchion, handaxe, katana*, katar, longsword, main gauche, rapier, scimitar, short sword, whip-blade",
    code: "1he", grip: "one" },
  { label: "One-Handed Blunt -- ball and chain, crowbill, cudgel, leather whip, mace, morning star, war hammer",
    code: "1hb", grip: "one" },
  { label: "Two-Handed Weapon -- bastard sword*, battle axe, claidhmore, flail, flamberge, katana*, maul, military pick, quarterstaff, two-handed sword, war mattock  (*can also be 1he)",
    code: "2hw", grip: "two" },
  { label: "Polearm -- awl-pike, halberd, hammer of Kai, jeddart-axe, javelin, lance, naginata, pilum, spear, trident",
    code: "polearm", grip: "two" },
  { label: "Ranged -- composite bow, long bow, short bow, light crossbow, heavy crossbow (AIM, not SWING)",
    code: "ranged", grip: "ranged" },
  { label: "Thrown -- bola, dart, discus, quoit, throwing net (THROW, not SWING)",
    code: "thrown", grip: "thrown" },
  { label: "Runestaff (CAST/INCANT only -- no melee swing)",
    code: "runestaff", grip: "runestaff" },
  { label: "Brawling -- blackjack, cestus, fist-scythe, hook-knife, jackblade, katar, knuckle-blade, knuckle-duster, paingrip, razorpaw, sai, tiger-claw, troll-claw, yierka-spur",
    code: "brawling", grip: "one" },
  { label: "UAC -- Unarmed Combat (handwraps, footwraps + brawling held items; JAB/PUNCH/GRAPPLE/KICK)",
    code: "uac", grip: "none" },
].freeze

