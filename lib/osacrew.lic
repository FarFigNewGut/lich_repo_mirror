def determine_enemy_type
	result = Lich::Util.quiet_command("look ocean", /\[(.*)\]/, end_pattern = /(Open waters: (.*)|Obvious paths: (.*))/, include_end = false ,timeout = 3, silent = true)
	if result.to_s =~ /You notice (.*) approaching your position/
		if $1.include? "ethereal"
			save_to_crew("enemy_type", "undead")
		end
		if $1.include? "krolvin"
			save_to_crew("enemy_type", "krolvin")
		end
		if $1.include? "dark"
			save_to_crew("enemy_type", "pirate")
		end
	else
		echo "Unable To Determine Enemy Type, Default Is\: Pirate"
			save_to_crew("enemy_type", "pirate")
	end
end

def ship_map
	case Room.current.id
	when (29038..29042)
		save_to_crew("ship_type", "sloop")
		save_to_crew("ship_map", ["main_deck", "cargo_hold", "crows_nest", "helm", "captains_quarters"])
	when (30140..30147)
		save_to_crew("ship_type", "brigantine")
		save_to_crew("ship_map", ["forward_deck", "main_deck", "crows_nest", "cargo_hold", "mess_hall", "crew_quarters", "helm", "captains_quarters"])
	when (30119..30127)
		save_to_crew("ship_type", "carrack")
		save_to_crew("ship_map", ["bow", "forward_deck", "crows_nest", "main_deck", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	when (30176..30186)
		save_to_crew("ship_type", "galleon")
		save_to_crew("ship_map", ["bow", "forward_deck", "crows_nest", "main_deck", "social_room", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	when (30166..30175)
		save_to_crew("ship_type", "frigate")
		save_to_crew("ship_map", ["bow", "forward_deck", "crows_nest", "main_deck", "social_room", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	when (30128..30139)
		save_to_crew("ship_type", "man o' war")
		save_to_crew("ship_map", ["bow", "forward_crows_nest", "forward_deck", "mid_deck", "crows_nest", "main_deck", "social_room", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	end
end

def lower_sail
	result = dothistimeout "lower sail", 3, /you slowly lower the (.*) sail until it is at half mast|you slowly lower the (.*) sail until it is fully open|far as it can go!/
        waitrt?
	if result.to_s =~ /...wait/
		waitrt?
		lower_sail
	elsif result.to_s =~ /you slowly lower the (.*) sail until it is at half mast/
		waitrt?
		lower_sail
	elsif result.to_s =~ /you slowly lower the (.*) sail until it is fully open/
		@lowered_sail = true
		waitrt?
	elsif result.to_s =~ /far as it can go!/
		end
end

def raise_anchor
	result = dothistimeout "push capstan", 3, /begin to push|one final push|anchor is already up/
        waitrt?
	if result.to_s =~ /...wait/
		waitrt?
		raise_anchor
	elsif result.to_s =~ /begin to push/
		waitrt?
		raise_anchor
	elsif result.to_s =~ /one final push/
		@anchor_aweigh = true
		waitrt?
	elsif result.to_s =~ /anchor is already up/
		return
	end
end

def one_mast
	fput "pull gangplank"
	lower_sail
	if @lowered_sail
		waitrt?
		if checkname == @crew_data["commander"]
			fput "yell Main Mast Unfurled, She's Ready to Sail!"
		else
			fput "yell Main Mast Unfurled, She's Ready to Sail Captain!"
		end
		@lowered_sail = false
	end
	pause 0.5
	move "west"
end

def two_masts
	fput "pull gangplank"
	lower_sail
	if @lowered_sail
		waitrt?
		fput "yell Main Mast Unfurled"
		@lowered_sail = false
	end
	pause 0.5
	move "east"
	lower_sail
	if @lowered_sail
		waitrt?
		if checkname == @crew_data["commander"]
