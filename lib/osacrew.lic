#================ Task Section ================
def go_to_handler
	start_script("go2", ["handler"])
	wait_while { running?("go2") }
	if Room.current.location == "Kraken's Fall"
		start_script("go2", ['28950'])
		wait_while { running?("go2") }
	end
end

def crew_check_task
	checktask = Lich::Util.quiet_command("osa task", /OSA TASK/, end_pattern = /Expedites your current task cooldown./, include_end = false ,timeout = 3, silent = true)
		if checktask.to_s =~ /You do not currently have a task from the Sea Hag's Roost/
			go_to_handler
			fput "take board"
			pause 0.5
			captains_quarters
			crew_task_complete
		elsif checktask.to_s =~ /You should return to the Sea Hag's Roost to report your success/
			if saturated?
				if @crew_data["uselte"]
					fput "boost long"
				end
				wait_until {!saturated?}
			end
			go_to_handler
			fput "turn board"
			pause 0.5
			fput "take board"
			pause 0.5
			captains_quarters
			crew_task_complete
		elsif checktask.to_s =~ /Abandons your current task/
			crew_task_complete
		else
			crew_task_complete
		end
end

def crew_cast_sever
	return if @severlist.empty?
	pause_script("osacombat") if running?("osacombat")
	# Cast sever spells on requesters
	@severlist.each do |entry|
		target   = entry[0]
		spells   = entry[1..]
		spells.compact.reject(&:empty?).each do |spell_num|
			num = spell_num.to_s.strip
			next if num.empty?
			if Spell[num.to_i] && Spell[num.to_i].known?
				waitrt?
				waitcastrt?
				Spell[num.to_i].cast(target)
			end
		end
	end
	@severlist.clear
	start_script("ewaggle", ['--start-at=181', '--stop-at=240', 'self'])
	@mana_watcher.kill if @mana_watcher&.alive?
	@mana_watcher = Thread.new { need_mana }
	wait_until { !running?("ewaggle") }
	@mana_watcher.kill if @mana_watcher&.alive?
	unpause_script("osacombat") if running?("osacombat")
	crew_task_complete
end

def crew_sever_cleanup
	# Stop any active spells not on this crew member's sever preference list.
	# Mirrors severance.lic logic: group spells and arcane circles are always exempt.
	sever_group_exempt = [307,310,605,620,1006,1007,1018,1035,1213,1216,1125,1605,1609,1617,1618,1699]
	sever_keep = [
		osacombat_data["sever_spell_1"].to_s.strip.to_i,
		osacombat_data["sever_spell_2"].to_s.strip.to_i,
		osacombat_data["sever_spell_3"].to_s.strip.to_i,
		osacombat_data["sever_spell_4"].to_s.strip.to_i
	].reject { |n| n == 0 }

	to_stop = Spell.active.select { |s|
		!s.known? &&
		!sever_group_exempt.include?(s.num.to_i) &&
		s.circle.to_i <= 16 &&
		s.num - (s.circle.to_i * 100) <= 50 &&
		!sever_keep.include?(s.num.to_i)
	}

	to_stop.each do |s|
		waitrt?
		waitcastrt?
		fput "stop #{s.num}"
		respond "--- crew_sever: stopped #{s.name} (#{s.num})"
	end
end

def crew_task_complete
	if !@crew_data["commander"].include? "#{checkname}"
		wait_until {checkpcs.include? @crew_data["commander"]}
		pause rand(1..8)
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Task Complete")
	end
end

#================ Spellup Section ================

def crew_send_mana
	if percentmana >= 50 && (checkpcs.include? @manaperson) && $matched_type
		if running? "osacombat"
			pause_script "osacombat"
		end
		if running? "osacombat"
			pause_script "osacombat"
		end
		waitrt?
		waitcastrt?
		fput "send #{(maxmana/100)*20.to_i} #{@manaperson}"
		if running? "osacombat"
			unpause_script "osacombat"
		end
	end
	$matched_type = false
end

def crew_recieve_bread
	result = matchtimeout 30, /#{@crew_data["medicalofficer"]} offers (.*) (a|some)|#{@crew_data["medicalofficer"]} offers you (a|some)/
	if result.to_s =~ /#{@crew_data["medicalofficer"]} offers you (a|some)/
		fput "accept"
		crew_eat_bread
	elsif result.to_s =~ /#{@crew_data["medicalofficer"]} offers (.*) (a|some)/
			crew_recieve_bread
	end
end

def crew_eat_bread
	fput "gobble ##{GameObj.right_hand.id}"
	if !GameObj.right_hand.noun.nil?
		crew_eat_bread
	else
		return
	end
end

def determine_group_members
	Group.members.map(&:noun)
end

def self_armor_spec
	if @crew_data["my_armor_spec"].downcase.include? "blessing"
		waitrt?
		fput "armor blessing"
	elsif @crew_data["my_armor_spec"].downcase.include? "reinforcement"
		waitrt?
		fput "armor reinforement"
	elsif @crew_data["my_armor_spec"].downcase.include? "support"
		waitrt?
		fput "armor support"
	elsif @crew_data["my_armor_spec"].downcase.include? "casting"
		waitrt?
		fput "armor casting"
	elsif @crew_data["my_armor_spec"].downcase.include? "evasion" 
		waitrt?
		fput "armor evasion"
	elsif @crew_data["my_armor_spec"].downcase.include? "fluidity"
		waitrt?
		fput "armor fluidity"
	elsif @crew_data["my_armor_spec"].downcase.include? "stealth"
		waitrt?
		fput "armor stealth"
	end
end

def crew_apply_support
	@supportlist.each do |n, t|
		@support_rec = n
		@support_type = t
		if @support_type == "Blessing"
			waitrt?
			fput "armor blessing #{@support_rec}"
			pause 5
		elsif @support_type == "Reinforcement"
			waitrt?
			fput "armor reinforement #{@support_rec}"
			pause 5
		elsif @support_type == "Support"
			waitrt?
			fput "armor support #{@support_rec}"
			pause 5
		elsif @support_type == "Casting"
			waitrt?
			fput "armor casting #{@support_rec}"
			pause 5
		elsif @support_type == "Evasion" 
			waitrt?
			fput "armor evasion #{@support_rec}"
			pause 5
		elsif @support_type == "Fluidity"
			waitrt?
			fput "armor fluidity #{@support_rec}"
			pause 5
		elsif @support_type == "Stealth"
			waitrt?
			fput "armor stealth #{@support_rec}"
			pause 5
		end
	end
end

def mana_share
	$mana_type = Array.new
	$mana_type.clear
	$my_mana_type = Array.new
	$my_mana_type.clear
	if (Skills.smc >= 24)
		$mana_type.push ("Spiritual")
		$my_mana_type.push ("Spiritual")
	end
	if (Skills.mmc >= 24)
		$mana_type.push ("Mental")
		$my_mana_type.push ("Mental")
	end
	if (Skills.emc >= 24)
		$mana_type.push ("Elemental")
		$my_mana_type.push ("Elemental")
	end
	if $mana_type.count > 1
		$new_mana_type = $mana_type.last()
		$mana_type.delete "#{$mana_type.last()}"
		$mana_type.push ("or #{$new_mana_type}")
	end
	if $mana_type.count.to_i == 3
		$mana_message = "I Need #{$mana_type[0]}, #{$mana_type[1]} #{$mana_type[2]} Mana!"
	end
	if $mana_type.count.to_i == 2
		$mana_message = "I Need #{$mana_type[0]} #{$mana_type[1]} Mana!"
	end
	if $mana_type.count.to_i == 1
		$mana_message = "I Need #{$mana_type[0]} Mana!"
	end
end

def need_mana
	while running?("ewaggle")
		if percentmana < 15
			lnet_crew($mana_message)
			wait_until { percentmana > 15 }
		else
			pause 2
		end
	end
end

def crew_spellup_time_left
	$timeleft = Array.new
	Spell.active.each { |s| 
		if ((s.timeleft <= 250) and (s.timeleft > 2)) 
			$timeleft.push (s.timeleft)
		end}
		if $timeleft.sum <= 1
			save_to_crew("waggletimeleft", 1)
		else
			save_to_crew("waggletimeleft", ($timeleft.sum/$timeleft.count))
		end
end

def crew_spell_individual
	if @crew_data["groupspellup"]
		if !Feat.known?("Kroderine Soul")
			echo "Spelling up, #{$pc}"
			start_script("ewaggle", ['--start-at=181', '--stop-at=240', $pc])
			@mana_watcher.kill if @mana_watcher&.alive?
			@mana_watcher = Thread.new { need_mana }
			wait_until { !running?("ewaggle") }
			@mana_watcher.kill if @mana_watcher&.alive?
		end
	end
end

def crew_spell_up
	if Stats.prof == "Empath"
		if running? "ecure"
			stop_script "ecure"
		end
		wait_while { running?("ecure") }
		Script.run("ecure","group")
		wait_while { running?("ecure") }
	end
	if Feat.known?("Kroderine Soul")
		multifput "leave", "group open"
	end
	spellup = Lich::Util.quiet_command("mana", /Normal/, end_pattern = /You have used the MANA SPELLUP ability (.*) out of (.*) times for today\./, include_end = true ,timeout = 3, silent = true)
	if spellup.to_s =~ /You have used the MANA SPELLUP ability (.*) out of (.*) times for today\./
		if ($2 == "0") or ($1 == $2 )
			$mana_spellup = false
		else
			$mana_spellup = true
		end
		if !@crew_data["mana_spellup"]
			$mana_spellup = false
		end
		if $mana_spellup
			crew_spellup_time_left
			if (@crew_data["waggletimeleft"] <= 90)
				waitrt?
				waitcastrt?
				pause 0.2
				fput "mana spellup"
			end
		end
	end
	 
	if @crew_data["groupspellup"]
		determine_group_members
		if @crew_data["selfspellup"]
			start_script("ewaggle", ['--start-at=181', '--stop-at=240', Group.members.map(&:noun), 'self'])
		else
			start_script("ewaggle", ['--start-at=181', '--stop-at=240', Group.members.map(&:noun)])
		end
	else
		if @crew_data["selfspellup"]
			start_script("ewaggle", ['--start-at=181', '--stop-at=240', 'self'])
		end
	end
	@mana_watcher.kill if @mana_watcher&.alive?
	@mana_watcher = Thread.new { need_mana }
	wait_until { !running?("ewaggle") }
	@mana_watcher.kill if @mana_watcher&.alive?
	if @crew_data["armor_specs"]
		crew_apply_support
		@supportlist.clear
	end	
	self_armor_spec
	crew_task_complete
end

#================ Bless Section ================

def recieve_bless
result = matchtimeout 15, /a moment and then gently dissipates|leaving a soft white afterglow|appears to become incorporated into it|but it quickly returns to normal/
	if result.to_s =~ /a moment and then gently dissipates|leaving a soft white afterglow|appears to become incorporated into it|but it quickly returns to normal/
		return
	else
		respond ""
		respond "                                  Something May Have Gone Wrong With The Bless                               "
		respond ""
	end
end

def get_bless
	if osacombat_data["needbless"]
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["blesser"] }, "I Need Blessed Please!")
		waitfor /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["blesser"]}\: \"#{checkname}/
		if osacombat_data["uachands"].empty? and osacombat_data["uacfeet"].empty?
			fput "gird"
			pause 1
		else
			if !osacombat_data["uachands"].empty?
				fput "remove #{osacombat_data["uachands"]}"
				pause 0.5
			end
			if !osacombat_data["uacfeet"].empty?
				fput "remove #{osacombat_data["uacfeet"]}"
			end
		end
		if !GameObj.left_hand.id.nil? && GameObj.right_hand.id.nil?
			fput "swap"
		end
		if !GameObj.left_hand.id.nil? && !GameObj.right_hand.id.nil?
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["blesser"] }, "I Have Two.")
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["blesser"] }, "I Am Ready.")
			recieve_bless
			fput "swap"
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["blesser"] }, "Ok, The Next One Is Ready.")
			recieve_bless
		else
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["blesser"] }, "I Have One.")
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["blesser"] }, "I Am Ready.")
			recieve_bless
		end
		if osacombat_data["uachands"].empty? and osacombat_data["uacfeet"].empty?
			fput "store both"
		else
			if !osacombat_data["uachands"].empty?
				fput "wear #{osacombat_data["uachands"]}"
				pause 0.5
			end
			if !osacombat_data["uacfeet"].empty?
				fput "wear #{osacombat_data["uacfeet"]}"
			end
		end	
	end
end

def cast_bless
	result = matchtimeout 5, /^\[Private\]-GSIV:#{@name}\: \"I Am Ready.\"|^\[Private\]-GSIV:#{@name}\: \"Ok, The Next One Is Ready.\"/
		if result.to_s =~ /^\[Private\]-GSIV:#{@name}\: \"I Am Ready.\"|^\[Private\]-GSIV:#{@name}\: \"Ok, The Next One Is Ready.\"/
			if Spell[1604].known? and Spell[1604].affordable?
				Spell[1604].cast("#{@name}")
			end
			waitcastrt?
			if Spell[304].known? and Spell[304].affordable?
				Spell[304].cast("#{@name}")
			else
				fput "symbol bless #{@name}"
			end
		end
end
		
def give_bless
	lnet_crew("#{@name}")
	result = matchtimeout 5, /^\[Private\]-GSIV:#{@name}\: \"I Have One.\"|^\[Private\]-GSIV:#{@name}\: \"I Have Two.\"/
		if result.to_s =~ /^\[Private\]-GSIV:#{@name}\: \"I Have One.\"/
			cast_bless
		elsif result.to_s =~ /^\[Private\]-GSIV:#{@name}\: \"I Have Two.\"/
			2.times{cast_bless}
		end
end

def who_needs_blessed
	result = matchtimeout 3, /^\[Private\]-GSIV:(.*)\: \"I Need Blessed Please!\"/
	if result.to_s =~ /^\[Private\]-GSIV:(.*)\: \"I Need Blessed Please!\"/
		@blessname.push($1)
		who_needs_blessed
	end
end

def begin_bless
	if (Spell[304].known? or Spell[9802].known?) && osacombat_data["givebless"]
		lnet_crew("I Will Be Providing All Crew Blessings!")
		@blessname = Array.new
		lnet_crew("Does Anyone Need A Bless?")
		who_needs_blessed
		@blessname.each do |n|
			@name = n
			give_bless
		end
		lnet_crew("The Crew Has Been Properly Blessed!")
	else
		lnet_crew("Can Anyone Bless?")
		result = matchtimeout 3, /^\[Private\]-GSIV:(.*)\: \"I Can Captain!\"/
		if result.to_s =~ /^\[Private\]-GSIV:(.*)\: \"I Can Captain!\"/
			save_to_crew("blesser", $1)
			lnet_crew("#{@crew_data["blesser"]}, Will You Please Bless The Crew?")
			waitfor /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["blesser"]}\: \"Does Anyone Need A Bless\?\"/
			get_bless
			waitfor /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["blesser"]}\: \"The Crew Has Been Properly Blessed Captain!"/
		else
			lnet_crew("We Do Not Have Anyone Present Who Can Bless The Crew, We Will Continue Without!")
		end
	end		
end

def status_check
	@capped = false
	exp = Lich::Util.quiet_command("exp", /Level:/, end_pattern = /You mind is (.*)\./, include_end = false ,timeout = 3, silent = true)
	if exp.to_s =~ /Exp to next TP: ([0-9,]+)/
		@capped = true
		@exptntp = $1
	elsif exp.to_s =~ /Exp until lvl: ([0-9,]+)/
		@capped = false
	end
	if exp.to_s =~ /PTPs\/MTPs: ([0-9,]+)\/([0-9,]+)/
		@mtrainingpoints = $2
		@ptrainingpoints = $1
	end
	if !@capped && checkname != @crew_data["commander"]
		pause rand(1..3)
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Health: #{health}/#{maxhealth} | Mana: #{mana}/#{maxmana} | Stamina: #{stamina}/#{maxstamina} | Spirit: #{spirit}/#{maxspirit} | Exp Till Level #{Stats.level.to_i + 1}: #{XMLData.next_level_text.to_i} | State Of Mind: #{checkmind.split(/ |\_/).map(&:capitalize).join(" ")} | Percent Encumberance: #{Char.percent_encumbrance}%")
	end
	if @capped && checkname != @crew_data["commander"]
		pause rand(1..3)
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Health: #{health}/#{maxhealth} | Mana: #{mana}/#{maxmana} | Stamina: #{stamina}/#{maxstamina} | Spirit: #{spirit}/#{maxspirit} | Exp Till Next TP: #{@exptntp} | #{@ptrainingpoints} PTP\'s | #{@mtrainingpoints} MTP\'s | State Of Mind: #{checkmind.split(/ |\_/).map(&:capitalize).join(" ")} | Percent Encumberance: #{Char.percent_encumbrance}%")
	end
	if !@capped && checkname == @crew_data["commander"]
		pause 1
		respond ""
		respond "    Your Stats Are:           Health: #{health}/#{maxhealth} | Mana: #{mana}/#{maxmana} | Stamina: #{stamina}/#{maxstamina} | Spirit: #{spirit}/#{maxspirit} | Exp Till Level #{Stats.level.to_i + 1}: #{XMLData.next_level_text.to_i} | State Of Mind: #{checkmind.split(/ |\_/).map(&:capitalize).join(" ")} | Percent Encumberance: #{Char.percent_encumbrance}%"
		respond ""
	end
	if @capped && checkname == @crew_data["commander"]
		pause 1
		respond ""
		respond "    Your Stats Are:           Health: #{health}/#{maxhealth} | Mana: #{mana}/#{maxmana} | Stamina: #{stamina}/#{maxstamina} | Spirit: #{spirit}/#{maxspirit} | Exp Till Next TP: #{@exptntp} | #{@ptrainingpoints} PTP\'s | #{@mtrainingpoints} MTP\'s | State Of Mind: #{checkmind.split(/ |\_/).map(&:capitalize).join(" ")} | Percent Encumberance: #{Char.percent_encumbrance}%"
		respond ""
	end
end


def gemstone_check
	if checkname != @crew_data["commander"] && !$killtracker[:weekly_gemstone].nil?
		pause rand(1..3)
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Weekly Gemstone: #{$killtracker[:weekly_gemstone]} | Monthly Gemstones:  #{$killtracker[:monthly_gemstones]} | Weekly Searches: #{$killtracker[:weekly_ascension_searches]}")
	end
end

def resource_check
	# Run resource silent to refresh the saved data then read everything from YAML
	begin
		pause rand(1..5)
		start_script("resource", ["silent"])
		wait_while { running?("resource") }
		bonus_file = File.join(DATA_DIR, "resource", "bonuses.yaml")
		return unless File.exist?(bonus_file)

		all_bonuses = YAML.load_file(bonus_file)
		char_key = "#{XMLData.game}:#{Char.name}"
		return unless all_bonuses && all_bonuses[char_key]

		entry      = all_bonuses[char_key]
		prof       = entry[:prof].to_s
		bonus_data = entry[:bonus]
		weekly     = entry[:weekly]
		total      = entry[:total]
		suffused   = entry[:suffused]

		# Map profession to resource type name
		resource_name = case prof
			when "Wizard"   then "Essence"
			when "Sorcerer" then "Necrotic Energy"
			when "Bard"     then "Luck Inspiration"
			when "Cleric"   then "Devotion"
			when "Paladin"  then "Devotion"
			when "Ranger"   then "Nature's Grace"
			when "Empath"   then "Vitality"
			when "Monk"     then "Motes of Tranquility"
			when "Warrior"  then "Grit"
			when "Rogue"    then "Guile"
			else "Resource"
		end

		# Build bonus string per profession
		bonus_msg = case prof
			when "Warrior"
				" | Weapon Bonus: #{bonus_data["Weapon"]} | Armor Bonus: #{bonus_data["Armor"]}"
			when "Monk"
				" | Self Tattoo Bonus: #{bonus_data["Self"]} | Other Tattoo Bonus: #{bonus_data["Other"]}"
			when "Rogue"
				" | Sidestep: #{bonus_data["Sidestep"]} | Keen Eye: #{bonus_data["Keen Eye"]} | Escape Artist: #{bonus_data["Escape Artist"]} | Swift Recovery: #{bonus_data["Swift Recovery"]} | Poisoncraft: #{bonus_data["Poisoncraft"]} | Recharge: #{bonus_data["Recharge"]}"
			when "Wizard"   then " | Enchanting Bonus: #{bonus_data}"
			when "Sorcerer" then " | Ensorcelling Bonus: #{bonus_data}"
			when "Bard"     then " | Luck Bonus: #{bonus_data}"
			when "Cleric"   then " | Sanctify Bonus: #{bonus_data}"
			when "Paladin"  then " | Battle Standard Bonus: #{bonus_data}"
			when "Ranger"   then " | Resist Bonus: #{bonus_data}"
			when "Empath"   then " | Bloodstone Bonus: #{bonus_data}"
			else ""
		end

		suffused_msg = suffused ? " | Suffused: #{suffused}" : ""
		full_msg = "Weekly #{resource_name}: #{weekly} | Total #{resource_name}: #{total}#{suffused_msg}#{bonus_msg}"

		if checkname != @crew_data["commander"]
			pause rand(1..3)
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, full_msg)
		else
			pause 1
			respond ""
			respond "    Your Resource Stats Are:  #{full_msg}"
			respond ""
		end
	rescue => e
		respond "--- OSACrew: resource_check failed: #{e.message}"
	end
end

def crew_match_city
	if (Room.current.location.include? "Landing" or Room.current.location.include? "Solhaven") and (@crew_orders_town.include? "Solhaven" or @crew_orders_town.include? "Landing")
		@crew_city_match = true
	end
	if Room.current.location.include? "River's Rest" and @crew_orders_town.include? "River's Rest"
		@crew_city_match = true
	end
	if Room.current.location.include? "Kharam-Dzu" and @crew_orders_town.include? "Kharam-Dzu"
		@crew_city_match = true
	end
	if Room.current.location.include? "Kraken's Fall" and @crew_orders_town.include? "Kraken's Fall"
		@crew_city_match = true
	end
	if @crew_city_match == true
		start_script("go2", [@crew_orders_room])
		wait_while { running?("go2") }
		wait_until { Room.current.id == @crew_orders_room.to_i }
		fput "go gangplank"
		captains_quarters
		respond "
		Crewman #{checkname} Standing By And Awaiting Orders Captain!
		"
		return
	else	
		respond "
		The Ship Has Arrived In #{@crew_orders_town}, Please Travel Closer Or Await It's Arrival Near #{Room.current.location}
		"
		exit
	end
end

def crew_give_coins
	if @endbalance > 0
		fput "withdraw #{@endbalance} silver"
		@endbalance = 0
	end
	if Lich::Util.silver_count != 0
		fput "give #{@crew_data["commander"]} #{Lich::Util.silver_count}"
	else
		return
	end
end

def crew_start_orders
	@crew_city_match = false
	respond "   ---------------------------==================================================================================================---------------------------

				                                               Welcome Back Crewman #{checkname}, Waiting For The Ship To Arrive!

	   ---------------------------==================================================================================================---------------------------"
	   while line = get
	   case line
	   when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"(.*) Is Now Moored In (.*). Room Number: (.*) \[/
		@crew_orders_town = $2
		@crew_orders_room = $3
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Crewman #{checkname}, Requesting Permission To Come Aboard!")
		result = matchtimeout 30, /^\[Private\]-GSIV:#{@crew_data["commander"]}\: \"Permission Granted\, Come Aboard!"|^\[Private\]-GSIV:#{@crew_data["commander"]}\: \"Permission Denied, Im Sorry Shipmate But The Ship Is Too Full Right Now. Try Again Later!"/
			if result.to_s =~ /^\[Private\]-GSIV:#{@crew_data["commander"]}\: \"Permission Granted\, Come Aboard!"/
				crew_match_city
				return
			elsif result.to_s =~ /^\[Private\]-GSIV:#{@crew_data["commander"]}\: \"Permission Denied, Im Sorry Shipmate But The Ship Is Too Full Right Now. Try Again Later!"/
				respond "
						Sorry Shipmate, The Ship Has A Full Berth! Restarting Orders!
						"
				crew_start_orders
		end
	end	
	end
end

def cast_sails
	if Spell[912].known?
		Spell[912].cast "sail"
	end
	if Spell[612].known?
		Spell[612].cast "sail"
	end
	waitrt?
	pause 0.3
	waitcastrt?
	pause 0.3
end

def winded_sails
	loop do
		# Reload from YAML each pass to pick up what osasail_watch wrote
		@crew_data = osacrew_data
		break unless @crew_data["winded_active"]

		main_deck
		cast_sails

		@crew_data = osacrew_data
		break unless @crew_data["winded_active"]

		if @crew_data["ship_map"]&.include?("mid_deck")
			mid_deck
			cast_sails
		end

		@crew_data = osacrew_data
		break unless @crew_data["winded_active"]

		if @crew_data["ship_map"]&.include?("forward_deck")
			forward_deck
			cast_sails
		end

		@crew_data = osacrew_data
		break unless @crew_data["winded_active"]

		# Wait up to 90 seconds before recasting, but check winded_active every
		# second so any event that ends the routine breaks out immediately
		90.times do
			pause 1
			@crew_data = osacrew_data
			break unless @crew_data["winded_active"]
		end
		break unless @crew_data["winded_active"]
	end

	# Done winding - make sure we end up back at main deck
	main_deck
end

def crew_display_settings
	if osacommander_data["othersailors"]
		$othersailors_value = "Yes"
	else
		$othersailors_value = "No"
	end
	if osacommander_data["stowaways"]
		$stowaways_value = "Yes"
	else
		$stowaways_value = "No"
	end
	if osacommander_data["piratehunter"]
		$piratehunter_value = "Yes"
	else 
		$piratehunter_value = "No"
	end
	if osacommander_data["cleanup"]
		$cleanup_value = "Yes"
	else
		$cleanup_value = "No"
	end
	if osacommander_data["share_silvers"]
		$silversharing_enabled = "Yes"
	else
		$silversharing_enabled = "No"
	end
	if osacommander_data["cleanup_type"] == nil
		$cleanup_type_value = "Normal"
	elsif osacommander_data["cleanup_type"] == "raze"
		$cleanup_type_value = "Raze Spawn"
	elsif osacommander_data["cleanup_type"] == "spawn"
		$cleanup_type_value = "Treasure Spawn"
	end
	respond "

	Your Current Crew Settings Are As Follows:

	Commander:                  #{@crew_data["commander"]}

	Crew:                       #{@crew_data['crew']}

	Medical Officer:            #{@crew_data["medicalofficer"]}

	"
	if checkname == (@crew_data["commander"])
		respond "
		
	You Are Currently Commander Of #{osacommander_data["commander_ship_name"]}, A Battle Ready #{osacommander_data["commander_ship_type"].split(/ |\_/).map(&:capitalize).join(" ")}!

	Current Crew Size:                          #{osacommander_data["crewsize"].count} out of #{osacommander_data["commander_max_crew"]}

	Accepting Outside Scripted Crew:            #{$othersailors_value}

	Pausing For Non-Scripted Crew:              #{$stowaways_value}

	Sharing Silver With Crew:                   #{$silversharing_enabled}

	Enemy Detection Mode:                       #{$piratehunter_value}
	"
	end
end

def crew_disembark
	save_to_crew("depart", true)
	respond ""
	respond "                     You Will Depart The Crew When The Crew Visits The Bank Next!
	                                      Thanks For Sailing With Us...
										 "
end

def crew_crew_swap
	if variable[2].nil?
			respond "
		 
		 Please Select A Valid Commander:
		  
		  ;osacrew swap <commander>
		 
		 "
		return
	else
		LNet.send_message(attr = { 'type' => 'private', 'to' => variable[2] }, "Crewman #{checkname} Checking Onboard Captain!")
		result = matchtimeout 3, /^\[Private\]-GSIV:(.*)\: \"Excellent Crewman #{checkname}, Welcome Aboard! Our Medical Officer Is: (.*). Our Shipboard Communications Channel Is: (.*)\"/
		if result.to_s =~ /^\[Private\]-GSIV:(.*)\: \"Excellent Crewman #{checkname}, Welcome Aboard! Our Medical Officer Is: (.*). Our Shipboard Communications Channel Is: (.*)\"/
			save_to_crew("commander", $1)
			save_to_crew("medicalofficer", $2)
			save_to_crew("crew", $3)
			respond ""
			_respond "\<preset id=\"thought\"\>" + "Your Crew Settings Have Changed And Now Are:" + "\<\/preset\>"
			respond ""
			_respond "\<preset id=\"thought\"\>" + "Crew:                #{@crew_data['crew']}" + "\<\/preset\>"
			_respond "\<preset id=\"thought\"\>" + "Commander:           #{@crew_data["commander"]}" + "\<\/preset\>"
			_respond "\<preset id=\"thought\"\>" + "Medical Officer:     #{@crew_data["medicalofficer"]}" + "\<\/preset\>"
			respond ""
			respond ""
		else
			respond "The Captain Didn't Respond, Try Again Later!"
			respond ""
			respond ""
		end
	end
end

def checkforenemies
	@deadnpcs = GameObj.npcs.find_all { |i| i.status =~ /dead|gone/ }
    @deadnpcs.delete_if { |npc| (npc.name =~ /animated/ && npc.name !~ /animated slush/) }
    @deadnpcs.delete_if { |npc| npc.noun =~ /child|traveller|scribe|merchant|dignitary|official|magistrate/i && npc.name !~ /ethereal|celestial|unworldly/i }
    @deadnpcs.delete_if { |npc| npc.noun =~ /^(?:arm|appendage|claw|limb|pincer|tentacle)s?$|^(?:palpus|palpi)$/i }
	@npcs = GameObj.targets.find_all { |i| i.status !~ /dead|gone/ }
	@npcs.delete_if { |npc| (npc.name =~ /animated/ && npc.name !~ /animated slush/) }
	@npcs.delete_if { |npc| (osacombat_data["exclusion"].to_s.include? npc.name) }
    @npcs.delete_if { |npc| npc.noun =~ /child|traveller|scribe|merchant|dignitary|official|magistrate/i && npc.name !~ /ethereal|celestial|unworldly/i }
    @npcs.delete_if { |npc| npc.noun =~ /^(?:arm|appendage|claw|limb|pincer|tentacle)s?$|^(?:palpus|palpi)$/i }
end	

# One helper to BUILD them all!
def self.ui(parent, type, **o)
	@OSA_CREW_ENTRY ||= {}
	@crew_data ||= {}
	@_ui_sizegroups ||= Hash.new { |h, k| h[k] = {} }  # { group_sym => { col_int => Gtk::SizeGroup } }
	get_key = ->(v) { v.nil? ? nil : v.to_s }
	get_val = ->(key) { d = self.osacrew_data; key && d.key?(key) ? d[key] : nil }
	set_widget_width = lambda do |widget, width|
		return widget unless widget && width
		widget.set_size_request(width, -1)
		widget
	end
	case type
	when :row
		row = Gtk::Box.new(:horizontal, o.fetch(:spacing, 12))
		row.set_halign(o[:halign]) if o[:halign]
		row.set_hexpand(o.fetch(:hexpand, true))
		parent.pack_start(row, false, false, o.fetch(:pad, 0)) if parent
		return row
	when :vrow
		col = Gtk::Box.new(:vertical, o.fetch(:spacing, 8))
		col.set_border_width(o[:border] || 0)
		parent.pack_start(col, false, false, o.fetch(:pad, 0)) if parent
		return col
	when :header
		outer = Gtk::Box.new(:vertical, o.fetch(:spacing, 4))
		label = Gtk::Label.new
		label.set_xalign(0.0)
		label.use_markup = true
		text = o.fetch(:text).to_s
		safe =
			if GLib.respond_to?(:markup_escape_text)
				GLib.markup_escape_text(text)
			else
				text.gsub("&", "&amp;").gsub("<", "&lt;").gsub(">", "&gt;")
			end
		label.label = "<b>#{safe}</b>"
		sep = Gtk::Separator.new(:horizontal)
		outer.pack_start(label, false, false, 0)
		outer.pack_start(sep, false, false, 0)
		parent.pack_start(outer, false, false, o.fetch(:pad, 6)) if parent
		return outer
	when :blank
		spacer = Gtk::Box.new(:vertical, 0)
		spacer.set_size_request(-1, o.fetch(:height, 8))
		parent.pack_start(spacer, false, false, 0) if parent
		return spacer
	when :sep
		s = Gtk::Box.new(:horizontal, 0)
		s.set_size_request(o.fetch(:width, 10), -1)
		parent.pack_start(s, false, false, 0) if parent
		return s
	when :label
		lab = Gtk::Label.new(o.fetch(:text, ""))
		lab.set_xalign(o.fetch(:xalign, 0.0))
		lab.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		set_widget_width.call(lab, o[:width])
		parent.pack_start(lab, false, false, o.fetch(:pad, 0)) if parent
		return lab
	when :entry
		key = get_key.call(o[:var])
		box = Gtk::Box.new(:horizontal, o.fetch(:spacing, 6))
		lab = Gtk::Label.new(o.fetch(:label))
		lab.set_xalign(0.0)
		lab.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		set_widget_width.call(lab, o[:label_width]) if o[:label_width]
		ent = Gtk::Entry.new
		if o[:width_chars]
			ent.width_chars = o[:width_chars]
			ent.max_width_chars = o[:max_width_chars] || o[:width_chars]
		else
			set_widget_width.call(ent, o[:entry_width] || o[:width])
		end
		ent.hexpand = false
		ent.halign = :start
		raw = get_val.call(key)
		ent.text = (raw.nil? || raw.to_s.empty?) ? o.fetch(:default, "").to_s : raw.to_s
		@OSA_CREW_ENTRY[key] = ent if key
		box.pack_start(lab, false, false, 0)
		box.pack_start(ent, false, false, 0)
		set_widget_width.call(box, o[:box_width] || o[:width]) if (o[:box_width] || o[:width])
		parent.pack_start(box, false, false, o.fetch(:pad, 0)) if parent
		return box
	when :check
		key = get_key.call(o[:var])
		cb = Gtk::CheckButton.new(o.fetch(:label))
		cb.tooltip_text = o[:tip] if o[:tip] && !o[:tip].to_s.empty?
		raw = get_val.call(key)
		cb.active = raw.nil? ? !!o.fetch(:default, false) : !!raw
		@OSA_CREW_ENTRY[key] = cb if key
		cb.set_halign(:start)
		cb.set_hexpand(false)
		widget = cb
		if o[:cell_width]
			wrapper = Gtk::Box.new(:horizontal, 0)
			wrapper.set_size_request(o[:cell_width], -1)
			wrapper.set_halign(:start)
			wrapper.pack_start(cb, false, false, 0)
			widget = wrapper
		end
		if o[:group] && o[:col]
			g = o[:group].to_sym
			c = o[:col].to_i
			@_ui_sizegroups[g][c] ||= Gtk::SizeGroup.new(:horizontal)
			@_ui_sizegroups[g][c].add_widget(widget)
		end
		parent.pack_start(widget, false, false, o.fetch(:pad, 0)) if parent
		return widget
	when :check_box
		key = get_key.call(o[:var])
		cb = Gtk::CheckButton.new
		cb.tooltip_text = o[:tip] if o[:tip] && !o[:tip].to_s.empty?
		raw = get_val.call(key)
		cb.active = raw.nil? ? !!o.fetch(:default, false) : !!raw
		@OSA_CREW_ENTRY[key] = cb if key
		cb.set_halign(:start)
		cb.set_hexpand(false)
		parent.pack_start(cb, false, false, o.fetch(:pad, 0)) if parent
		return cb
	when :spell
		r = ui(parent, :row, spacing: o.fetch(:spacing, 10))
		ui(r, :entry,
			label: o[:spell_label],
			tip: o[:spell_tip],
			var: o[:spell_var],
			width_chars: 4,
			entry_width: o.fetch(:spell_width, 50))
		ui(r, :entry,
			label: "Min Stam:",
			var: o[:stam_min_var],
			width_chars: 4,
			default: "0",
			entry_width: o.fetch(:stam_width, 50))
		ui(r, :entry,
			label: "Min Mana:",
			var: o[:mana_min_var],
			width_chars: 4,
			default: "0",
			entry_width: o.fetch(:mana_width, 50))
		ui(r, :entry,
			label: "Min Enemy:",
			var: o[:enemy_min_var],
			width_chars: 4,
			default: "0",
			entry_width: o.fetch(:enemy_min_width, 50))
		ui(r, :entry,
			label: "Max Enemy:",
			var: o[:enemy_max_var],
			width_chars: 4,
			default: "10",
			entry_width: o.fetch(:enemy_max_width, 50))
		ui(r, :check, label: "Warding", var: o[:ward_var])
		ui(r, :check, label: "Channel", var: o[:chan_var])
		ui(r, :check, label: "Evoke", var: o[:evoke_var])
		ui(r, :check, label: "Open", var: o[:open_var])
	when :attack
		r = ui(parent, :row, spacing: o.fetch(:spacing, 10))
		ui(r, :dropdown,
			label: o.fetch(:attack_label, "Attack:"),
			tip: o.fetch(:attack_tip, ""),
			var: o.fetch(:attack_var),
			options: o.fetch(:options),
			default_index: o.fetch(:default_index, 0),
			combo_width: o.fetch(:attack_width, 520))
		ui(r, :entry,
			label: o.fetch(:stam_label, "Min Stam:"),
			tip: o.fetch(:stam_tip, ""),
			var: o.fetch(:stam_min_var),
			default: o.fetch(:stam_default, "0"),
			width_chars: o.fetch(:stam_chars, 4),
			entry_width: o.fetch(:stam_width, 50))
		ui(r, :entry,
			label: o.fetch(:mana_label, "Min Mana:"),
			tip: o.fetch(:mana_tip, ""),
			var: o.fetch(:mana_min_var),
			default: o.fetch(:mana_default, "0"),
			width_chars: o.fetch(:mana_chars, 4),
			entry_width: o.fetch(:mana_width, 50))
		ui(r, :entry,
			label: o.fetch(:enemy_min_label, "Min Enemy:"),
			tip: o.fetch(:enemy_min_tip, ""),
			var: o.fetch(:enemy_min_var),
			default: o.fetch(:enemy_min_default, "0"),
			width_chars: o.fetch(:enemy_min_chars, 4),
			entry_width: o.fetch(:enemy_min_width, 50))
		ui(r, :entry,
			label: o.fetch(:enemy_max_label, "Max Enemy:"),
			tip: o.fetch(:enemy_max_tip, ""),
			var: o.fetch(:enemy_max_var),
			default: o.fetch(:enemy_max_default, "10"),
			width_chars: o.fetch(:enemy_max_chars, 4),
			entry_width: o.fetch(:enemy_max_width, 50))
			return r
	when :ability
		r = ui(parent, :row, spacing: o.fetch(:spacing, 10))
		label_w = o.fetch(:label_width, 175) # adjust once to taste
		ui(r, :label, text: o.fetch(:label), tip: o[:tip].to_s, width: label_w, xalign: 0.0)
		ui(r, :check_box,
			var: o.fetch(:var),
			tip: o[:tip].to_s,
			default: o.fetch(:default, false))
		ui(r, :sep, width: o.fetch(:sep_width, 12))
			fields = o.fetch(:fields, [])
			fields.each do |f|
				ui(r, :entry,
				label: f.fetch(:label),
				tip:   f[:tip].to_s,
				var:   f.fetch(:var),
				default: f.fetch(:default, ""),
				width_chars: f[:chars] || o[:chars] || 4,
				max_width_chars: f[:max_chars] || f[:chars] || o[:chars] || 4,
				entry_width: f[:entry_width] || o[:entry_width] || 90,
				label_width: f[:label_width] || o[:label_width])
			end
		return r
  when :dropdown
		key = get_key.call(o[:var])
		opts =
			case o[:options]
			when String then o[:options].split(/\s*,\s*/)
			when Array  then o[:options]
		else
			raise ArgumentError, "dropdown options must be String or Array"
		end
		box = Gtk::Box.new(:horizontal, o.fetch(:spacing, 6))
		lab = Gtk::Label.new(o.fetch(:label))
		lab.set_xalign(0.0)
		lab.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		set_widget_width.call(lab, o[:label_width]) if o[:label_width]
		combo = Gtk::ComboBoxText.new
		opts.each { |x| combo.append_text(x.to_s) }
			raw = get_val.call(key)
			idx = if raw.nil? || raw.to_s.strip.empty?
            o.fetch(:default_index, 0).to_i
		else
            raw.to_i
		end
		idx = 0 if idx < 0
		idx = opts.length - 1 if idx >= opts.length
		combo.set_active(idx)
		set_widget_width.call(combo, o[:combo_width] || o[:width])
		@OSA_CREW_ENTRY[key] = combo if key
		if o[:group] && o[:col]
			g = o[:group].to_s
			c = o[:col].to_i
			@_ui_sizegroups[g][c] ||= Gtk::SizeGroup.new(:horizontal)
			@_ui_sizegroups[g][c].add_widget(combo)
		end
		box.pack_start(lab, false, false, 0)
		box.pack_start(combo, false, false, 0)
		parent.pack_start(box, false, false, o.fetch(:pad, 0)) if parent
			return box
		else
			raise ArgumentError, "unknown ui type: #{type.inspect}"
		end
end

# ===== population =====

def self.populate_general(rows)
	ui(rows, :header, text: "Chain Of Command Settings:")
	ui(rows, :entry,
	  label: "Ship's Commander:",
	  tip: "This is the character who will be running the script OSACommander to issue commands to the crew.",
	  var: 'commander',
	  default: checkname.to_s,
	  entry_width: 238
	)
	ui(rows, :entry,
	  label: "Ship's Crew Channel:",
	  tip: "This is the LNet channel you will monitor for the commanders commands. This ***MUST*** be set before you can sail. Default setting is your name (to prevent errors).",
	  var: 'crew',
	  default: checkname.to_s,
	  entry_width: 230
	)
	ui(rows, :entry,
	  label: "Ship's Medical Officer:",
	  tip: "This is the designated Empath who will be healing your crew. Only insert a name if the player is running OSACrew. Without a Medical Officer you will default to using the script EHerbs.",
	  var: 'medicalofficer',
	  default: "",
	  entry_width: 220
	)
	ui(rows, :header, text: "General Settings:")
	ui(rows, :entry,
	  label: "Underway Mana Threshold",
	  tip: "This is the percent mana required before reporting back to the commander while getting the ship underway. Default setting is 80.",
	  var: 'checkformana',
	  default: "80",
	  width_chars: 3,
	  entry_width: 90
	)
	add_checks = lambda do |defs, cols: 4, group: :general_checks, spacing: 18|
	defs.each_slice(cols).with_index do |slice, _row_i|
			r = ui(rows, :row, spacing: spacing)
			slice.each_with_index do |d, col|
				ui(r, :check,
				label: d[:label],
				tip: d[:tip].to_s,
				var: d[:var],
				default: d.fetch(:default, false),
				group: group,
				col: col)
			end
		end
	end
	add_checks.call([
    { label: "Perform Crew Tasks", tip: "Checking this will enable the script to handle sails and repairs automatically.", var: 'osacrewtasks'},
	{ label: "Wind The Sails", tip: 'Checking this will enable you to automatically cast "Breeze" or "Call Wind" on the sails to increase the ships speed. Checking this will override any other sailing commands until combat is engaged.', var: 'windedsails', default: false}], cols: 2)
	add_checks.call([
	{ label: "Use Mana Spellup", tip: 'Checking this will enable the script to automatically use "Mana Spellup" before doing crew spellup sessions.', var: 'mana_spellup'},
	{ label: "Spellup Crew", tip: "Checking this will enable the script to cast spells on other crew members during crew spellup sessions.", var: 'groupspellup', default: false},
	{ label: "Spellup Self", tip: "Checking this will enable the script to cast spells on yourself during crew spellup sessions.", var: 'selfspellup' }], cols: 3)
	add_checks.call([
	{ label: "Use Long Term Exp Boost", tip: 'Checking this will enable the script to automatically is a "Long Term Experience Boost" when available, to clear your mind before turning in OSA tasks.', var: 'uselte'},
	{ label: "Sell Loot", tip: "Checking this will enable the script to automatically handle selling loot when the commander calls for it.", var: 'lootsell'}], cols: 2)	
end

def self.populate_support(rows)
ui(rows, :header, text: "Armor Specializations")
	hdr = ui(rows, :row, spacing: 18)
	ui(hdr, :label,
	  text: "Armor Specializations Known:",
	  tip: 'Checking these if known will allow the script to provide the selected specializations to other crew when requested during crew spellup sessions.',
	  xalign: 0.0,
	  width: 190
	)
	ui(hdr, :label,
	  text: "Armor Specialization To Use:",
	  tip: 'Checking one of these will allow the script to utilize that specialization on yourself during a crew spellup session.',
	  xalign: 0.0,
	  width: 175
	)
	ui(hdr, :label,
	  text: "Armor Specialization To Request:",
	  tip: 'Selecting one of these will allow other crew if known, to provide the selected specialization to you during a crew spellup session.',
	  xalign: 0.0,
	  width: 300
	)
	add_checks = lambda do |defs, cols: 4, group: :general_checks, spacing: 50|
	defs.each_slice(cols).with_index do |slice, _row_i|
				r = ui(rows, :row, spacing: spacing)
				slice.each_with_index do |d, col|
					ui(r, :check,
					label: d[:label],
					tip: d[:tip].to_s,
					var: d[:var],
					default: d.fetch(:default, false),
					group: group,
					col: col)
				end
			end
		end
	add_checks.call([
	  { label: "Armor Blessing", tip: "+10% per rank to reduce wound stacking caused by magical sources.", var: 'have_armor_blessing', default: false },
	  { label: "Armor Blessing", tip: "+10% per rank to reduce wound stacking caused by magical sources.", var: 'use_armor_blessing',  default: false },
	  { label: "Armor Blessing", tip: "+10% per rank to reduce wound stacking caused by magical sources.", var: 'need_armor_blessing', default: false  }], cols: 3)
	add_checks.call([
	  { label: "Armor Reinforcement", tip: "Provides a (Rank * 15)% chance of not stacking wounds of the same level when struck in combat by an attack that Damage Reduction could apply against.", var: 'have_armor_reinforcement', default: false },
	  { label: "Armor Reinforcement", tip: "Provides a (Rank * 15)% chance of not stacking wounds of the same level when struck in combat by an attack that Damage Reduction could apply against.", var: 'use_armor_reinforcement',  default: false },
	  { label: "Armor Reinforcement", tip: "Provides a (Rank * 15)% chance of not stacking wounds of the same level when struck in combat by an attack that Damage Reduction could apply against.", var: 'need_armor_reinforcement', default: false  }], cols: 3)
	add_checks.call([
	  { label: "Armor Support", tip: "Reduces encumbrance by a number of pounds equal to 5 + ((Armor Group + 1) * Rank).", var: 'have_armor_support', default: false },
	  { label: "Armor Support", tip: "Reduces encumbrance by a number of pounds equal to 5 + ((Armor Group + 1) * Rank).", var: 'use_armor_support',  default: false },
	  { label: "Armor Support", tip: "Reduces encumbrance by a number of pounds equal to 5 + ((Armor Group + 1) * Rank).", var: 'need_armor_support', default: false  }], cols: 3)
	add_checks.call([
	  { label: "Armored Casting", tip: "Fumbling or spell hindrance will cause (Armor Group * (6 - Rank)) seconds of hard roundtime instead of failing the cast. Roundtime may not be reduced with haste effects, and being undertrained for your armor will increase the roundtime. This skill has a minimum RT of 3 seconds and cannot be reduced below that value.", var: 'have_armor_casting', default: false },
	  { label: "Armored Casting", tip: "Fumbling or spell hindrance will cause (Armor Group * (6 - Rank)) seconds of hard roundtime instead of failing the cast. Roundtime may not be reduced with haste effects, and being undertrained for your armor will increase the roundtime. This skill has a minimum RT of 3 seconds and cannot be reduced below that value.", var: 'use_armor_casting',  default: false },
	  { label: "Armored Casting", tip: "Fumbling or spell hindrance will cause (Armor Group * (6 - Rank)) seconds of hard roundtime instead of failing the cast. Roundtime may not be reduced with haste effects, and being undertrained for your armor will increase the roundtime. This skill has a minimum RT of 3 seconds and cannot be reduced below that value.", var: 'need_armor_casting', default: false }], cols: 3)
	add_checks.call([
	  { label: "Armored Evasion", tip: "Reduces the Armor Action Penalty by (Rank * (7 - Armor Group)) / 2.", var: 'have_armor_evasion', default: false },
	  { label: "Armored Evasion", tip: "Reduces the Armor Action Penalty by (Rank * (7 - Armor Group)) / 2.", var: 'use_armor_evasion',  default: false },
	  { label: "Armored Evasion", tip: "Reduces the Armor Action Penalty by (Rank * (7 - Armor Group)) / 2.", var: 'need_armor_evasion', default: false }], cols: 3)
	add_checks.call([
	  { label: "Armored Fluidity", tip: "Reduces spell failure chance by 10% of the base spell failure chance per rank (all fractions dropped).", var: 'have_armor_fluidity', default: false },
	  { label: "Armored Fluidity", tip: "Reduces spell failure chance by 10% of the base spell failure chance per rank (all fractions dropped).", var: 'use_armor_fluidity',  default: false },
	  { label: "Armored Fluidity", tip: "Reduces spell failure chance by 10% of the base spell failure chance per rank (all fractions dropped).", var: 'need_armor_fluidity', default: false }], cols: 3)
	add_checks.call([
	  { label: "Armored Stealth", tip: "Provides a bonus to Stealth rolls equal to (Rank * 2 * (5 - Armor Group)).", var: 'have_armor_stealth', default: false },
	  { label: "Armored Stealth", tip: "Provides a bonus to Stealth rolls equal to (Rank * 2 * (5 - Armor Group)).", var: 'use_armor_stealth',  default: false },
	  { label: "Armored Stealth", tip: "Provides a bonus to Stealth rolls equal to (Rank * 2 * (5 - Armor Group)).", var: 'need_armor_stealth', default: false }], cols: 3)
	ui(rows, :blank, height: 8)
	add_checks.call([
	  { label: "Use Armor Specializations On Crew", tip: "Checking this will allow the use of selected specializations on other crew when requested during crew spellup sessions.", var: 'armor_specs', default: false }], cols: 1, group: :armor_specs)
end

def self.populate_cannons(rows)
	ui(rows, :header, text: "Cannon Settings")

	# Helper to unwrap a widget that may be inside a Box wrapper
	unwrap = ->(w) { w.is_a?(Gtk::Box) ? w.children.first : w }

	# --- Use Cannons (single checkbox, col 1) ---
	r0 = ui(rows, :row, spacing: 50)
	ui(r0, :check,
		label: "Use Cannons",
		tip: "Checking this will allow the script when called for by the commander, to utilize the shipboard cannons in combat.",
		var: 'cannoneer', default: false, group: :general_checks, col: 0)

	# --- Duties (col 0) and Cannons (col 1), laid out in 3 rows ---
	duty_defs = [
		{ label: "Load Only",    tip: "Checking this will allow the script to only load selected cannons.",            var: 'loadonly',      default: false },
		{ label: "Fire Only",    tip: "Checking this will allow the script to only fire selected cannons.",            var: 'fireonly',      default: false },
		{ label: "Load And Fire",tip: "Checking this will allow the script to load and fire selected cannons.",        var: 'loadandfire',   default: false },
	]
	cannon_defs = [
		{ label: "Main Cannons",    tip: "Checking this will enable use of the cannons on the \"Main Deck\" of the ship.",                    var: 'maincannons',    default: false },
		{ label: "Mid Cannons",     tip: "Checking this will enable use of the cannons on the \"Mid Deck\" of the ship.",                     var: 'midcannons',     default: false },
		{ label: "Forwards Cannons",tip: "Checking this will enable use of the cannons on the \"Forward Deck\" or \"Bow\" of the ship.",      var: 'forwardcannons', default: false },
	]
	duty_defs.zip(cannon_defs).each_with_index do |(dd, cd), _i|
		r = ui(rows, :row, spacing: 50)
		ui(r, :check, label: dd[:label], tip: dd[:tip].to_s, var: dd[:var], default: dd.fetch(:default, false), group: :general_checks, col: 0)
		ui(r, :check, label: cd[:label], tip: cd[:tip].to_s, var: cd[:var], default: cd.fetch(:default, false), group: :general_checks, col: 1)
	end

	# Grab duty widgets
	cb_loadonly    = unwrap.call(@OSA_CREW_ENTRY['loadonly'])
	cb_fireonly    = unwrap.call(@OSA_CREW_ENTRY['fireonly'])
	cb_loadandfire = unwrap.call(@OSA_CREW_ENTRY['loadandfire'])
	duty_cbs = [cb_loadonly, cb_fireonly, cb_loadandfire]

	# Grab cannon widgets
	cb_main    = unwrap.call(@OSA_CREW_ENTRY['maincannons'])
	cb_mid     = unwrap.call(@OSA_CREW_ENTRY['midcannons'])
	cb_forward = unwrap.call(@OSA_CREW_ENTRY['forwardcannons'])
	cannon_cbs = [cb_main, cb_mid, cb_forward]

	# Wire duty mutual exclusion - selecting one unchecks the other two
	duty_cbs.each do |cb|
		cb.signal_connect("toggled") do
			if cb.active?
				(duty_cbs - [cb]).each { |other| other.active = false }
			end
		end
	end

	# Wire cannon mutual exclusion - selecting one unchecks the other two
	cannon_cbs.each do |cb|
		cb.signal_connect("toggled") do
			if cb.active?
				(cannon_cbs - [cb]).each { |other| other.active = false }
			end
		end
	end
end

def self.crewsetup
	if @OSA_CREW_WINDOW
		begin
		@OSA_CREW_WINDOW.present
		return
		rescue
		@OSA_CREW_WINDOW = nil
		end
	end
	GLib::Idle.add do
		begin
			build_crewsetup_window
			rescue => e
			puts "--- OsaCrew GUI error: #{e.class}: #{e.message}"
			puts e.backtrace.join("\n")
		end
		false
	end
	nil
end

def self.save_settings!
  crew_keys = %w[
    commander crew medicalofficer checkformana osacrewtasks windedsails
    mana_spellup groupspellup selfspellup uselte lootsell armor_specs
    have_armor_blessing use_armor_blessing need_armor_blessing
    have_armor_reinforcement use_armor_reinforcement need_armor_reinforcement
    have_armor_support use_armor_support need_armor_support
    have_armor_casting use_armor_casting need_armor_casting
    have_armor_evasion use_armor_evasion need_armor_evasion
    have_armor_fluidity use_armor_fluidity need_armor_fluidity
    have_armor_stealth use_armor_stealth need_armor_stealth
    cannoneer loadonly fireonly loadandfire maincannons midcannons forwardcannons
    givebless needbless blesser my_armor_spec othersailors stowaways
  ]
  crew_keys.each { |k| save_to_crew(k, @crew_data[k]) if @crew_data.key?(k) }
  @crew_data = self.osacrew_data
  respond "--- OSACrew: Settings saved."
end
def self.profiles_dir
	File.join(DATA_DIR, XMLData.game, Char.name, "osacrew profiles")
end

def self.profile_path(name)
	File.join(profiles_dir, "#{name}.yaml")
end

def self.list_profiles
	FileUtils.mkdir_p(profiles_dir)
	Dir.glob(File.join(profiles_dir, "*.yaml")).map { |f| File.basename(f, ".yaml") }.sort
rescue StandardError
	[]
end

def self.save_profile(name)
	FileUtils.mkdir_p(profiles_dir)
	File.write(profile_path(name), YAML.dump(@crew_data))
	respond "--- OSACrew: Profile saved: #{name}"
rescue StandardError => e
	respond "--- OSACrew: Save failed: #{e.message}\n#{e.backtrace.first(3).join('\n')}"
end

def self.load_profile(name)
	path = profile_path(name)
	return unless File.exist?(path)
	raw  = File.read(path)
	data = YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}
	@crew_data = data.transform_keys(&:to_s)
	full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacrew.yaml")
	File.write(full_path, YAML.dump(@crew_data))
	respond "--- OSACrew: Profile loaded: #{name}"
rescue StandardError => e
	respond "--- OSACrew: Load failed: #{e.message}"
end

def self.delete_profile(name)
	File.delete(profile_path(name)) if File.exist?(profile_path(name))
	respond "--- OSACrew: Profile deleted: #{name}"
rescue StandardError => e
	respond "--- OSACrew: Delete failed: #{e.message}"
end

def self.refresh_crew_widgets
	return unless @OSA_CREW_ENTRY && @OSA_CREW_WINDOW
	@OSA_CREW_ENTRY.each do |var, widget|
		value = @crew_data[var.to_s]
		next if value.nil?
		begin
			if widget.is_a?(Gtk::CheckButton)
				widget.active = value ? true : false
			elsif widget.is_a?(Gtk::Entry)
				widget.text = value.to_s
			elsif widget.is_a?(Gtk::ComboBoxText)
				found = false
				widget.model.each do |_m, _path, iter|
					if iter[0].to_s == value.to_s
						widget.active_iter = iter
						found = true
						break
					end
				end
				widget.active = -1 unless found
			end
		rescue StandardError
			next
		end
	end
end

def self.build_crewsetup_window
	self.load_crew_yaml
	@OSA_CREW_WINDOW = Gtk::Window.new
	@OSA_CREW_WINDOW.set_default_size(1155, 900)
	@OSA_CREW_WINDOW.title = TITLE
	@OSA_CREW_WINDOW.set_border_width(10)
	@OSA_CREW_WINDOW.keep_above = true
	@OSA_CREW_WINDOW.signal_connect("destroy") do
		@OSA_CREW_WINDOW = nil
	end
	main_box = Gtk::Box.new(:vertical, 0)
	main_box.set_border_width(5)
	@OSA_CREW_WINDOW.add(main_box)
	notebook = Gtk::Notebook.new
	notebook.set_show_border(true)
	notebook.set_scrollable(true)
	main_box.pack_start(notebook, true, true, 0)
	@OSA_CREW_ENTRY = {}
	tab_names = ["General", "Support", "Cannons"]
	tab_names.each.with_index(1) do |name, idx|
		page_box = Gtk::Box.new(:vertical, 0)
		scroller = Gtk::ScrolledWindow.new
		scroller.set_policy(Gtk::POLICY_NEVER, Gtk::POLICY_AUTOMATIC)
		scroller.hexpand = true
		scroller.vexpand = true
		rows = Gtk::Box.new(:vertical, 8)
		rows.set_border_width(6)
		scroller.add(rows)
		page_box.pack_start(scroller, true, true, 0)
		notebook.append_page(page_box, Gtk::Label.new(name))
		instance_variable_set("@OSA_CREW_ROWS#{idx}", rows)
	end
	populate_general(@OSA_CREW_ROWS1)
	populate_support(@OSA_CREW_ROWS2)
	populate_cannons(@OSA_CREW_ROWS3)

	# Profiles section
	profile_sep = Gtk::Separator.new(:horizontal)
	main_box.pack_start(profile_sep, false, false, 4)
	profile_header = Gtk::Label.new
	profile_header.set_markup("<b>Profiles:</b>")
	profile_header.set_halign(:start)
	main_box.pack_start(profile_header, false, false, 2)
	# Row 1: combo + Load + Save + Delete
	profile_row1 = Gtk::Box.new(:horizontal, 6)
	profile_row1.set_border_width(4)
	@crew_profile_combo = Gtk::ComboBoxText.new
	list_profiles.each { |p| @crew_profile_combo.append_text(p) }
	@crew_profile_combo.active = 0 unless list_profiles.empty?
	profile_row1.pack_start(@crew_profile_combo, true, true, 4)
	profile_load_btn = Gtk::Button.new(label: "Load")
	profile_load_btn.signal_connect("clicked") do
		name = @crew_profile_combo.active_text
		next unless name && !name.empty?
		load_profile(name)
		refresh_crew_widgets
	end
	profile_row1.pack_start(profile_load_btn, false, false, 2)
	profile_save_btn = Gtk::Button.new(label: "Save")
	profile_save_btn.signal_connect("clicked") do
		name = @crew_profile_combo.active_text
		next unless name && !name.empty?
		save_settings!
		save_profile(name)
	end
	profile_row1.pack_start(profile_save_btn, false, false, 2)
	profile_del_btn = Gtk::Button.new(label: "Delete")
	profile_del_btn.signal_connect("clicked") do
		name = @crew_profile_combo.active_text
		next unless name && !name.empty?
		delete_profile(name)
		@crew_profile_combo.remove_all
		list_profiles.each { |p| @crew_profile_combo.append_text(p) }
		@crew_profile_combo.active = 0 unless list_profiles.empty?
	end
	profile_row1.pack_start(profile_del_btn, false, false, 2)
	main_box.pack_start(profile_row1, false, false, 0)
	# Row 2: name entry + Save As
	profile_row2 = Gtk::Box.new(:horizontal, 6)
	profile_row2.set_border_width(4)
	@crew_profile_name_entry = Gtk::Entry.new
	@crew_profile_name_entry.placeholder_text = "New profile name..."
	profile_row2.pack_start(@crew_profile_name_entry, true, true, 4)
	save_as_btn = Gtk::Button.new(label: "Save As")
	save_as_btn.signal_connect("clicked") do
		name = @crew_profile_name_entry.text.strip
		next if name.empty?
		begin
			save_settings!
			save_profile(name)
			@crew_profile_name_entry.text = ""
			@crew_profile_combo.remove_all
			list_profiles.each { |p| @crew_profile_combo.append_text(p) }
			@crew_profile_combo.active = list_profiles.index(name) || 0
		rescue StandardError => e
			respond "--- OSACrew: Save As failed: #{e.message}"
		end
	end
	profile_row2.pack_start(save_as_btn, false, false, 2)
	main_box.pack_start(profile_row2, false, false, 0)

	button_row = Gtk::Box.new(:horizontal, 12)
	button_row.set_halign(:end)
	save_btn  = Gtk::Button.new(label: "Save")
	close_btn = Gtk::Button.new(label: "Close")
	# Capture explicit references so the GTK callback closure has no
	# ambiguity about what self is inside the signal block.
	klass     = self
	entry_map = @OSA_CREW_ENTRY
	save_btn.signal_connect("clicked") do
		full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacrew.yaml")
		FileUtils.mkdir_p(File.dirname(full_path))
		File.open(full_path, File::RDWR | File::CREAT, 0o644) do |file|
			file.flock(File::LOCK_EX)
			raw  = file.read.to_s
			data = begin
				raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
			rescue StandardError
				{}
			end
			data = data.transform_keys(&:to_s)
			entry_map.each do |var_name, widget|
				data[var_name] =
					if widget.is_a?(Gtk::CheckButton)
						widget.active?
					elsif widget.is_a?(Gtk::Entry)
						widget.text
					elsif widget.is_a?(Gtk::ComboBoxText)
						widget.active
					end
			end
			file.rewind
			YAML.dump(data, file)
			file.flush
			file.truncate(file.pos)
		end
		klass.instance_variable_set(:@crew_data, klass.osacrew_data)
		respond "--- OSACrew: Settings saved."
	end
	close_btn.signal_connect("clicked") do 
		Gtk.queue do
			@OSA_CREW_WINDOW.hide
			@OSA_CREW_WINDOW.destroy
		end
	end
	button_row.pack_start(save_btn, false, false, 0)
	button_row.pack_start(close_btn, false, false, 0)
	main_box.pack_start(button_row, false, false, 6)
	@OSA_CREW_WINDOW.show_all
end

def self.save_to_crew(key, value, push: false)
	full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacrew.yaml")
	FileUtils.mkdir_p(File.dirname(full_path))
	File.open(full_path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read.to_s
		data = begin
			raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
			rescue StandardError; {}
			end
		data = data.transform_keys(&:to_s)
		k = key.to_s
		if push
			data[k] = [] unless data[k].is_a?(Array)
			data[k] << value
		else
			data[k] = value
		end
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
		@crew_data = data
	end
end

