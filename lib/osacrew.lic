def self.load_crew_yaml
	Settings.load
	dir = File.join(DATA_DIR, XMLData.game, Char.name)
	FileUtils.mkdir_p(dir) unless Dir.exist?(dir)
	path = File.join(dir, "osacrew.yaml")
	data = {}
	File.open(path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read
		if raw && !raw.strip.empty?
			data = YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}
		else
			data = {}
			file.rewind
			file.write(YAML.dump(data))
			file.flush
			file.truncate(file.pos)
		end
	end
	data = data.transform_keys(&:to_s)
	@crew_data = data
	Settings[Char.name]["osa_vars_yaml_file"] = path
	Settings.save
	path
end
TITLE = "OSACrew: v. (#{version})"
require "yaml"
require "gtk3"
require "fileutils"
toggle_upstream
self.load_crew_yaml

if script.vars[1] =~ /call/
(eval script.vars[2]).call
elsif (script.vars[1] =~ /setup/i)
  self.crewsetup
  exit
elsif (Script.current.vars[1] =~ /profile/i)
	self.profile(Script.current.vars)
	exit
elsif (script.vars[1] =~ /navigation/i)
	if Room.current.location != "Ships"
		respond "
				 Please Restart When You Are On Your Ship
				 "
	else
		ship_map
		end
	save_to_commander("piratehunter", false)
elsif script.vars[1].downcase == 'help'
	crew_help_display
	exit
	elsif script.vars[1].downcase == 'cannons'
		save_to_crew("cannoneer_boarded", false)
		save_to_crew("cannoneer_thirty",  false)
		save_to_crew("cannoneer_sunk",    false)
		save_to_crew("cannoneer_stop",    false)
		gunner_set_mode
		start_script("osacannon_watch") unless running?("osacannon_watch")
		gunner_cycle
		stop_script("osacannon_watch") if running?("osacannon_watch")
		save_to_crew("cannoneer_boarded", false)
		save_to_crew("cannoneer_thirty",  false)
		save_to_crew("cannoneer_sunk",    false)
		save_to_crew("cannoneer_stop",    false)
		exit
elsif script.vars[1].downcase == 'swap'
	crew_crew_swap
elsif script.vars[1].downcase == 'orders'
	crew_start_orders
elsif script.vars[1] == '?'
	crew_help_display
	exit
elsif script.vars[1] == 'version'
	respond ""
	respond "OSACrew Version #{version}"
	respond ""
	exit
elsif script.vars[1] =~ /underway/
		if script.vars[2].nil?
			ship_map
			if @crew_data["ship_type"] == "sloop"
				one_mast
			elsif (@crew_data["ship_type"] == "brigantine" or @crew_data["ship_type"] == "carrack" or @crew_data["ship_type"] == "galleon" or @crew_data["ship_type"] == "frigate")
				two_masts
			elsif @crew_data["ship_type"] == "man o' war"
				three_masts
			end		
			echo "Raising Anchor"
			helm
			raise_anchor
			waitrt?
			pause 0.1
			if @anchor_aweigh
				fput "yell Anchor's Aweigh!"
				@anchor_aweigh = false
			end
			multifput "depart","depart"
			fput "yell Underway!"
			exit
		end
		if !script.vars[2].include? "sai" and !variable[2].include? "anc"
			respond "
					Please Select A Valid Underway Option: Sails or Anchor.
						No Option Will default To Full Underway Process
					"
		end
		if script.vars[2].include? "sai"
			ship_map
			if @crew_data["ship_type"] == "sloop"
				one_mast
			elsif (@crew_data["ship_type"] == "brigantine" or @crew_data["ship_type"] == "carrack" or @crew_data["ship_type"] == "galleon" or @crew_data["ship_type"] == "frigate")
				two_masts
			elsif @crew_data["ship_type"] == "man o' war"
				three_masts
			end
		end
		if script.vars[2].include? "anc"
			ship_map
			helm
			raise_anchor
			if @anchor_aweigh
				fput "yell Anchor's Aweigh!"
				@anchor_aweigh = false
			end
		end	
elsif script.vars[1] =~ /repairs/
	damage_control
	exit
elsif script.vars[1] =~ /settings/
	crew_display_settings
	exit
end

if @crew_data['crew'].empty? or @crew_data['crew'].nil?
	respond "*********** Your Crew Channel Is Not Set, Please Set Your Crew Channel Before Proceeding (If You Do Not Have One Set, Use Your Character\'s First Name) ************"
	exit
end
if @crew_data['commander'].empty? or @crew_data['commander'].nil?
	respond "*********** Your Commander Is Not Set, Please Set Your Crew Channel Before Proceeding (If You Do Not Have One, Use Your Character\'s First Name) ************"
	exit
end

ship_type
determine_group_members
mana_share
check_dependencies("OSACrew", [
	{ name: "eloot",           author: "elanthia-online" },
	{ name: "eherbs",          author: "elanthia-online" },
	{ name: "foreach",         author: "elanthia-online" },
	{ name: "ewaggle",         author: "elanthia-online" },
	{ name: "ecure",           author: "elanthia-online" },
	{ name: "lnet",            author: "elanthia-online" },
	{ name: "osasail_watch",   author: "peggyanne"       },
	{ name: "osacannon_watch", author: "peggyanne"       },
	{ name: "osa_migrate",     author: "peggyanne"       },
])
fput "flag sortedview on"
$matched_type = false
@crew_lowered_sail = false
@crew_anchor_aweigh = false
@medicalofficer_patient = Array.new
@supportlist = Array.new
@severlist = Array.new
save_to_crew("cannoneer_boarded", false)
save_to_crew("cannoneer_thirty", false)
save_to_crew("cannoneer_sunk", false)
save_to_crew("cannoneer_stop", false)
save_to_crew("depart", false)
save_to_commander("piratehunter", false)
save_to_crew("logging", false)
if @crew_data["boarding"].nil?
	save_to_crew("boarding", false)
end
if @crew_data["sunk_ship"].nil?
	save_to_crew("sunk_ship", false)
end
if checkname != @crew_data["commander"]
	save_to_commander("cleanup", false)
	save_to_commander("piratehunter", false)
end
if script.vars[1].nil?
	crew_display_settings
end
save_to_crew("winded_active", false)
@mana_watcher = nil
Room[30129].tags.push("meta:trashcan:bucket")
Room[30175].tags.push("meta:trashcan:bucket")
Room[30180].tags.push("meta:trashcan:bucket")
Room[30124].tags.push("meta:trashcan:bucket")
Room[30140].tags.push("meta:trashcan:bucket")
Room[29042].tags.push("meta:trashcan:bucket")

before_dying {
	stop_script("osacannon_watch") if running?("osacannon_watch")
	stop_script("osasail_watch")   if running?("osasail_watch")
	@mana_watcher.kill if @mana_watcher&.alive?
	if (checkname == (@crew_data["commander"])) && !@crew_data["crew"].empty?
		if script.vars[1] != /settings/
			lnet_crew("*Ding* *Ding* #{osacommander_data["commander_ship_name"]} Departing!") if !@crew_data["crew"].empty?
		end
	else
		if (!script.vars[1] != /settings/) && !@crew_data["crew"].empty?
			lnet_crew("*Ding* *Ding* Crewman #{checkname} Departing!") if !@crew_data["crew"].empty?
		end
	end
}

while line = get
	case line
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["blesser"]}\: \"Does Anyone Need A Bless\?\"/
		if running? "osacommander"
			next
		end
		if osacombat_data["needbless"]
			get_bless
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Enemy Vessel Detected, (.*) Sound General Quarters! Gunners Man Your Irons!"/
		if $1.downcase.include? "ethereal"
			save_to_crew("enemy_type", "undead")
		end
		if $1.downcase.include? "krolvin"
			save_to_crew("enemy_type", "krolvin")
		end
		if $1.downcase.include? "dark"
			save_to_crew("enemy_type", "pirate")
		end
		ship_map
		if @crew_data["cannoneer"]
			save_to_crew("cannoneer_boarded", false)
			save_to_crew("cannoneer_thirty",  false)
			save_to_crew("cannoneer_sunk",    false)
			save_to_crew("cannoneer_stop",    false)
			stop_script("osacannon_watch") if running?("osacannon_watch")
			start_script("osacannon_watch")
			gunner_cycle
			stop_script("osacannon_watch") if running?("osacannon_watch")
		else
			if osacombat_data["osacombat"]
				if !running? "osacombat"
					start_script "osacombat"
				end
			else
				echo "You Are Not Currently In A Combatant Role, Ready Thyself For Combat!"
				if checkname != "Tearieyes"
					do_client "gird"
				else
					fput "get stick from my sling"
				end
				if @crew_data["medicalofficer"].include? "#{checkname}"
					captains_quarters
				end
			end
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Enemy Vessel Detected, (.*) Inbound. Sound General Quarters!"/
		if $1.downcase.include? "ethereal"
			save_to_crew("enemy_type", "undead")
			save_to_combat("creature_type", "undead")
		end
		if $1.downcase.include? "krolvin"
			save_to_crew("enemy_type", "krolvin")
			save_to_combat("creature_type", "living")
		end
		if $1.downcase.include? "dark"
			save_to_crew("enemy_type", "pirate")
			save_to_combat("creature_type", "living")
		end
		ship_map
		if @crew_data["windedsails"]
			save_to_crew("winded_active", true)
			@crew_data = osacrew_data
			stop_script("osasail_watch") if running?("osasail_watch")
			start_script("osasail_watch", ["combat"])
			winded_sails
			stop_script("osasail_watch") if running?("osasail_watch")
			save_to_crew("winded_active", false)
			wait_until { checkpcs.include?(@crew_data["commander"]) }
			fput "join #{@crew_data["commander"]}"
		end
		if osacombat_data["osacombat"]
			if !running? "osacombat"
				start_script "osacombat"
			end
		else
			echo "You Are Not Currently In A Combatant Role, Ready Thyself For Combat!"
			if checkname != "Tearieyes"
				do_client "gird"
			else
				fput "get stick from my sling"
			end
			if @crew_data["medicalofficer"].include? "#{checkname}"
				captains_quarters
			end
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "(.*) Expects To Make Way From/
		if @crew_data["windedsails"]
			save_to_crew("winded_active", true)
			@crew_data = osacrew_data
			stop_script("osasail_watch") if running?("osasail_watch")
			start_script("osasail_watch", ["underway"])
			winded_sails
			stop_script("osasail_watch") if running?("osasail_watch")
			save_to_crew("winded_active", false)
			wait_until { checkpcs.include?(@crew_data["commander"]) }
			fput "join #{@crew_data["commander"]}"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Turn To!\"/
		ship_type
		wait_until { !running?("eloot") }
		if osacombat_data["osacombat"]
				stop_script "osacombat"
				wait_while { running?("osacombat") }
		end
		waitrt?
		waitcastrt?
		if !GameObj.left_hand.id.nil? or !GameObj.right_hand.id.nil?
			fput "store both"
		end
		fput "leave"
		pause 0.5
		fput "group open"
		if Room.current.tags.include? "captains_quarters"
			nil
		else
			damage_control
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Stop\"/
		if osacombat_data["osacombat"]
			if running? "osacombat"
				stop_script "osacombat"
				wait_while { running?("osacombat") }
			end
			waitrt?
			waitcastrt?
			fput "store both"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"All Hands Make Ready To Get Underway!\"/
		ship_map
		if @crew_data["osacrewtasks"]
			fput "leave"
			pause 0.5
			fput "group open"
			main_deck
			if @crew_data["ship_type"] == "sloop"
				one_mast
			elsif (@crew_data["ship_type"] == "brigantine" or @crew_data["ship_type"] == "carrack" or @crew_data["ship_type"] == "galleon" or @crew_data["ship_type"] == "frigate")
				two_masts
			elsif @crew_data["ship_type"] == "man o' war"
				three_masts
			end
			#move "go door"
			captains_quarters
		else
			captains_quarters
			echo "You Are Not Currently In A Crew Role, Please Standby To Standby!" 
		end
		pause 1
		if percentmana <= 84
			respond ""
			respond "          -----------------------------------------------------"
			respond "          |                Waiting For Mana                   |"
			respond "          -----------------------------------------------------"
			respond ""
			wait_until {percentmana >= 85}
		end
		pause 5
		wait_until {Room.current.tags.include? "captains_quarters"}
		crew_task_complete
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Status Report\"/
		status_check
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Resource Report\"/
		resource_check
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Gemstone Report\"/
		gemstone_check
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Spells\"/
		crew_spell_up
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Crew, Spell Up (.*).\"/
		$pc = $1
		crew_spell_individual
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Task Time!\"/
		crew_check_task
		
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Deposit\"/
		fput "depo all"
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Sheath\"/
		do_client "sheath"
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Reset\"/
		do_client ";e stop_script 'osacrew';wait_while { running?('osacrew') };start_script 'osacrew'"
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Change Of Command: (.*)\"/
		save_to_crew("commander", $1)
		respond "
		Your New Commanding Officer Is Now: #{@crew_data["commander"]}
		"
		when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Crew Swap: (.*)\"/
		do_client ";lnet untune #{@crew_data["crew"]}"
		pause 0.5
		save_to_crew("crew", $1)
		pause 0.5
		do_client ";lnet tune #{@crew_data["crew"]}"
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Pause\"/
		if osacombat_data["osacombat"]
			if running? "osacombat"
				pause_script "osacombat"
			end
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Unpause\"/
		if osacombat_data["osacombat"]
			if running? "osacombat"
				unpause_script "osacombat"
			end
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*)\: \"I Need (.*) Mana!\"$/
		@manaperson = $1
		$mana_type_needed = Array.new
		$mana_type_needed.clear
		replacements = {'or ' => ' ', ' ' => '', ',' => ' '}
		$mana_type_needed = $2.gsub(Regexp.union(replacements.keys), replacements).split(' ')
		$mana_type_needed.each do |n|
			$matched_type = true if $my_mana_type.include? (n)
		end
		crew_send_mana
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Make Repairs!\"/
		damage_control
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Can Anyone Bless\?\"/
		if osacombat_data["givebless"]
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "I Can Captain!")
			result = matchtimeout 3, /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"#{checkname}, Will You Please Bless The Crew\?"/
				if result.to_s =~ /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"#{checkname}, Will You Please Bless The Crew\?"/
					lnet_crew("Of Course Captain!")
					@blessname = Array.new
					lnet_crew("Does Anyone Need A Bless?")
					who_needs_blessed
					@blessname.each do |n|
						@name = n
						give_bless
					end
					lnet_crew("The Crew Has Been Properly Blessed Captain!")
				else
					next
				end
		else
			next
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"(.*), Will You Please Bless The Crew\?\"/
		save_to_crew("blesser", $1)
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*)\: \"I Will Be Providing All Crew Blessings!\"/
		save_to_crew("blesser", $1)
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Quarters! All Hands To Quarters For Muster, Instruction and Inspection!\"/
			pause rand(1..5)
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Crewman #{checkname} Reporting For Duty Captain!")
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Current Version Are As Follows(.)/
		start_script("osacombat", ["version"])
		lnet_crew("My Versions are as follows: Combat #{osacommander_data["combatversion"]} and Crew #{@crew_data["crewversion"]}")
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: "Take Us To Hallowed Ground #{checkname}"$/
		if Spell[220].known?
			pause_script("osacombat") if running?("osacombat")
			pause_script("ecure") if running?("ecure")
			waitrt?
			waitcastrt?
			fput "release"
			waitrt?
			waitcastrt?
			Spell[220].cast
			unpause_script("ecure") if running?("ecure")
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: "Take Us Back #{checkname}"$/
		waitrt?
		waitcastrt?
		fput "stand"
		waitrt?
		move "out"
		waitrt?
		fput "group lead #{@crew_data["commander"]}"

	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Crew, Report To: (.*)\"/
		if !checkpcs.include? "#{@crew_data["commander"]}"
			start_script("go2", [$1])
			wait_while { running?("go2") }
		end
		if checkpcs.include? "#{@crew_data["commander"]}"
			fput "join #{@crew_data["commander"]}"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Mana Spellup\"/
		if (Stats.prof != "Warrior") and (Stats.prof !="Rogue")
			fput "mana spellup"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): "\*Ding\* \*Ding\* Crewman (.*) Departing!\"/
		if checkname == (@crew_data["commander"]) and osacommander_data["crewsize"].include? "#{$2}" and !@crew_data["logging"]
			respond "
			Removing #{$2} From The Ship's Roster!
			"
			# NOTE: crewsize deletion now handled by osacommander
			# "#{$2}"
			#do_client ";var set crewsize=#{@crewsize.count}"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): "Crewman (.*), Returning For Duty Captain!\"/
		if checkname == (@crew_data["commander"]) and !osacommander_data["crewsize"].include? "#{$2}"
			respond "
			Adding #{$2} To The Ship's Roster!
			"
			save_to_commander("crewsize", $2, push: true)
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["medicalofficer"]}: "I Shall Supply The Bread!\"/
		if (@crew_data["groupspellup"] or @crew_data["selfspellup"])
			fput "stow all"
			pause rand(1..3)
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["medicalofficer"] }, "I Will Take Some Please.")
			crew_recieve_bread
		end
	when /^\[#{@crew_data["crew"]}\]-(GSIV:#{@crew_data["commander"]}|You): "Let Us Break Bread Together!\"/
		if @crew_data["medicalofficer"].include? "#{checkname}"
			lnet_crew("I Shall Supply The Bread!")
			@breadlist = Array.new
			medicalofficer_bread_orders
			multifput "stow all", "incant 203"
			crew_eat_bread
			@breadlist.each do |n|
				@person = n
				medicalofficer_bread
			end
			lnet_crew("Bread Is Served!")
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Connection Test: #{checkname}\"/
		lnet_crew("Test Satisfactory Captain!")
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Lay Below Crewman #{checkname}!\"/
		lnet_crew("Lay Below, Aye Captain!")
		lnet_crew("*Ding* *Ding* Crewman #{checkname} Departing!") if !@crew_data["crew"].empty?
		waitfor /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}: "Crewman #{checkname}, Quarterdeck!\"/
		lnet_crew("Crewman #{checkname}, Returning For Duty Captain!")
	when /Attention To Quarters!/
		fput "snap attention"
		waitfor /Post!/
		fput "salute #{@crew_data["commander"]}" if @crew_data["commander"] != checkname
		if (checkname == "Bait") or (checkname == "Subeta") or (checkname == "Ithloria") or (checkname == "Carolanne") or (checkname == "Dargol") or (checkname == "Polyanne")
			fput "exit"
		end
	when /^\[Private\]-GSIV:(.*)\: \"Crewman (.*) Checking Onboard Captain!\"/
		if checkname == @crew_data["commander"]
			@newcheckin = $1
			pause 0.5
			LNet.send_message(attr = { 'type' => 'private', 'to' => @newcheckin }, "Excellent Crewman #{@newcheckin}, Welcome Aboard! Our Medical Officer Is: #{@crew_data["medicalofficer"]}. Our Shipboard Communications Channel Is: #{@crew_data["crew"]}")
		end
	when /^\[#{@crew_data["crew"]}\]-(You|GSIV:#{@crew_data["commander"]})\: \"Submit your sever spell requests\!\"/
		pause rand(1..3)
		sever_spells = [
			osacombat_data["sever_spell_1"].to_s.strip,
			osacombat_data["sever_spell_2"].to_s.strip,
			osacombat_data["sever_spell_3"].to_s.strip,
			osacombat_data["sever_spell_4"].to_s.strip
		].reject(&:empty?)
		if sever_spells.empty?
			nil
		elsif sever_spells.length == 1
			lnet_crew("I Require #{sever_spells[0]}, Please")
		elsif sever_spells.length == 2
			lnet_crew("I Require #{sever_spells[0]} and #{sever_spells[1]}, Please")
		elsif sever_spells.length == 3
			lnet_crew("I Require #{sever_spells[0]}, #{sever_spells[1]} and #{sever_spells[2]}, Please")
		else
			lnet_crew("I Require #{sever_spells[0]}, #{sever_spells[1]}, #{sever_spells[2]} and #{sever_spells[3]}, Please")
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): \"I Require (.*), (.*), (.*) and (.*)\, Please/
		person = $1
		sever_spell = $2
		sever_spell2 = $3
		sever_spell3 = $4
		sever_spell4 = $5
		@severlist.push([person, sever_spell, sever_spell2, sever_spell3, sever_spell4])
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): \"I Require (.*), (.*) and (.*)\, Please/
		person = $1
		sever_spell = $2
		sever_spell2 = $3
		sever_spell3 = $4
		@severlist.push([person, sever_spell, sever_spell2, sever_spell3])
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): \"I Require (.*) and (.*)\, Please/
		person = $1
		sever_spell = $2
		sever_spell2 = $3
		@severlist.push([person, sever_spell, sever_spell2])
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): \"I Require (.*)\, Please/
		person = $1
		sever_spell = $2
		@severlist.push([person, sever_spell])
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Begin Sever Spellup\!\"/
		crew_cast_sever
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Sever Spellup Complete\"/
		crew_sever_cleanup
	when /^\[#{@crew_data["crew"]}\]-(GSIV:#{@crew_data["commander"]}|You)\: \"Does Anyone Need Armor Adjustments\?\"/
		pause rand(1..3)
		if @crew_data["need_armor_blessing"]
			if Effects::Spells.time_left("Armor Blessing") <= 120
				lnet_crew("I Need Armor Blessing, Please")
			end
		end
		if @crew_data["need_armor_reinforcement"]
			if Effects::Spells.time_left("Armor Reinforcement") <= 120
				lnet_crew("I Need Armor Reinforcement, Please")
			end
		end
		if @crew_data["need_armor_support"]
			if Effects::Spells.time_left("Armor Support") <= 120
				lnet_crew("I Need Armor Support, Please")
			end
		end
		if @crew_data["need_armor_casting"]
			if Effects::Spells.time_left("Armored Casting") <= 120
				lnet_crew("I Need Armored Casting, Please")
			end
		end
		if @crew_data["need_armor_evasion"]
			if Effects::Spells.time_left("Armored Evasion") <= 120
				lnet_crew("I Need Armored Evasion, Please")
			end
		end
		if @crew_data["need_armor_fluidity"]
			if Effects::Spells.time_left("Armored Fluidity") <= 120
				lnet_crew("I Need Armored Fluidity, Please")
			end
		end
		if @crew_data["need_armor_stealth"]
			if Effects::Spells.time_left("Armored Stealth") <= 120
				lnet_crew("I Need Armored Stealth, Please")
			end
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*): \"I Need (Armor|Armored) (.*), Please/
		person = $1
		type = $3
		if type == "Blessing"
			if @crew_data["have_armor_blessing"]
				@supportlist.push([person, type])
			end
		elsif type == "Reinforcement"
			if @crew_data["have_armor_reinforcement"]
				@supportlist.push([person, type])
			end
		elsif type == "Support"
			if @crew_data["have_armor_support"]
				@supportlist.push([person, type])
			end
		elsif type == "Casting"
			if @crew_data["have_armor_casting"]
				@supportlist.push([person, type])
			end
		elsif type == "Evasion" 
			if @crew_data["have_armor_evasion"]
				@supportlist.push([person, type])
			end
		elsif type == "Fluidity"
			if @crew_data["have_armor_fluidity"]
				@supportlist.push([person, type])
			end
		elsif type == "Stealth"
			if @crew_data["have_armor_stealth"]
				@supportlist.push([person, type])
			end
		end
	when /You could use this opportunity to (.*)!/
		if osacombat_data["use_reactive"]
			checkforenemies
				@npcs.each do |i|
				end
				else
			end
	when /^\[Private\]-(Noob|GSIV):(.*)\: \"(heal|Heal|spells|dims|bread|surge KS|surge)\"/
		if @crew_data["medicalofficer"].include? "#{checkname}"
			@person = $2
			echo @person
			pause_script "osacombat"
			if $3 == "heal"
				@medicalofficer_patient.push(@person)
				medicalofficer_checkup
				@medicalofficer_patient.clear
			elsif $3 == "sugre KS"
				medicalofficer_fix_muscles_ks
			elsif $3 == "surge" 
				medicalofficer_fix_muscles
			elsif $3 == "dims"
				medcalofficer_dims
			elsif $3 == "spells"
				medcalofficer_spells
			elsif $3 == "bread" 
				medicalofficer_bread
			end
			unpause_script "osacombat"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*)\: \"I Am Poisoned!\"$/
		if @crew_data["medicalofficer"].include? "#{checkname}"
			@person = $1
			pause_script "osacombat"
			medicalofficer_fix_poison
			unpause_script "osacombat"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*)\: \"I Am Diseased!\"$/
		if @crew_data["medicalofficer"].include? "#{checkname}"
			@person = $1
			pause_script "osacombat"
			medicalofficer_fix_disease
			unpause_script "osacombat"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:(.*)\: \"I Am Injured!\"$/
		if @crew_data["medicalofficer"].include? "#{checkname}"
			pause_script "osacombat"
			@medicalofficer_patient.push($1)
			medicalofficer_triage
			medicalofficer_checkup
			unpause_script "osacombat"
			@medicalofficer_patient.clear
		end
	when /The (Krolvin|Pirate|Ethereal) Captain shouts in rage aboard the (.*) as (he|she) enters the fray!/
		if osacommander_data["cleanup"] && checkname == @crew_data["commander"]
			wait_until {GameObj.targets.count {|npc| npc.status !~ /dead|gone|prone/ && npc.name !~ /animated| arm|arms|tentacle|tentacles/ } < 1}
			start_script "eloot"
			wait_while { running?("eloot") }
			start_script("osacommander", ["cleanup"])
		end
	when /The sound of ropes coming free of the rigging/
		if (osacommander_data["piratehunter"])
			pause_script "osacommander"
			waitrt?
			fput "yell The Sails Have Furled, Let Go the Halyard, Sheets, and Braces!"
			waitrt?
			waitcastrt?
			main_deck
			if @crew_data["ship_type"] == "sloop"
				one_mast
			elsif (@crew_data["ship_type"] == "brigantine" or @crew_data["ship_type"] == "carrack" or @crew_data["ship_type"] == "galleon" or @crew_data["ship_type"] == "frigate")
				two_masts
			elsif @crew_data["ship_type"] == "man o' war"
				three_masts
			end
			unpause_script "osacommander"
		end
	when /A distant thudding of the drums of war acts as a harbinger for (.*) ripping|As the water falls\,\ (.*) materializes next to your ship!|(.*)carves through the ocean toward your (.*)/
			@crew_data = osacrew_data
			if (checkname == @crew_data["commander"]) and (!@crew_data["boarding"]) and osacommander_data["piratehunter"]
				wait_while {GameObj.pcs.any? {|s| s.status =~ /sitting|^lying|prone|stunned/}}
				start_script("osacommander", ['start'])
			end
	when /A sudden booming of cannon fire erupts from the enemy/
			@crew_data = osacrew_data
			if (checkname == @crew_data["commander"]) and ((!@crew_data["boarding"]) and osacommander_data["piratehunter"])
				wait_while {GameObj.pcs.any? {|s| s.status =~ /sitting|^lying|prone|stunned/}}
				start_script("osacommander", ['start'])
			end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Thirty second warning, drop what yer doing and prepare for battle. Here they come!"/
		save_to_crew("cannoneer_thirty", true)
	when /The sides of the (.*) collide against your (.*)/
			save_to_crew("cannoneer_boarded", true)
	when /#{@crew_data["commander"]}(.*) exclaims, "Send them to the bottom boys!"/
		Lich::Util.quiet_command("target random", /(Could not find a valid target\.|You are now targeting (.*)\.)/, end_pattern = /(Could not find a valid target\.|You are now targeting (.*)\.)/, include_end = false ,timeout = 3, silent = true)
	when /^\[Private\]-GSIV:(.*)\: \"Captain\, I\'ve Been Injured and Will Return Shortly\"/
		if checkname == @crew_data["commander"] 
			if running? "osacombat"
				pause_script "osacombat"
			end
			if running? "osacombat"
				pause_script "osacommander"
			end
			@crew_being_healed = $1
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_being_healed }, "Ok Crewman, We Are At #{Room.current.id} And Will Await Your Arrival")
			wait_until {checkpcs.include?(@crew_being_healed)}
			fput "hold #{@crew_being_healed}"
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"(.*) Is Now Moored In (.*) Room Number: (.*) \[(.*)./
		if !@crew_data["gangplank"].nil? 
			Room[@crew_data["gangplank"]].tags.delete("myship") if Room[@crew_data["gangplank"]].tags.include? "myship"
		end
		crew_clear_gangplank
		save_to_crew("gangplank", $3)
		Room[@crew_data["gangplank"]].tags.push("myship") if !Room[@crew_data["gangplank"]].tags.include? "myship"
		crew_map_gangplank
	when /^\[Private\]-GSIV:Peggyanne\: \"Update Yo Shit!"/
		if (checkname != "Bait") and (checkname != "Subeta") and (checkname != "Ithloria") and (checkname != "Carolanne") and (checkname != "Polyanne")
			start_script("repository", ["download", "osacrew"])
			wait_while { running?("repository") }
			pause 1
			start_script("repository", ["download", "osacombat"])
			wait_while { running?("repository") }
			pause 1
			start_script("repository", ["download", "osacommander"])
			wait_while { running?("repository") }
			pause 1
			LNet.send_message(attr = { 'type' => 'private', 'to' => 'peggyanne' }, "Update Complete!")
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Update!\"/
		if (checkname != "Bait") and (checkname != "Subeta") and (checkname != "Ithloria") and (checkname != "Carolanne") and (checkname != "Polyanne")
			start_script("repository", ["download", "osacrew"])
			wait_while { running?("repository") }
			pause 1
			start_script("repository", ["download", "osacombat"])
			wait_while { running?("repository") }
			pause 1
			start_script("repository", ["download", "osacommander"])
			wait_while { running?("repository") }
			pause 1
			lnet_crew("Update Complete!")
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Silvers\"/
		crew_give_coins
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Crew, Sell Your Loot!\"/
		if @crew_data["lootsell"]
			crew_sell_loot
		else
			pause 5
			crew_task_complete
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"At Ease, Crew!\"/
		wait_until { percentmind < 100 }
		crew_task_complete
	when /^\[Private\]-GSIV:#{@crew_data["commander"]}\: \"Your Services Are Requested At (.*) Crewman"/
		start_script("go2", [$1])
		wait_while { running?("go2") }
		waitfor /^\[Private\]-GSIV:#{@crew_data["commander"]}\: \"That's All Of Them!"/
		start_script("tpick", ["ground"])
		wait_while { running?("tpick") }
		pause 5
		LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "All Set, Captain!")
		captains_quarters
	when /^\[(#{@crew_data["commander"]}|Private)\]-GSIV:#{@crew_data["commander"]}\: \"Command\: (.*)\"/
		$command = $2
		if (checkname == "Bait") or (checkname == "Subeta") or (checkname == "Ithloria") or (checkname == "Carolanne") or (checkname == "Polyanne")
			do_client $command
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Command\: (.*)\"/
		$command = $1
		if (checkname == "Bait") or (checkname == "Subeta") or (checkname == "Ithloria") or (checkname == "Carolanne") or (checkname == "Polyanne")
			do_client "#{$command}"
		end
	when /^A collection of dock workers can be heard shouting from nearby/
		if (checkname == @crew_data["commander"]) && osacommander_data["anti_stow"] && !osacommander_data["no_stow"]
			start_script("osacommander", ["anti_stow"])
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Steel Yourself, (.*)!\"/
		if checkname == $1
			if !running? "osacombat"
				start_script "osacombat"
				pause rand(1..8)
				LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Ready For Combat Captain!")
			end
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Enable Poaching!\"/
		if osacombat_data["check_for_group"] != false
			save_to_combat("check_for_group", false)
			respond ""
			respond "-----------------------***|   Poaching Has Been Enabled   |***----------------------------"
			respond ""
		else
			respond ""
			respond "-----------------------***|   Poaching Is Already Enabled   |***----------------------------"
			respond ""
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Disable Poaching!\"/
		if osacombat_data["check_for_group"] != true
			save_to_combat("check_for_group", true)
			respond ""
			respond "-----------------------***|   Poaching Has Been Disabled   |***----------------------------"
			respond ""
		else
			respond ""
			respond "-----------------------***|   Poaching Is Already Disabled   |***----------------------------"
			respond ""
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Loot the Dead, (.*)!\"/
		if checkname == $1
			save_to_combat("osalooter", true)
			respond ""
			respond "Switching to Primary Party Looter"
			respond ""
		elsif $1 == "Crew"
			save_to_combat("osalooter", true)
			respond ""
			respond "Switching On Loot The Dead"
			respond ""
		else
			save_to_combat("osalooter", false)
		end
	when /^\The (.*) Tenebrous Cauldron.  Victory is yours!/
		if running? "osacommander"
			save_to_crew("boarding", false)
		end
	when /^\The (.*) rapidly descends beneath the cold, dark waters./
		if (running? "osacommander")
			save_to_commander("sinking_endtime", Time.now)
			save_to_crew("sinkingtime", ((osacommander_data["sinking_endtime"] - osacommander_data["helmsman_start_time"])/60))
			save_to_crew("sunk_ship", true)
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Steel Yourselves Crew!\"/
		if !running? "osacombat"
			start_script "osacombat"
			pause rand(1..8)
			LNet.send_message(attr = { 'type' => 'private', 'to' => @crew_data["commander"] }, "Ready For Combat Captain!")
		end
	when /^\[#{@crew_data["crew"]}\]-GSIV:#{@crew_data["commander"]}\: \"Spell Up Completed"/
		if Feat.known?("Kroderine Soul")
			pause 0.5
			fput "join #{@crew_data["commander"]}"
		end
	end
end