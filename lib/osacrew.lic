def save_to_crew(key, value, push: false)
	full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacrew.yaml")
	FileUtils.mkdir_p(File.dirname(full_path))
	File.open(full_path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read.to_s
		data = begin
			raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
		rescue StandardError
			{}
		end
		data = data.transform_keys(&:to_s)
		k = key.to_s
		if push
			data[k] = [] unless data[k].is_a?(Array)
			data[k] << value
		else
			data[k] = value
		end
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
		@crew_data = data.transform_keys(&:to_s)
	end
end

