def wait_for_go2
  Timeout.timeout(30) do
    loop do
      break unless Script.running?("go2")
      sleep 0.2
    end
  end
rescue Timeout::Error
  echo "--- WARNING: go2 did not finish within 30 seconds."
end

def flag_settings
	flagset = Lich::Util.quiet_command("flag", /You may also access these settings through/, end_pattern = /war in towns with active justice./, include_end = true ,timeout = 3, silent = true)
		if flagset.to_s =~ /ShowRoomID         OFF/
			#do_client "flag showroomid on"
			Lich::Util.quiet_command("flag showroomid on", /You will now display the room ID./, end_pattern = /You will now display the room ID./, include_end = true ,timeout = 3, silent = true)
			$roomflagon = true
		end
		if flagset.to_s =~ /ShowRoomID         ON/
			$roomflagon = false
		end
end

def lower_sail
	result = dothistimeout "lower sail", 3, /you slowly lower the (.*) sail until it is at half mast|you slowly lower the (.*) sail until it is fully open|far as it can go!/
        waitrt?
	if result.to_s =~ /...wait/
		waitrt?
		lower_sail
	elsif result.to_s =~ /you slowly lower the (.*) sail until it is at half mast/
		waitrt?
		lower_sail
	elsif result.to_s =~ /you slowly lower the (.*) sail until it is fully open/
		waitrt?
	elsif result.to_s =~ /far as it can go!/
		end
end

def main_mast
	start_script("go2", ["main_mast"])
	wait_while { running?("go2") }
end

def mid_mast
	start_script("go2", ["mid_mast"])
	wait_while { running?("go2") }
end 

def forward_mast
	start_script("go2", ["forward_mast"])
	wait_while { running?("go2") }
end

def raise_anchor
  result = dothistimeout "push capstan", 3, /begin to push|one final push|anchor is already up/
  waitrt?
  if result.to_s =~ /...wait/
    waitrt?
    raise_anchor
  elsif result.to_s =~ /begin to push/
    waitrt?
    raise_anchor
  elsif result.to_s =~ /one final push/
    @anchor_aweigh = true
    waitrt?
  elsif result.to_s =~ /anchor is already up/
    return
  end
end

def ensure_at_helm
  return if Room.current.tags.include?("helm")

  echo "--- Moving to helm"
  start_script("go2", ["helm"])
  wait_for_go2
  waitrt?
end

def ship_flag
	check_flag = Lich::Util.quiet_command("ship flag", //, end_pattern = /\[To change your flag please provide a valid option. Valid options: WHITE, BLACK, or NEUTRAL\]/, include_end = false ,timeout = 3, silent = true)
	if check_flag.to_s =~ /is currently flying (.*) flag./
		if $1 != "a white"
			crows_nest
			change_result = Lich::Util.quiet_command("ship flag white", /Your ship is now flying|Time until flag can be changed/, end_pattern = /Your ship is now flying|Time until flag can be changed/, include_end = true, timeout = 5, silent = true)
			if change_result.to_s =~ /Time until flag can be changed: (.*)/
				cooldown = $1.strip
				respond ""
				respond " =========================================================="
				respond "  WARNING: Your ship flag could not be changed to white."
				respond "  #{cooldown} remaining before you can change it again."
				respond "  Sailing without a white flag is dangerous - enemy ships"
				respond "  may engage you on sight."
				respond " =========================================================="
				respond "  How would you like to proceed?"
				respond "    1. Continue sailing with your current flag (risky)"
				respond "    2. Exit sail2 and wait for the cooldown to expire"
				respond " =========================================================="
				respond "  Please select an option - ;send <#>"
				respond ""
				clear
				answer = nil
				answer = get until answer.to_s.strip =~ /^[12]$/
				if answer.strip == "2"
					respond "  Exiting sail2. Please try again in #{cooldown}."
					exit
				else
					respond "  Understood. Proceeding with current flag. Sail carefully!"
					respond ""
				end
			end
		end
	end
end

def start_nav
	ensure_at_helm
	check_city = Lich::Util.quiet_command("look ocean", //, end_pattern = /(Open waters:|Obvious paths:)/, include_end = true ,timeout = 3, silent = true)
	if check_city.to_s =~ /Potential docking options include|Open waters:/
		ship_flag
		return
	elsif check_city.to_s =~ /Obvious paths:/
		if Room.current.id.between?(29039, 29042)
			$mast_count = 1
		elsif Room.current.id.between?(310145, 310147)
			$mast_count = 2
		elsif Room.current.id.between?(30119, 30127)
			$mast_count = 2
		elsif Room.current.id.between?(30176, 30185)
			$mast_count = 2
		elsif Room.current.id.between?(30166, 30175)
			$mast_count = 2
		elsif Room.current.id.between?(30129, 30139)
			$mast_count = 3
		end
		if $mast_count >= 1
			main_mast
			fput "pull gang"
			lower_sail
		end
		if $mast_count >= 2
			forward_mast
			lower_sail
		end
		if $mast_count == 3
			mid_mast
			lower_sail
		end
		ensure_at_helm
		raise_anchor
		waitrt?
		fput "depart"
		fput "depart"
	else
		echo "Please get your ship underway, then restart Sail2.lic."
		exit
	end
end

