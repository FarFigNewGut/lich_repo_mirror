JSON_GIT_PATH  = ''
LOCAL_JSON_DIR = File.join(MAP_DIR, 'OSAMaps', 'Database')

# -- Sail2 Timing System ----------------------------------------------------

def sail2_yaml_path
	File.join(DATA_DIR, XMLData.game, Char.name, "sail2.yaml")
end

def load_sail2_data
	path = sail2_yaml_path
	return {} unless File.exist?(path)
	raw = File.read(path)
	return {} if raw.strip.empty?
	YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}
rescue StandardError
	{}
end

def load_yaml_file(path)
	return {} unless File.exist?(path)
	raw = File.read(path)
	return {} if raw.strip.empty?
	YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}
rescue StandardError
	{}
end

def save_sail2_data(data)
	path = sail2_yaml_path
	FileUtils.mkdir_p(File.dirname(path))
	File.open(path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
	end
rescue StandardError => e
	echo "--- sail2: failed to save timing data: #{e.message}"
end

def ship_timing_key
	case Room.current.id
	when 29038..29042 then "sloop_times"
	when 30140..30147 then "brigantine_times"
	when 30119..30127 then "carrack_times"
	when 30176..30186 then "galleon_times"
	when 30166..30175 then "frigate_times"
	when 30128..30139 then "manowar_times"
	else "unknown_times"
	end
end

def ship_display_name
	case Room.current.id
	when 29038..29042 then "Sloop"
	when 30140..30147 then "Brigantine"
	when 30119..30127 then "Carrack"
	when 30176..30186 then "Galleon"
	when 30166..30175 then "Frigate"
	when 30128..30139 then "Man O\'War"
	else "Unknown"
	end
end

def record_move_time(seconds)
	data = load_sail2_data
	key  = ship_timing_key
	data[key] ||= []
	data[key] << seconds.round(4)
	data[key] = data[key].last(50)
	save_sail2_data(data)
end

def average_move_seconds
	data  = load_sail2_data
	times = data[ship_timing_key]
	return 0.35 if times.nil? || times.empty?
	(times.sum / times.size.to_f).round(4)
end

def eastern_time(time)
	# Convert any Time object to US Eastern (auto DST)
	# DST: second Sunday in March through first Sunday in November
	year = time.utc.year
	dst_start = Time.utc(year, 3,  8 + (7 - Time.utc(year, 3,  8).wday) % 7, 2)
	dst_end   = Time.utc(year, 11, 1 + (7 - Time.utc(year, 11, 1).wday) % 7, 2)
	offset = (time.utc >= dst_start && time.utc < dst_end) ? -4 * 3600 : -5 * 3600
	Time.at(time.to_i + offset).utc
end

def format_duration(total_seconds)
	total_seconds = total_seconds.to_i
	h = total_seconds / 3600
	m = (total_seconds % 3600) / 60
	s = total_seconds % 60
	h > 0 ? "#{h}h #{m}m #{s}s" : (m > 0 ? "#{m}m #{s}s" : "#{s}s")
end
# -- End Sail2 Timing System ------------------------------------------------


def sync_echo(msg); respond "[MapSync: #{msg}]" rescue puts msg; end

def download_folder(user, repo, api_path, local_dir)
  FileUtils.mkdir_p(local_dir) unless Dir.exist?(local_dir)
  api_url = "https://api.github.com/repos/#{user}/#{repo}/contents/#{api_path}"
  
  begin
    # GitHub API requires a User-Agent header [cite: 26, 27]
    response = URI.open(api_url, "User-Agent" => "Lich-Map-Syncer").read
    data = JSON.parse(response)

    unless data.is_a?(Array)
      sync_echo("Error: #{api_path} in #{repo} is not a folder.")
      return 0
    end

    count = 0
    data.each do |file|
      next unless file['type'] == 'file' # Only download files, skip folders [cite: 30]
      
      file_name    = file['name']
      remote_size  = file['size'].to_i
      download_url = file['download_url']
      local_path   = File.join(local_dir, file_name)

      # Only download if file is missing or size has changed [cite: 31]
      if !File.exist?(local_path) || File.size(local_path) != remote_size
        sync_echo("Downloading: #{file_name} from #{repo}...")
        URI.open(download_url) do |remote|
          File.open(local_path, "wb") { |local| local.write(remote.read) }
        end
        count += 1
      end
    end
    count
  rescue => e
    sync_echo("Error syncing #{repo}/#{api_path}: #{e.message}")
    0
  end
end

def sync_all
  sync_echo("Connecting to GitHub APIs...")
  
  # 1. Sync the JSON data from the separate Git 
  json_updates = download_folder(JSON_GIT_USER, JSON_GIT_REPO, JSON_GIT_PATH, LOCAL_JSON_DIR)

  total = json_updates
  if total > 0
    sync_echo("Success! Updated #{total} files from one repository.")
  else
    sync_echo("All files are up to date.")
  end
end

