ship_type
flag_settings

def fatal(msg)
  echo "--- ERROR: #{msg}"
  exit
end

def valid_room_id?(s)
  s.to_s.match?(/^\d{7}$/)
end

def normalize_input(raw)
  s = raw.to_s.strip.downcase
  return "" if s.empty?
  return PORTS[s] if PORTS.key?(s)
  return s if valid_room_id?(s)
  ""
end

def port_destination?(room_id)
  PORTS.value?(room_id.to_s)
end

def load_ocean_map_flat
  path = File.join(MAP_DIR, 'OSAMaps', 'Database', 'oceandb.json')
  fatal("Missing #{MAP_FILE} in DATA_DIR (#{path})") unless File.exist?(path)

  raw = JSON.parse(File.read(path))
  flat = {}

  if raw.is_a?(Hash) && raw.keys.any? { |k| k.to_s.match?(/^\d{7}$/) }
    raw.each do |rid, exits|
      rid = rid.to_s.strip
      next unless valid_room_id?(rid)
      flat[rid] = exits.is_a?(Hash) ? exits : {}
    end
    return flat
  end

  raw.each do |_, rooms|
    next unless rooms.is_a?(Hash)
    rooms.each do |rid, exits|
      rid = rid.to_s.strip
      next unless valid_room_id?(rid)
      flat[rid] = exits.is_a?(Hash) ? exits : {}
    end
  end

  flat
end

def bfs(map, start_id, goal_id)
  visited = Set.new([start_id])
  queue = [[start_id, []]]

  until queue.empty?
    cur, path = queue.shift
    return path if cur == goal_id

    exits = map[cur]
    next unless exits.is_a?(Hash)

    exits.each do |dir, nxt|
      nid = nxt.to_s.strip
      next unless valid_room_id?(nid)
      next if visited.include?(nid)

      visited << nid
      queue << [nid, path + [[dir.to_s.downcase, nid]]]
    end
  end

  nil
end

def compress_route(path)
  return [] if path.nil? || path.empty?

  legs = []
  current_dir = path.first[0].to_s.downcase
  expected_rooms = [path.first[1].to_s]

  path[1..-1].each do |dir, nid|
    dir = dir.to_s.downcase
    nid = nid.to_s

    if dir == current_dir
      expected_rooms << nid
    else
      legs << [current_dir, expected_rooms.dup]
      current_dir = dir
      expected_rooms = [nid]
    end
  end

  legs << [current_dir, expected_rooms.dup]
  legs
end

def update_current_room_from_watch(line)
  return false if line.nil?

  text = line.to_s

  if text =~ /roomName.*?\((\d{7})\)/
    $current_room_id = $1.to_s
    return true
  end

  if text =~ /\((\d{7})\)/
    $current_room_id = $1.to_s
    return true
  end

  false
end

def ensure_ocean_watch
  return if $ocean_watch_started
	result = dothistimeout "watch ocean", 3, /You begin to watch the ocean waters surrounding the ship|You are already watching the ocean/
		if result.to_s =~ /You begin to watch the ocean waters surrounding the ship/
			waitrt?
			nil
		elsif result.to_s =~ /You are already watching the ocean/
			waitrt?
			fput "look ocean"
			nil
		end
  waitrt?
  $ocean_watch_started = true
end

def wait_for_current_room(timeout = 8)
  start_time = Time.now

  loop do
    rid = $current_room_id.to_s
    return rid unless rid.empty?

    break if (Time.now - start_time) > timeout

    line = get?
    if line
      update_current_room_from_watch(line)
    else
      sleep 0.1
    end
  end

  ""
end

def wait_for_room_change(previous_room, timeout = 8)
  start_time = Time.now
  previous_room = previous_room.to_s

  loop do
    current = $current_room_id.to_s
    return current if !current.empty? && current != previous_room

    break if (Time.now - start_time) > timeout

    line = get?
    if line
      update_current_room_from_watch(line)
    else
      sleep 0.1
    end
  end

  $current_room_id.to_s
end

def current_sea_room
  $current_room_id.to_s
end

def set_heading(dir)
  dir = dir.to_s.strip.downcase

  if $current_heading.to_s.strip.downcase == dir
    echo "--- Wheel already set to #{dir.upcase}"
    return
  end

  ensure_at_helm
  fput "turn wheel #{dir}"
  waitrt?
  $current_heading = dir
end

def wait_for_sailing_result(timeout = 300)
  start_time = Time.now

  loop do
    return :timeout if (Time.now - start_time) > timeout

    line = get?
    unless line
      sleep 0.1
      next
    end

    update_current_room_from_watch(line)

    case line
    when /The (.*) (cuts through the ocean, heading|drifts slowly)/
      return :moved
    when /A large swell crashes into the side of the/
      return :rogue_wave
    when /The sound of ropes coming free of the rigging/
      return :rigging
    when /The (.*) suddenly drifts from its course as the/
      return :off_course
    when /The (.*) drifts steadily toward the/
      return :arrival
    when /The .* wheel slowly turns off course\./
      return :invalid_heading
    when /Aimless, the .* rocks idly in the ocean waters\./
      return :aimless
    end
  end
end

def sail_leg(dir, expected_rooms)
  echo "--- Heading #{dir.upcase} for #{expected_rooms.length} move(s)"
  set_heading(dir)

  moved = 0

  while moved < expected_rooms.length
    previous_room = current_sea_room
    result = wait_for_sailing_result

    if result == :moved
      actual_room = wait_for_room_change(previous_room, 8)
      expected_room = expected_rooms[moved]

      if actual_room.empty?
        echo "--- WARNING: Could not confirm current room after movement."
        return [:reroute, actual_room]
      end

      if actual_room == previous_room
        echo "--- WARNING: Room did not update after movement. Still showing #{actual_room}."
        return [:reroute, actual_room]
      end

      if actual_room != expected_room
        echo "--- Course deviation: expected #{expected_room}, got #{actual_room}"
        return [:reroute, actual_room]
      end

      moved += 1
      echo "--- Move #{moved}/#{expected_rooms.length}: now at #{actual_room}"
      next
    elsif result == :rogue_wave
      waitrt?
      fput "yell Rogue Wave! Secure the Anchor!"
      ensure_at_helm
      waitrt?
      waitcastrt?
      raise_anchor
      $current_heading = nil
      echo "--- Rogue wave handled. Resuming travel..."
      return [:reroute, current_sea_room]
    elsif result == :rigging
      echo "The Sails Have Been Furled"
      if $mast_count >= 1
        main_mast
        lower_sail
      end
      if $mast_count >= 2
        forward_mast
        lower_sail
      end
      if $mast_count == 3
        mid_mast
        lower_sail
      end
      ensure_at_helm
      $current_heading = nil
      echo "--- Rigging secured. Resuming travel..."
      return [:reroute, current_sea_room]
    end

    if [:invalid_heading, :aimless, :off_course].include?(result)
      $current_heading = nil
    end

    actual_room = wait_for_current_room(5)
    echo "--- Sailing interrupted (#{result}). Current room: #{actual_room.empty? ? 'UNKNOWN' : actual_room}"
    return [:reroute, actual_room]
  end

  [:ok, current_sea_room]
end

def before_dying
	if $roomflagon == true
		#fput "flag showroomid off"
		Lich::Util.quiet_command("flag showroomid off", /You will no longer display the room ID./, end_pattern = /You will no longer display the room ID./, include_end = true ,timeout = 3, silent = true)
	end
end

def sail_into_port
  echo "--- Final approach: turning wheel PORT"
  $current_heading = nil
  ensure_at_helm
  fput "turn wheel port"
  waitrt?

  loop do
    result = wait_for_sailing_result

    case result
    when :arrival
      echo "--- Port approach confirmed."
      return :arrived
    when :moved
      next
    when :invalid_heading, :aimless, :off_course
      $current_heading = nil
      return :reroute
    else
      return :reroute
    end
  end
end

def autopilot_to(map, start_id, goal_id)
  current_id = start_id.to_s
  goal_is_port = port_destination?(goal_id)

  loop do
    path = bfs(map, current_id, goal_id)
    fatal("No path found from #{current_id} to #{goal_id}.") if path.nil?

    legs = compress_route(path)

    echo "--- ROUTE FOUND (#{path.length} moves / #{legs.length} heading changes#{goal_is_port ? ' + port entry' : ''}) ---"
    legs.each_with_index do |(dir, rooms), i|
      echo "#{i + 1}. #{dir.upcase.ljust(3)} x #{rooms.length} -> #{rooms.last}"
    end
    echo "#{legs.length + 1}. PORT entry from #{goal_id}" if goal_is_port

    reroute_needed = false

    legs.each do |dir, expected_rooms|
      status, new_room = sail_leg(dir, expected_rooms)

      if status == :reroute
        new_room = wait_for_current_room(5) if new_room.to_s.empty?
        fatal("Unable to determine current room for reroute.") if new_room.to_s.empty?

        if new_room.to_s == goal_id.to_s && !goal_is_port
          echo "--- ARRIVED AT #{goal_id}"
          return
        end

        echo "--- Re-routing from #{new_room} to #{goal_id}"
        current_id = new_room.to_s
        reroute_needed = true
        break
      end
    end

    next if reroute_needed

    actual = wait_for_current_room(5)

    if actual != goal_id.to_s
      current_id = actual unless actual.empty?
      echo "--- Route exhausted but destination not confirmed. Re-routing from #{current_id}"
      next
    end

    # We are now in the port room itself
    if goal_is_port
      port_result = sail_into_port

      if port_result == :arrived
        echo "--- ARRIVED AT PORT #{goal_id}"
        return
      end

      current_id = wait_for_current_room(5)
      fatal("Unable to determine current room after failed port entry.") if current_id.to_s.empty?

      echo "--- Re-routing from #{current_id} to #{goal_id}"
      next
    end

    echo "--- ARRIVED AT #{goal_id}"
    return
  end
end

# ---------------- MAIN ----------------

arg1 = variable[1].to_s
arg2 = variable[2].to_s

fatal("Usage: ;routeme <end>  OR  ;routeme <start> <end>") if arg1.empty?

map = load_ocean_map_flat


if arg2.empty?
  ensure_ocean_watch

  start_id = wait_for_current_room(8)
  goal_id  = normalize_input(arg1)

  fatal("Could not determine current ocean room from watch ocean.") if start_id.empty?
  fatal("End must be a known port or 7-digit room id.") if goal_id.empty?
  fatal("Start room #{start_id} not found in #{MAP_FILE}.") unless map.key?(start_id)
  fatal("End room #{goal_id} not found in #{MAP_FILE}.") unless map.key?(goal_id)

  $current_room_id = start_id

  echo "--- Voyage: #{start_id} -> #{goal_id}"
  autopilot_to(map, start_id, goal_id)

else
  start_id = normalize_input(arg1)
  goal_id  = normalize_input(arg2)

  fatal("Start must be a known port or 7-digit room id.") if start_id.empty?
  fatal("End must be a known port or 7-digit room id.") if goal_id.empty?
  fatal("Start room #{start_id} not found in #{MAP_FILE}.") unless map.key?(start_id)
  fatal("End room #{goal_id} not found in #{MAP_FILE}.") unless map.key?(goal_id)

  echo "--- Voyage: #{start_id} -> #{goal_id}"

  path = bfs(map, start_id, goal_id)

  if path
    echo "--- ROUTE FOUND (#{path.length} moves) ---"
    path.each_with_index do |(dir, nid), i|
      echo "#{i + 1}. Steer #{dir.to_s.upcase.ljust(3)} -> #{nid}"
    end
  else
    echo "--- ERROR: No path found."
  end
end