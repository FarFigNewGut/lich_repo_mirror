  respond "  Usage:"
  respond "    ;sail2 <port or uid>          Sail to destination"
  respond "    ;sail2 <port> <port>          Show route between two points"
  respond "    ;sail2 update                 Update ocean map files"
  respond " =================================================="
  respond "  Available Ports:"
  respond "    Brisker's Cove        briskercove"
  respond "    Glaoveln              glaoveln"
