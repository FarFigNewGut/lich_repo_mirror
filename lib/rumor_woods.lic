# CharSettings rows are keyed by script name; DownstreamHook runs without Script.current, so raikhen persistence uses this name explicitly.
RWO_RAIKHEN_CS_SCRIPT = (script.name rescue "rumor_woods").freeze

# Things to Test
# make movement not backtrack (randomly selected pre defined routes in an array)
# use CharSettings (per character, per script) instead of UserVars (per character)
# CharSettings[:timeout] = number

# Fox maze topology: FOX_HUNT_WAYTO_GRAPH_GAME in-script (Lich room ids; extracted from data/GSIV/map-1776031619.json).
# Fox Hunt Entrance: 8211332 / 25932 (treeline)
# Fox Hunt Just Inside: 8208601
# Fox Hunt Exit: 8208699 (out)
# Shallow cave: u8208625 - from u8208624 exit "west"; excluded from automated fox routing

# Pixie Hunt Entrance: 8208746 / 29706 (steps)
# Pixie Hunt Just Inside: 8208501
# Pixie Hunt Exit: 8208599 (out)

# number of observe/track commands for a 90 second run is 17-19; 19 is the max

def rumor_woods_fox_find_counts_hash
	raw = CharSettings['rumor_woods_fox_find_counts']
	return {} unless raw.is_a?(Hash)
	out = {}
	raw.each { |k, v| out[k.to_s] = v.to_i }
	out
end

def rumor_woods_fox_room_game_number_for_log(rid)
	return nil unless rid.is_a?(Integer)
	g = (Room[rid].id rescue nil)
	return g if g
	return nil unless respond_to?(:hunt_fox_warm_game_uid_maps!, true)
	begin
		hunt_fox_warm_game_uid_maps!
		return @hunt_fox_uid2game[rid] if @hunt_fox_uid2game && @hunt_fox_uid2game[rid]
	rescue
	end
	nil
end

def rumor_woods_maybe_log_fox_find(result)
	return unless result.to_s =~ /many signs of a fox/i
	return unless @fox
	rid = XMLData.room_id
	return if rid == 8208699 || rid == 8208599
	h = rumor_woods_fox_find_counts_hash
	key = rid.to_s
	h[key] = (h[key] || 0) + 1
	CharSettings['rumor_woods_fox_find_counts'] = h
	tot = h.values.inject(0, :+)
	respond
	gn = rumor_woods_fox_room_game_number_for_log(rid)
	respond "[rumor_woods] Fox find logged: ##{gn || '?'} (#{h[key]} in this room, #{tot} total)."
	respond
end

def rumor_woods_pixie_find_counts_hash
	raw = CharSettings['rumor_woods_pixie_find_counts']
	return {} unless raw.is_a?(Hash)
	out = {}
	raw.each { |k, v| out[k.to_s] = v.to_i }
	out
end

def rumor_woods_pixie_room_game_number_for_log(rid)
	return nil unless rid.is_a?(Integer)
	g = (Room[rid].id rescue nil)
	return g if g
	return nil unless respond_to?(:hunt_pixie_warm_game_uid_maps!, true)
	begin
		hunt_pixie_warm_game_uid_maps!
		return @hunt_pixie_uid2game[rid] if @hunt_pixie_uid2game && @hunt_pixie_uid2game[rid]
	rescue
	end
	nil
end

def rumor_woods_maybe_log_pixie_find(result)
	return unless result.to_s =~ /many signs of a pixie/i
	return if @fox
	rid = XMLData.room_id
	return if rid == 8208699 || rid == 8208599
	h = rumor_woods_pixie_find_counts_hash
	key = rid.to_s
	h[key] = (h[key] || 0) + 1
	CharSettings['rumor_woods_pixie_find_counts'] = h
	tot = h.values.inject(0, :+)
	respond
	gn = rumor_woods_pixie_room_game_number_for_log(rid)
	respond "[rumor_woods] Pixie find logged: ##{gn || '?'} (#{h[key]} in this room, #{tot} total)."
	respond
end

def rumor_woods_fox_find_print_stats
	h = rumor_woods_fox_find_counts_hash
	if h.empty?
		respond
		respond "[rumor_woods] No fox finds logged yet (CharSettings, per character)."
		respond
		return
	end
	tot = h.values.inject(0, :+)
	pairs = h.sort_by { |_uid, n| [-n, _uid.to_i] }
	respond
	respond "[rumor_woods] Fox finds by room (#{tot} total, ## = Lich room id):"
	pairs.each do |uid, n|
		r = uid.to_i
		gn = rumor_woods_fox_room_game_number_for_log(r)
		respond "  ##{gn || uid}: #{n}"
	end
	respond
end

def rumor_woods_pixie_find_print_stats
	h = rumor_woods_pixie_find_counts_hash
	if h.empty?
		respond
		respond "[rumor_woods] No pixie finds logged yet (CharSettings, per character)."
		respond
		return
	end
	tot = h.values.inject(0, :+)
	pairs = h.sort_by { |_uid, n| [-n, _uid.to_i] }
	respond
	respond "[rumor_woods] Pixie finds by room (#{tot} total, ## = Lich room id):"
	pairs.each do |uid, n|
		r = uid.to_i
		gn = rumor_woods_pixie_room_game_number_for_log(r)
		respond "  ##{gn || uid}: #{n}"
	end
	respond
end

# DownstreamHook passes raw XML; tags can sit between words and break a naive regexp.
def rumor_woods_raikhen_plain_for_match(server_string)
	return "" unless server_string.is_a?(String)
	raw = server_string.to_s
	if defined?(strip_xml)
		s = strip_xml(raw.dup, type: "main") rescue nil
		return s if s.is_a?(String) && !s.strip.empty?
	end
	raw.gsub(/<[^>]+>/, "").gsub("&gt;", ">").gsub("&lt;", "<")
end

def rumor_woods_raikhen_amount_from_line(server_string)
	plain = rumor_woods_raikhen_plain_for_match(server_string)
	return nil if plain.empty?
	# "hands you a sack" or "hands you an ornate sack"; optional XML already stripped.
	return $1.to_i if plain =~ /You exchange .+? with Eyaeno who hands you (?:a|an) .+? and (\d+)\s*raikhen\b/i
	return $1.to_i if plain =~ /You exchange .+? with Eyaeno who hands you .+? and (\d+)\s*raikhen\b/i
	return $1.to_i if plain =~ /You exchange .+? with Eyaeno who gives you .+? and (\d+)\s*raikhen\b/i
	# Fox enclosure: the trapper (gunny sack, ferrets, etc.).
	return $1.to_i if plain =~ /You exchange .+? with (?:the )?trapper who hands you (?:a|an) .+? and (\d+)\s*raikhen\b/i
	return $1.to_i if plain =~ /You exchange .+? with (?:the )?trapper who hands you .+? and (\d+)\s*raikhen\b/i
	return $1.to_i if plain =~ /You exchange .+? with (?:the )?trapper who gives you .+? and (\d+)\s*raikhen\b/i
	# Shared closing phrase on medium-reward exchanges (strip_xml leaves this intact).
	return $1.to_i if plain =~ /You exchange .+? and (\d+)\s*raikhen, which you quickly pocket/i
	nil
end

def rumor_woods_raikhen_int_from_setting(val)
	return 0 if val.nil?
	val.to_s.to_i
end

def rumor_woods_raikhen_process_line(server_string)
	amt = rumor_woods_raikhen_amount_from_line(server_string)
	return if amt.nil? || amt <= 0
	sm = Lich::Common::Settings
	scope = CharSettings.active_scope
	sn = RWO_RAIKHEN_CS_SCRIPT
	tot = rumor_woods_raikhen_int_from_setting(sm.get_scoped_setting(scope, "rumor_woods_raikhen_total", script_name: sn)) + amt
	n = rumor_woods_raikhen_int_from_setting(sm.get_scoped_setting(scope, "rumor_woods_raikhen_count", script_name: sn)) + 1
	sm.set_script_settings(scope, "rumor_woods_raikhen_total", tot, script_name: sn)
	sm.set_script_settings(scope, "rumor_woods_raikhen_count", n, script_name: sn)
	avg = (tot.to_f / n).round(1)
	run_tot = (@rumor_woods_raikhen_run_total || 0) + amt
	run_n = (@rumor_woods_raikhen_run_count || 0) + 1
	@rumor_woods_raikhen_run_total = run_tot
	@rumor_woods_raikhen_run_count = run_n
	run_avg = (run_tot.to_f / run_n).round(1)
	respond
	respond "[rumor_woods] Rumor Woods raikhen: +#{amt} this exchange | this run: #{run_tot} total, #{run_n} payout(s), ~#{run_avg} avg | lifetime: #{tot} total, #{n} payout(s), ~#{avg} avg."
	respond
end

def rumor_woods_raikhen_print_stats
	sm = Lich::Common::Settings
	scope = CharSettings.active_scope
	sn = RWO_RAIKHEN_CS_SCRIPT
	tot = rumor_woods_raikhen_int_from_setting(sm.get_scoped_setting(scope, "rumor_woods_raikhen_total", script_name: sn))
	n = rumor_woods_raikhen_int_from_setting(sm.get_scoped_setting(scope, "rumor_woods_raikhen_count", script_name: sn))
	rn = (@rumor_woods_raikhen_run_count || 0).to_i
	rt = (@rumor_woods_raikhen_run_total || 0).to_i
	respond
	if n <= 0 && rn <= 0
		respond "[rumor_woods] No Rumor Woods raikhen logged yet (CharSettings, per character)."
	else
		if rn > 0
			ravg = (rt.to_f / rn).round(1)
			respond "[rumor_woods] Rumor Woods raikhen this script run: #{rt} from #{rn} payout(s), ~#{ravg} avg."
		end
		if n > 0
			avg = (tot.to_f / n).round(1)
			respond "[rumor_woods] Rumor Woods raikhen lifetime (CharSettings, per character): #{tot} from #{n} payout(s), ~#{avg} avg."
		end
	end
	respond
end

v0 = (script.vars[1] || "").strip.downcase
rumor_woods_gate_rid = XMLData.room_id
rumor_woods_in_fox_maze = rumor_woods_gate_rid.is_a?(Integer) && rumor_woods_gate_rid >= 8208601 && rumor_woods_gate_rid <= 8208640
rumor_woods_in_pixie_maze = rumor_woods_gate_rid.is_a?(Integer) && rumor_woods_gate_rid >= 8208501 && rumor_woods_gate_rid <= 8208536
rumor_woods_stats_cmd = %w[foxstats foxfindreset pixiestats pixiefindreset raikhenstats raikhenreset].include?(v0)
unless rumor_woods_gate_rid == 8211332 || rumor_woods_gate_rid == 8208746 || rumor_woods_in_fox_maze || rumor_woods_in_pixie_maze || rumor_woods_stats_cmd
	respond
	respond "Start at the fox entrance (;go2 u8211332), pixie entrance (;go2 u8208746), or anywhere inside the fox maze (u8208601..8208640) or pixie maze (u8208501..8208536)."
	respond
	exit
else
	if rumor_woods_gate_rid == 8211332 || rumor_woods_in_fox_maze
		@fox = true
	else
		@fox = false
	end
end

if v0 == "foxstats"
	rumor_woods_fox_find_print_stats
	exit
end
if v0 == "foxfindreset"
	CharSettings['rumor_woods_fox_find_counts'] = {}
	respond
	respond "[rumor_woods] Fox find room counts cleared (CharSettings)."
	respond
	exit
end
if v0 == "pixiestats"
	rumor_woods_pixie_find_print_stats
	exit
end
if v0 == "pixiefindreset"
	CharSettings['rumor_woods_pixie_find_counts'] = {}
	respond
	respond "[rumor_woods] Pixie find room counts cleared (CharSettings)."
	respond
	exit
end
if v0 == "raikhenstats"
	rumor_woods_raikhen_print_stats
	exit
end
if v0 == "raikhenreset"
	sm = Lich::Common::Settings
	scope = CharSettings.active_scope
	sn = RWO_RAIKHEN_CS_SCRIPT
	sm.set_script_settings(scope, "rumor_woods_raikhen_total", 0, script_name: sn)
	sm.set_script_settings(scope, "rumor_woods_raikhen_count", 0, script_name: sn)
	@rumor_woods_raikhen_run_total = 0
	@rumor_woods_raikhen_run_count = 0
	respond
	respond "[rumor_woods] Rumor Woods raikhen total and exchange count cleared (CharSettings)."
	respond
	exit
end

if Vars.lootsack.nil?
	respond
	respond "Set your lootsack variable first."
	respond
	respond ";vars set lootsack = CONTAINER-NOUN"
	respond
	exit
end

script.vars[1] = (script.vars[1] == nil) ? "farm" : script.vars[1].downcase

case script.vars[1]
	when "fox", "pixie"
		respond
		if script.vars[1] == "fox" && rumor_woods_in_pixie_maze
			respond "[rumor_woods] You are in the pixie hunt maze. Use ;#{script.name} pixie from here, or fox mode from the fox maze or treeline (u8211332)."
			respond
			exit
		end
		if script.vars[1] == "pixie" && rumor_woods_in_fox_maze
			respond "[rumor_woods] You are in the fox hunt maze. Use ;#{script.name} fox from here, or pixie mode from the pixie maze or steps (u8208746)."
			respond
			exit
		end
		@fox ? (respond "Fox Hunting Mode") : (respond "Pixie Hunting Mode")
		respond
		#if ((UserVars.FoxPixieHuntTimeout == nil) || (UserVars.FoxPixieHuntTimeout.class != Integer) || (UserVars.FoxPixieHuntTimeout < 0) || (UserVars.FoxPixieHuntTimeout > 100))
		if ((UserVars.FoxPixieHuntTimeout == nil) || (!UserVars.FoxPixieHuntTimeout.is_a?(Integer)) || (UserVars.FoxPixieHuntTimeout < 0) || (UserVars.FoxPixieHuntTimeout > 90))
			respond "Your fox/pixie hunt timeout has not been set."
			respond
			respond "This is the number of seconds before hunt mode gives up the chase."
			respond
			respond ";e echo UserVars.FoxPixieHuntTimeout = NUMBER"
			respond
			respond "The number needs to be between 0 and 90."
			respond
			respond "90 seconds is the recommended default."
			respond
			exit
		else
			respond "Your fox/pixie hunt timeout is currently #{UserVars.FoxPixieHuntTimeout} seconds."
			respond
		end
	when "farm"
		respond
		respond "Raikhen Farming Mode"
		respond
	when "manual"
		respond
		respond "Manual Mode"
		respond
	when "motivation"
		respond
		respond "It doesn't matter what the trapper or elder says, you ARE good at this!"
		respond
		respond "Good luck in there, you can do it!"
		respond
		exit
	when "debug"
		exit
	else
		respond
		respond "Invalid Option (help, fox, pixie, farm, manual, motivation, foxstats, foxfindreset, pixiestats, pixiefindreset, raikhenstats, raikhenreset)"
		respond
		exit
end

announce_increment = 5 # seconds between timer announcements (fox/pixie chase + manual)
	
kill_foxpixiehunt = false

upstream_action = proc { |client_string|
   begin
	  if client_string =~ /^(?:<c>)?toggle$|^(?:<c>)?toggle foxpixiehunt$|^(?:<c>)?toggle foxpixie$|^(?:<c>)?toggle fox$/i
		if !kill_foxpixiehunt
			kill_foxpixiehunt = true
			respond
			respond "FoxPixieHunt Set to Exit"
			respond
			nil
		else
			kill_foxpixiehunt = false
			respond
			respond "FoxPixieHunt Set to Continue"
			respond
			nil
		end
	  else
		 client_string
	  end
   rescue
	  respond $!
	  respond $!.backtrace
	  UpstreamHook.remove("#{script.name}")
	  client_string
   end
}
	
UpstreamHook.add("#{script.name}", upstream_action)

rumor_woods_raikhen_downstream = proc { |server_string|
	begin
		rumor_woods_raikhen_process_line(server_string)
	rescue
		respond "[rumor_woods] Rumor Woods raikhen hook error: #{$!}"
	end
	server_string
}
DownstreamHook.add("#{script.name}_rw_raikhen", rumor_woods_raikhen_downstream)

before_dying {
	UpstreamHook.remove("#{script.name}")
	DownstreamHook.remove("#{script.name}_rw_raikhen") rescue nil
}	

