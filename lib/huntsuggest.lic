  TOWN_LABELS = {
    'wehnimer'   => "Wehnimer's Landing",
    'solhaven'   => 'Solhaven',
    'icemule'    => 'Icemule Trace',
    'illistim'   => "Ta'Illistim",
    'tavaalor'   => "Ta'Vaalor",
    'tafaendryl' => "Ta'Faendryl",
    'teras'      => 'Kharam-Dzu/Teras Isle',
    'riverrest'  => "River's Rest",
    'mistharbor' => 'Mist Harbor',
    'zul'        => 'Zul Logoth'
  }.freeze

  Hunt = Struct.new(
    :level,
    :area_name,
    :creature_names,
    :bounty_location,
    :creature_type,
    :town,
    :spawn_rate,
    :silver_farm,
    :skin_name,
    :estimated_skin_value,
    :bounty_status,
    :anchor_room_id,
    :go2_target,
    keyword_init: true
  )

  module_function

  def data_source
    @data_source || 'unknown'
  end

  def enable_status_tags
    return if @status_tags_enabled

    begin
      status_tags('on')
    rescue StandardError
      nil
    end

    @status_tags_enabled = true
  end

  def default_settings
    {
      'engine' => 'huntpro',
      'style' => DEFAULT_STYLE,
      'range' => DEFAULT_RANGE,
      'town_filter' => '',
      'type_filter' => '',
      'creature_filter' => '',
      'local_only' => false,
      'favorites' => [],
      'blacklist' => []
    }
  end

  def normalize_settings_hash(data)
    settings = default_settings.merge(data.is_a?(Hash) ? data : {})
    settings['engine'] = normalize_text(settings['engine']).downcase
    settings['engine'] = 'huntpro' unless %w[huntpro ashborne beta-ashborne].include?(settings['engine'])
    settings['style'] = settings['style'].to_i
    settings['style'] = DEFAULT_STYLE unless STYLE_OPTIONS.key?(settings['style'])
    settings['range'] = settings['range'].to_i
    settings['range'] = DEFAULT_RANGE if settings['range'] <= 0
    settings['town_filter'] = normalize_text(settings['town_filter'])
    settings['type_filter'] = normalize_text(settings['type_filter'])
    settings['creature_filter'] = normalize_text(settings['creature_filter'])
    settings['local_only'] = !!settings['local_only']
    settings['favorites'] = Array(settings['favorites']).map { |v| normalize_text(v) }.reject(&:empty?).uniq
    settings['blacklist'] = Array(settings['blacklist']).map { |v| normalize_text(v) }.reject(&:empty?).uniq
    settings
  end

  def load_settings
    return default_settings unless File.exist?(SETTINGS_FILE)

    data = YAML.load_file(SETTINGS_FILE)
    normalize_settings_hash(data)
  rescue StandardError
    default_settings
  end

  def save_settings(settings)
    normalized = normalize_settings_hash(settings)
    FileUtils.mkdir_p(File.dirname(SETTINGS_FILE))
    File.write(SETTINGS_FILE, normalized.to_yaml)
  rescue StandardError => e
    safe_echo("huntsuggest: could not save settings: #{e.message}")
  end

  def favorite?(hunt, settings)
    settings['favorites'].include?(hunt_area_key(hunt))
  end

  def blacklisted?(hunt, settings)
    settings['blacklist'].include?(hunt_area_key(hunt))
  end

  def add_favorite(settings, hunt)
    area = hunt_area_key(hunt)
    settings['favorites'] |= [area]
    settings['blacklist'].delete(area)
    settings
  end

  def add_blacklist(settings, hunt)
    area = hunt_area_key(hunt)
    settings['blacklist'] |= [area]
    settings['favorites'].delete(area)
    settings
  end

  def remove_area_flags(settings, hunt)
    area = hunt_area_key(hunt)
    settings['favorites'].delete(area)
    settings['blacklist'].delete(area)
    settings
  end

  def parse_query_args(args, settings = nil)
    settings ||= load_settings
    parts = Array(args).map { |v| normalize_text(v) }.reject(&:empty?)

    level = detect_level
    level_range = settings['range']
    town_filter = settings['town_filter']
    style = settings['style']
    type_filter = settings['type_filter']
    creature_filter = settings['creature_filter']
    local_only = settings['local_only']

    level = parts.shift.to_i if integer_text?(parts[0])
    level_range = parts.shift.to_i if integer_text?(parts[0])

    trailing = normalize_text(parts.join(' '))
    town_filter = trailing unless trailing.empty?

    [level, level_range, town_filter, style, type_filter, creature_filter, local_only]
  end

  def detect_level
    level = begin
      Char.level
    rescue StandardError
      nil
    end

    level ||= begin
      XMLData.level
    rescue StandardError
      nil
    end

    raise 'could not determine your level, use ;huntsuggest <level>' unless level

    level.to_i
  end

  def current_location_context
    {
      area_text: current_area_text,
      room_id: current_room_id,
      town_key: normalize_town_key(current_area_text)
    }
  end

  def current_area_text
    area = begin
      checkarea
    rescue StandardError
      nil
    end
    area = normalize_text(area)
    return area unless area.empty?

    title = begin
      Room.current.title.to_s
    rescue StandardError
      ''
    end

    normalize_text(title)
  end

  def current_room_id
    value = begin
      XMLData.room_id
    rescue StandardError
      nil
    end
    integer_from(value.to_s)
  end

  def normalize_town_key(text)
    value = normalize_text(text).downcase
    return nil if value.empty?

    TOWN_AREA_ALIASES.each do |canonical, aliases|
      return canonical if aliases.any? { |alias_text| value.include?(alias_text) }
    end

    nil
  end

  def hunt_town_key(hunt)
    normalize_town_key(hunt.town)
  end

  def haystacks_for(hunt)
    [
      normalize_text(hunt.town).downcase,
      normalize_text(hunt.bounty_location).downcase,
      normalize_text(hunt.area_name).downcase,
      normalize_text(hunt.creature_names).downcase,
      normalize_text(hunt.creature_type).downcase
    ]
  end

  def local_area_match?(hunt, current_context)
    current_area = normalize_text(current_context[:area_text]).downcase
    return false if current_area.empty?

    haystacks_for(hunt).any? do |text|
      next false if text.empty?
      current_area.include?(text) || text.include?(current_area)
    end
  end

  def local_town_match?(hunt, current_context)
    current_town = current_context[:town_key]
    return false if current_town.nil?

    hunt_town_key(hunt) == current_town
  end

  def local_flags_text(hunt, current_context, settings = nil)
    flags = []
    flags << 'FAV' if settings && favorite?(hunt, settings)
    flags << 'LOCAL-AREA' if local_area_match?(hunt, current_context)
    flags << 'LOCAL-TOWN' if local_town_match?(hunt, current_context)
    flags.empty? ? '' : "[#{flags.join(', ')}]"
  end

  def load_hunts
    ensure_custom_catalog

    remote_hunts = []
    source = nil

    begin
      csv_text = URI.open(SHEET_URL, open_timeout: 8, read_timeout: 15, &:read)
      remote_hunts = parse_hunts_csv(csv_text)
      raise 'no valid rows found in sheet' if remote_hunts.empty?

      write_cache(csv_text)
      source = 'Google Sheet'
    rescue StandardError => error
      if File.exist?(CACHE_FILE)
        remote_hunts = parse_hunts_csv(File.read(CACHE_FILE))
        source = "offline cache (#{File.mtime(CACHE_FILE).strftime('%Y-%m-%d')})"
        safe_echo("huntsuggest: sheet unavailable, using #{source}: #{error.message}")
      else
        raise "sheet unavailable and no cache exists: #{error.message}"
      end
    end

    custom_hunts = parse_hunts_csv(File.read(CUSTOM_FILE))
    huntplan_hunts = load_huntplan_hunts
    @data_source = source
    @data_source += " + #{custom_hunts.length} local" if custom_hunts.any?
    @data_source += " + #{huntplan_hunts.length} HuntPlan" if huntplan_hunts.any?

    hunts = dedupe_hunts(custom_hunts + huntplan_hunts + remote_hunts)
    raise 'no valid hunting grounds found' if hunts.empty?
    hunts
  end

  def parse_hunts_csv(csv_text)
    CSV.parse(csv_text.to_s, headers: true).map { |row| build_hunt(row) }.compact
  end

  def ensure_custom_catalog
    return if File.exist?(CUSTOM_FILE)

    FileUtils.mkdir_p(File.dirname(CUSTOM_FILE))
    File.write(CUSTOM_FILE, CSV.generate_line(CSV_HEADERS))
  rescue StandardError => error
    safe_echo("huntsuggest: could not create local catalog: #{error.message}")
  end

  def write_cache(csv_text)
    FileUtils.mkdir_p(File.dirname(CACHE_FILE))
    temporary_file = "#{CACHE_FILE}.tmp"
    File.write(temporary_file, csv_text)
    FileUtils.mv(temporary_file, CACHE_FILE)
  rescue StandardError => error
    safe_echo("huntsuggest: could not update cache: #{error.message}")
  end

  def default_huntplan_path
    candidates = []
    candidates << File.join($script_dir, 'huntplan.lic') if defined?($script_dir) && $script_dir
    candidates << File.join(File.dirname(__FILE__), 'huntplan.lic') if defined?(__FILE__)
    candidates << File.join(Dir.pwd, 'huntplan.lic')
    candidates.find { |path| File.exist?(path) }
  rescue StandardError
    nil
  end

  def parse_huntplan_creatures(source)
    source.to_s.scan(/Creature\.new\(\s*(\[[^\]]*\])\s*,\s*(nil|\d+)\s*,\s*(\[[^\]]*\])\s*\)/m).filter_map do |names_source, level_source, spawn_source|
      names = names_source.scan(/"((?:\\.|[^"])*)"/).flatten.map { |name| normalize_text(name.gsub('\"', '"')) }.reject(&:empty?)
      next if names.empty?

      level = level_source == 'nil' ? nil : level_source.to_i
      spawn_ids = spawn_source.scan(/\d+/).map(&:to_i).uniq
      next unless level && level.positive?
      next if spawn_ids.empty?

      {
        names: names,
        level: level,
        spawn_ids: spawn_ids
      }
    end
  end

  def parse_huntplan_spawn_index(source)
    index = {}
    source.to_s.scan(/(\d+)\s*=>\s*\[([^\]]*)\]/m) do |spawn_id, room_source|
      rooms = room_source.scan(/\d+/).map(&:to_i).uniq
      index[spawn_id.to_i] = rooms unless rooms.empty?
    end
    index
  end

  def huntplan_room_label(room_id)
    return '' unless room_id && defined?(Map)

    room = Map[room_id] rescue nil
    return '' unless room

    values = []
    values << room.title if room.respond_to?(:title)
    values << room.location if room.respond_to?(:location)
    values << room.area if room.respond_to?(:area)
    values << room.image if room.respond_to?(:image)
    values.flatten.map { |value| normalize_text(value) }.reject(&:empty?).uniq.first.to_s
  rescue StandardError
    ''
  end

  def town_label_from_text(text)
    key = normalize_town_key(text)
    key ? TOWN_LABELS.fetch(key, key) : ''
  end

  def huntplan_town_label(room_id)
    return '' unless room_id && defined?(Map)

    room = Map[room_id] rescue nil
    return '' unless room

    values = []
    values << room.location if room.respond_to?(:location)
    values << room.area if room.respond_to?(:area)
    values << room.image if room.respond_to?(:image)
    values << room.title if room.respond_to?(:title)
    values.flatten.map { |value| normalize_text(value) }.reject(&:empty?).each do |value|
      label = town_label_from_text(value)
      return label unless label.empty?
    end

    huntplan_room_label(room_id)
  rescue StandardError
    ''
  end

  def huntplan_target_for(hunt)
    target = normalize_text(hunt&.go2_target)
    return target.sub(/\Ahuntplan:/i, '').strip if target =~ /\Ahuntplan:/i

    area = normalize_text(hunt&.area_name)
    area.sub(/\AHuntPlan:\s*/i, '').strip if area =~ /\AHuntPlan:/i
  end

  def clean_area_name(value)
    text = normalize_text(value)
    text = text.sub(/\AHuntPlan:\s*/i, '')
    text = text.sub(/\Ahuntplan:\s*/i, '')
    text = text.sub(/\Ahp[_:\-\s]+/i, '')
    text.tr('_', ' ').gsub(/\s+/, ' ').strip
  end

  def catalog_area_slug(value)
    clean_area_name(value).downcase.gsub(/[^a-z0-9]+/, '_').gsub(/\A_+|_+\z/, '')
  end

  def beta_ashborne_area_for(hunt)
    target = huntplan_target_for(hunt)
    return '' if blank_text?(target)

    catalog_area_slug(target)
  end

  def load_huntplan_hunts
    built_in_hunts = parse_hunts_csv(HUNTPLAN_CATALOG_CSV)
    source_path = default_huntplan_path
    return built_in_hunts if source_path.to_s.empty? || !File.exist?(source_path)

    source = File.read(source_path)
    creatures = parse_huntplan_creatures(source)
    spawn_index = parse_huntplan_spawn_index(source)

    local_hunts = creatures.map do |creature|
      primary_name = creature[:names].first
      rooms = creature[:spawn_ids].flat_map { |spawn_id| spawn_index[spawn_id] || [] }.uniq
      anchor = rooms.first
      room_label = huntplan_room_label(anchor)
      town_label = huntplan_town_label(anchor)
      spawn_text = "#{creature[:spawn_ids].length} spawn #{creature[:spawn_ids].length == 1 ? 'area' : 'areas'}"
      spawn_text += ", #{rooms.length} mapped #{rooms.length == 1 ? 'room' : 'rooms'}" if rooms.any?

      Hunt.new(
        level: creature[:level],
        area_name: clean_area_name(primary_name),
        creature_names: creature[:names].join(' | '),
        bounty_location: room_label.empty? ? 'HuntPlan spawn data' : room_label,
        creature_type: '',
        town: town_label.empty? ? (room_label.empty? ? 'HuntPlan' : room_label) : town_label,
        spawn_rate: spawn_text,
        silver_farm: '',
        skin_name: '',
        estimated_skin_value: '',
        bounty_status: 'HuntPlan catalog',
        anchor_room_id: anchor,
        go2_target: "huntplan:#{primary_name}"
      )
    end

    dedupe_hunts(local_hunts + built_in_hunts)
  rescue StandardError => error
    safe_echo("huntsuggest: could not read HuntPlan catalog: #{error.message}")
    parse_hunts_csv(HUNTPLAN_CATALOG_CSV)
  end

  def build_hunt(row)
    level = integer_from(read_value(row, 'Creature Level', 'Level'))
    area_name = read_value(row, 'Area Name')
    return nil unless level
    return nil if blank_text?(area_name)

    anchor_room_id = integer_from(read_value(row, 'Anchor Room ID', 'Room ID', 'AnchorRoomID'))
    town = read_value(row, 'Town')
    if area_name =~ /\AHuntPlan:/i && (blank_text?(town) || town =~ /\AHuntPlan\z/i)
      mapped_town = huntplan_town_label(anchor_room_id)
      town = mapped_town unless blank_text?(mapped_town)
    end
    area_name = clean_area_name(area_name)

    Hunt.new(
      level: level,
      area_name: area_name,
      creature_names: read_value(row, 'Creature Names'),
      bounty_location: read_value(row, 'Bounty Location'),
      creature_type: read_value(row, 'Type', 'Creature Type'),
      town: town,
      spawn_rate: read_value(row, 'Spawn Rate'),
      silver_farm: read_value(row, 'Silver Farm'),
      skin_name: read_value(row, 'Skin Name'),
      estimated_skin_value: read_value(row, 'Estimated Skin Value'),
      bounty_status: read_value(row, 'Bounty Status'),
      anchor_room_id: anchor_room_id,
      go2_target: read_value(row, 'Go2 Target', 'GO2 Target', 'go2')
    )
  end

  def read_value(row, *names)
    headers = row.headers.compact.map(&:to_s)

    names.each do |wanted|
      found = headers.find { |header| normalize_header(header) == normalize_header(wanted) }
      return normalize_text(row[found]) if found
    end

    ''
  end

  def filter_hunts(hunts_arg = nil, level:, level_range:, town_filter:, type_filter:, creature_filter:, local_only:, current_context:, settings:, hunts: nil)
    hunts = hunts_arg || hunts
    raise ArgumentError, 'hunts is required' unless hunts

    filtered = hunts.select do |hunt|
      next false unless hunt.level
      next false if blacklisted?(hunt, settings)

      in_range = (hunt.level - level).abs <= level_range

      town_ok =
        if town_filter && !town_filter.empty?
          haystacks_for(hunt).any? { |text| text.include?(town_filter.downcase) }
        else
          true
        end

      type_ok =
        if type_filter && !type_filter.empty?
          normalize_text(hunt.creature_type).downcase.include?(type_filter.downcase)
        else
          true
        end

      creature_ok =
        if creature_filter && !creature_filter.empty?
          normalize_text(hunt.creature_names).downcase.include?(creature_filter.downcase)
        else
          true
        end

      local_ok =
        if local_only
          local_area_match?(hunt, current_context) || local_town_match?(hunt, current_context)
        else
          true
        end

      in_range && town_ok && type_ok && creature_ok && local_ok
    end

    ranked = filtered.sort_by do |hunt|
      [
        favorite?(hunt, settings) ? 0 : 1,
        local_area_match?(hunt, current_context) ? 0 : 1,
        local_town_match?(hunt, current_context) ? 0 : 1,
        (hunt.level - level).abs,
        -hunt_bounty_score(hunt),
        -hunt_spawn_score(hunt),
        normalize_text(hunt.town),
        hunt_area_key(hunt)
      ]
    end

    dedupe_hunts(ranked)
  end

  def dedupe_hunts(hunts)
    seen = {}
    hunts.each_with_object([]) do |hunt, result|
      key = hunt_area_key(hunt).downcase
      next if seen[key]

      seen[key] = true
      result << hunt
    end
  end

  def hunting_command(hunt, style_number, engine = 'huntpro')
    script_name = case normalize_text(engine).downcase
                  when 'ashborne' then 'ashborne'
                  when 'beta-ashborne', 'beta', 'beta ashborne' then 'beta-ashborne'
                  else 'huntpro'
                  end
    catalog_area = beta_ashborne_area_for(hunt)
    launch_area = %w[ashborne beta-ashborne].include?(script_name) && !blank_text?(catalog_area) ? catalog_area : hunt_area_key(hunt)
    ";#{script_name} #{style_number} #{launch_area}"
  end

  def huntpro_command(hunt, style_number)
    hunting_command(hunt, style_number, 'huntpro')
  end

  def hunt_area_key(hunt)
    clean_area_name(hunt.area_name)
  end

  def hunt_spawn_score(hunt)
    text = normalize_text(hunt.spawn_rate).downcase
    return 5 if text.include?('very high')
    return 4 if text.include?('high')
    return 3 if text.include?('medium')
    return 2 if text.include?('low')
    return 1 if text.include?('very low')
    0
  end

  def hunt_bounty_score(hunt)
    text = normalize_text(hunt.bounty_status).downcase
    return 3 if text.include?('complete')
    return 1 if text.include?('partial')
    0
  end

  def click(label, command)
    %(<d cmd="#{xml_escape(command)}">#{xml_escape(label)}</d>)
  end

  def emit_backup_clickable(command, prefix = 'Command')
    safe_echo("#{prefix}: #{command}")
    send_line("#{prefix}: #{click(command, command)}")
  end

  def start_hunting_script(style_number, area_name, engine = 'huntpro', hunt = nil)
    style = style_number.to_i
    area = normalize_text(area_name)
    catalog_area = beta_ashborne_area_for(hunt)
    selected_script = case normalize_text(engine).downcase
                      when 'ashborne' then 'ashborne'
                      when 'beta-ashborne', 'beta', 'beta ashborne' then 'beta-ashborne'
                      else 'huntpro'
                      end
    script_name = selected_script
    launch_area = %w[ashborne beta-ashborne].include?(script_name) && !blank_text?(catalog_area) ? catalog_area : area
    raise "blank #{script_name} area name" if launch_area.empty?
    unless Script.exists?(script_name)
      safe_echo("huntsuggest: #{script_name}.lic is not installed. Install it or select another hunting engine.")
      return false
    end

    command = ";#{script_name} #{style} #{launch_area}"
    safe_echo("huntsuggest: starting #{command}")
    emit_backup_clickable(command, 'Backup')

    args = [style.to_s, launch_area]

    begin
      start_script(script_name, args)
      return true
    rescue StandardError
      nil
    end

    begin
      Script.start(script_name, args)
      return true
    rescue StandardError
      nil
    end

    begin
      Script.run(script_name, *args)
      return true
    rescue StandardError
      nil
    end

    safe_echo("huntsuggest: unable to start #{script_name}. Use the displayed backup command.")
    false
  rescue StandardError => e
    safe_echo("huntsuggest: failed to start #{script_name || engine}: #{e.message}")
    false
  end

  def start_huntpro(style_number, area_name)
    start_hunting_script(style_number, area_name, 'huntpro')
  end

  def send_line(text)
    puts %(<output class="mono" />#{text})
  rescue StandardError
    safe_echo(strip_tags(text))
  end

  def strip_tags(text)
    text.to_s.gsub(/<[^>]+>/, '')
  end

  def xml_escape(value)
    CGI.escapeHTML(value.to_s)
  end

  def normalize_header(value)
    value.to_s.downcase.gsub(/[^a-z0-9]+/, '')
  end

  def integer_from(value)
    match = value.to_s.match(/\d+/)
    match ? match[0].to_i : nil
  end

  def integer_text?(value)
    value.to_s.match?(/^\d+$/)
  end

  def present_text(value)
    text = normalize_text(value)
    text.empty? ? 'N/A' : text
  end

  def normalize_text(value)
    value.to_s.gsub(/\s+/, ' ').strip
  end

  def blank_text?(value)
    normalize_text(value).empty?
  end

  def safe_echo(message)
    echo message
  rescue StandardError
    puts message
  end
end

module HuntSuggestDiscovery
  POLL_SECONDS = 2
  CHECKPOINT_SECONDS = 300

  class Session
    attr_reader :output_file

    def initialize(area_name, source_file = nil)
      @area_name = HuntSuggestCore.normalize_text(area_name)
      raise 'an area name is required' if @area_name.empty?

      @source_file = source_file
      @started_at = Time.now
      @rooms = {}
      @creatures = Set.new
      @caster_creatures = Set.new
      @action_counts = {}
      @spell_events = []
      @finished = false
      @dirty = false
      @last_checkpoint = Time.now

      FileUtils.mkdir_p(HuntSuggestCore::DISCOVERY_DIR)
      slug = @area_name.downcase.gsub(/[^a-z0-9]+/, '-').gsub(/^-|-$/, '')
      slug = 'area' if slug.empty?
      merge_previous_scan(slug)
      stamp = @started_at.strftime('%Y%m%d-%H%M%S')
      @output_file = File.join(HuntSuggestCore::DISCOVERY_DIR, "#{slug}-#{stamp}.yaml")
    end

    def observe_current
      room = Room.current
      return unless room && room.respond_to?(:id) && room.id.to_i.positive?

      observe_room_id(room.id.to_i, room)
      Array(GameObj.targets).each do |target|
        next if target.respond_to?(:status) && target.status.to_s =~ /dead|gone/i

        name = target.respond_to?(:name) ? target.name : target.to_s
        observe_creature(name, room.id.to_i)
      end
      checkpoint_if_due
    rescue StandardError => error
      HuntSuggestCore.safe_echo("huntsuggest scan warning: #{error.message}")
    end

    def observe_room_id(room_id, room = nil, title = nil)
      room ||= map_room(room_id)
      room_key = room_id.to_s
      @dirty = true unless @rooms.key?(room_key)
      record = (@rooms[room_key] ||= { 'creatures' => [] })
      record['title'] = room_title(room, title)
      record['location'] = room.location.to_s if room && room.respond_to?(:location)
      record['image'] = room.image.to_s if room && room.respond_to?(:image)
      record['tags'] = Array(room.tags).map(&:to_s) if room && room.respond_to?(:tags)
      record
    end

    def observe_creature(name, room_id = nil)
      creature = clean_creature_name(name)
      return if creature.empty?

      unless @creatures.include?(creature)
        @creatures << creature
        @dirty = true
      end
      return unless room_id

      record = observe_room_id(room_id)
      record['creatures'] ||= []
      unless record['creatures'].include?(creature)
        record['creatures'] << creature
        @dirty = true
      end
    end

    def observe_line(line)
      text = HuntSuggestCore.normalize_text(line)
      return text if text.empty?

      target = matching_target(text)
      return line unless target

      category = action_category(text)
      return line unless category

      creature = clean_creature_name(target.name)
      @action_counts[creature] ||= Hash.new(0)
      @action_counts[creature][category] += 1
      if category == 'spell'
        @caster_creatures << creature
        @spell_events << text if @spell_events.length < 100 && !@spell_events.include?(text)
      end
      @dirty = true
      line
    rescue StandardError
      line
    end

    def finish
      return @output_file if @finished

      @finished = true
      write_snapshot
      append_candidate
      HuntSuggestCore.safe_echo(
        "huntsuggest: discovery saved #{@rooms.length} rooms, #{@creatures.length} creatures, " \
        "#{boundary_room_ids.length} boundaries"
      )
      HuntSuggestCore.safe_echo("huntsuggest: review #{@output_file}")
      @output_file
    rescue StandardError => error
      HuntSuggestCore.safe_echo("huntsuggest: could not finish discovery: #{error.message}")
      nil
    end

    private

    def merge_previous_scan(slug)
      previous = Dir[File.join(HuntSuggestCore::DISCOVERY_DIR, "#{slug}-*.yaml")].sort.last
      return unless previous

      data = YAML.load_file(previous)
      return unless data.is_a?(Hash)

      @rooms.merge!(data['rooms']) if data['rooms'].is_a?(Hash)
      Array(data['creatures']).each { |name| @creatures << name.to_s }
    rescue StandardError
      nil
    end

    def map_room(room_id)
      Room[room_id.to_i]
    rescue StandardError
      nil
    end

    def room_title(room, fallback)
      titles = room && room.respond_to?(:title) ? Array(room.title) : []
      HuntSuggestCore.normalize_text(titles.first || fallback)
    end

    def clean_creature_name(value)
      text = HuntSuggestCore.normalize_text(value)
      text = text.sub(/^(?:a|an|the)\s+/i, '')
      text.gsub(/[!.,;:]+\z/, '')
    end

    def matching_target(text)
      Array(GameObj.targets).find do |target|
        names = [target.respond_to?(:name) ? target.name : nil, target.respond_to?(:noun) ? target.noun : nil]
        names.compact.any? { |name| text.match?(/\b#{Regexp.escape(name.to_s)}\b/i) }
      end
    rescue StandardError
      nil
    end

    def action_category(text)
      return 'spell' if text =~ /\b(?:prepar(?:e|es|ing)|incant(?:s|ing)?|chant(?:s|ing)?|gesture(?:s|d)?|invok(?:e|es|ing)|summon(?:s|ing)?|spell)\b/i
      return 'maneuver' if text =~ /\b(?:charges?|rushes?|sweeps?|tramples?|tackles?|grapples?|pounces?|roars?)\b/i
      return 'physical' if text =~ /\b(?:attacks?|swings?|slashes?|jabs?|punches?|kicks?|bites?|claws?|strikes?|fires?|shoots?)\b/i

      nil
    end

    def observed_room_ids
      @rooms.keys.map(&:to_i).select(&:positive?).uniq.sort
    end

    def boundary_room_ids
      observed = observed_room_ids.to_set
      observed.each_with_object(Set.new) do |room_id, boundaries|
        room = map_room(room_id)
        next unless room && room.respond_to?(:wayto) && room.wayto

        room.wayto.keys.each do |destination|
          destination_id = destination.to_i
          boundaries << destination_id if destination_id.positive? && !observed.include?(destination_id)
        end
      end.to_a.sort
    end

    def snapshot
      {
        'version' => 1,
        'area_name' => @area_name,
        'started_at' => @started_at.strftime('%Y-%m-%d %H:%M:%S %z'),
        'updated_at' => Time.now.strftime('%Y-%m-%d %H:%M:%S %z'),
        'character_level' => character_level,
        'source_file' => @source_file,
        'anchor_room_id' => observed_room_ids.first,
        'hunting_room_ids' => observed_room_ids,
        'boundary_room_ids' => boundary_room_ids,
        'creatures' => @creatures.to_a.sort,
        'caster_creatures' => @caster_creatures.to_a.sort,
        'action_counts' => @action_counts,
        'spell_events' => @spell_events,
        'locations' => @rooms.values.map { |room| room['location'].to_s }.reject(&:empty?).uniq.sort,
        'map_images' => @rooms.values.map { |room| room['image'].to_s }.reject(&:empty?).uniq.sort,
        'rooms' => @rooms
      }
    end

    def character_level
      Char.level.to_i
    rescue StandardError
      nil
    end

    def checkpoint_if_due
      return unless @dirty
      return if Time.now - @last_checkpoint < CHECKPOINT_SECONDS

      write_snapshot
      @dirty = false
      @last_checkpoint = Time.now
    end

    def write_snapshot
      temporary_file = "#{@output_file}.tmp"
      File.write(temporary_file, snapshot.to_yaml)
      FileUtils.mv(temporary_file, @output_file)
    end

    def append_candidate
      create_index = !File.exist?(HuntSuggestCore::DISCOVERY_INDEX_FILE)
      data = snapshot
      CSV.open(HuntSuggestCore::DISCOVERY_INDEX_FILE, 'ab') do |csv|
        csv << HuntSuggestCore::DISCOVERY_HEADERS if create_index
        csv << [
          data['updated_at'], data['area_name'], data['character_level'],
          data['creatures'].join(' | '), data['caster_creatures'].join(' | '),
          data['locations'].join(' | '),
          data['map_images'].join(' | '), data['anchor_room_id'],
          data['hunting_room_ids'].join(' '), data['boundary_room_ids'].join(' '),
          data['source_file']
        ]
      end
    end
  end

  module_function

  def live_scan(area_name)
    session = Session.new(area_name)
    hook_name = "huntsuggest_discovery_#{Char.name}"
    HuntSuggestCore.safe_echo("huntsuggest discovery ON for '#{area_name}'")
    HuntSuggestCore.safe_echo(
      "huntsuggest: sampling every #{POLL_SECONDS} seconds; changed data checkpoints every " \
      "#{CHECKPOINT_SECONDS / 60} minutes"
    )
    HuntSuggestCore.safe_echo('huntsuggest: OFF automatically after HuntPro or Ashborne exits, or use ;kill huntsuggest')
    saw_hunting_script = Script.running?('huntpro') || Script.running?('ashborne')

    begin
      DownstreamHook.add(hook_name, proc { |line| session.observe_line(line) })
      loop do
        session.observe_current
        running = Script.running?('huntpro') || Script.running?('ashborne')
        saw_hunting_script ||= running
        break if saw_hunting_script && !running
        sleep POLL_SECONDS
      end
    ensure
      begin
        DownstreamHook.remove(hook_name)
      rescue StandardError
        nil
      end
      session.finish
    end
  end

  def import_log(area_name, path)
    expanded_path = File.expand_path(path.to_s)
    raise "log file not found: #{expanded_path}" unless File.file?(expanded_path)

    session = Session.new(area_name, expanded_path)
    current_room_id = nil
    File.open(expanded_path, 'r:BOM|UTF-8', invalid: :replace, undef: :replace, replace: '') do |file|
      file.each_line do |line|
        room_match = line.match(/^\[(.+?)(?:\s+-\s+(\d+))?\]\s+\(u\d+\)/)
        if room_match
          current_room_id = room_match[2].to_i if room_match[2]
          session.observe_room_id(current_room_id, nil, room_match[1]) if current_room_id.to_i.positive?
          next
        end

        target_match =
          line.match(/You are now targeting (?:an?|the)?\s*(.+?)\./i) ||
          line.match(/attempts to \w+ (?:an?|the)?\s*(.+?)!/i)
        session.observe_creature(target_match[1], current_room_id) if target_match
      end
    end
    session.finish
  end

  def list_scans
    files = Dir[File.join(HuntSuggestCore::DISCOVERY_DIR, '*.yaml')].sort.reverse.first(10)
    if files.empty?
      HuntSuggestCore.safe_echo('huntsuggest: no discovery scans saved yet')
      return
    end

    HuntSuggestCore.safe_echo('=== Recent Huntsuggest Scans ===')
    files.each do |path|
      data = YAML.load_file(path)
      HuntSuggestCore.safe_echo(
        "#{data['area_name']}: #{Array(data['hunting_room_ids']).length} rooms, " \
        "#{Array(data['creatures']).join(', ')}"
      )
    rescue StandardError
      HuntSuggestCore.safe_echo(File.basename(path))
    end
    HuntSuggestCore.safe_echo("Candidate index: #{HuntSuggestCore::DISCOVERY_INDEX_FILE}")
  end
end

module HuntSuggestLocalMapImport
  MAX_IMPORTED_ROOMS = 500

  module_function

  def mob_data_file
    candidates = [
      File.join(HuntSuggestCore::BASE_DATA_DIR, 'mob_list_out_dict.yaml'),
      File.join($lich_dir, 'data', 'mob_list_out_dict.yaml')
    ]
    candidates.find { |path| File.file?(path) }
  end

  def ebestiary_file
    path = File.join($lich_dir, 'scripts', 'ebestiary.lic')
    File.file?(path) ? path : nil
  end

  def creature_levels
    path = ebestiary_file
    return {} unless path

    source = File.read(path)
    marker = 'creature_str = %Q('
    start_at = source.index(marker)
    finish_at = source.index('JSON.parse(creature_str)', start_at.to_i)
    return {} unless start_at && finish_at

    json_start = source.index('{', start_at)
    json_text = source[json_start...finish_at].to_s.strip.sub(/\)\s*\z/, '')
    JSON.parse(json_text).each_with_object({}) do |(name, data), levels|
      levels[HuntSuggestCore.normalize_text(name).downcase] = data['level'].to_i
    end
  rescue StandardError => error
    HuntSuggestCore.safe_echo("huntsuggest: could not read ebestiary levels: #{error.message}")
    {}
  end

  def room_creatures(mob_data, room_id)
    values = mob_data[room_id.to_i] || mob_data[room_id.to_s]
    Array(values).map { |name| HuntSuggestCore.normalize_text(name) }
      .reject { |name| name.empty? || name.casecmp('NONE').zero? }
      .uniq
  end

  def room_level(creatures, levels)
    creatures.map { |name| levels[name.downcase] }.compact.max
  end

  def room_context(room)
    {
      location: room.respond_to?(:location) ? HuntSuggestCore.normalize_text(room.location) : '',
      image: room.respond_to?(:image) ? HuntSuggestCore.normalize_text(room.image) : ''
    }
  end

  def same_mapped_area?(origin_context, room)
    context = room_context(room)
    if !origin_context[:image].empty? && !context[:image].empty?
      return false unless origin_context[:image] == context[:image]
    end
    if !origin_context[:location].empty? && !context[:location].empty?
      return false unless origin_context[:location] == context[:location]
    end
    true
  end

  def import_current_area(area_name)
    normalized_area = HuntSuggestCore.normalize_text(area_name)
    raise 'usage: ;huntsuggest importmap <area-name>' if normalized_area.empty?

    source_file = mob_data_file
    raise 'mob_list_out_dict.yaml was not found in the Lich data folder' unless source_file

    origin = Room.current
    raise 'current room is not mapped' unless origin && origin.respond_to?(:id) && origin.id.to_i.positive?

    HuntSuggestCore.safe_echo("huntsuggest: loading local mob map for '#{normalized_area}'")
    mob_data = YAML.load_file(source_file)
    raise 'local mob map did not contain room data' unless mob_data.is_a?(Hash)

    levels = creature_levels
    origin_creatures = room_creatures(mob_data, origin.id)
    raise 'the current room has no creatures in the local mob map' if origin_creatures.empty?

    origin_level = room_level(origin_creatures, levels)
    character_level = HuntSuggestCore.detect_level
    safe_level = [character_level, origin_level || character_level].max + 2
    origin_context = room_context(origin)
    session = HuntSuggestDiscovery::Session.new(normalized_area, source_file)

    queue = [origin.id.to_i]
    queued = Set.new(queue)
    visited = Set.new
    unknown_level_creatures = Set.new

    until queue.empty? || visited.length >= MAX_IMPORTED_ROOMS
      room_id = queue.shift
      next if visited.include?(room_id)

      room = Room[room_id]
      next unless room && same_mapped_area?(origin_context, room)

      creatures = room_creatures(mob_data, room_id)
      next if creatures.empty?

      level = room_level(creatures, levels)
      next if level && level > safe_level

      visited << room_id
      session.observe_room_id(room_id, room)
      creatures.each do |creature|
        session.observe_creature(creature, room_id)
        unknown_level_creatures << creature unless levels.key?(creature.downcase)
      end

      next unless room.respond_to?(:wayto) && room.wayto

      room.wayto.keys.each do |destination|
        destination_id = destination.to_i
        next unless destination_id.positive?
        next if visited.include?(destination_id) || queued.include?(destination_id)
        next if room_creatures(mob_data, destination_id).empty?

        queue << destination_id
        queued << destination_id
      end
    end

    output_file = session.finish
    HuntSuggestCore.safe_echo(
      "huntsuggest: imported #{visited.length} connected rooms with a maximum creature level of #{safe_level}"
    )
    unless unknown_level_creatures.empty?
      HuntSuggestCore.safe_echo(
        "huntsuggest: review unknown creature levels: #{unknown_level_creatures.to_a.sort.join(', ')}"
      )
    end
    HuntSuggestCore.safe_echo("huntsuggest: import capped at #{MAX_IMPORTED_ROOMS} rooms") if visited.length >= MAX_IMPORTED_ROOMS
    output_file
  end
end

module HuntSuggest
  module_function

  def run(script)
    HuntSuggestCore.enable_status_tags

    settings = HuntSuggestCore.load_settings
    args = Array(script.vars[1..]).map { |v| HuntSuggestCore.normalize_text(v) }.reject(&:empty?)
    first = args.first.to_s.downcase

    case first
    when 'help'
      print_help
    when 'styles'
      print_styles
    when 'engine'
      engine = args[1].to_s.downcase
      engine = 'beta-ashborne' if engine =~ /\Abeta(?:-ashborne)?\z/
      raise 'usage: ;huntsuggest engine huntpro|ashborne|beta-ashborne' unless %w[huntpro ashborne beta-ashborne].include?(engine)
      settings['engine'] = engine
      HuntSuggestCore.save_settings(settings)
      label = { 'huntpro' => 'HuntPro', 'ashborne' => 'Ashborne', 'beta-ashborne' => 'Beta Ashborne' }[engine]
      HuntSuggestCore.safe_echo("huntsuggest will now start #{label}.")
    when 'scan'
      scan_action = args[1].to_s.downcase
      if scan_action == 'off'
        HuntSuggestCore.safe_echo('huntsuggest discovery is only active while its scan script is running.')
        HuntSuggestCore.safe_echo('Use ;kill huntsuggest to turn an active scan OFF immediately.')
      else
        area_name = scan_action == 'on' ? args[2] : args[1]
        raise 'usage: ;huntsuggest scan on <area-name>' if HuntSuggestCore.blank_text?(area_name)
        HuntSuggestDiscovery.live_scan(area_name)
      end
    when 'importlog'
      raise 'usage: ;huntsuggest importlog <area-name> <log-file>' if args.length < 3
      HuntSuggestDiscovery.import_log(args[1], args[2..].join(' '))
    when 'importmap'
      raise 'usage: ;huntsuggest importmap <area-name>' if HuntSuggestCore.blank_text?(args[1])
      HuntSuggestLocalMapImport.import_current_area(args[1..].join(' '))
    when 'scans'
      HuntSuggestDiscovery.list_scans
    else
      level, level_range, town_filter, style, type_filter, creature_filter, local_only =
        HuntSuggestCore.parse_query_args(args, settings)

      hunts = HuntSuggestCore.load_hunts
      current_context = HuntSuggestCore.current_location_context

      if gui_available?
        begin
          window = HuntSuggestGUI::Window.new(
            hunts: hunts,
            level: level,
            level_range: level_range,
            town_filter: town_filter,
            style: style,
            type_filter: type_filter,
            creature_filter: creature_filter,
            local_only: local_only,
            current_context: current_context,
            settings: settings
          )
          if window.scan_area
            HuntSuggestDiscovery.live_scan(window.scan_area)
          elsif window.import_area
            HuntSuggestLocalMapImport.import_current_area(window.import_area)
          end
        rescue StandardError => e
          HuntSuggestCore.safe_echo("huntsuggest: gui failed, falling back to text: #{e.class}: #{e.message}")
          show_text_suggestions(
            hunts, level, level_range, town_filter, type_filter,
            creature_filter, local_only, current_context, settings, style
          )
        end
      else
        show_text_suggestions(
          hunts, level, level_range, town_filter, type_filter,
          creature_filter, local_only, current_context, settings, style
        )
      end
    end
  rescue StandardError => e
    HuntSuggestCore.safe_echo("huntsuggest error: #{e.class}: #{e.message}")
  end

  def gui_available?
    defined?(Gtk) &&
      Gtk.const_defined?(:Window) &&
      Gtk.const_defined?(:Box) &&
      Gtk.const_defined?(:TreeView)
  end

  def print_help
    HuntSuggestCore.safe_echo('=== huntsuggest help ===')
    HuntSuggestCore.safe_echo('Built for use with HuntPro or Ashborne.')
    HuntSuggestCore.safe_echo('Manual GTK GUI, saved settings, favorites, blacklist.')
    HuntSuggestCore.safe_echo('Starts the selected hunting engine directly through Lich.')
    HuntSuggestCore.safe_echo('GUI selector: Hunting Engine = HuntPro, Ashborne, or Beta Ashborne.')
    HuntSuggestCore.safe_echo('Text command: ;huntsuggest engine huntpro|ashborne|beta-ashborne')
    HuntSuggestCore.safe_echo('Imported catalog rows launch clean Ashborne area keys like ;ashborne 3 lesser_burrow_orc.')
    HuntSuggestCore.safe_echo("Add hunting grounds in: #{HuntSuggestCore::CUSTOM_FILE}")
    HuntSuggestCore.safe_echo('Local rows override Google Sheet rows with the same Area Name.')
    HuntSuggestCore.safe_echo('Click any Creature, Lvl, Area, Town, Type, Spawn, Bounty, or Flags header to sort.')
    HuntSuggestCore.safe_echo('Discovery is OFF by default and never runs during normal huntsuggest use.')
    HuntSuggestCore.safe_echo('Turn ON: ;huntsuggest scan on <area-name>')
    HuntSuggestCore.safe_echo('Turn OFF: ;kill huntsuggest (also stops automatically when the selected hunt ends)')
    HuntSuggestCore.safe_echo('The GUI also has a Start New Area Scan button.')
    HuntSuggestCore.safe_echo('Active scans count creature attacks, maneuvers, and spell behavior without saving full logs.')
    HuntSuggestCore.safe_echo('Local map import: ;huntsuggest importmap <area-name>')
    HuntSuggestCore.safe_echo('Map imports run only on demand and stop at higher-level or different map areas.')
    HuntSuggestCore.safe_echo('Log review: ;huntsuggest importlog <area-name> <log-file>')
    HuntSuggestCore.safe_echo('Recent discoveries: ;huntsuggest scans')
    HuntSuggestCore.safe_echo("Discovery candidates: #{HuntSuggestCore::DISCOVERY_INDEX_FILE}")
  end

  def print_styles
    HuntSuggestCore.safe_echo('=== Hunt Styles for HuntPro and Ashborne ===')
    HuntSuggestCore::STYLE_OPTIONS.each do |number, name|
      HuntSuggestCore.safe_echo("  #{number} = #{name}")
    end
  end

  def show_text_suggestions(hunts, level, level_range, town_filter, type_filter, creature_filter, local_only, current_context, settings, style)
    engine = settings['engine']
    results = HuntSuggestCore.filter_hunts(
      hunts,
      level: level,
      level_range: level_range,
      town_filter: town_filter,
      type_filter: type_filter,
      creature_filter: creature_filter,
      local_only: local_only,
      current_context: current_context,
      settings: settings
    ).first(HuntSuggestCore::TEXT_LIMIT)

    raise 'no suggestions found' if results.empty?

    HuntSuggestCore.send_line('')
    HuntSuggestCore.send_line('=== Hunt Suggestions ===')
    HuntSuggestCore.send_line("Current Area: #{HuntSuggestCore.present_text(current_context[:area_text])}")
    HuntSuggestCore.send_line("Data Source: #{HuntSuggestCore.data_source}")
    HuntSuggestCore.send_line("Level: #{level}")
    HuntSuggestCore.send_line("Range: +/- #{level_range}")
    HuntSuggestCore.send_line("Town Filter: #{town_filter || 'Auto-local'}")
    HuntSuggestCore.send_line("Type Filter: #{type_filter.empty? ? 'Any' : type_filter}")
    HuntSuggestCore.send_line("Creature Filter: #{creature_filter.empty? ? 'Any' : creature_filter}")
    HuntSuggestCore.send_line("Local Only: #{local_only ? 'Yes' : 'No'}")
    HuntSuggestCore.send_line("Style: #{style}")
    engine_label = { 'huntpro' => 'HuntPro', 'ashborne' => 'Ashborne', 'beta-ashborne' => 'Beta Ashborne' }[engine] || 'HuntPro'
    HuntSuggestCore.send_line("Hunting Engine: #{engine_label}")
    HuntSuggestCore.send_line('')

    results.each_with_index do |hunt, index|
      HuntSuggestCore.send_line("[#{index + 1}] #{HuntSuggestCore.present_text(hunt.creature_names)} #{HuntSuggestCore.local_flags_text(hunt, current_context, settings)}".strip)
      HuntSuggestCore.send_line("  Level: #{HuntSuggestCore.present_text(hunt.level)}")
      HuntSuggestCore.send_line("  Area Name: #{HuntSuggestCore.present_text(HuntSuggestCore.hunt_area_key(hunt))}")
      HuntSuggestCore.send_line("  Town: #{HuntSuggestCore.present_text(hunt.town)}")
      HuntSuggestCore.send_line("  Type: #{HuntSuggestCore.present_text(hunt.creature_type)}")
      HuntSuggestCore.send_line("  Spawn: #{HuntSuggestCore.present_text(hunt.spawn_rate)}")
      quick = HuntSuggestCore::QUICK_STYLES.map do |label, style_num|
        cmd = HuntSuggestCore.hunting_command(hunt, style_num, engine)
        HuntSuggestCore.click("#{label}: #{cmd}", cmd)
      end.join('  ')
      HuntSuggestCore.send_line("  Quick: #{quick}")
      HuntSuggestCore.send_line('')
    end
  end
end

if defined?(Gtk)
  module HuntSuggestGUI
    class Window
      attr_reader :scan_area, :import_area

      INDEX_COL = 0
      CREATURE_COL = 1
      LEVEL_COL = 2
      AREA_COL = 3
      TOWN_COL = 4
      TYPE_COL = 5
      SPAWN_COL = 6
      BOUNTY_COL = 7
      LOCAL_COL = 8

      QUICK_TOWNS = [
        ['WL', 'landing'],
        ['Sol', 'solhaven'],
        ['IMT', 'icemule'],
        ['TI', 'illistim'],
        ['TV', 'ta vaalor'],
        ['TF', 'tafaendryl'],
        ['Zul', 'zul logoth'],
        ['Mist', 'mist harbor'],
        ['RR', 'riverrest'],
        ['Teras', 'teras'],
        ['Clear', nil]
      ].freeze

      def initialize(hunts:, level:, level_range:, town_filter:, style:, type_filter:, creature_filter:, local_only:, current_context:, settings:)
        @running = true
        @all_hunts = hunts
        @current_results = []
        @selected_hunt = nil
        @default_level = level
        @default_level_range = level_range
        @default_town_filter = town_filter
        @default_style = style
        @default_type_filter = type_filter
        @default_creature_filter = creature_filter
        @default_local_only = local_only
        @current_context = current_context
        @settings = settings

        if Gtk.respond_to?(:queue)
          Gtk.queue { build_ui }
          wait_while { @running }
        else
          build_ui
          wait_while { @running }
        end
      end

      def build_ui
        @window = Gtk::Window.new('HuntSuggest')
        @window.set_default_size(1320, 860)
        @window.border_width = 8
        @window.signal_connect('delete-event') do
          request_close
          false
        end
        @window.signal_connect('destroy') do
          finish_close
        end

        outer = Gtk::Box.new(:vertical, 8)

        current_area_label = Gtk::Label.new(
          "Current Area: #{HuntSuggestCore.present_text(@current_context[:area_text])} | Data: #{HuntSuggestCore.data_source}"
        )
        current_area_label.xalign = 0.0
        outer.pack_start(current_area_label, false, true, 0)

        filter_frame = Gtk::Frame.new('Filters')
        filter_box = Gtk::Box.new(:vertical, 6)
        filter_box.margin = 8

        filter_grid = Gtk::Grid.new
        filter_grid.row_spacing = 6
        filter_grid.column_spacing = 8

        filter_grid.attach(label('Target Level'), 0, 0, 1, 1)

        @level_entry = Gtk::Entry.new
        @level_entry.text = @default_level.to_s
        @level_entry.width_chars = 6
        filter_grid.attach(@level_entry, 1, 0, 1, 1)

        filter_grid.attach(label('Level Range (+/-)'), 2, 0, 1, 1)

        @range_entry = Gtk::Entry.new
        @range_entry.text = @default_level_range.to_s
        @range_entry.width_chars = 6
        filter_grid.attach(@range_entry, 3, 0, 1, 1)

        filter_grid.attach(label('Town Filter'), 4, 0, 1, 1)

        @town_entry = Gtk::Entry.new
        @town_entry.text = @default_town_filter.to_s
        filter_grid.attach(@town_entry, 5, 0, 1, 1)

        filter_grid.attach(label('Type Filter'), 6, 0, 1, 1)

        @type_entry = Gtk::Entry.new
        @type_entry.text = @default_type_filter.to_s
        filter_grid.attach(@type_entry, 7, 0, 1, 1)

        filter_grid.attach(label('Creature Filter'), 8, 0, 1, 1)

        @creature_entry = Gtk::Entry.new
        @creature_entry.text = @default_creature_filter.to_s
        filter_grid.attach(@creature_entry, 9, 0, 1, 1)

        filter_grid.attach(label('Style'), 10, 0, 1, 1)

        @style_combo = Gtk::ComboBoxText.new
        HuntSuggestCore::STYLE_OPTIONS.each do |number, name|
          @style_combo.append_text("#{number} - #{name}")
        end
        @style_combo.active = HuntSuggestCore::STYLE_OPTIONS.keys.sort.index(@default_style) || 0
        @style_combo.signal_connect('changed') do
          persist_settings
          populate_details_from_selection
        end
        filter_grid.attach(@style_combo, 11, 0, 1, 1)

        apply_button = make_button('Apply')
        apply_button.signal_connect('clicked') { refresh_results }
        filter_grid.attach(apply_button, 12, 0, 1, 1)

        filter_box.pack_start(filter_grid, false, true, 0)

        quick_row = Gtk::Box.new(:horizontal, 6)
        quick_row.pack_start(label('Hunting Engine:'), false, false, 0)

        @engine_combo = Gtk::ComboBoxText.new
        @engine_combo.append_text('HuntPro')
        @engine_combo.append_text('Ashborne')
        @engine_combo.append_text('Beta Ashborne')
        @engine_combo.active = { 'huntpro' => 0, 'ashborne' => 1, 'beta-ashborne' => 2 }[@settings['engine']] || 0
        @engine_combo.set_tooltip_text(
          'Choose which hunting script HuntSuggest starts. This choice is saved for the next time you open HuntSuggest.'
        )
        @engine_combo.signal_connect('changed') do
          persist_settings
          populate_details_from_selection
          selected_engine = @engine_combo.active_text.to_s
          @status_label.text = "Hunting engine set to #{selected_engine}." if @status_label
        end
        quick_row.pack_start(@engine_combo, false, false, 0)

        quick_row.pack_start(label('Quick Towns:'), false, false, 0)

        QUICK_TOWNS.each do |button_label, town_value|
          button = make_button(button_label)
          button.signal_connect('clicked') { apply_town_filter(town_value) }
          quick_row.pack_start(button, false, false, 0)
        end

        local_button = make_button('Local')
        local_button.signal_connect('clicked') { apply_local_filter }
        quick_row.pack_start(local_button, false, false, 0)

        @local_only_check = make_check_button('Local Only')
        @local_only_check.active = @default_local_only
        @local_only_check.signal_connect('toggled') do
          persist_settings
          refresh_results
        end
        quick_row.pack_start(@local_only_check, false, false, 0)

        filter_box.pack_start(quick_row, false, true, 0)

        type_row = Gtk::Box.new(:horizontal, 6)
        type_row.pack_start(label('Quick Types:'), false, false, 0)

        HuntSuggestCore::QUICK_TYPES.each do |button_label, type_value|
          button = make_button(button_label)
          button.signal_connect('clicked') { apply_type_filter(type_value) }
          type_row.pack_start(button, false, false, 0)
        end

        filter_box.pack_start(type_row, false, true, 0)

        filter_frame.add(filter_box)
        outer.pack_start(filter_frame, false, true, 0)

        paned = Gtk::Paned.new(:horizontal)

        left_scroll = Gtk::ScrolledWindow.new
        left_scroll.set_policy(:automatic, :automatic)

        @results_store = Gtk::ListStore.new(Integer, String, Integer, String, String, String, String, String, String)
        @results_view = Gtk::TreeView.new(@results_store)
        @results_view.headers_visible = true
        @results_view.activate_on_single_click = false
        @results_view.enable_grid_lines = :both if @results_view.respond_to?(:enable_grid_lines=)

        add_text_column(@results_view, 'Creature', CREATURE_COL)
        add_text_column(@results_view, 'Lvl', LEVEL_COL)
        add_text_column(@results_view, 'Area Name', AREA_COL)
        add_text_column(@results_view, 'Town', TOWN_COL)
        add_text_column(@results_view, 'Type', TYPE_COL)
        add_text_column(@results_view, 'Spawn', SPAWN_COL)
        add_text_column(@results_view, 'Bounty', BOUNTY_COL)
        add_text_column(@results_view, 'Flags', LOCAL_COL)

        @results_view.selection.mode = :single if @results_view.selection.respond_to?(:mode=)
        @results_view.selection.signal_connect('changed') { sync_selection_from_tree }
        @results_view.signal_connect('cursor-changed') { sync_selection_from_tree }
        @results_view.signal_connect('row-activated') do |_view, path, _column|
          begin
            model = @results_view.model
            iter = model.get_iter(path)
            idx = iter[INDEX_COL].to_i
            @selected_hunt = @current_results[idx]
            populate_details_from_selection
          rescue StandardError
            nil
          end
          @status_label.text = 'Selection ready. Click Start Selected Hunt when you are ready.' if @status_label
        end

        left_scroll.add(@results_view)
        paned.pack1(left_scroll, true, false)

        right_box = Gtk::Box.new(:vertical, 8)

        detail_frame = Gtk::Frame.new('Selected Hunt Details')
        detail_scroll = Gtk::ScrolledWindow.new
        detail_scroll.set_policy(:automatic, :automatic)

        @details = Gtk::TextView.new
        @details.editable = false
        @details.cursor_visible = false
        @details.wrap_mode = :word
        @details.monospace = true if @details.respond_to?(:monospace=)
        detail_scroll.add(@details)
        detail_frame.add(detail_scroll)
        right_box.pack_start(detail_frame, true, true, 0)

        @command_preview = Gtk::Entry.new
        @command_preview.editable = false
        right_box.pack_start(@command_preview, false, true, 0)

        style_row = Gtk::Box.new(:horizontal, 6)
        HuntSuggestCore::QUICK_STYLES.each do |label_text, style_num|
          button = make_button(label_text)
          button.signal_connect('clicked') { quick_send(style_num) }
          style_row.pack_start(button, false, false, 0)
        end
        right_box.pack_start(style_row, false, true, 0)

        flag_row = Gtk::Box.new(:horizontal, 6)

        @favorite_button = make_button('Favorite')
        @favorite_button.signal_connect('clicked') { favorite_selected }
        flag_row.pack_start(@favorite_button, false, false, 0)

        @blacklist_button = make_button('Blacklist')
        @blacklist_button.signal_connect('clicked') { blacklist_selected }
        flag_row.pack_start(@blacklist_button, false, false, 0)

        @clear_flags_button = make_button('Clear Flags')
        @clear_flags_button.signal_connect('clicked') { clear_selected_flags }
        flag_row.pack_start(@clear_flags_button, false, false, 0)

        right_box.pack_start(flag_row, false, true, 0)

        button_row = Gtk::Box.new(:horizontal, 6)

        @copy_button = make_button('Copy Command')
        @copy_button.signal_connect('clicked') { copy_command }
        button_row.pack_start(@copy_button, false, false, 0)

        @echo_button = make_button('Echo Command')
        @echo_button.signal_connect('clicked') { echo_command }
        button_row.pack_start(@echo_button, false, false, 0)

        @send_button = make_button('Start Selected Hunt')
        @send_button.signal_connect('clicked') { send_command }
        button_row.pack_start(@send_button, false, false, 0)

        @send_close_button = make_button('Start + Close')
        @send_close_button.signal_connect('clicked') do
          next unless send_selected_hunt
          queue_close
        end
        button_row.pack_start(@send_close_button, false, false, 0)

        right_box.pack_start(button_row, false, true, 0)

        @status_label = Gtk::Label.new('Select a hunt, review the command, then click Start Selected Hunt.')
        @status_label.xalign = 0.0
        right_box.pack_start(@status_label, false, true, 0)

        paned.pack2(right_box, false, false)
        outer.pack_start(paned, true, true, 0)

        footer = Gtk::Box.new(:horizontal, 6)

        footer.pack_start(label('New area name:'), false, false, 0)

        @scan_area_entry = Gtk::Entry.new
        @scan_area_entry.placeholder_text = 'Select a hunt or enter a new area key'
        @scan_area_entry.width_chars = 30
        footer.pack_start(@scan_area_entry, false, false, 0)

        @scan_button = make_button('Start New Area Scan')
        @scan_button.signal_connect('clicked') { start_new_area_scan }
        footer.pack_start(@scan_button, false, false, 0)

        @import_button = make_button('Import Current Map Area')
        @import_button.signal_connect('clicked') { start_current_map_import }
        footer.pack_start(@import_button, false, false, 0)

        refresh_button = make_button('Refresh')
        refresh_button.signal_connect('clicked') { refresh_results }
        footer.pack_end(refresh_button, false, false, 0)

        close_button = make_button('Close')
        close_button.signal_connect('clicked') { request_close }
        footer.pack_end(close_button, false, false, 0)

        outer.pack_start(footer, false, true, 0)

        @window.add(outer)
        clear_selection_panel
        refresh_results
        @window.show_all
      end

      def make_button(text)
        button = Gtk::Button.new
        button.label = text
        button
      end

      def make_check_button(text)
        button = Gtk::CheckButton.new
        button.label = text
        button
      end

      def label(text)
        lbl = Gtk::Label.new(text)
        lbl.xalign = 0.0
        lbl
      end

      def add_text_column(view, title, index)
        renderer = Gtk::CellRendererText.new
        column = Gtk::TreeViewColumn.new(title)
        column.resizable = true
        column.sort_column_id = index
        column.clickable = true if column.respond_to?(:clickable=)
        column.pack_start(renderer, true)
        column.add_attribute(renderer, 'text', index)
        view.append_column(column)
      end

      def request_close
        persist_settings
        finish_close
        begin
          @window.destroy if @window && !@window.destroyed?
        rescue StandardError
          nil
        end
      end

      def start_new_area_scan
        area_name = selected_or_entered_area

        if area_name.empty?
          @status_label.text = 'Enter a new area name, or select a hunt first.'
          return
        end

        @scan_area = area_name
        @status_label.text = "Discovery will start for #{area_name} after this window closes."
        request_close
      end

      def start_current_map_import
        area_name = selected_or_entered_area

        if area_name.empty?
          @status_label.text = 'Enter a new area name, or select a hunt first.'
          return
        end

        @import_area = area_name
        @status_label.text = "The connected local map area will import as #{area_name} after this window closes."
        request_close
      end

      def selected_or_entered_area
        entered_area = HuntSuggestCore.normalize_text(@scan_area_entry.text)
        selected_area = @selected_hunt ? HuntSuggestCore.hunt_area_key(@selected_hunt) : ''
        entered_area.empty? ? selected_area : entered_area
      end

      def finish_close
        return unless @running
        @running = false
      end

      def queue_close
        if defined?(GLib::Timeout)
          GLib::Timeout.add(150) do
            request_close
            false
          end
        else
          request_close
        end
      end

      def selected_style
        text = @style_combo.active_text.to_s
        match = text.match(/^(\d+)/)
        match ? match[1].to_i : HuntSuggestCore::DEFAULT_STYLE
      end

      def selected_engine
        return 'huntpro' unless @engine_combo

        case @engine_combo.active
        when 1 then 'ashborne'
        when 2 then 'beta-ashborne'
        else 'huntpro'
        end
      end

      def persist_settings
        @settings['engine'] = selected_engine
        @settings['style'] = selected_style
        @settings['range'] = integer_or_default(@range_entry.text, HuntSuggestCore::DEFAULT_RANGE)
        @settings['town_filter'] = HuntSuggestCore.normalize_text(@town_entry.text)
        @settings['type_filter'] = HuntSuggestCore.normalize_text(@type_entry.text)
        @settings['creature_filter'] = HuntSuggestCore.normalize_text(@creature_entry.text)
        @settings['local_only'] = !!@local_only_check.active?
        HuntSuggestCore.save_settings(@settings)
      end

      def integer_or_default(value, fallback)
        text = value.to_s.strip
        return fallback unless text.match?(/^\d+$/)
        text.to_i
      end

      def apply_town_filter(town_value)
        @town_entry.text = town_value.to_s
        refresh_results
      end

      def apply_local_filter
        local_town = @current_context[:town_key]
        @town_entry.text =
          case local_town
          when 'wehnimer' then 'landing'
          when 'mistharbor' then 'mist harbor'
          else local_town.to_s
          end
        refresh_results
      end

      def apply_type_filter(type_value)
        @type_entry.text = type_value.to_s
        refresh_results
      end

      def refresh_results
        level = integer_or_default(@level_entry.text, @default_level)
        level_range = integer_or_default(@range_entry.text, HuntSuggestCore::DEFAULT_RANGE)
        town_filter = HuntSuggestCore.normalize_text(@town_entry.text)
        town_filter = nil if town_filter.empty?
        type_filter = HuntSuggestCore.normalize_text(@type_entry.text)
        creature_filter = HuntSuggestCore.normalize_text(@creature_entry.text)
        local_only = !!@local_only_check.active?

        @current_results = HuntSuggestCore.filter_hunts(
          @all_hunts,
          level: level,
          level_range: level_range,
          town_filter: town_filter,
          type_filter: type_filter,
          creature_filter: creature_filter,
          local_only: local_only,
          current_context: @current_context,
          settings: @settings
        )

        persist_settings
        @results_store.clear

        @current_results.each_with_index do |hunt, index|
          iter = @results_store.append
          iter[INDEX_COL] = index
          iter[CREATURE_COL] = HuntSuggestCore.present_text(hunt.creature_names)
          iter[LEVEL_COL] = hunt.level.to_i
          iter[AREA_COL] = HuntSuggestCore.present_text(HuntSuggestCore.hunt_area_key(hunt))
          iter[TOWN_COL] = HuntSuggestCore.present_text(hunt.town)
          iter[TYPE_COL] = HuntSuggestCore.present_text(hunt.creature_type)
          iter[SPAWN_COL] = HuntSuggestCore.present_text(hunt.spawn_rate)
          iter[BOUNTY_COL] = HuntSuggestCore.present_text(hunt.bounty_status)
          iter[LOCAL_COL] = HuntSuggestCore.local_flags_text(hunt, @current_context, @settings)
        end

        @status_label.text = "#{@current_results.length} hunt#{@current_results.length == 1 ? '' : 's'} found."

        if @current_results.any?
          @selected_hunt = @current_results[0]
          begin
            first_path = Gtk::TreePath.new([0])
            @results_view.selection.select_path(first_path)
            @results_view.set_cursor(first_path, nil, false)
          rescue StandardError
            nil
          end
          populate_details_from_selection
        else
          @selected_hunt = nil
          clear_selection_panel
        end
      end

      def sync_selection_from_tree
        iter = @results_view.selection.selected
        return unless iter

        idx = iter[INDEX_COL].to_i
        hunt = @current_results[idx]
        return unless hunt

        @selected_hunt = hunt
        populate_details_from_selection
      rescue StandardError
        nil
      end

      def current_command(style_override = nil)
        return nil unless @selected_hunt
        HuntSuggestCore.hunting_command(@selected_hunt, style_override || selected_style, selected_engine)
      end

      def populate_details_from_selection
        hunt = @selected_hunt
        return clear_selection_panel unless hunt

        local_text = HuntSuggestCore.local_flags_text(hunt, @current_context, @settings).sub(/^\[/, '').sub(/\]$/, '')
        local_text = 'No' if local_text.empty?

        details = [
          "Creature: #{HuntSuggestCore.present_text(hunt.creature_names)}",
          "Level: #{HuntSuggestCore.present_text(hunt.level)}",
          "Area Name: #{HuntSuggestCore.present_text(HuntSuggestCore.hunt_area_key(hunt))}",
          "Bounty Location: #{HuntSuggestCore.present_text(hunt.bounty_location)}",
          "Town: #{HuntSuggestCore.present_text(hunt.town)}",
          "Type: #{HuntSuggestCore.present_text(hunt.creature_type)}",
          "Spawn Rate: #{HuntSuggestCore.present_text(hunt.spawn_rate)}",
          "Silver Farm: #{HuntSuggestCore.present_text(hunt.silver_farm)}",
          "Skin: #{HuntSuggestCore.present_text(hunt.skin_name)}",
          "Skin Value: #{HuntSuggestCore.present_text(hunt.estimated_skin_value)}",
          "Bounty Status: #{HuntSuggestCore.present_text(hunt.bounty_status)}",
          "Anchor Room: #{HuntSuggestCore.present_text(hunt.anchor_room_id)}",
          "Go2 Target: #{HuntSuggestCore.present_text(hunt.go2_target)}",
          "Local Match: #{local_text}"
        ].join("\n")

        @details.buffer.text = details
        @command_preview.text = current_command.to_s
        @copy_button.sensitive = true
        @echo_button.sensitive = true
        @send_button.sensitive = true
        @send_close_button.sensitive = true
        @favorite_button.sensitive = true
        @blacklist_button.sensitive = true
        @clear_flags_button.sensitive = true
        @status_label.text = "Selected #{HuntSuggestCore.present_text(hunt.creature_names)}"
      end

      def clear_selection_panel
        @details.buffer.text = ''
        @command_preview.text = ''
        @copy_button.sensitive = false
        @echo_button.sensitive = false
        @send_button.sensitive = false
        @send_close_button.sensitive = false
        @favorite_button.sensitive = false
        @blacklist_button.sensitive = false
        @clear_flags_button.sensitive = false
      end

      def copy_command
        command = current_command
        return unless command

        clipboard = Gtk::Clipboard.get(Gdk::Selection::CLIPBOARD)
        clipboard.set_text(command)
        HuntSuggestCore.safe_echo("huntsuggest: copied #{command}")
      rescue StandardError => e
        HuntSuggestCore.safe_echo("huntsuggest: copy failed: #{e.message}")
      end

      def echo_command
        command = current_command
        return unless command
        HuntSuggestCore.safe_echo("huntsuggest: #{command}")
        HuntSuggestCore.emit_backup_clickable(command, 'Backup')
      end

      def send_command
        send_selected_hunt
      end

      def quick_send(style_num)
        hunt = @selected_hunt
        return unless hunt
        command = HuntSuggestCore.hunting_command(hunt, style_num, selected_engine)
        @status_label.text = "Starting #{command}"
        HuntSuggestCore.start_hunting_script(style_num, hunt.area_name, selected_engine, hunt)
      end

      def send_selected_hunt
        hunt = @selected_hunt
        return false unless hunt
        style_num = selected_style
        command = HuntSuggestCore.hunting_command(hunt, style_num, selected_engine)
        @status_label.text = "Starting #{command}"
        HuntSuggestCore.start_hunting_script(style_num, hunt.area_name, selected_engine, hunt)
      end

      def favorite_selected
        hunt = @selected_hunt
        return unless hunt
        HuntSuggestCore.add_favorite(@settings, hunt)
        persist_settings
        refresh_results
        HuntSuggestCore.safe_echo("huntsuggest: favorited #{HuntSuggestCore.hunt_area_key(hunt)}")
      end

      def blacklist_selected
        hunt = @selected_hunt
        return unless hunt
        HuntSuggestCore.add_blacklist(@settings, hunt)
        persist_settings
        refresh_results
        HuntSuggestCore.safe_echo("huntsuggest: blacklisted #{HuntSuggestCore.hunt_area_key(hunt)}")
      end

      def clear_selected_flags
        hunt = @selected_hunt
        return unless hunt
        HuntSuggestCore.remove_area_flags(@settings, hunt)
        persist_settings
        refresh_results
        HuntSuggestCore.safe_echo("huntsuggest: cleared flags for #{HuntSuggestCore.hunt_area_key(hunt)}")
      end
    end
  end
end

HuntSuggest.run(script)
