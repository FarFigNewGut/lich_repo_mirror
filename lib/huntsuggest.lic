# HuntSuggest recommends hunting areas based on your level by reading a Google Sheet
# and presenting HuntPro- or Ashborne-compatible options in a manual GTK GUI or text fallback.
#
# Designed for use with the HuntPro and Ashborne scripts.
#
# Usage:
#   ;huntsuggest
#   ;huntsuggest <level>
#   ;huntsuggest <town>
#   ;huntsuggest <level> <town>
#   ;huntsuggest <level> <range> <town>
#   ;huntsuggest scan on <area-name>
#   ;huntsuggest importmap <area-name>
#   ;huntsuggest importlog <area-name> <log-file>
#   ;huntsuggest scans
#   ;huntsuggest help
#   ;huntsuggest styles
#
#         author: NecroDeus
#           game: gs
#           tags: hunting, huntpro, ashborne, recommendations, discovery, map, utility, gui
#       required: Lich > 5.0.1
#        version: 2.5.0-beta
#
# changelog:
#   2.5.0-beta (2026-06-16):
#     Added Beta Ashborne as a launch engine
#     Converted imported catalog rows to clean Ashborne/Beta Ashborne area commands
#   2.4.0 (2026-06-16):
#     Added automatic HuntPlan-backed recommendations from the installed huntplan.lic catalog
#     Added beta-Ashborne launch commands for HuntPlan-backed rows instead of requiring HuntPlan
#   2.3.0 (2026-06-15):
#     Added Ashborne, discovery, and map repository tags
#     Prevented missing scripts from leaking launch commands into the game
#     Clarified combat styles and made GUI hunt launching more deliberate
#   2.2.0 (2026-06-11):
#     Added opt-in local mob-map imports with level and map-area boundaries
#     Added a GUI button for importing the connected mapped area around the current room
#   2.1.0 (2026-06-11):
#     Added a New Area Scan button to the GTK menu
#     Discovery now learns compact creature action and spell-casting behavior
#   2.0.1 (2026-06-11):
#     Made discovery explicitly opt-in and reduced its polling and disk activity
#   2.0.0 (2026-06-11):
#     Added clickable sorting for every results column
#     Added low-overhead live hunting-ground discovery and offline log review
#     Added Lich map metadata and conservative boundary-room discovery
#   1.9.0 (2026-06-11):
#     Added offline sheet caching and a local supplemental hunting-ground catalog
#     Added missing quick-town filters and data-source reporting
#     Local catalog entries override matching Google Sheet area names
#   1.8.1 (2026-04-12):
#     Fixed GTK single-click selection syncing to the right-hand details pane
#     Removed background close thread; GUI close now stops cleanly
#   1.8.0 (2026-04-12):
#     Switched from trying to inject ;huntpro into the game to starting huntpro directly via Lich
#     Fixed GUI selection state and enabled buttons/details reliably
#     Kept backup clickable output in game window
#   1.7.0 (2026-04-12):
#     Full-file rebuild
#     Fixed selection state by tracking selected hunt directly

require 'csv'
require 'open-uri'
require 'uri'
require 'cgi'
require 'yaml'
require 'fileutils'
require 'set'
require 'json'

begin
  require 'gtk3'
rescue LoadError
  nil
end

module HuntSuggestCore
  BASE_DATA_DIR = defined?(DATA_DIR) ? DATA_DIR : File.join(Dir.home, '.lich')

  SHEET_URL = 'https://docs.google.com/spreadsheets/d/1KR5-3WQCKL8aU1pH-buY03W5Fj1iIr5K10gC6Do4raE/export?format=csv&gid=603710211'
  DEFAULT_STYLE = 9
  DEFAULT_RANGE = 5
  TEXT_LIMIT = 12
  SETTINGS_FILE = File.join(BASE_DATA_DIR, 'huntsuggest_settings.yaml')
  CACHE_FILE = File.join(BASE_DATA_DIR, 'huntsuggest_cache.csv')
  CUSTOM_FILE = File.join(BASE_DATA_DIR, 'huntsuggest_custom.csv')
  DISCOVERY_DIR = File.join(BASE_DATA_DIR, 'huntsuggest_scans')
  DISCOVERY_INDEX_FILE = File.join(BASE_DATA_DIR, 'huntsuggest_scan_candidates.csv')
  DISCOVERY_HEADERS = [
    'Scanned At', 'Area Name', 'Character Level', 'Creature Names',
    'Caster Creatures', 'Observed Locations', 'Map Images', 'Anchor Room ID',
    'Hunting Room IDs', 'Boundary Room IDs', 'Source File'
  ].freeze
  CSV_HEADERS = [
