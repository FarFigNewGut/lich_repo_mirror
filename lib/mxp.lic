=begin
  mxp.lic

  Equalizes experience across a group of characters by adjusting each character's
  ascension absorption rate. Characters above the group average are set to their
  max rate (their level%), diverting XP into ascension and slowing regular gain.
  Characters at or below average are set to a configurable low rate (default 0).

  Fully decentralized: every character runs ;mxp on its own. Each instance reports
  its own experience to a shared file and independently computes its own rate from
  everyone else's latest report. No queen, no drones, no borg/drone.lic required -
  just run ;mxp on each character you want in the group and leave it running.

  Run ;mxp help for full syntax and setup instructions.

  Quick command reference:
    ;mxp                       self-managing mode - report, compute, adjust, repeat
    ;mxp once                  do a single report/compute/adjust pass, then exit
    ;mxp report                save own experience to shared file only (no rate change)
    ;mxp status                show stored data and computed rates, no changes made
    ;mxp set chars <names>     set the comma-separated list of characters to manage
    ;mxp set rate <N>          set the ascension % for at/below-average chars (default 0)
    ;mxp set interval <N>      set seconds between report/adjust cycles (default 30)
    ;mxp help                  full setup instructions and command list

       author: Mara
         game: gs
         tags: experience, ascension, utility, multi
      contact: mara.lilly on Discord, @Lillymara on GitHub
    co-author: Claude (Anthropic) - claude.ai/code
      version: 2.0

  Changelog:
    2.0 (2026-07-01) - Removed the borg/drone dependency. Each character now runs
                        its own instance and computes its own rate from shared data
                        instead of a "queen" pushing commands over DRb. Added
                        continuous self-managing mode, stale-data detection scaled
                        to the polling interval, and a single-pass ";mxp once" mode.
    1.0 (2026-06-26) - Initial release.
=end

MXP_FILE = File.join(DATA_DIR, 'mxp_data.yaml')
ASC_MIN_LEVEL = 20

# ---- file helpers ----

def mxp_load
  return {} unless File.exist?(MXP_FILE)
  YAML.safe_load(File.read(MXP_FILE), permitted_classes: [Time]) || {}
rescue StandardError
  {}
end

def mxp_save(level, experience)
  data = mxp_load
  data[Char.name] = { 'level' => level, 'experience' => experience, 'updated' => Time.now }
  tmp = MXP_FILE + '.tmp'
  File.write(tmp, YAML.dump(data))
  File.rename(tmp, MXP_FILE)
end

# ---- parse experience command ----

def mxp_read_exp
  output = Lich::Util.quiet_command("experience", /Level:/, end_pattern = /PTPs\/MTPs:/, include_end = true, timeout = 5, silent = true)
  text = output.to_s
  level = text[/Level:\s+(\d+)/, 1].to_i
  exp   = text[/\bExperience:\s+([\d,]+)/, 1]&.gsub(',', '').to_i || 0
  [level, exp]
end

# ---- config helpers ----

def mxp_chars_cfg
  (Vars.mxp_chars || '').split(',').map(&:strip).reject(&:empty?)
end

def mxp_interval
  n = (Vars['mxp_interval'] || 30).to_i
  n > 0 ? n : 30
end

def mxp_stale_seconds
  mxp_interval * 3
end

# ---- data filtering ----

def mxp_relevant_data(chars_cfg)
  data = mxp_load
  return data if chars_cfg.empty?
  data.select { |c, _| chars_cfg.any? { |cc| cc.casecmp(c) == 0 } }
end

def mxp_fresh_data(data)
  data.select { |_, v| v['updated'] && (Time.now - v['updated']) <= mxp_stale_seconds }
end

# ---- equalization math ----

def mxp_compute_rates(data)
  eligible = data.select { |_, v| v.is_a?(Hash) && v['experience'].to_i > 0 && v['level'].to_i >= ASC_MIN_LEVEL }
  return {} if eligible.empty?
  all_with_exp = data.select { |_, v| v.is_a?(Hash) && v['experience'].to_i > 0 }
  avg = all_with_exp.values.map { |v| v['experience'] }.sum / all_with_exp.length
  low = (Vars['mxp_low_rate'] || 0).to_i
  eligible.transform_values { |v| v['experience'] <= avg ? low : v['level'] }
end

# ---- formatting helpers ----

def fmt_exp(n)
  n.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\1,').reverse
end

# ---- status display ----

def mxp_show_status(data, rates = nil)
  rates ||= mxp_compute_rates(data)
  avg = data.values.map { |v| v['experience'].to_i }.sum / [data.length, 1].max
  respond "[MXP] ---- Experience Status ---- (avg: #{fmt_exp(avg)}, stale after #{mxp_stale_seconds}s)"
  data.sort_by { |_, v| -(v['experience'].to_i) }.each do |char, info|
    age_sec = info['updated'] ? (Time.now - info['updated']).round : nil
    stale   = age_sec && age_sec > mxp_stale_seconds ? " [#{age_sec}s old - stale]" : ''
    rate     = rates[char]
    too_low  = info['level'].to_i > 0 && info['level'].to_i < ASC_MIN_LEVEL
    rate_str = if too_low
      "-> level too low (need #{ASC_MIN_LEVEL})"
    elsif rate
      "-> ascension #{rate}%"
    else
      '-> no data'
    end
    respond "[MXP]  #{char.ljust(16)} Lv#{info['level'].to_s.rjust(3)}  #{fmt_exp(info['experience']).rjust(12)}  #{rate_str}#{stale}"
  end
end

# ---- one report/compute/adjust cycle ----
# Reports own XP, reads the (fresh, in-group) shared data, computes this
# character's own rate, and applies it via `ascension set` only if it changed.
# Returns the rate that is now active (or the previous value if unchanged).

def mxp_set_ascension(rate)
  # Below level 100, the game requires the same "ascension set" command to be
  # entered twice within 30 seconds to confirm the change, so send it twice.
  2.times do
    fput "ascension set #{rate}"
    waitrt?
  end
end

def mxp_cycle(chars_cfg, last_rate)
  level, experience = mxp_read_exp
  if level > 0 && experience > 0
    mxp_save(level, experience)
  else
    respond "[MXP] Could not read own experience this cycle - skipping report."
    return last_rate
  end

  data  = mxp_fresh_data(mxp_relevant_data(chars_cfg))
  rates = mxp_compute_rates(data)
  my_rate = rates[Char.name]

  if my_rate && my_rate != last_rate
    mxp_set_ascension(my_rate)
    respond "[MXP] Ascension rate set to #{my_rate}% (Lv#{level}, Exp #{fmt_exp(experience)}, group avg #{fmt_exp(data.values.map { |v| v['experience'].to_i }.sum / [data.length, 1].max)})"
    last_rate = my_rate
  elsif my_rate.nil? && level > 0 && level < ASC_MIN_LEVEL
    respond "[MXP] Not adjusting - level #{level} is below #{ASC_MIN_LEVEL}."
  end

  last_rate
end

# ---- arg dispatch ----

cmd = Script.current.vars[1..-1]&.join(' ').to_s.strip

if cmd =~ /^set\s+chars?\s+(.+)$/i
  Vars.mxp_chars = $1.strip
  respond "[MXP] Characters set: #{Vars.mxp_chars}"
  raise SystemExit

elsif cmd =~ /^set\s+rate\s+(\d+)$/i
  Vars.mxp_low_rate = $1.to_i
  respond "[MXP] Low rate set to #{Vars.mxp_low_rate}%. Characters at or below average will be set to this."
  raise SystemExit

elsif cmd =~ /^set\s+interval\s+(\d+)$/i
  Vars.mxp_interval = $1.to_i
  respond "[MXP] Interval set to #{Vars.mxp_interval}s between report/adjust cycles (data considered stale after #{Vars.mxp_interval.to_i * 3}s)."
  raise SystemExit

elsif cmd =~ /^report$/i
  level, experience = mxp_read_exp
  if level == 0 || experience == 0
    respond "[MXP] Could not parse experience output. Try again."
    raise SystemExit
  end
  mxp_save(level, experience)
  respond "[MXP] Reported: #{Char.name} Lv#{level} Exp #{fmt_exp(experience)}"
  raise SystemExit

elsif cmd =~ /^status$/i
  data = mxp_load
  if data.empty?
    respond "[MXP] No data yet. Run ;mxp on at least one character first."
  else
    mxp_show_status(data)
  end
  raise SystemExit

elsif cmd =~ /^once$/i
  chars_cfg = mxp_chars_cfg
  if chars_cfg.empty?
    respond "[MXP] No characters configured. Run: ;mxp set chars Name1,Name2,..."
    raise SystemExit
  end
  mxp_cycle(chars_cfg, nil)
  mxp_show_status(mxp_fresh_data(mxp_relevant_data(chars_cfg)))
  raise SystemExit

elsif cmd =~ /^help$/i || cmd == '?'
  respond "[MXP] ---- Help ----"
  respond "[MXP]"
  respond "[MXP] SETUP (run on EVERY character you want in the group):"
  respond "[MXP]   ;mxp set chars Name1,Name2,...   Set the full list of characters to manage"
  respond "[MXP]   Example: ;mxp set chars Kirk,Spock,McCoy,Scotty,Uhura,Sulu,Chekov"
  respond "[MXP]   (Set the same list on every character - order doesn't matter.)"
  respond "[MXP]   Then just run ;mxp on each character and leave it running."
  respond "[MXP]"
  respond "[MXP] REQUIREMENTS:"
  respond "[MXP]   mxp.lic must be installed and running on every character in the group."
  respond "[MXP]   All characters must be played from this same Lich installation/PC,"
  respond "[MXP]   since coordination happens through a shared data file."
  respond "[MXP]"
  respond "[MXP] COMMANDS:"
  respond "[MXP]   ;mxp                  Self-managing mode - report, compute, adjust, repeat forever"
  respond "[MXP]   ;mxp once             Do a single report/compute/adjust pass, then exit"
  respond "[MXP]   ;mxp report           Save own experience to the shared file only (no rate change)"
  respond "[MXP]   ;mxp status           Show stored data and computed rates (no changes made)"
  respond "[MXP]   ;mxp set chars ...    Update the character list"
  respond "[MXP]   ;mxp set rate <N>     Set the ascension % for at/below-average characters (default 0)"
  respond "[MXP]   ;mxp set interval <N> Set seconds between cycles in self-managing mode (default 30)"
  respond "[MXP]   ;mxp help             Show this help"
  respond "[MXP]"
  respond "[MXP] HOW IT WORKS:"
  respond "[MXP]   There is no queen and no borg/drone system. Every character runs its own copy"
  respond "[MXP]   of ;mxp, which loops on its own:"
  respond "[MXP]     1. Report own level/experience to a shared file (data/mxp_data.yaml)."
  respond "[MXP]     2. Read the other configured characters' latest reports from that file."
  respond "[MXP]     3. Compute the group's average experience."
  respond "[MXP]     4. Set its OWN ascension rate:"
  respond "[MXP]          At or below average  ->  ascension set <low rate>%  (default 0; fastest XP gain)"
  respond "[MXP]          Above average        ->  ascension set <level>%    (slowest XP gain)"
  respond "[MXP]     5. Wait, then repeat."
  respond "[MXP]   Reports older than 3x the interval (default 90s) are treated as stale and dropped from"
  respond "[MXP]   the average, so a character who logs off or stops running ;mxp naturally falls out of"
  respond "[MXP]   the group instead of skewing everyone else's rate."
  respond "[MXP]"
  respond "[MXP]   Note: ascension set % is capped at the character's current level."
  respond "[MXP]   To stop the self-managing loop, use ;kill mxp."
  raise SystemExit

elsif !cmd.empty?
  respond "[MXP] Unknown command '#{cmd}'. Try: ;mxp help"
  raise SystemExit
end

# ---- self-managing mode ----

chars_cfg = mxp_chars_cfg
if chars_cfg.empty?
  respond "[MXP] No characters configured. Run: ;mxp set chars Name1,Name2,..."
  raise SystemExit
end

respond "[MXP] Self-managing mode started for #{Char.name} (group: #{chars_cfg.join(', ')})."
respond "[MXP] Reporting and adjusting every #{mxp_interval}s. Use ;kill mxp to stop, or ;mxp once for a single pass."

last_rate = nil
loop do
  last_rate = mxp_cycle(chars_cfg, last_rate)
  pause mxp_interval
end
