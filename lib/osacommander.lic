def commander_end_routine
	save_to_commander("clearing_end_time", Time.now)
	if @commander_data["enemyship"] == nil
		save_to_commander("enemyship", "a pirate ship")
	end
	if @commander_data["boardingtime"].nil?
		save_to_commander("boardingtime", ((Time.now - Time.now)/60))
	end
	if @commander_data["helmsman_endtime"].nil?
		save_to_commander("helmsman_endtime", Time.now)
	end
	save_to_commander("clearing_time", ((@commander_data["clearing_end_time"] - @commander_data["helmsman_endtime"])/60).as_time)
	pause 2
	if running? "osacombat"
		stop_script "osacombat"
		wait_until {!running? "osacombat"}
	end
	if (@commander_data["crewsize"] || []).count != 0
		lnet_crew("Turn To!")
		pause 2
	else
		commander_damage_control
	end
	if XMLData.injuries.any?{|key,value| value["wound"] > 1}
		start_script("eherbs", ['--buy=off', '--mending=on', '--skipscars=on', '--yaba=on', '--potions=on'])
		wait_until {!running? "eherbs"}
	end
	if XMLData.injuries.any?{|key,value| value["wound"] > 1}
		echo "You still have some wounds, this may inhibate your ability to handle loot!"
	end
	enemy_main_deck
	commander_prep_it
end



def commander_avg_sink_time
	ship_type = @commander_data["enemy_ship_type"]
	sink_key  = case ship_type
		when "Sloop"       then "Sloop_sink_times"
		when "Brigantine"  then "Brig_sink_times"
		when "Carrack"     then "Car_sink_times"
		when "Galleon"     then "Gal_sink_times"
		when "Frigate"     then "Frig_sink_times"
		when "Man O' War"  then "Man_sink_times"
		else nil
	end
	return unless sink_key
	times = (@commander_data[sink_key] || [])
	times = [] unless times.is_a?(Array)
	times << @commander_data["sinkingtime"].to_f
	times = times.last(50)
	save_to_commander(sink_key, times)
	best_key = sink_key.sub("_sink_times", "_best_sink_time")
	current_best = @commander_data[best_key].to_f
	current_best = 100 if current_best == 0
	new_best = [current_best, times.min].min
	save_to_commander(best_key, new_best)
	avg_key = sink_key.sub("_sink_times", "_avg_sink_time")
	save_to_commander(avg_key, (times.sum / times.size.to_f))
end

def commander_sunk_ship
	# Calculate total encounter duration from helm start to now
	start_time = @commander_data["helmsman_start_time"]
	if start_time.is_a?(Time)
		save_to_commander("sinkingtime", (Time.now - start_time).round(1))
	else
		save_to_commander("sinkingtime", 0)
	end
	@commander_data = osacommander_data
	commander_avg_sink_time
	@commander_data = osacommander_data
	enemy     = @commander_data["enemyship"].to_s.split(/\b/).map(&:capitalize).join
	ship_type = @commander_data["enemy_ship_type"].to_s
	sink_secs = @commander_data["sinkingtime"].to_f
	# Build ship-type-specific keys to match what commander_avg_sink_time writes
	type_key  = case ship_type
		when "Sloop"       then "Sloop"
		when "Brigantine"  then "Brig"
		when "Carrack"     then "Car"
		when "Galleon"     then "Gal"
		when "Frigate"     then "Frig"
		when "Man O' War"  then "Man"
		else nil
	end
	avg_time  = type_key ? @commander_data["#{type_key}_avg_sink_time"]  : nil
	best_time = type_key ? @commander_data["#{type_key}_best_sink_time"] : nil
	msg = "Encounter With #{enemy} | Time To Sink Vessel: #{sink_secs.as_time}"
	msg += " | Average Time To Sink A #{ship_type}: #{avg_time.as_time}" if avg_time
	msg += " | Best Time To Sink A #{ship_type}: #{best_time.as_time}" if best_time
	lnet_crew(msg)
	if @commander_data["stowaways"]
		fput "whisper ooc group #{msg}"
	end
	save_to_commander("cleanup", false)
	save_to_commander("piratehunter", false)
	wait_until { osacrew_data["sunk_ship"] }
	if running? "osacombat"
		stop_script "osacombat"
		wait_until {!running? "osacombat"}
	end
	pause 3
	# If we anchored to use cannons, raise anchor before getting underway again
	if @commander_data["cannon_engage"]
		helm
		raise_anchor
		waitrt?
	end
	lnet_crew("Turn To!")
	if XMLData.injuries.any?{|key,value| value["wound"] > 1}
		start_script("eherbs", ['--buy=off', '--mending=on', '--skipscars=on', '--yaba=on', '--potions=on'])
		wait_until {!running? "eherbs"}
	end
	if XMLData.injuries.any?{|key,value| value["wound"] > 1}
		echo "You still have some wounds, this may inhibate your ability to handle loot!"
	end
	check_for_crate
	captains_quarters
	commander_task_complete
	GameObj.pcs.each{|pc|;fput "hold ##{pc.id}"}
	save_to_commander("cleanup", true)
	save_to_commander("piratehunter", true)
	exit
end

# ------ Solo damage control (used when sailing without a crew) ------------------------------------------------------------

def commander_ship_map
	case Room.current.id
	when (29038..29042)
		save_to_crew("ship_type", "sloop")
		save_to_crew("ship_map", ["main_deck", "cargo_hold", "crows_nest", "helm", "captains_quarters"])
	when (30140..30147)
		save_to_crew("ship_type", "brigantine")
		save_to_crew("ship_map", ["forward_deck", "main_deck", "crows_nest", "cargo_hold", "mess_hall", "crew_quarters", "helm", "captains_quarters"])
	when (30119..30127)
		save_to_crew("ship_type", "carrack")
		save_to_crew("ship_map", ["bow", "forward_deck", "crows_nest", "main_deck", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	when (30176..30186)
		save_to_crew("ship_type", "galleon")
		save_to_crew("ship_map", ["bow", "forward_deck", "crows_nest", "main_deck", "social_room", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	when (30166..30175)
		save_to_crew("ship_type", "frigate")
		save_to_crew("ship_map", ["bow", "forward_deck", "crows_nest", "main_deck", "social_room", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	when (30128..30139)
		save_to_crew("ship_type", "man o' war")
		save_to_crew("ship_map", ["bow", "forward_crows_nest", "forward_deck", "mid_deck", "crows_nest", "main_deck", "social_room", "mess_hall", "cargo_hold", "crew_quarters", "helm", "captains_quarters"])
	end
	@commander_data = osacommander_data
end

def commander_get_wood
	return if GameObj.left_hand.id && GameObj.right_hand.id
	cargo_hold
	result = dothistimeout "get wood", 5, /You will need a free|You search through the salvaged wood and|You search through the salvaged wood only|\.\.\.wait/
	if result.to_s =~ /You will need a free/
		commander_get_wood
	elsif result.to_s =~ /You search through the salvaged wood and/
		waitrt?
		commander_get_wood
	elsif result.to_s =~ /You search through the salvaged wood only/
		waitrt?
		@out_of_wood = true
	elsif result.to_s =~ /\.\.\.wait/
		pause 1
		waitrt?
		commander_get_wood
	end
end

def commander_fix_ship
	return if @fixed == true
	if !GameObj.left_hand.id && !GameObj.right_hand.id
		waitrt?
		commander_get_wood
		return if @out_of_wood
		unless Room.current.tags.include?(@repair_room)
			start_script("go2", [@repair_room])
			wait_while { running?("go2") }
		end
	end
	result = dothistimeout "fix", 5, /\.\.\.wait|all the damage|some of the damage|This area does not look/
	if result.to_s =~ /\.\.\.wait/
		pause 1
		waitrt?
		commander_fix_ship
	elsif result.to_s =~ /all the damage/
		@fixed = true
		waitrt?
		commander_fix_ship
	elsif result.to_s =~ /some of the damage/
		@fixed = false
		waitrt?
		commander_fix_ship
	elsif result.to_s =~ /This area does not look/
		@fixed = true
		waitrt?
		commander_fix_ship
	end
end

def commander_check_rooms
	fput "assess"
	while line = get
		case line
		when /Main Deck:  It appears to be/
			@boatswain = true
		when /Main Deck:  You cannot seem/
			@boatswain = true
			@repair_map.delete("main_deck")
		when /Helm:  You cannot seem/
			@repair_map.delete("helm")
		when /Cargo Hold:  You cannot seem/
			@repair_map.delete("cargo_hold")
		when /Captain\'s Quarters:  You cannot seem/
			@repair_map.delete("captains_quarters")
		when /Forward Crow's Nest:  You cannot seem/
			@repair_map.delete("forward_crows_nest")
		when /Crow's Nest:  You cannot seem/
			@repair_map.delete("crows_nest")
		when /Mess Hall:  You cannot seem/
			@repair_map.delete("mess_hall")
		when /Mid Deck:  You cannot seem/
			@repair_map.delete("mid_deck")
		when /Crew Quarters:  You cannot seem/
			@repair_map.delete("crew_quarters")
		when /Bow:  You cannot seem/
			@repair_map.delete("bow")
		when /Social Room:  You cannot seem/
			@repair_map.delete("social_room")
		when /Forward Deck:  You cannot seem/
			@repair_map.delete("forward_deck")
		when /\[Health of your ship: (.*)\/(.*)\]/
			if $1 == $2
				waitrt?
				@repairs_complete = true
				return
			end
		when /Roundtime:/
			return
		end
	end
end

def commander_begin_repairs
	pause 0.5
	@repairs_complete = false
	@out_of_wood = false
	@repair_map = Array.new
	@commander_data = osacommander_data
	@repair_map = osacrew_data["ship_map"] || []
	commander_check_rooms
	@repair_map.each do |repair_room|
		@fixed = false
		@repair_room = repair_room
		break if @out_of_wood
		break if @repairs_complete
		unless Room.current.tags.include?(@repair_room)
			start_script("go2", [@repair_room])
			wait_while { running?("go2") }
		end
		waitrt?
		result = dothistimeout "assess", 5, /It appears to be|You cannot seem to find any damage/
		if result.to_s =~ /It appears to be/
			waitrt?
			commander_fix_ship
		elsif result.to_s =~ /You cannot seem to find any damage\./
			if get.to_s =~ /\[Health of your ship: (.*)\/(.*)\]/ && $1 == $2
				waitrt?
				@repairs_complete = true
				return
			end
		end
	end
end

def commander_damage_control
	wait_while { running?("osacombat") }
	fput "store both" if !GameObj.left_hand.id.nil? || !GameObj.right_hand.id.nil?
	main_deck
	commander_ship_map
	commander_begin_repairs
	# Return leftover wood to the salvage pile
	if !GameObj.left_hand.id.nil? || !GameObj.right_hand.id.nil?
		cargo_hold
		fput "put left in wood"  if !GameObj.left_hand.id.nil?
		fput "put right in wood" if !GameObj.right_hand.id.nil?
	end
	main_deck
	if @out_of_wood
		echo "The Hull Is Repaired As Much As Possible. However, We Are Out Of Shoring Planks!"
	elsif @repairs_complete
		echo "The Hull Is Repaired!"
	end
	captains_quarters
end

# ------ End solo damage control ---------------------------------------------------------------------------------------------------------------------------------------------------------

def reel_launcher
	# Pull the net-launcher crank until the crate lands on deck or nothing to pull
	loop do
		waitrt?
		result = dothistimeout "pull net-launcher", 5,
			/crate gets closer!|crate comes plopping onto the deck|net-launcher emits a final clicking noise|You do not see a reason to pull the crank/
		if result.to_s =~ /crate gets closer!/
			waitrt?
			next  # keep pulling
		elsif result.to_s =~ /crate comes plopping onto the deck/
			waitrt?
			# Stow whatever landed
			if GameObj.loot.any? { |item| item.name =~ /supply crate/ }
				fput "take supply crate"
				waitrt?
				cargo_hold
				result2 = dothistimeout "put my crate in wood", 3, /You put|You cannot/
				if result2.to_s =~ /You cannot/
					dothistimeout "put my crate in balls", 3, /You put|You cannot/
				end
				pause 0.5
				if GameObj.left_hand.noun.to_s == "crate" || GameObj.right_hand.noun.to_s == "crate"
					fput "drop supply crate"
				end
				main_deck
			end
			if GameObj.loot.any? { |item| item.name =~ /salvage crate/ }
				fput "take salvage crate"
				waitrt?
				fput "stow salvage crate"
				waitrt?
			end
			return  # crate handled, caller decides whether to fire again
		elsif result.to_s =~ /net-launcher emits a final clicking noise|You do not see a reason to pull the crank/
			return  # nothing to pull
		else
			waitrt?
			return  # unexpected result, bail out
		end
	end
end

def fire_launcher
	waitrt?
	result = dothistimeout "fire net-launcher", 5,
		/pretend to fire at an imaginary target|A clean miss!|A direct hit!|You need to PULL on the crank to retract the net first|\.\.\.wait/
	if result.to_s =~ /pretend to fire at an imaginary target/
		return false  # nothing in the water to hit
	elsif result.to_s =~ /A direct hit!/
		waitrt?
		reel_launcher
		return true
	elsif result.to_s =~ /A clean miss!/
		waitrt?
		reel_launcher  # retract before firing again
		return true    # still something out there, caller loops
	elsif result.to_s =~ /You need to PULL on the crank to retract the net first/
		waitrt?
		reel_launcher  # net still out, reel it in
		return true    # still something out there, caller loops
	elsif result.to_s =~ /\.\.\.wait/
		waitrt?
		return true    # in RT, caller loops
	else
		return false
	end
end

def check_for_crate
	waitrt?
	main_deck
	# Keep firing until nothing is left in the water
	loop do
		result = Lich::Util.quiet_command("look ocean", /\[(.*)]/,
			end_pattern = /(Open waters: (.*)| Obvious paths: (.*))/,
			include_end = false, timeout = 3, silent = true)
		break unless result.to_s =~ /crate floating near enough to your ship/
		waitrt?
		# fire_launcher returns false when nothing left to hit
		break unless fire_launcher
	end
end

def commander_begin_it
	if variable[1] =~ /start/
		save_to_commander("straggler_boxes", Array.new)
		helm
		determine_enemy_type
		determine_to_engage
		if @commander_data["engage"]
			if !osacrew_data["enemy_type"] == "undead" && @commander_data["no_bless"]
				$whisper_message = "If you need any weapon blesses, speak now then let me know when you're all set"
				if (@commander_data["crewsize"] || []).count == 0
					get_self_bless
					commander_stowaways
				else
					begin_bless
					commander_stowaways
					pause 1
				end
			end	
			commander_vessel_messaging
			cleanup_on
			if @commander_data["cannon_engage"]
				lnet_crew("Enemy Vessel Detected, #{@commander_data["enemyship"].split(/\b/).map(&:capitalize).join} Inbound. Sound General Quarters! Gunners Man Your Irons!")
			else
				lnet_crew("Enemy Vessel Detected, #{@commander_data["enemyship"].split(/\b/).map(&:capitalize).join} Inbound. Sound General Quarters!")
			end
			@start_time = Time.now
			if !running? "osacombat"
				start_script "osacombat"
				pause 3
				wait_rt
				pause 0.1
			end
			commander_ship_map
			helm
			save_to_commander("helmsman_start_time", Time.now)
			commander_check_role
			enemy_counter
		else
			do_not_board
		end
	elsif (Script.current.vars[1] =~ /profile/i)
	self.profile(Script.current.vars)
	exit
	elsif variable[1] =~ /broadcast/
		commander_broadcast_location
	elsif variable[1] =~ /end/
		commander_end_routine
	elsif variable[1] =~ /silvers/
		commander_give_coins
	elsif variable[1] =~ /version/
	respond ""
	respond "OSACommander Version\: (#{@commander_data["commanderversion"]})"
	respond ""
	exit
	elsif variable[1] =~ /stop/
		lnet_crew("Stop")
		save_to_commander("cleanup", false)
		save_to_commander("piratehunter", false)
		save_to_crew("boarding", false)
		save_to_crew("sunk_ship", false, push: false)
			if running? "osacombat"
				stop_script "osacombat"
				wait_until {!running? "osacombat"}
			end
	elsif variable[1] =~ /spells/
		commander_spell_up
	elsif variable[1] =~ /spellup/
		if variable[2]
			lnet_crew("Crew, Spell Up #{variable[2].capitalize}.")
			if osacrew_data["groupspellup"]
				if !Feat.known?("Kroderine Soul")
					echo "Spelling up, #{variable[2].capitalize}"
					start_script("ewaggle", ['--start-at=181', '--stop-at=240', $pc])
					need_mana
				end
			end
		else
			lnet_crew("Mana Spellup")
			if (Stats.prof != "Warrior") and (Stats.prof != "Rogue")
				fput "mana spellup"
			end
		end
	elsif variable[1] =~ /exit/
		save_to_crew("logging", true, push: false)
		if Room.current.location == "Ships"
			main_deck
			fput "push gangplank"
			move "go gangplank"
		end
		fput "recite #{osacrew_data["commander_ship_name"]}!;Attention To Quarters!"
		pause 1.5
		fput "snap attention"
		pause 1.5
		multifput "salute", "recite Post!"
		pause 3
		fput "exit"
	elsif variable[1] =~ /repairs/
		lnet_crew("Make Repairs!")
	elsif variable[1] =~ /status/
		lnet_crew("Status Report")
		status_check
	elsif variable[1] =~ /resource/
		lnet_crew("Resource Report")
		commander_resource_check
	elsif variable[1] =~ /gemstone/
		lnet_crew("Gemstone Report")
		@weekly_gemstone_count = Array.new
		@weekly_gemstone_count.clear
		@monthly_gemstone_count = Array.new
		@monthly_gemstone_count.clear
		@gemstone_count = Array.new
		@gemstone_count.clear
		(@commander_data["crewsize"] || []).count.times {
		result = matchtimeout 600, /^\[Private\]-GSIV:(.*)\: \"Weekly Gemstone: (.*) \| Monthly Gemstones:  (.*) \| Weekly Searches: (.*)\"$/
		if result.to_s =~ /^\[Private\]-GSIV:(.*)\: \"Weekly Gemstone: (.*) \| Monthly Gemstones:  (.*) \| Weekly Searches: (.*)\"$/
			@weekly_gemstone_count.push($2.to_i)
			@monthly_gemstone_count.push($3.to_i)
			@gemstone_count.push($4.to_i)
		end}
		commander_gemstone_check
		lnet_crew("Total Weekly Searches: #{($killtracker[:weekly_ascension_searches] + (@gemstone_count.sum))} | Total Gemstones Found This Week: #{($killtracker[:weekly_gemstones] + (@weekly_gemstone_count.sum))} | Total Gemstones Found This Month: #{($killtracker[:monthly_gemstones] + (@monthly_gemstone_count.sum))}")
	elsif variable[1] =~ /bread/
		lnet_crew("Let Us Break Bread Together!")
	elsif variable[1] =~ /detection/
		if variable[2] =~ /on/
			ph_on
		end
		if variable[2] =~ /off/
			ph_off
		end
	elsif variable[1] =~ /noscript/
		if variable[2] =~ /on/
			no_script_on
		end
		if variable[2] =~ /off/
			no_script_off
		end
	elsif variable[1] =~ /poaching/
		if variable[2] =~ /on/
			anti_poaching_off
		end
		if variable[2] =~ /off/
			anti_poaching_on
		end
	elsif variable[1] =~ /scripted/
		if variable[2] =~ /on/
			scripted_crew_on
		end
		if variable[2] =~ /off/
			scripted_crew_off
		end
	elsif variable[1] =~ /cleanup/
		if variable[2] =~ /on/
			cleanup_on
		elsif variable[2] =~ /off/
			cleanup_off
		else
			cleanup_begin_routine
		end
	elsif variable[1] =~ /unkick/
		lnet_crew("Crewman #{variable[2].capitalize}, Quarterdeck!")
	elsif variable[1] =~ /kick/
		lnet_crew("Lay Below Crewman #{variable[2].capitalize}!")
	elsif variable[1] =~ /reset/
		do_client ";e stop_script 'osacrew';wait_while { running?('osacrew') };start_script 'osacrew'"
		save_to_crew("logging", true, push: false)
		lnet_crew("Reset")
		pause 2
		save_to_crew("logging", false, push: false)
	elsif variable[1] =~ /task/
		if variable[2].nil?
			lnet_crew("Task Time!")
			return
		end
		if !variable[2].include? "cou"
			respond "
					Please Select A Valid Task Option:
						
						Count:          Will Determine Who Hasn't Rogered Up
						No Option:      Will Call For The Crew To Get A Task
					"
		end
		if variable[2].include? "cou"
			commander_roger_up
			return
		end
	elsif variable[1] =~ /begin/
		commander_start_up
	elsif variable[1] =~ /testcon/
		lnet_crew("Connection Test: #{variable[2].capitalize}")
	elsif variable[1] =~ /summon/ && variable[2] =~ /force/
		fput "group open"
		lnet_crew("Crew, Report To: #{Room.current.id}")
	elsif variable[1] =~ /summon/
		fput "group open"
		crewsize = (@commander_data["crewsize"] || [])
		if crewsize.empty?
			respond ""
			respond " ------ No Crew Roster Found, Calling Muster First ------ "
			respond ""
			lnet_crew("Quarters! All Hands To Quarters For Muster, Instruction and Inspection!")
			commander_take_muster
			crew_count = (@commander_data["crewsize"] || []).count
			crew_count = (@commander_data["crewsize"] || []).count
		lnet_crew("All Present And Accounted For! We Have #{crew_count} Crew Onboard For A Total Compliment of #{crew_count + 1} Personnel!")
			pause 3
			lnet_crew("Crew, Report To: #{Room.current.id}")
		else
			missing = crewsize.reject { |n| (checkpcs || []).include?(n) }
			group_members = Group.members.map(&:noun).map(&:downcase)
			not_in_group = crewsize.select { |n| (checkpcs || []).include?(n) && !group_members.include?(n.downcase) }
			if missing.empty? && not_in_group.empty?
				respond ""
				respond " ------ All Crew Present And In Group, Skipping Summon ------ "
				respond ""
			elsif missing.empty? && !not_in_group.empty?
				respond ""
				respond " ------ All Crew Present But #{not_in_group.count} Not In Group, Summoning ------ "
				respond ""
				lnet_crew("Crew, Report To: #{Room.current.id}")
			else
				respond ""
				respond " ------ #{missing.count} Crew Member(s) Not Present, Summoning ------ "
				respond ""
				lnet_crew("Crew, Report To: #{Room.current.id}")
			end
		end
	elsif variable[1] =~ /bless/
		begin_bless
	elsif variable[1] =~ /unpause/
		lnet_crew("Unpause")
		if running? "osacombat"
			unpause_script "osacombat"
		end
	elsif variable[1] =~ /pause/
		lnet_crew("Pause")
		if running? "osacombat"
			pause_script "osacombat"
		end
	elsif variable[1] =~ /muster/
		if variable[2].nil?
			save_to_commander("crewsize", [])
			lnet_crew("Quarters! All Hands To Quarters For Muster, Instruction and Inspection!")
			commander_take_muster
			crew_count = (@commander_data["crewsize"] || []).count
			crew_count = (@commander_data["crewsize"] || []).count
		lnet_crew("All Present And Accounted For! We Have #{crew_count} Crew Onboard For A Total Compliment of #{crew_count + 1} Personnel!")
			pause 3
			return
		end
		if !variable[2].include? "cou"
			respond "
					Please Select A Valid Muster Option:
						
						Count:          Will Determine Who Present Is Not Of The Ships Company
						No Option:      Will Call A Ships Muster
					"
		end
		if variable[2].include? "cou"
			commander_muster_up
			return
		end
	elsif variable[1] =~ /crew/
		commander_crew_menu
	elsif variable[1] =~ /info/
		if variable[2].downcase.include? "sloo"
			save_to_commander("commander_ship_type", "sloop")
			save_to_commander("commander_max_crew", 2)
		elsif variable[2].downcase.include? "bri"
		save_to_commander("commander_ship_type", "brigantine")
			save_to_commander("commander_max_crew", 4)
		elsif variable[2].downcase.include? "car"
			save_to_commander("commander_ship_type", "carrack")
			save_to_commander("commander_max_crew", 7)
		elsif variable[2].downcase.include? "gal"
			save_to_commander("commander_ship_type", "galleon")
			save_to_commander("commander_max_crew", 11)
		elsif variable[2].downcase.include? "fri"
			save_to_commander("commander_ship_type", "frigate")
			save_to_commander("commander_max_crew", 13)
		elsif variable[2].downcase.include? "man"
			save_to_commander("commander_ship_type", "man o' war")
			save_to_commander("commander_max_crew", 19)
		else
			respond "
						Please Select A Valid Ship Type From Your Fleet: Sloop, Brigantine, Carrack, Galleon, Frigate or Man O' War
						"
				return
		end
		@ship_type = variable[2]
		commander_ship_info
	elsif variable[1] =~ /helmsman/
		save_to_commander("helmsman_start_time", Time.now)
		commander_check_role
		enemy_counter
	elsif variable[1] =~ /setup/i
		self.commandersetup()
		exit
	elsif variable[1] =~ /anti_stow/
		save_to_commander("no_stow", true, push: true)
		if (@commander_data["crewsize"] || []).count != 0
			commander_call_muster
		end
		save_to_crew("boarding", false)
		save_to_crew("sunk_ship", false, push: false)
		if (@commander_data["crewsize"] || []).count != 0
			commander_get_underway
		else
			commander_solo_get_underway
		end
		ph_off
		helm
		wait_rt
		fput "turn wheel port"
		waitfor /The (.*) drifts steadily toward the (.*) port/
		lnet_crew("Moored!")
		waitrt?
		fput "yell Moored!"
		commander_broadcast_location
		captains_quarters
		save_to_commander("no_stow", false)
	elsif variable[1] =~ /repairs/
		begin_repairs
	elsif variable[1] =~ /settings/
		crew_display_settings
	elsif variable[1] =~ /call/
		(eval variable[2]).call
	elsif variable[1] =~ /sell/
		lnet_crew("Crew, Sell Your Loot!")
	elsif variable[1] =~ /setup/
		self.commandersetup()
	elsif variable[1] =~ /return/
		ph_off
		helm
		wait_rt
		fput "turn wheel port"
		waitfor /The (.*) drifts steadily toward the (.*) port/
		lnet_crew("Moored!")
		waitrt?
		fput "yell Moored!"
		commander_broadcast_location
		captains_quarters
	elsif variable[1] =~ /underway/
		if (@commander_data["crewsize"] || []).count != 0
			commander_call_muster
		end
		save_to_crew("boarding", false)
		save_to_crew("sunk_ship", false, push: false)
		if (@commander_data["crewsize"] || []).count != 0
			commander_get_underway
		else
			commander_solo_get_underway
		end
	elsif variable[1] =~ /checkversion/
		lnet_crew("Current Version Are As Follows: Combat #{@commander_data["combatversion"]}, Crew #{osacrew_data["crewversion"]} and Commander #{@commander_data["commanderversion"]}")
	elsif variable[1] =~ /combat/
		if variable[2].nil?
			lnet_crew("Steel Yourselves Crew!")
			start_script "osacombat"
		else
			lnet_crew("Steel Yourself, #{variable[2].capitalize}!")
		end
	elsif variable[1] =~ /loot/
		if variable[2].nil?
			save_to_combat("osalooter", true)
		else
			lnet_crew("Loot the Dead, #{variable[2].capitalize}!")
		end
	else
		commander_help_display
	end
end

# One helper to BUILD them all!
def self.ui(parent, type, **o)
	@OSA_COMMANDER_ENTRY ||= {}
	@commander_data ||= {}
	@_ui_sizegroups ||= Hash.new { |h, k| h[k] = {} }  # { group_sym => { col_int => Gtk::SizeGroup } }
	get_key = ->(v) { v.nil? ? nil : v.to_s }
	get_val = ->(key) { key && @commander_data.key?(key) ? @commander_data[key] : nil }
	set_widget_width = lambda do |widget, width|
		return widget unless widget && width
		widget.set_size_request(width, -1)
		widget
	end
	case type
	when :row
		row = Gtk::Box.new(:horizontal, o.fetch(:spacing, 12))
		row.set_halign(o[:halign]) if o[:halign]
		row.set_hexpand(o.fetch(:hexpand, true))
		parent.pack_start(row, false, false, o.fetch(:pad, 0)) if parent
		return row
	when :vrow
		col = Gtk::Box.new(:vertical, o.fetch(:spacing, 8))
		col.set_border_width(o[:border] || 0)
		parent.pack_start(col, false, false, o.fetch(:pad, 0)) if parent
		return col
	when :header
		outer = Gtk::Box.new(:vertical, o.fetch(:spacing, 4))
		label = Gtk::Label.new
		label.set_xalign(0.0)
		label.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		label.use_markup = true
		text = o.fetch(:text).to_s
		safe =
			if GLib.respond_to?(:markup_escape_text)
				GLib.markup_escape_text(text)
			else
				text.gsub("&", "&amp;").gsub("<", "&lt;").gsub(">", "&gt;")
			end
		label.label = "<b>#{safe}</b>"
		sep = Gtk::Separator.new(:horizontal)
		outer.pack_start(label, false, false, 0)
		outer.pack_start(sep, false, false, 0)
		parent.pack_start(outer, false, false, o.fetch(:pad, 6)) if parent
		return outer
	when :blank
		spacer = Gtk::Box.new(:vertical, 0)
		spacer.set_size_request(-1, o.fetch(:height, 8))
		parent.pack_start(spacer, false, false, 0) if parent
		return spacer
	when :sep
		s = Gtk::Box.new(:horizontal, 0)
		s.set_size_request(o.fetch(:width, 10), -1)
		parent.pack_start(s, false, false, 0) if parent
		return s
	when :label
		lab = Gtk::Label.new(o.fetch(:text, ""))
		lab.set_xalign(o.fetch(:xalign, 0.0))
		lab.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		set_widget_width.call(lab, o[:width])
		parent.pack_start(lab, false, false, o.fetch(:pad, 0)) if parent
		return lab
	when :entry
		key = get_key.call(o[:var])
		box = Gtk::Box.new(:horizontal, o.fetch(:spacing, 6))
		lab = Gtk::Label.new(o.fetch(:label))
		lab.set_xalign(0.0)
		lab.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		set_widget_width.call(lab, o[:label_width]) if o[:label_width]
		ent = Gtk::Entry.new
		if o[:width_chars]
			ent.width_chars = o[:width_chars]
			ent.max_width_chars = o[:max_width_chars] || o[:width_chars]
		else
			set_widget_width.call(ent, o[:entry_width] || o[:width])
		end
		ent.hexpand = false
		ent.halign = :start
		raw = get_val.call(key)
		ent.text = (raw.nil? || raw.to_s.empty?) ? o.fetch(:default, "").to_s : raw.to_s
		@OSA_COMMANDER_ENTRY[key] = ent if key
		box.pack_start(lab, false, false, 0)
		box.pack_start(ent, false, false, 0)
		set_widget_width.call(box, o[:box_width] || o[:width]) if (o[:box_width] || o[:width])
		parent.pack_start(box, false, false, o.fetch(:pad, 0)) if parent
		return box
	when :check
		key = get_key.call(o[:var])
		cb = Gtk::CheckButton.new(o.fetch(:label))
		cb.tooltip_text = o[:tip] if o[:tip] && !o[:tip].to_s.empty?
		raw = get_val.call(key)
		cb.active = raw.nil? ? !!o.fetch(:default, false) : !!raw
		@OSA_COMMANDER_ENTRY[key] = cb if key
		cb.set_halign(:start)
		cb.set_hexpand(false)
		widget = cb
		if o[:cell_width]
			wrapper = Gtk::Box.new(:horizontal, 0)
			wrapper.set_size_request(o[:cell_width], -1)
			wrapper.set_halign(:start)
			wrapper.pack_start(cb, false, false, 0)
			widget = wrapper
		end
		if o[:group] && o[:col]
			g = o[:group].to_sym
			c = o[:col].to_i
			@_ui_sizegroups[g][c] ||= Gtk::SizeGroup.new(:horizontal)
			@_ui_sizegroups[g][c].add_widget(widget)
		end
		parent.pack_start(widget, false, false, o.fetch(:pad, 0)) if parent
		return widget
	when :check_box
		key = get_key.call(o[:var])
		cb = Gtk::CheckButton.new
		cb.tooltip_text = o[:tip] if o[:tip] && !o[:tip].to_s.empty?
		raw = get_val.call(key)
		cb.active = raw.nil? ? !!o.fetch(:default, false) : !!raw
		@OSA_COMMANDER_ENTRY[key] = cb if key
		cb.set_halign(:start)
		cb.set_hexpand(false)
		parent.pack_start(cb, false, false, o.fetch(:pad, 0)) if parent
		return cb
	when :spell
		r = ui(parent, :row, spacing: o.fetch(:spacing, 10))
		ui(r, :entry,
			label: o[:spell_label],
			tip: o[:spell_tip],
			var: o[:spell_var],
			width_chars: 4,
			entry_width: o.fetch(:spell_width, 50))
		ui(r, :entry,
			label: "Min Stam:",
			var: o[:stam_min_var],
			width_chars: 4,
			default: "0",
			entry_width: o.fetch(:stam_width, 50))
		ui(r, :entry,
			label: "Min Mana:",
			var: o[:mana_min_var],
			width_chars: 4,
			default: "0",
			entry_width: o.fetch(:mana_width, 50))
		ui(r, :entry,
			label: "Min Enemy:",
			var: o[:enemy_min_var],
			width_chars: 4,
			default: "0",
			entry_width: o.fetch(:enemy_min_width, 50))
		ui(r, :entry,
			label: "Max Enemy:",
			var: o[:enemy_max_var],
			width_chars: 4,
			default: "10",
			entry_width: o.fetch(:enemy_max_width, 50))
		ui(r, :check, label: "Warding", var: o[:ward_var])
		ui(r, :check, label: "Channel", var: o[:chan_var])
		ui(r, :check, label: "Evoke", var: o[:evoke_var])
		ui(r, :check, label: "Open", var: o[:open_var])
	when :attack
		r = ui(parent, :row, spacing: o.fetch(:spacing, 10))
		ui(r, :dropdown,
			label: o.fetch(:attack_label, "Attack:"),
			tip: o.fetch(:attack_tip, ""),
			var: o.fetch(:attack_var),
			options: o.fetch(:options),
			default_index: o.fetch(:default_index, 0),
			combo_width: o.fetch(:attack_width, 520))
		ui(r, :entry,
			label: o.fetch(:stam_label, "Min Stam:"),
			tip: o.fetch(:stam_tip, ""),
			var: o.fetch(:stam_min_var),
			default: o.fetch(:stam_default, "0"),
			width_chars: o.fetch(:stam_chars, 4),
			entry_width: o.fetch(:stam_width, 50))
		ui(r, :entry,
			label: o.fetch(:mana_label, "Min Mana:"),
			tip: o.fetch(:mana_tip, ""),
			var: o.fetch(:mana_min_var),
			default: o.fetch(:mana_default, "0"),
			width_chars: o.fetch(:mana_chars, 4),
			entry_width: o.fetch(:mana_width, 50))
		ui(r, :entry,
			label: o.fetch(:enemy_min_label, "Min Enemy:"),
			tip: o.fetch(:enemy_min_tip, ""),
			var: o.fetch(:enemy_min_var),
			default: o.fetch(:enemy_min_default, "0"),
			width_chars: o.fetch(:enemy_min_chars, 4),
			entry_width: o.fetch(:enemy_min_width, 50))
		ui(r, :entry,
			label: o.fetch(:enemy_max_label, "Max Enemy:"),
			tip: o.fetch(:enemy_max_tip, ""),
			var: o.fetch(:enemy_max_var),
			default: o.fetch(:enemy_max_default, "10"),
			width_chars: o.fetch(:enemy_max_chars, 4),
			entry_width: o.fetch(:enemy_max_width, 50))
			return r
	when :ability
		r = ui(parent, :row, spacing: o.fetch(:spacing, 10))
		label_w = o.fetch(:label_width, 175) # adjust once to taste
		ui(r, :label, text: o.fetch(:label), tip: o[:tip].to_s, width: label_w, xalign: 0.0)
		ui(r, :check_box,
			var: o.fetch(:var),
			tip: o[:tip].to_s,
			default: o.fetch(:default, false))
		ui(r, :sep, width: o.fetch(:sep_width, 12))
			fields = o.fetch(:fields, [])
			fields.each do |f|
				ui(r, :entry,
				label: f.fetch(:label),
				tip:   f[:tip].to_s,
				var:   f.fetch(:var),
				default: f.fetch(:default, ""),
				width_chars: f[:chars] || o[:chars] || 4,
				max_width_chars: f[:max_chars] || f[:chars] || o[:chars] || 4,
				entry_width: f[:entry_width] || o[:entry_width] || 90,
				label_width: f[:label_width] || o[:label_width])
			end
		return r
  when :dropdown
		key = get_key.call(o[:var])
		opts =
			case o[:options]
			when String then o[:options].split(/\s*,\s*/)
			when Array  then o[:options]
		else
			raise ArgumentError, "dropdown options must be String or Array"
		end
		box = Gtk::Box.new(:horizontal, o.fetch(:spacing, 6))
		lab = Gtk::Label.new(o.fetch(:label))
		lab.set_xalign(0.0)
		lab.set_tooltip_text(o[:tip]) if o[:tip] && !o[:tip].to_s.empty?
		set_widget_width.call(lab, o[:label_width]) if o[:label_width]
		combo = Gtk::ComboBoxText.new
		opts.each { |x| combo.append_text(x.to_s) }
			raw = get_val.call(key)
			idx = if raw.nil? || raw.to_s.strip.empty?
            o.fetch(:default_index, 0).to_i
		else
            raw.to_i
		end
		idx = 0 if idx < 0
		idx = opts.length - 1 if idx >= opts.length
		combo.set_active(idx)
		set_widget_width.call(combo, o[:combo_width] || o[:width])
		@OSA_COMMANDER_ENTRY[key] = combo if key
		if o[:group] && o[:col]
			g = o[:group].to_s
			c = o[:col].to_i
			@_ui_sizegroups[g][c] ||= Gtk::SizeGroup.new(:horizontal)
			@_ui_sizegroups[g][c].add_widget(combo)
		end
		box.pack_start(lab, false, false, 0)
		box.pack_start(combo, false, false, 0)
		parent.pack_start(box, false, false, o.fetch(:pad, 0)) if parent
			return box
		else
			raise ArgumentError, "unknown ui type: #{type.inspect}"
		end
end

# ===== population =====
def self.populate_general(rows)
	add_checks = lambda do |defs, cols: 4, group: :general_checks, spacing: 18|
	defs.each_slice(cols).with_index do |slice, _row_i|
			r = ui(rows, :row, spacing: spacing)
			slice.each_with_index do |d, col|
				ui(r, :check,
				label: d[:label],
				tip: d[:tip].to_s,
				var: d[:var],
				default: d.fetch(:default, false),
				group: group,
				col: col)
			end
		end
	end
	
	ui(rows, :header, text: "Enemy Types To Engage:", tip: "These are the sub-types of pirates that can be encountered. The script will engage only the sub-types you select. Those left unselected will be avoided by turning the ship back into port and then getting underway again.")
	add_checks.call([
    { label: "Pirates",  tip: "These are your base pirate sub-type. Pirates can have any race prefix and are re-skinned clones of bandits. They tend to have moderate treasure.", var: 'enemy_pirate',  default: false },
    { label: "Krolvin",  tip: 'These pirates will only show with the "Krolvin" prefix. They are re-skinned clones of grimswarm enemies and they tend to have large amounts of treasure and boxes.', var: 'enemy_krolvin', default: false },
    { label: "Ethereal", tip: 'These pirates will only show with the "Ethereal" prefix. They are non-coporeal undead and are re-skinned clones of Reim citizens. They tend to have little to no treasure.', var: 'enemy_undead', default: false }], cols: 3, group: :enemy_types)
	ui(rows, :blank, height: 8)
	ui(rows, :header, text: "Ship Types To Board:", tip: "Ship encounters will always reflect the size of your vessel. An encounter ship size can be your size category +1 or lower. In a storm this can be your size category +2.")
	add_checks.call([
    { label: "Sloop",      tip: "This is a 5 room vessel with an enemy range of 15-20 enemies.", var: 'board_sloop', default: false },
    { label: "Brigantine", tip: "This is a 6 room vessel with an enemy range of 30-40 enemies.", var: 'board_brigantine', default: false },
    { label: "Carrack",    tip: "This is a 7 room vessel with an enemy range of 35-45 enemies.", var: 'board_carrack', default: false },
    { label: "Galleon",    tip: "This is a 7 room vessel with an enemy range of 50-60 enemies.", var: 'board_galleon', default: false },
    { label: "Frigate",    tip: "This is a 6 room vessel with an enemy range of 60-80 enemies.", var: 'board_frigate', default: false },
    { label: "Man O' War", tip: "This is a 9 room vessel with an enemy range of 90-120 enemies.", var: 'board_man', default: false }], cols: 3)
	ui(rows, :blank, height: 8)
	ui(rows, :header, text: "Ship Types To Cannon:")
	add_checks.call([
    { label: "Sloop", tip: "", var: 'fire_sloop', default: false },
    { label: "Brigantine", tip: "", var: 'fire_brigantine', default: false },
    { label: "Carrack",    tip: "", var: 'fire_carrack', default: false },

    { label: "Galleon", tip: "", var: 'fire_galleon', default: false },
    { label: "Frigate", tip: "", var: 'fire_frigate', default: false },
    { label: "Man O' War", tip: "", var: 'fire_man', default: false }], cols: 3)
	ui(rows, :blank, height: 10)
	ui(rows, :header, text: "General Settings")
	ui(rows, :entry, label: "Security Officer:", tip: "This is a crew member who you are designating to be the ships locksmith.", var: 'securityofficer', default: "", width_chars: 24 )
	ui(rows, :entry, label: "Security Officer Room Number:", tip: "This is the designated room the Security Officer will reside in during lock picking. Please enter the room number numerically.", var: 'security_officer_location', default: "", width_chars: 11 )
	ui(rows, :entry, label: "Spellup Time Threshold", tip: "The script will determine the average time remaining on your spells and if less than the designated threshold, it will call for a spellup automatically at the end of an encounter.", var: 'time_left_setting', default: "65", width_chars: 18 )
	ui(rows, :entry, label: "Fossil Charm Adjective:", tip: "Please enter the adjective of your fossil charm if available.", var: 'charm_adjective', default: "", width_chars: 18 )
	ui(rows, :blank, height: 6)
	add_checks.call([
    { label: "Four Winds Access", tip: "Check this box if you are a premium account. Any premium transport will be handled via the script Go2 and it's settings.", var: 'fwi', default: false },
    { label: "Use Net-Launcher",  tip: "Checking this enables the script to utilize the net-launcher on your ship for added supply and salvage crates.", var: 'netlauncher', default: false },
    { label: "Use Mana Bread",    tip: "Checking this enables the Medical Officer to hand mana bread to the crew prior to performing a crew spellup session.", var: 'use_bread', default: false },
    { label: "Skip Blessing Routine",         tip: "Checking this will skip blessing routines before an undead vessel encounter.", var: 'no_bless', default: false },
    { label: "Use Security Officer For Boxes", tip: "Checking this will enable the use of your Security Officer for picking boxes.", var: 'use_security_officer', default: false },
    { label: "Use Non-Scripting Picker",       tip: "Checking this will use a non-scripted lock picker. You will simply drop your boxes into the Captain's quarters for them to pick.", var: 'no_script_picking', default: false },
    { label: "Use Fossil Charm",              tip: "Checking this will enable the use of a fossil charm for gathering coins from opened boxes.", var: 'fossil_charm', default: false },
    { label: "Keep Ship From Being Stowed",   tip: "Checking this will prevent the ship from being stowed automatically when your time limit is expired on the pier. This is a triggered response and could be construed as AFK scripting. Please use with caution.", var: 'anti_stow', default: false },
    { label: "Share Silvers With Crew",       tip: "Checking this will enable the script to calculate your earned silvers and share that amount with your crew at the end of an encounter", var: 'share_silvers', default: false },
    { label: "Accept outside crew",           tip: "Checking this will enable the script to enroll the help of other players who are using OSACrew.", var: 'othersailors', default: false },
    { label: "Accept non-scripted crew",      tip: "Checking this will enable the script to enroll the help of other players who are not using OSACrew by allowing pauses with manual confirmation before continuing.", var: 'stowaways', default: false }], cols: 3)
end

def self.commandersetup
	if @OSA_COMMANDER_WINDOW
		begin
		@OSA_COMMANDER_WINDOW.present
		return
		rescue
		@OSA_COMMANDER_WINDOW = nil
		end
	end
	GLib::Idle.add do
		begin
			build_commandersetup_window
			rescue => e
			respond "--- OsaCrew GUI error: #{e.class}: #{e.message}"
			respond e.backtrace.join("\n")
		end
		false
	end
	nil
end

def self.save_settings!
	file_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacommander.yaml")
	commander_file_keys = %w[
		enemy_pirate enemy_krolvin enemy_undead
		board_sloop board_brigantine board_carrack board_galleon board_frigate board_man
		fire_sloop fire_brigantine fire_carrack fire_galleon fire_frigate fire_man
		securityofficer security_officer_location time_left_setting charm_adjective
		fwi netlauncher use_bread no_bless use_security_officer no_script_picking
		fossil_charm anti_stow share_silvers othersailors stowaways
	]
	FileUtils.mkdir_p(File.dirname(file_path))
	File.open(file_path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read.to_s
		data = begin
			raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
			rescue StandardError; {}
			end
		data = data.transform_keys(&:to_s)
		commander_file_keys.each do |k|
			data[k] = @commander_data[k] if @commander_data.key?(k)
			@commander_data[k] = data[k]
		end
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
	end
	respond "--- OSACommander: Settings saved to #{file_path}"
end

def self.build_commandersetup_window
	self.load_commander_yaml
	@OSA_COMMANDER_WINDOW = Gtk::Window.new
	@OSA_COMMANDER_WINDOW.set_default_size(1155, 900)
	@OSA_COMMANDER_WINDOW.title = TITLE
	@OSA_COMMANDER_WINDOW.set_border_width(10)
	@OSA_COMMANDER_WINDOW.keep_above = true
	@OSA_COMMANDER_WINDOW.signal_connect("destroy") do
		@OSA_COMMANDER_WINDOW = nil
	end
	main_box = Gtk::Box.new(:vertical, 0)
	main_box.set_border_width(5)
	@OSA_COMMANDER_WINDOW.add(main_box)
	notebook = Gtk::Notebook.new
	notebook.set_show_border(true)
	notebook.set_scrollable(true)
	main_box.pack_start(notebook, true, true, 0)
	@OSA_COMMANDER_ENTRY = {}
	tab_names = ["General"]
	tab_names.each.with_index(1) do |name, idx|
		page_box = Gtk::Box.new(:vertical, 0)
		scroller = Gtk::ScrolledWindow.new
		scroller.set_policy(Gtk::POLICY_NEVER, Gtk::POLICY_AUTOMATIC)
		scroller.hexpand = true
		scroller.vexpand = true
		rows = Gtk::Box.new(:vertical, 8)
		rows.set_border_width(6)
		scroller.add(rows)
		page_box.pack_start(scroller, true, true, 0)
		notebook.append_page(page_box, Gtk::Label.new(name))
		instance_variable_set("@OSA_COMMANDER_ROWS#{idx}", rows)
	end
	populate_general(@OSA_COMMANDER_ROWS1)
	button_row = Gtk::Box.new(:horizontal, 12)
	button_row.set_halign(:end)
	save_btn  = Gtk::Button.new(label: "Save")
	close_btn = Gtk::Button.new(label: "Close")
	save_btn.signal_connect("clicked") do
		@OSA_COMMANDER_ENTRY.each do |var_name, widget|
			if widget.is_a?(Gtk::CheckButton)
				@commander_data[var_name] = widget.active?
			elsif widget.is_a?(Gtk::Entry)
				@commander_data[var_name] = widget.text
			elsif widget.is_a?(Gtk::ComboBoxText)
				@commander_data[var_name] = widget.active 
			end
		end
		self.save_settings!
	end
	close_btn.signal_connect("clicked") do 
		Gtk.queue do
			@OSA_COMMANDER_WINDOW.hide
			@OSA_COMMANDER_WINDOW.destroy
		end
	end
	button_row.pack_start(save_btn, false, false, 0)
	button_row.pack_start(close_btn, false, false, 0)
	main_box.pack_start(button_row, false, false, 6)
	@OSA_COMMANDER_WINDOW.show_all
end

def self.delete_script_data(key, value)
	data = self.osacommander_data
	k = key.to_s
	target = data[k]
	if target.is_a?(Array)
		target.delete(value)
		self.save_to_commander(k, target)
	elsif target == value
		data.delete(k)
		self.save_to_commander(k, nil)
	end
end

def self.save_to_commander(key, value, push: false)
	full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacommander.yaml")
	FileUtils.mkdir_p(File.dirname(full_path))
	File.open(full_path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read.to_s
		data = begin
			raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
			rescue StandardError; {}
			end
		data = data.transform_keys(&:to_s)
		k = key.to_s
		if push
			data[k] = [] unless data[k].is_a?(Array)
			data[k] << value
		else
			data[k] = value
		end
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
		@commander_data = data
	end
end

def self.save_to_crew(key, value, push: false)
	full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacrew.yaml")
	FileUtils.mkdir_p(File.dirname(full_path))
	File.open(full_path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read.to_s
		data = begin
			raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
			rescue StandardError; {}
			end
		data = data.transform_keys(&:to_s)
		k = key.to_s
		if push
			data[k] = [] unless data[k].is_a?(Array)
			data[k] << value
		else
			data[k] = value
		end
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
	end
end

def self.save_to_combat(key, value, push: false)
	full_path = File.join(DATA_DIR, XMLData.game, Char.name, "osacombat.yaml")
	FileUtils.mkdir_p(File.dirname(full_path))
	File.open(full_path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read.to_s
		data = begin
			raw.strip.empty? ? {} : (YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {})
			rescue StandardError; {}
			end
		data = data.transform_keys(&:to_s)
		k = key.to_s
		if push
			data[k] = [] unless data[k].is_a?(Array)
			data[k] << value
		else
			data[k] = value
		end
		file.rewind
		YAML.dump(data, file)
		file.flush
		file.truncate(file.pos)
	end
end

def self.osacommander_data
	path = File.join(DATA_DIR, XMLData.game, Char.name, "osacommander.yaml")
	return {} unless File.exist?(path)
	raw = File.read(path)
	return {} if raw.strip.empty?
	(YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}).transform_keys(&:to_s)
rescue StandardError
	{}
end

def self.osacrew_data
	path = File.join(DATA_DIR, XMLData.game, Char.name, "osacrew.yaml")
	return {} unless File.exist?(path)
	raw = File.read(path)
	return {} if raw.strip.empty?
	(YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}).transform_keys(&:to_s)
rescue StandardError
	{}
end

def self.osacombat_data
	path = File.join(DATA_DIR, XMLData.game, Char.name, "osacombat.yaml")
	return {} unless File.exist?(path)
	raw = File.read(path)
	return {} if raw.strip.empty?
	(YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}).transform_keys(&:to_s)
rescue StandardError
	{}
end

def self.load_commander_yaml
	Settings.load
	dir = File.join(DATA_DIR, XMLData.game, Char.name)
	FileUtils.mkdir_p(dir) unless Dir.exist?(dir)
	path = File.join(dir, "osacommander.yaml")
	data = {}
	File.open(path, File::RDWR | File::CREAT, 0o644) do |file|
		file.flock(File::LOCK_EX)
		raw = file.read
		if raw && !raw.strip.empty?
			data = YAML.safe_load(raw, permitted_classes: [Time, Symbol], aliases: true) || {}
		else
			data = {}
			file.rewind
			file.write(YAML.dump(data))
			file.flush
			file.truncate(file.pos)
		end
	end
	data = data.transform_keys(&:to_s)
	@commander_data = data
	Settings[Char.name]["osa_vars_yaml_file"] = path
	Settings.save
	path
end

save_to_commander("commanderversion", "4.0.22 (May 22, 2026)", push: false)
TITLE = "OSACommander: v. (#{@commander_data["commanderversion"]})"
require "yaml"
require "gtk3"
require "fileutils"
toggle_upstream
self.load_commander_yaml

check_dependencies("OSACommander", [
	{ name: "eloot",           author: "elanthia-online" },
	{ name: "ewaggle",         author: "elanthia-online" },
	{ name: "ecure",           author: "elanthia-online" },
	{ name: "lnet",            author: "elanthia-online" },
	{ name: "osasail_watch",   author: "peggyanne"       },
	{ name: "osacannon_watch", author: "peggyanne"       },
	{ name: "osa_migrate",     author: "peggyanne"       },
])

if osacrew_data["crew"].empty?
	respond "*********** Your Crew Channel Is Not Set, Please Set Your Crew Channel Before Proceeding (If You Do Not Have One Set, Use Your Character\'s First Name) ************"
	exit
end
if osacrew_data["commander"].empty?
	respond "*********** Your Commander Is Not Set, Please Set Your Crew Channel Before Proceeding (If You Do Not Have One, Use Your Character\'s First Name) ************"
	exit
end
@mana_watcher = nil
before_dying {
	@mana_watcher.kill if @mana_watcher&.alive?
	@warning = false
}
@anchor_aweigh = false
@commander_lowered_sail = false
@warning = false
@done_with_sec_off = false
save_to_commander("cleanup_type", nil)
mana_share
commander_begin_it