  def self.yn(val)
    val ? 'Y' : 'N'
  end

  def self.display_table
    rows = WANDS.map do |w|
      [
        w[:name],
        w[:spell],
        w[:spell_num].to_s,
        yn(w[:crumbly]),
        yn(w[:treasure]),
        yn(w[:alchemy])
      ]
    end

    respond ''
    respond ''

    table = Terminal::Table.new do |t|
      t.headings = ['Wand', 'Spell', 'Spl#', 'C', 'T', 'A']
      rows.each { |row| t.add_row row }
      t.style = { border: :ascii, width: 88, padding_left: 0, padding_right: 0, all_separators: true }
    end

    _respond "<output class=\"mono\"/><pushBold/>                                   Wand Info<popBold/><output class=\"\"/>"
    respond table.to_s
    _respond "<preset id='whisper'>C=Crumbly  T=Found as Treasure  A=Alchemy-craftable</preset>"
    _respond "<preset id='whisper'>Type ;wands <name> for detail on a specific wand. Ex: ;wands twisted</preset>"
    respond ''
  end

  def self.display_detail(wand)
    respond ''
    _respond "<output class=\"mono\"/><pushBold/>#{wand[:name].upcase}<popBold/><output class=\"\"/>"
    respond "Spell:    #{wand[:spell]} (#{wand[:spell_num]})"
    respond "Circle:   #{wand[:circle]}"
    respond "Crumbly:  #{yn(wand[:crumbly])}"
    respond "Treasure: #{yn(wand[:treasure])}"
    respond "Alchemy:  #{yn(wand[:alchemy])}"
    respond ''
    respond "Notes:"
    respond wand[:notes]
    respond ''
  end

  def self.find(search_term)
    WANDS.find { |w| w[:name] =~ /#{Regexp.escape(search_term)}/i }
  end

end

# --- Entry point ---

if script.vars.empty?
  WandInfo.display_table
elsif script.vars[1] =~ /\Ahelp\z/i
  _respond "<output class=\"mono\"/><pushBold/>Usage: ;wands  OR  ;wands <partial wand name><popBold/><output class=\"\"/>"
  respond 'Example: ;wands twisted'
  respond 'Example: ;wands bone'
else
  search = script.vars[1..-1].join(' ')
  wand   = WandInfo.find(search)
  if wand
    WandInfo.display_detail(wand)
  else
    _respond "<output class=\"mono\"/><pushBold/>No wand matched \"#{search}\". Try ;wands for the full list.<popBold/><output class=\"\"/>"
  end
end
