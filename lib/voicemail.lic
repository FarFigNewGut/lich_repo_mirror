VERSION = '2.0.0 (June 19, 2026)'
=begin
	Voicemail Version: 2.0.0 (June 19, 2026)

	Usage:

	;voicemail                            Starts the background listener
	voicemail help                        Brings up this message
	voicemail check                       Checks your saved messages
	voicemail delete <message #>          Deletes a saved message
	voicemail delete all                  Deletes all saved messages

	Messages are saved to:
	  <lich data dir>/<game>/<char>/voicemail.yaml

	Captures ThoughtNet (Focused) and LNet (Private) messages.
	OSA crew automation messages are silently ignored.
	Enjoy

	Originally by Peggyanne. Modernized for Lich 5.18 / Ruby 4.0.
=end

require 'yaml'

# ---------------------------------------------------------------------------
# YAML persistence
# ---------------------------------------------------------------------------

VOICEMAIL_YAML = File.join(DATA_DIR, XMLData.game, Char.name, 'voicemail.yaml')

def load_messages
	unless File.exist?(VOICEMAIL_YAML)
		Dir.mkdir(File.dirname(VOICEMAIL_YAML)) unless Dir.exist?(File.dirname(VOICEMAIL_YAML))
		save_messages([])
	end
	raw = YAML.safe_load(File.read(VOICEMAIL_YAML), permitted_classes: [Symbol])
	raw.is_a?(Array) ? raw : []
rescue => e
	respond "Voicemail: error loading YAML -- #{e.message}"
	[]
end

def save_messages(msgs)
	File.write(VOICEMAIL_YAML, YAML.dump(msgs))
rescue => e
	respond "Voicemail: error saving YAML -- #{e.message}"
end

def append_message(entry)
	msgs = load_messages
	return if msgs.include?(entry)
	msgs << entry
	save_messages(msgs)
end

# ---------------------------------------------------------------------------
# UI helpers
# ---------------------------------------------------------------------------

def help_display
	respond ''
	respond "Voicemail #{VERSION}"
	respond ''
	respond '   ;voicemail                            Starts the background listener'
	respond '   voicemail help                        Brings up this message'
	respond '   voicemail check                       Checks your saved messages'
	respond '   voicemail delete <message #>          Deletes a saved message'
	respond '   voicemail delete all                  Deletes all saved messages'
	respond ''
	respond "   Messages saved to: #{VOICEMAIL_YAML}"
	respond ''
end

def check_messages
	msgs = load_messages
	respond ''
	if msgs.empty?
		respond 'You have no saved messages.'
	else
		respond "You have #{msgs.length} saved message(s):"
		respond ''
		msgs.each_with_index do |msg, idx|
			respond "  #{idx + 1}. #{msg}"
		end
	end
	respond ''
end

def delete_message(num_str)
	idx = num_str.to_i - 1
	msgs = load_messages
	if idx < 0 || idx >= msgs.length
		respond ''
		respond "Voicemail: no message ##{num_str} to delete."
		respond ''
		return
	end
	respond ''
	respond "Deleting message ##{num_str}..."
	msgs.delete_at(idx)
	save_messages(msgs)
	respond "Message ##{num_str} deleted!"
	respond ''
	check_messages
end

def delete_all_messages
	respond ''
	respond 'Deleting all saved messages...'
	save_messages([])
	respond 'All messages deleted!'
	respond ''
	check_messages
end

# ---------------------------------------------------------------------------
# OSA noise filter -- messages we never want to record
# ---------------------------------------------------------------------------
OSA_NOISE = [
	/Health: .* \| Mana: .* \| Stamina: .* \| Spirit:/,
	/Weekly .*:/,
	/Ready For Combat Captain!/,
	/Task Complete/,
	/Reporting For Duty Captain!/,
].freeze

def osa_noise?(text)
	OSA_NOISE.any? { |pat| pat.match?(text) }
end

# ---------------------------------------------------------------------------
# Handle launch-time arguments
# ---------------------------------------------------------------------------
case variable[1].to_s.downcase
when 'help', '?'
	help_display
	exit
end

# ---------------------------------------------------------------------------
# If a listener instance is already running, don't start a second one.
# Script.list includes the current instance, so check for count > 1.
# ---------------------------------------------------------------------------
if Script.list.count { |s| s.name == 'voicemail' } > 1
	respond "Voicemail: listener is already running."
	exit
end

# ---------------------------------------------------------------------------
# UpstreamHook -- intercepts ;voicemail commands before they reach the game
# server. Returns nil to swallow the command, or xml to pass it through.
# ---------------------------------------------------------------------------
VOICEMAIL_HOOK = 'voicemail_command_hook'
UpstreamHook.remove(VOICEMAIL_HOOK)

$voicemail_hook = proc do |xml|
	next xml unless xml.start_with?('<c>')
	cmd = xml.sub(/\A<c>/i, '').sub(/<\/c>\z/i, '').strip
	case cmd
	when /^voicemail\s+check$/i
		check_messages
		nil
	when /^voicemail\s+help$/i
		help_display
		nil
	when /^voicemail\s+delete\s+all$/i
		delete_all_messages
		nil
	when /^voicemail\s+delete\s+(\d+)$/i
		delete_message($1)
		nil
	else
		xml
	end
end

UpstreamHook.add(VOICEMAIL_HOOK, $voicemail_hook)

# ---------------------------------------------------------------------------
# Cleanup on stop -- remove the hook so no orphaned intercepts remain.
# ---------------------------------------------------------------------------
before_dying do
	UpstreamHook.remove(VOICEMAIL_HOOK)
end

# ---------------------------------------------------------------------------
# Ensure YAML exists before entering the main loop
# ---------------------------------------------------------------------------
load_messages

respond ''
respond "Voicemail #{VERSION} running. Messages will be saved to:"
respond "  #{VOICEMAIL_YAML}"
respond ''

# ---------------------------------------------------------------------------
# Main game-line listener
# ---------------------------------------------------------------------------
while (line = get)
	case line
	when /^\[Focused\] (\S+) \S+, "(.+)"/
		person  = $1
		message = $2
		ts      = Time.now.strftime('%Y-%m-%d %H:%M:%S')
		append_message("#{ts}: #{person} thought, \"#{message}\"")
	when /^\[Private\]-GSIV:([^:]+): "(.+)"/
		person  = $1.strip
		message = $2
		next if osa_noise?(message)
		ts = Time.now.strftime('%Y-%m-%d %H:%M:%S')
		append_message("#{ts}: #{person} chat, \"#{message}\"")
	end
end
