# Normalizes Lich script arguments before command dispatch.
#
# Lich can sometimes pass duplicated command text through script variables.
# This helper keeps command handling predictable and removes the script name
# when the user typed it into the command line.
#
# @param raw_args [Array<#to_s>] raw Lich script arguments
# @return [Array<String>] normalized command arguments
def cm_normalize_args(raw_args)
  normalized = raw_args.to_a.flat_map { |arg| arg.to_s.strip.split(/\s+/) }.reject(&:empty?)
  half = normalized.length / 2
  normalized = normalized.first(half) if normalized.length.even? && half.positive? && normalized.first(half) == normalized.last(half)
  normalized = normalized.drop(1) if normalized.first.to_s.casecmp(SCRIPT_COMMAND).zero?
  normalized
end

args = cm_normalize_args(script.vars)
