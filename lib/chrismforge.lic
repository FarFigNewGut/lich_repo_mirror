def cm_mono_block(text)
  if defined?(_respond)
    _respond %Q{<output class="mono"/>\n#{text}<output class=""/>}
  else
    respond text
  end
end

def cm_inline_preset(preset, text)
  preset = preset.to_s
  if %w[monster creature error yellow bold].include?(preset)
    "#{monsterbold_start}#{text}#{monsterbold_end}"
  else
    "<preset id=\"#{preset}\">#{text}</preset>"
  end
end

def cm_bold(text)
  cm_inline_preset('speech', text)
end

def cm_gtk_markup_escape(text)
  text.to_s.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;')
end

def cm_status_warning_markup(text)
  "<span foreground=\"#ffbf40\" weight=\"bold\">#{cm_gtk_markup_escape(text)}</span>"
end

def cm_deep_copy(obj)
  Marshal.load(Marshal.dump(obj))
end

def cm_deep_merge(base, override)
  merged = cm_deep_copy(base)
  override.to_h.each do |key, value|
    if merged[key].is_a?(Hash) && value.is_a?(Hash)
      merged[key] = cm_deep_merge(merged[key], value)
    else
      merged[key] = value
    end
  end
  merged
end

def cm_script_root
  return DATA_DIR if defined?(DATA_DIR) && DATA_DIR

  File.expand_path(File.join(File.dirname(__FILE__), '..'))
rescue
  File.expand_path('.')
end

def cm_settings_dir
  File.join(cm_script_root, SCRIPT_COMMAND)
end

def cm_settings_path
  File.join(cm_settings_dir, 'settings.yaml')
end

def cm_setting_set(data, path, value)
  return if value.nil?

  target = data
  path[0...-1].each { |key| target = (target[key] ||= {}) }
  target[path.last] = value
end

# Loads saved Chrism Forge settings from YAML and fills in any missing defaults.
#
# Side effects: creates the settings file with defaults if it does not exist.
#
# @return [Hash] merged settings for this script
def cm_load_settings
  path = cm_settings_path
  if File.exist?(path)
    loaded = YAML.load_file(path)
    return cm_deep_merge(CHRISMFORGE_SETTINGS_DEFAULTS, loaded.is_a?(Hash) ? loaded : {})
  end

  settings = cm_deep_copy(CHRISMFORGE_SETTINGS_DEFAULTS)
  cm_save_settings(settings)
  settings
rescue
  cm_deep_copy(CHRISMFORGE_SETTINGS_DEFAULTS)
end

# Saves Chrism Forge settings to the script YAML file.
#
# Side effects: creates the settings folder when needed and writes settings.yaml.
#
# @param settings [Hash] settings to save
# @return [void]
def cm_save_settings(settings = $chrismforge_settings)
  FileUtils.mkdir_p(cm_settings_dir) unless Dir.exist?(cm_settings_dir)
  File.open(cm_settings_path, 'w') { |file| file.write(settings.to_yaml) }
rescue => error
  message("Could not save Chrism Forge settings: #{error.message}") if defined?(message)
end

$chrismforge_settings = cm_load_settings

def message(text = '')
  string = text.to_s.gsub(/^(\s*)~ ?/, '\1')
  puts string
  $chrism_maker_progress_callback.call(text.to_s) if $chrism_maker_progress_callback
end

def cm_timestamp
  Time.now.strftime('%H:%M:%S')
end

def cm_timestamp_text(text)
  source = text.to_s
  marker = source =~ /\A\s*~/ ? '~ ' : ''
  clean = source.gsub(/\A\s*~\s*/, '')
  "#{marker}[#{cm_timestamp}] #{clean}"
end

# Sends a progress update to the GTK window or the game line.
#
# If GTK progress is open, this updates the live panel. Without GTK progress,
# the line still goes to the game so command-line users get feedback.
#
# @param text [String] progress text
# @param state [Hash, nil] current run state for GTK timer updates
# @return [void]
def cm_progress_status(text, state = nil)
  clean = text.to_s.gsub(/\A\s*~\s*/, '')
  text = cm_timestamp_text(text)
  display_text = text.to_s.gsub(/\A~\s*/, '')
  if state
    if clean =~ /\AWaiting for/i
      state[:highlight_status] = display_text
    elsif clean =~ /\AChrismarium is full/i
      state[:highlight_status] = display_text
      state[:activity_status] = display_text
    elsif clean =~ /\AProcessed:/i
      state[:last_progress_line] = display_text
      state[:activity_status] = display_text
      state[:highlight_status] = nil
    else
      state[:activity_status] = display_text
      state[:last_progress_line] ||= display_text if clean =~ /\AStarting/i
    end
  end
  if $chrism_maker_progress_callback
    $chrism_maker_progress_callback.call(text.to_s, state)
  else
    puts text.to_s.gsub(/^(\s*)~ ?/, '\1')
  end
end

def help
  output = "\n"
  command_width = 62
  help_section = proc { |text| output.concat "\n#{cm_inline_preset('thought', "#{text}:")}\n" }
  help_line = proc do |command_text, description = ''|
    command_text = command_text.to_s
    padding = ' ' * [command_width - command_text.length, 2].max
    output.concat "   #{cm_inline_preset('speech', command_text)}#{padding}#{description}\n"
  end
  help_note = proc { |text| output.concat "      #{text}\n" }

  output.concat "#{cm_inline_preset('thought', "Chrism Forge #{VERSION}:")}\n"

  help_section.call('setup')
  help_line.call(";#{SCRIPT_COMMAND}", 'open setup and save YAML settings')
  help_line.call(";#{SCRIPT_COMMAND} setup", 'open setup and save YAML settings')
  help_line.call(";#{SCRIPT_COMMAND} config", 'same as setup')
  help_line.call(";#{SCRIPT_COMMAND} gtk", 'same as setup')
  help_line.call(";#{SCRIPT_COMMAND} gui", 'same as setup')

  help_section.call('make chrisms')
  help_line.call(";#{SCRIPT_COMMAND} run", 'make chrisms from Gems to try')
  help_line.call(";#{SCRIPT_COMMAND} run progress", 'run and open the progress window')
  help_line.call(";#{SCRIPT_COMMAND} run gtk-progress", 'same as run progress')
  help_line.call(";#{SCRIPT_COMMAND} chrismarium", 'fill your chrismarium instead')
  help_line.call(";#{SCRIPT_COMMAND} chrismarium progress", 'chrismarium mode with progress window')
  help_line.call(";#{SCRIPT_COMMAND} chrismarium gtk-progress", 'same as chrismarium progress')

  help_section.call('organize')
  help_line.call(";#{SCRIPT_COMMAND} count", 'count saved pouch contents')
  help_line.call(";#{SCRIPT_COMMAND} stage", 'move likely chrism gems into Gems to try')
  help_line.call(";#{SCRIPT_COMMAND} stage (source pouch)", 'stage from one pouch')
  help_line.call(";#{SCRIPT_COMMAND} stage-gems", 'same as stage')
  help_line.call(";#{SCRIPT_COMMAND} rawsort", 'same as stage')
  help_line.call(";#{SCRIPT_COMMAND} sort", 'move finished chrisms into Finished chrisms')
  help_line.call(";#{SCRIPT_COMMAND} sort (source pouch)", 'sort one pouch')
  help_line.call(";#{SCRIPT_COMMAND} sort (source pouch) (gem pouch) (chrism pouch)", 'sort with chosen pouches')
  help_line.call(";#{SCRIPT_COMMAND} chrismsort", 'same as sort')
  help_line.call(";#{SCRIPT_COMMAND} sort-chrisms", 'same as sort')

  help_section.call('info')
  help_line.call(";#{SCRIPT_COMMAND} quality", 'check whether this character can make chrisms')
  help_line.call(";#{SCRIPT_COMMAND} skill", 'same as quality')
  help_line.call(";#{SCRIPT_COMMAND} skills", 'same as quality')
  help_line.call(";#{SCRIPT_COMMAND} check", 'same as quality')
  help_line.call(";#{SCRIPT_COMMAND} canmake", 'same as quality')
  help_line.call(";#{SCRIPT_COMMAND} changelog", 'show important changes')
  help_line.call(";#{SCRIPT_COMMAND} changes", 'same as changelog')
  help_line.call(";#{SCRIPT_COMMAND} version", 'same as changelog')
  help_line.call(";#{SCRIPT_COMMAND} help", 'show this help')
  help_line.call(";#{SCRIPT_COMMAND} --help", 'same as help')
  help_line.call(";#{SCRIPT_COMMAND} -h", 'same as help')
  help_line.call(";#{SCRIPT_COMMAND} ?", 'same as help')

  help_section.call('settings')
  help_note.call("Use ;#{SCRIPT_COMMAND} setup. Chrism Forge does not use ;vars.")
  help_note.call('When GemGuard has saved orb status and value, Chrism Forge uses that before casting 325.')
  help_note.call('Known non-orbs and orb gems under 3000 silver are skipped to save mana.')
  help_note.call('Use the Chrismarium tab to choose which finished chrisms go into your chrismarium.')
  help_note.call('Use the Gemcutting tab to save a lapidary box and optionally cut gems during chrism runs.')
  output.concat "\n"

  cm_mono_block(output)
end

def changelog
  output = "\n"
  output.concat "#{cm_inline_preset('thought', 'chrismforge changelog:')}\n\n"
  output.concat "07-05-2026\n"
  output.concat "   0.12.4 - fix(gemcutting): Recognized grab and hand-swap messages while preparing the saved lapidary box.\n"
  output.concat "   0.12.3 - fix(setup): Made closing a Chrism Forge window request a safe stop after the current action.\n"
  output.concat "   0.12.2 - fix(gemcutting): Made the manual Cut Saved Pouch button change to Stop while cutting and stop after the current gem.\n"
  output.concat "   0.12.1 - fix(gemcutting): Made manual pouch cutting count already-cut gems before cutting and reuse the lapidary box setup for the batch.\n"
  output.concat "   0.12.0 - feat(gemcutting): Added a Gemcutting tab button to cut uncut gems in a chosen saved pouch outside chrism-making runs.\n"
  output.concat "   0.11.2 - fix(setup): Saved checkbox changes immediately and refreshed the Gemcutting summary when the run-cut toggle changes.\n"
  output.concat "   0.11.1 - fix(gemcutting): Skipped the lapidary cutter when a gem already shows one of the saved cut designs.\n\n"
  output.concat "07-04-2026\n"
  output.concat "   0.11.0 - feat(gemcutting): Added an opt-in chrism-run cutter that uses saved lapidary patterns after each gem outcome is known.\n\n"
  output.concat "07-03-2026\n"
  output.concat "   0.10.10 - fix(gemguard): Saved newly made chrism status, strength, and fullness back to GemGuard's item database.\n"
  output.concat "   0.10.9 - docs(help): Clarified that Chrism Forge uses GemGuard orb status and value data before casting 325.\n"
  output.concat "   0.10.8 - fix(progress): Replaced the old non-orb failed label with separate non-orb, low-value orb, and other failed counts.\n"
  output.concat "   0.10.7 - fix(chrismarium): Made chrismarium run mode respect saved strength and fullness filters before pushing new chrisms.\n"
  output.concat "   0.10.6 - fix(setup): Right-aligned setup labels and widened the label column so dropdowns line up cleanly.\n"
  output.concat "   0.10.5 - fix(report): Split low-value orb gems out of non-orb failed counts and clarified the setup pouch label.\n"
  output.concat "   0.10.4 - fix(progress): Renamed estimated finish to finish around so it is clear that the value is a clock time.\n"
  output.concat "   0.10.3 - fix(setup): Added the current character name to setup and progress window titles.\n\n"
  output.concat "06-30-2026\n"
  output.concat "   0.10.2 - fix(gemcutting): Added separate saved pattern choices for orb, chrism, purified, and regular gems, allowed held gemcutting tools and safer typed-name fallbacks, and captured full ANALYZE output so lapidary boxes save their designs correctly.\n\n"
  output.concat "06-29-2026\n"
  output.concat "   0.9.0 - feat(setup): Added chrismarium status refresh and gemcutter support for saved gemcutting designs.\n"
  output.concat "   0.8.0 - feat(lapidary): Added a Lapidary setup tab that analyzes a saved box and stores its current designs.\n"
  output.concat "   0.7.0 - feat(chrismarium): Added a Chrismarium setup tab that fills the chrismarium from finished chrisms by selected strength and fullness.\n"
  output.concat "   0.6.1 - fix(gemguard): Skipped GemGuard-known non-orbs without needing saved value and renamed the failed-gem pouch text to Non-orb gems.\n"
