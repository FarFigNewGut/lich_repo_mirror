# Builds the GTK title text with the current character name when Lich has it.
#
# @param base [String] base window title before version and character
# @return [String] title text for GTK windows
def cm_window_title(base)
  name = Char.name.to_s.strip
  suffix = name.empty? ? '' : " - #{name}"
  "#{base} #{VERSION}#{suffix}"
rescue
  "#{base} #{VERSION}"
end

