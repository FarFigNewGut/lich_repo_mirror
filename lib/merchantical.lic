# frozen_string_literal: true

=begin

Merchantical.lic is an item management window for marking and tracking equipment, and selling it,
It should make the experience of sorting and selling junk as well as saving and tracking more
interesting loot for manual sales to players. Includes a data export for shared URL shops.
Requires ;Loresang to work.

The following inputs are available:
  ;merchantical       - open merchant item manager

        author: Kyrandos
        Other scripts: Combatical, VolnRestore2, Loresang
        game: gs
        tags: utility, economy, merchant, loresang, sell, pawnshop, shop, item, management
        version: 1.1.5
        required: Lich > 5.0, loresang.lic (for source data)

        \Version\
        1.0.0 2/27/2026 - initial internal build.
        1.0.1 2/27/2026 - Loresang! button; live stream capture; empty-window
                          on no data; DATA_DIR path fix.
        1.0.2 2/27/2026 - Removed get_style_context (not in Ruby-GNOME 4.3.3).
                          All styling via Pango markup and widget.opacity=.
        1.0.5 2/28/2026 - Removed material filter. Added many filters. Detail panes hidden by
                          default (no_show_all). Added multiple buttons and applied logic fixes
        1.0.6 2/29/2026 - Removed initial run locker visit, fixed item discovery, added validate
        1.1.0 3/1/2026  - Locker bag validation and sell retrieval, locker items tracked with
                          package icon and sold by full name; per-character settings file;
                          ;go2 fixes, type filter normalization, pluralization detection;
                          Spell filter: detects imbedded spells, shows [Spell Name] tag
        1.1.2 3/01/2026 - Shop export: items grouped by type (H1) with item names as H2;
                          inline metadata (silvers, enchant, weight, spell, property tags);
                          DOCX export via PowerShell OOXML for Google Docs import;
                          EduBarbarian storage for all output files
        1.1.5 3/01/2026 - bug fixes, rebuilds and tweaks. Added batch sales. Search function
                          added to html output. Item handling improvements across board. 
        


=end

require 'gtk3' rescue nil
require 'json'

module Merchantical
  _mc_char         = XMLData.name.to_s.downcase.gsub(/[^a-z0-9]/, '_')
  EDUBARBARIAN_DIR = File.join(LICH_DIR, 'EduBarbarian').freeze
  Dir.mkdir(EDUBARBARIAN_DIR) unless Dir.exist?(EDUBARBARIAN_DIR)
  STATE_FILE       = File.join(EDUBARBARIAN_DIR, "merchantical_#{_mc_char}.json")
  ITEMS_FILE       = File.join(EDUBARBARIAN_DIR, "merchantical_#{_mc_char}_items.json")
  HTML_FILE        = File.join(EDUBARBARIAN_DIR, "merchantical_#{_mc_char}_loresang.html")
  LORESANG_HTML    = File.join(EDUBARBARIAN_DIR, 'loresang_report.html')
  SHOP_EXPORT_FILE = File.join(EDUBARBARIAN_DIR, "merchantical_#{_mc_char}_shop.html")
  SHOP_DOCX_FILE   = File.join(EDUBARBARIAN_DIR, "merchantical_#{_mc_char}_shop.docx")

  # Element selectors only — no class selectors (get_style_context unavailable)
  CSS = <<~CSS
    window { background-color: #1c1c1c; color: #c0c0c0; }
    listbox { background-color: #1c1c1c; }
    listboxrow { background-color: #1c1c1c; color: #c0c0c0; padding: 1px 2px; }
    listboxrow:hover { background-color: #252525; }
    entry { background-color: #252525; color: #c0c0c0; }
    button { background-color: #2a2a2a; color: #c0c0c0; border: 1px solid #383838; }
    button:hover { background-color: #333; }
    button#shop_flagged { border: 2px solid #d4af37; }
    button#batch_queued_sell { border: 2px solid #d4af37; }
    box#row_hover { border-bottom: 2px solid rgba(200,180,80,0.55); }
    checkbutton { color: #c0c0c0; }
    label { color: #c0c0c0; }
    separator { background-color: #333; min-height: 1px; }
  CSS

  ENCHANT_RANGES = [
    ['1-5',   '1-5'],   ['6-10',  '6-10'],  ['11-15', '11-15'],
    ['16-20', '16-20'], ['21-25', '21-25'], ['26-30', '26-30'],
    ['31-35', '31-35'], ['36-40', '36-40'], ['41-45', '41-45'],
    ['46-50', '46-50'], ['51-55', '51-55'], ['56-60', '56-60']
  ].freeze

  WEIGHT_OPTIONS = [
    ['under1', 'Under 1 lb'],
    ['1-5',    '1-5 lbs'],
    ['6-10',   '6-10 lbs'],
    ['over10', '> 10 lbs']
  ].freeze

  CHARGES_OPTIONS = [
    ['0',     '0 charges'],
    ['1-4',   '1-4'],
    ['5-10',  '5-10'],
    ['11-20', '11-20'],
    ['over20','> 20']
  ].freeze

  KNOWN_OBJ_TYPES = %w[
    armor clothing container gem jewelry
    magic\ item potion scroll shield wand weapon
  ].freeze

  # Noun-based type detection — matched against the last word(s) of the item name.
  # Used when recall text alone is insufficient (e.g. 0-charge jewelry, non-charged magic items).

  # Gemstone IV weapon nouns — covers edged, blunt, polearm, ranged, thrown, brawling categories.
  WEAPON_NOUN_RX = /\b(sword|claidhmore|claymore|longsword|shortsword|broadsword|bastard-?sword|falchion|scimitar|saber|sabre|rapier|cutlass|tulwar|khopesh|machete|espadon|estoc|epee|foil|blade|wakizashi|katana|tachi|dao|axe|ax|handaxe|battleaxe|waraxe|hatchet|tomahawk|mace|maul|hammer|warhammer|cudgel|club|flail|morningstar|staff|quarterstaff|nunchaku|sai|mattock|pick|dagger|dirk|knife|stiletto|misericorde|main-?gauche|tanto|jambiya|spear|lance|halberd|poleaxe|pike|glaive|guisarme|voulge|trident|ranseur|scythe|naginata|bow|longbow|shortbow|crossbow|arbalest|yumi|warbow|shuriken|dart|javelin|handwraps|cestus|knuckles|fist-?scythe|tiger-?claw|fighting-?spike|whip|runestaff|katar|kukri|falcastra|yklwa|parry-?stick|jeddart-?staff|awl-?pike)s?\b/i.freeze

  JEWELRY_NOUN_RX = /\b(ring|band|signet|necklace|pendant|chain|amulet|medallion|
    locket|choker|earring|earbob|bracelet|bangle|wristlet|anklet|brooch|
    stickpin|clasp|buckle|fibula|circlet|diadem|tiara|coronet|gorget|
    cameo|intaglio|barrette|hairpin|armlet|torque|torc)s?\b/xi.freeze

  MAGIC_ITEM_NOUN_RX = /\b(orb|sceptre|scepter|figurine|statuette|
    miniature|idol|fetish|totem|sphere|globe)s?\b/xi.freeze

  # Shields — used as noun fallback when recall text lacks "blocking" keyword
  SHIELD_NOUN_RX = /\b(shield|buckler|targe|target|heater|pavise|scutum|roundshield|aegis)s?\b/xi.freeze

  # Wearable clothing — checked AFTER containers/armor so bags/helmets win first.
  # Deliberately excludes ambiguous nouns like "helm", "gauntlet", "belt" (handled elsewhere).
  CLOTHING_NOUN_RX = /\b(cape|capelet|cloak|robe|coat|jacket|shirt|blouse|chemise|bodice|
    pants|trousers|breeches|skirt|dress|gown|tunic|vest|doublet|jerkin|
    surcoat|tabard|mantle|stole|pelisse|poncho|kaftan|caftan|kimono|toga|
    wrap|shawl|cassock|frock|gambeson|gambison|legging|stocking|hose|
    sash|baldric|cincture|girdle|cummerbund)s?\b/xi.freeze

  # Bags, pouches, packs, etc. — many are wearable so Lich types them "clothing";
  # check these BEFORE jewelry so "canvas bag" doesn't become "jewelry".
  CONTAINER_NOUN_RX = /\b(bag|sack|pouch|pack|backpack|haversack|rucksack|knapsack|
    bundle|basket|box|coffer|chest|case|trunk|bin|satchel|purse|quiver|
    scabbard|sheath|holster|sling|carrier|tote|wallet|ruck|pocketbook)s?\b/xi.freeze

  def self.pango_escape(str)
    str.to_s.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;')
  end

  # ---------------------------------------------------------------------------
  # Parser
  # ---------------------------------------------------------------------------
  module Parser
    def self.extract_items(html)
      if html =~ /<script[^>]+id="batch-data"[^>]*>(.*?)<\/script>/m
        items = JSON.parse($1.strip)
        items.each { |item| item.merge!(parse_recall(item['recall_text'].to_s, item['name'].to_s)) }
        return items
      end
      []
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Parse error: #{e.message}")
      []
    end

    # Infer object type from recall text + item name using Gemstone recall output patterns.
    # ORDER MATTERS: specific patterns must precede catch-alls.
    # name is checked for known jewelry/magic-item nouns when recall text is ambiguous.
    def self.parse_obj_type(text, name = '')
      t = text.to_s.downcase
      n = name.to_s.downcase

      # Weapons — text signals first, then noun fallback
      return 'weapon'     if t =~ /\b(edged|blunt|piercing|ranged|brawling|polearm|thrown)\s+weapon\b/ ||
                             t =~ /\bweapon\s+(type|class)\b/ ||
                             t =~ /\bpolearm\b/ ||
                             t =~ /\bweighted\s+to\s+inflict\b/ ||
                             (!n.empty? && n =~ Merchantical::WEAPON_NOUN_RX)

      # Shields — noun check FIRST so "kidney shield" isn't mis-tagged armor;
      # then text signals as fallback for unnamed/generic shield recall.
      return 'shield'     if (!n.empty? && n =~ Merchantical::SHIELD_NOUN_RX) ||
                             t =~ /\bblocking\b/ || t =~ /\bshield\s+(type|class)\b/

      # Armor — explicit armor keywords (protection/hindrance text) after shields win by noun
      return 'armor'      if t =~ /\barmor\s+(type|class)\b/ ||
                             t =~ /points?\s+of\s+protection\b/ ||
                             t =~ /\bhindrance\b.*\bprotection\b/

      # Scrolls
      return 'scroll'     if t =~ /contains?\s+the\s+following\s+spell/

      # Wands (specific "charged item" language)
      return 'wand'       if t =~ /\bcharged\s+item\b/

      # Containers — check BEFORE clothing/jewelry. Many bags/packs/pouches are wearable so
      # Lich reports gi.type = "clothing"; noun matching corrects this.
      return 'container'  if !n.empty? && n =~ Merchantical::CONTAINER_NOUN_RX

      # Clothing — noun fallback for capes, cloaks, robes, etc. Check AFTER containers.
      return 'clothing'   if !n.empty? && n =~ Merchantical::CLOTHING_NOUN_RX

      # Jewelry — MUST come before the generic magic item/charges check.
      # Many jewelry items in Gemstone have charges (rings, pendants, earrings, etc.) but
      # their recall text may lack explicit "worn on" language, especially at 0 charges.
      # Noun matching covers rings, bands, earrings, pendants, stickpins, clasps, etc.
      return 'jewelry'    if t =~ /it\s+is\s+an\s+enhancive\s+item/  ||
                             t =~ /\bworn\s+(on|around|in)\b/          ||
                             (!n.empty? && n =~ Merchantical::JEWELRY_NOUN_RX)

      # Orbs, sceptres, figurines — magic items that may have 0 charges in recall
      return 'magic item' if (!n.empty? && n =~ Merchantical::MAGIC_ITEM_NOUN_RX) ||
                             t =~ /it\s+has\s+\d+\s+charges?/

      ''
    end

    def self.parse_recall(text, name = '')
      props = {
        'weight' => nil, 'enchantment' => nil,
        'persistent' => false, 'disintegrate' => false, 'spiked' => false,
        'enhancive' => false, 'crumbly' => false, 'charges' => nil,
        'spell' => nil, 'obj_type' => ''
      }
      return props if text.to_s.empty?

      # Weight
      if text =~ /It is a small item, under a pound/i
        props['weight'] = 0.1
      elsif text =~ /It appears to weigh about ([\d.]+) pound/i
        props['weight'] = $1.to_f
      elsif text =~ /weight of ([\d.]+) pound/i
        props['weight'] = $1.to_f
      elsif text =~ /weighs? ([\d.]+) pound/i
        props['weight'] = $1.to_f
      end

      # Enchantment — primary: "imparts a bonus of +N more than usual"
      if text =~ /It imparts a bonus of \+?(\d+) more than usual/i
        props['enchantment'] = $1.to_i
      elsif text =~ /enchantment of \+?(\d+)/i
        props['enchantment'] = $1.to_i
      elsif text =~ /enchanted to \+?(\d+)/i
        props['enchantment'] = $1.to_i
      elsif text =~ /\+(\d+)\s+enchant/i
        props['enchantment'] = $1.to_i
      end

      # Charges
      if text =~ /It has (\d+) charges?/i
        props['charges'] = $1.to_i
      end

      # Boolean properties
      props['persistent']   = true if text =~ /It will persist after its last magical charge has been expended/i
      props['disintegrate'] = true if text =~ /disintegrate/i
      props['spiked']       = true if text =~ /spiked/i
      props['enhancive']    = true if text =~ /It is an enhancive item/i
      props['crumbly']      = true if text =~ /It will crumble into dust after its last enhancive charge has been expended/i
      if text =~ /currently imbedded with (?:the )?(.+?)\s+spell/i
        props['spell'] = $1.strip
      elsif text =~ /could be imbedded/i
        props['spell'] = 'none'
      end
      props['obj_type']     = parse_obj_type(text, name)

      props
    end
  end

  # ---------------------------------------------------------------------------
  # State
  # ---------------------------------------------------------------------------
  module State
    DEFAULTS = {
      'locked'          => [],
      'shop_flagged'    => [],
      'vendor_rejected' => [],
      'removed'         => [],
      'options'      => {
        'locker_room'    => '',
        'use_locker'     => false,
        'always_on_top'  => false,
        'bags'           => ['', '', '', '', '']
      }
    }.freeze

    def self.load
      return deep_dup(DEFAULTS) unless File.exist?(STATE_FILE)
      base = deep_dup(DEFAULTS)
      data = JSON.parse(File.read(STATE_FILE))
      base['locked']          = data['locked']          if data['locked']
      base['shop_flagged']    = data['shop_flagged']    if data['shop_flagged']
      base['vendor_rejected'] = data['vendor_rejected'] if data['vendor_rejected']
      base['removed']         = data['removed']         if data['removed']
      if data['options'].is_a?(Hash)
        base['options'].merge!(data['options'])
        base['options']['bags'] = Array.new(5) { |i| data['options']['bags']&.at(i).to_s }
      end
      base
    rescue
      deep_dup(DEFAULTS)
    end

    def self.save(data)
      File.write(STATE_FILE, JSON.generate(data))
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] State save error: #{e.message}")
    end

    def self.deep_dup(obj)
      case obj
      when Hash  then obj.transform_values { |v| deep_dup(v) }
      when Array then obj.map { |v| deep_dup(v) }
      else obj
      end
    end
  end

  # ---------------------------------------------------------------------------
  # MainWindow
  # ---------------------------------------------------------------------------
  class MainWindow < Gtk::Window
    SELL_COLOR_IDLE      = '#3c9c3c'.freeze
    SELL_COLOR_ARMED     = '#3377cc'.freeze
    REMOVE_COLOR_ARMED   = '#cc3333'.freeze
    LORESANG_COLOR       = '#a0c8ff'.freeze
    LORESANG_COLOR_ARMED = '#cc66ff'.freeze
    FOUND_COLOR      = '#3c9c3c'.freeze
    NOTFOUND_COLOR   = '#cc5555'.freeze
    SEARCH_ICON      = "\u{1F50D}".freeze
    SHOP_ICON        = "\u{1F3EA}".freeze
    MUSIC_ICON       = "\u266B".freeze   # ♫ text char — responds to Pango foreground
    GEAR_ICON        = "\u2699".freeze
    LOCK_ON_ICON     = "\u{1F512}".freeze  # 🔒
    LOCK_OFF_ICON    = "\u{1F513}".freeze  # 🔓
    LOCKER_ICON      = "\u{1F4E6}".freeze  # 📦 locker indicator

    def initialize(items, cmd_queue, on_close, state)
      super()
      @items             = items
      @cmd_queue         = cmd_queue
      @on_close          = on_close
      @state             = state
      @options           = state['options'] || {}
      @row_data          = []
      @sell_timers       = {}
      @sell_arm_times    = {}
      @remove_timers     = {}
      @remove_arm_times  = {}
      @loresang_btn      = nil
      @loresang_lbl      = nil
      @loresang_timer    = nil
      @loresang_arm_time = nil
      @locked_list       = nil
      @unlocked_list     = nil
      @main_box          = nil
      @type_combo        = nil
      @updating_type_combo = false
      @filter = {
        search: '', enchantment_range: nil,
        persistent: false, disintegrate: false, spiked: false,
        enhancive: false, crumbly: false, imbued: false,
        value_min: nil, value_dir: :gte, weight: nil, charges: nil, obj_type: nil
      }

      self.title = "Merchantical - Item Manager"
      self.set_default_size(1080, 700)
      self.set_window_position(:center)

      apply_css
      build_ui
      self.keep_above = true if @options['always_on_top']
      signal_connect('destroy') { @on_close.call }
    end

    def update_batch(new_items)
      locked_ids   = @state['locked']          || []
      flagged_ids  = @state['shop_flagged']    || []
      rejected_ids = @state['vendor_rejected'] || []
      new_items.each do |item|
        item[:locked]          = locked_ids.include?(item['id'])
        item[:shop_flagged]    = flagged_ids.include?(item['id'])
        item[:vendor_rejected] = rejected_ids.include?(item['id'])
      end
      @items = new_items
      repopulate_type_combo
      rebuild_list
    end

    def refresh_found_state
      # Called after inventory validation — rebuilds rows to update found/not-found icons
      repopulate_type_combo
      rebuild_list
    end

    def enable_loresang_btn
      if @loresang_timer
        GLib::Source.remove(@loresang_timer) rescue nil
        @loresang_timer    = nil
        @loresang_arm_time = nil
      end
      @loresang_btn&.sensitive = true
      @loresang_lbl&.markup = loresang_idle_markup
    end

    private

    def pe(str)
      Merchantical.pango_escape(str)
    end

    def dbg(msg)
      return unless @options['debug']
      Lich::Messaging.msg("yellow", "[Merchantical DBG] #{msg}")
    end

    def loresang_idle_markup
      "<span foreground='#3399ff'>#{MUSIC_ICON}</span>" \
      "<span foreground='#{LORESANG_COLOR}' weight='bold'> Loresang!</span>"
    end

    def apply_css
      provider = Gtk::CssProvider.new
      provider.load_from_data(Merchantical::CSS)
      Gtk::StyleContext.add_provider_for_screen(
        Gdk::Screen.default, provider,
        Gtk::StyleProvider::PRIORITY_APPLICATION
      )
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] CSS load warning: #{e.message}")
    end

    def build_ui
      vbox = Gtk::Box.new(:vertical, 0)
      add(vbox)
      toolbar = build_toolbar
      vbox.pack_start(toolbar, expand: false, fill: false, padding: 0)
      repopulate_type_combo
      vbox.pack_start(Gtk::Separator.new(:horizontal), expand: false, fill: false, padding: 0)

      scroll = Gtk::ScrolledWindow.new
      scroll.hscrollbar_policy = :never
      scroll.vscrollbar_policy = :automatic
      vbox.pack_start(scroll, expand: true, fill: true, padding: 0)

      @main_box = Gtk::Box.new(:vertical, 0)
      scroll.add(@main_box)
      build_item_list
    end

    def build_toolbar
      # Outer is horizontal: title on left spanning both rows, right vbox has action + filter rows
      outer = Gtk::Box.new(:horizontal, 6)
      outer.margin = 4

      # ---- Title (left side, spans both rows) ----
      title_lbl = Gtk::Label.new
      title_lbl.markup =
        "<b><span foreground='#d4af37' size='large'>\u{1F4B0} MERCHANTICAL \u{1F4B0}</span></b>"
      title_lbl.set_alignment(0.5, 0.5)
      outer.pack_start(title_lbl, expand: false, fill: false, padding: 4)

      # ---- Right vbox: action row on top, filter row below ----
      right_vbox = Gtk::Box.new(:vertical, 2)
      outer.pack_start(right_vbox, expand: true, fill: true, padding: 0)

      # ---- Action row ----
      arow = Gtk::Box.new(:horizontal, 4)
      right_vbox.pack_start(arow, expand: false, fill: false, padding: 0)

      # Search entry at far left of action row (aligns above Ench: in filter row)
      search_entry = Gtk::SearchEntry.new
      search_entry.width_request = 130
      search_entry.set_tooltip_text("Filter by item name or recall text")
      search_entry.signal_connect('search-changed') do
        @filter[:search] = search_entry.text.strip.downcase
        dbg("Search: '#{search_entry.text.strip}'")
        schedule_rebuild
      end
      arow.pack_start(search_entry, expand: false, fill: false, padding: 0)

      # Expander pushes remaining buttons to the right
      arow.pack_start(Gtk::Label.new(""), expand: true, fill: true, padding: 0)

      # Loresang! button
      @loresang_lbl = Gtk::Label.new
      @loresang_lbl.markup = loresang_idle_markup
      @loresang_btn = Gtk::Button.new
      @loresang_btn.add(@loresang_lbl)
      @loresang_btn.set_tooltip_text(
        "Run ;loresang and pull new item data from the game stream.\n" \
        "Click once to arm (flashes purple 3s), click again to confirm.\n" \
        "NOTE: This will refresh all items below. Lock items you want to keep first!"
      )
      @loresang_btn.signal_connect('clicked') do
        if @loresang_timer
          # Second click — confirm (0.25s minimum to avoid accidental double-click)
          next if @loresang_arm_time && (Time.now - @loresang_arm_time) < 0.25
          GLib::Source.remove(@loresang_timer)
          @loresang_timer    = nil
          @loresang_arm_time = nil
          dbg("Loresang confirmed -- starting run")
          @loresang_btn.sensitive = false
          @loresang_lbl.markup =
            "<span foreground='#555'>#{MUSIC_ICON}</span><span foreground='#666'> Running...</span>"
          @cmd_queue.push({ run_loresang: true })
        else
          # First click — arm with purple flash
          dbg("Loresang armed -- click again within 3s to confirm")
          ticks = [0]
          timer_id = GLib::Timeout.add(500) do
            ticks[0] += 1
            if ticks[0] > 6
              @loresang_lbl.markup = loresang_idle_markup
              @loresang_timer    = nil
              @loresang_arm_time = nil
              false
            else
              color = ticks[0].even? ? LORESANG_COLOR_ARMED : LORESANG_COLOR
              @loresang_lbl.markup =
                "<span foreground='#3399ff'>#{MUSIC_ICON}</span>" \
                "<span foreground='#{color}' weight='bold'> Loresang!</span>"
              true
            end
          end
          @loresang_lbl.markup =
            "<span foreground='#3399ff'>#{MUSIC_ICON}</span>" \
            "<span foreground='#{LORESANG_COLOR_ARMED}' weight='bold'> Loresang!</span>"
          @loresang_timer    = timer_id
          @loresang_arm_time = Time.now
        end
      end
      arow.pack_start(@loresang_btn, expand: false, fill: false, padding: 4)

      # Validate Items button
      validate_lbl = Gtk::Label.new
      validate_lbl.markup = "<span foreground='#80c8ff' weight='bold'>Validate Items</span>"
      validate_btn = Gtk::Button.new
      validate_btn.add(validate_lbl)
      validate_btn.set_tooltip_text(
        "Checks inventory to validate that items can be found\n" \
        "* if 'Use locker?' is checked on, will visit locker."
      )
      validate_btn.signal_connect('clicked') do
        dbg("Validate Items triggered")
        validate_btn.sensitive = false
        validate_lbl.markup = "<span foreground='#555'>Validating...</span>"
        @cmd_queue.push({ validate_items: true })
        GLib::Timeout.add(1500) do
          validate_btn.sensitive = true
          validate_lbl.markup = "<span foreground='#80c8ff' weight='bold'>Validate Items</span>"
          false
        end
      end
      arow.pack_start(validate_btn, expand: false, fill: false, padding: 4)

      # Gear (settings) button
      gear_lbl = Gtk::Label.new
      gear_lbl.markup = "<span foreground='#aaa' size='large'>#{GEAR_ICON}</span>"
      gear_btn = Gtk::Button.new
      gear_btn.add(gear_lbl)
      gear_btn.set_tooltip_text("Settings and help")
      gear_btn.signal_connect('clicked') { show_gear }
      arow.pack_start(gear_btn, expand: false, fill: false, padding: 2)

      # Copy Shop Data button
      copy_lbl = Gtk::Label.new
      copy_lbl.markup =
        "<span foreground='#d4af37' weight='bold'>Export Shop HTML #{SHOP_ICON}</span>"
      copy_btn = Gtk::Button.new
      copy_btn.add(copy_lbl)
      copy_btn.set_tooltip_text(
        "Save all shop-flagged items as an HTML file.\n" \
        "Customers can open it in any browser and click items to expand recall details."
      )
      copy_btn.signal_connect('clicked') { copy_shop_data }
      arow.pack_start(copy_btn, expand: false, fill: false, padding: 2)

      # ---- Filter row ----
      frow = Gtk::Box.new(:horizontal, 4)
      right_vbox.pack_start(frow, expand: false, fill: false, padding: 0)

      frow.pack_start(Gtk::Label.new(" Ench:"), expand: false, fill: false, padding: 0)
      ench_combo = Gtk::ComboBoxText.new
      ench_combo.append('', 'Any')
      ENCHANT_RANGES.each { |id, lbl| ench_combo.append(id, lbl) }
      ench_combo.active = 0
      ench_combo.set_tooltip_text("Filter by enchantment (blocks of 5)")
      ench_combo.signal_connect('changed') do
        id = ench_combo.active_id.to_s
        @filter[:enchantment_range] = id.empty? ? nil : id
        dbg("Filter Enchantment: #{id.empty? ? 'Any' : id}")
        schedule_rebuild
      end
      frow.pack_start(ench_combo, expand: false, fill: false, padding: 0)

      frow.pack_start(Gtk::Label.new(" Wt:"), expand: false, fill: false, padding: 0)
      wt_combo = Gtk::ComboBoxText.new
      wt_combo.append('', 'Any')
      WEIGHT_OPTIONS.each { |id, lbl| wt_combo.append(id, lbl) }
      wt_combo.active = 0
      wt_combo.set_tooltip_text("Filter by weight")
      wt_combo.signal_connect('changed') do
        id = wt_combo.active_id.to_s
        @filter[:weight] = id.empty? ? nil : id
        dbg("Filter Weight: #{id.empty? ? 'Any' : id}")
        schedule_rebuild
      end
      frow.pack_start(wt_combo, expand: false, fill: false, padding: 0)

      frow.pack_start(Gtk::Label.new(" Chrg:"), expand: false, fill: false, padding: 0)
      chrg_combo = Gtk::ComboBoxText.new
      chrg_combo.append('', 'Any')
      CHARGES_OPTIONS.each { |id, lbl| chrg_combo.append(id, lbl) }
      chrg_combo.active = 0
      chrg_combo.set_tooltip_text("Filter by number of charges")
      chrg_combo.signal_connect('changed') do
        id = chrg_combo.active_id.to_s
        @filter[:charges] = id.empty? ? nil : id
        dbg("Filter Charges: #{id.empty? ? 'Any' : id}")
        schedule_rebuild
      end
      frow.pack_start(chrg_combo, expand: false, fill: false, padding: 0)

      frow.pack_start(Gtk::Label.new(" Type:"), expand: false, fill: false, padding: 0)
      @type_combo = Gtk::ComboBoxText.new
      @type_combo.append('', 'Any')
      @type_combo.active = 0
      @type_combo.set_tooltip_text("Filter by object type (weapon, jewelry, magic, etc.)")
      @type_combo.signal_connect('changed') do
        next if @updating_type_combo
        id = @type_combo.active_id.to_s
        @filter[:obj_type] = id.empty? ? nil : id
        dbg("Filter Type: #{id.empty? ? 'Any' : id}")
        schedule_rebuild
      end
      frow.pack_start(@type_combo, expand: false, fill: false, padding: 0)

      # Value filter with clickable >= / <= toggle
      frow.pack_start(Gtk::Label.new(" Val"), expand: false, fill: false, padding: 0)
      val_dir_btn = Gtk::Button.new(label: ">=")
      val_dir_btn.relief = :none
      val_dir_btn.width_request = 32
      val_dir_btn.set_tooltip_text("Click to toggle: >= finds items worth at least this value, <= finds items worth at most")
      val_dir_btn.signal_connect('clicked') do
        if @filter[:value_dir] == :gte
          @filter[:value_dir] = :lte
          val_dir_btn.label = "<="
        else
          @filter[:value_dir] = :gte
          val_dir_btn.label = ">="
        end
        dbg("Filter Value direction: #{@filter[:value_dir]}")
        schedule_rebuild
      end
      frow.pack_start(val_dir_btn, expand: false, fill: false, padding: 0)
      val_entry = Gtk::Entry.new
      val_entry.width_request = 55
      val_entry.set_placeholder_text("silvers")
      val_entry.set_tooltip_text("Filter items by silver value (use the >= / <= button to change direction)")
      val_entry.signal_connect('changed') do
        text = val_entry.text.strip.gsub(',', '')
        @filter[:value_min] = text.empty? ? nil : text.to_i
        dbg("Filter Value: #{text.empty? ? 'cleared' : "#{text} silvers"}")
        schedule_rebuild
      end
      frow.pack_start(val_entry, expand: false, fill: false, padding: 0)

      [
        [:persistent,   "Pers",  "Show only persistent items"],
        [:disintegrate, "Disi",  "Show only disintegrate items"],
        [:spiked,       "Spkd",  "Show only spiked items"],
        [:enhancive,    "Enh",   "Show only enhancive items"],
        [:crumbly,      "Crmb",  "Show only crumbly items"],
        [:imbued,       "Spell", "Show only items imbedded with a spell"]
      ].each do |key, label, tip|
        cb = Gtk::CheckButton.new(label)
        cb.set_tooltip_text(tip)
        cb.signal_connect('toggled') do
          @filter[key] = cb.active?
          dbg("Filter #{label}: #{cb.active?}")
          schedule_rebuild
        end
        frow.pack_start(cb, expand: false, fill: false, padding: 2)
      end

      outer
    end

    def repopulate_type_combo
      return unless @type_combo
      @updating_type_combo = true
      @type_combo.remove_all
      @type_combo.append('', 'Any')
      # Use symbol key (from live inventory) if present, else string key (from recall parser)
      item_types = @items.map { |i|
        t = i[:obj_type].to_s
        t.empty? ? i['obj_type'].to_s : t
      }.reject(&:empty?)
      types = (KNOWN_OBJ_TYPES + item_types).uniq.sort
      types.each { |t| @type_combo.append(t, t.capitalize) }
      @type_combo.active = 0
      @filter[:obj_type] = nil
    ensure
      @updating_type_combo = false
    end

    def build_item_list
      @main_box.children.each { |w| @main_box.remove(w) }
      @row_data = []

      locked_items   = @items.select { |i| i[:locked] }
      unlocked_items = @items.reject { |i| i[:locked] }
      locked_items   = locked_items.sort_by   { |i| filter_matches?(i) ? 0 : 1 }
      unlocked_items = unlocked_items.sort_by { |i| filter_matches?(i) ? 0 : 1 }

      if locked_items.any?
        lbl = Gtk::Label.new
        lbl.markup = "<b><span foreground='#7ec850'>Locked Items (Mark and Lock)</span></b>"
        lbl.halign = :start
        lbl.margin_start = 8; lbl.margin_top = 3; lbl.margin_bottom = 3
        @main_box.pack_start(lbl, expand: false, fill: false, padding: 0)

        @locked_list = Gtk::ListBox.new
        @locked_list.selection_mode = :none
        @main_box.pack_start(@locked_list, expand: false, fill: false, padding: 0)
        locked_items.each { |item| add_item_row(@locked_list, item) }
        @main_box.pack_start(
          Gtk::Separator.new(:horizontal), expand: false, fill: false, padding: 4
        )
      end

      items_hdr_box = Gtk::Box.new(:horizontal, 4)

      hdr = Gtk::Label.new
      hdr.markup = "<b><span foreground='#d4af37'>Items</span></b>"
      hdr.halign = :start
      hdr.margin_start = 8; hdr.margin_top = 3; hdr.margin_bottom = 3
      items_hdr_box.pack_start(hdr, expand: true, fill: true, padding: 0)

      # "Sell all selected" button — only visible when items are batch-queued.
      queued = @items.select { |i| i[:batch_queued] }
      if queued.any?
        sell_all_lbl = Gtk::Label.new
        sell_all_lbl.markup =
          "<span foreground='#d4af37' weight='bold' size='large'>$</span>"
        sell_all_btn = Gtk::Button.new
        sell_all_btn.add(sell_all_lbl)
        sell_all_btn.relief       = :none
        sell_all_btn.valign       = :center
        sell_all_btn.margin_top   = 1
        sell_all_btn.margin_bottom = 5
        sell_all_btn.set_tooltip_text(
          "Sell all selected (#{queued.count} item#{"s" if queued.count != 1})\n" \
          "Regular inventory items sell first; locker items in one visit last.\n" \
          "Ctrl+click the $ on any item to add/remove it from the queue."
        )
        sell_all_btn.signal_connect('clicked') do
          @cmd_queue.push({ batch_sell: queued.map { |i| i['id'] } })
          queued.each { |i| i[:batch_queued] = false }
          schedule_rebuild
        end

        # Invisible spacers mirror the shop and remove button columns so sell_all_btn
        # aligns visually with the green sell buttons in the rows below.
        # pack_end places widgets right-to-left, so: remove column → shop column → sell column.
        remove_spacer2_lbl = Gtk::Label.new
        remove_spacer2_lbl.markup = "<span foreground='#666666' size='large'>\u{2620}</span>"
        remove_spacer2 = Gtk::Button.new
        remove_spacer2.add(remove_spacer2_lbl)
        remove_spacer2.relief  = :none
        remove_spacer2.opacity = 0.0
        remove_spacer2.sensitive = false

        shop_spacer2_lbl = Gtk::Label.new
        shop_spacer2_lbl.markup = "<span size='large'>#{SHOP_ICON}</span>"
        shop_spacer2 = Gtk::Button.new
        shop_spacer2.add(shop_spacer2_lbl)
        shop_spacer2.relief  = :none
        shop_spacer2.opacity = 0.0
        shop_spacer2.sensitive = false

        items_hdr_box.pack_end(remove_spacer2, expand: false, fill: false, padding: 0)
        items_hdr_box.pack_end(shop_spacer2,   expand: false, fill: false, padding: 0)
        items_hdr_box.pack_end(sell_all_btn,   expand: false, fill: false, padding: 0)
      end

      @main_box.pack_start(items_hdr_box, expand: false, fill: false, padding: 0)

      @unlocked_list = Gtk::ListBox.new
      @unlocked_list.selection_mode = :none
      @main_box.pack_start(@unlocked_list, expand: true, fill: true, padding: 0)
      unlocked_items.each { |item| add_item_row(@unlocked_list, item) }

      if @items.empty?
        empty_lbl = Gtk::Label.new
        empty_lbl.markup =
          "<i>No item data loaded. Click #{MUSIC_ICON} Loresang! above to populate.</i>"
        empty_lbl.margin = 20
        @main_box.pack_start(empty_lbl, expand: false, fill: false, padding: 0)
      end

      @main_box.show_all
    end

    def add_item_row(list, item)
      row = Gtk::ListBoxRow.new
      row.activatable = false
      row.selectable  = false
      row.opacity = filter_matches?(item) ? 1.0 : 0.35

      row_vbox = Gtk::Box.new(:vertical, 0)
      row.add(row_vbox)

      hbox = Gtk::Box.new(:horizontal, 4)
      hbox.margin_top = 2; hbox.margin_bottom = 2
      hbox.margin_start = 4; hbox.margin_end = 4
      row_vbox.pack_start(hbox, expand: false, fill: false, padding: 0)

      # Lock button (🔒 = locked, 🔓 = unlocked)
      noun = item['noun'].to_s
      lock_lbl = Gtk::Label.new
      lock_lbl.markup = "<span size='large'>#{item[:locked] ? LOCK_ON_ICON : LOCK_OFF_ICON}</span>"
      lock_btn = Gtk::Button.new
      lock_btn.add(lock_lbl)
      lock_btn.relief = :none
      lock_btn.opacity = item[:locked] ? 1.0 : 0.45
      lock_btn.set_tooltip_text(
        "Mark and Lock: \u{1F512} pins item to top and sends 'mark #id' in-game.\n" \
        "Unlocking sends 'mark #id remove' to clear the mark.\n" \
        "Both get from bag \u2192 mark/unmark \u2192 return. Persists across restarts."
      )
      lock_btn.signal_connect('clicked') do
        item[:locked] = !item[:locked]
        lock_lbl.markup = "<span size='large'>#{item[:locked] ? LOCK_ON_ICON : LOCK_OFF_ICON}</span>"
        lock_btn.opacity = item[:locked] ? 1.0 : 0.45
        dbg("#{item[:locked] ? 'Locked' : 'Unlocked'}: #{item['name']} (id=#{item['id']})")
        if item[:locked]
          if item[:gameobj_id]
            @cmd_queue.push({ mark_item: {
              item_id:      item[:gameobj_id],
              container_id: item[:container_id],
              name:         item['name']
            }})
          else
            Lich::Messaging.msg("yellow",
              "[Merchantical] #{item['name']}: pinned to top but not in current inventory -- " \
              "mark skipped. Run Loresang or ensure item is accessible first.")
          end
        else
          if item[:gameobj_id]
            @cmd_queue.push({ unmark_item: {
              item_id:      item[:gameobj_id],
              container_id: item[:container_id],
              name:         item['name']
            }})
          else
            Lich::Messaging.msg("yellow",
              "[Merchantical] #{item['name']}: not in current inventory -- " \
              "mark remove skipped. Run Validate to locate item first.")
          end
        end
        save_state
        schedule_rebuild
      end
      hbox.pack_start(lock_btn, expand: false, fill: false, padding: 0)

      # Inventory found icon (🔍).
      # In debug mode, the icon for validated non-locker items becomes a clickable button
      # that probes the game live for the real gameobj_id and prints it vs memory.
      found_icon_lbl = Gtk::Label.new
      if item[:found].nil?
        found_icon_lbl.markup = "<span foreground='#555'>#{SEARCH_ICON}</span>"
        found_tooltip = "Inventory status unknown"
      elsif item[:found]
        found_icon_lbl.markup = "<span background='#{FOUND_COLOR}'> #{SEARCH_ICON} </span>"
        found_tooltip = "Found in inventory"
      else
        found_icon_lbl.markup = "<span background='#{NOTFOUND_COLOR}'> #{SEARCH_ICON} </span>"
        found_tooltip = "Not found in inventory -- check lockers"
      end

      if @options['debug'] && item[:found] && !item[:in_locker]
        found_icon_btn = Gtk::Button.new
        found_icon_btn.add(found_icon_lbl)
        found_icon_btn.relief = :none
        found_icon_btn.set_tooltip_text("#{found_tooltip}\n[DBG] Click to probe live gameobj_id vs memory")
        found_icon_btn.signal_connect('clicked') do
          @cmd_queue.push({ probe_item: {
            item_uid:     item['id'],
            stored_id:    item[:gameobj_id].to_s,
            container_id: item[:container_id].to_s,
            name:         item['name'],
            noun:         item['noun'].to_s
          }})
        end
        hbox.pack_start(found_icon_btn, expand: false, fill: false, padding: 0)
      else
        hbox.pack_start(found_icon_lbl, expand: false, fill: false, padding: 0)
      end

      # Item name button
      name_color = case item['status'].to_s
                   when 'completed'        then '#7ec850'
                   when 'already_unlocked' then '#6699cc'
                   when 'failed'           then '#cc5555'
                   else '#c0c0c0'
                   end
      name_lbl = Gtk::Label.new
      display_name = (item[:gameobj_name] && !item[:gameobj_name].empty?) ? item[:gameobj_name] : item['name'].to_s
      name_lbl.markup =
        "<b><span foreground='#{name_color}'>#{pe(display_name)}</span></b>"
      name_btn = Gtk::Button.new
      name_btn.add(name_lbl)
      name_btn.relief = :none
      name_btn.halign = :start
      name_btn.set_tooltip_text("Click to expand/collapse full recall text")
      hbox.pack_start(name_btn, expand: false, fill: false, padding: 0)

      # Locker indicator
      if item[:in_locker]
        locker_ind_lbl = Gtk::Label.new
        locker_ind_lbl.markup = "<span foreground='#80c8ff' size='small'> #{LOCKER_ICON}</span>"
        locker_ind_lbl.set_tooltip_text("Found in locker bag")
        hbox.pack_start(locker_ind_lbl, expand: false, fill: false, padding: 0)
      end

      # Object type badge
      if item[:obj_type].to_s != ''
        type_lbl = Gtk::Label.new
        type_lbl.markup =
          "<span foreground='#666' size='small'>  [#{pe(item[:obj_type])}]</span>"
        hbox.pack_start(type_lbl, expand: false, fill: false, padding: 0)
      end

      # Silver value
      if item['value'].to_i > 0
        formatted = item['value'].to_i.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\1,').reverse
        val_lbl = Gtk::Label.new
        val_lbl.markup =
          "<span foreground='#d4af37' size='small'>  ~#{formatted} silvers</span>"
        hbox.pack_start(val_lbl, expand: false, fill: false, padding: 0)
      end

      # Property badges
      props = []
      props << "PERS" if item['persistent']
      props << "DISI" if item['disintegrate']
      props << "SPKD" if item['spiked']
      props << "ENH"  if item['enhancive']
      props << "CRMB" if item['crumbly']
      if props.any?
        prop_lbl = Gtk::Label.new
        prop_lbl.markup =
          "<span foreground='#999' size='small'>  [#{props.join(' ')}]</span>"
        hbox.pack_start(prop_lbl, expand: false, fill: false, padding: 0)
      end

      # Spell tag — separate brackets, distinct color
      if item['spell'].to_s != ''
        spell_lbl = Gtk::Label.new
        spell_lbl.markup =
          "<span foreground='#b08adf' size='small'>  [#{pe(item['spell'])}]</span>"
        hbox.pack_start(spell_lbl, expand: false, fill: false, padding: 0)
      end

      # Vendor rejected tag
      if item[:vendor_rejected]
        rejected_lbl = Gtk::Label.new
        rejected_lbl.markup = "<span foreground='#cc3333' size='small'>  [vendor rejected]</span>"
        hbox.pack_start(rejected_lbl, expand: false, fill: false, padding: 0)
      end

      # Enchant / charges / weight badge
      detail_parts = []
      detail_parts << "+#{item['enchantment']}"         if item['enchantment'].to_i > 0
      detail_parts << "#{item['charges']} chrg"          unless item['charges'].nil?
      detail_parts << "#{item['weight']} lb"             if item['weight'].to_f > 0
      if detail_parts.any?
        detail_lbl = Gtk::Label.new
        detail_lbl.markup =
          "<span foreground='#777' size='small'>  #{pe(detail_parts.join(' | '))}</span>"
        hbox.pack_start(detail_lbl, expand: false, fill: false, padding: 0)
      end

      hbox.pack_start(Gtk::Label.new(""), expand: true, fill: true, padding: 0)

      if item[:locked]
        # Locked items cannot be sold — invisible spacer keeps shop/remove columns aligned.
        sell_spacer_lbl = Gtk::Label.new
        sell_spacer_lbl.markup = sell_markup(SELL_COLOR_IDLE)
        sell_spacer = Gtk::Button.new
        sell_spacer.add(sell_spacer_lbl)
        sell_spacer.relief    = :none
        sell_spacer.opacity   = 0.0
        sell_spacer.sensitive = false
        hbox.pack_start(sell_spacer, expand: false, fill: false, padding: 0)
      else
        # Sell button ($) — flashes every 500ms for 3s when armed
        sell_lbl = Gtk::Label.new
        sell_lbl.markup = sell_markup(SELL_COLOR_IDLE)
        sell_btn = Gtk::Button.new
        sell_btn.add(sell_lbl)
        sell_btn.relief = :none
        sell_btn.name   = item[:batch_queued] ? 'batch_queued_sell' : ''
        sell_btn.set_tooltip_text(
          "Sell at pawnshop.\nClick once to arm (flashes blue 3s).\nClick again to confirm.\n" \
          "Ctrl+click to add/remove from batch sell queue (gold border when queued)."
        )
        # Ctrl+click: toggle batch queue — consume event so the arm/confirm logic is skipped.
        sell_btn.signal_connect('button-press-event') do |_btn, event|
          if (event.state.to_i & 4) != 0  # GDK_CONTROL_MASK = 4
            item[:batch_queued] = !item[:batch_queued]
            sell_btn.name = item[:batch_queued] ? 'batch_queued_sell' : ''
            dbg("Batch queue #{item[:batch_queued] ? 'added' : 'removed'}: #{item['name']}")
            schedule_rebuild
            true  # consume — prevents 'clicked' from firing
          else
            false
          end
        end
        sell_btn.signal_connect('clicked') do
          if @sell_timers[noun]
            # Second click — confirm sell (minimum 0.25s after arming to avoid accidental double-click)
            next if @sell_arm_times[noun] && (Time.now - @sell_arm_times[noun]) < 0.25
            GLib::Source.remove(@sell_timers[noun])
            @sell_timers.delete(noun)
            @sell_arm_times.delete(noun)
            sell_lbl.markup = sell_markup(SELL_COLOR_IDLE)
            dbg("Sell confirmed: #{item['name']} (id=#{item['id']}, gameobj_id=#{item[:gameobj_id]}, container_id=#{item[:container_id]}, found=#{item[:found]})")
            if item[:found] == false
              flash_not_found(found_icon_lbl)
            else
              @cmd_queue.push({ sell_item: {
                item_id:         item[:gameobj_id],
                container_id:    item[:container_id],
                name:            item['name'],
                noun:            item['noun'],
                item_uid:        item['id'],
                in_locker:       item[:in_locker],
                locker_bag_name: item[:locker_bag_name],
                origin_room:     ((Map.current_room_id rescue nil) || XMLData.room_id).to_s
              }})
            end
          else
            # First click — arm with flashing text color only
            dbg("Sell armed: #{item['name']} (id=#{item['id']})")
            ticks = [0]
            timer_id = GLib::Timeout.add(500) do
              ticks[0] += 1
              if ticks[0] > 6
                sell_lbl.markup = sell_markup(SELL_COLOR_IDLE)
                @sell_timers.delete(noun)
                @sell_arm_times.delete(noun)
                false
              else
                armed = ticks[0].even?
                sell_lbl.markup = sell_markup(armed ? SELL_COLOR_ARMED : SELL_COLOR_IDLE)
                true
              end
            end
            sell_lbl.markup = sell_markup(SELL_COLOR_ARMED)
            @sell_timers[noun]    = timer_id
            @sell_arm_times[noun] = Time.now
          end
        end
        hbox.pack_start(sell_btn, expand: false, fill: false, padding: 0)
      end

      # Shop flag button (🏪) — opacity dims unflagged; CSS name gives gold border when flagged
      shop_lbl = Gtk::Label.new
      shop_lbl.markup = shop_markup
      shop_btn = Gtk::Button.new
      shop_btn.add(shop_lbl)
      shop_btn.relief = :none
      shop_btn.opacity = item[:shop_flagged] ? 1.0 : 0.35
      shop_btn.name    = item[:shop_flagged] ? 'shop_flagged' : ''
      shop_btn.set_tooltip_text(
        "Flag for shop export.\nGold border + bright = flagged; dim = unflagged."
      )
      shop_btn.signal_connect('clicked') do
        item[:shop_flagged] = !item[:shop_flagged]
        shop_btn.opacity = item[:shop_flagged] ? 1.0 : 0.35
        shop_btn.name    = item[:shop_flagged] ? 'shop_flagged' : ''
        dbg("Shop flag #{item[:shop_flagged] ? 'set' : 'cleared'}: #{item['name']}")
        save_state
      end
      hbox.pack_start(shop_btn, expand: false, fill: false, padding: 0)

      # Remove button (☠) — flashes red for 3s; second click removes item from list
      remove_uid = item['id'].to_s
      remove_lbl = Gtk::Label.new
      remove_lbl.markup = "<span foreground='#666666' size='large'>\u{2620}</span>"
      remove_btn = Gtk::Button.new
      remove_btn.add(remove_lbl)
      remove_btn.relief = :none
      remove_btn.set_tooltip_text(
        "Remove this item from the list.\n" \
        "Click once to arm (flashes red 3s). Click again to confirm.\n" \
        "Item will reappear if found in a subsequent Loresang!"
      )
      remove_btn.signal_connect('clicked') do
        if @remove_timers[remove_uid]
          # Second click — confirm remove (0.25s minimum wait)
          next if @remove_arm_times[remove_uid] && (Time.now - @remove_arm_times[remove_uid]) < 0.25
          GLib::Source.remove(@remove_timers[remove_uid])
          @remove_timers.delete(remove_uid)
          @remove_arm_times.delete(remove_uid)
          remove_lbl.markup = "<span foreground='#666666' size='large'>\u{2620}</span>"
          dbg("Remove confirmed: #{item['name']} (uid=#{remove_uid})")
          remove_sold_item(remove_uid)
        else
          # First click — arm with red flash
          dbg("Remove armed: #{item['name']} (uid=#{remove_uid})")
          ticks = [0]
          timer_id = GLib::Timeout.add(500) do
            ticks[0] += 1
            if ticks[0] > 6
              remove_lbl.markup = "<span foreground='#666666' size='large'>\u{2620}</span>"
              @remove_timers.delete(remove_uid)
              @remove_arm_times.delete(remove_uid)
              false
            else
              color = ticks[0].even? ? REMOVE_COLOR_ARMED : '#666666'
              remove_lbl.markup = "<span foreground='#{color}' size='large'>\u{2620}</span>"
              true
            end
          end
          remove_lbl.markup = "<span foreground='#{REMOVE_COLOR_ARMED}' size='large'>\u{2620}</span>"
          @remove_timers[remove_uid]    = timer_id
          @remove_arm_times[remove_uid] = Time.now
        end
      end
      hbox.pack_start(remove_btn, expand: false, fill: false, padding: 0)

      # Row highlight: draw a gold underline on the hbox when hovering any action button.
      # A tiny 80ms debounce prevents flicker when moving between adjacent buttons.
      hover_active = [false]
      set_hover    = -> { hbox.name = 'row_hover'; hover_active[0] = true }
      clear_hover  = -> {
        hover_active[0] = false
        GLib::Timeout.add(80) { hbox.name = '' unless hover_active[0]; false } rescue nil
      }
      [sell_btn, shop_btn, remove_btn].each do |btn|
        btn.signal_connect('enter-notify-event') { set_hover.call; false }
        btn.signal_connect('leave-notify-event')  { clear_hover.call; false }
      end

      # Recall detail area — hidden by default
      # no_show_all prevents @main_box.show_all from making it visible
      detail_frame = Gtk::Frame.new
      detail_frame.shadow_type  = :in
      detail_frame.margin_start  = 22
      detail_frame.margin_end    = 4
      detail_frame.margin_bottom = 4
      detail_frame.no_show_all = true
      detail_frame.visible = false

      recall_text = item['recall_text'].to_s.strip
      recall_lbl = Gtk::Label.new
      recall_lbl.markup =
        "<span foreground='white' font_family='monospace' size='small'>" \
        "#{pe(recall_text.empty? ? '(no recall data)' : recall_text)}</span>"
      recall_lbl.halign    = :start
      recall_lbl.wrap      = true
      recall_lbl.selectable = true
      recall_lbl.xalign    = 0.0
      recall_lbl.margin    = 6
      detail_frame.add(recall_lbl)
      recall_lbl.show  # pre-show so toggling the frame's visible flag reveals it
      row_vbox.pack_start(detail_frame, expand: false, fill: false, padding: 0)

      name_btn.signal_connect('clicked') do
        # Use visible= instead of show_all — no_show_all blocks show_all on self
        detail_frame.visible = !detail_frame.visible?
      end

      list.add(row)
      @row_data << { item: item, row: row }
    end

    def sell_markup(color)
      "<b><span foreground='#{color}' size='large'>$</span></b>"
    end

    def shop_markup
      # Emoji ignores Pango foreground= on Windows; use button.opacity for dim/bright instead
      "<span size='large'>#{SHOP_ICON}</span>"
    end

    def flash_not_found(icon_lbl)
      ticks = [0]
      GLib::Timeout.add(120) do
        ticks[0] += 1
        icon_lbl.markup = if ticks[0].odd?
          "<span background='#ff4444'> #{SEARCH_ICON} </span>"
        else
          "<span background='#{NOTFOUND_COLOR}'> #{SEARCH_ICON} </span>"
        end
        if ticks[0] >= 8
          icon_lbl.markup =
            "<span background='#{NOTFOUND_COLOR}'> #{SEARCH_ICON} </span>"
          GLib::Idle.add do
            dialog = Gtk::MessageDialog.new(
              parent: self, flags: :destroy_with_parent,
              type: :warning, buttons_type: :ok,
              message: "Item not found in inventory.\nCheck your lockers."
            )
            dialog.keep_above = true
            dialog.run
            dialog.destroy
            false
          end
          false
        else
          true
        end
      end
    end

    def filter_matches?(item)
      f = @filter
      unless f[:search].empty?
        return false unless item['name'].to_s.downcase.include?(f[:search]) ||
                            item['recall_text'].to_s.downcase.include?(f[:search])
      end
      if f[:enchantment_range]
        parts = f[:enchantment_range].split('-')
        if parts.length == 2
          low, high = parts[0].to_i, parts[1].to_i
          return false unless item['enchantment'].to_i.between?(low, high)
        end
      end
      if f[:weight]
        w = item['weight'].to_f
        case f[:weight]
        when 'under1' then return false unless w > 0 && w < 1
        when '1-5'    then return false unless w >= 1 && w <= 5
        when '6-10'   then return false unless w >= 6 && w <= 10
        when 'over10' then return false unless w > 10
        end
      end
      if f[:charges]
        has_charges = !item['charges'].nil?
        c = item['charges'].to_i
        case f[:charges]
        when '0'      then return false unless has_charges && c == 0
        when '1-4'    then return false unless has_charges && c.between?(1, 4)
        when '5-10'   then return false unless has_charges && c.between?(5, 10)
        when '11-20'  then return false unless has_charges && c.between?(11, 20)
        when 'over20' then return false unless has_charges && c > 20
        end
      end
      if f[:obj_type]
        # Prefer live inventory type (symbol key); fall back to recall-parsed type (string key)
        effective_type = item[:obj_type].to_s
        effective_type = item['obj_type'].to_s if effective_type.empty?
        return false unless effective_type.downcase == f[:obj_type].downcase
      end
      return false if f[:persistent]   && !item['persistent']
      return false if f[:disintegrate] && !item['disintegrate']
      return false if f[:spiked]       && !item['spiked']
      return false if f[:enhancive]    && !item['enhancive']
      return false if f[:crumbly]      && !item['crumbly']
      return false if f[:imbued]       && item['spell'].to_s.empty?
      if f[:value_min]
        v = item['value'].to_i
        return false if f[:value_dir] == :lte ? v > f[:value_min] : v < f[:value_min]
      end
      true
    end

    def schedule_rebuild
      GLib::Idle.add do
        rebuild_list
        false
      end
    end
    public :schedule_rebuild

    def rebuild_list
      @sell_timers.each { |_, tid| GLib::Source.remove(tid) rescue nil }
      @sell_timers.clear
      @sell_arm_times.clear
      @remove_timers.each { |_, tid| GLib::Source.remove(tid) rescue nil }
      @remove_timers.clear
      @remove_arm_times.clear
      build_item_list
    end

    def save_state
      @state['locked']          = @items.select { |i| i[:locked] }.map          { |i| i['id'] }
      @state['shop_flagged']    = @items.select { |i| i[:shop_flagged] }.map    { |i| i['id'] }
      @state['vendor_rejected'] = @items.select { |i| i[:vendor_rejected] }.map { |i| i['id'] }
      State.save(@state)
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Save error: #{e.message}")
    end

    def remove_sold_item(uid)
      # For skull-button manual removes — permanently blacklists the name-slug so
      # the item doesn't reappear on restart or future Loresang! runs.
      @items.reject! { |i| i['id'].to_s == uid }
      @state['removed'] ||= []
      @state['removed'] |= [uid]
      save_state
      rebuild_list
    end
    public :remove_sold_item

    def remove_sold_item_sold(uid)
      # For items that were actually sold at the pawnshop.  We only remove from the
      # current in-memory list without touching @state['removed'], so a new item with
      # the same name can appear normally in a future Loresang! run.
      @items.reject! { |i| i['id'].to_s == uid }
      rebuild_list
    end
    public :remove_sold_item_sold

    def save_options
      @state['options'] = @options
      State.save(@state)
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Options save error: #{e.message}")
    end

    def copy_shop_data
      flagged = @items.select { |i| i[:shop_flagged] }
      if flagged.empty?
        dialog = Gtk::MessageDialog.new(
          parent: self, flags: :destroy_with_parent,
          type: :info, buttons_type: :ok,
          message: "No items flagged for shop.\nClick the shop icon next to items to flag them."
        )
        dialog.keep_above = true
        dialog.run
        dialog.destroy
        return
      end

      begin
        html = build_shop_html(flagged)
      rescue => e
        Lich::Messaging.msg("yellow", "[Merchantical] HTML build error: #{e.message}")
        return
      end

      # ---- Export window (no markup= on any dynamic string) ----
      win = Gtk::Window.new
      win.title = "Shop Export -- #{flagged.count} item(s)"
      win.set_default_size(480, 300)
      win.transient_for = self
      win.set_window_position(:center_on_parent)
      win.keep_above = true

      vbox = Gtk::Box.new(:vertical, 8)
      vbox.margin = 14
      win.add(vbox)

      count_lbl = Gtk::Label.new("#{flagged.count} item(s) ready to export:")
      count_lbl.xalign = 0.0
      vbox.pack_start(count_lbl, expand: false, fill: false, padding: 0)

      # Item names in a plain read-only TextView — avoids all markup pitfalls
      tv = Gtk::TextView.new
      tv.editable    = false
      tv.wrap_mode   = :word_char
      tv.left_margin = 4
      tv.buffer.text = flagged.map { |i| "  \u2022 #{i['name']}" }.join("\n")
      name_scroll = Gtk::ScrolledWindow.new
      name_scroll.set_policy(:never, :automatic)
      name_scroll.add(tv)
      vbox.pack_start(name_scroll, expand: true, fill: true, padding: 0)

      # Path labels — plain text, no markup
      path_lbl = Gtk::Label.new("HTML: #{SHOP_EXPORT_FILE}")
      path_lbl.xalign = 0.0
      path_lbl.wrap   = true
      vbox.pack_start(path_lbl, expand: false, fill: false, padding: 0)

      docx_lbl = Gtk::Label.new("DOCX: #{SHOP_DOCX_FILE}")
      docx_lbl.xalign = 0.0
      docx_lbl.wrap   = true
      vbox.pack_start(docx_lbl, expand: false, fill: false, padding: 0)

      btn_row   = Gtk::Box.new(:horizontal, 6)
      vbox.pack_start(btn_row, expand: false, fill: false, padding: 2)

      save_btn  = Gtk::Button.new(label: "Save HTML")
      docx_btn  = Gtk::Button.new(label: "Save DOCX")
      open_btn  = Gtk::Button.new(label: "Open in Browser")
      dir_btn   = Gtk::Button.new(label: "Open Directory")
      close_btn = Gtk::Button.new(label: "Close")
      open_btn.sensitive = false

      docx_btn.set_tooltip_text(
        "For importing into Google Docs. Use Pageless mode under Page Setup."
      )

      btn_row.pack_start(save_btn,  expand: false, fill: false, padding: 0)
      btn_row.pack_start(docx_btn,  expand: false, fill: false, padding: 0)
      btn_row.pack_start(open_btn,  expand: false, fill: false, padding: 0)
      btn_row.pack_start(dir_btn,   expand: false, fill: false, padding: 0)
      btn_row.pack_start(close_btn, expand: false, fill: false, padding: 0)

      save_btn.signal_connect('clicked') do
        begin
          File.write(SHOP_EXPORT_FILE, html, encoding: 'UTF-8')
          save_btn.label = "Saved!"
          open_btn.sensitive = true
          path_lbl.text = "HTML: Saved to #{SHOP_EXPORT_FILE}"
          Lich::Messaging.msg("yellow", "[Merchantical] Shop HTML saved: #{SHOP_EXPORT_FILE}")
          GLib::Timeout.add(3000) { save_btn.label = "Save HTML" rescue nil; false }
        rescue => e
          Lich::Messaging.msg("yellow", "[Merchantical] Save error: #{e.message}")
        end
      end

      docx_btn.signal_connect('clicked') do
        docx_btn.label     = "Building..."
        docx_btn.sensitive = false
        Thread.new do
          ok = build_shop_docx(flagged)
          Gtk.queue do
            if ok
              docx_btn.label = "Saved!"
              docx_lbl.text  = "DOCX: Saved to #{SHOP_DOCX_FILE}"
              Lich::Messaging.msg("yellow", "[Merchantical] Shop DOCX saved: #{SHOP_DOCX_FILE}")
            else
              docx_btn.label = "DOCX Failed"
              docx_lbl.text  = "DOCX: Export failed — check game window for details"
            end
            docx_btn.sensitive = true
            GLib::Timeout.add(4000) { docx_btn.label = "Save DOCX" rescue nil; false }
          end rescue nil
        end
      end

      open_btn.signal_connect('clicked') do
        begin
          native_path = SHOP_EXPORT_FILE.tr('/', '\\')
          Thread.new { system("start \"\" \"#{native_path}\"") }
        rescue => e
          Lich::Messaging.msg("yellow", "[Merchantical] Browser open error: #{e.message}")
        end
      end

      dir_btn.signal_connect('clicked') do
        begin
          native_dir = File.dirname(SHOP_EXPORT_FILE).tr('/', '\\')
          Thread.new { system("explorer \"#{native_dir}\"") }
        rescue => e
          Lich::Messaging.msg("yellow", "[Merchantical] Directory open error: #{e.message}")
        end
      end

      close_btn.signal_connect('clicked') { win.destroy }
      win.signal_connect('delete-event') { win.destroy; false }
      win.show_all
    end

    # Escape a string for safe inclusion in HTML content/attributes
    def mc_he(str)
      str.to_s
         .gsub('&', '&amp;')
         .gsub('<', '&lt;')
         .gsub('>', '&gt;')
         .gsub('"', '&quot;')
    end

    # Returns [[type_label, [items...]], ...] sorted by KNOWN_OBJ_TYPES order, "Other" last.
    def group_items_by_type(flagged)
      known_order = Merchantical::KNOWN_OBJ_TYPES
      groups = {}
      flagged.each do |i|
        t = i[:obj_type].to_s
        t = i['obj_type'].to_s if t.empty?
        t = 'other' if t.empty?
        (groups[t] ||= []) << i
      end
      sorted_keys = groups.keys.sort_by { |k| [known_order.index(k) || 999, k] }
      sorted_keys.map do |k|
        label = k == 'other' ? 'Other' : k.split.map(&:capitalize).join(' ')
        [label, groups[k]]
      end
    end

    # Returns an array of human-readable metadata strings for one item.
    def item_meta_parts(item)
      parts = []
      if item['value'].to_i > 0
        fv = item['value'].to_i.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\1,').reverse
        parts << "~#{fv} silvers"
      end
      parts << "+#{item['enchantment']}" if item['enchantment'].to_i > 0
      parts << "#{item['weight']} lbs"   if item['weight'].to_f > 0
      parts << "#{item['charges']} charges" unless item['charges'].nil?
      sp = item['spell'].to_s
      parts << "[#{sp}]" if sp != '' && sp != 'none'
      parts << "Persistent"   if item['persistent']
      parts << "Disintegrate" if item['disintegrate']
      parts << "Spiked"       if item['spiked']
      parts << "Enhancive"    if item['enhancive']
      parts << "Crumbly"      if item['crumbly']
      parts
    end

    def build_shop_html(flagged)
      date   = Time.now.strftime('%Y-%m-%d')
      char   = XMLData.name.to_s
      groups = group_items_by_type(flagged)

      sections_html = groups.map do |type_label, items|
        item_blocks = items.map do |item|
          name   = mc_he(item['name'].to_s)
          recall = mc_he(item['recall_text'].to_s.strip)
          recall = "(No recall data available.)" if recall.empty?

          parts     = item_meta_parts(item)
          meta_html = parts.empty? ? '' :
            "<span class='meta'>#{parts.map { |p| mc_he(p) }.join(' &nbsp;&middot;&nbsp; ')}</span>"

          # data-search holds lowercased name+recall for JS filtering (HTML-encoded so quotes are safe)
          search_text = mc_he((item['name'].to_s + ' ' + item['recall_text'].to_s).downcase)

          "  <details data-search=\"#{search_text}\">\n" \
          "    <summary>\n" \
          "      <h2 class='iname'>#{name}</h2>\n" \
          "      #{meta_html}\n" \
          "    </summary>\n" \
          "    <div class='recall'>#{recall}</div>\n" \
          "  </details>"
        end.join("\n")

        "<section class='type-section'>\n" \
        "  <h1 class='type-header'>#{mc_he(type_label)}</h1>\n" \
        "#{item_blocks}\n" \
        "</section>"
      end.join("\n\n")

      char_esc = mc_he(char)
      cnt      = flagged.count
      plural   = cnt == 1 ? '' : 's'

      "<!DOCTYPE html>\n" \
      "<html lang=\"en\">\n" \
      "<head>\n" \
      "  <meta charset=\"UTF-8\">\n" \
      "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n" \
      "  <title>#{char_esc} &mdash; Shop Inventory</title>\n" \
      "  <style>\n" \
      "    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n" \
      "    body {\n" \
      "      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;\n" \
      "      background: #1a1a1a; color: #d0d0d0;\n" \
      "      max-width: 860px; margin: 0 auto; padding: 28px 18px 60px;\n" \
      "    }\n" \
      "    .page-title { color: #d4af37; font-size: 1.5em; margin-bottom: 4px; }\n" \
      "    .subtitle { color: #666; font-size: 0.82em; margin-bottom: 22px; }\n" \
      "    .type-section { margin-top: 28px; }\n" \
      "    h1.type-header {\n" \
      "      color: #d4af37; font-size: 1.25em; font-weight: 700;\n" \
      "      border-bottom: 1px solid #333; padding-bottom: 4px; margin-bottom: 8px;\n" \
      "    }\n" \
      "    details {\n" \
      "      margin: 5px 0; border: 1px solid #2c2c2c; border-radius: 6px;\n" \
      "      background: #1e1e1e; overflow: hidden;\n" \
      "    }\n" \
      "    summary {\n" \
      "      display: flex; align-items: baseline; flex-wrap: wrap; gap: 8px;\n" \
      "      padding: 11px 14px; cursor: pointer; background: #242424;\n" \
      "      user-select: none; list-style: none;\n" \
      "    }\n" \
      "    summary::-webkit-details-marker { display: none; }\n" \
      "    summary::before {\n" \
      "      content: '\\25B6'; color: #d4af37; font-size: 0.7em;\n" \
      "      flex-shrink: 0; transition: transform 0.15s; margin-right: 2px; align-self: center;\n" \
      "    }\n" \
      "    details[open] > summary::before { transform: rotate(90deg); }\n" \
      "    summary:hover { background: #2a2a2a; }\n" \
      "    h2.iname { display: inline; margin: 0; padding: 0; font-size: 1em; font-weight: 600; color: #e8e8e8; }\n" \
      "    .meta { font-size: 0.8em; color: #7aabcc; }\n" \
      "    .recall {\n" \
      "      padding: 11px 16px 13px;\n" \
      "      font-family: 'Consolas', 'Courier New', monospace;\n" \
      "      font-size: 0.875em; line-height: 1.6; color: #c0c0c0;\n" \
      "      border-top: 1px solid #282828; white-space: pre-wrap;\n" \
      "      background: #181818;\n" \
      "    }\n" \
      "    footer { margin-top: 30px; font-size: 0.72em; color: #3a3a3a; text-align: center; }\n" \
      "    .search-wrap { margin-bottom: 20px; }\n" \
      "    #mc-search {\n" \
      "      width: 100%; padding: 9px 14px; background: #242424; color: #d0d0d0;\n" \
      "      border: 1px solid #3a3a3a; border-radius: 6px;\n" \
      "      font-size: 0.95em; outline: none;\n" \
      "    }\n" \
      "    #mc-search:focus { border-color: #d4af37; }\n" \
      "    #mc-search::placeholder { color: #555; }\n" \
      "    .no-results { color: #555; font-size: 0.9em; margin-top: 18px; display: none; }\n" \
      "  </style>\n" \
      "</head>\n" \
      "<body>\n" \
      "  <p class=\"page-title\">#{char_esc}'s Shop Inventory</p>\n" \
      "  <p class=\"subtitle\">#{cnt} item#{plural} &nbsp;&middot;&nbsp; #{date}" \
        " &nbsp;&middot;&nbsp; Click any item to expand recall details</p>\n" \
      "  <div class=\"search-wrap\">\n" \
      "    <input id=\"mc-search\" type=\"search\" autocomplete=\"off\"\n" \
      "           placeholder=\"Search item names and recall text&hellip;\">\n" \
      "  </div>\n" \
      "  <p class=\"no-results\" id=\"mc-noresults\">No items match your search.</p>\n\n" \
      "#{sections_html}\n\n" \
      "  <footer>Exported from Merchantical &middot; Gemstone IV</footer>\n" \
      "  <script>\n" \
      "    (function() {\n" \
      "      var inp      = document.getElementById('mc-search');\n" \
      "      var noRes    = document.getElementById('mc-noresults');\n" \
      "      var sections = document.querySelectorAll('.type-section');\n" \
      "      inp.addEventListener('input', function() {\n" \
      "        var q = this.value.toLowerCase();\n" \
      "        var totalVisible = 0;\n" \
      "        sections.forEach(function(sec) {\n" \
      "          var items = sec.querySelectorAll('details');\n" \
      "          var secVisible = 0;\n" \
      "          items.forEach(function(d) {\n" \
      "            var match = !q || d.dataset.search.indexOf(q) !== -1;\n" \
      "            d.style.display = match ? '' : 'none';\n" \
      "            if (match) secVisible++;\n" \
      "          });\n" \
      "          sec.style.display = secVisible > 0 ? '' : 'none';\n" \
      "          totalVisible += secVisible;\n" \
      "        });\n" \
      "        noRes.style.display = (q && totalVisible === 0) ? 'block' : 'none';\n" \
      "      });\n" \
      "    })();\n" \
      "  </script>\n" \
      "</body>\n" \
      "</html>\n"
    end


    # Generate Google-Docs-friendly HTML (inline styles only, no details/summary,
    # item name + meta on one line, recall split to one sentence per <p>).
    def build_shop_docx(flagged)
      date   = Time.now.strftime('%Y-%m-%d')
      char   = mc_he(XMLData.name.to_s)
      groups = group_items_by_type(flagged)
      cnt    = flagged.count
      plural = cnt == 1 ? '' : 's'

      sections = groups.map do |type_label, items|
        item_blocks = items.map do |item|
          name      = mc_he(item['name'].to_s)
          parts     = item_meta_parts(item)
          meta_text = mc_he(parts.join(" \u00B7 "))
          meta_span = parts.empty? ? '' :
            " <span style=\"font-size:8pt; font-weight:normal; color:#336699\">#{meta_text}</span>"

          recall_lines = item['recall_text'].to_s.strip.split(/\n+/).reject(&:empty?)
          recall_lines = ['(No recall data available.)'] if recall_lines.empty?
          recall_paras = recall_lines.map { |l|
            "<p style=\"margin:1px 0 1px 1.5em; font-size:8pt; " \
            "font-family:Consolas,monospace; color:#555555\">#{mc_he(l)}</p>"
          }.join("\n")

          "<h2 style=\"font-size:10pt; font-weight:bold; margin:8px 0 1px\">" \
          "#{name}#{meta_span}</h2>\n#{recall_paras}"
        end.join("\n")

        type_h1_style = "font-size:12pt; color:#8B6914; border-bottom:1px solid #cccccc; " \
                        "margin:18px 0 4px; padding-bottom:2px"
        "<h1 style=\"#{type_h1_style}\">#{mc_he(type_label)}</h1>\n#{item_blocks}"
      end.join("\n\n")

      html = "<!DOCTYPE html>\n" \
             "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n" \
             "<title>#{char}'s Shop Inventory</title>\n</head>\n<body " \
             "style=\"font-family:Arial,sans-serif; max-width:860px; margin:0 auto; padding:20px\">\n" \
             "<h1 style=\"font-size:14pt; color:#8B6914\">#{char}'s Shop Inventory</h1>\n" \
             "<p style=\"font-size:9pt; color:#888888\">#{cnt} item#{plural} \u00B7 #{date}</p>\n\n" \
             "#{sections}\n</body>\n</html>\n"

      File.write(SHOP_DOCX_FILE, html, encoding: 'UTF-8')
      true
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] DOCX save error: #{e.message}")
      nil
    end

    def show_gear
      gear_win = Gtk::Window.new
      gear_win.title = "Merchantical - Settings"
      gear_win.set_default_size(580, 660)
      gear_win.transient_for = self
      gear_win.set_window_position(:center_on_parent)
      gear_win.keep_above = true

      outer = Gtk::Box.new(:vertical, 0)
      gear_win.add(outer)

      notebook = Gtk::Notebook.new
      outer.pack_start(notebook, expand: true, fill: true, padding: 0)

      # ---- Options tab ----
      opt_scroll = Gtk::ScrolledWindow.new
      opt_scroll.hscrollbar_policy = :never
      opt_scroll.vscrollbar_policy = :automatic
      opt_vbox = Gtk::Box.new(:vertical, 8)
      opt_vbox.margin = 14
      opt_scroll.add(opt_vbox)

      use_locker_cb = Gtk::CheckButton.new("Use locker?")
      use_locker_cb.active = @options['use_locker'] || false
      use_locker_cb.set_tooltip_text(
        "On startup, go to your locker and look in listed bags to match inventory."
      )
      use_locker_cb.signal_connect('toggled') do
        @options['use_locker'] = use_locker_cb.active?
        save_options
      end
      opt_vbox.pack_start(use_locker_cb, expand: false, fill: false, padding: 0)

      always_on_top_cb = Gtk::CheckButton.new("Window always on top")
      always_on_top_cb.active = @options['always_on_top'] || false
      always_on_top_cb.set_tooltip_text("Keep the Merchantical window above all other windows")
      always_on_top_cb.signal_connect('toggled') do
        @options['always_on_top'] = always_on_top_cb.active?
        self.keep_above = always_on_top_cb.active?
        save_options
      end
      opt_vbox.pack_start(always_on_top_cb, expand: false, fill: false, padding: 0)

      lr_hbox = Gtk::Box.new(:horizontal, 6)
      lr_hbox.pack_start(Gtk::Label.new("Locker room #:"), expand: false, fill: false, padding: 0)
      locker_entry = Gtk::Entry.new
      locker_entry.width_request = 100
      locker_entry.text = @options['locker_room'].to_s
      locker_entry.set_tooltip_text("Room number for your locker")
      locker_entry.signal_connect('changed') do
        @options['locker_room'] = locker_entry.text.strip
        save_options
      end
      lr_hbox.pack_start(locker_entry, expand: false, fill: false, padding: 0)
      set_locker_btn = Gtk::Button.new(label: "Get current room #")
      set_locker_btn.set_tooltip_text("Click to use current room number")
      set_locker_btn.signal_connect('clicked') do
        room_num = ((Map.current_room_id rescue nil) || XMLData.room_id).to_s
        unless room_num.empty?
          locker_entry.text = room_num
          @options['locker_room'] = room_num
          save_options
        end
      end
      lr_hbox.pack_start(set_locker_btn, expand: false, fill: false, padding: 0)
      opt_vbox.pack_start(lr_hbox, expand: false, fill: false, padding: 0)

      opt_vbox.pack_start(
        Gtk::Separator.new(:horizontal), expand: false, fill: false, padding: 4
      )

      bags_hdr = Gtk::Label.new
      bags_hdr.markup = "<b>Locker Bags</b>"
      bags_hdr.halign = :start
      opt_vbox.pack_start(bags_hdr, expand: false, fill: false, padding: 0)
      bags_note = Gtk::Label.new(
        "Enter the best descript name of each bag in your locker. The script will\n" \
        "look inside them during a locker inventory search. Do not use short names"
      )
      bags_note.halign = :start
      bags_note.wrap   = true
      bags_note.xalign = 0.0
      opt_vbox.pack_start(bags_note, expand: false, fill: false, padding: 0)

      @options['bags'] ||= Array.new(5, '')
      5.times do |i|
        bag_hbox = Gtk::Box.new(:horizontal, 6)
        bag_hbox.pack_start(Gtk::Label.new("Bag #{i + 1}:"), expand: false, fill: false, padding: 0)
        bag_entry = Gtk::Entry.new
        bag_entry.text = @options['bags'][i].to_s
        bag_entry.width_request = 300
        bag_entry.set_placeholder_text("e.g. black bag, blue rucksack")
        bag_entry.signal_connect('changed') do
          @options['bags'][i] = bag_entry.text.strip
          save_options
        end
        bag_hbox.pack_start(bag_entry, expand: false, fill: false, padding: 0)
        opt_vbox.pack_start(bag_hbox, expand: false, fill: false, padding: 0)
      end

      opt_vbox.pack_start(
        Gtk::Separator.new(:horizontal), expand: false, fill: false, padding: 4
      )

      debug_cb = Gtk::CheckButton.new("Debug mode")
      debug_cb.active = @options['debug'] || false
      debug_cb.set_tooltip_text(
        "Enables extra diagnostic output to the game window.\n" \
        "Useful for troubleshooting sell, validate, or locker issues."
      )
      debug_cb.signal_connect('toggled') do
        @options['debug'] = debug_cb.active?
        save_options
        schedule_rebuild
      end
      opt_vbox.pack_start(debug_cb, expand: false, fill: false, padding: 0)

      notebook.append_page(opt_scroll, Gtk::Label.new("Options"))

      # ---- About tab ----
      about_scroll = Gtk::ScrolledWindow.new
      about_scroll.hscrollbar_policy = :never
      about_scroll.vscrollbar_policy = :automatic

      about_vbox = Gtk::Box.new(:vertical, 10)
      about_vbox.margin = 16
      about_scroll.add(about_vbox)

      about_title = Gtk::Label.new
      about_title.markup = "<b>Merchantical - Help &amp; About</b>"
      about_title.halign = :start
      about_vbox.pack_start(about_title, expand: false, fill: false, padding: 0)

      help_text = <<~TXT
        Usage:
          * Click an item name to expand/collapse its full recall text
          * Check the lock box to mark & lock (sends 'mark <noun>' to game)
          * Unlocking sends 'mark <noun> remove' to clear the in-game mark
          * Click $ once to arm sell (flashes blue); click again within 3s to confirm
          * Click #{SHOP_ICON} to flag items for Copy Shop Data export
          * #{SEARCH_ICON} green = found in current inventory;  red = not found
          * Use the filter bar and search box to narrow the item list
          * Locked and filter-matching items sort to the top
          * #{LOCKER_ICON} items can be sold directly from the locker when validated
          * Blue name = previously unlocked item.  Green = newly lore-unlocked

        ──────────────────────────────────────────────────────────────

        Bugs, missing features, or suggestions?
        Contact: EducatedBarbarian@proton.me

        My other scripts:
          * Loresang      - You're already using it
          * VolnRestore2  - Automatic Voln Symbol of Restoration safetynet
          * Combatical    - The world's premier ability management tool.
                            Never forget your powers again.

        Thanks for using Merchantical!
        If you find it useful -- spread the word!
      TXT

      help_tv = Gtk::TextView.new
      help_tv.editable    = false
      help_tv.cursor_visible = false
      help_tv.wrap_mode   = :word
      help_tv.left_margin = 4
      help_tv.monospace   = true if help_tv.respond_to?(:monospace=)
      help_tv.buffer.text = help_text
      about_vbox.pack_start(help_tv, expand: false, fill: false, padding: 0)

      notebook.append_page(about_scroll, Gtk::Label.new("About"))

      close_btn = Gtk::Button.new(label: "Close")
      close_btn.signal_connect('clicked') { gear_win.destroy }
      outer.pack_end(close_btn, expand: false, fill: false, padding: 6)

      gear_win.show_all
    end
  end

  # ---------------------------------------------------------------------------
  # App
  # ---------------------------------------------------------------------------
  class App
    def initialize
      @cmd_queue = Queue.new
      @running   = true
      @items     = []
      @state     = State.load
    end

    def run
      @items = if File.exist?(ITEMS_FILE)
                 Lich::Messaging.msg("yellow", "[Merchantical] Loading previous loresang data...")
                 begin
                   loaded = JSON.parse(File.read(ITEMS_FILE))
                   # Back-fill obj_type for items saved before noun-regex was added
                   loaded.each do |item|
                     if item['obj_type'].to_s.empty?
                       item['obj_type'] = Parser.parse_obj_type(
                         item['recall_text'].to_s, item['name'].to_s
                       )
                     end
                   end
                   Lich::Messaging.msg("yellow", "[Merchantical] Loaded #{loaded.count} item(s) from cache.")
                   loaded
                 rescue => e
                   Lich::Messaging.msg("yellow", "[Merchantical] Cache load error: #{e.message}")
                   []
                 end
               elsif File.exist?(HTML_FILE)
                 Lich::Messaging.msg("yellow", "[Merchantical] Loading previous loresang data (HTML)...")
                 Parser.extract_items(File.read(HTML_FILE))
               else
                 Lich::Messaging.msg("yellow", "[Merchantical] No loresang data -- starting empty.")
                 Lich::Messaging.msg("yellow", "[Merchantical] Click #{"\u{1F3B6}"} Loresang! to load items.")
                 []
               end

      removed_ids = @state['removed']       || []
      @items.reject! { |i| removed_ids.include?(i['id']) }

      locked_ids   = @state['locked']          || []
      flagged_ids  = @state['shop_flagged']    || []
      rejected_ids = @state['vendor_rejected'] || []
      @items.each do |item|
        item[:locked]          = locked_ids.include?(item['id'])
        item[:shop_flagged]    = flagged_ids.include?(item['id'])
        item[:vendor_rejected] = rejected_ids.include?(item['id'])
      end

      # Quick pre-match from cached GameObj state (no game commands needed).
      # Press Validate to do a full scan including worn containers and locker.
      match_inventory_items(@items)

      unless defined?(Gtk) && Gtk.respond_to?(:queue)
        Lich::Messaging.msg("yellow", "[Merchantical] GTK3 not available.")
        return
      end

      Thread.new do
        Gtk.queue do
          @window = MainWindow.new(@items, @cmd_queue, -> { @running = false }, @state)
          @window.show_all
        end
      end

      while @running
        task = begin; @cmd_queue.pop(true); rescue ThreadError; nil; end
        if task
          if    task[:sell_item]      then do_sell(task[:sell_item])
          elsif task[:mark_item]      then do_mark_item(task[:mark_item])
          elsif task[:unmark_item]    then do_unmark_item(task[:unmark_item])
          elsif task[:run_loresang]   then start_loresang_with_capture
          elsif task[:validate_items] then do_validate_items
          elsif task[:probe_item]     then do_probe_item(task[:probe_item])
          elsif task[:batch_sell]     then do_batch_sell(task[:batch_sell])
          end
        else
          pause 0.1
        end
      end

      save_final_state
      Lich::Messaging.msg("yellow", "[Merchantical] Window closed. State saved.")
    end

    private

    def match_inventory_items(items)
      return if items.empty?

      # Build pairs of [GameObj, container_id_or_nil] from current Lich inventory state.
      inv_pairs = []
      begin
        GameObj.inv.to_a.each { |gi| inv_pairs << [gi, nil] }
        if GameObj.respond_to?(:containers)
          GameObj.containers.each do |cid, contents|
            contents.to_a.each { |gi| inv_pairs << [gi, cid.to_s] }
          end
        end
      rescue => e
        Lich::Messaging.msg("yellow", "[Merchantical] Inventory scan error: #{e.message}")
      end

      # Track which GameObj IDs have already been matched so two loresang items with the
      # same noun (e.g. two stickpins) don't both match the same GameObj entry.
      used_ids = {}

      items.each do |item|
        item_name = item['name'].to_s.downcase.strip
        # Strip leading article so "a vultite claidhmore" == "vultite claidhmore"
        bare_name  = item_name.sub(/\A(?:a |an |the )/, '')
        item_noun  = item['noun'].to_s.downcase.strip

        # Three separate find passes in strict priority order.
        # MUST be separate calls — NOT combined with ||.  Array#find returns the first
        # element satisfying any condition, so combining them lets an earlier same-noun
        # item (e.g. worn "white opal inset silver clasp") steal the match before a
        # correct full-name match ("garnet clasp") further down the array.

        # Pass 1: exact full-name match.
        # GS4 sends the full adjective+noun name in <inv><a> tags so this reliably
        # distinguishes same-noun items like worn jewelry from loot to sell.
        pair = inv_pairs.find { |gi, _|
          next if used_ids[gi.id]
          gn  = gi.name.to_s.downcase.strip
          bgn = gn.sub(/\A(?:a |an |the )/, '')
          gn == item_name || bgn == bare_name
        }

        # Pass 2: bidirectional multi-word suffix match.
        # Handles two common loresang/GameObj name length mismatches:
        #   A) GameObj name shorter: bgn "garnet band" is a suffix of loresang "green garnet band"
        #   B) GameObj name longer:  loresang "green garnet band" is a suffix of
        #                            GameObj "pewter and green garnet band"
        # Requiring at least two words in one side prevents bare-noun "band" from stealing
        # same-noun worn items before the correct name is found in a container.
        pair ||= inv_pairs.find { |gi, _|
          next if used_ids[gi.id]
          bgn = gi.name.to_s.downcase.strip.sub(/\A(?:a |an |the )/, '')
          (bgn.include?(' ') && bare_name =~ /(?:\A|\s)#{Regexp.escape(bgn)}\z/) ||
          (bare_name.include?(' ') && bgn =~ /(?:\A|\s)#{Regexp.escape(bare_name)}\z/)
        }

        # Pass 3: noun-only — last resort when no name data distinguishes items.
        pair ||= inv_pairs.find { |gi, _|
          next if used_ids[gi.id]
          gi_noun = gi.noun.to_s.downcase.strip
          !item_noun.empty? && !gi_noun.empty? && gi_noun == item_noun
        }

        if pair
          gi, cid = pair
          used_ids[gi.id] = true
          item[:found]        = true
          item[:gameobj_id]   = gi.id.to_s
          item[:container_id] = cid
          # Full name from GameObj (e.g. "engraved mithril stickpin") — used for display only,
          # so same-noun items like two different stickpins show their distinguishing adjectives.
          item[:gameobj_name] = gi.name.to_s.sub(/\A(?:a |an |the )/i, '').strip
          live_type   = (gi.type.to_s rescue '')
          parsed_type = item['obj_type'].to_s
          normalized_live = case live_type.downcase
                            when /weapon/     then 'weapon'
                            when /armor/      then 'armor'
                            when /shield/     then 'shield'
                            when /jewelry/    then 'jewelry'
                            when /magic.item/ then 'magic item'
                            when /container/  then 'container'
                            when /clothing/   then 'clothing'
                            when /\bgem\b/    then 'gem'
                            when /scroll/     then 'scroll'
                            when /\bwand\b/   then 'wand'
                            when /potion/     then 'potion'
                            else live_type
                            end
          item[:obj_type] = if parsed_type == 'container'
                              'container'
                            elsif normalized_live.empty?
                              parsed_type
                            else
                              normalized_live
                            end
        else
          item[:found]        = false
          item[:gameobj_id]   = nil
          item[:container_id] = nil
          item[:obj_type]     = item['obj_type'].to_s
          item[:gameobj_name] = nil  # clear stale name so display falls back to loresang name
        end
      end
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Inventory match error: #{e.message}")
    end

    def do_validate_items
      Lich::Messaging.msg("yellow", "[Merchantical] Validating #{@items.count} item(s)...")

      # Show what Lich currently sees in inventory before matching
      begin
        inv_items = GameObj.inv.to_a
        con_items = GameObj.respond_to?(:containers) ?
          GameObj.containers.values.flat_map(&:to_a) : []
        Lich::Messaging.msg("yellow",
          "[Merchantical] GameObj: #{inv_items.count} top-level, #{con_items.count} in-container.")
        # Show top-level names so name-mismatch is visible
        if inv_items.any?
          names = inv_items.map { |gi| gi.name.to_s }.first(8).join(", ")
          Lich::Messaging.msg("yellow", "[Merchantical] Inv names: #{names}")
        end
      rescue => e
        Lich::Messaging.msg("yellow", "[Merchantical] GameObj read error: #{e.message}")
      end

      @items.each { |i| i[:in_locker] = false }

      # Look into every worn container so Lich populates GameObj.containers with
      # their contents. Items inside cloaks, backpacks, pouches etc. are invisible
      # to GameObj until an explicit 'look in' is issued.
      begin
        GameObj.inv.to_a.each do |gi|
          if gi.type.to_s =~ /container/i
            fput "look in ##{gi.id}"
            waitrt?
            pause 0.3
          end
        end
      rescue => e
        Lich::Messaging.msg("yellow", "[Merchantical] Worn container scan error: #{e.message}")
      end

      match_inventory_items(@items)

      options = @state['options'] || {}
      if options['use_locker'] && !options['locker_room'].to_s.empty?
        Lich::Messaging.msg("yellow", "[Merchantical] Checking locker...")
        search_locker(options)
      else
        Lich::Messaging.msg("yellow",
          "[Merchantical] Locker check skipped (not configured -- see Settings > Use locker?).")
      end

      found_count  = @items.count { |i| i[:found] }
      locker_count = @items.count { |i| i[:in_locker] }
      Lich::Messaging.msg("yellow",
        "[Merchantical] Validation complete -- #{found_count}/#{@items.count} item(s) found" \
        "#{locker_count > 0 ? ", #{locker_count} in locker" : ""}.")

      if found_count == 0 && @items.any?
        Lich::Messaging.msg("yellow",
          "[Merchantical] No items matched. Check: are items in your hands/inventory?" \
          " If in containers, open them once so Lich can see the contents.")
      end

      Gtk.queue { @window&.refresh_found_state } rescue nil
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Validate error: #{e.message}\n#{e.backtrace.first(2).join("\n")}")
    end

    def do_probe_item(info)
      name         = info[:name].to_s
      noun         = info[:noun].to_s.downcase.strip
      stored_id    = info[:stored_id].to_s
      container_id = info[:container_id].to_s
      bare_name    = name.downcase.strip.sub(/\A(?:a |an |the )/, '')
      name_dc      = name.downcase.strip

      # If the item lives in a worn container, refresh that container's contents first.
      unless container_id.empty?
        fput "look in ##{container_id}"
        waitrt?
        pause 0.3
      end

      # Fresh lookup — same three-pass priority as match_inventory_items.
      live_gi = nil
      if !container_id.empty?
        contents = (GameObj.containers.find { |cid, _| cid.to_s == container_id }&.last || []).to_a rescue []
        live_gi  = contents.find { |gi|
          gn  = gi.name.to_s.downcase.strip
          bgn = gn.sub(/\A(?:a |an |the )/, '')
          gn == name_dc || bgn == bare_name
        }
        live_gi ||= contents.find { |gi|
          bgn = gi.name.to_s.downcase.strip.sub(/\A(?:a |an |the )/, '')
          (bgn.include?(' ') && bare_name =~ /(?:\A|\s)#{Regexp.escape(bgn)}\z/) ||
          (bare_name.include?(' ') && bgn =~ /(?:\A|\s)#{Regexp.escape(bare_name)}\z/)
        }
        live_gi ||= contents.find { |gi| gi.noun.to_s.downcase.strip == noun }
      else
        gi_list = GameObj.inv.to_a rescue []
        live_gi = gi_list.find { |gi|
          gn  = gi.name.to_s.downcase.strip
          bgn = gn.sub(/\A(?:a |an |the )/, '')
          gn == name_dc || bgn == bare_name
        }
        live_gi ||= gi_list.find { |gi|
          bgn = gi.name.to_s.downcase.strip.sub(/\A(?:a |an |the )/, '')
          (bgn.include?(' ') && bare_name =~ /(?:\A|\s)#{Regexp.escape(bgn)}\z/) ||
          (bare_name.include?(' ') && bgn =~ /(?:\A|\s)#{Regexp.escape(bare_name)}\z/)
        }
        live_gi ||= gi_list.find { |gi| gi.noun.to_s.downcase.strip == noun }
      end

      live_id = live_gi ? live_gi.id.to_s : "NOT_FOUND"
      match   = live_id == stored_id ? "OK" : "MISMATCH"
      Lich::Messaging.msg("yellow",
        "[Merchantical DBG] #{name}: #{live_id} | #{stored_id}  [#{match}]")
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical DBG] Probe error: #{e.message}")
    end

    def do_batch_sell(item_ids)
      items_to_sell = @items.select { |i| item_ids.include?(i['id']) }
      regular_items = items_to_sell.reject { |i| i[:in_locker] }.select { |i| i[:found] && i[:gameobj_id] }
      locker_items  = items_to_sell.select  { |i| i[:in_locker] }

      if regular_items.empty? && locker_items.empty?
        Lich::Messaging.msg("yellow", "[Merchantical] Batch sell: nothing validated to sell.")
        return
      end

      origin_room = ((Map.current_room_id rescue nil) || XMLData.room_id).to_s
      options     = @state['options'] || {}
      locker_room = options['locker_room'].to_s

      Lich::Messaging.msg("yellow",
        "[Merchantical] Batch sell: #{regular_items.count} regular, #{locker_items.count} locker item(s).")

      # Reusable: send one sell attempt for item already in hand, return [sold, note_offer, refused].
      # fput handles roundtime; DownstreamHook captures the broker response before fput returns.
      sell_one = lambda do |item_id, item_uid|
        lines = []; pawnbroker_refused = [false]
        hk = "mc_bs_#{Thread.current.object_id}_#{item_uid}"
        DownstreamHook.add(hk, proc { |s|
          lines << s.to_s
          if s =~ /hands it back|not interested|can.t say|interested in that|
                    worthless|wouldn.t give|find a buyer|no\s+thank|
                    can.t\s+(accept|use|buy)|don.t\s+want|shakes.*head/xi
            pawnbroker_refused[0] = true
          end
          s
        })
        fput "sell ##{item_id}"
        DownstreamHook.remove(hk) rescue nil

        note_offer = lines.any? { |l| l =~ /25[,.]?000\s*silver|note\s+worth\s+25/i }
        if note_offer
          Lich::Messaging.msg("yellow", "[Merchantical] 25k cap — confirming sale...")
          lines2 = []; refused2 = [false]
          hk2 = "mc_bs2_#{Thread.current.object_id}_#{item_uid}"
          DownstreamHook.add(hk2, proc { |s|
            lines2 << s.to_s
            refused2[0] = true if s =~ /hands it back|not interested|can.t say/i
            s
          })
          fput "sell ##{item_id}"
          DownstreamHook.remove(hk2) rescue nil
          lines = lines2
          pawnbroker_refused[0] = refused2[0]
        end

        sold = lines.any? { |l| l =~ /pawnbroker takes.*hands you|hands you \d+\s*silver|handed? you \d+/i }
        [sold, note_offer, pawnbroker_refused[0]]
      end

      # Navigate to pawnshop lazily — only when we actually have something to sell there.
      at_pawnshop = (XMLData.room_description || "").downcase.include?("pawnshop")
      go_to_pawnshop = lambda do
        return if at_pawnshop
        start_script("go2", ["pawnshop"])
        while running?("go2"); pause 0.5; end
        waitrt?
        at_pawnshop = true
      end

      # -----------------------------------------------------------------------
      # Regular inventory items
      # -----------------------------------------------------------------------
      regular_items.each do |item|
        item_id      = item[:gameobj_id]
        container_id = item[:container_id]
        name         = item['name'].to_s
        item_uid     = item['id'].to_s

        if container_id
          fput "get ##{item_id} from ##{container_id}"
        else
          fput "get ##{item_id}"
        end
        waitrt?

        go_to_pawnshop.call
        sold, note_offer, truly_rejected = sell_one.call(item_id, item_uid)
        waitrt?

        if sold
          msg = "[Merchantical] Batch: sold #{name}!"
          msg += " Check hands for a bank note." if note_offer
          Lich::Messaging.msg("yellow", msg)
          Gtk.queue { @window&.remove_sold_item_sold(item_uid) } rescue nil
        else
          if truly_rejected
            Lich::Messaging.msg("yellow", "[Merchantical] Batch: #{name} rejected by vendor — returning.")
            item[:vendor_rejected] = true
            @state['vendor_rejected'] ||= []
            @state['vendor_rejected'] |= [item_uid]
          else
            Lich::Messaging.msg("yellow",
              "[Merchantical] Batch: #{name} could not be sold (item not found or worn) — returning.")
          end
          if container_id
            fput "put ##{item_id} in ##{container_id}"
          else
            fput "wear ##{item_id}"
          end
          waitrt?
        end
      end

      # -----------------------------------------------------------------------
      # Locker items — single visit, retrieve all into worn inventory, then sell
      # -----------------------------------------------------------------------
      if locker_items.any?
        if locker_room.empty?
          Lich::Messaging.msg("yellow",
            "[Merchantical] Batch: locker items skipped (locker room not configured).")
        else
          at_pawnshop = false  # leaving town to go to locker
          Lich::Messaging.msg("yellow",
            "[Merchantical] Batch: going to locker for #{locker_items.count} item(s)...")
          start_script("go2", [locker_room])
          while running?("go2"); pause 0.5; end
          waitrt?; pause 1

          retrieved = []  # [{item:, item_id:, stow_container_id:}]

          if try_open_locker
            # Find a worn container for temporarily stowing retrieved items so we can carry
            # multiple items to the pawnshop without needing a free hand.  Must be identified
            # BEFORE picking up any locker bag (otherwise the bag itself would be a candidate).
            stow_container_id = GameObj.inv.to_a
              .find { |gi| gi.type.to_s =~ /container/i && gi.id }
              &.id.to_s

            bag_groups = locker_items.group_by { |i| i[:locker_bag_name].to_s }

            bag_groups.each do |bag_name, items_in_bag|
              next if bag_name.empty?

              Lich::Messaging.msg("yellow", "[Merchantical] Batch: retrieving from #{bag_name}...")
              fput "get #{bag_name}"; waitrt?; pause 0.5

              known_ids    = GameObj.containers.keys.map(&:to_s).to_set
              fput "look in #{bag_name}"; waitrt?; pause 1

              new_entry    = GameObj.containers.find { |cid, _| !known_ids.include?(cid.to_s) }
              bag_contents = new_entry ? new_entry[1].to_a : []

              items_in_bag.each do |item|
                name_dc   = item['name'].to_s.downcase.strip
                bare      = name_dc.sub(/\A(?:a |an |the )/, '')
                item_noun = item['noun'].to_s.downcase.strip

                target = bag_contents.find { |gi|
                  gn = gi.name.to_s.downcase.strip; bgn = gn.sub(/\A(?:a |an |the )/, '')
                  gn == name_dc || bgn == bare
                }
                target ||= bag_contents.find { |gi|
                  bgn = gi.name.to_s.downcase.strip.sub(/\A(?:a |an |the )/, '')
                  (bgn.include?(' ') && bare =~ /(?:\A|\s)#{Regexp.escape(bgn)}\z/) ||
                  (bare.include?(' ') && bgn =~ /(?:\A|\s)#{Regexp.escape(bare)}\z/)
                }
                target ||= bag_contents.find { |gi|
                  gi.noun.to_s.downcase.strip == item_noun
                }

                unless target
                  Lich::Messaging.msg("yellow",
                    "[Merchantical] Batch: could not find #{item['name']} in #{bag_name} — skipping.")
                  next
                end

                fresh_id = target.id.to_s
                fput "get ##{fresh_id}"; waitrt?; pause 0.2
                # Stow into worn container so we can free a hand for the next item.
                # GS4 does not accept `stow #id`; use `put #id in #container_id` instead.
                if stow_container_id && !stow_container_id.empty?
                  fput "put ##{fresh_id} in ##{stow_container_id}"; waitrt?; pause 0.2
                end

                item[:gameobj_id] = fresh_id
                retrieved << { item: item, item_id: fresh_id, stow_container_id: stow_container_id }
              end

              fput "put #{bag_name} in locker"; waitrt?; pause 0.5
            end
          else
            Lich::Messaging.msg("yellow",
              "[Merchantical] A selfish individual has set up camp in the locker. The smell was unbearable.")
          end

          unless retrieved.empty?
            go_to_pawnshop.call

            retrieved.each do |r|
              item      = r[:item]
              item_id   = r[:item_id]
              item_uid  = item['id'].to_s
              name      = item['name'].to_s
              stow_cid  = r[:stow_container_id]

              if stow_cid && !stow_cid.empty?
                fput "get ##{item_id} from ##{stow_cid}"; waitrt?
              else
                fput "get ##{item_id}"; waitrt?
              end

              sold, note_offer, truly_rejected = sell_one.call(item_id, item_uid)
              waitrt?

              if sold
                msg = "[Merchantical] Batch: sold #{name}!"
                msg += " Check hands for a bank note." if note_offer
                Lich::Messaging.msg("yellow", msg)
                Gtk.queue { @window&.remove_sold_item_sold(item_uid) } rescue nil
              else
                if truly_rejected
                  Lich::Messaging.msg("yellow",
                    "[Merchantical] Batch: #{name} rejected by vendor — stowing.")
                  item[:vendor_rejected] = true
                  @state['vendor_rejected'] ||= []
                  @state['vendor_rejected'] |= [item_uid]
                else
                  Lich::Messaging.msg("yellow",
                    "[Merchantical] Batch: #{name} could not be sold (item not found or worn) — stowing.")
                end
                # Return to stow container (or try wear as last resort)
                if stow_cid && !stow_cid.empty?
                  fput "put ##{item_id} in ##{stow_cid}"; waitrt?
                else
                  fput "wear ##{item_id}"; waitrt? rescue nil
                end
              end
            end
          end
        end
      end

      # Persist any rejections and rebuild UI
      State.save(@state) if items_to_sell.any? { |i| i[:vendor_rejected] }
      Gtk.queue { @window&.schedule_rebuild } rescue nil

      unless origin_room.empty?
        Lich::Messaging.msg("yellow", "[Merchantical] Batch sell: returning home...")
        start_script("go2", [origin_room])
        while running?("go2"); pause 0.5; end
        waitrt?
      end

      Lich::Messaging.msg("yellow", "[Merchantical] Batch sell complete.")
    rescue => e
      Lich::Messaging.msg("yellow",
        "[Merchantical] Batch sell error: #{e.message}\n#{e.backtrace.first(2).join("\n")}")
    end

    def do_mark_item(info)
      item_id      = info[:item_id]
      container_id = info[:container_id]
      name         = info[:name].to_s
      unless item_id
        Lich::Messaging.msg("yellow", "[Merchantical] Mark skipped for #{name}: no gameobj ID.")
        return
      end
      if container_id
        Lich::Messaging.msg("yellow", "[Merchantical] Retrieving #{name} from container ##{container_id}...")
        fput "get ##{item_id} from ##{container_id}"
        waitrt?
      end
      fput "mark ##{item_id}"
      waitrt?
      if container_id
        fput "put ##{item_id} in ##{container_id}"
        waitrt?
        Lich::Messaging.msg("yellow", "[Merchantical] Marked #{name} and returned to bag.")
      else
        Lich::Messaging.msg("yellow", "[Merchantical] Marked #{name}.")
      end
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Mark error for #{name}: #{e.message}")
    end

    def do_unmark_item(info)
      item_id      = info[:item_id]
      container_id = info[:container_id]
      name         = info[:name].to_s
      unless item_id
        Lich::Messaging.msg("yellow", "[Merchantical] Unmark skipped for #{name}: no gameobj ID.")
        return
      end
      if container_id
        Lich::Messaging.msg("yellow", "[Merchantical] Retrieving #{name} to remove mark...")
        fput "get ##{item_id} from ##{container_id}"
        waitrt?
      end
      fput "mark ##{item_id} remove"
      waitrt?
      if container_id
        fput "put ##{item_id} in ##{container_id}"
        waitrt?
        Lich::Messaging.msg("yellow", "[Merchantical] Mark removed from #{name}, returned to bag.")
      else
        Lich::Messaging.msg("yellow", "[Merchantical] Mark removed from #{name}.")
      end
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Unmark error for #{name}: #{e.message}")
    end

    def do_sell(info)
      item_id         = info[:item_id]
      container_id    = info[:container_id]
      name            = info[:name].to_s
      item_noun       = info[:noun].to_s.downcase.strip
      in_locker       = info[:in_locker]
      locker_bag_name = info[:locker_bag_name].to_s

      if in_locker
        # Locker items: get bag by name, look in to get fresh IDs, then use #id for item
        options     = @state['options'] || {}
        locker_room = options['locker_room'].to_s
        if locker_room.empty?
          Lich::Messaging.msg("yellow", "[Merchantical] Sell skipped for #{name}: locker room not configured.")
          return
        end
        if locker_bag_name.empty?
          Lich::Messaging.msg("yellow", "[Merchantical] Sell skipped for #{name}: locker bag name not recorded.")
          return
        end
        Lich::Messaging.msg("yellow", "[Merchantical] Navigating to locker to retrieve #{name}...")
        start_script("go2", [locker_room])
        while running?("go2"); pause 0.5; end
        waitrt?
        pause 1
        unless try_open_locker
          Lich::Messaging.msg("yellow",
            "[Merchantical] A selfish individual has set up camp in the locker. The smell was unbearable.")
          start_script("go2", [info[:origin_room].to_s]) unless info[:origin_room].to_s.empty?
          while running?("go2"); pause 0.5; end
          return
        end
        pause 0.5
        fput "get #{locker_bag_name}"
        waitrt?
        pause 0.5

        # Snapshot, look in bag, find fresh IDs
        known_ids    = GameObj.containers.keys.map(&:to_s).to_set
        fput "look in #{locker_bag_name}"
        waitrt?
        pause 1
        new_entry    = GameObj.containers.find { |cid, _| !known_ids.include?(cid.to_s) }
        bag_contents = new_entry ? new_entry[1].to_a : []
        bare_name    = name.downcase.strip.sub(/\A(?:a |an |the )/, '')
        name_dc      = name.downcase.strip
        target       = bag_contents.find { |gi|
          gn  = gi.name.to_s.downcase.strip
          bgn = gn.sub(/\A(?:a |an |the )/, '')
          gn == name_dc || bgn == bare_name
        }
        target ||= bag_contents.find { |gi|
          bgn = gi.name.to_s.downcase.strip.sub(/\A(?:a |an |the )/, '')
          !bgn.empty? && bare_name =~ /(?:\A|\s)#{Regexp.escape(bgn)}\z/
        }
        target ||= bag_contents.find { |gi|
          gi_noun = gi.noun.to_s.downcase.strip
          !item_noun.empty? && !gi_noun.empty? && gi_noun == item_noun
        }

        unless target
          Lich::Messaging.msg("yellow", "[Merchantical] Could not locate #{name} in #{locker_bag_name} -- aborting sell.")
          fput "put #{locker_bag_name} in locker"
          return
        end

        fresh_item_id = target.id.to_s
        fput "get ##{fresh_item_id}"
        waitrt?
        pause 0.5
        fput "put #{locker_bag_name} in locker"
        waitrt?
        pause 0.5
        item_id = fresh_item_id
        # Persist fresh gameobj_id so mark/unmark/sell all target the right item going forward
        item_rec_upd = @items.find { |i| i['id'].to_s == info[:item_uid].to_s }
        item_rec_upd[:gameobj_id] = fresh_item_id if item_rec_upd
      else
        # Regular inventory item: use GameObj IDs
        unless item_id
          Lich::Messaging.msg("yellow", "[Merchantical] Sell skipped for #{name}: item not found in inventory.")
          return
        end
        # GS4 requires the item to be in-hand to sell it — get it out regardless of
        # whether it is inside a bag (container_id set) or worn directly (container_id nil).
        if container_id
          fput "get ##{item_id} from ##{container_id}"
        else
          fput "get ##{item_id}"
        end
        waitrt?
      end

      room_desc = (XMLData.room_description || "").downcase
      unless room_desc.include?("pawnshop")
        Lich::Messaging.msg("yellow", "[Merchantical] Navigating to pawnshop...")
        start_script("go2", ["pawnshop"])
        while running?("go2"); pause 0.5; end
        waitrt?
      end

      # Helper: send one sell attempt and collect the pawnshop response.
      # fput handles roundtime; DownstreamHook captures broker lines before fput returns.
      do_one_sell = lambda do
        lines = []
        hk    = "mc_sell_#{Thread.current.object_id}"
        DownstreamHook.add(hk, proc { |s|
          lines << s.to_s
          s
        })
        fput "sell ##{item_id}"
        DownstreamHook.remove(hk) rescue nil
        lines
      end

      sell_response = do_one_sell.call

      # Detect 25k note offer — pawnshop caps at 25,000 and requires a second sell to confirm
      note_offer = sell_response.any? { |l| l =~ /25[,.]?000\s*silver|note\s+worth\s+25/i }
      if note_offer
        Lich::Messaging.msg("yellow", "[Merchantical] 25,000 silver cap detected — confirming sale for bank note...")
        sell_response = do_one_sell.call
      end

      # Success = broker physically took the item and handed over coin/note
      sold = sell_response.any? { |l| l =~ /pawnbroker takes.*hands you|hands you \d+\s*silver|handed? you \d+/i }

      # Anything else after the offer = rejection (item was handed back or broker declined)
      rejected = !sold

      origin_room = info[:origin_room].to_s
      item_uid    = info[:item_uid].to_s

      if rejected
        waitrt?
        # Return item to its original location before heading home
        if in_locker && !locker_room.to_s.empty?
          Lich::Messaging.msg("yellow", "[Merchantical] Returning #{name} to locker...")
          start_script("go2", [locker_room])
          while running?("go2"); pause 0.5; end
          waitrt?
          pause 1
          if try_open_locker
            fput "get #{locker_bag_name}"
            waitrt?; pause 0.3
            fput "put ##{item_id} in #{locker_bag_name}"
            waitrt?; pause 0.3
            fput "put #{locker_bag_name} in locker"
            waitrt?; pause 0.3
          end
        elsif container_id
          fput "put ##{item_id} in ##{container_id}"
          waitrt?
        else
          # Item was worn directly — re-wear it on rejection
          fput "wear ##{item_id}"
          waitrt?
        end
      else
        # Queue GTK removal immediately — before waitrt? so the item disappears from the
        # list the moment the sale is confirmed, not after round-time clears.
        unless item_uid.empty?
          Gtk.queue { @window&.remove_sold_item_sold(item_uid) } rescue nil
        end
        waitrt?
      end

      # Return to origin room
      unless origin_room.empty?
        start_script("go2", [origin_room])
        while running?("go2"); pause 0.5; end
        waitrt?
      end

      if rejected
        unless item_uid.empty?
          item_rec = @items.find { |i| i['id'].to_s == item_uid }
          if item_rec
            item_rec[:vendor_rejected] = true
            @state['vendor_rejected'] ||= []
            @state['vendor_rejected'] |= [item_uid]
            State.save(@state)
            Gtk.queue { @window&.schedule_rebuild } rescue nil
          end
        end
        Lich::Messaging.msg("yellow", "[Merchantical] Pawnshop has rejected your garbage.")
      else
        msg = "[Merchantical] Item sold and removed from list!"
        msg += " Please check hands for a bank note." if note_offer
        Lich::Messaging.msg("yellow", msg)
      end
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Sell error for #{name}: #{e.message}")
    end

    # Opens the locker, retrying if another player is occupying the booth.
    # Returns true on success, false after all retries exhausted.
    def try_open_locker(max_tries: 3, wait_secs: 10)
      max_tries.times do |attempt|
        busy      = [false]
        responded = [false]
        hook_name = "mc_locker_#{Thread.current.object_id}_#{attempt}"
        DownstreamHook.add(hook_name, proc { |line|
          if line =~ /presently using that locker booth/i
            busy[0] = true; responded[0] = true
          elsif line =~ /you open|already open/i
            responded[0] = true
          end
          line
        })
        put "open locker"
        deadline = Time.now + 5
        until responded[0] || Time.now > deadline; pause 0.2; end
        DownstreamHook.remove(hook_name) rescue nil
        waitrt?
        return true unless busy[0]
        if attempt < max_tries - 1
          Lich::Messaging.msg("yellow",
            "[Merchantical] Locker is occupied. Waiting #{wait_secs}s... " \
            "(attempt #{attempt + 1}/#{max_tries})")
          pause wait_secs
        end
      end
      false
    end

    def search_locker(options)
      origin_room = (Map.current_room_id rescue nil).to_s
      Lich::Messaging.msg("yellow", "[Merchantical] Searching locker bags...")
      start_script("go2", [options['locker_room'].to_s])
      while running?("go2"); pause 0.5; end
      waitrt?
      pause 1
      unless try_open_locker
        Lich::Messaging.msg("yellow",
          "[Merchantical] A selfish individual has set up camp in the locker. The smell was unbearable.")
        start_script("go2", [origin_room]) unless origin_room.empty?
        while running?("go2"); pause 0.5; end
        return
      end
      pause 1

      bag_names = (options['bags'] || []).map(&:strip).reject(&:empty?)
      bag_names.each do |bag_name|
        Lich::Messaging.msg("yellow", "[Merchantical] Checking bag: #{bag_name}")
        fput "get #{bag_name}"
        waitrt?
        pause 0.5

        # Snapshot existing container IDs before looking — so we can find exactly
        # what's new after the look, without touching worn containers
        known_ids = GameObj.containers.keys.map(&:to_s).to_set

        fput "look in #{bag_name}"
        waitrt?
        pause 1

        # The new entry added to GameObj.containers IS the bag we just looked in
        new_entry    = GameObj.containers.find { |cid, _| !known_ids.include?(cid.to_s) }
        bag_contents = new_entry ? new_entry[1].to_a : []

        # Track which @items have already been claimed so two different bag contents
        # (e.g. two stickpins) don't both match the same @item entry.
        used_matched_ids = {}

        bag_contents.each do |gi|
          gi_name = gi.name.to_s.downcase.strip
          gi_bgn  = gi_name.sub(/\A(?:a |an |the )/, '')
          gi_noun = gi.noun.to_s.downcase.strip

          # Same three-pass priority as match_inventory_items — full name first, noun last.
          matched = @items.find { |i|
            next if used_matched_ids[i['id']]
            n = i['name'].to_s.downcase.strip
            b = n.sub(/\A(?:a |an |the )/, '')
            gi_name == n || gi_bgn == b
          }
          matched ||= @items.find { |i|
            next if used_matched_ids[i['id']]
            b = i['name'].to_s.downcase.strip.sub(/\A(?:a |an |the )/, '')
            (gi_bgn.include?(' ') && b =~ /(?:\A|\s)#{Regexp.escape(gi_bgn)}\z/) ||
            (b.include?(' ') && gi_bgn =~ /(?:\A|\s)#{Regexp.escape(b)}\z/)
          }
          matched ||= @items.find { |i|
            next if used_matched_ids[i['id']]
            in2 = i['noun'].to_s.downcase.strip
            !gi_noun.empty? && !in2.empty? && gi_noun == in2
          }
          if matched
            used_matched_ids[matched['id']] = true
            matched[:found]           = true
            matched[:in_locker]       = true
            matched[:locker_bag_name] = bag_name
            matched[:gameobj_id]      = nil
            matched[:container_id]    = nil
            # Set authoritative display name from the actual GameObj in the locker
            matched[:gameobj_name]    = gi.name.to_s.sub(/\A(?:a |an |the )/i, '').strip
            Lich::Messaging.msg("yellow", "[Merchantical]   Found: #{matched[:gameobj_name]}")
          end
        end

        fput "put #{bag_name} in locker"
        waitrt?
        pause 1
      end

      unless origin_room.empty?
        Lich::Messaging.msg("yellow", "[Merchantical] Returning to origin room...")
        start_script("go2", [origin_room])
        while running?("go2"); pause 0.5; end
        waitrt?
      end
    rescue => e
      Lich::Messaging.msg("yellow", "[Merchantical] Locker search error: #{e.message}")
    end

    def start_loresang_with_capture
      loresang_paths = [
        "#{SCRIPT_DIR}loresang.lic",
        File.join(SCRIPT_DIR, 'loresang.lic'),
        File.join(SCRIPT_DIR, 'custom', 'loresang.lic')
      ]
      unless loresang_paths.any? { |p| File.exist?(p) }
        Lich::Messaging.msg("yellow", "[Merchantical] Loresang not found.")
        Lich::Messaging.msg("yellow", "[Merchantical] USER, PLEASE DOWNLOAD AND CONFIGURE LORESANG FIRST: ;repo download loresang")
        Gtk.queue { @window&.enable_loresang_btn } rescue nil
        return
      end

      Lich::Messaging.msg("yellow", "[Merchantical] Starting loresang -- capturing stream...")

      capture_mutex           = Mutex.new
      captures                = []
      noun_statuses           = {}
      current_capture         = nil
      last_recall_noun        = nil
      last_recall_fullname    = nil
      last_loresing_fullname  = nil
      last_loresang_get_name  = nil
      hook_id                 = "merchantical_cap_#{Time.now.to_i}"

      # DownstreamHook.add requires an explicit Proc as second argument (not a block)
      hook_proc = proc { |server_string|
        text = server_string.to_s
                            .gsub(/<[^>]+>/, '')
                            .gsub(/\e\[[0-9;]*[mK]/, '')
                            .gsub(/&lt;/, '<').gsub(/&gt;/, '>').gsub(/&amp;/, '&')
                            .strip

        # Capture full item name from the loresing start line.
        # "You sing a loresong as you carefully examine the mithril spear."
        # This is the only reliable source of the full name in stream mode.
        if text =~ /\Ayou sing a loresong as you carefully examine (?:the |an? )?(.+?)\s*\.\z/i
          last_loresing_fullname = $1.strip.downcase
        end

        # Capture full item name when loresang retrieves an already-unlocked item.
        # "You remove a topaz-inset mithril stickpin from your greatcloak."
        # Note: we do NOT check $_LASTUPSTREAM_ here because loresang may have already
        # sent the next command (recall) by the time the game response arrives — checking
        # upstream would miss the name. We capture unconditionally; it is only consumed
        # when last_recall_noun is set (i.e. a loresang recall command followed).
        if text =~ /\AYou (?:remove|get|take) (?:the |an? )?(.+?) (?:from|out of)/i
          last_loresang_get_name = $1.strip.downcase
        end

        # Matches both:
        #   "As you recall your song..."  (normal recall / post-loresing recall)
        #   "As you recall Ool's song, you feel a faint resonating vibration from the [item]..."  (permanently unlocked by another bard)
        if text =~ /^as you recall/i
          us = $_LASTUPSTREAM_.to_s
          last_recall_noun = us =~ /\[loresang\]>recall\s+(\S+)/i ? $1.downcase : nil
          last_recall_fullname =
            if text =~ /vibration from (?:the|an?) (.+?) in your (?:(?:right|left) )?hand/i
              # Permanently unlocked by another bard — full name is in this trigger line
              $1.strip.downcase
            elsif last_recall_noun && last_loresing_fullname
              # Post-loresing recall: use the name we captured from "You sing a loresong..."
              fn = last_loresing_fullname
              last_loresing_fullname = nil
              fn
            elsif last_recall_noun && last_loresang_get_name
              # Already-unlocked item retrieved by loresang — use name from "You remove X from..."
              fn = last_loresang_get_name
              last_loresang_get_name = nil
              fn
            end
          # Mid-verse "as you recall" triggers (null noun, from loresing output) do not
          # consume last_loresing_fullname so it remains available for the final recall.
        end

        capture_mutex.synchronize do
          if text =~ /^as you recall/i
            captures << current_capture if current_capture && current_capture[:lines].any?
            current_capture = { noun: last_recall_noun, full_name: last_recall_fullname, lines: [] }
          elsif current_capture
            if text =~ /\[Loresang\]|\[Merchantical\]/i
              captures << current_capture if current_capture[:lines].any?
              current_capture = nil
              if text =~ /Loresong Completed.*?,\s*(\S+)/i ||
                 text =~ /(\S+)\s+fully identified/i
                noun_statuses[$1.downcase] = :completed
              elsif text =~ /(\S+)\s+already fully unlocked/i
                noun_statuses[$1.downcase] = :already_unlocked
              end
            elsif !text.empty?
              # Whitelist: every loresang recall line begins with "It " or "This item ".
              # Anything else (prompts ">", inventory dumps, spell messages,
              # item transfer lines, container listings, etc.) is discarded.
              current_capture[:lines] << text if text =~ /\A(?:It |This item )/i
            end
          else
            if text =~ /\[Loresang\]/i
              if text =~ /Loresong Completed.*?,\s*(\S+)/i ||
                 text =~ /(\S+)\s+fully identified/i
                noun_statuses[$1.downcase] = :completed
              elsif text =~ /(\S+)\s+already fully unlocked/i
                noun_statuses[$1.downcase] = :already_unlocked
              end
            end
          end
        end

        server_string
      }
      DownstreamHook.add(hook_id, hook_proc)

      start_script("loresang")
      while running?("loresang"); pause 0.5; end
      pause 1
      DownstreamHook.remove(hook_id)

      capture_mutex.synchronize do
        captures << current_capture if current_capture && current_capture[:lines].any?
      end

      # Build items from stream capture — iterate captures directly to preserve duplicates.
      # (e.g. 4 stickpins with the same noun all become separate entries instead of collapsing to 1)
      Lich::Messaging.msg("yellow", "[Merchantical] Stream: #{captures.count} capture(s), nouns: #{captures.map { |c| c[:noun] }.compact.join(', ')}")
      noun_indices = Hash.new(0)
      stream_items = captures.filter_map do |cap|
        next unless cap[:noun]
        noun        = cap[:noun]
        recall_text = cap[:lines].join("\n")
        full_name   = cap[:full_name] || noun
        parsed      = Parser.parse_recall(recall_text, full_name)
        value       = recall_text =~ /estimated to be worth about ([\d,]+) silvers/i ?
                        $1.gsub(',', '').to_i : nil
        status      = noun_statuses[noun] || :completed
        idx         = noun_indices[noun]
        noun_indices[noun] += 1
        base_id     = full_name.gsub(/[^a-zA-Z0-9]/, '-').downcase
        item_id     = idx == 0 ? base_id : "#{base_id}-#{idx}"
        { 'id' => item_id, 'name' => full_name, 'noun' => noun,
          'status' => status.to_s, 'recall_text' => recall_text,
          'value' => value }.merge(parsed)
      end

      # Prefer freshly-written HTML file from loresang if updated within the last 5 minutes —
      # HTML items have authoritative full names and richer data from loresang's own output.
      # We read from the shared LORESANG_HTML (written by loresang.lic) then save a
      # per-character copy to HTML_FILE so other characters' runs don't bleed over.
      new_items = begin
        if File.exist?(LORESANG_HTML) && (Time.now - File.mtime(LORESANG_HTML)) < 300
          html_content = File.read(LORESANG_HTML)
          html_items   = Parser.extract_items(html_content)
          if html_items.any?
            # Save per-character copy for future startups
            File.write(HTML_FILE, html_content) rescue nil
            # Merge stream-captured status back in
            html_items.each do |hi|
              n = hi['noun'].to_s.downcase
              hi['status'] = noun_statuses[n].to_s if noun_statuses[n]
            end
            Lich::Messaging.msg("yellow", "[Merchantical] Using HTML data (#{html_items.count} items with full names).")
            html_items
          else
            stream_items
          end
        else
          stream_items
        end
      rescue
        stream_items
      end

      match_inventory_items(new_items)
      @items = new_items

      # Persist items so they survive script restarts (string keys only — no runtime state)
      begin
        serializable = new_items.map { |i| i.select { |k, _| k.is_a?(String) } }
        File.write(ITEMS_FILE, serializable.to_json, encoding: 'UTF-8')
      rescue => e
        Lich::Messaging.msg("yellow", "[Merchantical] Warning: could not save items: #{e.message}")
      end

      count = new_items.count
      Lich::Messaging.msg(
        "yellow",
        count > 0 ?
          "[Merchantical] Loresang complete -- #{count} item(s) captured." :
          "[Merchantical] Loresang complete -- no items captured. Check ;loresang setup."
      )

      Gtk.queue do
        @window&.update_batch(new_items)
        @window&.enable_loresang_btn
      end rescue nil
    end

    def save_final_state
      @state['locked']          = @items.select { |i| i[:locked] }.map          { |i| i['id'] }
      @state['shop_flagged']    = @items.select { |i| i[:shop_flagged] }.map    { |i| i['id'] }
      @state['vendor_rejected'] = @items.select { |i| i[:vendor_rejected] }.map { |i| i['id'] }
      State.save(@state)
    end
  end
end

# Entry point
Merchantical::App.new.run
