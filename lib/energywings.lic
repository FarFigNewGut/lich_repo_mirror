# ----------------------------
# Prep reaction (pull my wing pin)
# ----------------------------

def with_paused_scripts
  return yield unless @settings[:pause_other_scripts]

  pause_mutex = (@pause_mutex ||= Mutex.new)
  pause_mutex.synchronize do
    @pause_depth ||= 0
    acquire_shared_script_pauses(PAUSE_OWNER_KEY, scripts_to_pause) if @pause_depth.zero?
    @pause_depth += 1
  end
  yield
ensure
  should_release = false
  pause_mutex = (@pause_mutex ||= Mutex.new)
  pause_mutex.synchronize do
    @pause_depth = [@pause_depth.to_i - 1, 0].max
    should_release = @pause_depth.zero?
  end
  release_shared_script_pauses(PAUSE_OWNER_KEY, scripts_to_pause) if should_release
end

def shared_pause_registry
  $lich_shared_pause_registry ||= {}
end

def shared_pause_mutex
  $lich_shared_pause_mutex ||= Mutex.new
end

def acquire_shared_script_pauses(owner_key, script_names)
  shared_pause_mutex.synchronize do
    script_names.each do |script_name|
      next unless Script.running?(script_name)

      entry = (shared_pause_registry[script_name] ||= { owners: {}, paused_by_registry: false })
      next if entry[:owners][owner_key]

      if entry[:owners].empty?
        if Script.paused?(script_name)
          entry[:paused_by_registry] = false
        else
          Script.pause(script_name)
          entry[:paused_by_registry] = true
        end
      end
      entry[:owners][owner_key] = true
    end
  end
end

def release_shared_script_pauses(owner_key, script_names)
  scripts_to_unpause = []

  shared_pause_mutex.synchronize do
    script_names.each do |script_name|
      entry = shared_pause_registry[script_name]
      next unless entry

      next unless entry[:owners][owner_key]

      entry[:owners].delete(owner_key)

      next unless entry[:owners].empty?

      scripts_to_unpause << script_name if entry[:paused_by_registry]
      shared_pause_registry.delete(script_name)
    end
  end

  scripts_to_unpause.each do |script_name|
    Script.unpause(script_name) if Script.paused?(script_name)
  end
end

def react_to_enemy_prep(mode)
  return unless in_allowed_room?
  return unless @settings[:use_prep_reaction]
  return if hidden?
  return if checkstunned
  npc = living_npc
  return unless npc
  # return Feat.available?('Absorb Magic')

  if mode == "dark"
    return unless ability_ready?("Crawling Shadow")
    result = nil
    with_paused_scripts do
      waitrt?
      waitcastrt?
      sleep 0.25
      result = dothistimeout("pull my wing pin", 2, /You draw your umbrous wings close as shadows seep outward/)
      sleep 0.5
    end
    echo "CRAWLING SHADOW {!}".center(45) if result.is_a?(String)
  else
    return unless ability_ready?("Prismatic Aegis")
    # We do not hard-require a specific success line; cooldown gating is the primary guard.
    with_paused_scripts do
      waitrt?
      waitcastrt?
      sleep 0.25
      dothistimeout("pull my wing pin", 2, /You draw your luminous wings inward and then snap them wide/)
      sleep 0.5
    end
    echo "PRISMATIC AEGIS {!}".center(45)
  end
end

# ----------------------------
# Combat abilities (your original logic)
# ----------------------------

def precast_commands_for(ability_name)
  raw = @settings[:precasts][ability_name]
  return [] if raw.nil? || raw.to_s.strip.empty?

  raw.to_s.split(/[\r\n;]+/).map(&:strip).reject(&:empty?)
end

def run_precast_for(ability_name)
  return if hidden?

  cmds = precast_commands_for(ability_name)
  return if cmds.empty?

  cmds.each do |cmd|
    next if cmd.nil? || cmd.strip.empty?
    if cmd =~ /\A(?:incant|prep)\s+(\d+)\b/i
      spell_num = Regexp.last_match(1).to_i
      next unless Spell[spell_num].available?
    end

    waitrt?
    waitcastrt?

    # Use dothistimeout and treat "You gesture" as success
    dothistimeout(cmd, 5, /^You gesture/i)

    waitrt?
    waitcastrt?
    sleep 0.25
  end
end

def fire_wing_ability(command, ability_name)
  return if hidden?

  with_paused_scripts do
    waitrt?
    waitcastrt?
    run_precast_for(ability_name)
    fput command
    sleep 0.5
  end
end

def activate_wing_ability(command, ability_name, npc)
  attempts = 0

  while attempts < ABILITY_MAX_ATTEMPTS
    break if hidden?
    break if npc.status =~ /dead|gone/
    break if Effects::Cooldowns.active?(ability_name)

    fire_wing_ability(command, ability_name)
    attempts += 1
    sleep 0.2
  end

  Effects::Cooldowns.active?(ability_name)
rescue StandardError
  false
end


def do_combat_actions(mode, npc)
  return if hidden?
  update_mount_trample_trigger_state
  target_count = GameObj.targets.count

  if mode == "dark"
    tap    = "Shadow Mantle"
    single = "Shadow Barb"
    multi  = "Barbed Sweep"
    aoe    = "Rain of Thorns"
    guard  = "Carrion Guard"
  else
    tap    = "Luminous Flight"
    single = "Radiant Pulse"
    multi  = "Blast of Brilliance"
    aoe    = "Blinding Reprisal"
    guard  = "Wings of Warding"
  end

  # Defensive tap ability when available
  if @settings[:use_defensive_tap] && ability_ready?(tap)
    echo "#{tap} {!}".upcase.center(45) if activate_wing_ability('tap my wing pin', tap, npc)
  end

  # Single target when prone/stunned
  if @settings[:use_single_target] && ability_ready?(single)
    echo "#{single} {!}".upcase.center(45) if activate_wing_ability('turn my wing pin', single, npc)
  end

  # Multi-target (3+) when prone/stunned
  if @settings[:use_multi_target] && target_count >= @settings[:multi_target_threshold] && ability_ready?(multi)
    echo "#{multi} {!}".upcase.center(45) if activate_wing_ability('knock my wing pin', multi, npc)
  end

  # AOE
  aoe_allowed = if @settings[:use_aoe_after_mount_trample]
                  mount_trample_aoe_triggered?
                else
                  target_count >= @settings[:aoe_target_threshold]
                end

  if @settings[:use_aoe] && aoe_allowed && ability_ready?(aoe)
    if activate_wing_ability('fold my wing pin', aoe, npc)
      consume_mount_trample_aoe_trigger if @settings[:use_aoe_after_mount_trample]
      echo "#{aoe} {!}".upcase.center(45)
    end
  end

  # Defensive AOE (6+ targets, bleeding)
  if @settings[:use_guard_aoe] && bleeding? && target_count >= @settings[:guard_target_threshold] && ability_ready?(guard)
    echo "#{guard} {!}".upcase.center(45) if activate_wing_ability('push my wing pin', guard, npc)
  end

end

def load_settings
  Settings.load
  Settings[Char.name] ||= {}

  settings = DEFAULT_SETTINGS.merge(
    use_prep_reaction: parse_setting_bool(Settings[Char.name]['energywings_use_prep_reaction'], DEFAULT_SETTINGS[:use_prep_reaction]),
    use_defensive_tap: parse_setting_bool(Settings[Char.name]['energywings_use_defensive_tap'], DEFAULT_SETTINGS[:use_defensive_tap]),
    use_single_target: parse_setting_bool(Settings[Char.name]['energywings_use_single_target'], DEFAULT_SETTINGS[:use_single_target]),
    use_multi_target: parse_setting_bool(Settings[Char.name]['energywings_use_multi_target'], DEFAULT_SETTINGS[:use_multi_target]),
    use_aoe: parse_setting_bool(Settings[Char.name]['energywings_use_aoe'], DEFAULT_SETTINGS[:use_aoe]),
    use_aoe_after_mount_trample: parse_setting_bool(Settings[Char.name]['energywings_use_aoe_after_mount_trample'], DEFAULT_SETTINGS[:use_aoe_after_mount_trample]),
    use_guard_aoe: parse_setting_bool(Settings[Char.name]['energywings_use_guard_aoe'], DEFAULT_SETTINGS[:use_guard_aoe]),
    multi_target_threshold: normalize_threshold_setting(Settings[Char.name]['energywings_multi_target_threshold'], DEFAULT_SETTINGS[:multi_target_threshold], minimum: 2),
    aoe_target_threshold: normalize_threshold_setting(Settings[Char.name]['energywings_aoe_target_threshold'], DEFAULT_SETTINGS[:aoe_target_threshold], minimum: 2),
    guard_target_threshold: normalize_threshold_setting(Settings[Char.name]['energywings_guard_target_threshold'], DEFAULT_SETTINGS[:guard_target_threshold], minimum: 1),
    pause_other_scripts: parse_setting_bool(Settings[Char.name]['energywings_pause_other_scripts'], DEFAULT_SETTINGS[:pause_other_scripts]),
    pause_bigshot: parse_setting_bool(Settings[Char.name]['energywings_pause_bigshot'], DEFAULT_SETTINGS[:pause_bigshot]),
    additional_pause_scripts: normalize_script_list_setting(Settings[Char.name]['energywings_additional_pause_scripts'], DEFAULT_SETTINGS[:additional_pause_scripts]),
    precasts: load_precast_settings
  )

  persist_settings(settings)
  settings
rescue StandardError
  DEFAULT_SETTINGS.merge(precasts: DEFAULT_PRECAST_FOR_ABILITY.dup)
end

def load_precast_settings
  DEFAULT_PRECAST_FOR_ABILITY.each_with_object({}) do |(ability_name, default_value), precasts|
    precasts[ability_name] = normalize_precast_setting(Settings[Char.name][precast_setting_key(ability_name)], default_value)
  end
end

def persist_settings(settings)
  Settings[Char.name]['energywings_use_prep_reaction'] = settings[:use_prep_reaction]
  Settings[Char.name]['energywings_use_defensive_tap'] = settings[:use_defensive_tap]
  Settings[Char.name]['energywings_use_single_target'] = settings[:use_single_target]
  Settings[Char.name]['energywings_use_multi_target'] = settings[:use_multi_target]
  Settings[Char.name]['energywings_use_aoe'] = settings[:use_aoe]
  Settings[Char.name]['energywings_use_aoe_after_mount_trample'] = settings[:use_aoe_after_mount_trample]
  Settings[Char.name]['energywings_use_guard_aoe'] = settings[:use_guard_aoe]
  Settings[Char.name]['energywings_multi_target_threshold'] = settings[:multi_target_threshold]
  Settings[Char.name]['energywings_aoe_target_threshold'] = settings[:aoe_target_threshold]
  Settings[Char.name]['energywings_guard_target_threshold'] = settings[:guard_target_threshold]
  Settings[Char.name]['energywings_pause_other_scripts'] = settings[:pause_other_scripts]
  Settings[Char.name]['energywings_pause_bigshot'] = settings[:pause_bigshot]
  Settings[Char.name]['energywings_additional_pause_scripts'] = normalize_script_list_setting(settings[:additional_pause_scripts], DEFAULT_SETTINGS[:additional_pause_scripts])
  settings[:precasts].each do |ability_name, value|
    Settings[Char.name][precast_setting_key(ability_name)] = normalize_precast_setting(value, DEFAULT_PRECAST_FOR_ABILITY[ability_name])
  end
  Settings.save
end

def parse_setting_bool(value, default)
  return default if value.nil?
  return value if value == true || value == false

  case value.to_s.strip.downcase
  when 'true', 't', '1', 'yes', 'y', 'on'
    true
  when 'false', 'f', '0', 'no', 'n', 'off'
    false
  else
    default
  end
end

def normalize_threshold_setting(value, default, minimum:)
  text = value.to_s.strip
  return default if text.empty?

  number = text.to_i
  number >= minimum ? number : default
end

def normalize_precast_setting(value, default = '')
  text = value.nil? ? default.to_s : value.to_s
  text.split(/\r?\n/).map(&:rstrip).join("\n").strip
end

def normalize_script_list_setting(value, default = '')
  parse_script_list_setting(value.nil? ? default : value).join(', ')
end

def parse_script_list_setting(value)
  value.to_s.split(/[,\r\n;]+/).map(&:strip).reject(&:empty?)
end

def precast_setting_key(ability_name)
  "energywings_precast_#{ability_name.downcase.gsub(/[^a-z0-9]+/, '_').gsub(/\A_|_\z/, '')}"
end

def launch_settings_ui
  Settings.load
  Settings[Char.name] ||= {}
  settings = load_settings

  window = window_action = nil
  save_message = nil

  reaction_check = defensive_tap_check = single_check = multi_check = aoe_check = aoe_after_trample_check = guard_check = nil
  multi_threshold_entry = aoe_threshold_entry = guard_threshold_entry = nil
  pause_scripts_check = nil
  pause_bigshot_check = nil
  additional_pause_scripts_entry = nil
  precast_entries = {}

  Gtk.queue {
    Gtk::Button.new('Save')

    reaction_check = Gtk::CheckButton.new('React to enemy spell prep (Crawling Shadow / Prismatic Aegis)')
    defensive_tap_check = Gtk::CheckButton.new('Use defensive tap ability (Shadow Mantle / Luminous Flight)')
    single_check = Gtk::CheckButton.new('Use single-target wing ability (Shadow Barb / Radiant Pulse)')
    multi_check = Gtk::CheckButton.new('Use multi-target wing ability (Barbed Sweep / Blast of Brilliance)')
    aoe_check = Gtk::CheckButton.new('Use AOE wing ability (Rain of Thorns / Blinding Reprisal)')
    aoe_after_trample_check = Gtk::CheckButton.new('Only fire AOE wing ability after Mount Trample')
    guard_check = Gtk::CheckButton.new('Use defensive AOE (Carrion Guard / Wings of Warding)')

    reaction_check.active = settings[:use_prep_reaction]
    defensive_tap_check.active = settings[:use_defensive_tap]
    single_check.active = settings[:use_single_target]
    multi_check.active = settings[:use_multi_target]
    aoe_check.active = settings[:use_aoe]
    aoe_after_trample_check.active = settings[:use_aoe_after_mount_trample]
    guard_check.active = settings[:use_guard_aoe]

    multi_threshold_entry = Gtk::Entry.new
    aoe_threshold_entry = Gtk::Entry.new
    guard_threshold_entry = Gtk::Entry.new
    [multi_threshold_entry, aoe_threshold_entry, guard_threshold_entry].each do |entry|
      entry.width_chars = 6 if entry.respond_to?(:width_chars=)
    end
    multi_threshold_entry.text = settings[:multi_target_threshold].to_s
    aoe_threshold_entry.text = settings[:aoe_target_threshold].to_s
    guard_threshold_entry.text = settings[:guard_target_threshold].to_s

    pause_scripts_check = Gtk::CheckButton.new('Pause other scripts while wing abilities fire')
    pause_bigshot_check = Gtk::CheckButton.new('Pause bigshot')
    additional_pause_scripts_entry = Gtk::Entry.new
    pause_scripts_check.active = settings[:pause_other_scripts]
    pause_bigshot_check.active = settings[:pause_bigshot]
    additional_pause_scripts_entry.text = settings[:additional_pause_scripts].to_s
    additional_pause_scripts_entry.width_chars = 36 if additional_pause_scripts_entry.respond_to?(:width_chars=)

    content_box = Gtk::VBox.new(false, 0)
    content_box.border_width = 5 if content_box.respond_to?(:border_width=)
    content_box.add(Gtk::HSeparator.new)
    content_box.add(Gtk::Label.new('EnergyWings Settings'))
    content_box.add(defensive_tap_check)
    content_box.add(reaction_check)
    content_box.add(single_check)
    content_box.add(multi_check)
    content_box.add(aoe_check)
    content_box.add(aoe_after_trample_check)
    content_box.add(guard_check)
    content_box.add(Gtk::HSeparator.new)
    content_box.add(Gtk::Label.new('Target thresholds'))
    content_box.add(Gtk::Label.new('Multi-target threshold'))
    content_box.add(multi_threshold_entry)
    content_box.add(Gtk::Label.new('AOE threshold'))
    content_box.add(aoe_threshold_entry)
    content_box.add(Gtk::Label.new('Defensive bleeding AOE threshold'))
    content_box.add(guard_threshold_entry)
    content_box.add(Gtk::HSeparator.new)
    content_box.add(Gtk::Label.new('Pause these scripts while wing abilities fire'))
    content_box.add(pause_scripts_check)
    content_box.add(pause_bigshot_check)
    content_box.add(Gtk::Label.new('Additional scripts to pause (comma or semicolon separated)'))
    content_box.add(additional_pause_scripts_entry)
    content_box.add(Gtk::HSeparator.new)
    content_box.add(Gtk::Label.new('Per-ability precasts (semicolon-separated commands; blank disables)'))

    DEFAULT_PRECAST_FOR_ABILITY.each do |ability_name, default_value|
      content_box.add(Gtk::Label.new("#{ability_name} precast"))
      entry = Gtk::Entry.new
      entry.text = settings[:precasts][ability_name].to_s.gsub("\n", '; ')
      entry.width_chars = 48 if entry.respond_to?(:width_chars=)
      entry.tooltip_text = "Default: #{default_value.empty? ? 'none' : default_value.gsub("\n", ' ; ')}" if entry.respond_to?(:tooltip_text=)
      precast_entries[ability_name] = entry
      content_box.add(entry)
    end

    save_btn = Gtk::Button.new('Save')
    content_box.add(Gtk::HSeparator.new)
    content_box.add(save_btn)

    scroller = Gtk::ScrolledWindow.new
    scroller.set_policy(Gtk::POLICY_AUTOMATIC, Gtk::POLICY_AUTOMATIC) if scroller.respond_to?(:set_policy)
    scroller.add_with_viewport(content_box)

    window = Gtk::Window.new
    window.title = 'EnergyWings Setup'
    window.border_width = 5
    window.set_default_size(560, 700) if window.respond_to?(:set_default_size)
    window.set_window_position(:center) if window.respond_to?(:set_window_position)
    window.set_keep_above(true) if window.respond_to?(:set_keep_above)
    window.add(scroller)

    save_btn.signal_connect('clicked') {
      Gtk.queue {
        settings[:use_prep_reaction] = reaction_check.active?
        settings[:use_defensive_tap] = defensive_tap_check.active?
        settings[:use_single_target] = single_check.active?
        settings[:use_multi_target] = multi_check.active?
        settings[:use_aoe] = aoe_check.active?
        settings[:use_aoe_after_mount_trample] = aoe_after_trample_check.active?
        settings[:use_guard_aoe] = guard_check.active?
        settings[:multi_target_threshold] = normalize_threshold_setting(multi_threshold_entry.text, DEFAULT_SETTINGS[:multi_target_threshold], minimum: 2)
        settings[:aoe_target_threshold] = normalize_threshold_setting(aoe_threshold_entry.text, DEFAULT_SETTINGS[:aoe_target_threshold], minimum: 2)
        settings[:guard_target_threshold] = normalize_threshold_setting(guard_threshold_entry.text, DEFAULT_SETTINGS[:guard_target_threshold], minimum: 1)
        settings[:pause_other_scripts] = pause_scripts_check.active?
        settings[:pause_bigshot] = pause_bigshot_check.active?
        settings[:additional_pause_scripts] = normalize_script_list_setting(additional_pause_scripts_entry.text, DEFAULT_SETTINGS[:additional_pause_scripts])
        settings[:precasts] = DEFAULT_PRECAST_FOR_ABILITY.each_key.each_with_object({}) do |ability_name, precasts|
          precasts[ability_name] = normalize_precast_setting(precast_entries[ability_name].text, DEFAULT_PRECAST_FOR_ABILITY[ability_name])
        end
        save_message = "settings saved: prep_reaction=#{settings[:use_prep_reaction]} defensive_tap=#{settings[:use_defensive_tap]} single=#{settings[:use_single_target]} multi=#{settings[:use_multi_target]} aoe=#{settings[:use_aoe]} aoe_after_trample=#{settings[:use_aoe_after_mount_trample]} guard=#{settings[:use_guard_aoe]} pause_scripts=#{settings[:pause_other_scripts]}"
        window_action = :save
      }
    }

    window.signal_connect('delete_event') { window_action = :cancel }
    window.show_all
    window.present if window.respond_to?(:present)
  }

  before_dying { Gtk.queue { window.destroy if window } }
  wait_while { window_action.nil? }
  undo_before_dying
  Gtk.queue { window.destroy if window }

  persist_settings(settings) if window_action == :save
  echo save_message if window_action == :save && save_message
rescue StandardError => e
  echo "setup UI error: #{e.class} #{e.message}"
end

def run
  @settings = load_settings

  if setup_mode?
    launch_settings_ui
    return
  end

  # ----------------------------
  # Startup: auto-detect mode
  # ----------------------------
  pin  = find_wing_pin
  mode = wing_pin_mode(pin)

  unless pin && mode
    echo "Usage: Wear a dark or pale wing-shaped pin, then run ;energywings"
    echo "No dark/pale wing-shaped pin found in inventory."
    GameObj.inv.each { |i| echo "INV: #{i.name} ##{i.id}" if i && i.name =~ /pin/i }
    return
  end

  echo "==============================================="
  echo "  ENERGYWINGS AUTO MODE: #{mode.upcase}"
  echo "  PIN: #{pin.name} ##{pin.id}"
  echo "==============================================="

  # ----------------------------
  # Thread A: line-driven prep detection (KSwole style)
  # ----------------------------
  listener = Thread.new do
    begin
      while (line = get)
        Script.current.kill if checkdead

        # Auto-switch if you swap pins while running
        new_pin = find_wing_pin
        new_mode = wing_pin_mode(new_pin)
        if new_pin && new_mode && (new_mode != mode || new_pin.id != pin.id)
          mode = new_mode
          pin = new_pin
          echo "==============================================="
          echo "  ENERGYWINGS MODE SWITCHED: #{mode.upcase}"
          echo "  PIN: #{pin.name} ##{pin.id}"
          echo "==============================================="
        end

        react_to_enemy_prep(mode) if line =~ CREATURE_SPELL_PREPS_WING_PIN
      end
    rescue StandardError => e
      echo "listener error: #{e.class} #{e.message}"
      Script.current.kill
    end
  end

  # ----------------------------
  # Thread B: periodic combat loop
  # ----------------------------
  combat = Thread.new do
    begin
      loop do
        sleep 0.5
        next unless in_allowed_room?

        npc = living_npc
        next unless npc

        do_combat_actions(mode, npc)
      end
    rescue StandardError => e
      echo "combat error: #{e.class} #{e.message}"
      Script.current.kill
    end
  end

  listener.join
  combat.join
end
end

EnergyWings.run
