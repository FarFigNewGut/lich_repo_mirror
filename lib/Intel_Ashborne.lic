      wait_while { running? "go2" } unless $ashborne_my_area =~ /newbounty|fastbounty/
      Intel_ashborne_toolkit.top_menu unless $ashborne_my_area =~ /newbounty|fastbounty/
      respond "#{Char.name}, you have a gem bounty.  I'll let you handle it from here." unless $ashborne_my_area =~ /newbounty|fastbounty/
