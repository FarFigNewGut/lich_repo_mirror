author: NecroDeus
game: Gemstone
version: 0.4.0-rc39
tags: hunting, combat, group, support, utility
required: Lich >= 5.17.1

Companion intelligence service required by ashborne.lic.

Internal hunting intelligence service for ;ashborne.

|---------------------------------------------------------|
=end

# Hide Command Inputs
silence_me

require 'fileutils'


# OOP

module Intel_ashborne_toolkit
  extend self

  def intel_ashborne_feedback
    respond
    respond "Hello #{Char.name}, I'm Intel Ashborne."
    respond
  end

  def top_menu
    respond "|0-100 Hunting Script - Please do not AFK Script in Prime.|"
    respond
  end

  def bottom_menu
    respond
    respond "|---------------------------------------------------------|"
  end

  def safe_script_pause(script_name)
    Script.pause(script_name.to_s)
  rescue NoMethodError => error
    respond "[Intel Ashborne] skipped pausing #{script_name}: Lich script thread lookup failed (#{error.message})."
  rescue => error
    respond "[Intel Ashborne] skipped pausing #{script_name}: #{error.message}."
  end

  def safe_script_unpause(script_name)
    Script.unpause(script_name.to_s)
  rescue NoMethodError => error
    respond "[Intel Ashborne] skipped unpausing #{script_name}: Lich script thread lookup failed (#{error.message})."
  rescue => error
    respond "[Intel Ashborne] skipped unpausing #{script_name}: #{error.message}."
  end

  def post_hunt_injured?
    return false if checkdead

    injury_parts = ["head", "neck", "abs", "lhand", "rhand", "larm", "rarm", "chest", "back", "rleg", "lleg", "nerves", "torso", "leye", "reye"]
    wound_rank = injury_parts.map { |part| Wounds.send(part).to_i rescue 0 }.max || 0
    scar_rank = injury_parts.map { |part| Scars.send(part).to_i rescue 0 }.max || 0

    percenthealth.to_i < 100 || wound_rank >= 1 || scar_rank >= 1
  rescue
    false
  end

  def post_hunt_needs_healing_rc9?
    return false if checkdead

    injury_parts = ["head", "neck", "abs", "lhand", "rhand", "larm", "rarm", "chest", "back", "rleg", "lleg", "nerves", "torso", "leye", "reye"]
    wound_rank = injury_parts.map { |part| Wounds.send(part).to_i rescue 0 }.max || 0
    scar_rank = injury_parts.map { |part| Scars.send(part).to_i rescue 0 }.max || 0
    health_floor = defined?($ashborne_group_health_floor) ? $ashborne_group_health_floor.to_i : 70
    health_floor = 70 if health_floor <= 0

    percenthealth.to_i < health_floor || wound_rank >= 1 || scar_rank >= 1 || checkreallybleeding
  rescue
    false
  end

  def post_hunt_service_safe_rc8?
    return false if checkdead

    injury_parts = ["head", "neck", "abs", "lhand", "rhand", "larm", "rarm", "chest", "back", "rleg", "lleg", "nerves", "torso", "leye", "reye"]
    wound_rank = injury_parts.map { |part| Wounds.send(part).to_i rescue 0 }.max || 0
    scar_rank = injury_parts.map { |part| Scars.send(part).to_i rescue 0 }.max || 0
    health_floor = defined?($ashborne_group_health_floor) ? $ashborne_group_health_floor.to_i : 70
    health_floor = 70 if health_floor <= 0

    percenthealth.to_i >= health_floor && wound_rank < 1 && scar_rank < 1 && !checkreallybleeding
  rescue
    false
  end

  def run_post_hunt_healing_rc8
    unless Intel_ashborne_toolkit.post_hunt_needs_healing_rc9?
      respond "#{Char.name} has no wounds and is above the group safety floor; skipping ;eherbs."
      return true
    end

    healing_script = if Script.exists?("eherb")
                       "eherb"
                     elsif Script.exists?("eherbs")
                       "eherbs"
                     end

    if healing_script.nil?
      respond "#{Char.name} is hurt after the hunt, but ;eherb or ;eherbs is not installed."
      return false
    end

    respond "#{Char.name} is hurt after the hunt. Running ;#{healing_script}."
    waitrt?
    Script.run(healing_script) unless Script.running?(healing_script)
    wait_while { Script.running?(healing_script) }
    if Intel_ashborne_toolkit.post_hunt_service_safe_rc8?
      if Intel_ashborne_toolkit.post_hunt_injured?
        respond "#{Char.name} remains slightly below full health after ;#{healing_script}, but has no wounds and is above the group safety floor."
      else
        respond "#{Char.name} finished post-hunt healing."
      end
    else
      respond "#{Char.name} remains unsafe after ;#{healing_script}; remaining safely in town."
      return false
    end
    true
  rescue => error
    respond "Post-hunt healing could not run: #{error}"
    false
  end

  def post_hunt_sell
    return false unless $ashborne_rest_sell == "1"

    unless Script.exists?("eloot")
      respond "#{Char.name} could not sell after resting because ;eloot is not installed."
      return false
    end

    respond "#{Char.name} is selling post-hunt loot with ;eloot sell."
    wait_while { Script.running?("eloot") }
    Script.run("eloot", "sell")
    wait_while { Script.running?("eloot") }
    respond "#{Char.name} finished selling post-hunt loot."
    true
  rescue => error
    respond "Post-hunt selling could not run: #{error}"
    false
  end

  def cycle_stop_file
    data_directory = File.join($lich_dir, "data", "ashborne")
    FileUtils.mkdir_p(data_directory) unless File.directory?(data_directory)
    safe_name = Char.name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    File.join(data_directory, "#{safe_name}_ashborne_cycle_stopped.txt")
  end

  def publish_cycle_stopped
    payload = [
      $ashborne_group_session_id.to_s,
      Time.now.to_i,
      Char.name.to_s
    ].join("|")
    File.write(Intel_ashborne_toolkit.cycle_stop_file, payload)
  rescue => error
    respond "Ashborne follower shutdown receipt failed: #{error}"
  end

  def intel_town_service_receipt_file_rc16
    data_directory = File.join($lich_dir, "data", "ashborne")
    FileUtils.mkdir_p(data_directory) unless File.directory?(data_directory)
    leader_name = $ashborne_captain.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    member_name = Char.name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    File.join(data_directory, "#{leader_name}_ashborne_town_service_#{member_name}.txt")
  end

  def publish_town_service_ready(session_id, room_id, status = "ready")
    payload = [
      session_id.to_s,
      Time.now.to_i,
      Char.name.to_s,
      room_id.to_s,
      status.to_s
    ].join("|")
    File.write(Intel_ashborne_toolkit.intel_town_service_receipt_file_rc16, payload)
  rescue => error
    respond "Ashborne follower town-service receipt failed: #{error}"
  end

  def oop_script_kill
    Script.kill "#{$ashborne_script_one}" if Script.running? "#{$ashborne_script_one}"
    Script.kill "#{$ashborne_script_two}" if Script.running? "#{$ashborne_script_two}"
    Script.kill "#{$ashborne_script_three}" if Script.running? "#{$ashborne_script_three}"

    Script.kill "child2" if Script.running? "child2"
    Script.kill "betazzherb" if Script.running? "betazzherb"
    Script.kill "song-manager" if Script.running? "song-manager"
    Script.kill "symbolz" if Script.running? "symbolz"
    Script.kill "isigns" if Script.running? "isigns"
    Script.kill "isigils" if Script.running? "isigils"
    Script.kill "reactive" if Script.running? "reactive"
  end

  def path_rt
    # This was moved FROM ashborne
    # Group followers will briefly create a small file in scripts folder to indicate the leader should not move yet.
    # if $ashborne_group_ai == "2"
    #	if checkrt > 0
    #		#respond "create file"
    #		#Creates and overwrites
    #		File.open("/Lich5/scripts/#{Char.name}_ashborne_rt.lic", "w") do |f|
    #		f.write("
    #		Well aren't you nosey! :)
    #		This is a file leftover from testing rt on your character, it will be removed automatically.
    #
    #				")
    #
    #				f.close
    #
    #				end
    #
    #				waitrt?
    #
    #				FileUtils.rm "/Lich5/scripts/#{Char.name}_ashborne_rt.lic" if Script.exists? "#{Char.name}_ashborne_rt"
    #				#respond "delete file"
    #
    #			end
    #		end
  end

  def time_zone
    # respond "You're in the time zone."

    # respond "140 cooldown is #{$ashborne_140_cooldown}."
    # respond "Future 140 is #{$ashborne_future_140}."
    # respond
    # respond "919 cooldown is #{$ashborne_919_cooldown}."
    # respond "Future 919 is #{$ashborne_future_919}."
    # respond
    # respond "The current time is #{Time.now.to_i}."

    if $ashborne_future_140 == 0
      nil
    else
      if Time.now.to_i > $ashborne_future_140
        # respond "140 cooldown is over, you can cast this spell again."
        $ashborne_140_cooldown = "0"
        $ashborne_future_140 = 0
      end
    end

    if $ashborne_future_919 == 0
      nil
    else
      if Time.now.to_i > $ashborne_future_919
        # respond "919 cooldown is over, you can cast this spell again."
        $ashborne_919_cooldown = "0"
        $ashborne_future_919 = 0
      end
    end


    if $ashborne_timelimit == "0"
      nil
    else
      if $ashborne_killtimelimit == 0
        $ashborne_killtimelimit = Time.now.to_i + $ashborne_timelimit.to_i
      else
        if Time.now.to_i > $ashborne_killtimelimit
          # respond "Time to stop hunting."
          $ashborne_return_why = "You have reached your time limit for running Ashborne."
          $ashborne_action = 99
        end
      end
    end
  end
end

include Intel_ashborne_toolkit


intel_ashborne_kill_scripts = proc {
  Script.kill "#{$ashborne_script_one}" if Script.running? "#{$ashborne_script_one}"
  Script.kill "#{$ashborne_script_two}" if Script.running? "#{$ashborne_script_two}"
  Script.kill "#{$ashborne_script_three}" if Script.running? "#{$ashborne_script_three}"

  Script.kill "child2" if Script.running? "child2"
  Script.kill "betazzherb" if Script.running? "betazzherb"
  Script.kill "song-manager" if Script.running? "song-manager"
  Script.kill "symbolz" if Script.running? "symbolz"
  Script.kill "isigns" if Script.running? "isigns"
  Script.kill "isigils" if Script.running? "isigils"
  Script.kill "reactive" if Script.running? "reactive"
}

#########################################
#########################################

# Start of Script

#########################################
#########################################


# Local Build Information

if script.vars[1].downcase =~ /update_all/
  Intel_ashborne_toolkit.top_menu
  respond "intel_ashborne is bundled with the standalone Ashborne build."
  Intel_ashborne_toolkit.bottom_menu
  exit
end



loop {
  Intel_ashborne_toolkit.time_zone
  # Intel_ashborne_toolkit.path_rt
  if Script.running?("ashborne") || Script.running?("beta-ashborne")
    nil
  else
    Intel_ashborne_toolkit.oop_script_kill
    intel_ashborne_kill_scripts.call
    exit
  end

  line = get

  # Cman Skill Watch

  if $ashborne_cman_watch == "1"

    if line =~ /tackle/
      $ashborne_cman_tackle = "1" if Stats.prof =~ /Warrior/
    end

    if line =~ /bearhug/
      $ashborne_cman_bearhug = "1"  if Stats.prof =~ /Warrior|Monk/
    end

    if line =~ /sweep/
      $ashborne_cman_sweep = "1" if Stats.prof =~ /Rogue|Ranger|Bard|Monk/
    end

    if line =~ /Disarm Weapon/
      $ashborne_cman_disarm = "1"
    end

    if line =~ /Berserk/
      $ashborne_cman_berserk = "1" if Stats.prof =~ /Warrior/
    end

    if line =~ /Spell Cleave/
      $ashborne_cman_spellcleave = "1" if Stats.prof =~ /Warrior|Monk|Paladin/
    end

    # New Here

    if line =~ /Bull Rush/
      $ashborne_cman_bullrush = "1" if Stats.prof =~ /Warrior|Monk|Paladin/
    end

    if line =~ /Mighty Blow/
      $ashborne_cman_mightyblow = "1" if Stats.prof =~ /Warrior/
    end

    if line =~ /Eviscerate/
      $ashborne_cman_eviscerate = "1" if Stats.prof =~ /Rogue/
    end

    if line =~ /Mug/
      $ashborne_cman_mug = "1" if Stats.prof =~ /Rogue/
    end

    if line =~ /Spin Attack/
      $ashborne_cman_spinattack = "1" if Stats.prof =~ /Warrior|Rogue|Ranger|Bard|Monk|Paladin/
    end

    if line =~ /Staggering Blow/
      $ashborne_cman_staggeringblow = "1" if Stats.prof =~ /Warrior|Paladin/
    end

    if line =~ /True Strike/
      $ashborne_cman_truestrike = "1" if Stats.prof =~ /Warrior|Rogue|Ranger|Bard|Monk|Paladin/
    end

    if line =~ /Crowd Press/
      $ashborne_cman_crowdpress = "1" if Stats.prof =~ /Warrior|Rogue|Monk/
    end

    if line =~ /Dirtkick/
      $ashborne_cman_dirtkick = "1"
    end

    # Cheapshots

    if line =~ /Eyepoke/
      $ashborne_cman_eyepoke = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    if line =~ /Footstomp/
      $ashborne_cman_footstomp = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    if line =~ /Kneebash/
      $ashborne_cman_kneebash = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    if line =~ /Nosetweak/
      $ashborne_cman_nosetweak = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    if line =~ /Templeshot/
      $ashborne_cman_templeshot = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    if line =~ /Throatchop/
      $ashborne_cman_throatchop = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    if line =~ /Swiftkick/
      $ashborne_cman_swiftkick = "1" if Stats.prof =~ /Rogue|Bard|Monk/
    end

    # End Cheapshots

    if line =~ /Feint/
      $ashborne_cman_feint = "1"
    end

    if line =~ /Groin Kick/
      $ashborne_cman_groinkick = "1"
    end

    if line =~ /Haymaker/
      $ashborne_cman_haymaker = "1"  if Stats.prof =~ /Warrior|Monk/
    end

    if line =~ /Headbutt/
      $ashborne_cman_headbutt = "1"  if Stats.prof =~ /Warrior|Rogue|Monk|Paladin/
    end

    if line =~ /Sucker Punch/
      $ashborne_cman_suckerpunch = "1"  if Stats.prof =~ /Rogue|Monk/
    end

    if line =~ /Sunder Shield/
      $ashborne_cman_sundershield = "1" if Stats.prof =~ /Warrior/
    end

    if line =~ /Trip/
      $ashborne_cman_trip = "1"
    end


    if line =~ /Vault Kick/
      $ashborne_cman_truestrike = "1" if Stats.prof =~ /Warrior|Rogue|Ranger|Bard|Monk|Paladin/
    end


    # Feat Detection

    if Stats.prof == "Rogue"
      if Stats.level >= 25 && $ashborne_my_style =~ /4/ && Skills.stalkingandhiding >= 1
        $ashborne_feat_silentstrike = "1"
      end

      if Stats.level >= 50 && $ashborne_my_style =~ /4/ && Skills.stalkingandhiding >= 1
        $ashborne_feat_shadowdance = "1"
      end
    end

    if Stats.prof == "Monk"
      if Stats.level >= 25
        $ashborne_feat_mysticstrike = "1"
      end
    end


    # Shield Detection


    if line =~ /Steely Resolve/
      $ashborne_shield_steelyresolve = "1" if Stats.prof =~ /Warrior|Paladin/
    end

    if line =~ /Shield Charge/
      $ashborne_shield_shieldcharge = "1" if Stats.prof =~ /Warrior|Paladin/
    end

    if line =~ /Shield Trample/
      $ashborne_shield_shieldtrample = "1" if Stats.prof =~ /Warrior/
    end

    if line =~ /Shield Bash/
      $ashborne_shield_shieldbash = "1" if Stats.prof =~ /Warrior|Rogue|Paladin/
    end

    if line =~ /Shield Pin/
      $ashborne_shield_shieldpin = "1" if Stats.prof =~ /Warrior/
    end

    if line =~ /Shield Strike/
      $ashborne_shield_shieldstrike = "1" if Stats.prof =~ /Warrior|Rogue|Paladin/
    end

    if line =~ /Shield Push/
      $ashborne_shield_shieldpush = "1" if Stats.prof =~ /Warrior|Paladin/
    end

    if line =~ /Shield Throw/
      $ashborne_shield_shieldthrow = "1" if Stats.prof =~ /Warrior|Rogue/
      $ashborne_disable_mstrike = "1"
    end





  end

  # Cman Ready Watch



  if line =~ /Bearhug is ready for use|You cannot bearhug/
    $ashborne_cman_bearhug_cooldown = 1
  end

  if line =~ /Bearhug is still in cooldown/
    $ashborne_cman_bearhug_cooldown = 5
  end

  if line =~ /break your bearhug and escape|release your grip on a|manages to fend off your grasp/
    $ashborne_cman_bearhug_tracker = "0"
  end

  if line =~ /learned how to disarm without a weapon/
    $ashborne_cman_disarm = "0"
  end

  if line =~ /redness fades from the world and you begin to breathe/
    $ashborne_ragemode = "0"
  end

  if line =~ /know anything about Berserk\./
    $ashborne_cman_berserk = "0"
    $ashborne_ragemode = "0"
  end

  if line =~ /might have more success with anti\-magical equipment/
    $ashborne_cman_spellcleave = "0"
    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, you don't have an ensorcelled or anti magic weapon to perform the Spell Cleave maneuver."
    Intel_ashborne_toolkit.bottom_menu
  end

  if line =~ /You must be wielding a shield/
    $ashborne_no_shield_control = "1"
    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, you don't have a shield set or equipped.  Disabling shield maneuvers this hunt."
    Intel_ashborne_toolkit.bottom_menu
  end


  # General Traps for Variables


  # Feat Detection

  if line =~ /no spells afflicting you to dispel/
    $ashborne_feat_absorbmagic = "1"
    $ashborne_feat_dispelmagic = "1"
    $ashborne_feat_dispelmagic_cooldown = 10
  end

  if line =~ /You don't know anything about Dispel/
    $ashborne_feat_absorbmagic = "0"
    $ashborne_feat_dispelmagic = "0"
  end

  # Dispel Cooldown
  if line =~ /scouring away the energies that cling to you/
    $ashborne_feat_absorbmagic = "1"
    $ashborne_feat_dispelmagic = "1"
    $ashborne_feat_dispelmagic_cooldown = 100
  end

  # Dispel Ready
  if line =~ /feel you can once again dispel magic/
    $ashborne_feat_dispelmagic_cooldown = 0
  end


  # Absorb Cooldown
  if line =~ /open yourself to the ravenous void at the core of your/
    $ashborne_feat_absorbmagic_cooldown = 100
  end

  # Absorb Ready
  if line =~ /you can once again feel the hunger of the void/
    $ashborne_feat_absorbmagic_cooldown = 0
  end





  # Go2Hinterwilds traps

  if line =~ /If you can\'t provide us with at least four of them\, we won\'t be able to make the portal available/
    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, I apologize, you don't have the required currency to use the portal."
    respond
    respond "Killing creatures in the Hinterwilds gives you the currency you need."
    respond
    respond "If you've never hunted in the Hinterwilds, you need to first reach room 29860 on your own."
    respond
    respond "I recommend this help page for more information on this zone."
    respond
    respond "https://gswiki.play.net/Category:Hinterwilds_creatures"
    Intel_ashborne_toolkit.bottom_menu
    Script.kill "go2"
    intel_ashborne_kill_scripts.call
    Script.kill "ashborne"
    exit
  end

  # Rage Trap

  if line =~ /rage causes you to use all of your skill in an all out/
    if Spell[119].known? && Spell[119].affordable? && Stats.level >= 19
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      fput "prep 119"
      fput "chan #{Char.name}"
      sleep 5
      Intel_ashborne_toolkit.safe_script_unpause('ashborne')
    elsif Spell[417].known? && Spell[417].affordable? && Stats.level >= 17
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      fput "prep 417"
      fput "chan #{Char.name}"
      sleep 5
      Intel_ashborne_toolkit.safe_script_unpause('ashborne')
    end
  end

  if line =~ /What were you referring to\?|that you can\'t pull that\./
    if Room.current.id == 2674
      Intel_ashborne_toolkit.safe_script_pause('go2')
      fput "southwest"
      Intel_ashborne_toolkit.safe_script_unpause('go2')
    end
  end

  if line =~ /Suddenly\, small writhing tendrils of shadow reach out towards you\!|abruptly grows cold\, the shadows suddenly seem alive/

    if Spell[205].known? && Spell[205].affordable?
      waitcastrt?
      sleep 1
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      Spell[205].cast() if Spell[205].known? && Spell[205].affordable?
      sleep 5
      Intel_ashborne_toolkit.safe_script_unpause('ashborne')
    end
  end

  if line =~ /aid you with the Tangleweed spell/
    $ashborne_my_vine = "1"
  end

  if line =~ /obvious signs of someone hiding/
    # respond "Debug Output - Someone is here Obviously."
    $ashborne_action = 98
  end

  if line =~ /absorbs the energy of your spell/
    # Anti Magic Creature or Wrong Spell choice.
    $ashborne_action = 98
  end

  if line =~ /there is no need to fight/
    # respond "Debug Output - Sancted."
    $ashborne_action = 98
  end

  if line =~ /no need for spells of war/
    # respond "Debug Output - Sancted."
    $ashborne_action = 98
  end

  if line =~ /Be at peace my child\, there/
    # respond "Debug Output - Sancted."
    $ashborne_action = 98
  end

  if line =~ /sense of peace and calm settles over the/
    # respond "Debug Output - Sancted."
    $ashborne_action = 98
  end



  if line =~ /disruption of the noise in the area causes the spell to fizzle/
    # respond "Debug Output - Song of Noise"
    $ashborne_action = 98
  end

  if line =~ /Perhaps you should try throwing or shooting something at/
    Intel_ashborne_toolkit.safe_script_pause('ashborne')
    respond
    respond "#{Char.name}, these creatures are out of your reach. Pausing 3 seconds."
    respond
    respond "Once they attack, you should be able to hit them."
    respond
    sleep 3
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')

  end

  if line =~ /unable to muster the will to attack/
    Intel_ashborne_toolkit.safe_script_pause('ashborne')
    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, you're calmed.  Pausing 3 seconds."
    respond
    respond "Once you're attacked, you should be able to resume combat."
    Intel_ashborne_toolkit.bottom_menu
    sleep 3
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')
  end

  if line =~ /You fire a/
    $ashborne_cock_block = "0"
  end

  # Lich Support South Scatter

  if line =~ /grasps at the gnarled bone phylactery hanging around/
    $ashborne_lich_support = "1"
    Intel_ashborne_toolkit.safe_script_pause('ashborne')

    until $ashborne_lich_support == "0"
      result = dothistimeout "attack phylactery", 5, /falter significantly\, then fades away entirely\.|falter significantly\./
      if result =~ /falter significantly\, then fades away entirely\./
        $ashborne_lich_support = "0"
      elsif result =~ /falter significantly\./
        nil
      end
    end

    do_client ";#{$ashborne_loot_script}"
    wait_while { running? "#{$ashborne_loot_script}" }

    Intel_ashborne_toolkit.safe_script_unpause('ashborne')

  end



  if line =~ /Your spell misfires/

    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, I am unable to recast this spell."
    respond
    respond "I'll start casting this spell again after a fresh cooldown period."
    Intel_ashborne_toolkit.bottom_menu

    if Spell[140].known?

      $ashborne_140_cooldown = "1"
      $ashborne_future_140 = Time.now.to_i + 270

    end

    if Spell[919].known?

      $ashborne_919_cooldown = "1"
      $ashborne_future_919 = Time.now.to_i + 180

    end

    # sleep 1
    # $ashborne_140_divergence = "1"

  end

  if line =~ /You are confused\!|Your thoughts become clouded and confused/
    waitrt?
    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, you have been confused."
    respond
    respond "I'm going to run to an empty room, pause 2 seconds then continue."
    Intel_ashborne_toolkit.bottom_menu
    run
    sleep 2

  end

  if line =~ /The fog of confusion recedes\./

    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, you are no longer confused."
    Intel_ashborne_toolkit.bottom_menu
  end


  if line =~ /bright white light briefly appears\, then fades again/

    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, divergence applies.  Unable to recast this spell."
    respond
    respond "I'll start casting this spell again once you're able."
    Intel_ashborne_toolkit.bottom_menu
    sleep 1
    $ashborne_240_divergence = "1"

  end


  if line =~ /you feel able to cast Spirit Slayer again\./

    $ashborne_240_divergence = "0"
  end

  if line =~ /you feel able to cast Wall of Force again\./

    $ashborne_140_divergence = "0"
  end

  # Sorc 709 Dumb Check

  if line =~ /discern that you are the origin/
    fput "stop 709"
    sleep 1
  end

  # Dumb Stuff Check Maybe

  # Pause Ashborne, Get Spells & Return
  if line =~ /currently at Town Square\, Small Park and offering spells to those/
    if $ashborne_get_invoked == "1"
      $ashborne_my_room_number = Room.current.id
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      do_client ";go2 288"
      wait_while { running? "go2" }

      if Room.current.id == 288
        fput "ask invoker for spells"
      else
        intel_ashborne_kill_scripts.top_menu
        respond "#{Char.name}, I apologize, I could not get to the small park room 288."
        respond
        respond "Run ;ashborne support and include the generated report when filing an issue."
        intel_ashborne_kill_scripts.bottom_menu
        do_client ";kill ashborne"
        exit
      end

      do_client ";go2 #{$ashborne_my_room_number}"
      wait_while { running? "go2" }

      Intel_ashborne_toolkit.safe_script_unpause('ashborne')
    else
      nil
    end

  end

  if line =~ /reaction requirements/
    do_client ";k reactive"
    do_client ";reactive"
  end

  if line =~ /cannot attack with (.*) in your/
    $ashborne_inventory_zonk = "1"
    $ashborne_action = 99
    $ashborne_return_why = "You are having inventory issues.  This usually happens when containers are too full or you're attacking with an object not meant to be a weapon.  You may need to manually empty your hands, then try running ;ashborne cleanup or enable the auto cleanup feature with ;ashborne setup change cleanup 1 "
  end

  # RESCUEBOX Logic
  if line =~ /You drop a (.*) (strongbox|box|chest|coffer|trunk)/
    if $ashborne_rescuebox == "1"

      $ashborne_my_area = "quick"
      $ashborne_inventory_zonk = "1"
      $ashborne_action = 99
      $ashborne_return_why = "You are having inventory issues.  You just dropped a treasure strongbox, box, chest, coffer or trunk without saving it.  Maybe it's too big to fit in a container?  Per your setup option, RESCUEBOX, aborting script. "
    end
  end


  if line =~ /have a bandit problem/

    $ashborne_bounty_type = "Bandit" if $ashborne_bounty_bandit_buddy == "1"

  end

  if line =~ /already have an active Bounty Boost/
    $ashborne_stop_activating_bounty_boost = "1"
  end

  if line =~ /do not have any Bounty Boosts/
    $ashborne_no_bounty_boost_zonk = "1"
  end

  if line =~ /seem to have any expedited task reassignment/
    $ashborne_no_expedite_vouchers_zonk = "1"
  end

  if line =~ /may purchase expedited task reassignment vouchers from the SimuCoins/
    $ashborne_no_expedite_vouchers_zonk = "1"
  end

  # Using society abilities for a society you're not a part of.  Difficult to reproduce.
  if line =~ /You may not do/
    $ashborne_deedmana_zonk = "1"
  end

  # Leader is Offline

  if line =~ /Player not found/
    # Group Leader Not Found, Waiting & Trying Again.  OLD LOGIC
    # Intel_ashborne_toolkit.top_menu
    # respond "#{Char.name}, your party leader is not online.  Check their connection status or your group settings."
    # Intel_ashborne_toolkit.bottom_menu
    # do_client ";kill ashborne"
  end


  # Dead Player Oops

  if line =~ /must wait until someone resurrects|are a ghost\!/
    $ashborne_action = 99
    Intel_ashborne_toolkit.top_menu
    respond "#{Char.name}, I'm very sorry, I see you died. If ;ashborne caused your death, please share this feedback."
    Intel_ashborne_toolkit.bottom_menu
    do_client ";kill ashborne"
  end

  # Symbol of Mana ZONK
  if line =~ /but no mana flows|strain to perform the symbol of mana/
    $ashborne_deedmana_zonk = "1"
    $ashborne_deedmana = "0"
  end


  if line =~ /You will have to stand up first/
    until checkstanding
      fput "stand"
      sleep 0.5
    end
  end

  if line =~ /Experience Boosts to redeem/
    $ashborne_boost_long = "0"
  end

  if line =~ /You rub your chin/
    $ashborne_consider_setup = "1"
  end

  if line =~ /the RECOVER ITEM command/
    $ashborne_lost_item = Room.current.id
    waitrt?
    sleep 1
    fput "think to #{Char.name} #{Char.name}, you lost an item in room #{$ashborne_lost_item}."
            # Lost-item notices remain local to this character.
    if Spell.active? "218"
      waitcastrt?
      waitrt?
      fput "tell spirit to recover"
    else
      $ashborne_action = 99
      $ashborne_return_why = "You lost an item in room #{$ashborne_lost_item}. Return there, kneel and use RECOVER ITEM.  Check your recovery options with RECOVER LIST.  You can also pay the adventure guild master to recover the item for you using silvers and pick it up an hour later."
    end
  end

  if line =~ /wasting away to an attenuated mockery of/

    Intel_ashborne_toolkit.safe_script_pause('ashborne')
    do_client ";#{$ashborne_loot_script}"
    wait_while { running? "#{$ashborne_loot_script}" }
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')
  end

  if line =~ /twitches one final time before falling still upon the/

    Intel_ashborne_toolkit.safe_script_pause('ashborne')
    do_client ";#{$ashborne_loot_script}"
    wait_while { running? "#{$ashborne_loot_script}" }
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')
  end

  if $ashborne_group_ai == "0"
    nil
  else
    # Things do capture in a group.

    if line =~ /\: \"(.*) EMPATH\"/
      $ashborne_group_empath = $1
    end


    if checkdead
      respond "#{Char.name} is dead; Ashborne's local state bus will notify the group leader."
      Script.kill "ashborne"
      intel_ashborne_kill_scripts.call
      exit
    end

    if line =~ /appears less confident/
      $ashborne_group_upkeep211 = "0"
    end

    if line =~ /brilliant aura fades away/
      $ashborne_group_upkeep215 = "0"
    end

    if line =~ /"(.*) please heal us\.\"/

      if $ashborne_group_support == "0"
        nil
      else
        if $ashborne_group_empath == "#{Char.name}"
          # respond "I am the healer and I'm healing you now."
          if Script.exists? "heal2"
            nil
          else
            Script.run('repository', 'download heal2.lic')
          end

          if Script.exists? "selfhealall"
            nil
          else
            Script.run('repository', 'download selfhealall.lic')
          end
          Spell[213].cast() if Spell[213].known? && Stats.level >= 13 && Spell[213].affordable?
          waitcastrt?
          sleep 1
          # Thanks to Darkcipher for making ;unstun.  This routine is a slightly modified version of it.
          if (!checkstunned && !checkdead && players == GameObj.pcs)
            players.each do |p|
              waitcastrt?

              # Heal People

              result = dothistimeout "trans " + p.noun + " any", 3, /could not find any|feel some of your|Roundtime/
              if result =~ /could not find any/
                nil
              elsif result =~ /feel some of your|Roundtime/
                $ashborne_current_patient = "0"
                $ashborne_current_patient = "#{p.noun}"
                waitrt?
                sleep 0.1
                fput "trans " + p.noun
                fput "cure"
                waitcastrt?
                waitrt?
                do_client ";heal #{$ashborne_current_patient}"
                sleep 5
                if Script.running? "heal"
                  Script.kill "heal"
                end

              end
            end
            pause 0.5
          end
          pause 1

          Script.run('selfhealall')
          fput "stop 213"
          nil
        end
      end
    end
  end



  if line =~ /"#{$ashborne_group_empath} help\, (.*) diseased\.\"/
    # respond "Debug Output - Detected someone is poisoned."
    if $ashborne_group_support == "0"
      nil
    else
      $ashborne_group_diseased = $1
      if Spell[113].known? && Spell[113].affordable? && Stats.level >= 13
        fput "release"
        fput "prep 113"
        fput "cast #{$ashborne_group_diseased}"
        waitcastrt?
        sleep 3
      end
          nil
    end

  end


  if line =~ /"#{$ashborne_group_empath} help\, (.*) poisoned\.\"/
    # respond "Debug Output - Detected someone is poisoned."
    if $ashborne_group_support == "0"
      nil
    else
      $ashborne_group_poisoned = $1
      if Spell[114].known? && Spell[114].affordable? && Stats.level >= 14
        fput "release"
        fput "prep 114"
        fput "cast #{$ashborne_group_poisoned}"
        waitcastrt?
        sleep 3
      end
          nil
    end

  end


  if line =~ /"(.*) MANA\.\"/
    $ashborne_group_mana_target = $1
    SLICE = (checkmana * 0.25)
    waitcastrt?
    waitrt?
    fput "send #{SLICE.round(0)} #{$ashborne_group_mana_target}"


  end



  # Traps for the group leader.  You can delegate new features here.
  if $ashborne_group_ai == "1"
    if line =~ /\: \"Dead\"/
      $ashborne_recent_death = "1"
      $ashborne_action = 99
      $ashborne_return_why = "A member of your group has died."
    elsif line =~ /\: \"RESUME\"/
      Intel_ashborne_toolkit.safe_script_unpause('ashborne')
    end

    if line =~ /\: \"I\'m injured\"/
      if $ashborne_group_empath == "0"
        nil
      else
        Intel_ashborne_toolkit.safe_script_pause('ashborne')
        fput "whisper #{$ashborne_group_empath} please heal us."
      end

    elsif line =~ /\: \"Low Health"/

      if $ashborne_group_empath == "0"
        nil
      else
        Intel_ashborne_toolkit.safe_script_pause('ashborne')
        fput "whisper #{$ashborne_group_empath} please heal us."
      end

    elsif line =~ /\: \"(.*) is diseased\"/
      $ashborne_group_diseased = $1
      if $ashborne_group_empath == "0"
        nil
      else
        Intel_ashborne_toolkit.safe_script_pause('ashborne')
        fput "whisper #{$ashborne_group_empath} help, #{$ashborne_group_diseased} is diseased"
        sleep 0.5
      end
    elsif line =~ /\: \"(.*) is poisoned\"/
      $ashborne_group_poisoned = $1
      if $ashborne_group_empath == "0"
        nil
      else
        Intel_ashborne_toolkit.safe_script_pause('ashborne')
        fput "whisper #{$ashborne_group_empath} help, #{$ashborne_group_poisoned} is poisoned"
        sleep 0.5
      end
    elsif line =~ /\: \"(.*) needs MANA\"/
      if $ashborne_group_sharemana == "0"
        nil
      else
        $ashborne_group_mana_target = $1
        waitrt?
        waitcastrt?
        SLICE = (checkmana * 0.25)
        waitcastrt?
        waitrt?
        fput "send #{SLICE.round(0)} #{$ashborne_group_mana_target}"
        nil
        sleep 0.5
      end


    end
  end

  if line =~ /but it has no effect|your attack has no effect/
    $ashborne_action = 99
    $ashborne_return_why = "You aren't wearing correct equipment to fight a creature in this zone. You may need enchanted weapons, armor or ammo."
  end


  # Caedera Trap
  if line =~ /ground shakes violently as a caedera explodes from the ground/
    nil
  elsif line =~ /appendages burst from the ground and tear into/
    nil

  # Boil Trap
  # elsif line =~ /burst from the ground|explodes from the ground|earth cracks|icy mist rises from the ground/

  # New Boil Logic
  elsif line =~ /ground beneath your feet suddenly frosts and rumbles|earth cracks beneath you\, releasing a column of frigid|stalagmites burst from the ground beneath you\!|ground beneath your feet begins to boil violently|debris explodes from the ground beneath you\!/
    # respond "Debug Output - Intel Boil Trap"
    $ashborne_action = 98
  end

  if line =~ /Accept your fate/
    Intel_ashborne_toolkit.safe_script_pause('ashborne')
  end

  if line =~ /tossed about like a rag|you flail awkwardly before landing with a dull/
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')
  end


  if checkright == "caederine"
    fput "stow right" unless $ashborne_active_cleanup != "0"
  end

  if checkleft == "caederine"
    fput "stow left" unless $ashborne_active_cleanup != "0"
  end

  if $ashborne_my_area =~ /teraspyrothag/
    if checkleft == "glaes"
      fput "stow left"
    end

    if checkright == "glaes"
      fput "stow right"
    end
  end



  # Rifted Check

  if line =~ /Suddenly you feel sick and queasy\, and your world seems blurry and indistinct|hurled improbably backwards\, away from the fissure\./
    Intel_ashborne_toolkit.safe_script_pause('ashborne')
    if $ashborne_my_area =~ /rift1/
      Script.run('go2', '2579')
      pause 1
    elsif $ashborne_my_area =~ /rift2/
      Script.run('go2', '12142')
      pause 1
    elsif $ashborne_my_area =~ /rift3/
      Script.run('go2', '12184')
      pause 1
    elsif $ashborne_my_area =~ /rift4/
      Script.run('go2', '12138')
      pause 1
    elsif $ashborne_my_area =~ /rift5/
      Script.run('go2', '12159')
      pause 1
    elsif $ashborne_my_area =~ /northscatter/
      Script.run('go2', '12219')
      pause 1
    elsif $ashborne_my_area =~ /southscatter/
      Script.run('go2', '12245')
      pause 1
    end
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')
  end

  # AIM Missing Trap

  if line =~ /is already missing that|cannot aim that high/
    Intel_ashborne_toolkit.safe_script_pause('ashborne')
    $ashborne_aim_fail = $ashborne_aim_fail + 1
    waitrt?
    sleep 0.5
    if $ashborne_aim_fail == 1
      fput "aim left leg"
    elsif $ashborne_aim_fail == 2
      fput "aim right leg"
    elsif $ashborne_aim_fail == 3
      fput "aim clear"
    end
    Intel_ashborne_toolkit.safe_script_unpause('ashborne')
  end


  # Bounty Support

  if $ashborne_bounty_intel_watch == "0"
    nil
  else

    # Bounty Forks

    if line =~ /You are eligible for new task assignment/
      $ashborne_bounty_stage = "1"
      $ashborne_bounty_type = "Eligible"
    end

    if line =~ /You will be eligible for new task assignment/
      $ashborne_bounty_stage = "8"
      $ashborne_bounty_type = "Not Eligible"
    end

    if line =~ /probably can\'t help you if (she|he) can't see you/
      Intel_ashborne_toolkit.top_menu
      respond "#{Char.name}, you are invisible.  Please UNHIDE.  After doing so, restart Ashborne Bounty feature."
      # respond "#{Char.name}, we're about to do bandits."
      # respond "Use ;ua to begin or ;ka to do your own thing."
      Intel_ashborne_toolkit.bottom_menu
      Script.kill "ashborne"
      intel_ashborne_kill_scripts.call
      exit

    end

    # Trap Bounty Type

    if line =~ /provide a protective escort/
      $ashborne_bounty_type = "Escort"
      Intel_ashborne_toolkit.top_menu
      respond "#{Char.name} - Escort Bounties Disabled Currently."
      # respond "#{Char.name}, we're about to do bandits."
      # respond "Use ;ua to begin or ;ka to do your own thing."
      Intel_ashborne_toolkit.bottom_menu
      Script.kill "ashborne"
      intel_ashborne_kill_scripts.call
      exit

    end

    if line =~ /some kind of lost heirloom/
      $ashborne_bounty_type = "Heirloom"
      $ashborne_bounty_stage = "4"

    end

    if line =~ /and LOOT the item/
      $ashborne_bounty_type = "Heirloom"
      $ashborne_bounty_heirloom_type = "LOOT"
      $ashborne_bounty_stage = "5" if $ashborne_bounty_stage == "0"

    end

    if line =~ /SEARCH the area/
      $ashborne_bounty_type = "Heirloom"
      $ashborne_bounty_heirloom_type = "SEARCH"
      Intel_ashborne_toolkit.top_menu
      respond "#{Char.name} - This is a SEARCH bounty."
      respond
      respond "Head out to the creature area, stow all, kneel and search."
      respond
      respond "You should move rooms every search.  Use 3-4 rooms for best results."
      Intel_ashborne_toolkit.bottom_menu
      Script.kill "ashborne"
      intel_ashborne_kill_scripts.call
      exit

    end

    if line =~ /have a bandit problem/

      $ashborne_bounty_type = "Bandit" if $ashborne_bounty_bandit_buddy == "1"
      $ashborne_bounty_type = "Bandit" unless $ashborne_my_area =~ /newbounty|fastbounty/
      $ashborne_bounty_stage = "4" unless $ashborne_my_area =~ /newbounty|fastbounty/
      # #Intel_ashborne_toolkit.safe_script_pause('ashborne')
      # Intel_ashborne_toolkit.top_menu unless $ashborne_my_area =~ /newbounty|fastbounty/
      # respond "#{Char.name} - Bandit Setting Disabled Currently." unless $ashborne_my_area =~ /newbounty|fastbounty/
      # Intel_ashborne_toolkit.bottom_menu unless $ashborne_my_area =~ /newbounty|fastbounty/
      # Script.kill "ashborne" unless $ashborne_my_area =~ /newbounty|fastbounty/
      # intel_ashborne_kill_scripts.call unless $ashborne_my_area =~ /newbounty|fastbounty/
      # exit unless $ashborne_my_area =~ /newbounty|fastbounty/
      # $ashborne_my_area = "bounty"
    end

    if line =~ /suppress bandit activity/
      $ashborne_bounty_type = "Bandit"
      $ashborne_bounty_stage = "5"
      $ashborne_my_area = "bandit"

    end

    if line =~ /a creature problem they\'d like you to solve/
      $ashborne_bounty_stage = "4"
      $ashborne_bounty_type = "creature"
    end

    if line =~ /local resident urgently needs/
      $ashborne_bounty_type = "child"
      $ashborne_bounty_stage = "4"

    end

    if line =~ /report to Quin Telaren|report back to one of the|report to the purser to find out|report back to Quin Telaren/
      $ashborne_bounty_stage = "4"

    end

    if line =~ /report back to one of the Icemule Trace gate|report back to the purser of/

      $ashborne_bounty_stage = "4"

    end

    if line =~ /You have succeeded in your task and can return to the Adventurer\'s Guild/

      $ashborne_bounty_stage = "7"

    end

    # Combat Matches

    if line =~ /This must be the child|made contact with the child/
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      if Script.exists? "step2"
        nil
      else
        Script.run('repository', 'download step2.lic')
      end

      if Script.exists? "child2"
        nil
      else
        Script.run('repository', 'download child2.lic')
      end
      wait_while { running? "#{$ashborne_loot_script}" }
      do_client ";#{$ashborne_loot_script}"
      wait_while { running? "#{$ashborne_loot_script}" }
      do_client ";child2"

    end

    if line =~ /You may return to the Adventurer's Guild|may pick up your reward there|You have completed this portion of your Adventurer\'s Guild task|looks like the heirloom that you are searching for/
      # Reload Ashborne to collect reward.
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      Script.run "#{$ashborne_loot_script}"

      if checkarea =~ /The Rift/
        waitrt?
        waitcastrt?
        if $ashborne_my_society == "Voln"
          fput "sym return"
        end

        do_client ";go2 2635"
        wait_while { running? "go2" }


        Spell[130].cast() if Spell[130].known? && Stats.level >= 30 && Spell[130].affordable?

        do_client ";go2 2300"
        wait_while { running? "go2" }

      end

      if Script.running? "child2"
        Script.kill "child2"
      end
      Script.kill "ashborne"
      do_client ";ashborne #{$ashborne_my_style} bounty"
      exit
    end

    if line =~ /You have succeeded in your task and can return to the Adventurer\'s Guild/

      $ashborne_bounty_stage = "7"

    end

    if line =~ /and should bring it back to/

      $ashborne_bounty_stage = "4.25"
      $ashborne_bounty_type = "Heirloom"

    end

    if line =~ /don\'t see it in your hands/

      Script.kill "ashborne"
      Intel_ashborne_toolkit.top_menu
      respond "#{Char.name}, you seem to be done with your heirloom bounty but are having trouble getting the heirloom from your #{Vars.lootsack}."
      respond
      respond "Most likely this happens because the heirloom was put in a different container."
      respond
      respond "If you can't find the heirloom item, you might have to abandon this bounty."
      respond
      respond "I'll let you find the item and turn it in.  After doing so, restart Ashborne Bounty feature."
      Intel_ashborne_toolkit.bottom_menu
      Script.kill "ashborne"
      intel_ashborne_kill_scripts.call
      exit

    end

    if line =~ /you must be able to use at least one of your hands/
      Intel_ashborne_toolkit.safe_script_pause('ashborne')
      Intel_ashborne_toolkit.safe_script_pause('betazzherb')
      waitrt?
      if Stats.prof == "Cleric"
        Spell[315].cast() if Spell[315].known? && Stats.level >= 15 && Spell[315].affordable?
        fput "stow all"
        Intel_ashborne_toolkit.safe_script_unpause('ashborne')
        Intel_ashborne_toolkit.safe_script_unpause('betazzherb')
      else
        Intel_ashborne_toolkit.top_menu
        respond "#{Char.name}, you might be cursed or having hand/container management issues."
        respond
        respond "I'm taking you to the nearest supernode so you can fix this."
        Intel_ashborne_toolkit.bottom_menu
        waitrt?
        if Char.status =~ /Voln/
          fput "sym return"
        end

        Spell[130].cast() if Spell[130].known? && Stats.level >= 30 && Spell[130].affordable?

        do_client ";go2 supernode"
        sleep 3
        do_client ";u go2"
        wait_while { running? "go2" }

        Script.kill "ashborne"
        intel_ashborne_kill_scripts.call
        exit
      end
    end



    # Herb Forage Traps
