#Mtrawl
=begin

Automated Mana Trawling for the Nyessem event.
A reworking of trawl.lic by Alastir.

author: Mara
contact: mara.lilly on Discord, @Lillymara on GitHub
co-author: Claude (Anthropic) - claude.ai/code

https://gswiki.play.net/Mana_Trawl

--- SETUP ---

Stand in any trawl room and run ;mtrawl. The script prefers you redeem your
aevarch before starting. If none is in inventory it withdraws one entry from
the inquisitor automatically. When entries run out it trades any pending
incidentals to the girl then exits.

--- VARIABLES ---

mtrade (default false) - automatic incidental trade-ins
  Shallow Cast, Fair Catch, and Grand Reel results yield boxes of incidentals
  that can be traded to the girl for more event currency. With mtrade on, the
  script stows them and walks to the trade-in girl (room 36702) when your stow
  container fills up or entries run out.
  ;vars set mtrade=true

mrest (default true) - pause fishing when mind is saturated
  Pauses before waggling when your mind is full and resumes once it drops.
  ;vars set mrest=false

mtrawl_junk (default: fish flakes only) - which items to scan for and trade on exit
  NOTE: Only fish flakes are traded by default. Vissi extractors and all other
  items are left alone unless explicitly added to the junk list.
  When entries run out the script looks in your stow container and trades
  anything matching the junk list. Tiers: T1=Shallow Cast, T2=Fair Catch,
  T4=Grand Reel. Items not on the list are never touched.
  Set by tier:        ;mtrawl junk T1
  Set by item name:   ;mtrawl junk a disfigured water blobfish
  Remove an entry:    ;mtrawl junk remove T2  (or shorthand: ;mtrawl rem T2 / ;mtrawl rm T2)
  Clear the list:     ;mtrawl junk clear
  Show the list:      ;mtrawl junk list

--- IN-GAME COMMANDS ---

These can be sent while the script is running:
  ;send mtrawl trade           - trade all queued incidentals now, after current fish
  ;send mtrawl status          - show current variable settings
  ;send mtrawl junk T4         - add Grand Reel fish to junk list
  ;send mtrawl junk list       - show junk list

--- QUICK REFERENCE ---

  ;mtrawl                      - start fishing
  ;mtrawl trade                - walk to the girl, trade junk from stow, walk back
  ;mtrawl status               - show current settings (works without script running)
  ;mtrawl list                 - show full loot table by tier (works without script running)
  ;mtrawl junk <tier or full name>  - manage junk list (works without script running)

=end

module Trawl

  GIRL_ROOM = 36702

  TRADE_TIERS = {
    'T1' => /vissi extractor|fish flakes/i,
    'T2' => /(?:sand-abraded|ribbed|abyss-touched|bubble-streaked|ray-flat|tide-twisted) formation/i,
    'T4' => /disfigured water/i
  }.freeze

  TRADE_DEFAULT = /fish flakes/i

  def self.goto(room_id)
    Script.start('go2', room_id.to_s)
    wait_while { Script.running?('go2') }
  end

  def self.show_loot
    respond '[Mtrawl] ----- Mana Trawl Loot Table -----'
    respond '[Mtrawl] T1 - Shallow Cast (tradeable)'
    respond '[Mtrawl]   a vissi extractor'
    respond '[Mtrawl]   a package of ruby red fish flakes (12 currency)'
    respond '[Mtrawl] T2 - Fair Catch (tradeable)'
    respond '[Mtrawl]   a coarse sand-abraded formation'
    respond '[Mtrawl]   a delicate ribbed formation'
    respond '[Mtrawl]   a glassy abyss-touched formation'
    respond '[Mtrawl]   a rippled bubble-streaked formation (30 currency)'
    respond '[Mtrawl]   a spotted ray-flat formation'
    respond '[Mtrawl]   a warped tide-twisted formation (30 currency)'
    respond '[Mtrawl] T3 - Favored Cast (keeper)'
    respond '[Mtrawl]   a Lower Self vissi'
    respond '[Mtrawl]   a Higher Self vissi'
    respond '[Mtrawl]   a Tidal Visions vissi'
    respond '[Mtrawl] T4 - Grand Reel (tradeable)'
    respond '[Mtrawl]   a disfigured water blobfish/brinefish/driftfish/gloomfish'
    respond '[Mtrawl]   a disfigured water gloopfish (60 currency)'
    respond '[Mtrawl]   a disfigured water lumpfin/mudgill/noodlefish/oceanborn'
    respond '[Mtrawl]   a disfigured water nubblefin (60 currency)'
    respond '[Mtrawl]   a disfigured water pufflet (60 currency)'
    respond '[Mtrawl]   a disfigured water squibfish/squidgeon/trenchling/wigglefin/dumple'
    respond '[Mtrawl] T5 - Deep Bounty (keeper)'
    respond '[Mtrawl]   grippy brown kelp / scallop / rough sparkling diamond'
    respond '[Mtrawl]   shimmering tide-scarred formation / briny dusk-washed formation'
    respond '[Mtrawl] T5 - Lustrous Haul (keeper)'
    respond '[Mtrawl]   salt-crusted leather bag / dense purple starfish'
    respond '[Mtrawl] T6 - Mythic Haul / Radiant Pull / Gilded Catch (keeper)'
    respond '[Mtrawl]   confused bumpy seahorse / spiny puzzled lionfish / prickly perplexed pufferfish'
    respond '[Mtrawl]   Wisdom vissi / Wealth vissi'
    respond '[Mtrawl] ------------------------------------'
    respond '[Mtrawl] Source: https://gswiki.play.net/Mana_Trawl'
  end

  def self.trade_pattern
    junk = Array(Vars.mtrawl_junk)
    return TRADE_DEFAULT if junk.empty?
    patterns = junk.map { |e| TRADE_TIERS[e.upcase] || Regexp.new(Regexp.escape(e), Regexp::IGNORECASE) }
    Regexp.union(*patterns)
  end

  def self.show_junk
    junk = Array(Vars.mtrawl_junk)
    if junk.empty?
      respond '[Mtrawl] Junk list is empty - defaulting to fish flakes only.'
    else
      respond '[Mtrawl] Current junk list: ' + junk.join(', ')
    end
  end

  def self.handle_junk(arg)
    case arg.strip
    when /^list$/i, ''
      Trawl::show_junk
    when /^clear$/i
      Vars.mtrawl_junk = []
      respond '[Mtrawl] Junk list cleared - defaulting to T1.'
    when /^remove\s+(.+)/i
      entry = $1.strip
      junk = Array(Vars.mtrawl_junk)
      junk.reject! { |j| j.casecmp(entry) == 0 }
      Vars.mtrawl_junk = junk
      respond "[Mtrawl] Removed '#{entry}' from junk list."
    else
      entry = TRADE_TIERS.key?(arg.upcase) ? arg.upcase : arg
      junk = Array(Vars.mtrawl_junk)
      if junk.any? { |j| j.casecmp(entry) == 0 }
        respond "[Mtrawl] '#{entry}' is already in the junk list."
      else
        junk << entry
        Vars.mtrawl_junk = junk
        respond "[Mtrawl] Added '#{entry}' to junk list."
        Trawl::show_junk
      end
    end
  end

  def self.print_summary
    respond ''
    respond '[Mtrawl] ----- Session Summary -----'
    respond "[Mtrawl] Waggles:      #{@stats[:waggles]}"
    respond "[Mtrawl] Items stowed: #{@stats[:stowed]}"
    respond "[Mtrawl] Items traded: #{@stats[:traded]} (#{@stats[:trade_runs]} trip#{@stats[:trade_runs] == 1 ? '' : 's'} to the girl)"
    respond "[Mtrawl] Currency:     #{@stats[:currency]} aevits"
    respond '[Mtrawl] ---------------------------'
  end

  # Trades one item and captures the currency response.
  def self.trade_item(item_id)
    fput "get ##{item_id}"
    fput "swap"
    r1 = dothistimeout "ask girl about trade", 10, /aevit|\w+/i
    r2 = dothistimeout "ask girl about trade", 10, /aevit|\w+/i
    [r1, r2].each { |r| @stats[:currency] += $1.to_i if r =~ /(\d+)\s*aevit/i }
  end

  def self.flush_trades
    return if @trade_queue.empty?
    @stats[:trade_runs] += 1
    Trawl::goto(GIRL_ROOM)
    @trade_queue.each { |id|
      Trawl::trade_item(id)
      @stats[:traded] += 1
    }
    @trade_queue.clear
    Trawl::goto(@trawl_room)
  end

  def self.scan_stow_for_trades
    pattern = Trawl::trade_pattern
    items = GameObj.inv.flat_map { |obj| Array(obj.contents) }
                       .select { |item| item.name =~ pattern }
    return unless items && !items.empty?
    @stats[:trade_runs] += 1
    Trawl::goto(GIRL_ROOM)
    items.each { |item|
      Trawl::trade_item(item.id)
      if checkright || checkleft
        fput "stow ##{item.id}"
      else
        @stats[:traded] += 1
      end
    }
    Trawl::goto(@trawl_room)
  end

  def self.stow_item(item_id)
    fput "get ##{item_id}"
    result = dothistimeout "stow ##{item_id}", 5, /You put|There isn't enough room|You can't fit/
    if result =~ /There isn't enough room|You can't fit/
      Trawl::flush_trades
      dothistimeout "stow ##{item_id}", 5, /You put/
    end
    @stats[:stowed] += 1
  end

  def self.aevarch
    result = dothistimeout 'get my aevarch', 10, /Get what?|You remove|You discreetly remove|You already have that/
    if result =~ /Get what?/
      result = dothistimeout 'event entries inquisitor 1', 10, /You grab a wisp of prismatic aevarch from your entries stash|You don't have that many entries for Nyessem's events/
      if result =~ /You grab a wisp of prismatic aevarch from your entries stash/
        Trawl::waggle_pool
      elsif result =~ /You don't have that many entries for Nyessem's events/
        Trawl::flush_trades
        Trawl::scan_stow_for_trades
        raise SystemExit
      end
    elsif result =~ /You remove|You discreetly remove|You already have that/
      fput 'redeem my aevarch'
      Trawl::aevarch
    end
  end

  def self.check_box
    result = dothistimeout "look in my box", 5, /In the .*(?:you see|box:)|There is nothing in the box/
    case result
    when /In the .*(?:you see|box:)/
      box = GameObj.right_hand || GameObj.left_hand
      return unless box
      if box.contents.nil? || box.contents.empty?
        respond '[Mtrawl] Unable to read box contents, skipping.'
        fput 'toss box'
        Trawl::waggle_pool
        return
      end
      items = box.contents.dup
      items.each { |item|
        Trawl::stow_item(item.id)
        @trade_queue << item.id if @trawl_trade
      }
      Trawl::check_box
    when /There is nothing in the box/
      fput "toss box"
      Trawl::waggle_pool
    end
  end

  def self.empty_box
    result = dothistimeout "open my box", 10, /You open a saltglass-lined box/
    if result =~ /You open a saltglass-lined box/
      @stats[:waggles] += 1
      Trawl::check_box
    end
  end

  def self.show_status
    mtrade = Vars.mtrade == true
    mrest  = Vars.mrest != false
    junk   = Array(Vars.mtrawl_junk)
    respond '[Mtrawl] ----- Current Settings -----'
    respond "[Mtrawl] mtrade : #{mtrade} - incidentals will #{mtrade ? 'be traded to the girl automatically when stow fills' : 'just be stowed, no trips to the girl'}"
    respond "[Mtrawl] mrest  : #{mrest} - fishing will #{mrest ? 'pause when mind is saturated and resume when it drops' : 'continue regardless of mind state'}"
    respond "[Mtrawl] junk   : #{junk.empty? ? 'fish flakes (default)' : junk.join(', ')} - items scanned for on exit and traded to the girl"
    respond '[Mtrawl] ----------------------------'
    respond '[Mtrawl] Tiers: T1=Shallow Cast  T2=Fair Catch  T4=Grand Reel'
  end

  def self.check_commands
    while (cmd = Script.current.gets?)
      case cmd.strip
      when /^trade$/i
        @force_trade = true
        respond '[Mtrawl] Will trade after current cycle completes.'
      when /^status$/i
        Trawl::show_status
      when /^junk\s*(.*)/i
        Trawl::handle_junk($1)
      when /^re?m\s+(.*)/i
        Trawl::handle_junk("remove #{$1}")
      when /^list$/i
        Trawl::show_loot
      end
    end
  end

  def self.waggle_pool
    Trawl::check_commands
    if @force_trade
      Trawl::flush_trades
      @force_trade = false
    end
    waitrt?
    if Vars.mrest != false && checkmind.to_i >= 6
      respond '[Mtrawl] Mind is full, waiting to recover...'
      wait_while { checkmind.to_i >= 6 }
      respond '[Mtrawl] Mind recovered, resuming.'
    end
    result = dothistimeout "waggle pool", 10, /You don't have a valid aevarch to play this game!|consolation aevit into your pocket|handing you a consolation prize|hand you a faintly humming container as acknowledgment|passing you a box in exchange|offers you a token package in its place|hands you a box in quiet recognition|eases the flawless creation into a saltglass-lined box and presents it to you|The shards fold inward, glowing brighter with each beat, until a solid shape rests where chaos once drifted, perfectly balanced, perfectly still.|You begin to waggle instinctively, as if remembering a song written in your bones.  The pool answers with a rising chime.  Shards dance in ecstatic orbit before collapsing into a single luminous form that hums with your heartbeat.|The fragments spiral, obedient to your gesture.  A silver thread of energy binds them, welding light to matter.  When the glow fades, something new gleams, warm with your lifeforce./

    if result =~ /You don't have a valid aevarch to play this game!/
      Trawl::aevarch

    elsif result =~ /consolation aevit into your pocket/
      @stats[:waggles] += 1
      @trawl_trade = false
      Trawl::waggle_pool

    elsif result =~ /handing you a consolation prize/
#      respond 'Shallow Cast'
      if Vars.mtrade == true
        @trawl_trade = true
      else
        @trawl_trade = false
      end
      Trawl::empty_box

    elsif result =~ /hand you a faintly humming container as acknowledgment/
#      respond 'Favored Cast?'
      @trawl_trade = false
      Trawl::empty_box

    elsif result =~ /passing you a box in exchange/
#      respond 'Fair Catch'
      if Vars.mtrade == true
        @trawl_trade = true
      else
        @trawl_trade = false
      end
      Trawl::empty_box

    elsif result =~ /offers you a token package in its place/
#      respond 'Grand Reel'
      if Vars.mtrade == true
        @trawl_trade = true
      else
        @trawl_trade = false
      end
      Trawl::empty_box

    elsif result =~ /hands you a box in quiet recognition/
#      respond 'Deep Bounty'
      @trawl_trade = false
      Trawl::empty_box

    elsif result =~ /The shards fold inward, glowing brighter with each beat, until a solid shape rests where chaos once drifted, perfectly balanced, perfectly still./
      #respond 'Lustrous Haul'
      @trawl_trade = false
      Trawl::empty_box
      
    elsif result =~ /You begin to waggle instinctively, as if remembering a song written in your bones.  The pool answers with a rising chime.  Shards dance in ecstatic orbit before collapsing into a single luminous form that hums with your heartbeat./
      #Radiant Pull
      @trawl_trade = false
      Trawl::empty_box

    elsif result =~ /eases the flawless creation into a saltglass-lined box and presents it to you|The fragments spiral, obedient to your gesture.  A silver thread of energy binds them, welding light to matter.  When the glow fades, something new gleams, warm with your lifeforce./
#      respond 'Gilded Catch'
      @trawl_trade = false
      Trawl::empty_box      
    else
      Script.pause
      Lich::Messaging.stream_window("Unknown Result: Send this messaging to Alastir please.", "thoughts")
      
    end
  end

  cmd_arg = Script.current.vars[1..-1]&.join(' ').to_s.strip
  if cmd_arg =~ /^status$/i
    Trawl::show_status
  elsif cmd_arg =~ /^junk\s*(.*)/i
    Trawl::handle_junk($1)
  elsif cmd_arg =~ /^re?m\s+(.*)/i
    Trawl::handle_junk("remove #{$1}")
  elsif cmd_arg =~ /^list$/i
    Trawl::show_loot
  elsif cmd_arg =~ /^trade$/i
    @trawl_room = Room.current.id
    @stats = { waggles: 0, stowed: 0, traded: 0, trade_runs: 0, currency: 0 }
    Trawl::scan_stow_for_trades
    respond "[Mtrawl] Trade run complete. #{@stats[:traded]} items traded for #{@stats[:currency]} aevits."
  elsif cmd_arg.empty?
    @trawl_room = Room.current.id
    @trawl_trade = false
    @trade_queue = []
    @force_trade = false
    @stats = { waggles: 0, stowed: 0, traded: 0, trade_runs: 0, currency: 0 }

    if checkright || checkleft
      fput 'stow all'
      waitrt?
      if checkright || checkleft
        respond '[Mtrawl] Could not stow everything - please empty your hands before starting.'
        raise SystemExit
      end
    end

    Script.at_exit { Trawl::print_summary }

    Trawl::waggle_pool
  else
    respond "[Mtrawl] Unknown command '#{cmd_arg}'. Try: ;mtrawl status / trade / list / junk / rem"
  end

end