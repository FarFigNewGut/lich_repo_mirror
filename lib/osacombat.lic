	cast_spell_rapid_fire if @combat_data["spell_rapid_fire"] && (!$rapid_fire_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_rapid_fire if @combat_data["spell_rapid_fire"] && $rapid_fire_first_cast
	cast_spell_zealot if @combat_data["cast_spell_di_zeal"]
	cast_spell_wall_of_force if @combat_data["spell_wall_of_force"] && (!$wall_of_force_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_wall_of_force if @combat_data["spell_wall_of_force"] && $wall_of_force_first_cast
	cast_spell_faith_shield if @combat_data["spell_shield_faith"] && (!$faith_shield_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_faith_shield if @combat_data["spell_shield_faith"] && $faith_shield_first_cast
	cast_spell_heroism if @combat_data["spell_heroism"] && (!$heroism_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_heroism if @combat_data["spell_heroism"] && $heroism_first_cast
	cast_spell_group_barkskin if @combat_data["barkskin_spell_group"] && (!$group_barkskin_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_group_barkskin if @combat_data["barkskin_spell_group"] && $group_barkskin_first_cast
	cast_spell_barkskin if @combat_data["barkskin_spell"] && (!$barkskin_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_barkskin if @combat_data["barkskin_spell"] && $barkskin_first_cast
	cast_spell_beacon_of_courage if @combat_data["spell_beacon_of_courage"] && (!$beacon_of_courage_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_beacon_of_courage if @combat_data["spell_beacon_of_courage"] && $beacon_of_courage_first_cast
	sing_song_song_of_tonis if @combat_data["song_song_of_tonis"] && (!$song_of_tonis_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	sing_song_song_of_tonis if @combat_data["song_song_of_tonis"] && $song_of_tonis_first_cast
	cry_warcry_shout if @combat_data["warcry_shout"] && (!$warcry_shout_first_cry && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cry_warcry_shout if @combat_data["warcry_shout"] && $warcry_shout_first_cry
	cry_warcry_holler if @combat_data["warcry_holler"] && (!$warcry_holler_first_cry && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cry_warcry_holler if @combat_data["warcry_holler"] && $warcry_holler_first_cry
	use_shield_steely if @combat_data["shield_steely"] && (!$osa_shield_steely_first_use && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	use_shield_steely if @combat_data["shield_steely"] && $osa_shield_steely_first_use	
	use_cman_surge_of_strength_cooldown if @combat_data["cman_surge_of_strength_cooldown"] && (!$osa_cman_surge_of_strength_cooldown_first_use && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	use_cman_surge_of_strength_cooldown if @combat_data["cman_surge_of_strength_cooldown"] && $osa_cman_surge_of_strength_cooldown_first_use
	use_cman_surge_of_strength_no_cooldown if @combat_data["cman_surge_of_strength_no_cooldown"] && (!$osa_cman_surge_of_strength_no_cooldown_first_use && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	use_cman_surge_of_strength_no_cooldown if @combat_data["cman_surge_of_strength_no_cooldown"] && $osa_cman_surge_of_strength_no_cooldown_first_use
	use_light_wings_luminous_flight if @combat_data["wings_light_luminous_flight"] && (!$wings_light_luminous_flight_first_use && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
