	row = ui(rows, :row)
	ui(row, :entry, label: "Sever Spell 2:", tip: "Spell number you can cast for the crew during a Spell Sever call. Leave blank if unused.", var: 'sever_spell_2', default: "", width_chars: 6, label_width: 120)
