$osa_gemstone_arcanists_ascendancy_first_activate = false
$osa_gemstone_arcane_aegis_first_activate = false
$wings_light_luminous_flight_first_use = false
$wings_light_prismatic_aegis_first_use = false
$wings_light_wings_of_warding_first_use = false
$wings_dark_shadow_mantle_first_use = false
$wings_dark_crawling_shadow_first_use = false
$wings_dark_carrion_guard_first_use = false

$poaching              = false
$poach_strikes         = 0
$osa_reactive          = false
$osa_reactivetype      = nil
$osa_reactive_creatures = []
if @room_creatures.nil?
	@room_creatures = Array.new
end
if script.vars[1] == '?'
	osacombat_help_display
	exit
elsif script.vars[1] == 'living'
	self.save_script_data("enemy_type", "living")
	respond ""
	respond "Setting Creature Type to Living"
	respond ""
elsif script.vars[1] == 'undead'
	self.save_script_data("enemy_type", "undead")
	respond ""
	respond "Setting Creature Type to Undead"
	respond ""
elsif (script.vars[1] =~ /setup/i)
	self.combatsetup()
	exit
elsif (Script.current.vars[1] =~ /profile/i)
	self.profile(Script.current.vars)
	exit
elsif script.vars[1] == 'help'
	osacombat_help_display
	exit
elsif script.vars[1] == 'version'
	respond ""
	respond "OSACombat Version #{version}"
	respond ""
	exit
end

$osa_hook_name = "osa_combat_setup_interceptor"
UpstreamHook.remove($osa_hook_name)
$osa_interceptor = proc do |xml|
	next xml unless xml.start_with?('<c>')
	next xml if xml =~ /^<c>_/i
	cmd = xml.sub(/\A<c>/i, '').sub(/<\/c>\z/i, '').strip
	case cmd.downcase
	when 'osacombat setup'
		self.combatsetup
		nil   # swallow the command so it doesn't echo/run elsewhere (optional)
	when 'osacombat help', 'osacombat ?'
		osacombat_help_display
		nil
	else
		xml
	end
end

UpstreamHook.add($osa_hook_name, $osa_interceptor)

if @combat_data["usebriefcombat"]
	multifput "flag combatbrief on", "flag combatnonumbers on", "flag combatselffull off"
end
mana_share
if @combat_data["mob"]
	Spell[1213].cast if (Spell[1213].known?) && (Spell[1213].affordable?)
end
if @combat_data["focus"]
	Spell[1216].cast if (Spell[1216].known?) && (Spell[1216].affordable?)
end
fput "store both"
if @combat_data["nouacweapons"]
		nil
else
	fput "gird"
end
if (Spell[330].known?) && (Spell[330].affordable?)
	pause 1
	if @combat_data["sanctrighthand"] && !GameObj.right_hand.id.nil?
		pause 0.2
		multifput "prep 330", "evoke ##{GameObj.right_hand.id}"
		wait_castrt
	end
	if @combat_data["sanctlefthand"] && !GameObj.left_hand.id.nil?
		pause 0.2
		multifput "prep 330", "evoke ##{GameObj.left_hand.id}"
		wait_castrt
	end
end
if checkname == "Peggyanne"
	wait_rt
	pause 0.1
	energy_shield
end
$osacombat_auto_stow = nil
$osacombat_my_mstrike_focus = nil        #These are variables for Mstrike.  Not needed in GUI as they are autoset in mstrike def below.  Can remove or try to autoset this in osacrew.vars so settings are saved.  But this will check settings on open each time.
$osacombat_my_mstrike_open = nil
$osacombat_uac_current_attack = 0
$osacombat_retaliate = 0
mstrike_setup
#if (Spell[1625].known?) and (Stats.level >= 29) and !GameObj.right_hand.id.nil?
#	pause 0.5
#	fput "beseech ##{GameObj.right_hand.id} conserve"
#end
if Spell[630].known?
	fput "tell comp return"
	pause 0.5
	fput "tell comp behave offensive"
end

before_dying {
	UpstreamHook.remove($osa_hook_name)
	DownstreamHook.remove("osa_downstream_monitor")
	if !checkdead
		wait_while { running?("eloot") }
		if (Spell[1625].known?) and (Stats.level >= 29) and !GameObj.right_hand.id.nil? and !@combat_data["infusespell"].to_s.strip.empty?
			infuse_weapon
		end
		if Spell[1604].known? and !GameObj.left_hand.id.nil?
			pause 0.2
			infuse_shield
		end
		if Spell[630].known?
			fput "tell comp behave defensive"
		end
		if checkname == "Peggyanne"
				wait_rt
				pause 0.1
				energy_shield
		end
		fput "store both"
		if @combat_data["usebriefcombat"]
			multifput "flag combatbrief off", "flag combatnonumbers off", "flag combatselffull on"
		end
	end}

$osa_last_mana_share = nil
$osa_healing_status = "clear"

# OSA downstream monitor - tracks active spell states and affected targets
$earthen_fury_active  = false
$osa_affected_targets = Hash.new { |h, k| h[k] = [] }
DownstreamHook.remove("osa_downstream_monitor")
DownstreamHook.add("osa_downstream_monitor", proc { |line|
	# 917 Earthen Fury - channel state
	$earthen_fury_active = true  if line =~ /The ground beneath .+ begins to boil violently/
	$earthen_fury_active = false if line =~ /The ground beneath .+ suddenly calms/
	# When a target dies, scrub it from all affected target arrays
	if line =~ /(?:goes? limp|falls? to the ground|is dead|slumps? to the ground|crumples? to)/
		npc = GameObj.targets.find { |n| line.include?(n.name) }
		if npc
			$osa_affected_targets.each_value { |arr| arr.delete(npc.id) }
		end
	end
	# Green mist - disease incoming
	if line =~ /^A virulent green mist seeps out of .* lips toward you,/
		$osa_healing_status = "diseased"
	end
	# Stealth disabler - hidden pirate/stalker detected
	if line =~ /Something stirs in the shadows\.|A .+ darts into the shadows/
		if @combat_data["stealth_disabler"] && @combat_data["stealth_disabler"] != "Search (Default)"
			GLib::Idle.add { stealth_disabler_routine; false }
		elsif @combat_data["stealth_disabler"] == "Search (Default)"
			GLib::Idle.add { fput "search"; false }
		end
	end
	# Reactive attack opportunity
	if line =~ /You could use this opportunity to (.*)!/
		if @combat_data["use_reactive"]
			raw = $1
			# The game sends XML like: <d cmd='WEAPON radialsweep #112628214'>Radial Sweep</d>
			# Extract just the command word from the cmd attribute, stripping the target id
			if raw =~ /cmd='WEAPON\s+(\S+?)(?:\s+#\d+)?'/
				$osa_reactivetype = $1.downcase
			else
				# Plain text fallback - strip any remaining XML tags
				$osa_reactivetype = raw.gsub(/<[^>]+>/, "").strip.downcase
			end
			$osa_reactive_creatures = GameObj.targets.reject { |n| n.status =~ /dead|gone/ }.map(&:id)
			$osa_reactive         = true
		end
	end
	line
})

load_attack_vars
loop {
	stance_defensive
	health_monitor
	groupeffects
	gemstone_effects
	mana_leech
	looter
	check_dead
	if GameObj.targets.count > 0 && !checkdead
		get_target
		load_attack_vars
		reactive
		combat
	end
	sleep 0.1
}
