	ui(rows, :blank, height: 4)
	ui(rows, :spell, spell_label: "Opener Spell:", spell_tip: "Opener spells fire at the very start of each combat cycle, before attacks and regular spells. Intended for room-effect or setup spells (e.g. Tangleweed, Cold Snap) that should land before you engage. All standard conditions still apply - min/max enemies, mana, and the room-effect guard will prevent recasting if the effect is already active.", spell_var: 'living_opener1', stam_min_var: 'living_opener1_stam_min', mana_min_var: 'living_opener1_man_min', enemy_min_var: 'living_opener1_enemy_min', enemy_max_var: 'living_opener1_enemy_max', ward_var: 'living_opener1_warding', chan_var: 'living_opener1_channel', evoke_var: 'living_opener1_evoke', open_var: 'living_opener1_open_cast')
	ui(rows, :spell, spell_label: "Opener Spell:", spell_tip: "Opener spells fire at the very start of each combat cycle, before attacks and regular spells. Intended for room-effect or setup spells (e.g. Tangleweed, Cold Snap) that should land before you engage. All standard conditions still apply - min/max enemies, mana, and the room-effect guard will prevent recasting if the effect is already active.", spell_var: 'living_opener2', stam_min_var: 'living_opener2_stam_min', mana_min_var: 'living_opener2_man_min', enemy_min_var: 'living_opener2_enemy_min', enemy_max_var: 'living_opener2_enemy_max', ward_var: 'living_opener2_warding', chan_var: 'living_opener2_channel', evoke_var: 'living_opener2_evoke', open_var: 'living_opener2_open_cast')
