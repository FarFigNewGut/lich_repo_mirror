def time_diff_seconds(start,finish)
	(finish - start)
end

def combat_spellup
	health_monitor
	if (Effects::Debuffs.active? "Mystic Impedance") or (Effects::Debuffs.active? "Silenced") or ((stunned?) or (webbed?) or (bound?))
		return
	end
    if running? "ecure"
		wait_until { !running?('ecure') }
	end
	if !checkprep.include? "None"
		fput "release"
	end
	if Char.mana < 50
		if $osa_last_mana_share.nil? || (Time.now - $osa_last_mana_share) > (@combat_data["mana_share_cooldown"] || 90).to_i
			mana_share
			lnet_crew($mana_message)
			$osa_last_mana_share = Time.now
		end
		pause 1
	end
	wait_rt
    result = dothistimeout "incant #{@combat_spell} #{@combat_cast_type}", 30, /Wait|...wait|Spell Hindrance|(Cast|Sing) Roundtime (.*) Seconds./
        if result.to_s =~ /Wait|...wait/
            combat_spellup
        elsif result.to_s =~ /Spell Hindrance/
            wait_castrt
            combat_spellup
        elsif result.to_s =~ /(Cast|Sing) Roundtime/
            return
        else
            combat_spellup
        end
end

def cast_spell_society
	health_monitor
	Spell["Sign of Warding"].cast if Spell["Sign of Warding"].known? && Spell["Sign of Warding"].affordable? && !Spell["Sign of Warding"].active? && @combat_data["sign_of_warding"]
	Spell["Sign of Defending"].cast if Spell["Sign of Defending"].known? && Spell["Sign of Defending"].affordable? && !Spell["Sign of Defending"].active? && @combat_data["sign_of_defending"]
	Spell["Sign of Shields"].cast if Spell["Sign of Shields"].known? && Spell["Sign of Shields"].affordable? && !Spell["Sign of Shields"].active? && @combat_data["sign_of_shields"]
	Spell["Sign of Striking"].cast if Spell["Sign of Striking"].known? && Spell["Sign of Striking"].affordable? && !Spell["Sign of Striking"].active? && @combat_data["sign_of_striking"]
	Spell["Sign of Smiting"].cast if Spell["Sign of Smiting"].known? && Spell["Sign of Smiting"].affordable? && !Spell["Sign of Smiting"].active? && @combat_data["sign_of_smiting"]
	Spell["Sign of Swords"].cast if Spell["Sign of Swords"].known? && Spell["Sign of Swords"].affordable? && !Spell["Sign of Swords"].active? && @combat_data["sign_of_swords"]
	Spell["Sigil of Minor Bane"].cast if Spell["Sigil of Minor Bane"].known? && Spell["Sigil of Minor Bane"].affordable? && !Spell["Sigil of Minor Bane"].active? && @combat_data["sigil_of_minor_bane"]
	Spell["Sigil of Offense"].cast if Spell["Sigil of Offense"].known? && Spell["Sigil of Offense"].affordable? && !Spell["Sigil of Offense"].active? && @combat_data["sigil_of_offense"]
	Spell["Sigil of Major Bane"].cast if Spell["Sigil of Major Bane"].known? && Spell["Sigil of Major Bane"].affordable? && !Spell["Sigil of Major Bane"].active? && @combat_data["sigil_of_major_bane"]
	Spell["Sigil of Minor Protection"].cast if Spell["Sigil of Minor Protection"].known? && Spell["Sigil of Minor Protection"].affordable? && !Spell["Sigil of Minor Protection"].active? && @combat_data["sigil_of_minor_protection"]
	Spell["Sigil of Defense"].cast if Spell["Sigil of Defense"].known? && Spell["Sigil of Defense"].affordable? && !Spell["Sigil of Defense"].active? && @combat_data["sigil_of_defense"]
	Spell["Sigil of Major Protection"].cast if Spell["Sigil of Major Protection"].known? && Spell["Sigil of Major Protection"].affordable? && !Spell["Sigil of Major Protection"].active? && @combat_data["sigil_of_major_protection"]
	Spell["Sigil of Concentration"].cast if Spell["Sigil of Concentration"].known? && Spell["Sigil of Concentration"].affordable? && !Spell["Sigil of Concentration"].active? && @combat_data["sigil_of_concentration"]
	Spell["Symbol of Courage"].cast if Spell["Symbol of Courage"].known? && Spell["Symbol of Courage"].affordable? && !Spell["Symbol of Courage"].active? && @combat_data["symbol_of_courage"]
	Spell["Symbol of Protection"].cast if Spell["Symbol of Protection"].known? && Spell["Symbol of Protection"].affordable? && !Spell["Symbol of Protection"].active? && @combat_data["symbol_of_protection"]
	Spell["Symbol of Retribution"].cast if Spell["Symbol of Retribution"].known? && Spell["Symbol of Retribution"].affordable? && !Spell["Symbol of Retribution"].active? && @combat_data["symbol_of_retribution"] && @creature_type == "undead"
	Spell["Symbol of Supremacy"].cast if Spell["Symbol of Supremacy"].known? && Spell["Symbol of Supremacy"].affordable? && !Spell["Symbol of Supremacy"].active? && @combat_data["symbol_of_supremacy"] && @creature_type == "undead"
	Spell[1607].cast if (Spell[1607].available? && Spell[1607].affordable?) && (!Effects::Buffs.active? "Rejuvenation") && Char.percent_stamina <= 50
	$society_firstcast = true
end

def cast_spell_mana_focus
	# Always mark as cast so the caller stops re-triggering regardless of outcome
	$mana_focus_first_cast = nil
	return if Spell[1018].active?
	return unless Spell[418].known?
	@combat_spell = "418"
	@combat_cast_type = ""
	combat_spellup
end

