################# Mstrike Routine	
def mstrike_routine
	if Skills.multiopponentcombat >= 5 && @combat_data["use_mstrike"]
		if Effects::Cooldowns.active? "Multi-Strike" or ((stunned?) or (webbed?) or (bound?))
			return
		else
			if GameObj.targets.count >= 2 && $osacombat_my_mstrike_focus == 0 && $osacombat_my_mstrike_open >= 1 && @combat_data["use_mstrike"]
				if Char.percent_stamina >= 50
					stance_offensive
					fput "mstrike"
					wait_rt
					stance_defensive
				end
			elsif GameObj.targets.count == 1 && $osacombat_my_mstrike_focus >= 1 && $osacombat_my_mstrike_open >= 1 && @combat_data["use_mstrike"]
				if Char.percent_stamina >= 50
					get_target
					stance_offensive
					fput "mstrike target"
					wait_rt
					stance_defensive
				end
			elsif GameObj.targets.count >= 2 && $osacombat_my_mstrike_focus >= 1 && $osacombat_my_mstrike_open >= 1 && @combat_data["use_mstrike"]
				if Char.percent_stamina >= 50
					stance_offensive
					fput "mstrike"
					wait_rt
					stance_defensive
				end
			end
		end
	else
		return
	end
	wait_rt
end

################# Combat Styles	

def parse_slots(str)
	str.to_s.split(",").map { |s| s.strip.to_i }.select { |n| n > 0 }
end

def target_in_routine?(base_var)
	return true if GameObj.target.nil?
	# Determine if base_var is an attack, spell, or opener slot and extract slot number
	if base_var =~ /(?:living|undead)_atk_(\d+)$/
		slot_num = $1.to_i
		skip_key = lambda { |n| "creature_#{n}_skip_attacks" }
		only_key = lambda { |n| "creature_#{n}_only_attacks" }
	elsif base_var =~ /(?:undead_)?spell(\d+)$/
		slot_num = $1.to_i
		skip_key = lambda { |n| "creature_#{n}_skip_spells" }
		only_key = lambda { |n| "creature_#{n}_only_spells" }
	elsif base_var =~ /(?:living|undead)_opener(\d+)$/
		slot_num = $1.to_i
		skip_key = lambda { |n| "creature_#{n}_skip_openers" }
		only_key = lambda { |n| "creature_#{n}_only_openers" }
	else
		return true
	end
	# If no creature slots defined, fire normally
	defined_slots = (1..10).select { |n| !@combat_data["creature_#{n}"].to_s.strip.empty? }
	return true if defined_slots.empty?
	target_noun = GameObj.target.noun.to_s.downcase
	target_name = GameObj.target.name.to_s.downcase
	matched_slot = nil
	defined_slots.each do |n|
		creature = @combat_data["creature_#{n}"].to_s.downcase.strip
		creature_words = creature.split
		if target_noun.split.any? { |w| creature_words.include?(w) } ||
		   target_name.split.any? { |w| creature_words.include?(w) }
			matched_slot = n
			break
		end
	end
	# Check Exclusive lists across ALL defined slots -
	# if this slot_num is marked exclusive for ANY creature slot,
	# it must not fire on non-matching creatures
	if matched_slot.nil?
		defined_slots.each do |n|
			only_slots = parse_slots(@combat_data[only_key.call(n)])
			return false if only_slots.include?(slot_num)
		end
		return true
	end
	# Target matched a creature slot - apply Skip check
	skip_slots = parse_slots(@combat_data[skip_key.call(matched_slot)])
	return false if skip_slots.include?(slot_num)
	# Fire normally - Exclusive only restricts on non-matching creatures, not on matching ones
	true
end


def stealth_disabler_routine
	return if @combat_data["stealth_disabler"].nil? || @combat_data["stealth_disabler"] == "Search (Default)"
	case @combat_data["stealth_disabler"]
	when "Search (Default)"
		stance_defensive
		fput "search"
		wait_rt
	when "Eviscerate"
		stance_offensive
		fput "cman eviscerate"
		stance_defensive
	when "Carn\'s Cry (Open)"
		stance_offensive
		Warcry.use("Cry", "All")
		stance_defensive
	when "Symbol of Sleep"
		stance_defensive
		fput "symbol of sleep"
		wait_rt
	else
		# Spell-based disablers
		$stealth_disabler_spell = @combat_data["stealth_disabler"]
		cast_disabler
	end
end

def cast_disabler
	if $stealth_disabler_spell.nil? || $stealth_disabler_spell.to_s.strip.empty?
		fput "search"
		wait_rt
		return
	end
	unless Spell[$stealth_disabler_spell].known?
		respond "--- OSACombat: Stealth disabler spell \'#{$stealth_disabler_spell}\' not known. Defaulting to Search."
		fput "search"
		wait_rt
		return
	end
	wait_rt
	wait_castrt
	fput "prep #{$stealth_disabler_spell}"
	fput "cast"
	wait_rt
	wait_castrt
	if $stealth_disabler_spell == "Light"
		fput "search"
		wait_rt
	end
end
def dispatch_attack(atk, stam_min, mana_min, enemy_min, enemy_max, base_var: nil)
	return if stunned? || webbed? || bound? || checkdead || GameObj.targets.empty?
	return if Char.stamina.to_i < stam_min
	return if Char.mana.to_i < mana_min
	return if GameObj.targets.count < enemy_min
	return if GameObj.targets.count > enemy_max
	return unless get_target
	return if excluded_target?
	return unless base_var.nil? || target_in_routine?(base_var)
	case atk
	when "Barrage (Ranged)"                    then barrage
	when "Bearhug"                             then bearhug
	when "Berserk"                             then berserk
	when "Bertrandt's Bellow (Single Target)"  then bertrandts_bellow_single
	when "Bertrandt's Bellow (Open)"           then bertrandts_bellow_open
	when "Bull Rush"                           then bull_rush
	when "Carn's Cry (Single Target)"          then carns_cry_single
	when "Carn's Cry (Open)"                   then carns_cry_open
	when "Chastise"                            then chastise
	when "Charge (Polearm)"                    then charge
	when "Clash (Brawling)"                    then clash
	when "Cripple (Edged)"                     then cripples
	when "Crowd Press"                         then crowd_press
	when "Cutthroat"                           then cutthroat
	when "Cyclone (Polearm)"                   then cyclone
	when "Dark Energy Wings: Shadow Barb"      then dark_wings_turn
	when "Dark Energy Wings: Barbed Sweep"     then dark_wings_knock
	when "Dark Energy Wings: Rain of Thorns"   then dark_wings_fold
	when "Dirtkick"                            then dirt_kick
	when "Disarm Weapon"                       then disarm_manuever
	when "Dislodge"                            then dislodge
	when "Dizzying Swing (Blunt)"              then dizzying_swing
	when "Eviscerate"                          then eviscerate
	when "Excoriate"                           then excoriate
	when "Exsanguinate"                        then exsanguinate
	when "Eyepoke"                             then eyepoke
	when "Feint"                               then feint_manuever
	when "Flurry (Edged)"                      then flurry
	when "Footstomp"                           then footstomp
	when "Fury (Brawling)"                     then fury
	when "Garrelle's Growl (Single Target)"    then gerrelles_growl_single
	when "Garrelle's Growl (Open)"             then gerrelles_growl_open
	when "Groin Kick"                          then groin_kick
	when "Guardant Thrusts (Polearm)"          then gthrusts
	when "Hamstring"                           then hamstring
	when "Haymaker"                            then haymaker
	when "Headbutt"                            then headbutt
	when "Kneebash"                            then kneebash
	when "Leap Attack"                         then leap_attack
	when "Light Energy Wings: Radiant Pulse"   then light_wings_turn
	when "Light Energy Wings: Blast of Brilliance" then light_wings_knock
	when "Light Energy Wings: Blinding Reprisal"   then light_wings_fold
	when "Mighty Blow"                         then mighty_blow
	when "Mounted Combat: Charge"              then mounted_combat_charge
	when "Mounted Combat: Trample"             then mounted_combat_trample
	when "Mug"                                 then mug
	when "Nosetweak"                           then nosetweak
	when "Pin Down (Ranged)"                   then pin_down
	when "Pound (Flare Gloves)"               then flare_gloves_pound
	when "Pulverize (Blunt)"                   then pulverize
	when "Pummel (Blunt)"                      then pummel
	when "Shield Bash"                         then shield_bash
	when "Shield Charge"                       then shield_charge
	when "Shield Push"                         then shield_push
	when "Shield Strike"                       then shield_strike
	when "Shield Throw"                        then shield_throw
	when "Shield Trample"                      then shield_trample
	when "Spin Attack"                         then spin_attack
	when "Spell Cleave"                        then spell_cleave
	when "Staggering Blow"                     then staggering_blow
	when "Subdue"                              then subdue
	when "Sunder Shield"                       then sunder_shield
	when "Sweep"                               then sweep
	when "Swiftkick"                           then swiftkick
	when "Tackle"                              then tackle_manuever
	when "Templeshot"                          then templeshot
	when "Thrash (Two-Handed)"                 then thrash
	when "Throatchop"                          then throatchop
	when "Trip"                                then trip
	when "True Strike"                         then true_strike
	when "Twin Hammerfists (Brawling)"         then twin_hammerfists
	when "Vault Kick"                          then vault_kick
	when "Volley (Ranged)"                     then volley
	when "Voln Sleep"                          then voln_sleep
	when "Whirling Blade (Edged)"              then whirling_blade
	when "Whirlwind (Two-Handed)"              then whirlwind
	end
end

def refresh_affected_targets(spell)
	return unless $osa_affected_targets[spell]
	current_npc_ids = GameObj.targets.map(&:id)
	$osa_affected_targets[spell].select! { |id| current_npc_ids.include?(id) }
end

# Spells that leave a persistent room effect - skip if already active
ROOM_EFFECT_SPELLS = {
	"335" => /miniature storm of faintly glowing snowflakes/,
	"610" => /vine|bramble|widgeonweed|vathor club|swallowwort|smilax|creeper|creepers|briar|ivy|tumbleweed/,
	"709" => / arm|arms|pincer|pincers|tentacle|tentacles/,
	"710" => /tempest/,
	"720" => /void/,
	"118" => /web/,
}

# Spells that persist on specific targets - tracked via $osa_affected_targets[spell]
AFFECTED_TARGET_SPELLS = %w[917 1117 1614 217 512 611 603]

def can_cast_spell(spell, cast_type, stam_min, mana_min, enemy_min, enemy_max, warding, open_cast, base_var: nil)
	spell = spell.to_s.strip
	return if spell.empty? || spell == "0"
	return if Effects::Debuffs.active?("Mystic Impedance") || Effects::Debuffs.active?("Silenced")
	return if stunned? || webbed? || bound? || checkdead || GameObj.targets.empty?
	return unless get_target
	return if excluded_target?
	return unless base_var.nil? || target_in_routine?(base_var)
	return if Char.stamina.to_i < stam_min.to_i
	return if Char.mana.to_i    < mana_min.to_i
	return if GameObj.targets.count < enemy_min.to_i
	return if GameObj.targets.count > enemy_max.to_i
	unless Spell[spell].known?
		echo "------==== You Do Not Know Spell #{spell}. Check Your Spell Settings. ==== ------"
		return
	end

	# Room effect guard - don't recast if the effect is already present
	if (pattern = ROOM_EFFECT_SPELLS[spell])
		return if GameObj.loot.any? { |loot| loot.name =~ pattern }
	end

	# 909 (Tremors) - only cast if non-prone targets exist, then follow up
	if spell == "909"
		not_prone = GameObj.targets.reject { |npc| npc.status =~ /dead|gone|lying/ }
		return if not_prone.empty?
		if Spell[909].available?
			fput "incant 909 channel"
		end
		wait_rt
		pause 0.1
		fput "stomp" if @combat_data["stomp"]
		fput "pound" if @combat_data["pound"]
		fput "tap"   if @combat_data["tap"]
		return
	end

	# Affected target spells - skip if all current targets already affected and still alive
	if AFFECTED_TARGET_SPELLS.include?(spell) && spell != "917"
		refresh_affected_targets(spell)
		unaffected = GameObj.targets.map(&:id) - ($osa_affected_targets[spell] || [])
		if unaffected.empty?
			return
		else
			$osa_affected_targets[spell] ||= []
			$osa_affected_targets[spell].concat(GameObj.targets.map(&:id)).uniq!
		end
	end


	# 316 (Censure) - skip if already active, cast as warding spell
	if spell == "316"
		return if Effects::Buffs.active?("Censure")
		get_target
		stance_offensive
		fput "incant 316 #{cast_type} target"
		wait_castrt
		stance_defensive
		return
	end

	# 917 (Earthen Fury) - channel flag + per-target tracking
	if spell == "917"
		return if $earthen_fury_active
		refresh_affected_targets("917")
		unaffected = GameObj.targets.map(&:id) - ($osa_affected_targets["917"] || [])
		return if unaffected.empty?
		$osa_affected_targets["917"] ||= []
		$osa_affected_targets["917"].concat(GameObj.targets.map(&:id)).uniq!
		get_target
		stance_offensive
		fput "incant 917 #{cast_type} target"
		wait_castrt
		stance_defensive
		return
	end
	# Wait for mana if needed
	unless Spell[spell].affordable?
		mana_leech
		symbol_of_mana
		sigil_of_power
		# Rate-limited mana share - only request from group once per cooldown period
		if $osa_last_mana_share.nil? || (Time.now - $osa_last_mana_share) > (@combat_data["mana_share_cooldown"] || 90).to_i
			mana_share
			lnet_crew($mana_message)
			$osa_last_mana_share = Time.now
		end
		# Brief wait for mana to arrive - if still not affordable just skip
		pause 2
		return unless Spell[spell].affordable?
	end

	get_target
	stance_offensive unless warding
	if open_cast
		fput "incant #{spell} #{cast_type} open"
	else
		get_target
		fput "incant #{spell} #{cast_type} target"
	end
	stance_guarded   # drop to guarded while in cast RT
	wait_castrt      # wait out cast RT before anything else
	stance_defensive
	health_monitor
end

def combat	
	prep_reset
	get_target
	return if GameObj.target.nil?
	load_attack_vars
	check_for_poaching if @combat_data["check_for_group"]
	# Opener spells - fire before attacks and regular spells each cycle
	if !$poaching && !@opener_spell1.to_s.empty?
		load_attack_vars
		can_cast_spell(@opener_spell1, @opener_cast_type1, @opener_spell1_stam_min, @opener_spell1_mana_min, @opener_spell1_enemy_min, @opener_spell1_enemy_max, @opener_spell1_warding, @opener_spell1_open, base_var: (@creature_type == "undead" ? "undead_opener" : "living_opener") + "1")
		health_monitor
	end
	if !$poaching && !@opener_spell2.to_s.empty?
		load_attack_vars
		can_cast_spell(@opener_spell2, @opener_cast_type2, @opener_spell2_stam_min, @opener_spell2_mana_min, @opener_spell2_enemy_min, @opener_spell2_enemy_max, @opener_spell2_warding, @opener_spell2_open, base_var: (@creature_type == "undead" ? "undead_opener" : "living_opener") + "2")
