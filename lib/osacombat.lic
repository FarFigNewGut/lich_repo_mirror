def wait_rt
	#pause 0.1
	waitrt?
end

def wait_castrt
	pause 0.3          # allow cast RT XML tag to arrive from server
	waitcastrt?        # wait out remaining cast RT
	waitrt?            # then wait out any combat RT
end

