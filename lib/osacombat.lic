def groupeffects
	check_dead
	cast_spell_society if !$society_firstcast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ }
	cast_spell_society if $society_firstcast
	cast_spell_mana_focus if @combat_data["cast_spell_mana_focus"] && (!$mana_focus_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_mana_focus if @combat_data["cast_spell_mana_focus"] && $mana_focus_first_cast && !Spell[1018].active?
	cast_spell_bravery if @combat_data["groupbravery"] && (!$bravery_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_bravery if @combat_data["groupbravery"] && $bravery_first_cast
	cast_spell_group_celerity if @combat_data["cast_spell_group_celerity"] && (!$group_celerity_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
	cast_spell_group_celerity if @combat_data["cast_spell_group_celerity"] && $group_celerity_first_cast
	cast_spell_celerity if @combat_data["cast_spell_self_celerity"] && (!$celerity_first_cast && GameObj.targets.any? { |n| n.type !~ /passive/ && n.status !~ /dead|gone/ })
