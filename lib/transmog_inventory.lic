# Folder + per-character CSV path for the catalog.
def transmog_dir
  scripts_dir = ($script_dir rescue nil) || (SCRIPT_DIR rescue nil) || Dir.pwd
  File.join(scripts_dir, "transmog")
end

def csv_path
  char_name = (Char.name rescue nil) || XMLData.name
  File.join(transmog_dir, "transmog_inventory_#{char_name}.csv")
end

def usage
  respond <<~HELP
    transmog_inventory -- catalog transmog items in a locker chest to CSV, and
    search/maintain that catalog.

    Scan (MERGES results into the saved list, deduped by full name):
      ;transmog_inventory               scans the default container (nouned "chest")
      ;transmog_inventory backpack      scans a container you name instead of "chest"
      ;transmog_inventory chest debug   dump raw ANALYZE/INSPECT for 2 items

    Fresh scan (WIPES the saved list first, then scans from scratch):
      ;transmog_inventory new           wipe the list, then scan "chest"
      ;transmog_inventory new backpack  wipe the list, then scan a container you name
      ;transmog_inventory fresh|reset|rebuild ...   aliases for new

    Search the saved CSV:
      ;transmog_inventory search neck            any column contains "neck"
      ;transmog_inventory search ring neck       AND: contains "ring" AND "neck"
      ;transmog_inventory search noun:ring       Noun column contains "ring"
      ;transmog_inventory search loc:neck        Worn Location contains "neck"
      ;transmog_inventory search noun:band loc:finger   combine fields
      ;transmog_inventory find ...               alias for search

    Remove an entry (when you use/trade/sell an item):
      ;transmog_inventory remove twisted ora ring     remove the single match
      ;transmog_inventory remove noun:band loc:finger combine fields
      ;transmog_inventory remove all noun:ring        remove every match
      ;transmog_inventory rm|delete|del ...           aliases for remove

      Field prefixes: noun:/n:  name:/full:/f:  loc:/location:/worn:/l:

      ;transmog_inventory help          this help

    Add/clear a note on an entry (e.g. asking price), then upload to publish:
      ;transmog_inventory note <id> Asking 2m silvers   set note by item ID
      ;transmog_inventory note <id> clear               clear note by item ID
      ;transmog_inventory note noun:ring -- Asking 2m   set note by search (-- required)
      (IDs shown in search results; max #{NOTE_MAX_CHARS} characters)

    Upload to the Transmog Exchange (shared web database):
      ;transmog_inventory upload        push your saved CSV to the central catalog
      Browse: #{EXCHANGE_WEB_URL}

    Stand at your open locker with the chest accessible (or have the container
    worn/held), with at least one free hand. Output (CSV, opens in Excel /
    Google Sheets) is written to:
      #{csv_path}
  HELP
end

# Read the saved CSV into an array of {noun:, name:, location:, quantity:} hashes.
def read_catalog
  path = csv_path
  return [] unless File.exist?(path)
  CSV.read(path, headers: true).map do |r|
    qty = r["Quantity"].to_s.strip
    qty = qty =~ /\A\d+\z/ ? qty.to_i : 1
    qty = 1 if qty < 1
    raw_id = r["ID"].to_s.strip
    {
      id:       raw_id =~ /\A\d+\z/ ? raw_id.to_i : nil,
      noun:     r["Noun"].to_s,
      name:     r["Full Name"].to_s,
      location: r["Worn Location"].to_s,
      quantity: qty,
      note:     r["Notes"].to_s.strip,
    }
  end
end

# Write an array of {noun:, name:, location:, quantity:} hashes to the CSV.
# Returns the path.
def generate_unique_id(existing_ids)
  loop do
    n = rand(100_000_000..999_999_999)
    return n unless existing_ids.include?(n)
  end
end

def write_catalog(rows)
  # Assign stable IDs to any entries that don't have one yet.
  existing_ids = rows.map { |r| r[:id] }.compact.to_set
  rows = rows.map do |r|
    next r if r[:id].to_i > 0
    id = generate_unique_id(existing_ids)
    existing_ids << id
    r.merge(id: id)
  end

  out_file = csv_path
  FileUtils.mkdir_p(File.dirname(out_file))
  CSV.open(out_file, "w") do |csv|
    csv << ["ID", "Noun", "Full Name", "Worn Location", "Quantity", "Notes"]
    rows.each do |r|
      qty = r[:quantity].to_i
      qty = 1 if qty < 1
      csv << [r[:id], r[:noun], r[:name], r[:location], qty, r[:note].to_s]
    end
  end
  out_file
end

# Parse one search token into [column_or_nil, value]. A nil column means
# "match against any column".
def parse_search_term(token)
  if token =~ /\A(noun|n|name|full|f|loc|location|worn|l)[:=](.+)\z/i
    field = Regexp.last_match(1).downcase
    value = Regexp.last_match(2)
    col = case field
          when "noun", "n"          then :noun
          when "name", "full", "f"  then :name
          else                           :location
          end
    [col, value]
  else
    [nil, token]
  end
end

# Does a catalog entry hash match all of the given [field_or_nil, value] terms?
def entry_matches?(entry, terms)
  terms.all? do |col, value|
    needle = value.downcase
    if col
      entry[col].to_s.downcase.include?(needle)
    else
      [entry[:noun], entry[:name], entry[:location], entry[:quantity]].any? { |f| f.to_s.downcase.include?(needle) }
    end
  end
end

def parse_terms(query)
  query.to_s.split(/\s+/).reject(&:empty?).map { |t| parse_search_term(t) }
end

def pretty_terms(terms)
  terms.map { |col, val| col ? "#{col}~#{val}" : val }.join(" AND ")
end

def show_entry(prefix, e)
  qty  = e[:quantity].to_i
  qty  = 1 if qty < 1
  qtag = qty > 1 ? " x#{qty}" : ""
  idtag  = e[:id].to_i > 0 ? "[#{e[:id]}] " : ""
  notetag = e[:note].to_s.empty? ? "" : "  | #{e[:note]}"
  respond "  #{prefix}#{idtag}[#{e[:location]}]  #{e[:name]}  (#{e[:noun]})#{qtag}#{notetag}"
end

# Print catalog rows matching the query (AND of all terms).
def run_search(query)
  unless File.exist?(csv_path)
    respond "transmog_inventory: no catalog found at #{csv_path}"
    respond "  Run a scan first, e.g. ;transmog_inventory chest"
    return
  end

  terms = parse_terms(query)
  if terms.empty?
    respond "transmog_inventory: provide something to search for, e.g. ;transmog_inventory search neck"
    return
  end

  rows = read_catalog
  if rows.any? { |r| r[:id].to_i == 0 }
    write_catalog(rows)
    rows = read_catalog
  end
  matches = rows.select { |e| entry_matches?(e, terms) }

  if matches.empty?
    respond "transmog_inventory: no matches for [#{pretty_terms(terms)}] (of #{rows.size} catalogued)."
    return
  end

  respond "transmog_inventory: #{matches.size} match(es) for [#{pretty_terms(terms)}]:"
  matches.each { |e| show_entry("", e) }
end

# Remove catalog entries matching the query. To avoid accidental mass deletion,
# a query matching more than one entry is only removed when prefixed with "all".
def run_remove(query)
  unless File.exist?(csv_path)
    respond "transmog_inventory: no catalog found at #{csv_path}"
    return
  end

  tokens    = query.to_s.split(/\s+/).reject(&:empty?)
  force_all = tokens.first&.downcase == "all" && tokens.shift # shift returns the value
  terms     = tokens.map { |t| parse_search_term(t) }

  if terms.empty?
    respond "transmog_inventory: specify which entry to remove, e.g."
    respond "  ;transmog_inventory remove twisted ora ring"
    respond "  ;transmog_inventory remove noun:band loc:finger"
    respond "  (prefix with 'all' to remove every match: ;transmog_inventory remove all noun:ring)"
    return
  end

  rows    = read_catalog
  matches = rows.select { |e| entry_matches?(e, terms) }

  if matches.empty?
    respond "transmog_inventory: no entry matches [#{pretty_terms(terms)}]; nothing removed."
    return
  end

  if matches.size > 1 && !force_all
    respond "transmog_inventory: #{matches.size} entries match [#{pretty_terms(terms)}] -- refine your search,"
    respond "  or repeat with 'all' to remove them all (;transmog_inventory remove all #{query})."
    matches.each { |e| show_entry("", e) }
    return
  end

  remaining = rows.reject { |e| entry_matches?(e, terms) }
  write_catalog(remaining)

  respond "transmog_inventory: removed #{matches.size} entr#{matches.size == 1 ? 'y' : 'ies'} (catalog now #{remaining.size}):"
  matches.each { |e| show_entry("- ", e) }
end

# Thin wrapper around Lich::Util.issue_command with our standard options.
def issue(cmd, start_rx, timeout: 4)
  Lich::Util.issue_command(
    cmd, start_rx, /<prompt/,
    include_end: false, timeout: timeout, silent: true, usexml: true, quiet: true
  )
end

# Find the container object by noun/name across worn/held inventory, the room,
# and any already-opened containers (whose IDs are tracked in GameObj.containers).
def find_container(noun)
  noun = noun.to_s.strip.downcase
  pools = []
  pools.concat(Array(GameObj.inv))
  pools.concat(Array(GameObj.loot))
  pools << GameObj.right_hand if GameObj.right_hand && GameObj.right_hand.id
  pools << GameObj.left_hand  if GameObj.left_hand  && GameObj.left_hand.id
  GameObj.containers.each_key { |cid| obj = GameObj[cid]; pools << obj if obj }
  pools.compact!

  pools.find { |o| o.noun.to_s.downcase == noun } ||
    pools.find { |o| o.name.to_s.downcase.include?(noun) }
end

# Re-LOOK in the container (by noun, which is stable even when locker IDs roll)
# and return the freshly-resolved container object. This repopulates
# GameObj.containers with the current item IDs.
def refresh_container(noun)
  issue(
    "look in #{noun}",
    /In the|Inside the|There is nothing|That is closed|isn't a container|don't see|I don't|<container|<exposeContainer/i,
    timeout: 3
  )
  find_container(noun)
end

# Current contents (Array of GameObj) of a resolved container.
def container_contents(container)
  return [] unless container
  Array(GameObj.containers[container.id])
end

# Stable identity for an item: its full descriptive name (article + name +
# trailing text). Locker IDs roll, but this text does not.
def item_identity(obj)
  return nil unless obj
  ((obj.full_name rescue nil) || obj.name).to_s.strip
end

# Pull the item identified by `ident` (its full name) out of the container into
# a hand, refreshing the volatile locker IDs and retrying on failure. Success is
# detected by a hand newly becoming occupied -- this is robust to the item's ID
# rolling and to name/after-name differences between the listing and the hand.
# Once held, an item gets a stable inventory ID. Returns [container, held_or_nil].
def acquire_item(container, noun, ident, tries: 4)
  tries.times do
    item = container_contents(container).find { |o| item_identity(o) == ident }
    if item.nil?
      container = refresh_container(noun)
      item = container_contents(container).find { |o| item_identity(o) == ident }
    end
    if item.nil?
      sleep 0.3
      next
    end

    right_before = GameObj.right_hand&.id
    left_before  = GameObj.left_hand&.id

    waitrt?
    issue(
      "get ##{item.id}",
      /You (?:get|pick up|remove|take|grab)|already (?:in your|holding)|What were you|I could not find|There is nothing|isn't here|don't see|need a free hand/i,
      timeout: 3
    )
    waitrt?

    rh = GameObj.right_hand
    lh = GameObj.left_hand
    held = if rh&.id && rh.id != right_before
             rh
           elsif lh&.id && lh.id != left_before
             lh
           end
    return [container, held] if held

    # GET didn't fill a hand -- most likely the locker rolled the ID. Refresh & retry.
    container = refresh_container(noun)
  end
  [container, nil]
end

# Put an item (by its now-stable in-hand ID) back into the container, refreshing
# the container's (also volatile) ID and retrying on failure.
# Returns [container, success_bool].
def stow_item(container, noun, item_id, tries: 4)
  tries.times do
    container ||= refresh_container(noun)
    if container
      waitrt?
      issue(
        "put ##{item_id} in ##{container.id}",
        /You put|You place|already in|won't fit|cannot|can't|There's no room|isn't a container/i,
        timeout: 3
      )
      waitrt?
    end
    held_ids = [GameObj.right_hand&.id, GameObj.left_hand&.id]
    return [container, true] unless held_ids.include?(item_id)

    # PUT failed -- container ID may have rolled. Refresh and retry.
    container = refresh_container(noun)
  end
  [container, false]
end

# Strip the leading "<noun>" from the inspect "wear" phrase to leave the location.
def clean_location(phrase, item)
  loc = phrase.to_s.strip
  loc = loc.sub(/^#{Regexp.escape(item.noun.to_s)}s?\b[,]?\s*/i, '') unless item.noun.to_s.empty?
  loc = loc.sub(/^[a-z\-]+[,]?\s+(?=(?:on|around|over|across|slinging|from|in|under|atop|onto)\b)/i, '')
  loc.strip
end

# Returns [canonical location label, location code] for an INSPECT phrase,
# or ["unknown", nil] if nothing matched.
def slot_for(text)
  SLOT_MAP.each { |rx, label, code| return [label, code] if text =~ rx }
  ["unknown", nil]
end

# ---------------------------------------------------------------------------
# Transmog Exchange upload

NOTE_MAX_CHARS = 120

def apply_note(catalog, target_name, note_text)
  new_note = note_text.strip.downcase == "clear" ? "" : note_text.strip[0, NOTE_MAX_CHARS]
  updated  = catalog.map { |r| r[:name] == target_name ? r.merge(note: new_note) : r }
  write_catalog(updated)
  [new_note, updated]
end

def run_note(raw)
  tokens = raw.to_s.strip.split(/\s+/, 2)

  # ID-based: ;transmog_inventory note 485712843 Asking 25k
  if tokens[0].to_s =~ /\A\d{6,9}\z/
    item_id = tokens[0].to_i
    note_text = tokens[1].to_s.strip
    if note_text.empty?
      respond "transmog_inventory: provide note text (or 'clear') after the ID."
      respond "  Example: ;transmog_inventory note #{item_id} Asking 25k"
      return
    end
    catalog = read_catalog
    entry   = catalog.find { |r| r[:id].to_i == item_id }
    if entry.nil?
      respond "transmog_inventory: no item with ID #{item_id} in your catalog."
      respond "  Use ;transmog_inventory search to find item IDs."
      return
    end
    new_note, = apply_note(catalog, entry[:name], note_text)
    if new_note.empty?
      respond "transmog_inventory: note cleared for [#{item_id}] #{entry[:name]}."
    else
      respond "transmog_inventory: [#{item_id}] #{entry[:name]}"
      respond "  Note (#{new_note.length}/#{NOTE_MAX_CHARS}): #{new_note}"
      respond "  Run ;transmog_inventory upload to publish."
    end
    return
  end

  # Search-based fallback: ;transmog_inventory note noun:ring -- Asking 25k
  unless raw =~ /\A(.+?)\s+--\s*(.*)\z/m
    respond "transmog_inventory: set a note by item ID:"
    respond "  ;transmog_inventory note <id> <note text>"
    respond "  ;transmog_inventory note <id> clear"
    respond "Or by search (use -- to separate terms from note):"
    respond "  ;transmog_inventory note noun:ring loc:finger -- Asking 25k"
    respond "Run ;transmog_inventory search to see item IDs."
    return
  end

  search_part = $1.strip
  note_text   = $2.strip
  terms       = parse_terms(search_part)
  catalog     = read_catalog
  matches     = catalog.select { |e| entry_matches?(e, terms) }

  if matches.empty?
    respond "transmog_inventory: no entries match [#{pretty_terms(terms)}]."
    return
  end

  if matches.size > 1
    respond "transmog_inventory: #{matches.size} entries match -- refine your search or use an ID:"
    matches.each { |e| show_entry("", e) }
    return
  end

  target = matches.first
  new_note, = apply_note(catalog, target[:name], note_text)
  if new_note.empty?
    respond "transmog_inventory: note cleared for [#{target[:id]}] #{target[:name]}."
  else
    respond "transmog_inventory: [#{target[:id]}] #{target[:name]}"
    respond "  Note (#{new_note.length}/#{NOTE_MAX_CHARS}): #{new_note}"
    respond "  Run ;transmog_inventory upload to publish."
  end
end

def config_path
  File.join(transmog_dir, "transmog_config.json")
end

def load_or_create_token
  if File.exist?(config_path)
    begin
      cfg   = JSON.parse(File.read(config_path))
      token = cfg["token"].to_s.strip
      return token unless token.empty?
    rescue JSON::ParserError
    end
  end
  token = SecureRandom.uuid
  FileUtils.mkdir_p(transmog_dir)
  File.write(config_path, JSON.generate({ "token" => token }))
  token
end

def run_upload
  unless File.exist?(csv_path)
    respond "transmog_inventory: no catalog at #{csv_path} -- run a scan first."
    return
  end

  if SUPABASE_URL.include?("YOUR_PROJECT")
    respond "transmog_inventory: upload is not configured yet."
    respond "  Fill in SUPABASE_URL and SUPABASE_ANON_KEY near the top of this script."
    respond "  Setup guide: #{EXCHANGE_WEB_URL}"
    return
  end

  catalog = read_catalog
  if catalog.empty?
    respond "transmog_inventory: catalog is empty -- run a scan first."
    return
  end

  char_name = (Char.name rescue nil) || XMLData.name
  token     = load_or_create_token

  respond "transmog_inventory: uploading #{catalog.size} item(s) for #{char_name}..."

  items = catalog.map do |r|
    { "noun" => r[:noun], "full_name" => r[:name], "worn_location" => r[:location], "quantity" => r[:quantity], "notes" => r[:note].to_s }
  end

  payload = JSON.generate({
    "p_character_name" => char_name,
    "p_token"          => token,
    "p_items"          => items,
  })

  begin
    uri  = URI("#{SUPABASE_URL}/rest/v1/rpc/upload_transmog")
    req  = Net::HTTP::Post.new(uri)
    req["Content-Type"]    = "application/json"
    req["Accept-Encoding"] = "identity"
    req["apikey"]          = SUPABASE_ANON_KEY
    req["Authorization"]   = "Bearer #{SUPABASE_ANON_KEY}"
    req.body = payload

    resp = Net::HTTP.start(uri.hostname, uri.port,
                           use_ssl: true, open_timeout: 10, read_timeout: 20) do |http|
      http.request(req)
    end

    result = JSON.parse(resp.body) rescue {}

    if result["success"]
      respond "transmog_inventory: uploaded #{result['items_uploaded']} item(s) for #{char_name}."
      respond "  Browse the exchange: #{EXCHANGE_WEB_URL}"
    elsif result["error"]
      respond "transmog_inventory: upload failed -- #{result['message'] || result['error']}"
    else
      respond "transmog_inventory: unexpected response (HTTP #{resp.code})."
      respond "  #{resp.body.to_s[0..200]}" if resp.body
    end
  rescue => e
    respond "transmog_inventory: upload error -- #{e.class}: #{e.message}"
  end
end

# ---------------------------------------------------------------------------

if script.vars[1].to_s =~ /^(?:help|\?|-h|--help)$/i
  usage
  exit
end

if script.vars[1].to_s =~ /^(?:search|find|s)$/i
  query = script.vars[0].to_s.sub(/\A\s*(?:search|find|s)\s+/i, "")
  run_search(query)
  exit
end

if script.vars[1].to_s =~ /^(?:remove|rm|delete|del)$/i
  query = script.vars[0].to_s.sub(/\A\s*(?:remove|rm|delete|del)\s+/i, "")
  run_remove(query)
  exit
end

if script.vars[1].to_s =~ /^(?:upload|push|sync)$/i
  run_upload
  exit
end

if script.vars[1].to_s =~ /^(?:note|notes|tag)$/i
  raw = script.vars[0].to_s.sub(/\A\s*(?:note|notes|tag)\s+/i, "")
  run_note(raw)
  exit
end

args  = script.vars[0].to_s.dup
debug = !!args.slice!(/\bdebug\b/i)
fresh = !!args.slice!(/\b(?:new|fresh|reset|rebuild)\b/i)
merge = !fresh
container_noun = args.strip.squeeze(" ")
container_noun = "chest" if container_noun.empty?

if checkright && checkleft
  respond "transmog_inventory: both hands are full -- I need at least one free hand."
  respond "  (If a previous run was interrupted, you may be holding items from the chest;"
  respond "   put them back, e.g. PUT LEFT IN #{container_noun} / PUT RIGHT IN #{container_noun}.)"
  exit
end

container = refresh_container(container_noun)
if container.nil?
  respond "transmog_inventory: couldn't find a container nouned '#{container_noun}'."
  respond "Make sure your locker is open and the chest is in the room (LOOK IN #{container_noun} should work), or that you are wearing/holding it."
  respond "You can also pass a different name, e.g. ;transmog_inventory chest"
  exit
end

container_label = container.name.to_s
respond "transmog_inventory: scanning '#{container_label}'..."

contents = container_contents(container)
if contents.empty?
  respond "transmog_inventory: nothing found inside '#{container_label}'. (Is it open and accessible?)"
  exit
end

# Locker IDs are volatile, so work from the stable full item names. Build an
# ordered list of unique candidate names with their quantities.
order = []
qty   = Hash.new(0)
contents.each do |item|
  next unless item.type.to_s =~ TRANSMOG_TYPES
  ident = item_identity(item)
  next if ident.nil? || ident.empty?
  order << ident unless qty.key?(ident)
  qty[ident] += 1
end

respond "transmog_inventory: #{contents.size} item(s) inside, #{order.size} distinct wearable candidate(s) to check."

results  = []
skipped  = []

order.each_with_index do |name, idx|
  tag = qty[name] > 1 ? " (x#{qty[name]})" : ""
  respond "  [#{idx + 1}/#{order.size}] #{name}#{tag}..."

  item_id = nil
  begin
    container, held = acquire_item(container, container_noun, name)
    if held.nil?
      respond "    -> couldn't retrieve it after retries (locker IDs may be rolling); skipping."
      skipped << name
      next
    end

    item_id   = held.id
    item_noun = held.noun.to_s

    analyze_lines = issue(
      "analyze ##{item_id}",
      /You analyze|cannot be analyzed|not a sound idea|isn't a sound idea|don't think/i
    )
    respond "    [debug] ANALYZE: #{analyze_lines.inspect}" if debug
    is_transmog = analyze_lines.any? { |l| l =~ TRANSMOG_LINE }

    unless is_transmog
      respond "    -> not a transmog; returned."
      next
    end

    inspect_lines = issue(
      "inspect ##{item_id}",
      /you could wear|not a sound idea|isn't a sound idea|cannot|You carefully inspect|You determine/i
    )
    respond "    [debug] INSPECT: #{inspect_lines.inspect}" if debug

    # Match the worn location against the whole INSPECT text (phrasing varies and
    # the sentence can be split across streamed lines).
    inspect_text = inspect_lines.join(" ")
    worn_slot, worn_code = slot_for(inspect_text)

    # Raw location phrase straight from "...you could wear the <noun> <where>."
    m = inspect_text.match(/you could wear (?:the |your |a |an |some )?(.+?)\.(?:\s|$)/i)
    worn_phrase = m ? clean_location(m[1], held) : nil

    # CSV location string: prefer the canonical label+code; otherwise fall back to
    # the raw phrase so unmapped phrasings still show a useful location.
    worn_location = if worn_code
                      "#{worn_slot} (#{worn_code})"
                    elsif worn_phrase && !worn_phrase.empty?
                      worn_phrase
                    else
                      "unknown"
                    end

    results << {
      noun:     item_noun,
      name:     name,
      location: worn_location,
      quantity: qty[name],
    }

    respond "    -> transmog | worn: #{worn_location}"
  rescue StandardError => e
    respond "    -> ERROR while processing '#{name}': #{e.class} #{e.message}"
    skipped << name unless skipped.include?(name)
  ensure
    if item_id
      held_ids = [GameObj.right_hand&.id, GameObj.left_hand&.id]
      if held_ids.include?(item_id)
        container, ok = stow_item(container, container_noun, item_id)
        respond "    -> WARNING: couldn't return '#{name}' to the container; it may be in your hand." unless ok
      end
    end
  end

  if debug && results.size >= 2
    respond "transmog_inventory: debug stop after 2 items. Paste the [debug] lines above."
    break
  end
end

# ---- write CSV (Excel / Google Sheets friendly) ---------------------------

respond ""
respond "transmog_inventory: scanned #{results.size} transmog item(s) in '#{container_label}'."
unless skipped.empty?
  respond "transmog_inventory: #{skipped.size} item(s) could not be retrieved and were skipped:"
  skipped.each { |s| respond "    - #{s}" }
end

if merge
  existing       = read_catalog
  existing_names = existing.map { |e| e[:name].downcase }
  added          = results.reject { |r| existing_names.include?(r[:name].downcase) }
  dup_count      = results.size - added.size
  combined       = existing + added
  out_file       = write_catalog(combined)
  respond "transmog_inventory: added #{added.size} new (#{dup_count} already in list); catalog now #{combined.size} item(s)."
else
  prior    = File.exist?(csv_path) ? read_catalog.size : 0
  out_file = write_catalog(results)
  if prior.positive?
    respond "transmog_inventory: wiped the previous list (#{prior} item(s)) and saved a fresh scan of #{results.size}."
  else
    respond "transmog_inventory: saved a fresh scan of #{results.size} item(s)."
  end
end

respond "Saved to: #{out_file}"
