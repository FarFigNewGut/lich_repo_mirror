# encoding: utf-8
before_dying { 
  # 1. Save variables (Safe because we are using local global vars, not UI calls)
  save_settings
  
  # 2. Cleanup Audio
  stop_audio

  # 3. Stop combat flash timer and null out references
  $combat_flash_active = false
  $combat_draw = nil
  $mac_settings_win = nil
  GLib::Source.remove($configure_timer_id) if $configure_timer_id rescue nil
  $configure_timer_id = nil
  GLib::Source.remove($follow_timer_id) if $follow_timer_id rescue nil
  $follow_timer_id = nil

  # 4. Final Window Cleanup
  # CRITICAL on Mac: never call ANY GTK method (including hide/destroy) from
  # the script thread. The Quartz backend requires all GTK calls on the GTK
  # main thread. Instead, set $minimap_alive = false so the main loop exits,
  # then queue the destroy so it runs safely on the GTK thread.
  $minimap_alive = false

  if $minimap_win
    win_ref = $minimap_win
    $minimap_win = nil
    Gtk.queue do
      begin
        win_ref.destroy if win_ref.respond_to?(:destroyed?) && !win_ref.destroyed?
      rescue
        # ignore any errors during teardown
      end
    end
  end
}

def stop_audio
  if Gem.win_platform?
    # Windows - kill by PID first, then sweep for any hidden powershell windows
    if $current_audio_pid
      system("taskkill /f /t /pid #{$current_audio_pid} > nul 2>&1")
    end
    system("taskkill /f /im powershell.exe /fi \"WINDOWTITLE eq Hidden\" > nul 2>&1")
  elsif RUBY_PLATFORM =~ /darwin/
    if $current_audio_pid
      begin
        # Kill the shell process directly by PID only.
        # Using -getpgid (process group kill) is dangerous if the PID has been
        # recycled by the OS -- it can accidentally signal Lich's own process group.
        Process.kill('TERM', $current_audio_pid)
        # Also kill any child afplay process by name scoped to our shell's children
        system("pkill -P #{$current_audio_pid} afplay 2>/dev/null")
      rescue Errno::ESRCH, Errno::EPERM
        # Process already gone - not an error
      end
    end
  else
    # Linux
    if $current_audio_pid
      Process.kill('TERM', $current_audio_pid) rescue nil
    end
    system("pkill -f mpg123 > /dev/null 2>&1")
  end
  $current_audio_pid = nil
end

=begin
	   Nautical-Charts Version: 1.2.3 (May 11, 2026)
	
	   Usage: 
	
	    ;nautical-charts update              Will Update All Neccesary Files.
	    Shift + Left-Click                   Will Run Sail2.lic To Travel To Room Clicked On.
	    Left-Click Anchor Icon               Will Re-Center You On Your Ship Location.
	    Right-Click                          Will Show Map Options Menu.
	    
	    Notes:                               Map Backgrounds And Ship Icons Can Be Customized.
	                                         Be Sure To Match Resolution Of Map File.
	                                         Icons Are Formatted As 40x40 Pixels.

	   This is the OSA Map.
	   It Will Show You Your Current Location When Sailing In OSA.
	   This Map Will Use UID's To Track Ship Location. 
	   You Must Use WATCH OCEAN To See Continued Tracking.
	   Otherwise LOOK OCEAN Can Update Location On Per Use Basis.
	   
	   Enjoy!
	   ~Peggyanne 
	   
	   PS: feel free to send me any bugs via discord Bait#4376 and I'll try my best to fix them.
	   
	   Change Log:
                    March 4, 2026 - Initial Release.
                    March 6, 2026 - Changed Map File Folder Locations And Added Repo Info.
                   March 14, 2026 - Added Update Option To Script To Remove Nautical-Charts-Update Dependancy.
                      May 1, 2026 - Added Port Image Ranges and Port Images Display.
                      May 3, 2026 - Added Selectable Ship Icons, Window Placement/Size Memory, Port Images and Sounds (With Toggle For On/Off).
                      May 9, 2026 - Added Combat Detection and Alert Animation w/ Sound.
                     May 10, 2026 - Updated The OceanDB and Some Of The Map Files To Fix Broken Pathways.
                     May 11, 2026 - Improved Icon Tracking, Location Detection and Scale Response W/Persistant Setting. Also Fixed the Center Button.
=end

i_stand_alone
clear

script.want_downstream_xml = true

