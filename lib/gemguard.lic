def gemguard_settings_path
  File.join(DATA_DIR, XMLData.game, Char.name, 'gemguard.yaml')
end

def gemguard_scan_snapshot_path
  File.join(DATA_DIR, XMLData.game, Char.name, 'gemguard-scan.yaml')
end

def gemguard_inventory_db_path
  File.join(DATA_DIR, XMLData.game, Char.name, 'gemguard-inventory.yaml')
end

def gemguard_debug_path
  File.join(DATA_DIR, XMLData.game, Char.name, 'gemguard-debug.log')
end

def gemguard_deep_string_keys(value)
  case value
  when Hash
    value.each_with_object({}) { |(key, item), out| out[key.to_s] = gemguard_deep_string_keys(item) }
  when Array
    value.map { |item| gemguard_deep_string_keys(item) }
  else
    value
  end
end

# Loads the per-character gem record file used by Review and Purify.
#
# @return [Hash] Saved gem records, always with an "items" hash.
def gemguard_load_inventory_db
  path = gemguard_inventory_db_path
  loaded = File.exist?(path) ? YAML.load_file(path) : {}
  loaded = {} unless loaded.is_a?(Hash)
  db = gemguard_deep_string_keys(loaded)
  db['items'] = {} unless db['items'].is_a?(Hash)
  db
rescue => error
  echo "gemguard: failed to load #{path}: #{error.class}: #{error.message}" if defined?(echo)
  { 'items' => {} }
end

# Saves the per-character gem record file. This changes GemGuard YAML data.
#
# @param db [Hash] GemGuard inventory data to write.
# @return [Boolean] true when the save succeeds, false when it fails.
def gemguard_save_inventory_db(db)
  path = gemguard_inventory_db_path
  db = gemguard_deep_string_keys(db || {})
  db['script'] = 'gemguard'
  db['version'] = GEMGUARD_VERSION
  db['game'] = XMLData.game.to_s
  db['character'] = Char.name.to_s
  db['updated_at'] = Time.now.strftime('%m/%d/%Y %H:%M:%S %z')
  db['items'] = {} unless db['items'].is_a?(Hash)
  FileUtils.mkdir_p(File.dirname(path))
  File.write(path, db.to_yaml)
  true
rescue => error
  echo "gemguard: failed to save #{path}: #{error.class}: #{error.message}" if defined?(echo)
  false
end

def gemguard_inventory_record_for_id(id)
  db = gemguard_load_inventory_db
  db['items'][id.to_s]
rescue
  nil
end

def gemguard_inventory_value(record, key)
  return nil unless record.is_a?(Hash)

  record[key.to_s]
end

def gemguard_inventory_boolean(record, key)
  value = gemguard_inventory_value(record, key)
  value == true || value.to_s =~ /\Atrue\z/i
rescue
  false
end

def gemguard_cache_status_for_row(row)
  return 'chrism' if row[:chrism]
  return 'orb' if row[:orb]
  return 'marked' if row[:marked]
  return row[:purify_status].to_s if gemguard_meaningful_purify_status?(row[:purify_status])

  row[:reason].to_s
end

# Checks whether a saved status is a plain scan label instead of a special
# gem state. These weak labels should not erase stronger saved results.
#
# @param value [Object] Status text to check.
# @return [Boolean] true when the status is a plain scan label.
def gemguard_weak_cache_status?(value)
  value.to_s.strip =~ /\A(?:not protected|protected|ready|appraised for sale|over sell limit|above threshold|appraised below threshold)\z/i
rescue
  false
end

# Checks whether a status is only an action failure and should not be saved as
# the gem's lasting Review status.
#
# @param value [Object] Status text to check.
# @return [Boolean] true when the status should fall back to a normal label.
def gemguard_failure_status?(value)
  value.to_s.strip =~ /\A(?:failed|purify failed|action failed)\z/i
rescue
  false
end

# Checks whether a status is worth keeping across scans.
#
# @param value [Object] Status text to check.
# @return [Boolean] true when the status describes a saved gem state.
def gemguard_meaningful_cache_status?(value)
  text = value.to_s.strip
  return false if text.empty?
  return false if gemguard_weak_cache_status?(text)
  return false if gemguard_failure_status?(text)

  true
rescue
  false
end

# Checks whether a Purify result should survive later scans.
#
# @param value [Object] Purify status text to check.
# @return [Boolean] true when the status is more useful than "ready".
def gemguard_meaningful_purify_status?(value)
  text = value.to_s.strip
  return false if text.empty? || text =~ /\Aready\z/i
  return false if gemguard_failure_status?(text)

  true
rescue
  false
end

# Builds the YAML cache key for a scanned row. Real item IDs are used when
# present. Rows without IDs get a temporary key based on their scan location,
# name, noun, and occurrence count.
#
# @param row [Hash] Review or Purify row to cache.
# @param no_id_counts [Hash, nil] Occurrence counter for one scan pass.
# @return [String] Cache key, or an empty string when the row cannot be cached.
def gemguard_inventory_cache_key(row, no_id_counts = nil)
  row ||= {}
  id = row[:id].to_s
  return id unless id.empty?

  container = row[:container_id].to_s
  container = gemguard_normalize_container_name(row[:container]) if container.empty?
  base = [
    container,
    row[:name].to_s.downcase.strip,
    row[:noun].to_s.downcase.strip
  ].join('|')
  return '' if base.gsub('|', '').strip.empty?

  no_id_counts ||= Hash.new(0)
  no_id_counts[base] += 1
  "noid:#{base.gsub(/[^a-z0-9|:_-]/, '_')}:#{no_id_counts[base]}"
rescue
  ''
end

# Checks whether a saved record belongs to the containers covered by the
# current scan. This is used to remove only stale rows from the same scan area.
#
# @param record [Hash] Saved inventory record.
# @param container_ids [Array<String>] Container IDs scanned this pass.
# @param container_labels [Array<String>] Normalized container names scanned.
# @return [Boolean] true when the record belongs to the scanned area.
def gemguard_record_in_inventory_scope?(record, container_ids, container_labels)
  record = gemguard_deep_string_keys(record || {})
  record_container_id = record['container_id'].to_s
  return true if !record_container_id.empty? && container_ids.include?(record_container_id)

  record_labels = [record['container'].to_s]
  record_norms = record_labels.map { |label| gemguard_normalize_container_name(label) }.reject(&:empty?).uniq
  record_norms.any? do |record_label|
    container_labels.any? { |label| record_label == label || record_label.include?(label) || label.include?(record_label) }
  end
rescue
  false
end

# Builds container IDs and normalized labels for matching saved records.
#
# @param containers [Array<Object>] Container objects to include.
# @param extra_labels [Array<String>] Saved labels to include when objects cannot be found.
# @return [Array<Array<String>, Array<String>>] Container IDs and normalized labels.
def gemguard_container_scope_arrays(containers, extra_labels = [])
  ids = []
  labels = []
  Array(containers).compact.each do |container|
    ids << container.id.to_s if container.respond_to?(:id) && !container.id.to_s.empty?
    gemguard_container_match_labels(container).each { |label| labels << gemguard_normalize_container_name(label) }
  end
  Array(extra_labels).each { |label| labels << gemguard_normalize_container_name(label) }
  [ids.reject(&:empty?).uniq, labels.reject(&:empty?).uniq]
rescue
  [[], []]
end

# Finds containers whose saved rows should survive a Review scan even when they
# are not part of that scan.
#
# @return [Array<Array<Object>, Array<String>>] Container objects and labels.
def gemguard_preserved_inventory_containers
  settings = gemguard_load_settings
  values = []
  values << settings[:purify_unsung_container]
  values << settings[:purify_sung_container]
  values << settings[:purify_orb_container]
  values << settings[:chrism_container]
  values.concat(Array(settings[:ignore_containers]))
  values = values.map(&:to_s).map(&:strip).reject(&:empty?).reject { |value| value == GEMGUARD_NONE_LABEL }
  containers = values.filter_map { |value| gemguard_find_container(value) }
  [containers, values]
rescue
  [[], []]
end

# Checks whether a gem name is on the exception list.
#
# @param name [String] Full gem name.
# @param exceptions [Array<String>, nil] Exception names to check.
# @return [Boolean] true when the full gem name is excepted.
def gemguard_name_protection_exception?(name, exceptions = nil)
  key = gemguard_protection_exception_key(name)
  return false if key.empty?

  Array(exceptions || gemguard_protected_exceptions).any? { |term| gemguard_protection_exception_key(term) == key }
rescue
  false
end

def gemguard_cached_protected_name?(name, noun = '', exceptions = nil)
  return false if gemguard_name_protection_exception?(name, exceptions)

  name = name.to_s.downcase
  noun = noun.to_s.downcase
  gemguard_protected_terms.any? do |term|
    normalized = term.to_s.downcase
    !normalized.empty? && (noun == normalized || name.include?(normalized))
  end
rescue
  false
end

def gemguard_clear_scan_snapshot
  path = gemguard_scan_snapshot_path
  File.delete(path) if File.exist?(path)
  true
rescue => error
  echo "gemguard: failed to clear #{path}: #{error.class}: #{error.message}" if defined?(echo)
  false
end

def gemguard_snapshot_row(row)
  row = row.dup
  gemguard_enrich_row_from_inventory!(row)
  {
    'id' => row[:id].to_s,
    'name' => row[:name].to_s,
    'noun' => row[:noun].to_s,
    'container_id' => row[:container_id].to_s,
    'container' => row[:container].to_s,
    'action' => row[:action].to_s,
    'status' => row[:reason].to_s,
    'marked' => !!row[:marked],
    'chrism' => !!row[:chrism],
    'orb' => !!row[:orb],
    'orb_tested' => !!row[:orb_tested],
    'orb_test_result' => row[:orb_test_result].to_s,
    'orb_test_method' => row[:orb_test_method].to_s,
    'purify_status' => row[:purify_status].to_s,
    'value' => row[:value].to_s
  }
end

# Saves the current Review and Purify window state. This changes GemGuard YAML
# data so the window can keep showing the latest scan during this run.
#
# @param state [Hash] Current sell, keep, and purify rows.
# @return [Boolean] true when the save succeeds, false when it fails.
def gemguard_save_scan_snapshot(state)
  state ||= {}
  sell_rows = Array(state[:sell])
  keep_rows = Array(state[:keep])
  path = gemguard_scan_snapshot_path
  snapshot = {
    'script' => 'gemguard',
    'version' => GEMGUARD_VERSION,
    'game' => XMLData.game.to_s,
    'character' => Char.name.to_s,
    'updated_at' => Time.now.strftime('%m/%d/%Y %H:%M:%S %z'),
    'sell_count' => sell_rows.length,
    'keep_count' => keep_rows.length,
    'sell' => sell_rows.map { |row| gemguard_snapshot_row(row) },
    'keep' => keep_rows.map { |row| gemguard_snapshot_row(row) }
  }
  FileUtils.mkdir_p(File.dirname(path))
  File.write(path, snapshot.to_yaml)
  true
rescue => error
  echo "gemguard: failed to save #{path}: #{error.class}: #{error.message}"
  false
end

def gemguard_placeholder_container_label?(value)
  text = value.to_s.strip
  text.empty? || text =~ /\A\((?:unknown|worn\/held)\)\z/i
rescue
  true
end

def gemguard_inventory_record_from_row(row, existing = nil)
  row ||= {}
  existing = gemguard_deep_string_keys(existing || {})
  action = row[:action].to_s
  action = existing['action'].to_s if action == 'purify' && !existing['action'].to_s.empty?
  value = row[:value].to_s
  value = existing['value'].to_s if !row[:clear_value] && !gemguard_meaningful_review_value?(value) && gemguard_meaningful_review_value?(existing['value'])
  value = '' unless gemguard_meaningful_review_value?(value)
  purify_status = row[:purify_status].to_s
  purify_status = existing['purify_status'].to_s if !gemguard_meaningful_purify_status?(purify_status) && gemguard_meaningful_purify_status?(existing['purify_status'])
  purify_status = '' unless gemguard_meaningful_purify_status?(purify_status)
  status = gemguard_cache_status_for_row(row)
  status = existing['status'].to_s if !gemguard_meaningful_cache_status?(status) && gemguard_meaningful_cache_status?(existing['status'])
  status = '' if gemguard_failure_status?(status)
  cache_id = row[:cache_id].to_s
  cache_id = row[:id].to_s if cache_id.empty?
  cache_id = existing['cache_id'].to_s if cache_id.empty?
  container_id = row[:container_id].to_s
  container_id = existing['container_id'].to_s if container_id.empty?
  container = row[:container].to_s
  if gemguard_placeholder_container_label?(container) && !gemguard_placeholder_container_label?(existing['container'])
    container = existing['container'].to_s
  end
  chrism_strength = row[:chrism_strength].to_s
  chrism_strength = existing['chrism_strength'].to_s if chrism_strength.empty?
  chrism_fullness = row[:chrism_fullness].to_s
  chrism_fullness = existing['chrism_fullness'].to_s if chrism_fullness.empty?
  chrism_output = row[:chrism_output].to_s
  chrism_output = existing['chrism_output'].to_s if chrism_output.empty?

  {
    'cache_id' => cache_id,
    'id' => row[:id].to_s,
    'name' => row[:name].to_s,
    'noun' => row[:noun].to_s,
    'container_id' => container_id,
    'container' => container,
    'action' => action,
    'status' => status,
    'marked' => row.key?(:marked) ? !!row[:marked] : gemguard_inventory_boolean(existing, 'marked'),
    'chrism' => row.key?(:chrism) ? !!row[:chrism] : gemguard_inventory_boolean(existing, 'chrism'),
    'chrism_strength' => chrism_strength,
    'chrism_fullness' => chrism_fullness,
    'chrism_output' => chrism_output,
    'orb' => row.key?(:orb) ? !!row[:orb] : gemguard_inventory_boolean(existing, 'orb'),
    'orb_tested' => row.key?(:orb_tested) ? !!row[:orb_tested] : gemguard_inventory_boolean(existing, 'orb_tested'),
    'orb_test_result' => row[:orb_test_result].to_s.empty? ? existing['orb_test_result'].to_s : row[:orb_test_result].to_s,
    'orb_test_method' => row[:orb_test_method].to_s.empty? ? existing['orb_test_method'].to_s : row[:orb_test_method].to_s,
    'orb_tested_at' => row[:orb_tested_at].to_s.empty? ? existing['orb_tested_at'].to_s : row[:orb_tested_at].to_s,
    'orb_test_output' => row[:orb_test_output].to_s.empty? ? existing['orb_test_output'].to_s : row[:orb_test_output].to_s,
    'purify_status' => purify_status,
    'value' => value,
    'last_seen_at' => Time.now.strftime('%m/%d/%Y %H:%M:%S %z'),
    'updated_at' => Time.now.strftime('%m/%d/%Y %H:%M:%S %z')
  }
end

def gemguard_row_from_inventory_record(record)
  record = gemguard_deep_string_keys(record || {})
  {
    id: record['id'].to_s,
    cache_id: record['cache_id'].to_s,
    name: record['name'].to_s,
    noun: record['noun'].to_s,
    container_id: record['container_id'].to_s,
    container: record['container'].to_s.empty? ? '(unknown)' : record['container'].to_s,
    action: record['action'].to_s.empty? ? :keep : record['action'].to_sym,
    reason: record['status'].to_s.empty? ? record['purify_status'].to_s : record['status'].to_s,
    marked: gemguard_inventory_boolean(record, 'marked'),
    chrism: gemguard_inventory_boolean(record, 'chrism'),
    chrism_strength: record['chrism_strength'].to_s,
    chrism_fullness: record['chrism_fullness'].to_s,
    chrism_output: record['chrism_output'].to_s,
    orb: gemguard_inventory_boolean(record, 'orb'),
    orb_tested: gemguard_inventory_boolean(record, 'orb_tested'),
    orb_test_result: record['orb_test_result'].to_s,
    orb_test_method: record['orb_test_method'].to_s,
    orb_tested_at: record['orb_tested_at'].to_s,
    orb_test_output: record['orb_test_output'].to_s,
    purify_status: record['purify_status'].to_s,
    value: record['value'].to_s
  }
end

# Updates cached gem records from visible Review or Purify rows. This changes
# GemGuard YAML data.
#
# @param rows [Array<Hash>] Rows to save.
# @param prune [Boolean] When true, remove cached rows missing from this scan.
# @return [void]
def gemguard_update_inventory_rows(rows, prune: false)
  db = gemguard_load_inventory_db
  items = db['items']
  seen = []
  scanned_container_ids = []
  scanned_container_labels = []
  no_id_counts = Hash.new(0)
  Array(rows).compact.each do |row|
    cache_id = gemguard_inventory_cache_key(row, no_id_counts)
    next if cache_id.empty?

    row[:cache_id] = cache_id
    seen << cache_id
    scanned_container_ids << row[:container_id].to_s unless row[:container_id].to_s.empty?
    scanned_container_labels << gemguard_normalize_container_name(row[:container]) unless gemguard_placeholder_container_label?(row[:container])
    items[cache_id] = gemguard_inventory_record_from_row(row, items[cache_id])
  end
  if prune
    scanned_container_ids.uniq!
    scanned_container_labels = scanned_container_labels.map(&:to_s).reject(&:empty?).uniq
    items.delete_if do |id, record|
      next false if seen.include?(id.to_s)
      next false if scanned_container_ids.empty? && scanned_container_labels.empty?

      gemguard_record_in_inventory_scope?(record, scanned_container_ids, scanned_container_labels)
    end
  end
  gemguard_save_inventory_db(db)
  rows
end

# Removes saved gem rows that no longer belong to the current GemGuard setup.
# This changes GemGuard YAML data after a real scan has confirmed current items.
#
# @param rows [Array<Hash>] Rows found by the current Review scan.
# @param scanned_containers [Array<Object>] Containers inspected by the scan.
# @return [Integer] Number of stale saved rows removed.
def gemguard_cleanup_inventory_after_review_scan(rows, scanned_containers)
  no_id_counts = Hash.new(0)
  seen = Array(rows).map { |row| gemguard_inventory_cache_key(row, no_id_counts) }.reject(&:empty?).uniq
  preserved_containers, preserved_labels = gemguard_preserved_inventory_containers
  scanned_ids, scanned_labels = gemguard_container_scope_arrays(scanned_containers)
  preserved_ids, preserved_norms = gemguard_container_scope_arrays(preserved_containers, preserved_labels)
  keep_ids = (scanned_ids + preserved_ids).uniq
  keep_labels = (scanned_labels + preserved_norms).uniq
  return 0 if keep_ids.empty? && keep_labels.empty?

  removed = 0
  db = gemguard_load_inventory_db
  db['items'].delete_if do |id, record|
    next false if seen.include?(id.to_s)

    keep_record = gemguard_record_in_inventory_scope?(record, keep_ids, keep_labels)
    remove_record = !keep_record
    removed += 1 if remove_record
    remove_record
  end
  gemguard_save_inventory_db(db) if removed.positive?
  removed
rescue => error
  gemguard_gtk_debug "inventory cleanup failed: #{error.class}: #{error.message}"
  0
end

def gemguard_remove_inventory_ids(ids)
  ids = Array(ids).map(&:to_s).reject(&:empty?)
  return false if ids.empty?

  db = gemguard_load_inventory_db
  ids.each { |id| db['items'].delete(id) }
  gemguard_save_inventory_db(db)
end

def gemguard_prune_inventory_source_rows(rows, source_name)
  source_name = source_name.to_s.strip
  return false if source_name.empty? || source_name == GEMGUARD_NONE_LABEL

  keep_ids = Array(rows).map { |row| row[:id].to_s }.reject(&:empty?)
  db = gemguard_load_inventory_db
  removed = false
  db['items'].delete_if do |id, record|
    next false if keep_ids.include?(id.to_s)

    row = gemguard_row_from_inventory_record(record)
    matched = gemguard_cached_row_in_purify_source?(row, source_name)
    removed ||= matched
    matched
  end
  gemguard_save_inventory_db(db) if removed
  removed
rescue => error
  gemguard_gtk_debug "failed to prune stale source rows: #{error.class}: #{error.message}"
  false
end

def gemguard_update_inventory_item(id, attrs = {})
  id = id.to_s
  return false if id.empty?

  db = gemguard_load_inventory_db
  record = gemguard_deep_string_keys(db['items'][id] || { 'id' => id })
  gemguard_deep_string_keys(attrs || {}).each { |key, value| record[key] = value }
  record['updated_at'] = Time.now.strftime('%m/%d/%Y %H:%M:%S %z')
  db['items'][id] = record
  gemguard_save_inventory_db(db)
end

def gemguard_enrich_row_from_inventory!(row)
  record = gemguard_inventory_record_for_id(row[:id])
  return row unless record.is_a?(Hash)

  cached = gemguard_row_from_inventory_record(record)
  row[:cache_status_matched] = true if cached[:marked] ||
                                      cached[:chrism] ||
                                      cached[:orb] ||
                                      gemguard_meaningful_cache_status?(cached[:reason]) ||
                                      gemguard_meaningful_purify_status?(cached[:purify_status])
  row[:value] = cached[:value] if gemguard_meaningful_review_value?(cached[:value])
  if row[:purify_status].to_s.empty? && gemguard_meaningful_purify_status?(cached[:purify_status])
    row[:purify_status] = cached[:purify_status]
  end
  row[:container_id] = cached[:container_id] if row[:container_id].to_s.empty? && !cached[:container_id].to_s.empty?
  if gemguard_placeholder_container_label?(row[:container]) && !gemguard_placeholder_container_label?(cached[:container])
    row[:container] = cached[:container]
  end
  row[:marked] = true if cached[:marked]
  row[:chrism] = true if cached[:chrism]
  row[:orb] = true if cached[:orb]
  row[:orb_tested] = true if cached[:orb_tested]
  [:chrism_strength, :chrism_fullness, :chrism_output].each do |key|
    row[key] = cached[key] unless cached[key].to_s.empty?
  end
  [:orb_test_result, :orb_test_method, :orb_tested_at, :orb_test_output].each do |key|
    row[key] = cached[key] unless cached[key].to_s.empty?
  end
  if gemguard_meaningful_cache_status?(cached[:reason]) && gemguard_weak_cache_status?(row[:reason])
    row[:reason] = cached[:reason]
  elsif gemguard_meaningful_purify_status?(row[:purify_status]) && row[:reason].to_s =~ /\A(?:not protected|protected|ready)\z/i
    row[:reason] = row[:purify_status]
  elsif row[:chrism]
    row[:reason] = 'chrism'
  elsif row[:orb]
    row[:reason] = 'orb'
  elsif row[:marked]
    row[:reason] = 'marked'
  end
  row
rescue
  row
end

def gemguard_purify_all_gems_enabled?(settings = nil)
  if settings.is_a?(Hash)
    value = settings[:purify_all_gems]
    value = settings['purify_all_gems'] if value.to_s.empty? && settings.key?('purify_all_gems')
    return gemguard_truthy_value?(value)
  end

  gemguard_truthy_value?(gemguard_setting_value(:purify_all_gems))
rescue
  false
end

def gemguard_cached_purify_candidate?(row, settings = nil)
  return false unless row
  return false if row[:name].to_s =~ /smooth stone/i
  return false if row[:noun].to_s =~ /\Ascarab\z/i || row[:name].to_s =~ /\bscarab\b/i
  return false if row[:marked] || row[:chrism] || row[:orb]

  status = row[:purify_status].to_s
  return false if status =~ /\b(?:purified|(?:pure )?orb|shattered|chrism)\b/i

  return true if gemguard_purify_all_gems_enabled?(settings)

  gemguard_cached_protected_name?(row[:name], row[:noun])
rescue
  false
end

def gemguard_purify_source_setting(settings = nil)
  if settings.is_a?(Hash)
    value = settings[:purify_unsung_container]
    value = settings['purify_unsung_container'] if value.to_s.empty? && settings.key?('purify_unsung_container')
    return value.to_s.strip unless value.to_s.strip.empty?
  end

  gemguard_setting_value(:purify_unsung_container).to_s.strip
rescue
  ''
end

def gemguard_cached_row_in_purify_source?(row, source_name)
  source_name = source_name.to_s.strip
  return true if source_name.empty? || source_name == GEMGUARD_NONE_LABEL

  source = gemguard_find_container(source_name)
  row_container_id = row[:container_id].to_s
  return true if source && !row_container_id.empty? && row_container_id == source.id.to_s

  source_labels = [source_name]
  if source
    source_labels << source.name.to_s
    source_labels << gemguard_container_label(source)
    source_labels << gemguard_container_display_label(source)
  end
  row_labels = [row[:container].to_s]
  source_norms = source_labels.map { |label| gemguard_normalize_container_name(label) }.reject(&:empty?).uniq
  row_norms = row_labels.map { |label| gemguard_normalize_container_name(label) }.reject(&:empty?).uniq
  row_norms.any? { |row_label| source_norms.any? { |source_label| row_label == source_label || row_label.include?(source_label) || source_label.include?(row_label) } }
rescue
  false
end

# Checks whether a row's known container matches a saved GemGuard container
# setting. This lets scans use saved bag choices even when item IDs changed.
#
# @param row [Hash] Review or Purify row with container_id/container.
# @param container [Object, nil] Container object found during the scan.
# @param setting [String] Saved container setting text or id.
# @return [Boolean] true when the row belongs to the saved container.
def gemguard_row_in_setting_container?(row, container, setting)
  setting = setting.to_s.strip
  return false if setting.empty? || setting == GEMGUARD_NONE_LABEL

  setting_container = gemguard_find_container(setting)
  row_container_id = row[:container_id].to_s
  return true if setting =~ /\A#?(\d+)\z/ && !row_container_id.empty? && row_container_id == Regexp.last_match(1).to_s
  return true if setting_container && !row_container_id.empty? && row_container_id == setting_container.id.to_s

  source_labels = [setting]
  if setting_container
    source_labels << setting_container.name.to_s
    source_labels << gemguard_container_label(setting_container)
    source_labels << gemguard_container_display_label(setting_container)
  end

  row_labels = [row[:container].to_s]
  if container
    row_labels << container.name.to_s
    row_labels << gemguard_container_label(container)
    row_labels << gemguard_container_display_label(container)
  end

  source_norms = source_labels.map { |label| gemguard_normalize_container_name(label) }.reject(&:empty?).uniq
  row_norms = row_labels.map { |label| gemguard_normalize_container_name(label) }.reject(&:empty?).uniq
  row_norms.any? { |row_label| source_norms.any? { |source_label| row_label == source_label || row_label.include?(source_label) || source_label.include?(row_label) } }
rescue
  false
end

# Applies status hints from saved GemGuard containers. This changes only the row
# being built; later cache writes save the result by item ID or scan key.
#
# @param row [Hash] Review or Purify row to update.
# @param container [Object, nil] Container object found during the scan.
# @return [Hash] Updated row.
def gemguard_apply_container_status_hints!(row, container = nil)
  return row unless row.is_a?(Hash)
  return row if row[:cache_status_matched]
  return row if row[:chrism] || row[:reason].to_s =~ /\bchrism\b/i
  return row if row[:orb] || row[:reason].to_s =~ /\borb\b/i

  settings = gemguard_load_settings
  source_container = gemguard_row_in_setting_container?(row, container, settings[:purify_unsung_container])
  purified_container = gemguard_row_in_setting_container?(row, container, settings[:purify_sung_container])
  orb_container = gemguard_row_in_setting_container?(row, container, settings[:purify_orb_container])
  chrism_container = gemguard_row_in_setting_container?(row, container, settings[:chrism_container])

  return row if source_container && (purified_container || orb_container || chrism_container)

  if purified_container && (orb_container || chrism_container)
    row[:purify_status] = 'purified'
    row[:reason] = 'purified' unless gemguard_review_row_marked?(row)
  elsif orb_container
    row[:orb] = true
    row[:reason] = 'orb' unless gemguard_review_row_marked?(row)
  elsif chrism_container
    row[:chrism] = true
    row[:reason] = 'chrism' unless gemguard_review_row_marked?(row)
  elsif purified_container
    row[:purify_status] = 'purified'
    row[:reason] = 'purified' unless gemguard_review_row_marked?(row)
  end

  row
rescue => error
  gemguard_gtk_debug "container status hint failed: #{error.class}: #{error.message}" if defined?(gemguard_gtk_debug)
  row
end

# Builds Purify tab rows from the current Review scan. This keeps the Purify
# list matched to the gems the user just scanned on the main Review page.
#
# @param review_rows [Array<Hash>] Rows from the Review sell and keep lists.
# @param purify_settings [Hash, nil] Current Purify container and filter settings.
# @return [Array<Hash>] Rows ready to show in the Purify tab.
def gemguard_purify_rows_from_review_rows(review_rows, purify_settings = nil)
  purify_source = gemguard_purify_source_setting(purify_settings)
  Array(review_rows).select do |row|
    gemguard_cached_purify_candidate?(row, purify_settings) &&
      gemguard_cached_row_in_purify_source?(row, purify_source)
  end.map do |row|
    row.merge(
      action: :purify,
      reason: row[:purify_status].to_s.empty? ? 'ready' : row[:purify_status].to_s
    )
  end
rescue => error
  gemguard_gtk_debug "review purify row build failed: #{error.class}: #{error.message}"
  []
end

def gemguard_state_from_inventory_db(purify_settings = nil)
  rows = gemguard_load_inventory_db['items'].values.map { |record| gemguard_row_from_inventory_record(record) }
  sell, keep = rows.reject { |row| row[:action].to_s == 'purify' }.partition { |row| row[:action].to_s == 'sell' }
  {
    sell: sell,
    keep: keep,
    purify: gemguard_purify_rows_from_review_rows(rows, purify_settings)
  }
rescue
  { sell: [], keep: [], purify: [] }
end

def gemguard_load_inventory_statuses!
  @orb_statuses = {} unless @orb_statuses.is_a?(Hash)
  @purify_statuses = {} unless @purify_statuses.is_a?(Hash)
  @chrism_statuses = {} unless @chrism_statuses.is_a?(Hash)
  @inventory_statuses = {} unless @inventory_statuses.is_a?(Hash)

  gemguard_load_inventory_db['items'].each do |id, record|
    record = gemguard_deep_string_keys(record)
    @orb_statuses[id.to_s] = { pure: true, method: 'cache', tested_at: record['updated_at'].to_s } if gemguard_inventory_boolean(record, 'orb')
    if gemguard_inventory_boolean(record, 'chrism')
      @chrism_statuses[id.to_s] = {
        chrism: true,
        tested_at: record['updated_at'].to_s,
        strength: record['chrism_strength'].to_s,
        fullness: record['chrism_fullness'].to_s
      }
    end
    if gemguard_meaningful_purify_status?(record['purify_status'])
      @purify_statuses[id.to_s] = { status: record['purify_status'].to_s, tested_at: record['updated_at'].to_s }
    end
    @inventory_statuses[id.to_s] = { marked: true, raw: '(marked)' } if gemguard_inventory_boolean(record, 'marked')
  end
rescue => error
  gemguard_gtk_debug "inventory status load failed: #{error.class}: #{error.message}" if defined?(gemguard_gtk_debug)
end

unless @scan_snapshot_cleanup_registered
  before_dying { gemguard_clear_scan_snapshot } if defined?(before_dying)
  @scan_snapshot_cleanup_registered = true
end

def gemguard_default_settings
  {
    protected_terms: GEMGUARD_DEFAULT_PROTECTED_GEMS.sort_by(&:downcase),
    protected_exceptions: [],
    purify_unsung_container: '',
    purify_sung_container: '',
    purify_orb_container: '',
    chrism_container: '',
    pure_orb_sell_threshold: '0',
    appraised_gem_sell_threshold: '0',
    sell_value_confirm_enabled: 'false',
    sell_value_ignore_protected: 'false',
    sell_purified_ignore_value: 'false',
    purify_all_gems: 'false',
    lapidary_box: '',
    lapidary_box_container: '',
    lapidary_design_slots: '0',
    lapidary_designs: [],
    lapidary_supports_whisper_design: 'false',
    gemcutter_device: '',
    gemcutter_pattern: '',
    gemcutter_regular_pattern: '',
    gemcutter_purified_pattern: '',
    gemcutter_orb_pattern: '',
    gemcutter_chrism_pattern: '',
    gemcutter_debug_enabled: 'false',
    scan_containers: [],
    ignore_containers: []
  }
end

# Loads this character's GemGuard settings.
#
# @return [Hash] Settings merged with defaults.
def gemguard_load_settings
  path = gemguard_settings_path
  return gemguard_default_settings unless File.exist?(path)

  loaded = YAML.load_file(path) || {}
  loaded = loaded.transform_keys(&:to_sym) if loaded.respond_to?(:transform_keys)
  defaults = gemguard_default_settings
  defaults.merge(loaded)
rescue => error
  echo "gemguard: failed to load #{path}: #{error.class}: #{error.message}"
  gemguard_default_settings
end

# Saves this character's GemGuard settings. This changes GemGuard YAML data.
#
# @param settings [Hash] Settings to write.
# @return [Boolean] false when saving fails.
def gemguard_save_settings(settings)
  path = gemguard_settings_path
  FileUtils.mkdir_p(File.dirname(path))
  File.write(path, settings.to_yaml)
rescue => error
  echo "gemguard: failed to save #{path}: #{error.class}: #{error.message}"
  false
end

def gemguard_protected_terms
  Array(gemguard_load_settings[:protected_terms]).map(&:to_s).map(&:strip).reject(&:empty?).uniq { |term| term.downcase }
end

# Normalizes gem names for exact protected-list exception matching.
#
# @param value [String] Gem name or saved exception text.
# @return [String] Lowercase comparison value.
def gemguard_protection_exception_key(value)
  value.to_s.downcase.strip.sub(/\s*\(\d+\)\s*\z/, '').gsub(/\s+/, ' ')
rescue
  ''
end

# Reads exact gem names that bypass broad protected terms.
#
# @return [Array<String>] Saved protected-list exceptions.
def gemguard_protected_exceptions
  Array(gemguard_load_settings[:protected_exceptions]).map(&:to_s).map(&:strip).reject(&:empty?).uniq { |term| gemguard_protection_exception_key(term) }
end

# Saves the protected gem name list. This changes GemGuard YAML data.
#
# @param terms [Array<String>] Gem names or nouns to keep protected.
# @return [Boolean] false when saving fails.
def gemguard_save_protected_terms(terms)
  settings = gemguard_load_settings
  settings[:protected_terms] = Array(terms).map(&:to_s).map(&:strip).reject(&:empty?).uniq { |term| term.downcase }.sort_by(&:downcase)
  gemguard_save_settings(settings)
end

# Saves exact gem names that should not be protected by broad protected terms.
# This changes GemGuard settings.
#
# @param terms [Array<String>] Exception gem names.
# @return [Boolean] false when saving fails.
def gemguard_save_protected_exceptions(terms)
  settings = gemguard_load_settings
  settings[:protected_exceptions] = Array(terms).map(&:to_s).map(&:strip).reject(&:empty?).uniq { |term| gemguard_protection_exception_key(term) }.sort_by(&:downcase)
  gemguard_save_settings(settings)
end

def gemguard_setting_value(key)
  settings = gemguard_load_settings
  value = settings[key.to_sym]
  value = settings[key.to_s] if value.nil? && settings.key?(key.to_s)
  value.to_s
rescue
  ''
end

def gemguard_truthy_value?(value)
  value.to_s.strip =~ /\A(?:1|true|yes|y|on)\z/i
rescue
  false
end

def gemguard_gemcutter_debug_enabled?
  gemguard_truthy_value?(gemguard_setting_value(:gemcutter_debug_enabled))
end

# Writes a focused Gemcutter debug line when debug mode is enabled. This changes
# a per-character debug file only when the setting is on.
#
# @param message [String] Short debug message.
# @return [void]
def gemguard_gemcutter_debug(message)
  return unless gemguard_gemcutter_debug_enabled?

  FileUtils.mkdir_p(File.dirname(gemguard_debug_path))
  File.open(gemguard_debug_path, 'a') do |file|
    file.puts "#{Time.now.strftime('%m/%d/%Y %H:%M:%S')} gemcutter v#{GEMGUARD_VERSION} build #{GEMGUARD_BUILD}: #{message}"
  end
rescue => error
  gemguard_gtk_debug "gemcutter debug failed: #{error.class}: #{error.message}" if defined?(gemguard_gtk_debug)
end

def gemguard_save_setting_value(key, value)
  settings = gemguard_load_settings
  settings[key.to_sym] = value.to_s.strip
  settings.delete(key.to_s) if settings.key?(key.to_s)
  gemguard_save_settings(settings)
end

def gemguard_setting_array(key)
  settings = gemguard_load_settings
  value = settings[key.to_sym]
  value = settings[key.to_s] if value.nil? && settings.key?(key.to_s)
  Array(value).map(&:to_s).map(&:strip).reject(&:empty?).uniq { |item| item.downcase }
rescue
  []
end

def gemguard_save_setting_array(key, values)
  settings = gemguard_load_settings
  settings[key.to_sym] = Array(values).map(&:to_s).map(&:strip).reject(&:empty?).uniq { |item| item.downcase }.sort_by(&:downcase)
  settings.delete(key.to_s) if settings.key?(key.to_s)
  gemguard_save_settings(settings)
end

def gemguard_script_command
  lich_char = defined?($clean_lich_char) && $clean_lich_char ? $clean_lich_char : ';'
  script_name = defined?(Script) && Script.respond_to?(:current) && Script.current ? Script.current.name : 'gemguard'
  "#{lich_char}#{script_name}"
end

def gemguard_current_script_name
  return Script.current.name.to_s if defined?(Script) && Script.respond_to?(:current) && Script.current && Script.current.respond_to?(:name)

  'gemguard'
rescue
  'gemguard'
end

def gemguard_mono_block(text)
  if defined?(_respond)
    _respond %Q{<output class="mono"/>\n#{text}<output class=""/>}
  else
    respond text
  end
end

def gemguard_inline_preset(preset, text)
  "<preset id=\"#{preset}\">#{text}</preset>"
end

def gemguard_silent
  hook_name = nil
  if defined?(DownstreamHook)
    hook_name = "#{gemguard_current_script_name}_gemguard_squelch_#{Time.now.to_f}_#{rand(1000)}"
    DownstreamHook.add(hook_name, proc { |_server_string| nil })
  end
  restore_silence = defined?(silence_me) ? silence_me : nil
  silence_me if defined?(silence_me) && !restore_silence
  yield
ensure
  DownstreamHook.remove(hook_name) if hook_name && defined?(DownstreamHook)
  silence_me if defined?(silence_me) && restore_silence
end

def gemguard_quiet_dothistimeout(command, timeout, pattern)
  gemguard_silent { dothistimeout(command, timeout, pattern) }
end

def gemguard_dothistimeout(command, timeout, pattern, quiet = true)
  quiet ? gemguard_quiet_dothistimeout(command, timeout, pattern) : dothistimeout(command, timeout, pattern)
end

def chrism_sell_eloot_profile_path
  File.join(DATA_DIR, XMLData.game, Char.name, 'eloot.yaml')
end

def chrism_sell_load_eloot_settings
  path = chrism_sell_eloot_profile_path
  return {} unless File.exist?(path)

  YAML.load_file(path) || {}
rescue => error
  echo "gemguard: failed to load #{path}: #{error.class}: #{error.message}"
  exit
end

def chrism_sell_save_eloot_settings(settings)
  path = chrism_sell_eloot_profile_path
  FileUtils.mkdir_p(File.dirname(path))
  File.write(path, settings.to_yaml)
rescue => error
  echo "gemguard: failed to save #{path}: #{error.class}: #{error.message}"
  exit
end

def chrism_sell_eloot_excludes(settings)
  value = settings[:sell_exclude]
  value = settings['sell_exclude'] if value.nil? && settings.key?('sell_exclude')
  Array(value).map(&:to_s)
end

def chrism_sell_set_eloot_excludes(settings, values)
  settings[:sell_exclude] = Array(values).map(&:to_s)
  settings.delete('sell_exclude') if settings.key?('sell_exclude')
end

def chrism_sell_inventory_objects(objects = GameObj.inv.to_a, seen = {})
  found = []

  Array(objects).each do |obj|
    next unless obj

    id = obj.id.to_s
    next if !id.empty? && seen[id]

    seen[id] = true unless id.empty?
    found << obj

    if obj.respond_to?(:contents) && obj.contents
      found.concat(chrism_sell_inventory_objects(obj.contents, seen))
    end
  end

  found
end

# Builds a lookup from item ID to the container that held it during this scan.
# This prevents Review rows from falling back to "(worn/held)" when GameObj no
# longer exposes the parent container by the time the table row is built.
#
# @param containers [Array<Object>] Containers GemGuard inspected.
# @param map [Hash] Existing item-id to container lookup.
# @return [Hash] Item IDs mapped to their known source container.
def gemguard_item_container_map(containers, map = {})
  Array(containers).compact.each do |container|
    next unless container.respond_to?(:contents) && container.contents

    Array(container.contents).compact.each do |item|
      id = item.id.to_s
      map[id] = container unless id.empty?
      if item.respond_to?(:contents) && item.contents
        gemguard_item_container_map([item], map)
      end
    end
  end
  map
rescue
  map || {}
end

def chrism_sell_inventory_containers
  GameObj.inv.to_a.select do |obj|
    next false unless obj
    next false if obj.id.to_s.empty?
    next false if obj.name.to_s == 'Empty'

    obj.respond_to?(:contents)
  end
end

def gemguard_normalize_container_name(name)
  name.to_s.downcase
      .gsub(/\b(?:a|an|the|some)\b/, ' ')
      .gsub(/[^a-z0-9]+/, ' ')
      .squeeze(' ')
      .strip
end

def gemguard_find_container(setting)
  wanted = gemguard_normalize_container_name(setting)
  return nil if wanted.empty?

  if setting.to_s.strip =~ /\A#?(\d+)\z/
    id = Regexp.last_match(1)
    return GameObj.inv.find { |obj| obj.id.to_s == id.to_s }
  end

  candidates = GameObj.inv.to_a
  match = candidates.find do |container|
    gemguard_container_match_labels(container).any? { |label| gemguard_normalize_container_name(label) == wanted }
  end
  return match if match

  match = candidates.find do |container|
    gemguard_container_match_labels(container).any? do |label|
      actual = gemguard_normalize_container_name(label)
      !actual.empty? && (actual.include?(wanted) || wanted.include?(actual))
    end
  end
  return match if match

  setting_words = wanted.split(/\s+/)
  setting_noun = setting_words.last.to_s
  setting_adjs = setting_words[0...-1].to_a
  return nil if setting_noun.empty?

  match = candidates.find do |container|
    next false unless gemguard_normalize_container_name(container.noun) == setting_noun

    labels = gemguard_container_match_labels(container).map { |label| gemguard_normalize_container_name(label) }
    setting_adjs.all? { |adj| labels.any? { |label| label.include?(adj) } }
  end
  return match if match

  noun_matches = candidates.select { |container| gemguard_normalize_container_name(container.noun) == setting_noun }
  noun_matches.length == 1 ? noun_matches.first : nil
rescue
  nil
end

def gemguard_container_label(container)
  name = container.name.to_s.strip
  noun = container.noun.to_s.strip
  name.empty? || name == 'Empty' ? noun : name
rescue
  ''
end

def gemguard_container_display_label(container, fallback = nil)
  [
    (container.full_name if container && container.respond_to?(:full_name)),
    (container.name if container && container.respond_to?(:name)),
    fallback,
    (container.noun if container && container.respond_to?(:noun))
  ].compact.map(&:to_s).map(&:strip).reject(&:empty?).first.to_s
rescue
  fallback.to_s
end

def gemguard_container_match_labels(container)
  [
    gemguard_container_label(container),
    gemguard_container_display_label(container),
    (container.noun if container.respond_to?(:noun))
  ].compact.map(&:to_s).map(&:strip).reject(&:empty?).uniq
end

def gemguard_container_choice(display, value = nil)
  display = display.to_s.strip
  value = value.to_s.strip
  value = display if value.empty?
  { display: display, value: value }
end

def gemguard_choice_display(choice)
  return choice[:display].to_s.strip if choice.is_a?(Hash) && choice.key?(:display)
  return choice['display'].to_s.strip if choice.is_a?(Hash) && choice.key?('display')

  choice.to_s.strip
end

def gemguard_choice_value(choice)
  if choice.is_a?(Hash)
    value = choice.key?(:value) ? choice[:value] : choice['value']
    value = value.to_s.strip
    return value unless value.empty?
  end

  gemguard_choice_display(choice)
end

def gemguard_choice_matches?(choice, selected)
  selected = selected.to_s.strip
  return false if selected.empty?

  [gemguard_choice_value(choice), gemguard_choice_display(choice)].any? { |text| text.to_s.casecmp(selected).zero? }
end

def gemguard_unique_container_choices(choices)
  seen = {}
  Array(choices).each_with_object([]) do |choice, list|
    display = gemguard_choice_display(choice)
    value = gemguard_choice_value(choice)
    next if display.empty?

    key = value.empty? ? display.downcase : value.downcase
    next if seen[key]

    seen[key] = true
    list << gemguard_container_choice(display, value)
  end
end

def gemguard_inventory_container_clause?(text)
  clause = text.to_s.strip
  return false if clause.empty?
  return false if clause =~ /\bno containers\b/i
  return false if clause =~ /\A(?:which|that|who|whose|where|when)\b/i

  true
end

def gemguard_container_choices
  gemguard_scan_container_choices
rescue
  []
end

def gemguard_saved_container_choices
  values = []
  values << gemguard_setting_value(:purify_unsung_container)
  values << gemguard_setting_value(:purify_sung_container)
  values << gemguard_setting_value(:purify_orb_container)
  values << gemguard_setting_value(:chrism_container)
  values << gemguard_setting_value(:lapidary_box_container)
  values.concat(gemguard_setting_array(:scan_containers))
  values.concat(gemguard_setting_array(:ignore_containers))
  gemguard_unique_container_choices(values.map { |value| gemguard_container_choice(value, value) })
rescue
  []
end

def gemguard_lapidary_designs
  settings = gemguard_load_settings
  value = settings[:lapidary_designs]
  value = settings['lapidary_designs'] if value.nil? && settings.key?('lapidary_designs')
  Array(value).map(&:to_s).map(&:strip).reject(&:empty?)
rescue
  []
end

def gemguard_lapidary_design_summary
  box = gemguard_setting_value(:lapidary_box)
  slots = gemguard_setting_value(:lapidary_design_slots).gsub(/[^\d]/, '').to_i
  designs = gemguard_lapidary_designs
  return 'Lapidary designs: none saved.' if box.empty? && designs.empty?
  return "Lapidary designs for #{box}: none saved yet." if designs.empty?

  slot_text = slots.positive? ? "#{slots} slot#{slots == 1 ? '' : 's'}" : "#{designs.length} design#{designs.length == 1 ? '' : 's'}"
  "Lapidary designs for #{box}: #{slot_text} - #{designs.join(', ')}"
rescue
  'Lapidary designs: none saved.'
end

# Reads a saved gemcutter pattern name. The regular-gem pattern falls back to
# the older single pattern setting so pre-existing setup is still shown.
#
# @param key [Symbol, String] Pattern setting key to read.
# @return [String] Saved pattern name or an empty string.
def gemguard_gemcutter_pattern_value(key)
  value = gemguard_setting_value(key)
  return value unless value.empty? && key.to_sym == :gemcutter_regular_pattern

  gemguard_setting_value(:gemcutter_pattern)
rescue
  ''
end

# Builds pattern choices from saved lapidary designs and already-saved pattern
# settings. This keeps dropdowns dynamic while preserving older saved choices.
#
# @param selected [String, nil] Current control value to keep available.
# @return [Array<Hash>] Dropdown choices.
def gemguard_lapidary_pattern_choices(selected = nil)
  values = gemguard_lapidary_designs
  values << selected
  values << gemguard_gemcutter_pattern_value(:gemcutter_regular_pattern)
  values << gemguard_gemcutter_pattern_value(:gemcutter_purified_pattern)
  values << gemguard_gemcutter_pattern_value(:gemcutter_orb_pattern)
  values << gemguard_gemcutter_pattern_value(:gemcutter_chrism_pattern)
  values.map(&:to_s).map(&:strip).reject(&:empty?).uniq { |value| value.downcase }.map { |value| gemguard_container_choice(value, value) }
rescue
  []
end

def gemguard_gemcutter_setup_summary
  cutter = gemguard_setting_value(:gemcutter_device)
  lapidary = gemguard_setting_value(:lapidary_box)
  lapidary_container = gemguard_setting_value(:lapidary_box_container)
  regular_pattern = gemguard_gemcutter_pattern_value(:gemcutter_regular_pattern)
  purified_pattern = gemguard_gemcutter_pattern_value(:gemcutter_purified_pattern)
  orb_pattern = gemguard_gemcutter_pattern_value(:gemcutter_orb_pattern)
  chrism_pattern = gemguard_gemcutter_pattern_value(:gemcutter_chrism_pattern)
  lines = []
  lines << "Gemcutter: #{cutter.empty? ? 'not set' : cutter}"
  lines << 'Patterns:'
  lines << "  regular gems: #{regular_pattern.empty? ? 'not set' : regular_pattern}"
  lines << "  purified non-orbs: #{purified_pattern.empty? ? 'not set' : purified_pattern}"
  lines << "  pure orbs: #{orb_pattern.empty? ? 'not set' : orb_pattern}"
  lines << "  chrisms: #{chrism_pattern.empty? ? 'not set' : chrism_pattern}"
  lines << "Lapidary box: #{lapidary.empty? ? 'not set' : lapidary}"
  lines << "Lapidary box container: #{lapidary_container.empty? ? 'not set' : lapidary_container}"
  lines << gemguard_lapidary_design_summary
  lines << "Debug log: #{gemguard_gemcutter_debug_enabled? ? gemguard_debug_path : 'off'}"
  lines << 'Cut Selected cuts selected Review rows when that gem type has a saved lapidary pattern.'
  lines.join("\n")
rescue
  'Gemcutter setup: not ready.'
end

# Returns the gemcutting type for a Review row.
#
# @param row [Hash] Review row.
# @return [Symbol] :chrism, :orb, :purified, or :regular.
def gemguard_gemcutter_row_kind(row)
  return :chrism if gemguard_review_row_chrism?(row)
  return :orb if gemguard_review_row_orb?(row)
  return :purified if gemguard_review_row_purified_non_orb?(row)

  :regular
rescue
  :regular
end

# Gives a plain name for a gemcutting kind.
#
# @param kind [Symbol] Gemcutting kind.
# @return [String] Plain display name.
def gemguard_gemcutter_kind_label(kind)
  case kind.to_sym
  when :chrism then 'chrism'
  when :orb then 'pure orb'
  when :purified then 'purified non-orb'
  else 'regular'
  end
rescue
  'regular'
end

# Reads the saved pattern for a Review row's gemcutting kind.
#
# @param row [Hash] Review row.
# @return [String] Saved pattern name, or an empty string when that type is disabled.
def gemguard_gemcutter_pattern_for_row(row)
  case gemguard_gemcutter_row_kind(row)
  when :chrism
    gemguard_gemcutter_pattern_value(:gemcutter_chrism_pattern)
  when :orb
    gemguard_gemcutter_pattern_value(:gemcutter_orb_pattern)
  when :purified
    gemguard_gemcutter_pattern_value(:gemcutter_purified_pattern)
  else
    gemguard_gemcutter_pattern_value(:gemcutter_regular_pattern)
  end
rescue
  ''
end

# Finds the 1-based saved lapidary design slot for a pattern name.
#
# @param pattern [String] Pattern name.
# @return [Integer, nil] Design slot number.
def gemguard_lapidary_design_index(pattern)
  wanted = gemguard_lapidary_pattern_key(pattern)
  return nil if wanted.empty?

  index = gemguard_lapidary_designs.find_index { |design| gemguard_lapidary_pattern_key(design) == wanted }
  index ? index + 1 : nil
rescue
  nil
end

# Normalizes lapidary design text from LOOK and TURN so sentence punctuation does
# not make a proven pattern look different.
#
# @param pattern [String] Design text from settings or game output.
# @return [String] Comparable design key.
def gemguard_lapidary_pattern_key(pattern)
  pattern.to_s.strip.downcase.sub(/[[:punct:]\s]+\z/, '')
rescue
  ''
end

# Builds the command target for a held lapidary box.
#
# @param box [Object] Lapidary box object.
# @return [String] "my noun" when possible, otherwise the item id target.
def gemguard_lapidary_box_target(box)
  noun = box.respond_to?(:noun) ? box.noun.to_s.strip : ''
  return "my #{noun}" unless noun.empty?

  "##{box.id}"
rescue
  ''
end

# Finds any inventory or held item by saved name, noun, or item id.
#
# @param setting [String] Item name, noun, or item id.
# @return [Object, nil] Matching GameObj item.
def gemguard_find_inventory_item(setting)
  wanted = gemguard_normalize_container_name(setting)
  return nil if wanted.empty?

  if setting.to_s.strip =~ /\A#?(\d+)\z/
    id = Regexp.last_match(1)
    direct = GameObj[id] rescue nil
    return direct if direct
  end

  candidates = [gemguard_hand_item(:right), gemguard_hand_item(:left)].compact
  candidates.concat(chrism_sell_inventory_objects)
  candidates.compact.uniq { |item| item.id.to_s }.find do |item|
    labels = [
      item.name.to_s,
      item.noun.to_s,
      item.respond_to?(:long_name) ? item.long_name.to_s : '',
      item.respond_to?(:after_name) ? "#{item.name} #{item.after_name}" : ''
    ].map { |label| gemguard_normalize_container_name(label) }.reject(&:empty?)
    labels.any? { |label| label == wanted || label.include?(wanted) || wanted.include?(label) }
  end
rescue
  nil
end

# Returns the real item in a hand using GameObj. Empty hand placeholders are
# treated as nil so GemGuard does not send pointless STOW commands.
#
# @param hand [Symbol, String] :right or :left.
# @return [Object, nil] Held item, or nil when the hand is empty.
def gemguard_hand_item(hand)
  item = hand.to_sym == :left ? GameObj.left_hand : GameObj.right_hand
  return nil unless item

  id = item.id.to_s
  name = item.name.to_s.strip
  noun = item.respond_to?(:noun) ? item.noun.to_s.strip : ''
  return nil if id.empty? || id == '0' || id == '-1'
  return nil if name.empty? || name == 'Empty'
  return nil if noun.empty? && name.casecmp('empty').zero?

  item
rescue
  nil
end

def gemguard_item_in_hand?(item, hand = nil)
  return false unless item
  hands = hand ? [gemguard_hand_item(hand)] : [gemguard_hand_item(:right), gemguard_hand_item(:left)]
  hands.compact.any? { |held| held.id.to_s == item.id.to_s }
rescue
  false
end

# Moves an item to a chosen hand without clearing the other hand.
# This sends STOW and _drag commands.
#
# @param item [Object] GameObj item.
# @param hand [Symbol] :right or :left.
# @return [Boolean] true when the item is in that hand.
def gemguard_drag_item_to_hand(item, hand = :right)
  return false unless item
  return true if gemguard_item_in_hand?(item, hand)

  hand = hand.to_sym == :left ? :left : :right
  held = gemguard_hand_item(hand)
  gemguard_dothistimeout("stow #{hand}", 3, /You put|You stow|You return|Stow what|You need|closed|can't/i, false) if held && held.id.to_s != item.id.to_s
  gemguard_dothistimeout(
    "_drag ##{item.id} #{hand}",
    5,
    /You remove|You take|You get|already holding|Get what|could not find|unable to handle/i,
    false
  )
  20.times do
    break if gemguard_item_in_hand?(item, hand)
    sleep 0.1
  end
  gemguard_item_in_hand?(item, hand)
rescue
  false
end

# Moves an item to a chosen hand using the command result as proof. This is used
# for cutting, where stale GameObj hand data can otherwise make GemGuard stop
# after setting the lapidary pattern.
#
# @param item [Object] GameObj item.
# @param hand [Symbol] :right or :left.
# @return [Boolean] true when the command or GameObj says the item is held.
def gemguard_force_drag_item_to_hand(item, hand = :right)
  return false unless item

  hand = hand.to_sym == :left ? :left : :right
  held = gemguard_hand_item(hand)
  gemguard_dothistimeout("stow #{hand}", 3, /You put|You stow|You return|Stow what|You need|closed|can't/i, false) if held && held.id.to_s != item.id.to_s
  result = gemguard_dothistimeout(
    "_drag ##{item.id} #{hand}",
    6,
    /You remove|You take|You get|You grab|already holding|Get what|could not find|unable to handle|But you're already holding/i,
    false
  ).to_s
  gemguard_gemcutter_debug "drag item=#{item.id} name=#{item.name} hand=#{hand} result=#{result.strip.gsub(/\s+/, ' ')}"
  return true if result =~ /You remove|You take|You get|You grab|already holding|already holding/i

  20.times do
    return true if gemguard_item_in_hand?(item, hand)
    sleep 0.1
  end
  gemguard_item_in_hand?(item, hand)
rescue
  false
end

# Opens one container and looks inside so GameObj contents are current.
# This sends OPEN and LOOK commands.
#
# @param container [Object] Container to open and inspect.
# @param quiet [Boolean] Hide command output when true.
# @return [Boolean] true when GemGuard opened a container it should close later.
def gemguard_open_container_for_contents(container, quiet = true)
  return false unless container && !container.id.to_s.empty?

  open_result = gemguard_dothistimeout(
    "open ##{container.id}",
    3,
    /open|opening|already open|doesn't seem|could not find|locked|closed|shut/i,
    quiet
  ).to_s
  opened = !(open_result =~ /already open|doesn't seem|could not find|locked/i)
  gemguard_dothistimeout(
    "look in ##{container.id}",
    3,
    GEMGUARD_LOOK_IN_DONE_RE,
    quiet
  )
  opened
rescue
  false
end

# Opens saved container names and looks inside them. This sends OPEN and LOOK
# commands for each found container.
#
# @param settings [Array<String>] Saved container names or ids.
# @param quiet [Boolean] Hide command output when true.
# @return [Array<Object>] Containers GemGuard opened and should close later.
def gemguard_open_saved_containers(settings, quiet = true)
  Array(settings).map(&:to_s).map(&:strip).reject(&:empty?)
                 .reject { |value| value =~ /\A\(.+\)\z/ }
                 .filter_map { |value| gemguard_find_container(value) }
                 .uniq { |container| container.id.to_s }
                 .select { |container| gemguard_open_container_for_contents(container, quiet) }
rescue
  []
end

# Gets the saved lapidary box into the right hand so its design can be set.
# This may open the saved box container, then send GET and _drag commands.
#
# @param setting [String] Saved lapidary box name or id.
# @param opened_containers [Array<Object>, nil] Containers to close later.
# @return [Object, nil] Held lapidary box.
def gemguard_get_lapidary_box(setting, opened_containers = nil)
  setting = setting.to_s.strip
  return nil if setting.empty?

  box_container = gemguard_find_container(gemguard_setting_value(:lapidary_box_container))
  if box_container
    opened_containers << box_container if opened_containers && gemguard_open_container_for_contents(box_container, false)
  end

  box = gemguard_find_inventory_item(setting)
  return box if box && gemguard_item_in_hand?(box, :right)

  gemguard_dothistimeout('stow right', 3, /You put|You stow|You return|Stow what|You need|closed|can't/i, false) if gemguard_hand_item(:right)
  box ||= gemguard_find_inventory_item(setting)
  if box
    return box if gemguard_drag_item_to_hand(box, :right)
  else
    gemguard_dothistimeout("get my #{setting}", 5, /You remove|You take|You get|already holding|Get what|could not find|What were|You need/i, false)
  end

  box = gemguard_find_inventory_item(setting)
  return box if box && gemguard_drag_item_to_hand(box, :right)

  held = gemguard_hand_item(:right)
  return held if held && gemguard_normalize_container_name(held.name).include?(gemguard_normalize_container_name(setting))

  nil
rescue
  nil
end

# Selects a lapidary box design by turning until the visible panel matches.
# This sends LOOK and TURN commands to the game.
#
# @param box [Object] Lapidary box object.
# @param pattern [String] Saved pattern name.
# @return [Array(Boolean, String)] success flag and status text.
def gemguard_lapidary_select_pattern(box, pattern)
  return [false, 'Lapidary box was not found.'] unless box

  pattern = pattern.to_s.strip
  index = gemguard_lapidary_design_index(pattern)
  return [false, "Pattern #{pattern} is not in the saved lapidary designs."] unless index
  return [false, 'Could not hold the lapidary box.'] unless gemguard_drag_item_to_hand(box, :right)

  current, look = gemguard_lapidary_visible_pattern(box)
  gemguard_gemcutter_debug "pattern check wanted=#{pattern} visible=#{current.empty? ? 'unknown' : current}"
  return [true, "Set lapidary pattern to #{pattern}."] if gemguard_lapidary_pattern_key(current) == gemguard_lapidary_pattern_key(pattern)

  gemguard_lapidary_turn_to_pattern(box, pattern)
rescue => error
  [false, "Could not set #{pattern}: #{error.message}"]
end

# Reads the visible lapidary box design from LOOK. This sends LOOK to the game.
#
# @param box [Object] Lapidary box object.
# @return [Array<String, String>] Current pattern text and raw LOOK output.
def gemguard_lapidary_visible_pattern(box)
  target = gemguard_lapidary_box_target(box)
  text = gemguard_dothistimeout(
    "look #{target}",
    5,
    /reveal(?:s)?(?: the words)?,?\s+"[^"]+"|What were|could not|You do not|doesn't seem/i,
    false
  ).to_s
  pattern = text[/reveal(?:s)?(?: the words)?,?\s+"([^"]+)"/i, 1].to_s.strip
  [pattern, text]
rescue => error
  ['', error.message]
end

# Turns a lapidary box until its visible design matches the requested design.
# This sends TURN commands, and uses one final LOOK if the TURN output does not
# prove the desired pattern.
#
# @param box [Object] Lapidary box object.
# @param pattern [String] Desired lapidary design.
# @return [Array<Boolean, String>] success flag and status text.
def gemguard_lapidary_turn_to_pattern(box, pattern)
  target = gemguard_lapidary_box_target(box)
  limit = [gemguard_lapidary_designs.length, gemguard_setting_value(:lapidary_design_slots).to_i, 1].max
  limit.times do
    turn = gemguard_dothistimeout(
      "turn #{target}",
      5,
      /set to|click|turn|What were|could not|You do not|doesn't seem/i,
      false
    ).to_s
    current = turn[/currently set to:\s+"([^"]+)"/i, 1].to_s.strip
    gemguard_gemcutter_debug "turn wanted=#{pattern} current=#{current.empty? ? 'unknown' : current}"
    next unless gemguard_lapidary_pattern_key(current) == gemguard_lapidary_pattern_key(pattern)

    confirmed, look = gemguard_lapidary_visible_pattern(box)
    gemguard_gemcutter_debug "turn confirm wanted=#{pattern} visible=#{confirmed.empty? ? 'unknown' : confirmed}"
    return [true, "Set lapidary pattern to #{pattern}."] if gemguard_lapidary_pattern_key(confirmed) == gemguard_lapidary_pattern_key(pattern)

    detail = confirmed.empty? ? look.strip : confirmed
    return [false, "Could not confirm #{pattern}; box shows #{detail.empty? ? 'unknown' : detail}."]
  end

  current, look = gemguard_lapidary_visible_pattern(box)
  detail = current.empty? ? look.strip : current
  [false, "Could not confirm #{pattern}; box shows #{detail.empty? ? 'unknown' : detail}."]
rescue => error
  [false, "Could not set #{pattern}: #{error.message}"]
end

# Checks whether a failed cut row failed before any gem was loaded into the
# cutter. This lets GemGuard stop a bad setup once instead of repeating the
# same failed WHISPER command for every selected gem.
#
# @param row [Hash] Review row with a failure reason.
# @return [Boolean] true when the cutter setup failed.
def gemguard_lapidary_setup_failure?(row)
  row[:reason].to_s =~ /Could not set|Could not confirm|Lapidary box|WHISPER DESIGN|Could not hold/i
rescue
  false
end

# Cuts one selected Review row with a lapidary box. This sends OPEN, item move,
# CLOSE, PUSH, and return-to-container commands.
#
# @param row [Hash] Review row to cut.
# @param box [Object] Lapidary box object.
# @param pattern [String] Saved lapidary pattern.
# @return [Symbol] :cut, :missing, :skipped, or :failed.
def gemguard_lapidary_cut_one(row, box, pattern)
  item = chrism_sell_item_by_id(row[:id])
  return :missing unless item

  gemguard_gemcutter_debug "cut start row=#{row[:id]} name=#{row[:name]} pattern=#{pattern} box=#{box && box.id}"
  selected, message = gemguard_lapidary_select_pattern(box, pattern)
  unless selected
    row[:reason] = message
    return :failed
  end
  unless gemguard_item_in_hand?(box, :right) || gemguard_force_drag_item_to_hand(box, :right)
    row[:reason] = 'could not hold lapidary box'
    gemguard_gemcutter_debug "cut failed row=#{row[:id]} reason=#{row[:reason]}"
    return :failed
  end
  unless gemguard_force_drag_item_to_hand(item, :left)
    row[:reason] = 'could not hold gem for cutting'
    gemguard_gemcutter_debug "cut failed row=#{row[:id]} reason=#{row[:reason]}"
    return :failed
  end

  target = "##{box.id}"
  gemguard_dothistimeout("open #{target}", 4, /open|already open|revealing|could not|locked|closed|shut/i, false)
  put = gemguard_dothistimeout(
    "_drag ##{item.id} #{target}",
    6,
    /You pop|You put|carefully place|comes to rest|will only hold|closed|full|could not|unable|won't fit/i,
    false
  ).to_s
  unless put =~ /You pop|You put|carefully place|comes to rest/i
    gemguard_return_item_after_mark(row, item, false)
    row[:reason] = 'cut failed'
    gemguard_gemcutter_debug "cut failed row=#{row[:id]} load_result=#{put.strip.gsub(/\s+/, ' ')}"
    return :failed
  end

  gemguard_dothistimeout("close #{target}", 4, /close|fasten|snapping|already closed|could not|What were/i, false)
  push = gemguard_dothistimeout(
    "push #{target}",
    35,
    /tumbling out|directly into your palm|perfectly cut|Roundtime|empty|no gem|could not|What were|must be holding/i,
    false
  ).to_s
  gemguard_gemcutter_debug "push row=#{row[:id]} result=#{push.strip.gsub(/\s+/, ' ')}"
  gemguard_wait_physical_rt(push)
  sleep 0.2

  current = chrism_sell_item_by_id(row[:id])
  current = gemguard_hand_item(:right) if (!current || !chrism_sell_hand_id?(current.id)) && gemguard_hand_item(:right)
  current = gemguard_hand_item(:left) if (!current || !chrism_sell_hand_id?(current.id)) && gemguard_hand_item(:left)
  if current
    row[:name] = current.name.to_s unless current.name.to_s.empty?
    row[:noun] = current.noun.to_s unless current.noun.to_s.empty?
    row[:reason] = gemguard_review_row_default_status(row)
    gemguard_return_item_after_mark(row, current, false)
    gemguard_update_inventory_rows([row])
    return :cut
  end

  row[:reason] = 'cut failed'
  :failed
rescue => error
  row[:reason] = "cut failed: #{error.message}"
  begin
    gemguard_return_item_after_mark(row, item, false) if item
  rescue
    nil
  end
  :failed
end

# Cuts selected Review rows that have a saved pattern for their gem type.
# This changes gems, sends game commands, and updates GemGuard cached rows.
#
# @param rows [Array<Hash>] Selected Review rows.
# @yield [done, total, row, counts] Reports progress.
# @return [Hash] Counts for :cut, :skipped, :missing, and :failed.
def gemguard_lapidary_cut_rows(rows)
  box_name = gemguard_setting_value(:lapidary_box)
  return { error: 'Choose and analyze a lapidary box first.' } if box_name.empty?

  selected = Array(rows).compact
  counts = { cut: 0, skipped: 0, missing: 0, failed: 0 }
  opened_containers = []
  begin
    box = gemguard_get_lapidary_box(box_name, opened_containers)
    return { error: "Could not get lapidary box #{box_name}." } unless box

    opened_containers.concat(gemguard_open_saved_containers(selected.map { |row| row[:container] }, false))

    selected.each_with_index do |row, index|
      break if gemguard_stop_requested?(true)

      pattern = gemguard_gemcutter_pattern_for_row(row)
      if pattern.empty?
        row[:reason] = "no #{gemguard_gemcutter_kind_label(gemguard_gemcutter_row_kind(row))} pattern"
        counts[:skipped] += 1
      else
        result = gemguard_lapidary_cut_one(row, box, pattern)
        counts[result] = counts[result].to_i + 1
        break if result == :failed && gemguard_lapidary_setup_failure?(row)
      end
      yield(index + 1, selected.length, row, counts) if block_given?
    end
  ensure
    chrism_sell_clear_hands(false)
    chrism_sell_close_inventory_containers(opened_containers, false)
  end
  counts
end

def gemguard_lapidary_command_target(setting)
  setting = setting.to_s.strip
  container = gemguard_find_container(setting)
  return "##{container.id}" if container && !container.id.to_s.empty?
  return "##{Regexp.last_match(1)}" if setting =~ /\A#?(\d+)\z/

  setting
rescue
  setting.to_s.strip
end

# Sends a visible command and captures downstream lines while letting the game
# output continue to the player. This avoids slow manual get loops for long
# command output such as ANALYZE text.
#
# @param command [String] Command to send.
# @param timeout [Numeric] Seconds to wait for the ending pattern.
# @param end_pattern [Regexp] Pattern that marks command completion.
# @return [Array<String>] Captured downstream lines.
def gemguard_capture_visible_command(command, timeout, end_pattern)
  lines = []
  hook_name = nil
  if defined?(DownstreamHook)
    hook_name = "#{gemguard_current_script_name}_gemguard_capture_#{Time.now.to_f}_#{rand(1000)}"
    DownstreamHook.add(hook_name, proc do |xml|
      lines << xml.to_s.rstrip
      xml
    end)
  end
  result = dothistimeout(command, timeout, end_pattern).to_s
  lines << result.rstrip if lines.empty? && !result.empty?
  lines.reject(&:empty?)
ensure
  begin
    DownstreamHook.remove(hook_name) if hook_name && defined?(DownstreamHook)
  rescue
    nil
  end
end

# Analyzes a lapidary box and returns its saved design information. This sends
# ANALYZE visibly so the player can see the same result GemGuard is reading.
#
# @param setting [String] Box name, noun, or item ID.
# @return [Hash] Parsed analyze result with :ok, :designs, :slots, and :error.
def gemguard_analyze_lapidary_box(setting)
  setting = setting.to_s.strip
  return { ok: false, error: 'Type a lapidary box name first.' } if setting.empty?

  target = gemguard_lapidary_command_target(setting)
  lines = gemguard_capture_visible_command(
    "analyze #{target}",
    5,
    /Try as you might|as light as it can get|could get any deeper|What were you referring to|I could not find|You do not|You can't|must be holding/i
  )
  text = lines.join("\n")
  return { ok: false, error: 'That did not look like a lapidary box.', output: text } unless text =~ /lapidary box|Current Designs:|currently has\s+\d+\s+unlocked design slots|WHISPER DESIGN/i

  slots = text[/currently has\s+(\d+)\s+unlocked design slots/i, 1].to_i
  designs = lines.filter_map do |line|
    match = gemguard_strip_xml(line).strip.match(/\A\d+\.\s+(.+?)\s*\z/)
    match ? match[1].to_s.strip : nil
  end
  {
    ok: true,
    box: setting,
    target: target,
    slots: slots,
    designs: designs,
    whisper_design: !!(text =~ /WHISPER DESIGN/i),
    output: text
  }
rescue Timeout::Error
  { ok: false, error: 'Analyze timed out before GemGuard saw the full design list.', output: lines.join("\n") }
rescue => error
  { ok: false, error: "Analyze failed: #{error.class}: #{error.message}", output: lines.join("\n") }
end

# Saves lapidary box design data from ANALYZE. This changes GemGuard settings.
#
# @param box [String] Box name, noun, or item ID.
# @param result [Hash] Parsed result from gemguard_analyze_lapidary_box.
# @return [Boolean] false when saving fails.
def gemguard_save_lapidary_settings(box, result)
  settings = gemguard_load_settings
  settings[:lapidary_box] = box.to_s.strip
  settings[:lapidary_design_slots] = result[:slots].to_i.to_s
  settings[:lapidary_designs] = Array(result[:designs]).map(&:to_s).map(&:strip).reject(&:empty?)
  settings[:lapidary_supports_whisper_design] = result[:whisper_design] ? 'true' : 'false'
  gemguard_save_settings(settings)
end

def gemguard_strip_xml(text)
  text.to_s.gsub(/<[^>]+>/, '').gsub(/\s+/, ' ').strip
end

# Sends a game command while hiding most output from the game window.
#
# @param command [String] Command to send to the game.
# @param start_pattern [Regexp] Pattern that marks useful output.
# @param end_pattern [Regexp] Pattern that marks command completion.
# @param timeout [Integer] Seconds to wait.
# @return [String] Captured command output.
def gemguard_quiet_command(command, start_pattern, end_pattern = /<prompt/i, timeout = 5)
  return [] unless defined?(DownstreamHook)

  result = []
  hook_name = "#{gemguard_current_script_name}_gemguard_quiet_#{Time.now.to_f}_#{rand(1000)}"
  filtering = false
  begin
    Timeout.timeout(timeout) do
      DownstreamHook.add(hook_name, proc do |xml|
        if filtering
          if xml =~ end_pattern
            DownstreamHook.remove(hook_name)
            filtering = false
          end
          nil
        elsif xml =~ start_pattern
          filtering = true
          nil
        else
          xml
        end
      end)
      fput command
      until (line = get) =~ start_pattern; end
      result << line.rstrip
      until (line = get) =~ end_pattern
        result << line.rstrip
      end
      result << line.rstrip
    end
  rescue Timeout::Error
    nil
  ensure
    DownstreamHook.remove(hook_name) rescue nil
  end
  result
rescue
  []
end

def gemguard_inventory_full_lines
  start_pattern = /^(?:You are carrying nothing at this time|You are currently (?:wearing|holding))/i
  end_pattern = /(?:<prompt)|(?:.*items? displayed\.\)$)|(?:^\(Items:\s*\d+\))/i

  if defined?(Lich::Util) && Lich::Util.respond_to?(:quiet_command_xml)
    begin
      lines = Lich::Util.quiet_command_xml('inventory full', start_pattern, end_pattern, true, 6, true)
      return Array(lines) if lines && !Array(lines).empty?
    rescue ArgumentError
      begin
        lines = Lich::Util.quiet_command_xml('inventory full', start_pattern, end_pattern)
        return Array(lines) if lines && !Array(lines).empty?
      rescue
        nil
      end
    rescue
      nil
    end
  end

  gemguard_quiet_command('inventory full', start_pattern, end_pattern, 6)
end

def gemguard_quiet_inventory_full_objects
  gemguard_load_inventory_statuses!
  @inventory_statuses = @inventory_statuses.is_a?(Hash) ? @inventory_statuses : {}
  @inventory_marked_name_counts = {}
  lines = gemguard_inventory_full_lines

  Array(lines).filter_map do |line|
    match = GEMGUARD_INVFULL_RE.match(line)
    if match
      id = match[:exist].to_s
      noun = match[:noun].to_s
      name = match[:name].to_s
      pre_name = match[:pre].to_s
      post_name = match[:post].to_s
      attrs = match[:attrs].to_s
      @inventory_statuses[id] = {
        raw: attrs,
        marked: !!(attrs =~ /marked/i),
        registered: !!(attrs =~ /registered/i),
        hidden: !!(attrs =~ /hidden/i)
      }

      GameObj.new(id.dup, noun.dup, name.dup, pre_name.dup, post_name.dup)
    elsif (plain = GEMGUARD_INVFULL_NOXML_RE.match(line))
      attrs = plain[:attrs].to_s
      if attrs =~ /marked/i
        key = gemguard_normalize_container_name(plain[:name].to_s)
        @inventory_marked_name_counts[key] ||= 0
        @inventory_marked_name_counts[key] += 1
      end
      nil
    end
  rescue
    nil
  end
end

def gemguard_apply_plain_marked_status(objects)
  counts = @inventory_marked_name_counts
  return objects unless counts.is_a?(Hash) && counts.any?

  used = Hash.new(0)
  Array(objects).each do |item|
    id = item.id.to_s
    next if id.empty?
    existing = @inventory_statuses.is_a?(Hash) ? @inventory_statuses[id] : nil
    next if existing.is_a?(Hash) && existing[:marked]

    key = gemguard_normalize_container_name(item.name)
    next unless counts[key].to_i > used[key]

    @inventory_statuses[id] = {
      raw: '(marked)',
      marked: true,
      registered: false,
      hidden: false
    }
    used[key] += 1
  end
  objects
end

def gemguard_item_marked?(item)
  status = @inventory_statuses.is_a?(Hash) ? @inventory_statuses[item.id.to_s] : nil
  return status[:marked] if status.is_a?(Hash) && status.key?(:marked)
  return true if status.to_s =~ /\bmarked\b/i
  return !!item.marked? if item.respond_to?(:marked?)
  return !!item.marked if item.respond_to?(:marked)

  false
rescue
  false
end

def gemguard_item_chrism?(item)
  id = item.id.to_s
  status = @chrism_statuses.is_a?(Hash) ? @chrism_statuses[id] : nil
  return true if status.is_a?(Hash) && status[:chrism]
  return true if status == true
  return true if item.name.to_s =~ /\bchrism\b|\bcobalt liquid\b/i
  return true if item.noun.to_s =~ /\bchrism\b/i

  false
rescue
  false
end

# Reads chrism quality from LOOK output.
#
# @param text [String] Game output from looking at a gem.
# @return [Hash, nil] Strength and fullness details, or nil when none were seen.
def gemguard_chrism_quality_from_look(text)
  source = text.to_s
  strength = source[/\b(dull|ordinary|bright|vibrant|glowing),?\s+cobalt liquid/i, 1].to_s.downcase
  fullness_text = source[/outer shell of the (.*?) allows you to see/i, 1].to_s.downcase
  fullness = fullness_text[/\b(half full|more than half full|three quarters full|almost full|full)\b/i, 1].to_s.downcase
  return nil if strength.empty? && fullness.empty?

  {
    strength: strength.empty? ? nil : strength,
    fullness: fullness.empty? ? nil : fullness
  }
end

# Records that a gem has been proven to be a finished chrism. This updates
# in-memory state and the saved gem database so later scans keep it protected.
#
# @param item [Object] GameObj gem.
# @param output [String] LOOK or loresing output that proved the chrism.
# @return [void]
def gemguard_record_chrism_result(item, output = '')
  id = item.id.to_s
  return if id.empty?

  quality = gemguard_chrism_quality_from_look(output)
  @chrism_statuses = {} unless @chrism_statuses.is_a?(Hash)
  @chrism_statuses[id] = {
    chrism: true,
    tested_at: Time.now.strftime('%m/%d/%Y %H:%M:%S %z'),
    output: output.to_s[0, 500],
    strength: quality && quality[:strength].to_s,
    fullness: quality && quality[:fullness].to_s
  }
  attrs = {
    'id' => id,
    'name' => item.name.to_s,
    'noun' => item.noun.to_s,
    'chrism' => true,
    'status' => 'chrism',
    'chrism_output' => output.to_s[0, 500]
  }
  if quality
    attrs['chrism_strength'] = quality[:strength].to_s unless quality[:strength].to_s.empty?
    attrs['chrism_fullness'] = quality[:fullness].to_s unless quality[:fullness].to_s.empty?
  end
  gemguard_update_inventory_item(id, attrs)
end

# Looks at an item for finished-chrism wording and saves the result when found.
# This sends LOOK to the game and may update the saved gem database.
#
# @param item [Object] GameObj item to inspect.
# @param row [Hash, nil] Review row to update when a chrism is found.
# @param quiet [Boolean] Hide command output when true.
# @return [Boolean] true when the item was proven to be a chrism.
def gemguard_detect_chrism_by_look!(item, row = nil, quiet = false)
  output = gemguard_dothistimeout("look ##{item.id}", 3, GEMGUARD_CHRISM_LOOK_RE, quiet).to_s
  return false unless output =~ /cobalt liquid/i

  quality = gemguard_chrism_quality_from_look(output)
  gemguard_record_chrism_result(item, output)
  if row
    row[:chrism] = true
    row[:action] = :keep
    row[:reason] = 'chrism'
    row[:chrism_output] = output.to_s[0, 500]
    if quality
      row[:chrism_strength] = quality[:strength] unless quality[:strength].to_s.empty?
      row[:chrism_fullness] = quality[:fullness] unless quality[:fullness].to_s.empty?
    end
    row[:value] = '' if row[:value].to_s =~ /\A(?:n\/a|not gemshop)\z/i
  end
  true
rescue
  false
end

# Finds the saved chrism container.
#
# @return [Object, nil] Container object, or nil when unset or not found.
def gemguard_chrism_container
  gemguard_find_container(gemguard_setting_value(:chrism_container))
rescue
  nil
end

def gemguard_item_pure_orb?(item)
  id = item.id.to_s
  status = @orb_statuses.is_a?(Hash) ? @orb_statuses[id] : nil
  return true if status.is_a?(Hash) && status[:pure]
  return true if status == true

  false
rescue
  false
end

def gemguard_item_purify_status(item)
  id = item.id.to_s
  status = @purify_statuses.is_a?(Hash) ? @purify_statuses[id] : nil
  return status[:status].to_s if status.is_a?(Hash) && status[:status]
  return status.to_s if status

  ''
rescue
  ''
end

def gemguard_profession
  return Char.prof.to_s if defined?(Char) && Char.respond_to?(:prof)

  ''
rescue
  ''
end

# Reads the current character name for labels and window titles.
#
# @return [String] Character name, or an empty string when unavailable.
def gemguard_character_name
  return Char.name.to_s.strip if defined?(Char) && Char.respond_to?(:name)

  ''
rescue
  ''
end

# Builds a GTK window title that includes the character name when available.
#
# @param base [String] Base window title.
# @return [String] Window title with the character name appended.
def gemguard_window_title(base)
  character = gemguard_character_name
  character.empty? ? base.to_s : "#{base} - #{character}"
rescue
  base.to_s
end

def gemguard_bard?
  gemguard_profession =~ /\Abard\z/i
end

def gemguard_sorcerer?
  gemguard_profession =~ /\Asorcerer\z/i
end

def gemguard_orb_test_mode
  return :loresing if gemguard_bard?
  return :phase if gemguard_sorcerer?

  :disabled
end

def gemguard_orb_test_label
  case gemguard_orb_test_mode
  when :loresing
    'Loresing Orb Test'
  when :phase
    'Phase Orb Test'
  else
    'Orb Test'
  end
end

def gemguard_orb_test_tooltip
  case gemguard_orb_test_mode
  when :loresing
    'Loresing selected gems for pure-orb messaging. Gems that prove pure will move to keep as pure orb.'
  when :phase
    'Cast Phase at selected gems. Gems that become shifting or insubstantial will move to keep as pure orb.'
  else
    'Only bards and sorcerers can prove orb gems here.'
  end
end

def gemguard_quiet_inv_container_lines
  return [] unless defined?(Lich::Util) && Lich::Util.respond_to?(:quiet_command_xml)

  Array(Lich::Util.quiet_command_xml(
    'inventory container',
    /You are (?:holding|wearing)/i,
    /<prompt|R>/i,
    true,
    6,
    true
  ))
rescue
  []
end

def gemguard_container_command_output
  return '' unless defined?(Lich::Util) && Lich::Util.respond_to?(:quiet_command_xml)

  Array(Lich::Util.quiet_command_xml(
    'inventory container',
    /You are (?:holding|wearing)/i,
    /<prompt|R>/i,
    true,
    6,
    true
  )).join("\n")
rescue
  ''
end

def gemguard_visible_container_command_output
  dothistimeout(
    'inv containers',
    6,
    /You are wearing|You are holding|containers at this time|R>/i
  ).to_s
rescue
  ''
end

def gemguard_parse_container_xml_choices(text)
  choices = []
  # Match any <a ...>name</a> link and pull exist=/noun= from its attributes
  # regardless of attribute order, so container links still parse when the
  # game emits attributes in a different order than exist-then-noun.
  text.to_s.scan(%r{<a\b([^>]*)>(.*?)</a>}i).each do |attrs, name|
    next unless attrs =~ /\bexist=(?:'|")([^'"]+)(?:'|")/i

    id = Regexp.last_match(1)
    next unless attrs =~ /\bnoun=(?:'|")[^'"]+(?:'|")/i

    obj = GameObj.inv.find { |item| item.id.to_s == id.to_s } rescue nil
    fallback = gemguard_strip_xml(name)
    display = obj ? gemguard_container_display_label(obj, fallback) : fallback
    value = obj ? gemguard_container_label(obj) : fallback
    next unless gemguard_inventory_container_clause?(display)

    choices << gemguard_container_choice(display, value)
  end
  gemguard_unique_container_choices(choices)
end

def gemguard_parse_container_name_choices(text)
  choices = []
  gemguard_strip_xml(text).scan(/You are (?:holding|wearing|carrying) (.*?)(?:\.|$)/i).each do |match|
    list = match.first.to_s.strip
    next if list =~ /\bno containers\b/i

    list.gsub(/\s+and\s+/, ', ').split(/\s*,\s*/).each do |container|
      container = container.strip
      next unless gemguard_inventory_container_clause?(container)

      choices << gemguard_container_choice(container, container)
    end
  end
  gemguard_unique_container_choices(choices)
end

# Reads inventory containers for the Settings tab. This sends INV CONTAINER.
#
# @return [Array<Hash>] Container choices for dropdowns and checkboxes.
def gemguard_scan_container_choices
  output = gemguard_container_command_output
  choices = gemguard_parse_container_xml_choices(output)
  choices = gemguard_parse_container_name_choices(gemguard_visible_container_command_output) if choices.empty?
  gemguard_unique_container_choices(choices)
rescue
  []
end

def gemguard_parse_inv_container_xml_objects(lines)
  ids = []
  Array(lines).join("\n").scan(GEMGUARD_EXIST_RE) do
    ids << Regexp.last_match(:id).to_s
  end

  ids.uniq.filter_map { |id| GameObj.inv.find { |item| item.id.to_s == id } }
end

def gemguard_parse_inv_container_names(lines)
  Array(lines).flat_map do |line|
    text = gemguard_strip_xml(line).strip
    next [] unless text =~ /\AYou are (?:holding|wearing|carrying) /
    next [] if text =~ /\bno containers\b/i

    body = text.sub(/\AYou are (?:holding|wearing|carrying) /, '').sub(/\s+at this time\.\z/i, '').sub(/\.\z/, '')
    pieces = if body.include?(',')
               body.split(/\s*,\s*/)
             else
               body.split(/\s+and\s+(?=a |an |the |some )/i)
             end
    pieces.map { |piece| piece.sub(/\Aand\s+/i, '').strip }.reject(&:empty?)
  end
end

def gemguard_inv_container_objects
  quiet_lines = gemguard_quiet_inv_container_lines
  xml_objects = gemguard_parse_inv_container_xml_objects(quiet_lines)
  return xml_objects unless xml_objects.empty?

  names = gemguard_parse_inv_container_names(quiet_lines)
  return [] if names.empty?

  containers = chrism_sell_inventory_containers
  names.filter_map do |name|
    wanted = gemguard_normalize_container_name(name)
    containers.find do |container|
      actual = gemguard_normalize_container_name(container.name)
      wanted.include?(actual) || actual.include?(wanted)
    end
  end.uniq { |container| container.id.to_s }
end

def gemguard_stowlist_containers
  return [] unless defined?(StowList)

  StowList.check(silent: true, quiet: true) if StowList.respond_to?(:check) && (!StowList.respond_to?(:checked?) || !StowList.checked?)
  stow_list = StowList.respond_to?(:stow_list) ? StowList.stow_list : {}
  containers = []
  containers << stow_list[:gem]
  containers << StowList.default if StowList.respond_to?(:default)
  stow_list.keys.select { |key| key.to_s.start_with?('overflow_container') }.sort_by(&:to_s).each do |key|
    containers << stow_list[key]
  end

  containers.compact.uniq { |container| container.id.to_s }.select { |container| container.respond_to?(:contents) }
rescue
  []
end

def gemguard_likely_gem_container?(obj)
  noun = obj.noun.to_s.downcase
  name = obj.name.to_s.downcase
  return true if GEMGUARD_CONTAINER_NOUNS.include?(noun)
  return true if name =~ /\bgem\b/ && name =~ /\b(pouch|sack|bag|case|box|container)\b/

  false
end

def gemguard_scan_containers
  ignored = gemguard_setting_array(:ignore_containers)
  filter_ignored = proc do |list|
    Array(list).compact.reject do |container|
      label = gemguard_container_label(container)
      ignored.any? { |name| gemguard_find_container(name)&.id.to_s == container.id.to_s || label.casecmp(name).zero? }
    end
  end

  configured = gemguard_setting_array(:scan_containers).filter_map { |name| gemguard_find_container(name) }
  configured = filter_ignored.call(configured).uniq { |container| container.id.to_s }
  return [configured, 'GemGuard settings'] unless configured.empty?

  containers = filter_ignored.call(gemguard_stowlist_containers)
  return [containers, 'StowList'] unless containers.empty?

  containers = filter_ignored.call(gemguard_inv_container_objects)
  return [containers, 'INV CONTAINER fallback'] unless containers.empty?

  [filter_ignored.call(chrism_sell_inventory_containers.select { |container| gemguard_likely_gem_container?(container) }), 'local fallback']
end

def gemguard_container_open?(container)
  keys = GameObj.containers.keys
  (keys.include?(container.id) || keys.include?(container.id.to_s)) && container.contents.is_a?(Array)
rescue
  false
end

# Opens configured gem containers so GemGuard can read their contents. This sends
# game commands and returns only containers it opened itself.
#
# @param quiet [Boolean] Hide command output when true.
# @return [Array<Object>] Containers GemGuard should close later.
def chrism_sell_open_inventory_containers(quiet = true)
  containers, source = gemguard_scan_containers
  return [] if containers.empty?

  gemguard_gtk_debug "opening #{containers.length} containers from #{source} before scanning gems."
  opened = []
  containers.each do |container|
    break if gemguard_stop_requested?(true)

    open_result = gemguard_dothistimeout(
      "open ##{container.id}",
      3,
      /open|opening|already open|doesn't seem|could not find|locked|closed|shut/i,
      quiet
    ).to_s
    opened << container unless open_result =~ /already open|doesn't seem|could not find|locked/i
    gemguard_dothistimeout(
      "look in ##{container.id}",
      3,
      GEMGUARD_LOOK_IN_DONE_RE,
      quiet
    )
  end

  opened
end

# Closes containers that GemGuard opened earlier. This sends game commands.
#
# @param containers [Array<Object>] Containers returned by open helper.
# @param quiet [Boolean] Hide command output when true.
# @return [void]
def chrism_sell_close_inventory_containers(containers, quiet = true)
  Array(containers).compact.uniq { |container| container.id.to_s }.each do |container|
    next if container.id.to_s.empty?

    gemguard_dothistimeout(
      "close ##{container.id}",
      3,
      /close|closed|shut|fasten|knot|draw|already closed|doesn't seem|could not find/i,
      quiet
    )
  end
end

def gemguard_relevant_inventory_objects
  objects = gemguard_quiet_inventory_full_objects
  containers, _source = gemguard_scan_containers

  if containers.empty?
    objects.concat(chrism_sell_inventory_objects)
  else
    containers.each do |container|
      objects << container
      objects.concat(chrism_sell_inventory_objects(container.contents.to_a)) if container.respond_to?(:contents) && container.contents
    end
  end

  gemguard_apply_plain_marked_status(objects.compact.uniq { |item| item.id.to_s })
end

# Shows the player-facing command list.
#
# @return [void]
def chrism_sell_help
  output = "\n"
  command = gemguard_script_command
  command_width = 42
  help_line = proc do |command_text, description = ''|
    padding = ' ' * [command_width - command_text.length, 2].max
    output.concat "   #{gemguard_inline_preset('speech', command_text)}#{padding}#{description}\n"
  end
  help_section = proc do |text|
    output.concat "\n#{gemguard_inline_preset('thought', "#{text}:")}\n"
  end
  help_note = proc do |text|
    output.concat "      #{text}\n"
  end

  output.concat "#{gemguard_inline_preset('thought', "gemguard v#{GEMGUARD_VERSION}")}\n"
  output.concat "#{gemguard_inline_preset('thought', 'usage:')}\n"
  help_section.call('review window')
  help_line.call(command, 'open the review window')
  help_line.call("#{command} help", 'show this help')
  help_line.call("#{command} ?", 'show this help')
  help_section.call('selling')
  help_line.call("#{command} sell", 'sell approved gems one at a time')
  help_line.call("#{command} run", 'same as sell')
  help_line.call("#{command} status", 'preview sell and keep lists')
  help_line.call("#{command} show", 'same as status')
  help_section.call('chrism sorting')
  help_line.call("#{command} sort-chrisms", 'look for chrisms and move them to the saved chrism container')
  help_line.call("#{command} chrismsort", 'same as sort-chrisms')
  help_section.call('eloot')
  help_line.call("#{command} protect-eloot", "add protected gems to this character's ELoot sell_exclude")
  help_line.call("#{command} eloot-protect", 'same as protect-eloot')
  help_line.call("#{command} install-excludes", 'same as protect-eloot')
  help_note.call('Close and reopen ELoot Setup if its window was already open.')
  help_section.call('reference')
  help_line.call("#{command} list", 'show protected gem names')
  help_line.call("#{command} changelog", 'show recent changes')
  help_line.call("#{command} changes", 'same as changelog')
  output.concat "\n"
  gemguard_mono_block(output)
end

# Shows the player-facing changelog.
#
# @return [void]
