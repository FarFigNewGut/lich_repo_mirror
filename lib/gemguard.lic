def chrism_sell_list
  echo ''
  terms = gemguard_protected_terms
  exceptions = gemguard_protected_exceptions
  echo "gemguard protects #{terms.length} gem names:"
  terms.sort_by(&:downcase).each { |name| echo "  #{name}" }
  echo ''
  echo "gemguard has #{exceptions.length} protected-list exceptions:"
  exceptions.sort_by(&:downcase).each { |name| echo "  #{name}" }
  echo ''
end

def chrism_sell_protected?(item, protected_terms = nil, exceptions = nil)
  return true if item.name.to_s =~ /\borb\b/i
  return true if item.name.to_s =~ /\bbound\b/i
  return false if gemguard_name_protection_exception?(item.name, exceptions)

  noun = item.noun.to_s.downcase
  name = item.name.to_s.downcase.sub(/\s*\(\d+\)\s*\z/, '')
  protected_terms ||= gemguard_protected_terms

  protected_terms.any? do |term|
    normalized = term.downcase
    noun == normalized || name.include?(normalized)
  end
end

def gemguard_gem_item?(item)
  return false unless item

  item.type.to_s.split(',').any? { |type| type.strip =~ /^gem$/i }
end

def gemguard_scarab_item?(item)
  return false unless item

  item.noun.to_s =~ /^scarab$/i || item.name.to_s =~ /\bscarab\b/i
end

def gemguard_sellable_treasure_item?(item)
  gemguard_gem_item?(item) || gemguard_scarab_item?(item)
end

def chrism_sellable_gem?(item)
  return false unless gemguard_sellable_treasure_item?(item)
  return false if gemguard_item_marked?(item)
  return false if gemguard_item_chrism?(item)
  return false if gemguard_item_pure_orb?(item)

  item.sellable.to_s.split(',').any? { |place| place.strip =~ /^gemshop$/i }
end

def chrism_sell_gem_groups
  gems = gemguard_relevant_inventory_objects.select { |item| gemguard_sellable_treasure_item?(item) }
  protected_terms = gemguard_protected_terms
  protected = []
  candidates = []

  gems.each do |item|
    protected_by_name = chrism_sell_protected?(item, protected_terms)
    if gemguard_item_marked?(item) || gemguard_item_chrism?(item) || gemguard_item_pure_orb?(item) || (protected_by_name && !gemguard_sell_value_ignore_protected?)
      protected << item
    elsif chrism_sellable_gem?(item)
      candidates << item
    end
  end

  [candidates, protected]
end

def chrism_sell_status
  opened_containers = chrism_sell_open_inventory_containers

  begin
    candidates, protected = chrism_sell_gem_groups
    settings = chrism_sell_load_eloot_settings
    excludes = chrism_sell_eloot_excludes(settings)
    protected_terms = gemguard_protected_terms
    protected_in_eloot = protected_terms.count do |gem_name|
      excludes.any? { |existing| existing.downcase == gem_name.downcase }
    end

    echo ''
    echo "gemguard v#{GEMGUARD_VERSION}"
    echo "  Protected gem count: #{protected_terms.length}"
    echo "  Protected exception count: #{gemguard_protected_exceptions.length}"
    echo "  ELoot profile: #{chrism_sell_eloot_profile_path}"
    echo "  Protected gems already in ELoot sell_exclude: #{protected_in_eloot}/#{protected_terms.length}"
    echo "  Items currently kept by protection, chrism/orb status, or mark: #{protected.length}"
    echo "  Items this script would sell now: #{candidates.length}"
    candidates.each { |item| echo "    sell: #{item.name} (##{item.id})" }
    protected.each { |item| echo "    keep: #{item.name} (##{item.id})" }
    echo ''
  ensure
    chrism_sell_close_inventory_containers(opened_containers)
  end
end

# Scans current review containers and sorts chrisms without opening the GTK
# window. This sends game commands, moves proven chrisms, and saves
# updated chrism status to GemGuard's inventory cache.
#
# @return [void]
def gemguard_sort_chrisms_cli
  echo 'gemguard: scanning gem containers before chrism sort.' if defined?(echo)
  rows = gemguard_scan_review_rows
  state = { sell: rows[:sell], keep: rows[:keep], purify: [] }
  sort_rows = state[:sell] + state[:keep]
  if sort_rows.empty?
    echo 'gemguard: no gems found to check for chrisms.'
    return
  end

  summary = gemguard_sort_chrisms_review_rows(sort_rows) do |done, total, row, running|
    echo "gemguard: chrism sort #{done}/#{total}, #{running[:chrisms].to_i} found, #{running[:moved].to_i} moved, #{running[:already_in_container].to_i} already in Chrisms. Last: #{row[:name]}"
  end
  if summary[:error]
    echo "gemguard: #{summary[:error]}"
    return
  end

  gemguard_apply_sell_policy_to_state(state)
  gemguard_save_scan_snapshot(state)
  gemguard_mono_block("\n#{gemguard_chrism_sort_summary_text(summary)}\n\n")
end

def chrism_sell_protect_eloot
  settings = chrism_sell_load_eloot_settings
  existing = chrism_sell_eloot_excludes(settings)
  before = existing.length
  protected_terms = gemguard_protected_terms
  merged = (existing + protected_terms).uniq { |value| value.downcase }
  chrism_sell_set_eloot_excludes(settings, merged.sort_by(&:downcase))
  chrism_sell_save_eloot_settings(settings)

  added = merged.length - before
  echo "gemguard: added #{added} protected gem names to ELoot sell_exclude."
  echo "gemguard: ELoot sell_exclude now has #{merged.length} entries."
  echo "gemguard: profile updated: #{chrism_sell_eloot_profile_path}"
end

def chrism_sell_go_gemshop
  if running?('go2')
    echo 'gemguard: go2 is already running. Stop go2 first, then try again.'
    exit
  end

  gemshop = Room.current.find_nearest_by_tag('gemshop')
  unless gemshop
    echo 'gemguard: no gemshop room found from here.'
    exit
  end

  return true if Room.current.id.to_i == gemshop.to_i

  echo "gemguard: moving to gemshop room #{gemshop}."
  start_script('go2', [gemshop.to_s])
  wait_while { running?('go2') }

  if Room.current.id.to_i != gemshop.to_i
    echo "gemguard: go2 stopped before reaching gemshop room #{gemshop}; current room is #{Room.current.id}."
    exit
  end

  true
end

def chrism_sell_item_by_id(id)
  direct = GameObj[id.to_s] rescue nil
  return direct if direct

  chrism_sell_inventory_objects.find { |item| item.id.to_s == id.to_s }
end

def chrism_sell_hand_id?(id)
  [gemguard_hand_item(:right), gemguard_hand_item(:left)].compact.any? { |item| item.id.to_s == id.to_s }
end

def gemguard_sale_silver(result)
  matches = result.to_s.scan(/(?:hands you|gives you|for|worth|accepts).*?([0-9][0-9,]*)\s+silvers?/im)
  matches = result.to_s.scan(/([0-9][0-9,]*)\s+silvers?/i) if matches.empty?
  return 0 if matches.empty?

  matches.flatten.last.to_s.delete(',').to_i
rescue
  0
end

def gemguard_duration_text(seconds)
  seconds = seconds.to_i
  return '0s' if seconds <= 0

  minutes, seconds = seconds.divmod(60)
  hours, minutes = minutes.divmod(60)
  parts = []
  parts << "#{hours}h" if hours.positive?
  parts << "#{minutes}m" if minutes.positive? || hours.positive?
  parts << "#{seconds}s"
  parts.join(' ')
rescue
  '0s'
end

def gemguard_purify_progress_text(prefix, done, total, row = nil, kind = nil, summary = nil, timing = nil)
  summary ||= {}
  timing ||= {}
  total = total.to_i
  done = done.to_i
  remaining = total.positive? ? [total - done, 0].max : 0
  elapsed = timing[:started_at] ? Time.now - timing[:started_at] : nil
  current_elapsed = timing[:current_started_at] ? Time.now - timing[:current_started_at] : nil
  average = done.positive? && elapsed ? elapsed / done.to_f : nil
  eta = average && remaining.positive? ? average * remaining : nil
  lines = []
  lines << prefix.to_s
  lines << ''
  lines << "Current gem: #{row[:name]}" if row && row[:name]
  lines << "Last result: #{kind.to_s.tr('_', ' ')}" if kind
  lines << "Progress: #{done}/#{total} complete, #{remaining} remaining"
  lines << "Elapsed: #{gemguard_duration_text(elapsed)}" if elapsed
  lines << "Current gem time: #{gemguard_duration_text(current_elapsed)}" if current_elapsed
  lines << "Average per gem: #{gemguard_duration_text(average)}" if average
  lines << "Estimated remaining: #{gemguard_duration_text(eta)}" if eta
  lines << ''
  lines << "Purified: #{summary[:purified].to_i}"
  lines << "New orbs: #{summary[:orb].to_i}"
  lines << "Already orbs: #{summary[:already_orb].to_i}"
  lines << "Shattered: #{summary[:shattered].to_i}"
  lines << "Stopped: #{summary[:stopped].to_i}" if summary[:stopped].to_i.positive?
  lines << "Failed/missing: #{summary[:failed].to_i + summary[:missing].to_i}"
  lines << ''
  lines << 'Stop requested: this gem will be finished and put away before GemGuard stops.' if gemguard_stop_requested?
  lines.join("\n")
rescue
  prefix.to_s
end

def chrism_sell_clear_hands(quiet = true)
  gemguard_dothistimeout('stow right', 3, /You put|You stow|You return|Stow what|You need|closed|can't/i, quiet) if gemguard_hand_item(:right)
  gemguard_dothistimeout('stow left', 3, /You put|You stow|You return|Stow what|You need|closed|can't/i, quiet) if gemguard_hand_item(:left)
end

def chrism_sell_drag_to_hand(item, quiet = true)
  chrism_sell_clear_hands(quiet)
  gemguard_dothistimeout(
    "_drag ##{item.id} right",
    5,
    /You remove|You take|You get|already holding|Get what|could not find|unable to handle/i,
    quiet
  )
  20.times do
    break if chrism_sell_hand_id?(item.id)
    sleep 0.1
  end
  chrism_sell_hand_id?(item.id)
end

# Sells unprotected gems one at a time at the gemshop. This sends movement,
# item, appraisal, and selling commands.
#
# @return [void]
def chrism_sell_run
  opened_containers = chrism_sell_open_inventory_containers

  begin
    candidates, protected = chrism_sell_gem_groups

    echo "gemguard: keeping #{protected.length} protected gems."
    if candidates.empty?
      echo 'gemguard: no unprotected sellable gems found in inventory.'
      exit
    end

    echo "gemguard: found #{candidates.length} unprotected gems to sell."
    chrism_sell_go_gemshop

    sold = 0
    failed = 0
    skipped = 0
    total_silver = 0
    protected_terms = gemguard_protected_terms
    sell_value_threshold = gemguard_sell_value_threshold

    candidates.each do |item|
      current = chrism_sell_item_by_id(item.id)
      next unless current
      next if chrism_sell_protected?(current, protected_terms) && !gemguard_sell_value_ignore_protected?
      next if gemguard_item_marked?(current)
      next if gemguard_item_chrism?(current)
      next if gemguard_item_pure_orb?(current)
      row = gemguard_review_row(current, :sell, 'not protected')

      unless chrism_sell_drag_to_hand(current, false)
        echo "gemguard: could not get #{current.name} (##{current.id}) into hand."
        failed += 1
        next
      end

      bypass_value_limit = gemguard_sell_purified_ignore_value? && gemguard_review_row_purified_non_orb?(row)
      if sell_value_threshold.positive? && !bypass_value_limit
        value = gemguard_appraise_item_value(current, false).to_s
        row[:value] = value
        if gemguard_not_gemshop_value?(value)
          skipped += 1
          if gemguard_detect_chrism_by_look!(current, row, false)
            echo "gemguard: kept #{current.name} (##{current.id}); chrism found after gemshop refusal."
          else
            row[:action] = :keep
            row[:reason] = 'not gemshop'
            echo "gemguard: kept #{current.name} (##{current.id}); gemshop refused it."
          end
          gemguard_update_inventory_rows([row])
          gemguard_return_item_after_mark(row, current, false)
          next
        end
        amount = gemguard_review_value_amount(value)
        gemguard_update_inventory_rows([row])
        unless amount && amount <= sell_value_threshold
          skipped += 1
          echo "gemguard: skipped #{current.name} (##{current.id}); value #{value.empty? ? '?' : value} is over sell limit #{sell_value_threshold}."
          gemguard_return_item_after_mark(row, current, false)
          next
        end
      end

      sell_result = dothistimeout("sell ##{current.id}", 5, GEMGUARD_SELL_RESULT_RE)
      sleep 0.2

      if chrism_sell_item_by_id(current.id) || chrism_sell_hand_id?(current.id)
        if sell_result =~ /not quite my field|worthless here|not interested|no use for that|only deal in gems/i
          skipped += 1
          if gemguard_detect_chrism_by_look!(current, row, false)
            echo "gemguard: kept #{current.name} (##{current.id}); chrism found after gemshop refusal."
          else
            row[:action] = :keep
            row[:reason] = 'not gemshop'
            echo "gemguard: kept #{current.name} (##{current.id}); gemshop refused it."
          end
          gemguard_update_inventory_rows([row])
          gemguard_return_item_after_mark(row, current, false)
        else
          echo "gemguard: #{current.name} (##{current.id}) did not sell."
          failed += 1
        end
      else
        sold += 1
        total_silver += gemguard_sale_silver(sell_result)
        gemguard_remove_inventory_ids([current.id])
      end
    end

    chrism_sell_clear_hands(false)
    echo "gemguard: sold #{sold} gems for #{total_silver} silver; #{skipped} skipped by value; #{failed} failed; kept #{protected.length} protected gems."
  ensure
    chrism_sell_close_inventory_containers(opened_containers)
  end
end

def gemguard_container_for_item_id(item_id, objects = GameObj.inv.to_a)
  Array(objects).each do |container|
    next unless container.respond_to?(:contents) && container.contents

    return container if container.contents.any? { |item| item.id.to_s == item_id.to_s }

    nested = gemguard_container_for_item_id(item_id, container.contents)
    return nested if nested
  end

  nil
end

# Builds one visible Review/Purify row from a game item.
#
# @param item [Object] GameObj item.
# @param action [Symbol] Intended action, such as :sell, :keep, or :purify.
# @param reason [String] User-facing status text.
# @param known_container [Object, nil] Container already known from the scan.
# @return [Hash] Row used by the GTK tables and YAML cache.
def gemguard_review_row(item, action, reason, known_container = nil)
  container = known_container || gemguard_container_for_item_id(item.id)
  chrism = gemguard_item_chrism?(item) || reason.to_s =~ /\bchrism\b/i
  orb = gemguard_item_pure_orb?(item) || reason.to_s =~ /\b(?:orb|pure)\b/i
  purify_status = gemguard_item_purify_status(item)
  display_reason = reason
  display_reason = purify_status if !purify_status.empty? && display_reason.to_s =~ /\A(?:not protected|protected|ready)\z/i
  row = {
    id: item.id.to_s,
    name: item.name.to_s,
    noun: item.noun.to_s,
    container_id: container ? container.id.to_s : '',
    container: container ? container.name.to_s : '(worn/held)',
    action: action,
    reason: display_reason,
    marked: gemguard_item_marked?(item),
    chrism: chrism,
    orb: orb,
    purify_status: purify_status,
    value: ''
  }
  gemguard_enrich_row_from_inventory!(row)
  gemguard_apply_container_status_hints!(row, container)
end

# Scans gem containers for the Review tab. This opens configured containers,
# reads their contents, updates cached gem data, and closes what it opened.
#
# @return [Hash] Sell and keep row arrays.
def gemguard_scan_review_rows
  gemguard_load_inventory_statuses!
  opened_containers = chrism_sell_open_inventory_containers
  begin
    scanned_containers, _source = gemguard_scan_containers
    source_containers = gemguard_item_container_map(scanned_containers)
    sell_rows, keep_rows = chrism_sell_gem_groups
    rows = {
      sell: sell_rows.map { |item| gemguard_review_row(item, :sell, 'not protected', source_containers[item.id.to_s]) },
      keep: keep_rows.map do |item|
        reason = if gemguard_item_chrism?(item)
                   'chrism'
                 elsif gemguard_item_pure_orb?(item)
                   'orb'
                 elsif gemguard_item_marked?(item)
                   'marked'
                 else
                   'protected'
                 end
        gemguard_review_row(item, :keep, reason, source_containers[item.id.to_s])
      end
    }
    gemguard_update_inventory_rows(rows[:sell] + rows[:keep], prune: true)
    rows[:stale_removed] = gemguard_cleanup_inventory_after_review_scan(rows[:sell] + rows[:keep], scanned_containers)
    gemguard_save_scan_snapshot(rows)
    rows
  ensure
    chrism_sell_close_inventory_containers(opened_containers)
  end
end

def gemguard_format_review_rows(rows)
  return "(none)\n" if rows.empty?

  rows.each_with_index.map do |row, index|
    value = row[:value].to_s.empty? ? '-' : row[:value]
    format('%3d. %-34s %10s  %s',
           index + 1,
           row[:name].to_s[0, 34],
           value,
           row[:reason])
  end.join("\n") + "\n"
end

def gemguard_appraise_item_value(item, quiet = false)
  amount = nil
  work = proc do
    fput "appraise ##{item.id}"
    Timeout.timeout(6) do
      while (line = get)
        if line =~ /([,0-9]+) (?:silver|for it if you want to sell|for this if you'd like|silver coins? for it|silvers?\.)/i
          amount = Regexp.last_match(1).delete(',').to_i
          break
        elsif line =~ /not buying anything this valuable today/i
          amount = 'too valuable'
          break
        elsif line =~ /not quite my field|worthless here|not interested|no use for that|only deal in gems/i
          amount = 'not gemshop'
          break
        elsif line =~ /You ask .*to appraise|You offer to sell/i
          next
        end
      end
    end
  end
  quiet ? gemguard_silent { work.call } : work.call
  amount
rescue Timeout::Error
  nil
end

# Appraises visible Review rows one at a time. This gets each gem, appraises it,
# returns it to a container, and updates cached gem values.
#
# @param rows [Array<Hash>] Rows to appraise.
# @param quiet [Boolean] Hide command output when true.
# @yield [done, total, row] Reports progress after each row.
# @return [Array<Hash>] Updated rows.
def gemguard_appraise_review_rows(rows, quiet = false)
  opened_containers = chrism_sell_open_inventory_containers
  begin
    chrism_sell_go_gemshop
    total = Array(rows).length
    Array(rows).each_with_index do |row, index|
      break if gemguard_stop_requested?(true)

      item = chrism_sell_item_by_id(row[:id])
      if item && chrism_sell_drag_to_hand(item, quiet)
        row[:value] = gemguard_appraise_item_value(item, quiet).to_s
        if gemguard_not_gemshop_value?(row[:value])
          unless gemguard_detect_chrism_by_look!(item, row, quiet)
            row[:action] = :keep
            row[:reason] = 'not gemshop'
          end
        end
        gemguard_return_item_after_mark(row, item)
      else
        row[:value] = '' unless gemguard_meaningful_review_value?(row[:value])
      end
      row[:value] = '?' if row[:value].empty?
      gemguard_update_inventory_rows([row])
      yield(index + 1, total, row) if block_given?
    end
  ensure
    chrism_sell_clear_hands
    chrism_sell_close_inventory_containers(opened_containers)
  end
end

# Sells approved Review rows one at a time. This gets each gem, optionally
# appraises it by value rule, sells it, and updates cached gem data.
#
# @param rows [Array<Hash>] Rows approved for selling.
# @yield [sold, failed, silver, row, skipped] Reports progress.
# @return [Array] Sold ids, failed count, silver total, and skipped ids.
def gemguard_sell_review_rows(rows)
  opened_containers = chrism_sell_open_inventory_containers
  sold_ids = []
  skipped_ids = []
  failed = 0
  total_silver = 0
  sell_value_threshold = gemguard_sell_value_threshold

  begin
    chrism_sell_go_gemshop
    rows.each do |row|
      break if gemguard_stop_requested?(true)

      current = chrism_sell_item_by_id(row[:id])
      next unless current

      orb_blocked = (row[:orb] || row[:reason].to_s =~ /\b(?:pure orb|orb)\b/i || gemguard_item_pure_orb?(current)) && !gemguard_review_row_orb_sellable?(row)
      if row[:marked] || gemguard_item_marked?(current) || row[:chrism] || row[:reason].to_s =~ /\bchrism\b/i || gemguard_item_chrism?(current) || orb_blocked
        failed += 1
        next
      end

      if current.name.to_s =~ /\bbound\b/i || (current.name.to_s =~ /\borb\b/i && !gemguard_review_row_orb_sellable?(row))
        failed += 1
        next
      end

      unless chrism_sell_drag_to_hand(current, false)
        failed += 1
        next
      end

      bypass_value_limit = gemguard_sell_purified_ignore_value? && gemguard_review_row_purified_non_orb?(row)
      if sell_value_threshold.positive? && !bypass_value_limit
        row[:value] = gemguard_appraise_item_value(current, false).to_s
        if gemguard_not_gemshop_value?(row[:value])
          row[:action] = :keep
          row[:reason] = 'not gemshop'
          gemguard_detect_chrism_by_look!(current, row, false)
          skipped_ids << row[:id].to_s
          gemguard_update_inventory_rows([row])
          gemguard_return_item_after_mark(row, current, false)
          yield(sold_ids.length, failed, total_silver, row, skipped_ids.length) if block_given?
          next
        end
        amount = gemguard_review_value_amount(row[:value])
        gemguard_update_inventory_rows([row])
        unless amount && amount <= sell_value_threshold
          row[:action] = :keep
          row[:reason] = 'over sell limit'
          skipped_ids << row[:id].to_s
          gemguard_update_inventory_rows([row])
          gemguard_return_item_after_mark(row, current, false)
          yield(sold_ids.length, failed, total_silver, row, skipped_ids.length) if block_given?
          next
        end
      end

      sell_result = dothistimeout("sell ##{current.id}", 5, GEMGUARD_SELL_RESULT_RE)
      sleep 0.2

      if chrism_sell_item_by_id(current.id) || chrism_sell_hand_id?(current.id)
        if sell_result =~ /not quite my field|worthless here|not interested|no use for that|only deal in gems/i
          row[:action] = :keep
          row[:reason] = 'not gemshop'
          gemguard_detect_chrism_by_look!(current, row, false)
          skipped_ids << row[:id].to_s
          gemguard_update_inventory_rows([row])
          gemguard_return_item_after_mark(row, current, false)
        else
          failed += 1
        end
      else
        sold_ids << row[:id].to_s
        total_silver += gemguard_sale_silver(sell_result)
        gemguard_remove_inventory_ids([row[:id]])
      end
      yield(sold_ids.length, failed, total_silver, row, skipped_ids.length) if block_given?
    end
    chrism_sell_clear_hands(false)
  ensure
    chrism_sell_close_inventory_containers(opened_containers)
  end

  [sold_ids, failed, total_silver, skipped_ids]
end

def gemguard_return_item_after_mark(row, item, quiet = true)
  target_id = row[:container_id].to_s
  if !target_id.empty?
    gemguard_dothistimeout(
      "_drag ##{item.id} ##{target_id}",
      5,
      /You|could not find|unable|won't fit|closed|full/i,
      quiet
    )
    20.times do
      break unless chrism_sell_hand_id?(item.id)
      sleep 0.1
    end
    return true unless chrism_sell_hand_id?(item.id)
  end

  chrism_sell_clear_hands(quiet)
  !chrism_sell_hand_id?(item.id)
end

# Adds or removes the game unsellable mark from selected rows. This gets each
# gem, sends MARK commands, stows it, and refreshes cached gem data.
#
# @param rows [Array<Hash>] Rows to mark or unmark.
# @param remove_mark [Boolean] true to remove the mark.
# @return [Array] Changed item ids and failed count.
def gemguard_mark_review_rows(rows, remove_mark = false)
  opened_containers = chrism_sell_open_inventory_containers
  changed_ids = []
  failed = 0

  begin
    Array(rows).each do |row|
      break if gemguard_stop_requested?(true)

      current = chrism_sell_item_by_id(row[:id])
      unless current
        failed += 1
        next
      end

      unless chrism_sell_drag_to_hand(current)
        failed += 1
        next
      end

      command = remove_mark ? "mark ##{current.id} remove" : "mark ##{current.id}"
      result = gemguard_quiet_dothistimeout(
        command,
        5,
        /marked|unsellable|sellable|remove|holding|could not find|what were you referring|already/i
      ).to_s

      if result.empty? || result =~ /must be holding|could not find|what were you referring/i
        failed += 1
      else
        changed_ids << row[:id].to_s
        row[:marked] = !remove_mark
        row[:reason] = remove_mark ? (row[:chrism] ? 'chrism' : row[:orb] ? 'orb' : 'protected') : 'marked'
        gemguard_update_inventory_rows([row])
      end
      failed += 1 unless gemguard_return_item_after_mark(row, current)
      sleep 0.1
    end
  ensure
    chrism_sell_clear_hands
    chrism_sell_close_inventory_containers(opened_containers)
  end

  [changed_ids, failed]
end

def gemguard_loresing_orb_test(item)
  output = ''
  begin
    item_word = item.noun.to_s.strip
    item_word = item.name.to_s.strip if item_word.empty?
    verse = "#{item_word.capitalize} that I hold;let your purpose now be told"
    fput 'speak bard'
    output = dothistimeout(
      "loresing ::##{item.id}:: #{verse}",
      5,
      GEMGUARD_LORESING_DONE_RE
    ).to_s
  ensure
    fput 'speak common' rescue nil
  end

  {
    method: :loresing,
    pure: !!(output =~ GEMGUARD_LORESING_PURE_RE),
    chrism: !!(output =~ GEMGUARD_LORESING_CHRISM_RE),
    unknown: output.strip.empty?,
    output: output
  }
rescue Timeout::Error
  { method: :loresing, pure: false, unknown: true, output: output.to_s }
rescue => error
  { method: :loresing, pure: false, unknown: true, output: "#{error.class}: #{error.message}" }
end

def gemguard_phase_orb_test(item)
  prep = gemguard_quiet_dothistimeout(
    'prep 704',
    6,
    /Your spell is ready|already have a spell readied|already preparing a spell|don't know that spell|don't have enough mana|Roundtime/i
  ).to_s
  output = prep.dup

  if prep =~ /already have a spell readied|already preparing a spell|don't know that spell|don't have enough mana/i
    return { method: :phase, pure: false, unknown: true, output: output }
  end

  cast = gemguard_quiet_dothistimeout(
    "cast ##{item.id}",
    8,
    GEMGUARD_PHASE_DONE_RE
  ).to_s
  output = [prep, cast].join("\n")
  pure = !!(output =~ GEMGUARD_PHASE_PURE_RE)
  known_not_pure = output =~ /resist|nothing happens|What were you referring|I could not|could not find|must be holding|need to be holding/i
  gemguard_quiet_dothistimeout('release', 2, /release|aren't preparing|not preparing/i) if !pure && !(output =~ /Cast Roundtime|You gesture/i)

  {
    method: :phase,
    pure: pure,
    unknown: !pure && !known_not_pure,
    output: output
  }
rescue Timeout::Error
  gemguard_quiet_dothistimeout('release', 2, /release|aren't preparing|not preparing/i) rescue nil
  { method: :phase, pure: false, unknown: true, output: output.to_s }
rescue => error
  gemguard_quiet_dothistimeout('release', 2, /release|aren't preparing|not preparing/i) rescue nil
  { method: :phase, pure: false, unknown: true, output: "#{error.class}: #{error.message}" }
end

def gemguard_record_orb_test(item, result)
  @orb_statuses = {} unless @orb_statuses.is_a?(Hash)
  @orb_statuses[item.id.to_s] = {
    pure: true,
    method: result[:method].to_s,
    tested_at: Time.now.strftime('%m/%d/%Y %H:%M:%S %z'),
    output: result[:output].to_s[0, 500]
  }
  gemguard_update_inventory_item(
    item.id,
    'id' => item.id.to_s,
    'name' => item.name.to_s,
    'noun' => item.noun.to_s,
    'orb' => true,
    'status' => 'orb',
    'orb_method' => result[:method].to_s,
    'orb_output' => result[:output].to_s[0, 500]
  )
rescue
  nil
end

# Saves the result of an orb test for one gem. This updates the persistent gem
# data so future scans remember whether that item already tested as a non-orb.
#
# @param item [Object] Lich item being tested.
# @param result [Hash] Test details, including method and output text.
# @param status [String] Saved result such as orb, not_orb, or unknown.
# @return [void]
def gemguard_record_orb_test_result(item, result, status)
  status = status.to_s
  return gemguard_record_orb_test(item, result) if status == 'orb'

  gemguard_update_inventory_item(
    item.id,
    'id' => item.id.to_s,
    'name' => item.name.to_s,
    'noun' => item.noun.to_s,
    'orb' => false,
    'orb_tested' => true,
    'orb_test_result' => status,
    'orb_test_method' => result[:method].to_s,
    'orb_tested_at' => Time.now.strftime('%m/%d/%Y %H:%M:%S %z'),
    'orb_test_output' => result[:output].to_s[0, 500]
  )
rescue
  nil
end

def gemguard_record_purify_result(item, status, output = '')
  @purify_statuses = {} unless @purify_statuses.is_a?(Hash)
  @purify_statuses[item.id.to_s] = {
    status: status.to_s,
    tested_at: Time.now.strftime('%m/%d/%Y %H:%M:%S %z'),
    output: output.to_s[0, 500]
  }
  attrs = {
    'id' => item.id.to_s,
    'name' => item.name.to_s,
    'noun' => item.noun.to_s,
    'purify_status' => status.to_s,
    'status' => status.to_s,
    'purify_output' => output.to_s[0, 500]
  }
  attrs['orb'] = true if status.to_s =~ /\borb\b/i
  attrs['value'] = '' if status.to_s =~ /\A(?:purified|orb)\z/i
  gemguard_update_inventory_item(item.id, attrs)
rescue
  nil
end

# Tests selected rows for pure-orb behavior when the character can do so. This
# sends loresing or phase commands and records the result.
#
# @param rows [Array<Hash>] Rows to test.
# @yield [done, total, row, progress] Reports the current gem and running counts.
# @return [Array] Pure ids, not-pure count, unknown count, and failed count.
def gemguard_orb_test_review_rows(rows)
  mode = gemguard_orb_test_mode
  return [[], 0, Array(rows).length, 0] if mode == :disabled

  quiet = mode != :loresing
  opened_containers = chrism_sell_open_inventory_containers(quiet)
  pure_ids = []
  not_pure = 0
  unknown = 0
  failed = 0
  test_rows = Array(rows)

  begin
    test_rows.each_with_index do |row, index|
      break if gemguard_stop_requested?(true)

      progress = proc do |done, phase, result_text = ''|
        next unless block_given?

        yield(done, test_rows.length, row, {
          phase: phase,
          result: result_text,
          orbs: pure_ids.length,
          not_pure: not_pure,
          unknown: unknown,
          failed: failed
        })
      end
      progress.call(index, :testing)

      current = chrism_sell_item_by_id(row[:id])
      unless current
        failed += 1
        progress.call(index + 1, :done, 'missing')
        next
      end

      unless chrism_sell_drag_to_hand(current, quiet)
        failed += 1
        progress.call(index + 1, :done, 'could not get')
        next
      end

      result = mode == :loresing ? gemguard_loresing_orb_test(current) : gemguard_phase_orb_test(current)
      gemguard_wait_from_command_text(result[:output])
      result_text = 'not pure'
      if result[:pure]
        gemguard_record_orb_test_result(current, result, 'orb')
        pure_ids << row[:id].to_s
        result_text = 'orb'
      elsif result[:chrism]
        gemguard_record_chrism_result(current, result[:output])
        row[:chrism] = true
        row[:action] = :keep
        row[:reason] = 'chrism'
        not_pure += 1
        result_text = 'chrism'
      elsif result[:unknown]
        gemguard_record_orb_test_result(current, result, 'unknown')
        unknown += 1
        result_text = 'unknown'
      else
        gemguard_record_orb_test_result(current, result, 'not_orb')
        not_pure += 1
      end

      failed += 1 unless gemguard_return_item_after_mark(row, current, quiet)
      progress.call(index + 1, :done, result_text)
      sleep 0.1
    end
  ensure
    chrism_sell_clear_hands(quiet)
    chrism_sell_close_inventory_containers(opened_containers, quiet)
  end

  [pure_ids, not_pure, unknown, failed]
end

def gemguard_wait_spell_rt
  wait_while { (defined?(checkrt) && checkrt.to_i.positive?) || (defined?(checkcastrt) && checkcastrt.to_i.positive?) }
  sleep 0.2
rescue
  sleep 0.2
end

# Waits for physical roundtime after actions such as pushing a lapidary box.
# This reads Lich roundtime state and falls back to roundtime text when needed.
#
# @param text [String] Command output that may include a Roundtime line.
# @return [Boolean] true when a wait happened.
def gemguard_wait_physical_rt(text = '')
  10.times do
    break if defined?(checkrt) && checkrt.to_i.positive?
    sleep 0.1
  end
  if defined?(checkrt) && checkrt.to_i.positive?
    wait_while { checkrt.to_i.positive? }
    sleep 0.2
    return true
  end

  gemguard_wait_from_command_text(text)
rescue
  gemguard_wait_from_command_text(text)
end

def gemguard_wait_from_command_text(text)
  source = text.to_s
  seconds = if source =~ /Wait\s+(\d+)\s+sec/i
              Regexp.last_match(1).to_i
            elsif source =~ /(?:Sing|Cast)?\s*Roundtime:?\s+(\d+)\s+sec(?:onds?)?\.?/i
              Regexp.last_match(1).to_i
            else
              0
            end
  return false unless seconds.positive?

  sleep(seconds + 0.2)
  true
rescue
  false
end

# Checks whether the bard has enough mana to safely keep purifying. This reads
# current mana only and does not send game commands.
#
# @return [Boolean] true if the script should stop before another cast.
def gemguard_purify_low_mana?
  current = gemguard_current_mana
  return false unless current

  current < gemguard_purify_required_mana
rescue
  false
end

# Reads the current mana value when Lich exposes it.
#
# @return [Integer, nil] Current mana, or nil when it cannot be read.
def gemguard_current_mana
  return mana.to_i if defined?(mana)
  return checkmana.to_i if defined?(checkmana)

  nil
rescue
  nil
end

# Reads song status once at the start of a Purify batch and returns the renewal
# cost that should be preserved. This sends SONG STATUS silently.
#
# @return [Integer] Mana to keep reserved for song renewal.
def gemguard_song_renewal_reserve
  return 0 unless gemguard_bard?

  output = gemguard_quiet_dothistimeout(
    'song status',
    4,
    /current renewal cost is \d+ mana|not singing any songs/i
  ).to_s
  return 0 if output =~ /not singing any songs/i

  output[/current renewal cost is\s+(\d+)\s+mana/i, 1].to_i
rescue
  0
end

# Calculates the mana GemGuard should wait for before singing 1004. A Purify
# batch keeps the song renewal cost plus a small casting buffer when available.
#
# @return [Integer] Minimum mana needed before another Purification Song cast.
def gemguard_purify_required_mana
  reserve = @purify_song_renewal_reserve.to_i
  reserve.positive? ? [GEMGUARD_PURIFY_MIN_MANA, reserve + GEMGUARD_PURIFY_CAST_BUFFER].max : GEMGUARD_PURIFY_MIN_MANA
rescue
  GEMGUARD_PURIFY_MIN_MANA
end

# Waits for enough mana to safely prepare Purification Song. This keeps GTK
# events moving so Stop can still be clicked while waiting.
#
# @return [Boolean] true when mana is ready, false when Stop was requested.
def gemguard_wait_for_purify_mana
  current = gemguard_current_mana
  return true unless current

  required = gemguard_purify_required_mana
  while current < required
    return false if gemguard_stop_requested?(true)

    gemguard_pump_gtk_events
    sleep 1
    current = gemguard_current_mana
    return true unless current
  end
  true
rescue
  true
end

# Checks whether a prep response means the Purification Song is ready to sing at
# the held gem.
#
# @param text [String] Game output from prep 1004.
# @return [Boolean] true if singing at the gem is safe.
def gemguard_purify_prep_ready?(text)
  !!(text.to_s =~ /Your spell(?:song)? is ready/i)
rescue
  false
end

# Checks whether a prep response only asks the script to wait.
#
# @param text [String] Game output from prep 1004.
# @return [Boolean] true if the script should wait and try prep again.
def gemguard_purify_prep_wait?(text)
  !!(text.to_s =~ /Wait\s+\d+\s+sec|Roundtime/i)
rescue
  false
end

# Checks whether a prep response means GemGuard should stop the purify run and
# return the held gem without singing at an item number.
#
# @param text [String] Game output from prep 1004.
# @return [Boolean] true if the run should stop safely.
def gemguard_purify_prep_stop?(text)
  source = text.to_s
  return true if source.empty?

  !!(source =~ /can't think clearly enough|Need some mana|don't have enough mana|overextended|system shock|Spell Hindrance|don't know that spell|already have a spell readied|already preparing a spell/i)
rescue
  true
end

# Checks whether song output means Purify should stop after returning the held
# gem. This protects the character from continuing after low mana, system shock,
# or an unclear head.
#
# @param text [String] Game output seen after preparing or singing 1004.
# @return [Boolean] true when the purify batch should stop safely.
def gemguard_purify_hard_stop?(text)
  !!(text.to_s =~ /Need some mana|don't have enough mana|overextended|system shock|can't think clearly enough|Spell Hindrance/i)
rescue
  false
end

# Briefly watches for warning lines that can arrive after the visible sing
# roundtime line. This reads game output, requests a safe stop when needed, and
# returns any warning text for status storage.
#
# @return [String] Warning lines found after singing, or an empty string.
def gemguard_purify_post_song_warning
  lines = []
  Timeout.timeout(0.4) do
    while (line = get)
      text = line.to_s.rstrip
      next if text.empty?

      lines << text
      break if gemguard_purify_hard_stop?(text)
      break if text =~ /<prompt/i
    end
  end
  lines.join("\n")
rescue Timeout::Error
  lines.join("\n")
rescue
  ''
end

def gemguard_purify_candidate?(item)
  return false unless gemguard_gem_item?(item)
  return false if item.name.to_s =~ /smooth stone/i
  return false if gemguard_item_marked?(item)
  return false if gemguard_item_chrism?(item)
  return false if gemguard_item_pure_orb?(item)

  return true if gemguard_purify_all_gems_enabled?(@purify_runtime_settings)

  chrism_sell_protected?(item)
rescue
  false
end

def gemguard_purify_runtime_setting_value(key)
  settings = @purify_runtime_settings
  if settings.is_a?(Hash)
    return settings[key.to_sym].to_s if settings.key?(key.to_sym)
    return settings[key.to_s].to_s if settings.key?(key.to_s)
  end

  gemguard_setting_value(key)
rescue
  gemguard_setting_value(key)
end

def gemguard_with_purify_runtime_settings(settings)
  previous = @purify_runtime_settings
  @purify_runtime_settings = settings.is_a?(Hash) ? settings : {}
  yield
ensure
  @purify_runtime_settings = previous
end

def gemguard_purify_source_container
  gemguard_find_container(gemguard_purify_runtime_setting_value(:purify_unsung_container))
end

def gemguard_purify_target_container(kind)
  key = kind == :orb ? :purify_orb_container : :purify_sung_container
  gemguard_find_container(gemguard_purify_runtime_setting_value(key))
end

# Scans the configured unsung gem container for the Purify tab. This opens and
# looks in the source container, updates cached rows, and closes what it opened.
#
# @return [Hash] Purify rows and source label.
def gemguard_purify_scan_rows
  gemguard_load_inventory_statuses!
  source = gemguard_purify_source_container
  opened = []
  rows = []
  source_rows = []

  if source
    open_result = gemguard_quiet_dothistimeout("open ##{source.id}", 3, /open|already open|doesn't seem|locked|closed|shut/i).to_s
    opened = [source] unless open_result =~ /already open|doesn't seem|locked/i
    gemguard_quiet_dothistimeout("look in ##{source.id}", 3, /In the|There is nothing|doesn't seem|closed|locked/i)
    objects = source.contents.to_a
  else
    opened = chrism_sell_open_inventory_containers
    objects = gemguard_relevant_inventory_objects
  end

  objects.select { |item| gemguard_sellable_treasure_item?(item) }.each do |item|
    reason = if gemguard_item_chrism?(item)
               'chrism'
             elsif gemguard_item_pure_orb?(item)
               'orb'
             elsif gemguard_item_marked?(item)
               'marked'
             elsif chrism_sell_protected?(item)
               'protected'
             else
               'not protected'
             end
    row = gemguard_review_row(item, :purify, reason, source)
    source_rows << row
    next unless gemguard_cached_purify_candidate?(row, @purify_runtime_settings)

    rows << row.merge(
      action: :purify,
      reason: row[:purify_status].to_s.empty? ? 'ready' : row[:purify_status].to_s
    )
  end
  gemguard_update_inventory_rows(source_rows.empty? ? rows : source_rows, prune: !!source)
  gemguard_prune_inventory_source_rows(source_rows.empty? ? rows : source_rows, source.name.to_s) if source

  { rows: rows, source: source ? source.name.to_s : 'gem containers' }
ensure
  chrism_sell_close_inventory_containers(opened)
end

def gemguard_purify_put_held_item(row, item, kind)
  target = gemguard_purify_target_container(kind)
  target ||= gemguard_find_container(row[:container])
  row[:value] = ''
  row[:clear_value] = true
  if target
    gemguard_dothistimeout("_drag ##{item.id} ##{target.id}", 5, /You put|You add|could not|closed|full|unable/i, false)
    20.times do
      break unless chrism_sell_hand_id?(item.id)
      sleep 0.1
    end
    unless chrism_sell_hand_id?(item.id)
      row[:container_id] = target.id.to_s
      row[:container] = target.name.to_s
      gemguard_update_inventory_rows([row])
      return true
    end
  end

  gemguard_return_item_after_mark(row, item, false)
end

# Runs Purification Song on one gem and puts the result in the right container.
# This sends game commands, updates orb/purify status, and may destroy a gem if
# the game shatters it.
#
# @param row [Hash] Purify row to work on.
# @return [Symbol] Result kind, such as :purified, :orb, or :shattered.
def gemguard_purify_one(row)
  current = chrism_sell_item_by_id(row[:id])
  return :missing unless current
  return :failed unless chrism_sell_drag_to_hand(current, false)

  smoother_count = 0
  result_kind = :purified
  last_result = ''
  known_orb_before = row[:orb] || row[:reason].to_s =~ /\b(?:pure orb|already orb|orb)\b/i

  20.times do
    gemguard_pump_gtk_events

    gemguard_wait_spell_rt
    unless gemguard_wait_for_purify_mana
      last_result = 'stopped while waiting for mana'
      result_kind = :stopped
      break
    end
    wait_while { muckled? } if defined?(muckled?)

    prep = gemguard_dothistimeout('prep 1004', 6, GEMGUARD_PURIFY_PREP_RE, false).to_s
    if gemguard_purify_prep_wait?(prep)
      gemguard_wait_from_command_text(prep)
      next
    end

    unless gemguard_purify_prep_ready?(prep)
      last_result = prep
      result_kind = gemguard_purify_prep_stop?(prep) ? :stopped : :failed
      gemguard_request_stop if result_kind == :stopped
      break
    end

    result = gemguard_dothistimeout("sing ##{current.id}", 8, GEMGUARD_PURIFY_RESULT_RE, false).to_s
    post_warning = gemguard_purify_post_song_warning
    result = [result, post_warning].reject(&:empty?).join("\n")
    last_result = result
    gemguard_wait_from_command_text(result)

    if gemguard_purify_hard_stop?(result)
      result_kind = :stopped
      gemguard_request_stop
      break
    elsif result =~ /gem resonates in response to your voice.*cannot be purified any further/i
      result_kind = known_orb_before ? :already_orb : :orb
      gemguard_record_orb_test(current, method: :purify, output: result, pure: true)
      gemguard_record_purify_result(current, 'orb', result)
      break
    elsif result =~ /turn as the very essence/i
      result_kind = :orb
      gemguard_record_orb_test(current, method: :purify, output: result, pure: true)
      gemguard_record_purify_result(current, 'orb', result)
      break
    elsif result =~ /gem vibrates slightly in your hand.*cannot be purified any further/i
      result_kind = :purified
      break
    elsif result =~ /shatter/i
      result_kind = :shattered
      break
    elsif result =~ /gem becomes more perfect|sparkles a little more|appearing smoother and more pure|smoother and more pure in color/i
      smoother_count += 1
      if smoother_count >= 2
        result_kind = :purified
        break
      end
    elsif result =~ /crack|improves somewhat|what were you|cannot|must be holding|song misfires/i
      result_kind = :purified
      break
    elsif result.empty?
      result_kind = :failed
      break
    end
  end

  if result_kind == :shattered
    gemguard_record_purify_result(current, 'shattered', last_result)
    return :shattered
  elsif result_kind == :stopped
    gemguard_record_purify_result(current, 'stopped', last_result)
    gemguard_return_item_after_mark(row, current, false) if chrism_sell_hand_id?(current.id)
  elsif result_kind == :orb || result_kind == :already_orb
    gemguard_purify_put_held_item(row, current, :orb)
  elsif chrism_sell_hand_id?(current.id)
    if result_kind == :failed
      gemguard_return_item_after_mark(row, current, false)
    else
      gemguard_record_purify_result(current, 'purified', last_result)
      gemguard_purify_put_held_item(row, current, :sung)
    end
  end

  result_kind
ensure
  chrism_sell_clear_hands(false)
end

def gemguard_purify_summary_text(prefix, summary, total = nil)
  summary ||= {}
  purified = summary[:purified].to_i
  orbs = summary[:orb].to_i + summary[:already_orb].to_i
  shattered = summary[:shattered].to_i
  failed = summary[:failed].to_i + summary[:missing].to_i
  stopped = summary[:stopped].to_i
  processed = summary.values.map(&:to_i).inject(0) { |total, amount| total + amount }
  total_text = total ? " #{processed}/#{total} processed." : ''
  stop_text = stopped.positive? ? ", #{stopped} stopped" : ''

  "#{prefix}:#{total_text} #{purified} purified, #{orbs} orb#{orbs == 1 ? '' : 's'}, #{shattered} shattered, #{failed} failed#{stop_text}."
rescue
  "#{prefix}: summary unavailable."
end

# Prints the Purify result report to the game window.
#
# @param prefix [String] Report title state.
# @param summary [Hash] Result counts.
# @param total [Integer, nil] Total selected rows for the batch.
# @return [void]
def gemguard_purify_terminal_report(prefix, summary, total = nil)
  summary ||= {}
  total = total.to_i if total
  processed = summary.values.map(&:to_i).inject(0) { |sum, amount| sum + amount }
  remaining = total && total.positive? ? [total - processed, 0].max : 0
  title = prefix.to_s =~ /stopped/i ? 'Purify Stopped' : 'Purify Complete'
  report_width = 51
  line = proc do |left_label, left_value, right_label = '', right_value = ''|
    left = gemguard_inline_preset('speech', "#{left_label}:".ljust(16)) +
           gemguard_inline_preset('thought', left_value.to_s.rjust(8))
    right = if right_label.to_s.empty?
              ''
            else
              gemguard_inline_preset('speech', "#{right_label}:".ljust(16)) +
                gemguard_inline_preset('thought', right_value.to_s.rjust(8))
            end
    "   #{left}   #{right}\n"
  end
  output = "\n"
  output.concat "#{gemguard_inline_preset('thought', title.center(report_width))}\n"
  output.concat line.call('Processed', total && total.positive? ? "#{processed}/#{total}" : processed, 'Remaining', remaining)
  output.concat line.call('Purified', summary[:purified].to_i, 'New orbs', summary[:orb].to_i)
  output.concat line.call('Already orbs', summary[:already_orb].to_i, 'Shattered', summary[:shattered].to_i)
  if summary[:stopped].to_i.positive?
    output.concat line.call('Failed/missing', summary[:failed].to_i + summary[:missing].to_i, 'Stopped', summary[:stopped].to_i)
  else
    output.concat line.call('Failed/missing', summary[:failed].to_i + summary[:missing].to_i, 'Status', title.sub(/\APurify\s+/i, '').downcase)
  end
  output.concat "\n"
  gemguard_mono_block(output)
rescue
  echo "gemguard: #{gemguard_purify_summary_text(prefix, summary, total)}" if defined?(echo)
end

# Runs Purify on selected rows until done or safely stopped. This sends game
# commands and updates cached row status after each gem.
#
# @param rows [Array<Hash>] Rows to purify.
# @yield [stage, done, total, row, kind, running_summary] Reports progress.
# @return [Hash] Result counts.
def gemguard_purify_review_rows(rows)
  opened = chrism_sell_open_inventory_containers
  summary = Hash.new(0)
  total = Array(rows).length

  begin
    Array(rows).each_with_index do |row, index|
      break if gemguard_stop_requested?(true)

      yield(:start, index + 1, total, row, nil, summary) if block_given?
      kind = gemguard_purify_one(row)
      summary[kind] += 1
      result_text = (kind == :orb || kind == :already_orb) ? 'orb' : kind.to_s.tr('_', ' ')
      if kind == :failed
        row[:purify_status] = ''
        row[:reason] = gemguard_review_row_default_status(row)
      else
        row[:purify_status] = result_text
        row[:reason] = result_text
        row[:orb] = true if kind == :orb || kind == :already_orb
      end
      gemguard_update_inventory_rows([row])
      yield(:finish, index + 1, total, row, kind, summary) if block_given?
      sleep 0.1
    end
  ensure
    chrism_sell_close_inventory_containers(opened)
  end

  summary
end

def gemguard_gtk_debug(message = '')
  echo "gemguard GTK: #{message}" if @gtk_debug
rescue
  nil
end

def gemguard_pump_gtk_events
  return unless defined?(Gtk) && Gtk.respond_to?(:events_pending?)

  iterations = 0
  while Gtk.events_pending? && iterations < 20
    Gtk.main_iteration
    iterations += 1
  end
rescue
  nil
end

def gemguard_reset_stop_request
  @stop_requested = false
end

def gemguard_request_stop
  @stop_requested = true
end

def gemguard_stop_requested?(pump_events = false)
  gemguard_pump_gtk_events if pump_events
  !!@stop_requested
rescue
  !!@stop_requested
end

def gemguard_present_window(window)
  return unless window

  window.show_all if window.respond_to?(:show_all)
  window.deiconify if window.respond_to?(:deiconify)
  window.set_keep_above(true) if window.respond_to?(:set_keep_above)
  window.present if window.respond_to?(:present)
  window.window.raise if window.respond_to?(:window) && window.window && window.window.respond_to?(:raise)
  if defined?(GLib) && GLib.respond_to?(:Timeout)
    GLib::Timeout.add(150) do
      begin
        window.deiconify if window.respond_to?(:deiconify)
        window.present if window.respond_to?(:present)
        window.window.raise if window.respond_to?(:window) && window.window && window.window.respond_to?(:raise)
      rescue
        nil
      end
      false
    end
    GLib::Timeout.add(900) do
      begin
        window.set_keep_above(false) if window.respond_to?(:set_keep_above)
      rescue
        nil
      end
      false
    end
  else
    window.set_keep_above(false) if window.respond_to?(:set_keep_above)
  end
rescue
  nil
end

def gemguard_remember_gtk_window(name, window, window_ref = nil)
  @gtk_windows = {} unless @gtk_windows.is_a?(Hash)
  window_ref[:name] = name if window_ref.is_a?(Hash)
  window_ref[:window] = window if window_ref.is_a?(Hash)
  @gtk_windows[name] = window
rescue
  nil
end

def gemguard_forget_gtk_window(name, window_ref = nil, closed_ref = nil)
  closed_ref[:closed] = true if closed_ref
  window_ref[:window] = nil if window_ref.is_a?(Hash)
  @gtk_windows = {} unless @gtk_windows.is_a?(Hash)
  @gtk_windows.delete(name)
rescue
  nil
end

def gemguard_gtk_window_open?(window_ref)
  window = window_ref.is_a?(Hash) ? window_ref[:window] : window_ref
  !!window
rescue
  false
end

def gemguard_close_gtk_window_now(window_ref, closed_ref = nil)
  window = window_ref.is_a?(Hash) ? window_ref[:window] : window_ref
  name = window_ref.is_a?(Hash) ? window_ref[:name].to_s : '(direct)'
  closed_ref[:closed] = true if closed_ref
  gemguard_forget_gtk_window(name, window_ref, closed_ref) if window_ref.is_a?(Hash)
  return unless window

  if defined?(Gtk)
    Gtk.queue do
      begin
        window.hide if window.respond_to?(:hide)
        if window.respond_to?(:destroy)
          window.destroy
        elsif window.respond_to?(:close)
          window.close
        end
      rescue => error
        gemguard_gtk_debug "queued close failed: #{error.class}: #{error.message}"
      end
    end
  elsif window.respond_to?(:destroy)
    window.destroy
  elsif window.respond_to?(:hide)
    window.hide
  end
rescue
  nil
end

def gemguard_hide_gtk_window_now(window_ref, closed_ref = nil)
  window = window_ref.is_a?(Hash) ? window_ref[:window] : window_ref
  name = window_ref.is_a?(Hash) ? window_ref[:name].to_s : '(direct)'
  closed_ref[:closed] = true if closed_ref
  gemguard_forget_gtk_window(name, window_ref, closed_ref) if window_ref.is_a?(Hash)
  return unless window

  if defined?(Gtk)
    Gtk.queue do
      begin
        if window.respond_to?(:hide)
          window.hide
        elsif window.respond_to?(:iconify)
          window.iconify
        end
      rescue => error
        gemguard_gtk_debug "queued hide failed: #{error.class}: #{error.message}"
      end
    end
  elsif window.respond_to?(:hide)
    window.hide
  end
rescue
  nil
end

def gemguard_handle_gtk_delete_event(label, window_ref, closed_ref)
  gemguard_gtk_debug "#{label} delete_event"
  gemguard_gtk_debug "#{label} delete_event handled by script close"
  gemguard_close_gtk_window_now(window_ref, closed_ref)
  true
rescue => error
  gemguard_gtk_debug "#{label} delete_event close failed: #{error.class}: #{error.message}"
  true
end

def gemguard_close_all_gtk_windows_now
  windows = @gtk_windows.is_a?(Hash) ? @gtk_windows.values : []
  windows.reverse_each { |window| gemguard_close_gtk_window_now(window) }
  refs = @gtk_window_refs.is_a?(Array) ? @gtk_window_refs : []
  refs.reverse_each { |ref, closed| gemguard_close_gtk_window_now(ref, closed) }
  @gtk_windows = {}
  @gtk_window_refs = []
rescue
  nil
end

def gemguard_register_gtk_window_cleanup(window_ref, closed_ref)
  @gtk_windows = {} unless @gtk_windows.is_a?(Hash)
  @gtk_window_refs = [] unless @gtk_window_refs.is_a?(Array)
  @gtk_window_refs.reject! { |ref, closed| closed[:closed] || ref[:window].nil? }
  @gtk_window_refs << [window_ref, closed_ref]
  return if @gtk_cleanup_registered

  before_dying do
    begin
      gemguard_close_all_gtk_windows_now
    rescue
      nil
    end
  end if defined?(before_dying)
  @gtk_cleanup_registered = true
rescue
  nil
end

def gemguard_text_view(text = '', wrap = false)
  view = Gtk::TextView.new
  view.editable = false if view.respond_to?(:editable=)
  view.cursor_visible = false if view.respond_to?(:cursor_visible=)
  view.monospace = true if view.respond_to?(:monospace=)
  if defined?(Gtk::WrapMode) && view.respond_to?(:wrap_mode=)
    if wrap
      begin
        view.wrap_mode = Gtk::WrapMode::WORD_CHAR
      rescue
        view.wrap_mode = Gtk::WrapMode::WORD if defined?(Gtk::WrapMode::WORD)
      end
    else
      view.wrap_mode = Gtk::WrapMode::NONE
    end
  end
  view.buffer.text = text if view.respond_to?(:buffer) && view.buffer.respond_to?(:text=)
  view
end

def gemguard_set_text_view(view, text)
  return unless view && view.respond_to?(:buffer) && view.buffer

  if view.buffer.respond_to?(:text=)
    view.buffer.text = text.to_s
  elsif view.buffer.respond_to?(:set_text)
    view.buffer.set_text(text.to_s)
  end
rescue
  nil
end

def gemguard_set_tree_selection_multiple(selection)
  return unless selection

  if defined?(Gtk::SelectionMode::MULTIPLE)
    selection.mode = Gtk::SelectionMode::MULTIPLE
  elsif defined?(Gtk::SELECTION_MULTIPLE)
    selection.mode = Gtk::SELECTION_MULTIPLE
  elsif selection.respond_to?(:mode=)
    selection.mode = :multiple
  end
rescue
  nil
end

def gemguard_review_list_view(compact = false, &sort_handler)
  store = Gtk::ListStore.new(String, String, String, String, String, String)
  view = Gtk::TreeView.new(store)
  view.headers_visible = true if view.respond_to?(:headers_visible=)
  gemguard_set_tree_selection_multiple(view.selection) if view.respond_to?(:selection)

  columns = if compact
              [
                ['#', GEMGUARD_REVIEW_COLUMNS[:row], 32, nil],
                ['Gem', GEMGUARD_REVIEW_COLUMNS[:name], 148, 'name'],
                ['Value', GEMGUARD_REVIEW_COLUMNS[:value], 58, 'value'],
                ['Status', GEMGUARD_REVIEW_COLUMNS[:reason], 68, 'status'],
                ['Bag', GEMGUARD_REVIEW_COLUMNS[:container], 108, 'container']
              ]
            else
              [
                ['#', GEMGUARD_REVIEW_COLUMNS[:row], 36, nil],
                ['Gem', GEMGUARD_REVIEW_COLUMNS[:name], 170, 'name'],
                ['Value', GEMGUARD_REVIEW_COLUMNS[:value], 64, 'value'],
                ['Status', GEMGUARD_REVIEW_COLUMNS[:reason], 84, 'status'],
                ['Bag', GEMGUARD_REVIEW_COLUMNS[:container], 132, 'container']
              ]
            end

  columns.each do |title, column_index, width, sort_mode|
    renderer = Gtk::CellRendererText.new
    column = Gtk::TreeViewColumn.new(title, renderer, :text => column_index)
    column.resizable = true if column.respond_to?(:resizable=)
    column.fixed_width = width if width && column.respond_to?(:fixed_width=)
    if sort_mode && sort_handler
      column.clickable = true if column.respond_to?(:clickable=)
      column.signal_connect('clicked') { sort_handler.call(sort_mode) } if column.respond_to?(:signal_connect)
      column.set_tooltip_text("Sort by #{title.downcase}") if column.respond_to?(:set_tooltip_text)
    end
    view.append_column(column)
  end

  [view, store]
end

def gemguard_set_review_store(store, rows)
  return unless store

  store.clear if store.respond_to?(:clear)
  Array(rows).each_with_index do |row, index|
    iter = store.append
    value = row[:value].to_s.empty? ? '-' : row[:value].to_s
    iter[GEMGUARD_REVIEW_COLUMNS[:row]] = (index + 1).to_s
    iter[GEMGUARD_REVIEW_COLUMNS[:name]] = row[:name].to_s
    iter[GEMGUARD_REVIEW_COLUMNS[:value]] = value
    iter[GEMGUARD_REVIEW_COLUMNS[:reason]] = row[:reason].to_s
    iter[GEMGUARD_REVIEW_COLUMNS[:container]] = gemguard_table_container_label(row[:container])
    iter[GEMGUARD_REVIEW_COLUMNS[:id]] = row[:id].to_s
  end
rescue => error
  gemguard_gtk_debug "list refresh failed: #{error.class}: #{error.message}"
end

def gemguard_tree_path_for_index(index)
  if defined?(Gtk::TreePath) && Gtk::TreePath.respond_to?(:new_from_string)
    Gtk::TreePath.new_from_string(index.to_i.to_s)
  elsif defined?(Gtk::TreePath)
    Gtk::TreePath.new(index.to_i.to_s)
  else
    index.to_i
  end
rescue
  nil
end

def gemguard_follow_review_row(view, rows, row_id)
  row_id = row_id.to_s
  return false if row_id.empty? || !view

  index = Array(rows).index { |row| row[:id].to_s == row_id }
  return false unless index

  path = gemguard_tree_path_for_index(index)
  return false unless path

  if view.respond_to?(:scroll_to_cell)
    view.scroll_to_cell(path, nil, true, 0.5, 0.0)
  elsif view.respond_to?(:scroll_to_point)
    view.scroll_to_point(-1, index * 18)
  end
  true
rescue => error
  gemguard_gtk_debug "follow row failed: #{error.class}: #{error.message}"
  false
end

def gemguard_selected_review_ids(view)
  return [] unless view && view.respond_to?(:selection)

  ids = []
  selection = view.selection
  if selection.respond_to?(:selected_each)
    selection.selected_each do |_model, _path, iter|
      ids << iter[GEMGUARD_REVIEW_COLUMNS[:id]].to_s if iter
    end
  elsif selection.respond_to?(:selected_rows)
    selected = selection.selected_rows
    model = view.respond_to?(:model) ? view.model : nil
    paths = selected
    if selected.is_a?(Array) && selected.length == 2 && selected.first.respond_to?(:get_iter)
      model, paths = selected
    end
    Array(paths).each do |path|
      iter = model.get_iter(path) if model && model.respond_to?(:get_iter)
      ids << iter[GEMGUARD_REVIEW_COLUMNS[:id]].to_s if iter
    end
  end
  ids.reject(&:empty?).uniq
rescue => error
  gemguard_gtk_debug "selection read failed: #{error.class}: #{error.message}"
  []
end

def gemguard_review_row_marked?(row)
  !!row[:marked] || row[:reason].to_s =~ /\bmarked\b/i
rescue
  false
end

def gemguard_review_row_chrism?(row)
  !!row[:chrism] || row[:reason].to_s =~ /\bchrism\b/i
rescue
  false
end

def gemguard_review_row_orb?(row)
  !!row[:orb] || row[:reason].to_s =~ /\b(?:pure orb|orb)\b/i
rescue
  false
end

def gemguard_review_row_orb_tested_non_orb?(row)
  return false if gemguard_review_row_orb?(row)
  return false unless row[:orb_tested]

  row[:orb_test_result].to_s =~ /\A(?:not_orb|not orb)\z/i
rescue
  false
end

# Checks whether a Review row is a purified gem that is not an orb, chrism, or
# marked item. These rows can be moved into Will Sell by the Review button.
#
# @param row [Hash] Review row to check.
# @return [Boolean] true when the row is a purified non-orb gem.
def gemguard_review_row_purified_non_orb?(row)
  return false unless row
  return false if gemguard_review_row_marked?(row)
  return false if gemguard_review_row_chrism?(row)
  return false if gemguard_review_row_orb?(row)

  row[:purify_status].to_s =~ /\Apurified\z/i || row[:reason].to_s =~ /\Apurified\z/i
rescue
  false
end

# Looks at review gems for cobalt liquid and moves chrisms to the saved
# chrism container. This sends game commands, changes item containers, and saves
# chrism status back to GemGuard's inventory cache.
#
# @param rows [Array<Hash>] Review rows to inspect.
# @yield [done, total, row, summary] Reports progress after each inspected gem.
# @return [Hash] Sort counts and visible quality totals.
def gemguard_sort_chrisms_review_rows(rows)
  target = gemguard_chrism_container
  return { error: 'Chrism container is not set or was not found.' } unless target

  target_opened = []
  input_rows = Array(rows).compact.dup
  open_result = gemguard_dothistimeout("open ##{target.id}", 3, /open|already open|doesn't seem|could not find|locked|closed|shut/i, false).to_s
  target_opened << target unless open_result =~ /already open|doesn't seem|could not find|locked/i
  gemguard_dothistimeout("look in ##{target.id}", 3, GEMGUARD_LOOK_IN_DONE_RE, false)
  seen_ids = input_rows.map { |row| row[:id].to_s }.reject(&:empty?)
  target.contents.to_a.select { |item| gemguard_sellable_treasure_item?(item) }.each do |item|
    next if seen_ids.include?(item.id.to_s)

    reason = gemguard_item_chrism?(item) ? 'chrism' : 'protected'
    input_rows << gemguard_review_row(item, :keep, reason, target)
    seen_ids << item.id.to_s
  end
  candidates = gemguard_unique_review_rows(input_rows).reject { |row| row[:id].to_s.empty? || gemguard_review_row_marked?(row) }
  opened = chrism_sell_open_inventory_containers
  summary = {
    checked: 0,
    chrisms: 0,
    moved: 0,
    already_in_container: 0,
    normal: 0,
    missing: 0,
    stale: 0,
    failed: 0,
    quality_counts: Hash.new(0),
    fullness_counts: Hash.new(0),
    stopped_reason: nil
  }

  begin
    candidates.each_with_index do |row, index|
      break if gemguard_stop_requested?(true)

      item = chrism_sell_item_by_id(row[:id])
      unless item
        summary[:stale] += 1
        summary[:checked] += 1
        yield(index + 1, candidates.length, row, summary) if block_given?
        next
      end

      unless chrism_sell_drag_to_hand(item, false)
        summary[:failed] += 1
        summary[:checked] += 1
        yield(index + 1, candidates.length, row, summary) if block_given?
        next
      end

      look = gemguard_dothistimeout("look ##{item.id}", 2, GEMGUARD_CHRISM_LOOK_RE, false).to_s
      if look =~ /cobalt liquid/i
        already_target = row[:container_id].to_s == target.id.to_s ||
                         gemguard_normalize_container_name(row[:container]) == gemguard_normalize_container_name(gemguard_container_label(target))
        quality = gemguard_chrism_quality_from_look(look)
        gemguard_record_chrism_result(item, look)
        row[:chrism] = true
        row[:action] = :keep
        row[:reason] = 'chrism'
        row[:chrism_output] = look.to_s[0, 500]
        if quality
          row[:chrism_strength] = quality[:strength] unless quality[:strength].to_s.empty?
          row[:chrism_fullness] = quality[:fullness] unless quality[:fullness].to_s.empty?
        end
        row[:purify_status] = 'chrism' if row[:purify_status].to_s.empty? || row[:purify_status].to_s =~ /\A(?:ready|purified|stopped|failed|missing)\z/i
        summary[:chrisms] += 1
        summary[:quality_counts][quality[:strength] || 'unknown'] += 1 if quality
        summary[:fullness_counts][quality[:fullness] || 'unknown'] += 1 if quality

        put = gemguard_dothistimeout("_drag ##{item.id} ##{target.id}", 5, /You put|You add|could not|I could not|closed|full|unable|won't fit/i, false).to_s
        if put =~ /You put|You add/i
          row[:container_id] = target.id.to_s
          row[:container] = gemguard_container_label(target)
          if already_target
            summary[:already_in_container] += 1
          else
            summary[:moved] += 1
          end
        elsif put =~ /full|won't fit/i
          summary[:stopped_reason] = "#{gemguard_container_label(target)} is full."
          gemguard_return_item_after_mark(row, item, false) if chrism_sell_hand_id?(item.id)
          gemguard_request_stop
        else
          summary[:failed] += 1
          gemguard_return_item_after_mark(row, item, false) if chrism_sell_hand_id?(item.id)
        end
      else
        summary[:normal] += 1
        gemguard_return_item_after_mark(row, item, false) if chrism_sell_hand_id?(item.id)
      end

      summary[:checked] += 1
      gemguard_update_inventory_rows([row])
      yield(index + 1, candidates.length, row, summary) if block_given?
    end
  ensure
    chrism_sell_clear_hands(false)
    chrism_sell_close_inventory_containers(opened + target_opened)
  end

  summary
end

# Builds a short plain-language report for chrism sorting.
#
# @param summary [Hash] Counts returned by gemguard_sort_chrisms_review_rows.
# @return [String] Multi-line report text.
def gemguard_chrism_sort_summary_text(summary)
  return summary[:error].to_s if summary && summary[:error]

  summary ||= {}
  lines = []
  lines << (summary[:stopped_reason] ? "Chrism sort stopped: #{summary[:stopped_reason]}" : 'Chrism sort complete.')
  lines << "Checked: #{summary[:checked].to_i}"
  lines << "Chrisms found: #{summary[:chrisms].to_i}"
  lines << "Chrisms moved: #{summary[:moved].to_i}"
  lines << "Already in Chrisms: #{summary[:already_in_container].to_i}"
  lines << "Normal gems kept where they were: #{summary[:normal].to_i}"
  lines << "Skipped stale rows: #{summary[:stale].to_i}" if summary[:stale].to_i.positive?
  lines << "Missing or failed: #{summary[:missing].to_i + summary[:failed].to_i}"
  unless summary[:quality_counts].to_h.empty?
    lines << 'Cobalt liquid seen:'
    summary[:quality_counts].sort.each { |quality, count| lines << format('  %3d  %s', count, quality) }
  end
  unless summary[:fullness_counts].to_h.empty?
    lines << 'Chrism fullness seen:'
    summary[:fullness_counts].sort.each { |fullness, count| lines << format('  %3d  %s', count, fullness) }
  end
  lines.join("\n")
rescue
  'Chrism sort summary unavailable.'
end

def gemguard_pure_orb_sell_threshold
  gemguard_setting_value(:pure_orb_sell_threshold).gsub(/[^\d]/, '').to_i
rescue
  0
end

def gemguard_appraised_gem_sell_threshold
  gemguard_setting_value(:appraised_gem_sell_threshold).gsub(/[^\d]/, '').to_i
rescue
  0
end

def gemguard_sell_value_threshold
  return 0 unless gemguard_sell_value_confirm_enabled?

  gemguard_appraised_gem_sell_threshold
rescue
  0
end

def gemguard_sell_value_confirm_enabled?
  gemguard_truthy_value?(gemguard_setting_value(:sell_value_confirm_enabled))
rescue
  false
end

def gemguard_sell_value_ignore_protected?
  gemguard_sell_value_threshold.positive? && gemguard_truthy_value?(gemguard_setting_value(:sell_value_ignore_protected))
rescue
  false
end

# Checks whether purified non-orb gems can skip the sell-time value limit.
#
# @return [Boolean] true when sell-time value checking is enabled and the saved
#   setting allows purified non-orbs through it.
def gemguard_sell_purified_ignore_value?
  gemguard_sell_value_threshold.positive? && gemguard_truthy_value?(gemguard_setting_value(:sell_purified_ignore_value))
rescue
  false
end

def gemguard_review_value_amount(value)
  text = value.to_s.strip
  return nil if text.empty? || text =~ /\A[-?]\z/i || text =~ /too valuable|missing|n\/a|not gemshop/i

  text.gsub(/[^\d]/, '').to_i
rescue
  nil
end

# Checks whether an appraisal result means the gemshop refused the item.
#
# @param value [Object] Value text from the appraisal step.
# @return [Boolean] true when the item should not be treated as gemshop-priced.
def gemguard_not_gemshop_value?(value)
  value.to_s.strip =~ /\A(?:n\/a|not gemshop)\z/i
rescue
  false
end

# Checks whether a Review row is known to be refused by the gemshop.
#
# @param row [Hash] Review row to check.
# @return [Boolean] true when the row should be kept out of normal selling.
def gemguard_review_row_not_gemshop?(row)
  gemguard_not_gemshop_value?(row[:value]) || row[:reason].to_s =~ /\bnot gemshop\b/i
rescue
  false
end

def gemguard_review_row_orb_sellable?(row)
  return false unless gemguard_review_row_orb?(row)

  threshold = gemguard_pure_orb_sell_threshold
  return false unless threshold.positive?

  amount = gemguard_review_value_amount(row[:value])
  return false unless amount

  amount < threshold
rescue
  false
end

def gemguard_review_row_appraised_gem_sellable?(row)
  threshold = gemguard_appraised_gem_sell_threshold
  return false unless threshold.positive?
  return false if gemguard_review_row_marked?(row)
  return false if gemguard_review_row_chrism?(row)
  return false if gemguard_review_row_orb?(row)
  return false if gemguard_review_row_not_gemshop?(row)

  amount = gemguard_review_value_amount(row[:value])
  return false unless amount

  amount <= threshold
rescue
  false
end

def gemguard_review_row_appraised_gem_keepable?(row)
  threshold = gemguard_appraised_gem_sell_threshold
  return false unless threshold.positive?
  return false if gemguard_review_row_marked?(row)
  return false if gemguard_review_row_chrism?(row)
  return false if gemguard_review_row_orb?(row)
  return false if gemguard_review_row_not_gemshop?(row)

  amount = gemguard_review_value_amount(row[:value])
  return false unless amount

  amount > threshold
rescue
  false
end

# Returns the exact gem name used when saving a protected-list exception.
#
# @param row [Hash] Review row.
# @return [String] Full gem name without a grouped count suffix.
def gemguard_review_row_exception_name(row)
  row[:name].to_s.strip.sub(/\s*\(\d+\)\s*\z/, '')
rescue
  ''
end

# Checks whether a Review row is allowed through broad protected names.
#
# @param row [Hash] Review row.
# @param exceptions [Array<String>, nil] Exception names to check.
# @return [Boolean] true when the row's full name is excepted.
def gemguard_review_row_protection_exception?(row, exceptions = nil)
  gemguard_name_protection_exception?(gemguard_review_row_exception_name(row), exceptions)
rescue
  false
end

# Finds protected terms that match a Review row unless its exact name is excepted.
#
# @param row [Hash] Review row.
# @param protected_terms [Array<String>, nil] Protected terms to check.
# @param exceptions [Array<String>, nil] Exception names to check.
# @return [Array<String>] Matching protected terms.
def gemguard_review_row_matching_protected_terms(row, protected_terms = nil, exceptions = nil)
  return [] if gemguard_review_row_protection_exception?(row, exceptions)

  protected_terms ||= gemguard_protected_terms
  noun = row[:noun].to_s.downcase
  name = row[:name].to_s.downcase.sub(/\s*\(\d+\)\s*\z/, '')
  Array(protected_terms).select do |term|
    normalized = term.to_s.downcase.strip
    next false if normalized.empty?

    noun == normalized || name.include?(normalized)
  end
rescue
  []
end

# Checks whether protected terms keep a Review row.
#
# @param row [Hash] Review row.
# @param protected_terms [Array<String>, nil] Protected terms to check.
# @param exceptions [Array<String>, nil] Exception names to check.
# @return [Boolean] true when a protected term applies.
def gemguard_review_row_protected_by_term?(row, protected_terms = nil, exceptions = nil)
  gemguard_review_row_matching_protected_terms(row, protected_terms, exceptions).any?
rescue
  false
end

# Gives a Review row its normal status when a temporary action result should not
# stick to the gem.
#
# @param row [Hash] Review row to label.
# @param protected_terms [Array<String>, nil] Protected gem names to check.
# @return [String] Normal Review status for the row.
def gemguard_review_row_default_status(row, protected_terms = nil)
  return 'marked' if gemguard_review_row_marked?(row)
  return 'chrism' if gemguard_review_row_chrism?(row)
  return 'orb' if gemguard_review_row_orb?(row)
  return 'not gemshop' if gemguard_review_row_not_gemshop?(row)
  return 'protected' if gemguard_review_row_protected_by_term?(row, protected_terms)

  'not protected'
rescue
  row.to_h[:action].to_s == 'sell' ? 'not protected' : 'protected'
end

def gemguard_refresh_review_row_protection!(row, protected_terms = nil)
  protected_terms ||= gemguard_protected_terms
  if gemguard_review_row_marked?(row)
    row[:action] = :keep
    row[:reason] = 'marked'
  elsif gemguard_review_row_chrism?(row)
    row[:action] = :keep
    row[:reason] = 'chrism'
  elsif gemguard_review_row_orb?(row)
    row[:reason] = 'orb'
    row[:action] = gemguard_review_row_orb_sellable?(row) ? :sell : :keep
  elsif gemguard_review_row_not_gemshop?(row)
    row[:action] = :keep
    row[:reason] = 'not gemshop'
  elsif gemguard_review_row_protected_by_term?(row, protected_terms) && !gemguard_sell_value_ignore_protected?
    row[:action] = :keep
    row[:reason] = 'protected'
  elsif gemguard_review_row_appraised_gem_sellable?(row)
    row[:action] = :sell
    row[:reason] = 'within sell limit'
  elsif gemguard_review_row_appraised_gem_keepable?(row)
    row[:action] = :keep
    row[:reason] = 'over sell limit'
  else
    row[:action] = :sell
    row[:reason] = 'not protected'
  end
  row
rescue
  row
end

def gemguard_refresh_state_protection!(state, protected_terms = nil)
  return state unless state.is_a?(Hash)

  rows = gemguard_unique_review_rows(Array(state[:sell]) + Array(state[:keep]))
  rows.each { |row| gemguard_refresh_review_row_protection!(row, protected_terms) }
  state[:sell] = rows.select { |row| row[:action].to_s == 'sell' }
  state[:keep] = rows.reject { |row| row[:action].to_s == 'sell' }
  gemguard_update_inventory_rows(rows)
  state
rescue
  state
end

def gemguard_review_row_quality(row)
  score = 0
  score += 8 if gemguard_meaningful_review_value?(row[:value])
  score += 4 unless gemguard_placeholder_container_label?(row[:container])
  score += 2 unless row[:reason].to_s.empty?
  score += 1 unless row[:purify_status].to_s.empty?
  score
rescue
  0
end

def gemguard_unique_review_rows(rows)
  by_id = {}
  no_id = []
  Array(rows).compact.each do |row|
    id = row[:id].to_s
    if id.empty?
      no_id << row
      next
    end

    existing = by_id[id]
    by_id[id] = row if existing.nil? || gemguard_review_row_quality(row) >= gemguard_review_row_quality(existing)
  end
  by_id.values + no_id
end

def gemguard_dedupe_state!(state)
  return state unless state.is_a?(Hash)

  sell_rows = gemguard_unique_review_rows(state[:sell])
  sell_ids = sell_rows.map { |row| row[:id].to_s }.reject(&:empty?)
  keep_rows = gemguard_unique_review_rows(state[:keep]).reject { |row| sell_ids.include?(row[:id].to_s) }
  state[:sell] = sell_rows
  state[:keep] = keep_rows
  state[:purify] = gemguard_unique_review_rows(state[:purify])
  state
rescue
  state
end

# Applies saved value rules to the current Review rows and updates cached row
# actions.
#
# @param state [Hash] Current sell, keep, and purify rows.
# @return [Hash] Counts moved to sell and keep.
def gemguard_apply_sell_policy_to_state(state)
  result = { to_sell: 0, to_keep: 0 }
  return result unless state.is_a?(Hash)

  original_side = {}
  Array(state[:sell]).each { |row| original_side[row[:id].to_s] = :sell unless row[:id].to_s.empty? }
  Array(state[:keep]).each { |row| original_side[row[:id].to_s] ||= :keep unless row[:id].to_s.empty? }

  sell_rows = []
  keep_rows = []
  gemguard_unique_review_rows(Array(state[:sell]) + Array(state[:keep])).each do |row|
    if gemguard_review_row_marked?(row)
      row[:action] = :keep
      row[:reason] = 'marked'
      keep_rows << row
    elsif gemguard_review_row_chrism?(row)
      row[:action] = :keep
      row[:reason] = 'chrism'
      keep_rows << row
    elsif gemguard_review_row_orb?(row)
      if gemguard_review_row_orb_sellable?(row)
        row[:action] = :sell
        row[:reason] = 'orb'
        sell_rows << row
      else
        row[:action] = :keep
        row[:reason] = 'orb'
        keep_rows << row
      end
    elsif gemguard_review_row_not_gemshop?(row)
      row[:action] = :keep
      row[:reason] = 'not gemshop'
      keep_rows << row
    elsif gemguard_review_row_appraised_gem_sellable?(row)
      row[:action] = :sell
      row[:reason] = 'within sell limit'
      sell_rows << row
    elsif gemguard_review_row_appraised_gem_keepable?(row)
      row[:action] = :keep
      row[:reason] = 'over sell limit'
      keep_rows << row
    elsif original_side[row[:id].to_s] == :sell
      row[:action] = :sell
      sell_rows << row
    else
      row[:action] = :keep
      keep_rows << row
    end
  end

  state[:sell] = sell_rows
  state[:keep] = keep_rows
  result[:to_sell] = sell_rows.count { |row| original_side[row[:id].to_s] == :keep }
  result[:to_keep] = keep_rows.count { |row| original_side[row[:id].to_s] == :sell }
  gemguard_update_inventory_rows(sell_rows + keep_rows)
  result
rescue
  { to_sell: 0, to_keep: 0 }
end

def gemguard_sell_policy_text(policy)
  policy ||= {}
  to_sell = policy[:to_sell].to_i
  to_keep = policy[:to_keep].to_i
  "#{to_sell} moved to sell, #{to_keep} moved to keep by saved value limit."
rescue
  '0 moved to sell, 0 moved to keep by saved value limit.'
end

def gemguard_commas(number)
  number.to_i.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1,').reverse
rescue
  number.to_s
end

def gemguard_sort_rows!(rows, mode, reverse = false)
  list = Array(rows)
  case mode.to_s
  when 'name'
    list.sort_by! { |row| [row[:name].to_s.downcase, row[:reason].to_s.downcase] }
  when 'status'
    list.sort_by! { |row| [row[:reason].to_s.downcase, row[:name].to_s.downcase] }
  when 'container'
    list.sort_by! { |row| [row[:container].to_s.downcase, row[:name].to_s.downcase] }
  when 'value'
    priced, unpriced = list.partition { |row| gemguard_review_value_amount(row[:value]) }
    priced.sort_by! { |row| [gemguard_review_value_amount(row[:value]).to_i, row[:name].to_s.downcase] }
    priced.reverse! if reverse
    unpriced.sort_by! { |row| [row[:name].to_s.downcase, row[:reason].to_s.downcase] }
    list = priced + unpriced
    rows.replace(list) if rows.respond_to?(:replace)
    return rows
  end
  list.reverse! if reverse
  rows.replace(list) if rows.respond_to?(:replace)
  list
rescue
  rows
end

def gemguard_sort_state!(state, mode, reverse = false)
  return unless state.is_a?(Hash)

  gemguard_sort_rows!(state[:sell], mode, reverse)
  gemguard_sort_rows!(state[:keep], mode, reverse)
  gemguard_sort_rows!(state[:purify], mode, reverse)
end

def gemguard_meaningful_review_value?(value)
  text = value.to_s.strip
  return false if text.empty? || text == '-' || text =~ /\A(?:missing|failed|n\/a|not gemshop|\?)\z/i

  true
rescue
  false
end

def gemguard_sync_rows_from_review!(target_rows, review_rows)
  lookup = {}
  Array(review_rows).each do |row|
    id = row[:id].to_s
    lookup[id] = row unless id.empty?
  end

  Array(target_rows).each do |row|
    source = lookup[row[:id].to_s]
    next unless source

    row[:value] = source[:value] if gemguard_meaningful_review_value?(source[:value])
    row[:container_id] = source[:container_id] unless source[:container_id].to_s.empty?
    row[:container] = source[:container] unless gemguard_placeholder_container_label?(source[:container])
    [:marked, :chrism, :orb].each do |key|
      value = source[key]
      row[key] = value unless value.nil? || value.to_s.empty?
    end
    row[:purify_status] = source[:purify_status] if gemguard_meaningful_purify_status?(source[:purify_status])
    if gemguard_meaningful_purify_status?(source[:purify_status])
      row[:reason] = source[:purify_status].to_s
    elsif gemguard_review_row_chrism?(source)
      row[:reason] = 'chrism'
    elsif gemguard_review_row_orb?(source)
      row[:reason] = 'orb'
    elsif gemguard_review_row_marked?(source)
      row[:reason] = 'marked'
    end
  end
  target_rows
rescue => error
  gemguard_gtk_debug "review row sync failed: #{error.class}: #{error.message}"
  target_rows
end

# Copies newer item status and bag labels from one row list into another. This is
# used when Purify changes a gem so the Review tab can immediately show the same
# orb, chrism, purified, and container information.
#
# @param target_rows [Array<Hash>] Rows to update in place.
# @param source_rows [Array<Hash>] Rows with newer item details.
# @return [Array<Hash>] Updated target rows.
def gemguard_sync_review_rows_from_source!(target_rows, source_rows)
  lookup = {}
  Array(source_rows).each do |row|
    id = row[:id].to_s
    lookup[id] = row unless id.empty?
  end

  Array(target_rows).each do |row|
    source = lookup[row[:id].to_s]
    next unless source

    if source[:clear_value]
      row[:value] = ''
      row[:clear_value] = true
    elsif gemguard_meaningful_review_value?(source[:value])
      row[:value] = source[:value]
    end
    row[:container_id] = source[:container_id] unless source[:container_id].to_s.empty?
    row[:container] = source[:container] unless gemguard_placeholder_container_label?(source[:container])
    [:marked, :chrism, :orb, :orb_tested].each do |key|
      value = source[key]
      row[key] = value unless value.nil? || value.to_s.empty?
    end
    [:orb_test_result, :orb_test_method, :orb_tested_at, :orb_test_output].each do |key|
      row[key] = source[key] unless source[key].to_s.empty?
    end
    row[:purify_status] = source[:purify_status] if gemguard_meaningful_purify_status?(source[:purify_status])
    if gemguard_review_row_chrism?(row)
      row[:action] = :keep
      row[:reason] = 'chrism'
    elsif gemguard_review_row_orb?(row)
      row[:action] = gemguard_review_row_orb_sellable?(row) ? :sell : :keep
      row[:reason] = 'orb'
    elsif gemguard_meaningful_purify_status?(row[:purify_status])
      row[:reason] = row[:purify_status].to_s
    end
  end
  target_rows
rescue => error
  gemguard_gtk_debug "source row sync failed: #{error.class}: #{error.message}"
  target_rows
end

def gemguard_value_summary(rows)
  known = 0
  unknown = 0
  total = 0
  Array(rows).each do |row|
    amount = gemguard_review_value_amount(row[:value])
    if amount
      known += 1
      total += amount
    else
      unknown += 1
    end
  end
  { count: Array(rows).length, known: known, unknown: unknown, total: total }
end

# Builds the Review tab summary text.
#
# @param state [Hash] Current sell and keep rows.
# @return [String] Summary for the Review report box.
def gemguard_review_report(state)
  report_state = {
    sell: gemguard_unique_review_rows(state[:sell]),
    keep: gemguard_unique_review_rows(state[:keep])
  }
  sell_ids = report_state[:sell].map { |row| row[:id].to_s }.reject(&:empty?)
  report_state[:keep].reject! { |row| sell_ids.include?(row[:id].to_s) }
  sell = gemguard_value_summary(report_state[:sell])
  keep = gemguard_value_summary(report_state[:keep])
  keep_statuses = {}
  Array(report_state[:keep]).each do |row|
    status = row[:reason].to_s.empty? ? 'unknown' : row[:reason].to_s
    keep_statuses[status] ||= { count: 0, known: 0, unknown: 0, total: 0 }
    keep_statuses[status][:count] += 1
    amount = gemguard_review_value_amount(row[:value])
    if amount
      keep_statuses[status][:known] += 1
      keep_statuses[status][:total] += amount
    else
      keep_statuses[status][:unknown] += 1
    end
  end
  status_text = keep_statuses.sort_by { |status, _data| status.downcase }.map do |status, data|
    "#{status}: #{data[:count]} kept | #{data[:known]} appraised = #{gemguard_commas(data[:total])} silver | #{data[:unknown]} unpriced"
  end
  status_text = ['none'] if status_text.empty?
  gem_counts = Hash.new(0)
  Array(report_state[:sell]).concat(Array(report_state[:keep])).each do |row|
    name = row[:name].to_s.strip
    next if name.empty?

    gem_counts[name.downcase] += 1
  end
  gem_count_lines = gem_counts.sort_by { |name, count| [-count.to_i, name] }.map { |name, count| format('  %3d  %s', count, name) }
  gem_count_lines = ['  none'] if gem_count_lines.empty?

  [
    "Will Sell: #{sell[:count]} gems | #{sell[:known]} appraised = #{gemguard_commas(sell[:total])} silver | #{sell[:unknown]} unpriced",
    "Will Keep: #{keep[:count]} gems | #{keep[:known]} appraised = #{gemguard_commas(keep[:total])} silver | #{keep[:unknown]} unpriced",
    '',
    'Keep Status:',
    *status_text.map { |line| "  #{line}" },
    '',
    'Gem Counts:',
    *gem_count_lines
  ].join("\n")
rescue
  'Report unavailable.'
end

def gemguard_table_container_label(container)
  text = container.to_s.strip
  return '(unknown)' if text.empty?

  clean = text.sub(/\A(?:a|an|the)\s+/i, '')
  return clean if clean.length <= 22

  if clean =~ /\b(gem pouch|knapsack|sack|pouch|pack|bag|satchel|case|box|coffer|chest|jar|basket|trunk)\b/i
    noun = Regexp.last_match(1)
    descriptor = clean.split(/\s+/).first.to_s
    return noun if descriptor.empty? || noun.downcase.start_with?(descriptor.downcase)

    "#{descriptor} #{noun}"
  else
    clean[0, 22]
  end
rescue
  container.to_s
end

def gemguard_selected_review_rows_from_state(state, views)
  ids = Array(views).flat_map { |view| gemguard_selected_review_ids(view) }.map(&:to_s).reject(&:empty?).uniq
  rows = Array(state[:sell]) + Array(state[:keep])
  rows.select { |row| ids.include?(row[:id].to_s) }
rescue => error
  gemguard_gtk_debug "selected row lookup failed: #{error.class}: #{error.message}"
  []
end

def gemguard_protected_list_view(term_title = 'Protected Term')
  store = Gtk::ListStore.new(String, String)
  view = Gtk::TreeView.new(store)
  view.headers_visible = true if view.respond_to?(:headers_visible=)
  gemguard_set_tree_selection_multiple(view.selection) if view.respond_to?(:selection)

  [
    ['#', GEMGUARD_PROTECTED_COLUMNS[:row], 56],
    [term_title, GEMGUARD_PROTECTED_COLUMNS[:term], 640]
  ].each do |title, column_index, width|
    renderer = Gtk::CellRendererText.new
    column = Gtk::TreeViewColumn.new(title, renderer, :text => column_index)
    column.resizable = true if column.respond_to?(:resizable=)
    column.fixed_width = width if width && column.respond_to?(:fixed_width=)
    view.append_column(column)
  end

  [view, store]
end

def gemguard_set_protected_store(store, terms)
  return unless store

  store.clear if store.respond_to?(:clear)
  Array(terms).sort_by(&:downcase).each_with_index do |term, index|
    iter = store.append
    iter[GEMGUARD_PROTECTED_COLUMNS[:row]] = (index + 1).to_s
    iter[GEMGUARD_PROTECTED_COLUMNS[:term]] = term.to_s
  end
rescue => error
  gemguard_gtk_debug "protected list refresh failed: #{error.class}: #{error.message}"
end

def gemguard_selected_protected_terms(view)
  return [] unless view && view.respond_to?(:selection)

  terms = []
  selection = view.selection
  if selection.respond_to?(:selected_each)
    selection.selected_each do |_model, _path, iter|
      terms << iter[GEMGUARD_PROTECTED_COLUMNS[:term]].to_s if iter
    end
  elsif selection.respond_to?(:selected_rows)
    selected = selection.selected_rows
    model = view.respond_to?(:model) ? view.model : nil
    paths = selected
    if selected.is_a?(Array) && selected.length == 2 && selected.first.respond_to?(:get_iter)
      model, paths = selected
    end
    Array(paths).each do |path|
      iter = model.get_iter(path) if model && model.respond_to?(:get_iter)
      terms << iter[GEMGUARD_PROTECTED_COLUMNS[:term]].to_s if iter
    end
  end
  terms.map(&:strip).reject(&:empty?).uniq { |term| term.downcase }
rescue => error
  gemguard_gtk_debug "protected selection read failed: #{error.class}: #{error.message}"
  []
end

def gemguard_scroller(widget, width = nil, height = nil)
  scroller = Gtk::ScrolledWindow.new
  scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::AUTOMATIC) if scroller.respond_to?(:set_policy)
  scroller.width_request = width if width && scroller.respond_to?(:width_request=)
  scroller.height_request = height if height && scroller.respond_to?(:height_request=)
  scroller.add(widget)
  scroller
end

def gemguard_set_label(label, text)
  label.text = text.to_s if label && label.respond_to?(:text=)
rescue
  nil
end

def gemguard_set_progress_bar(bar, done, total)
  return unless bar

  total = total.to_i
  done = done.to_i
  fraction = total.positive? ? done.to_f / total.to_f : 0.0
  fraction = 0.0 if fraction.negative?
  fraction = 1.0 if fraction > 1.0
  bar.fraction = fraction if bar.respond_to?(:fraction=)
  bar.text = total.positive? ? "#{done}/#{total}" : '' if bar.respond_to?(:text=)
  bar.show_text = true if bar.respond_to?(:show_text=)
rescue
  nil
end

def gemguard_set_tooltip(widget, text)
  return unless widget

  widget.instance_variable_set(:@gemguard_tooltip_text, text.to_s) if widget.respond_to?(:instance_variable_set)
  if widget.respond_to?(:tooltip_text=)
    widget.tooltip_text = text.to_s
  elsif widget.respond_to?(:set_tooltip_text)
    widget.set_tooltip_text(text.to_s)
  end
rescue
  nil
end

def gemguard_set_sensitive(widget, enabled)
  return unless widget

  if widget.respond_to?(:sensitive=)
    widget.sensitive = !!enabled
  elsif widget.respond_to?(:set_sensitive)
    widget.set_sensitive(!!enabled)
  end
rescue
  nil
end

def gemguard_button_label(widget)
  return widget.label.to_s if widget && widget.respond_to?(:label)

  ''
rescue
  ''
end

def gemguard_set_button_label(widget, text)
  return unless widget

  if widget.respond_to?(:label=)
    widget.label = text.to_s
  elsif widget.respond_to?(:set_label)
    widget.set_label(text.to_s)
  end
rescue
  nil
end

def gemguard_entry_row(label_text, value = '')
  row = Gtk::Box.new(:horizontal, 8)
  label = Gtk::Label.new(label_text)
  label.xalign = 0 if label.respond_to?(:xalign=)
  label.set_size_request(160, -1) if label.respond_to?(:set_size_request)
  entry = Gtk::Entry.new
  entry.text = value.to_s if entry.respond_to?(:text=)
  row.pack_start(label, :expand => false, :fill => false)
  row.pack_start(entry, :expand => true, :fill => true)
  [row, entry]
end

def gemguard_set_container_dropdown_choices(combo, choices, selected = nil, allow_none = true)
  return unless combo

  if combo.respond_to?(:remove_all)
    combo.remove_all
  elsif combo.respond_to?(:model) && combo.model
    combo.model.clear
  end

  list = gemguard_unique_container_choices(choices)
  selected = selected.to_s.strip
  selected_index = list.index { |choice| gemguard_choice_matches?(choice, selected) }
  value_map = {}
  if allow_none
    list.unshift(gemguard_container_choice(GEMGUARD_NONE_LABEL, ''))
    active_index = selected_index ? selected_index + 1 : 0
  else
    list.unshift(gemguard_container_choice(selected, selected)) unless selected.empty? || selected_index
    active_index = list.index { |choice| gemguard_choice_matches?(choice, selected) } || 0
  end

  list.each do |choice|
    display = gemguard_choice_display(choice)
    value_map[display] = gemguard_choice_value(choice)
    combo.append_text(display) if combo.respond_to?(:append_text)
  end
  combo.instance_variable_set(:@gemguard_choice_values, value_map)
  combo.active = active_index if combo.respond_to?(:active=) && !list.empty?
rescue
  nil
end

def gemguard_container_dropdown_row(label_text, value = '', choices = [], allow_none = true)
  row = Gtk::Box.new(:horizontal, 8)
  label = Gtk::Label.new(label_text)
  label.xalign = 0 if label.respond_to?(:xalign=)
  label.set_size_request(160, -1) if label.respond_to?(:set_size_request)
  combo = Gtk::ComboBoxText.new
  gemguard_set_container_dropdown_choices(combo, choices, value, allow_none)
  row.pack_start(label, :expand => false, :fill => false)
  row.pack_start(combo, :expand => true, :fill => true)
  [row, combo]
rescue
  gemguard_entry_row(label_text, value)
end

# Builds a dropdown row for lapidary design patterns.
#
# @param label_text [String] Label shown beside the dropdown.
# @param value [String] Selected pattern value.
# @return [Array] GTK row and control.
def gemguard_lapidary_pattern_dropdown_row(label_text, value = '')
  row = Gtk::Box.new(:horizontal, 8)
  label = Gtk::Label.new(label_text)
  label.xalign = 0 if label.respond_to?(:xalign=)
  label.set_size_request(160, -1) if label.respond_to?(:set_size_request)
  combo = Gtk::ComboBoxText.new
  gemguard_set_container_dropdown_choices(combo, gemguard_lapidary_pattern_choices(value), value, true)
  row.pack_start(label, :expand => false, :fill => false)
  row.pack_start(combo, :expand => true, :fill => true)
  [row, combo]
rescue
  gemguard_entry_row(label_text, value)
end

def gemguard_control_text(control)
  if control.respond_to?(:active_text)
    display = control.active_text.to_s.strip
    values = control.instance_variable_get(:@gemguard_choice_values) rescue nil
    value = values.is_a?(Hash) ? values.fetch(display, display) : display
  elsif control.respond_to?(:text)
    value = control.text.to_s.strip
  else
    value = ''
  end
  value == GEMGUARD_NONE_LABEL ? '' : value
rescue
  ''
end

# Opens the main GemGuard GTK window and handles Review, Settings, Protected
# List, and Purify tab actions. This sends game commands, changes settings,
# changes cached gem data, and closes the scan snapshot when the window exits.
#
# @return [void]
def gemguard_review_window
  unless defined?(Gtk)
    echo 'gemguard: GTK is not available in this session.'
    return
  end

  window_ref = { window: nil }
  closed_ref = { closed: false }
  requested = { action: nil }
  sort_state = { mode: nil, reverse: false }
  gemguard_load_inventory_statuses!
  state = { sell: [], keep: [], purify: [] }
  widgets = {}
  gemguard_register_gtk_window_cleanup(window_ref, closed_ref)
  update_mark_buttons = nil
  current_purify_settings = nil

  refresh_text = proc do |follow_id = nil|
    Gtk.queue do
      next unless gemguard_gtk_window_open?(window_ref)
      gemguard_dedupe_state!(state)
      gemguard_set_review_store(widgets[:sell_store], state[:sell])
      gemguard_set_review_store(widgets[:keep_store], state[:keep])
      if follow_id
        followed = gemguard_follow_review_row(widgets[:sell_view], state[:sell], follow_id)
        gemguard_follow_review_row(widgets[:keep_view], state[:keep], follow_id) unless followed
      end
      gemguard_set_label(widgets[:sell_count], "Will Sell: #{state[:sell].length}")
      gemguard_set_label(widgets[:keep_count], "Will Keep: #{state[:keep].length}")
      gemguard_set_text_view(widgets[:report], gemguard_review_report(state))
      settings = chrism_sell_load_eloot_settings
      excludes = chrism_sell_eloot_excludes(settings)
      protected_terms = gemguard_protected_terms
      protected_exceptions = gemguard_protected_exceptions
      gemguard_set_protected_store(widgets[:protected_store], protected_terms)
      gemguard_set_protected_store(widgets[:exception_store], protected_exceptions)
      installed = protected_terms.count { |term| excludes.any? { |existing| existing.downcase == term.downcase } }
      gemguard_set_label(widgets[:protected_count], "Protected: #{protected_terms.length}    Exceptions: #{protected_exceptions.length}    ELoot: #{installed}/#{protected_terms.length}")
      gemguard_set_review_store(widgets[:purify_store], state[:purify]) if widgets[:purify_store]
      gemguard_set_label(widgets[:purify_count], "Purify: #{state[:purify].length}") if widgets[:purify_count]
      update_mark_buttons.call if update_mark_buttons
    end
  end

  set_status = proc do |text|
    Gtk.queue { gemguard_set_label(widgets[:status], text) if gemguard_gtk_window_open?(window_ref) }
  end

  set_purify_status = proc do |text|
    Gtk.queue { gemguard_set_label(widgets[:purify_status], text) if gemguard_gtk_window_open?(window_ref) && widgets[:purify_status] }
  end

  set_purify_report = proc do |text|
    Gtk.queue { gemguard_set_label(widgets[:purify_report], text) if gemguard_gtk_window_open?(window_ref) && widgets[:purify_report] }
  end

  set_purify_progress = proc do |text, done = nil, total = nil|
    widgets[:purify_progress_text_value] = text.to_s
    Gtk.queue do
      next unless gemguard_gtk_window_open?(window_ref)

      gemguard_set_text_view(widgets[:purify_progress_text], text) if widgets[:purify_progress_text]
      gemguard_set_progress_bar(widgets[:purify_progress_bar], done, total) if widgets[:purify_progress_bar] && !done.nil? && !total.nil?
    end
  end

  stop_purify_clock = proc do
    widgets.delete(:purify_clock_state)
    timer = widgets.delete(:purify_clock_timer)
    GLib::Source.remove(timer) if timer && defined?(GLib::Source) && GLib::Source.respond_to?(:remove)
  rescue
    widgets.delete(:purify_clock_timer)
  end

  start_purify_clock = proc do |clock_state|
    widgets[:purify_clock_state] = clock_state
    next if widgets[:purify_clock_timer]

    widgets[:purify_clock_timer] = GLib::Timeout.add(1000) do
      live = widgets[:purify_clock_state]
      unless gemguard_gtk_window_open?(window_ref) && live && live[:active]
        widgets.delete(:purify_clock_timer)
        false
      else
        set_purify_progress.call(
          gemguard_purify_progress_text(
            live[:prefix],
            live[:done],
            live[:total],
            live[:row],
            live[:kind],
            live[:summary],
            live[:timing]
          ),
          live[:done],
          live[:total]
        )
        true
      end
    end
  rescue => error
    gemguard_gtk_debug "purify clock failed: #{error.class}: #{error.message}"
  end

  start_action_button = proc do |button|
    next unless button

    widgets[:active_action_button] = button
    button.instance_variable_set(:@gemguard_original_label, gemguard_button_label(button))
    button.instance_variable_set(:@gemguard_original_tooltip, button.instance_variable_get(:@gemguard_tooltip_text).to_s) if button.instance_variable_defined?(:@gemguard_tooltip_text)
    Gtk.queue do
      gemguard_set_button_label(button, 'Stop')
      gemguard_set_tooltip(button, 'Ask this action to stop after the gem in hand is cleaned up.')
    end
  end

  finish_action_button = proc do
    button = widgets.delete(:active_action_button)
    next unless button

    original = button.instance_variable_get(:@gemguard_original_label).to_s
    tooltip = button.instance_variable_get(:@gemguard_original_tooltip).to_s
    Gtk.queue do
      gemguard_set_button_label(button, original.empty? ? 'Done' : original)
      gemguard_set_tooltip(button, tooltip) unless tooltip.empty?
    end
  end

  queue_action = proc do |button, action_value|
    if widgets[:active_action_button] == button
      gemguard_request_stop
      set_status.call('Stop requested. GemGuard will finish the current gem cleanup, then stop.')
      set_purify_status.call('Stop requested. Finishing the gem in hand, then stopping.')
      current_progress = widgets[:purify_progress_text_value].to_s
      stop_note = "Stop requested.\n\nGemGuard will finish the gem it is holding, put it away, then stop before grabbing another gem."
      combined_progress = current_progress.empty? ? stop_note : current_progress
      combined_progress = "#{combined_progress.rstrip}\n\n#{stop_note}" unless combined_progress.include?('Stop requested.')
      set_purify_progress.call(combined_progress)
    else
      requested[:action] = action_value
      requested[:button] = button
    end
  end

  close_review_window = proc do
    gemguard_request_stop
    requested[:action] = :close_window
    gemguard_close_gtk_window_now(window_ref, closed_ref)
  end

  update_mark_buttons = proc do
    Gtk.queue do
      next unless gemguard_gtk_window_open?(window_ref)

      selected_rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
      can_mark = selected_rows.any? { |row| !gemguard_review_row_marked?(row) }
      can_unmark = selected_rows.any? { |row| gemguard_review_row_marked?(row) }
      gemguard_set_sensitive(widgets[:mark_button], can_mark)
      gemguard_set_sensitive(widgets[:unmark_button], can_unmark)
      gemguard_set_sensitive(widgets[:protect_selected_button], selected_rows.any?)
      gemguard_set_sensitive(widgets[:review_cut_selected_button], selected_rows.any? && !gemguard_setting_value(:lapidary_box).to_s.empty?) if widgets[:review_cut_selected_button]
      gemguard_set_sensitive(widgets[:sort_chrisms_button], (state[:sell] + state[:keep]).any? && !gemguard_setting_value(:chrism_container).to_s.empty?)
      protected_terms = gemguard_protected_terms
      protected_selected = selected_rows.any? { |row| gemguard_review_row_protected_by_term?(row, protected_terms) }
      unprotected_selected = selected_rows.any? { |row| !gemguard_review_row_protected_by_term?(row, protected_terms) }
      if protected_selected && unprotected_selected
        gemguard_set_button_label(widgets[:protect_selected_button], 'Toggle Protection')
        gemguard_set_tooltip(widgets[:protect_selected_button], 'Flip each selected gem: protected gems become unprotected, and unprotected gems become protected.')
      elsif protected_selected
        gemguard_set_button_label(widgets[:protect_selected_button], 'Unprotect Selected')
        gemguard_set_tooltip(widgets[:protect_selected_button], 'Remove the selected gem names from GemGuard protection.')
      else
        gemguard_set_button_label(widgets[:protect_selected_button], 'Protect Selected')
        gemguard_set_tooltip(widgets[:protect_selected_button], 'Add selected gem names to the protected list.')
      end
      orb_testable_selected = selected_rows.any? do |row|
        !gemguard_review_row_chrism?(row) && !gemguard_review_row_orb?(row) && !gemguard_review_row_orb_tested_non_orb?(row)
      end
      gemguard_set_sensitive(widgets[:orb_test_button], gemguard_orb_test_mode != :disabled && orb_testable_selected)
      purify_settings = current_purify_settings ? current_purify_settings.call : nil
      selected_purify_ids = gemguard_selected_review_ids(widgets[:purify_view])
      selected_purify_rows = state[:purify].select { |row| selected_purify_ids.include?(row[:id].to_s) }
      gemguard_set_sensitive(widgets[:purify_selected_button], gemguard_bard? && selected_purify_rows.any? { |row| gemguard_cached_purify_candidate?(row, purify_settings) })
      gemguard_set_sensitive(widgets[:purify_all_button], gemguard_bard? && state[:purify].any? { |row| gemguard_cached_purify_candidate?(row, purify_settings) })
      gemguard_set_sensitive(widgets[:move_purified_to_sell], Array(state[:keep]).any? { |row| gemguard_review_row_purified_non_orb?(row) }) if widgets[:move_purified_to_sell]
    end
  rescue => error
    gemguard_gtk_debug "mark button update failed: #{error.class}: #{error.message}"
  end

  Gtk.queue do
    begin
      window = Gtk::Window.new(:toplevel)
      gemguard_remember_gtk_window('Review', window, window_ref)
      window.title = gemguard_window_title('GemGuard Review')
      window.border_width = 10 if window.respond_to?(:border_width=)
      window.set_position(Gtk::WindowPosition::CENTER) if defined?(Gtk::WindowPosition) && window.respond_to?(:set_position)
      window.set_default_size(1040, 640) if window.respond_to?(:set_default_size)

      notebook = defined?(Gtk::Notebook) ? Gtk::Notebook.new : Gtk::Box.new(:vertical, 6)
      status = Gtk::Label.new('Scan containers to build a review list.')
      report = gemguard_text_view("Will Sell: 0 gems | 0 appraised = 0 silver | 0 unpriced\nWill Keep: 0 gems | 0 appraised = 0 silver | 0 unpriced\n\nKeep Status:\n  scan or appraise gems to build totals\n\nGem Counts:\n  none", true)
      status.xalign = 0 if status.respond_to?(:xalign=)
      status.line_wrap = true if status.respond_to?(:line_wrap=)
      widgets[:status] = status
      widgets[:report] = report

      scan_button = Gtk::Button.new(:label => 'Scan Gem Containers')
      appraise_button = Gtk::Button.new(:label => 'Appraise All')
      sell_button = Gtk::Button.new(:label => 'Sell Approved')
      protect_selected_button = Gtk::Button.new(:label => 'Protect Selected')
      sort_chrisms_button = Gtk::Button.new(:label => 'Sort Chrisms')
      review_cut_selected = Gtk::Button.new(:label => 'Cut Selected')
      orb_test_button = Gtk::Button.new(:label => gemguard_orb_test_label)
      mark_button = Gtk::Button.new(:label => 'Mark Selected')
      unmark_button = Gtk::Button.new(:label => 'Unmark Selected')
      close_button = Gtk::Button.new(:label => 'Close')
      move_to_keep = Gtk::Button.new(:label => 'Move Selected To Keep')
      move_to_sell = Gtk::Button.new(:label => 'Move Selected To Sell')
      move_purified_to_sell = Gtk::Button.new(:label => 'Move Purified To Sell')
      widgets[:scan_button] = scan_button
      widgets[:move_purified_to_sell] = move_purified_to_sell

      gemguard_set_tooltip(scan_button, 'Open your gem containers, read the gems inside, and build the sell and keep lists.')
      gemguard_set_tooltip(appraise_button, 'Ask the gemshop value for every listed gem and show the price in the Value column.')
      gemguard_set_tooltip(sell_button, 'Sell only the gems currently shown on the Will Sell side.')
      gemguard_set_tooltip(protect_selected_button, 'Add selected gem names to the protected list and scan again.')
      gemguard_set_tooltip(sort_chrisms_button, 'Look at listed gems for cobalt liquid, mark chrisms, and move them to the chrism bag.')
      gemguard_set_tooltip(review_cut_selected, 'Cut selected Review gems with the saved Gemcutter patterns.')
      gemguard_set_tooltip(orb_test_button, gemguard_orb_test_tooltip)
      gemguard_set_tooltip(mark_button, 'Mark selected gems as unsellable. GemGuard will hold each one, mark it, stow it, and scan again.')
      gemguard_set_tooltip(unmark_button, 'Remove the unsellable mark from selected gems. GemGuard will hold each one, unmark it, stow it, and scan again.')
      gemguard_set_tooltip(close_button, 'Close this window and stop GemGuard.')
      gemguard_set_tooltip(move_to_keep, 'Move selected gems out of the sell list for this review only.')
      gemguard_set_tooltip(move_to_sell, 'Move selected gems into the sell list for this review only.')
      gemguard_set_tooltip(move_purified_to_sell, 'Move all purified non-orb gems into the sell list for review.')

      header_sort = proc do |mode|
        mode = mode.to_s
        sort_state[:reverse] = sort_state[:mode] == mode ? !sort_state[:reverse] : false
        sort_state[:mode] = mode
        requested[:action] = [:sort_review, [mode, sort_state[:reverse]]]
      end
      widgets[:sell_view], widgets[:sell_store] = gemguard_review_list_view(&header_sort)
      widgets[:keep_view], widgets[:keep_store] = gemguard_review_list_view(&header_sort)
      widgets[:protect_selected_button] = protect_selected_button
      widgets[:sort_chrisms_button] = sort_chrisms_button
      widgets[:review_cut_selected_button] = review_cut_selected
      widgets[:orb_test_button] = orb_test_button
      widgets[:mark_button] = mark_button
      widgets[:unmark_button] = unmark_button
      widgets[:sell_count] = Gtk::Label.new('Will Sell: 0')
      widgets[:keep_count] = Gtk::Label.new('Will Keep: 0')

      gemguard_set_sensitive(protect_selected_button, false)
      gemguard_set_sensitive(sort_chrisms_button, false)
      gemguard_set_sensitive(review_cut_selected, false)
      gemguard_set_sensitive(orb_test_button, false)
      gemguard_set_sensitive(mark_button, false)
      gemguard_set_sensitive(unmark_button, false)
      gemguard_set_sensitive(move_purified_to_sell, false)
      gemguard_set_tooltip(widgets[:sell_view], 'These gems are approved to sell if you press Sell Approved.')
      gemguard_set_tooltip(widgets[:keep_view], 'These gems will not be sold because they are protected, marked, chrisms, pure orbs, or manually kept.')
      gemguard_set_tooltip(widgets[:sell_count], 'How many gems are currently approved to sell.')
      gemguard_set_tooltip(widgets[:keep_count], 'How many gems are currently being kept.')

      top_buttons = Gtk::Box.new(:horizontal, 6)
      [scan_button, appraise_button, sell_button, protect_selected_button, sort_chrisms_button, review_cut_selected, orb_test_button, mark_button, unmark_button, close_button].each { |button| top_buttons.pack_start(button, :expand => false) }

      sell_panel = Gtk::Box.new(:vertical, 4)
      sell_panel.pack_start(widgets[:sell_count], :expand => false)
      sell_panel.pack_start(gemguard_scroller(widgets[:sell_view], 490, 285), :expand => true, :fill => true)
      sell_move_box = Gtk::Box.new(:horizontal, 4)
      sell_move_box.pack_start(move_to_keep, :expand => false)
      sell_panel.pack_start(sell_move_box, :expand => false)

      keep_panel = Gtk::Box.new(:vertical, 4)
      keep_panel.pack_start(widgets[:keep_count], :expand => false)
      keep_panel.pack_start(gemguard_scroller(widgets[:keep_view], 490, 285), :expand => true, :fill => true)
      keep_move_box = Gtk::Box.new(:horizontal, 4)
      keep_move_box.pack_start(move_to_sell, :expand => false)
      keep_move_box.pack_start(move_purified_to_sell, :expand => false)
      keep_panel.pack_start(keep_move_box, :expand => false)

      review_columns = Gtk::Box.new(:horizontal, 8)
      review_columns.pack_start(sell_panel, :expand => true, :fill => true)
      review_columns.pack_start(keep_panel, :expand => true, :fill => true)

      review_tab = Gtk::Box.new(:vertical, 8)
      review_tab.pack_start(top_buttons, :expand => false)
      review_tab.pack_start(review_columns, :expand => true, :fill => true)
      review_tab.pack_start(gemguard_scroller(report, 1000, 175), :expand => false, :fill => true)
      review_tab.pack_start(status, :expand => false)

      widgets[:protected_view], widgets[:protected_store] = gemguard_protected_list_view
      widgets[:exception_view], widgets[:exception_store] = gemguard_protected_list_view('Exception')
      widgets[:protected_count] = Gtk::Label.new('Protected: 0')
      protected_entry = Gtk::Entry.new
      protected_entry.placeholder_text = 'gem name or noun' if protected_entry.respond_to?(:placeholder_text=)
      exception_entry = Gtk::Entry.new
      exception_entry.placeholder_text = 'exact gem name' if exception_entry.respond_to?(:placeholder_text=)
      add_protected = Gtk::Button.new(:label => 'Add Protected')
      remove_protected = Gtk::Button.new(:label => 'Remove Selected')
      add_exception = Gtk::Button.new(:label => 'Add Exception')
      remove_exception = Gtk::Button.new(:label => 'Remove Exception')
      restore_defaults = Gtk::Button.new(:label => 'Restore Defaults')
      send_eloot = Gtk::Button.new(:label => 'Send To ELoot Exclusions')

      gemguard_set_tooltip(widgets[:protected_view], 'Gem names and nouns GemGuard treats as protected during scans.')
      gemguard_set_tooltip(widgets[:exception_view], 'Exact gem names that can sell even when a broader protected name matches them.')
      gemguard_set_tooltip(widgets[:protected_count], 'How many protected terms and exact exceptions GemGuard has, and how many protected terms are already in ELoot exclusions.')
      gemguard_set_tooltip(protected_entry, 'Type a gem name or noun here to add or remove it from the protected list.')
      gemguard_set_tooltip(exception_entry, 'Type the exact gem name to allow through a broad protected term, like blue sapphire when sapphire is protected.')
      gemguard_set_tooltip(add_protected, 'Add the typed gem name or noun to the protected list.')
      gemguard_set_tooltip(remove_protected, 'Remove the selected protected-list rows, or remove the typed name if you typed one.')
      gemguard_set_tooltip(add_exception, 'Add the typed exact gem name to the exception list so broad protected terms do not keep it.')
      gemguard_set_tooltip(remove_exception, 'Remove the selected exception rows, or remove the typed exception if you typed one.')
      gemguard_set_tooltip(restore_defaults, 'Put the protected list back to GemGuard defaults.')
      gemguard_set_tooltip(send_eloot, 'Copy the protected list into ELoot exclusions so ELoot will not sell those gem names.')

      protected_buttons = Gtk::Box.new(:horizontal, 6)
      [protected_entry, add_protected, remove_protected, restore_defaults, send_eloot].each do |widget|
        protected_buttons.pack_start(widget, :expand => widget == protected_entry, :fill => true)
      end
      exception_buttons = Gtk::Box.new(:horizontal, 6)
      [exception_entry, add_exception, remove_exception].each do |widget|
        exception_buttons.pack_start(widget, :expand => widget == exception_entry, :fill => true)
      end
      protected_lists = Gtk::Box.new(:horizontal, 8)
      protected_panel = Gtk::Box.new(:vertical, 4)
      exception_panel = Gtk::Box.new(:vertical, 4)
      protected_header = Gtk::Label.new('Protected Names')
      exception_header = Gtk::Label.new('Exceptions')
      protected_header.xalign = 0 if protected_header.respond_to?(:xalign=)
      exception_header.xalign = 0 if exception_header.respond_to?(:xalign=)
      protected_panel.pack_start(protected_header, :expand => false)
      protected_panel.pack_start(gemguard_scroller(widgets[:protected_view], 490, 420), :expand => true, :fill => true)
      exception_panel.pack_start(exception_header, :expand => false)
      exception_panel.pack_start(gemguard_scroller(widgets[:exception_view], 490, 420), :expand => true, :fill => true)
      protected_lists.pack_start(protected_panel, :expand => true, :fill => true)
      protected_lists.pack_start(exception_panel, :expand => true, :fill => true)
      protected_tab = Gtk::Box.new(:vertical, 8)
      protected_tab.pack_start(widgets[:protected_count], :expand => false)
      protected_tab.pack_start(protected_lists, :expand => true, :fill => true)
      protected_tab.pack_start(protected_buttons, :expand => false)
      protected_tab.pack_start(exception_buttons, :expand => false)

      container_choices = gemguard_saved_container_choices
      source_container_label = gemguard_bard? ? 'Unsung gems' : 'Gem bag'
      orb_container_label = gemguard_bard? ? 'Pure orbs' : 'Pure orb bag'
      settings_unsung_row, settings_unsung = gemguard_container_dropdown_row(source_container_label, gemguard_setting_value(:purify_unsung_container), container_choices, true)
      settings_sung_row, settings_sung = gemguard_container_dropdown_row('Sung non-orbs', gemguard_setting_value(:purify_sung_container), container_choices, true)
      settings_orb_row, settings_orb = gemguard_container_dropdown_row(orb_container_label, gemguard_setting_value(:purify_orb_container), container_choices, true)
      settings_chrism_row, settings_chrism = gemguard_container_dropdown_row('Chrisms', gemguard_setting_value(:chrism_container), container_choices, true)
      settings_orb_threshold = Gtk::Entry.new
      settings_orb_threshold.placeholder_text = '0' if settings_orb_threshold.respond_to?(:placeholder_text=)
      settings_orb_threshold.text = gemguard_setting_value(:pure_orb_sell_threshold) if settings_orb_threshold.respond_to?(:text=)
      settings_appraised_threshold = Gtk::Entry.new
      settings_appraised_threshold.placeholder_text = '0' if settings_appraised_threshold.respond_to?(:placeholder_text=)
      settings_appraised_threshold.text = gemguard_setting_value(:appraised_gem_sell_threshold) if settings_appraised_threshold.respond_to?(:text=)
      settings_sell_value_confirm = Gtk::CheckButton.new('Reappraise before Sell Approved')
      settings_sell_value_confirm.active = gemguard_sell_value_confirm_enabled? if settings_sell_value_confirm.respond_to?(:active=)
      settings_sell_value_ignore_protected = Gtk::CheckButton.new('Ignore protected list for sell by value')
      settings_sell_value_ignore_protected.active = gemguard_truthy_value?(gemguard_setting_value(:sell_value_ignore_protected)) if settings_sell_value_ignore_protected.respond_to?(:active=)
      settings_sell_purified_ignore_value = Gtk::CheckButton.new('Purified non-orbs bypass value limit')
      settings_sell_purified_ignore_value.active = gemguard_truthy_value?(gemguard_setting_value(:sell_purified_ignore_value)) if settings_sell_purified_ignore_value.respond_to?(:active=)
      settings_purify_all = nil
      if gemguard_bard?
        settings_purify_all = Gtk::CheckButton.new('Purify all gems in unsung bag')
        settings_purify_all.active = gemguard_purify_all_gems_enabled? if settings_purify_all.respond_to?(:active=)
      end
      save_global_settings = Gtk::Button.new(:label => 'Save Settings')
      refresh_containers = Gtk::Button.new(:label => 'Refresh Containers')

      gemguard_set_tooltip(settings_unsung, gemguard_bard? ? 'Container GemGuard scans for gems you have not purified yet.' : 'Main gem container for gem management and orb testing workflows.')
      gemguard_set_tooltip(settings_sung, 'Container GemGuard puts purified gems in when they do not turn into pure orbs.')
      gemguard_set_tooltip(settings_orb, 'Container GemGuard puts gems in when they prove to be pure orbs.')
      gemguard_set_tooltip(settings_chrism, 'Container GemGuard uses when Sort Chrisms finds chrisms.')
      gemguard_set_tooltip(settings_orb_threshold, 'Pure orbs appraised below this silver value can move to Will Sell. Use 0 to keep all pure orbs.')
      gemguard_set_tooltip(settings_appraised_threshold, 'After Appraise All, non-orb gems appraised at or below this value move to Will Sell. If Reappraise before Sell Approved is checked, this same value is also checked again before selling. Use 0 to disable.')
      gemguard_set_tooltip(settings_sell_value_confirm, 'When checked, Sell Approved appraises each gem again and only sells it when it is at or below the shared value limit.')
      gemguard_set_tooltip(settings_sell_value_ignore_protected, 'When sell by value is enabled, protected gem names can be tested and sold by value. Marks, chrisms, and orbs still stay protected.')
      gemguard_set_tooltip(settings_sell_purified_ignore_value, 'When checked, purified gems that did not become orbs can sell even when they are over the gem value limit.')
      gemguard_set_tooltip(settings_purify_all, 'When checked, Purify Scan lists every gem in the unsung bag instead of only protected gem names.') if settings_purify_all
      gemguard_set_tooltip(save_global_settings, 'Save container names and sell policy to GemGuard settings.')
      gemguard_set_tooltip(refresh_containers, 'Refresh the container dropdowns and checkbox lists from current inventory.')

      settings_sell_box = Gtk::Box.new(:horizontal, 6)
      settings_sell_box.pack_start(Gtk::Label.new('Pure orb sell below'), :expand => false)
      settings_sell_box.pack_start(settings_orb_threshold, :expand => false)
      settings_sell_box.pack_start(Gtk::Label.new('silver'), :expand => false)
      settings_sell_box.pack_start(Gtk::Label.new('Gem value limit <= '), :expand => false)
      settings_sell_box.pack_start(settings_appraised_threshold, :expand => false)
      settings_sell_box.pack_start(Gtk::Label.new('silver'), :expand => false)
      settings_sell_box.pack_start(refresh_containers, :expand => false)
      settings_sell_box.pack_start(save_global_settings, :expand => false)
      settings_value_sell_box = Gtk::Box.new(:horizontal, 6)
      settings_value_sell_box.pack_start(settings_sell_value_confirm, :expand => false)
      settings_value_sell_box.pack_start(settings_sell_value_ignore_protected, :expand => false)
      settings_value_sell_box.pack_start(settings_sell_purified_ignore_value, :expand => false)
      settings_scan_checks = {}
      settings_ignore_checks = {}
      settings_scan_box = Gtk::Box.new(:vertical, 2)
      settings_ignore_box = Gtk::Box.new(:vertical, 2)
      rebuild_container_lists = proc do
        hidden_scan_checks = []
        [settings_scan_box, settings_ignore_box].each do |box|
          next unless box.respond_to?(:children)

          box.children.each { |child| box.remove(child) }
        end
        settings_scan_checks.clear
        settings_ignore_checks.clear
        current_scan = gemguard_setting_array(:scan_containers).map(&:downcase)
        current_ignore = gemguard_setting_array(:ignore_containers).map(&:downcase)
        if container_choices.empty?
          settings_scan_box.pack_start(Gtk::Label.new('(press Refresh Containers)'), :expand => false)
          settings_ignore_box.pack_start(Gtk::Label.new('(press Refresh Containers)'), :expand => false)
        else
          container_choices.each do |choice|
            display = gemguard_choice_display(choice)
            value = gemguard_choice_value(choice)
            scan_cb = Gtk::CheckButton.new(display)
            ignore_cb = Gtk::CheckButton.new(display)
            ignored = current_ignore.include?(value.downcase) || current_ignore.include?(display.downcase)
            scanned = !ignored && (current_scan.include?(value.downcase) || current_scan.include?(display.downcase))
            scan_cb.active = scanned if scan_cb.respond_to?(:active=)
            ignore_cb.active = ignored if ignore_cb.respond_to?(:active=)
            scan_tip = 'Checked containers are opened and scanned for Review, Sell Approved, Appraise All, orb testing, and chrism sorting.'
            ignore_tip = 'Ignored containers are skipped by Review and selling scans. Checking this clears the same container from Review/Sell Scan Containers.'
            scan_tip = "#{scan_tip} Container setting: #{value}" if value != display
            ignore_tip = "#{ignore_tip} Container setting: #{value}" if value != display
            gemguard_set_tooltip(scan_cb, scan_tip)
            gemguard_set_tooltip(ignore_cb, ignore_tip)
            if scan_cb.respond_to?(:signal_connect) && ignore_cb.respond_to?(:active=)
              scan_cb.signal_connect('toggled') do
                if scan_cb.respond_to?(:active?) && scan_cb.active?
                  ignore_cb.active = false
                  scan_cb.show if scan_cb.respond_to?(:show)
                end
              end
            end
            if ignore_cb.respond_to?(:signal_connect) && scan_cb.respond_to?(:active=)
              ignore_cb.signal_connect('toggled') do
                if ignore_cb.respond_to?(:active?) && ignore_cb.active?
                  scan_cb.active = false
                  scan_cb.hide if scan_cb.respond_to?(:hide)
                elsif scan_cb.respond_to?(:show)
                  scan_cb.show
                end
              end
            end
            settings_scan_checks[value] = scan_cb
            settings_ignore_checks[value] = ignore_cb
            settings_scan_box.pack_start(scan_cb, :expand => false)
            settings_ignore_box.pack_start(ignore_cb, :expand => false)
            hidden_scan_checks << scan_cb if ignored
          end
        end
        settings_scan_box.show_all if settings_scan_box.respond_to?(:show_all)
        settings_ignore_box.show_all if settings_ignore_box.respond_to?(:show_all)
        hidden_scan_checks.each { |cb| cb.hide if cb.respond_to?(:hide) }
      end
      rebuild_container_lists.call
      lapidary_box_container = nil
      # Apply freshly scanned container choices to the dropdowns and checkbox
      # lists. The scan itself must run on the script thread (game I/O), so the
      # main action loop calls this with the results; the widget updates here
      # are wrapped in Gtk.queue so they run on the GTK thread.
      apply_container_choices = proc do |choices|
        Gtk.queue do
          next unless gemguard_gtk_window_open?(window_ref)

          container_choices = Array(choices)
          gemguard_set_container_dropdown_choices(settings_unsung, container_choices, gemguard_control_text(settings_unsung), true)
          gemguard_set_container_dropdown_choices(settings_sung, container_choices, gemguard_control_text(settings_sung), true)
          gemguard_set_container_dropdown_choices(settings_orb, container_choices, gemguard_control_text(settings_orb), true)
          gemguard_set_container_dropdown_choices(settings_chrism, container_choices, gemguard_control_text(settings_chrism), true)
          if lapidary_box_container
            gemguard_set_container_dropdown_choices(lapidary_box_container, container_choices, gemguard_control_text(lapidary_box_container), true)
          end
          rebuild_container_lists.call
        end
      end
      widgets[:apply_container_choices] = apply_container_choices
      scan_scroller = gemguard_scroller(settings_scan_box, 480, 135)
      ignore_scroller = gemguard_scroller(settings_ignore_box, 480, 135)
      settings_lists = Gtk::Box.new(:horizontal, 8)
      scan_panel = Gtk::Box.new(:vertical, 4)
      ignore_panel = Gtk::Box.new(:vertical, 4)
      scan_header = Gtk::Label.new('Review/Sell Scan Containers')
      ignore_header = Gtk::Label.new('Ignore Containers')
      gemguard_set_tooltip(scan_header, 'Containers checked here are included when GemGuard scans gems for review, appraising, selling, orb testing, and chrism sorting.')
      gemguard_set_tooltip(ignore_header, 'Containers checked here are skipped by review and selling scans. A container cannot be both scanned and ignored.')
      scan_panel.pack_start(scan_header, :expand => false)
      scan_panel.pack_start(scan_scroller, :expand => true, :fill => true)
      ignore_panel.pack_start(ignore_header, :expand => false)
      ignore_panel.pack_start(ignore_scroller, :expand => true, :fill => true)
      settings_lists.pack_start(scan_panel, :expand => true, :fill => true)
      settings_lists.pack_start(ignore_panel, :expand => true, :fill => true)
      settings_tab = Gtk::Box.new(:vertical, 8)
      settings_tab.pack_start(settings_unsung_row, :expand => false)
      settings_tab.pack_start(settings_sung_row, :expand => false) if gemguard_bard?
      settings_tab.pack_start(settings_orb_row, :expand => false)
      settings_tab.pack_start(settings_chrism_row, :expand => false)
      settings_tab.pack_start(settings_purify_all, :expand => false) if settings_purify_all
      settings_tab.pack_start(settings_sell_box, :expand => false)
      settings_tab.pack_start(settings_value_sell_box, :expand => false)
      settings_tab.pack_start(settings_lists, :expand => true, :fill => true)

      gemcutter_device_row, gemcutter_device = gemguard_entry_row('Gemcutter', gemguard_setting_value(:gemcutter_device))
      gemcutter_regular_pattern_row, gemcutter_regular_pattern = gemguard_lapidary_pattern_dropdown_row('Regular gems', gemguard_gemcutter_pattern_value(:gemcutter_regular_pattern))
      gemcutter_purified_pattern_row, gemcutter_purified_pattern = gemguard_lapidary_pattern_dropdown_row('Purified non-orbs', gemguard_gemcutter_pattern_value(:gemcutter_purified_pattern))
      gemcutter_orb_pattern_row, gemcutter_orb_pattern = gemguard_lapidary_pattern_dropdown_row('Pure orbs', gemguard_gemcutter_pattern_value(:gemcutter_orb_pattern))
      gemcutter_chrism_pattern_row, gemcutter_chrism_pattern = gemguard_lapidary_pattern_dropdown_row('Chrisms', gemguard_gemcutter_pattern_value(:gemcutter_chrism_pattern))
      lapidary_box_row, lapidary_box = gemguard_entry_row('Lapidary box', gemguard_setting_value(:lapidary_box))
      lapidary_box_container_row, lapidary_box_container = gemguard_container_dropdown_row('Lapidary box container', gemguard_setting_value(:lapidary_box_container), container_choices, true)
      lapidary_analyze = Gtk::Button.new(:label => 'Analyze Box')
      gemcutter_cut_selected = Gtk::Button.new(:label => 'Cut Selected')
      gemcutter_save = Gtk::Button.new(:label => 'Save Cutter Setup')
      gemcutter_debug = Gtk::CheckButton.new('Gemcutter debug log')
      gemcutter_debug.active = gemguard_gemcutter_debug_enabled? if gemcutter_debug.respond_to?(:active=)
      gemcutter_status = gemguard_text_view(gemguard_gemcutter_setup_summary, true)
      widgets[:gemcutter_status] = gemcutter_status
      widgets[:gemcutter_pattern_controls] = [
        gemcutter_regular_pattern,
        gemcutter_purified_pattern,
        gemcutter_orb_pattern,
        gemcutter_chrism_pattern
      ]
      lapidary_box_row.pack_start(lapidary_analyze, :expand => false)

      gemguard_set_tooltip(gemcutter_device, 'Type the normal gemcutter name, noun, or item number to save for future cutter use.')
      gemguard_set_tooltip(gemcutter_regular_pattern, 'Pattern GemGuard should use later for regular gems.')
      gemguard_set_tooltip(gemcutter_purified_pattern, 'Pattern GemGuard should use later for purified gems that are not orbs.')
      gemguard_set_tooltip(gemcutter_orb_pattern, 'Pattern GemGuard should use later for pure orbs.')
      gemguard_set_tooltip(gemcutter_chrism_pattern, 'Pattern GemGuard should use later for chrisms.')
      gemguard_set_tooltip(lapidary_box, 'Type the lapidary box name, noun, or item number GemGuard should analyze for saved cutter designs.')
      gemguard_set_tooltip(lapidary_box_container, 'Container where GemGuard should look for the lapidary box before cutting. This avoids opening every gem bag just to find the box.')
      gemguard_set_tooltip(lapidary_analyze, 'Analyze the typed lapidary box, read its unlocked designs, and save them for future cutter use.')
      gemguard_set_tooltip(gemcutter_cut_selected, 'Cut selected gems from the Review tab. GemGuard only cuts gem types that have a saved pattern.')
      gemguard_set_tooltip(gemcutter_save, 'Save the gemcutter, pattern, and lapidary box names.')
      gemguard_set_tooltip(gemcutter_debug, 'Write cutter steps to gemguard-debug.log so cutter failures are easier to find.')
      gemguard_set_tooltip(gemcutter_status, 'Shows saved cutter setup and cutting progress.')

      gemcutter_buttons = Gtk::Box.new(:horizontal, 6)
      gemcutter_buttons.pack_start(gemcutter_save, :expand => false)
      gemcutter_buttons.pack_start(gemcutter_cut_selected, :expand => false)
      gemcutter_buttons.pack_start(gemcutter_debug, :expand => false)
      gemcutter_tab = Gtk::Box.new(:vertical, 8)
      gemcutter_tab.pack_start(gemcutter_device_row, :expand => false)
      gemcutter_tab.pack_start(gemcutter_regular_pattern_row, :expand => false)
      gemcutter_tab.pack_start(gemcutter_purified_pattern_row, :expand => false)
      gemcutter_tab.pack_start(gemcutter_orb_pattern_row, :expand => false)
      gemcutter_tab.pack_start(gemcutter_chrism_pattern_row, :expand => false)
      gemcutter_tab.pack_start(lapidary_box_row, :expand => false)
      gemcutter_tab.pack_start(lapidary_box_container_row, :expand => false)
      gemcutter_tab.pack_start(gemcutter_buttons, :expand => false)
      gemcutter_tab.pack_start(gemguard_scroller(gemcutter_status, 980, 420), :expand => true, :fill => true)

      if gemguard_bard?
        widgets[:purify_view], widgets[:purify_store] = gemguard_review_list_view(true, &header_sort)
        widgets[:purify_count] = Gtk::Label.new('Purify: 0')
        widgets[:purify_status] = Gtk::Label.new('Purify status: idle.')
        widgets[:purify_report] = Gtk::Label.new('Purify results: none yet.')
        widgets[:purify_progress_text] = gemguard_text_view("No purify action running.\n\nScan unsung gems, select the ones to purify, then click Purify Selected.", true)
        widgets[:purify_progress_bar] = Gtk::ProgressBar.new if defined?(Gtk::ProgressBar)
        gemguard_set_progress_bar(widgets[:purify_progress_bar], 0, 0) if widgets[:purify_progress_bar]
        [widgets[:purify_status], widgets[:purify_report]].each do |label|
          label.xalign = 0 if label.respond_to?(:xalign=)
          label.line_wrap = true if label.respond_to?(:line_wrap=)
        end
        purify_progress_title = Gtk::Label.new('Progress')
        purify_progress_title.xalign = 0 if purify_progress_title.respond_to?(:xalign=)
        purify_scan = Gtk::Button.new(:label => 'Scan Unsung')
        purify_selected = Gtk::Button.new(:label => 'Purify Selected')
        purify_all = Gtk::Button.new(:label => 'Purify All')
        widgets[:purify_selected_button] = purify_selected
        widgets[:purify_all_button] = purify_all

        gemguard_set_tooltip(widgets[:purify_view], 'Gems from the unsung container that match the purify candidate list.')
        gemguard_set_tooltip(widgets[:purify_count], 'How many gems are ready for the purify workflow.')
        gemguard_set_tooltip(widgets[:purify_status], 'Shows which gem GemGuard is purifying right now.')
        gemguard_set_tooltip(widgets[:purify_report], 'Shows running and final totals for this purify batch.')
        gemguard_set_tooltip(widgets[:purify_progress_text], 'Shows the current purify batch, running totals, and what will happen after Stop is clicked.')
        gemguard_set_tooltip(widgets[:purify_progress_bar], 'Shows how far through the selected purify batch GemGuard is.') if widgets[:purify_progress_bar]
        gemguard_set_tooltip(purify_scan, 'Open the unsung container and list gems GemGuard thinks are worth purifying.')
        gemguard_set_tooltip(purify_selected, 'Run Purification Song on the selected gems and sort the results.')
        gemguard_set_tooltip(purify_all, 'Run Purification Song on every gem currently shown in the Purify list.')
        gemguard_set_sensitive(purify_selected, false)
        gemguard_set_sensitive(purify_all, state[:purify].any?)

        purify_button_box = Gtk::Box.new(:horizontal, 6)
        [purify_scan, purify_selected, purify_all].each { |button| purify_button_box.pack_start(button, :expand => false) }
        purify_left_panel = Gtk::Box.new(:vertical, 4)
        purify_left_panel.pack_start(widgets[:purify_count], :expand => false)
        purify_left_panel.pack_start(gemguard_scroller(widgets[:purify_view], 440, 420), :expand => true, :fill => true)
        purify_progress_panel = Gtk::Box.new(:vertical, 6)
        purify_progress_panel.pack_start(purify_progress_title, :expand => false)
        purify_progress_panel.pack_start(widgets[:purify_progress_bar], :expand => false, :fill => true) if widgets[:purify_progress_bar]
        purify_progress_panel.pack_start(widgets[:purify_status], :expand => false, :fill => true)
        purify_progress_panel.pack_start(widgets[:purify_report], :expand => false, :fill => true)
        purify_progress_panel.pack_start(gemguard_scroller(widgets[:purify_progress_text], 520, 340), :expand => true, :fill => true)
        purify_body = Gtk::Box.new(:horizontal, 8)
        purify_body.pack_start(purify_left_panel, :expand => false, :fill => true)
        purify_body.pack_start(purify_progress_panel, :expand => true, :fill => true)
        purify_tab = Gtk::Box.new(:vertical, 8)
        purify_tab.pack_start(purify_button_box, :expand => false)
        purify_tab.pack_start(purify_body, :expand => true, :fill => true)

        current_purify_settings = proc do
          {
            purify_unsung_container: gemguard_control_text(settings_unsung),
            purify_sung_container: gemguard_control_text(settings_sung),
            purify_orb_container: gemguard_control_text(settings_orb),
            purify_all_gems: settings_purify_all && settings_purify_all.respond_to?(:active?) && settings_purify_all.active? ? 'true' : 'false'
          }
        end
        purify_scan.signal_connect('clicked') { queue_action.call(purify_scan, [:scan_purify, current_purify_settings.call]) }
        purify_selected.signal_connect('clicked') do
          queue_action.call(purify_selected, [:purify_selected, [gemguard_selected_review_ids(widgets[:purify_view]), current_purify_settings.call]])
        end
        purify_all.signal_connect('clicked') do
          queue_action.call(purify_all, [:purify_all, current_purify_settings.call])
        end
        if widgets[:purify_view].respond_to?(:selection) && widgets[:purify_view].selection.respond_to?(:signal_connect)
          widgets[:purify_view].selection.signal_connect('changed') { update_mark_buttons.call if update_mark_buttons }
        end
      end

      if notebook.respond_to?(:append_page)
        notebook.append_page(review_tab, Gtk::Label.new('Review'))
        notebook.append_page(protected_tab, Gtk::Label.new('Protected List'))
        notebook.append_page(settings_tab, Gtk::Label.new('Settings'))
        notebook.append_page(gemcutter_tab, Gtk::Label.new('Gemcutter'))
        notebook.append_page(purify_tab, Gtk::Label.new('Purify')) if gemguard_bard? && defined?(purify_tab) && purify_tab
      else
        notebook.pack_start(review_tab, :expand => true, :fill => true)
        notebook.pack_start(protected_tab, :expand => true, :fill => true)
        notebook.pack_start(settings_tab, :expand => true, :fill => true)
        notebook.pack_start(gemcutter_tab, :expand => true, :fill => true)
        notebook.pack_start(purify_tab, :expand => true, :fill => true) if gemguard_bard? && defined?(purify_tab) && purify_tab
      end

      show_gemcutter_tab = proc do
        next unless notebook.respond_to?(:append_page)

        if notebook.respond_to?(:page=)
          notebook.page = 3
        elsif notebook.respond_to?(:set_current_page)
          notebook.set_current_page(3)
        end
      rescue => error
        gemguard_gtk_debug "switch to gemcutter tab failed: #{error.class}: #{error.message}"
      end

      scan_button.signal_connect('clicked') { queue_action.call(scan_button, :scan) }
      appraise_button.signal_connect('clicked') { queue_action.call(appraise_button, :appraise) }
      sell_button.signal_connect('clicked') { queue_action.call(sell_button, :sell_approved) }
      sort_chrisms_button.signal_connect('clicked') { queue_action.call(sort_chrisms_button, :sort_chrisms) }
      review_cut_selected.signal_connect('clicked') do
        rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
        show_gemcutter_tab.call
        gemguard_save_setting_value(:gemcutter_debug_enabled, gemcutter_debug.respond_to?(:active?) && gemcutter_debug.active? ? 'true' : 'false')
        queue_action.call(gemcutter_cut_selected, [:cut_selected_gems, rows.map { |row| row[:id].to_s }])
      end
      protect_selected_button.signal_connect('clicked') do
        rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
        requested[:action] = [:toggle_protection, rows.map { |row| row[:id].to_s }]
      end
      orb_test_button.signal_connect('clicked') do
        rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
        queue_action.call(orb_test_button, [:orb_test_selected, rows.map { |row| row[:id].to_s }])
      end
      mark_button.signal_connect('clicked') do
        rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
        queue_action.call(mark_button, [:mark_selected, rows.select { |row| !gemguard_review_row_marked?(row) }.map { |row| row[:id].to_s }])
      end
      unmark_button.signal_connect('clicked') do
        rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
        queue_action.call(unmark_button, [:unmark_selected, rows.select { |row| gemguard_review_row_marked?(row) }.map { |row| row[:id].to_s }])
      end
      close_button.signal_connect('clicked') { close_review_window.call }
      move_to_keep.signal_connect('clicked') { requested[:action] = [:move_to_keep, gemguard_selected_review_ids(widgets[:sell_view])] }
      move_to_sell.signal_connect('clicked') { requested[:action] = [:move_to_sell, gemguard_selected_review_ids(widgets[:keep_view])] }
      move_purified_to_sell.signal_connect('clicked') { requested[:action] = :move_purified_to_sell }
      add_protected.signal_connect('clicked') { requested[:action] = [:add_protected, protected_entry.text.to_s] }
      remove_protected.signal_connect('clicked') { requested[:action] = [:remove_protected, [protected_entry.text.to_s, gemguard_selected_protected_terms(widgets[:protected_view])]] }
      add_exception.signal_connect('clicked') { requested[:action] = [:add_exception, exception_entry.text.to_s] }
      remove_exception.signal_connect('clicked') { requested[:action] = [:remove_exception, [exception_entry.text.to_s, gemguard_selected_protected_terms(widgets[:exception_view])]] }
      restore_defaults.signal_connect('clicked') { requested[:action] = :restore_defaults }
      send_eloot.signal_connect('clicked') { requested[:action] = :send_eloot }
      save_global_settings.signal_connect('clicked') do
        scan_values = settings_scan_checks.select { |_value, cb| cb.respond_to?(:active?) ? cb.active? : false }.keys
        ignore_values = settings_ignore_checks.select { |_value, cb| cb.respond_to?(:active?) ? cb.active? : false }.keys
        ignore_lookup = ignore_values.map(&:downcase)
        scan_values.reject! { |value| ignore_lookup.include?(value.to_s.downcase) }
        settings_scan_checks.each do |value, cb|
          cb.active = false if ignore_lookup.include?(value.to_s.downcase) && cb.respond_to?(:active=)
        end
        requested[:action] = [
          :save_global_settings,
          [
            gemguard_control_text(settings_unsung),
            gemguard_control_text(settings_sung),
            gemguard_control_text(settings_orb),
            gemguard_control_text(settings_chrism),
            gemguard_control_text(lapidary_box),
            gemguard_control_text(lapidary_box_container),
            gemguard_control_text(gemcutter_device),
            gemguard_control_text(gemcutter_regular_pattern),
            gemguard_control_text(gemcutter_purified_pattern),
            gemguard_control_text(gemcutter_orb_pattern),
            gemguard_control_text(gemcutter_chrism_pattern),
            settings_orb_threshold.text.to_s,
            settings_appraised_threshold.text.to_s,
            settings_sell_value_confirm.respond_to?(:active?) && settings_sell_value_confirm.active? ? 'true' : 'false',
            settings_sell_value_ignore_protected.respond_to?(:active?) && settings_sell_value_ignore_protected.active? ? 'true' : 'false',
            settings_sell_purified_ignore_value.respond_to?(:active?) && settings_sell_purified_ignore_value.active? ? 'true' : 'false',
            settings_purify_all && settings_purify_all.respond_to?(:active?) && settings_purify_all.active? ? 'true' : 'false',
            gemcutter_debug.respond_to?(:active?) && gemcutter_debug.active? ? 'true' : 'false',
            scan_values,
            ignore_values
          ]
        ]
      end
      refresh_containers.signal_connect('clicked') { queue_action.call(refresh_containers, :refresh_containers) }
      lapidary_analyze.signal_connect('clicked') { queue_action.call(lapidary_analyze, [:analyze_lapidary_box, gemguard_control_text(lapidary_box)]) }
      gemcutter_cut_selected.signal_connect('clicked') do
        rows = gemguard_selected_review_rows_from_state(state, [widgets[:sell_view], widgets[:keep_view]])
        gemguard_save_setting_value(:gemcutter_debug_enabled, gemcutter_debug.respond_to?(:active?) && gemcutter_debug.active? ? 'true' : 'false')
        queue_action.call(gemcutter_cut_selected, [:cut_selected_gems, rows.map { |row| row[:id].to_s }])
      end
      gemcutter_save.signal_connect('clicked') do
        requested[:action] = [
          :save_gemcutter_settings,
          [
            gemguard_control_text(gemcutter_device),
            gemguard_control_text(gemcutter_regular_pattern),
            gemguard_control_text(gemcutter_purified_pattern),
            gemguard_control_text(gemcutter_orb_pattern),
            gemguard_control_text(gemcutter_chrism_pattern),
            gemguard_control_text(lapidary_box),
            gemguard_control_text(lapidary_box_container),
            gemcutter_debug.respond_to?(:active?) && gemcutter_debug.active? ? 'true' : 'false'
          ]
        ]
      end
      [widgets[:sell_view], widgets[:keep_view]].each do |view|
        next unless view.respond_to?(:selection) && view.selection.respond_to?(:signal_connect)

        view.selection.signal_connect('changed') { update_mark_buttons.call if update_mark_buttons }
      end

      window.signal_connect('delete_event') do
        close_review_window.call
        gemguard_handle_gtk_delete_event('Review', window_ref, closed_ref)
      end
      window.signal_connect('destroy') { gemguard_forget_gtk_window(window_ref[:name], window_ref, closed_ref) }
      window.add(notebook)
      gemguard_present_window(window)
      refresh_text.call
      set_status.call('Starting scan. Saved gem values and statuses will be matched as items are found.')
      widgets[:startup_scan_pending] = true
      requested[:action] = :refresh_containers
    rescue => error
      echo "gemguard: review window failed: #{error.class}: #{error.message}"
      gemguard_close_gtk_window_now(window_ref, closed_ref)
    end
  end

  until closed_ref[:closed]
    action = requested.delete(:action)
    action_button = requested.delete(:button)
    start_action_button.call(action_button) if action && action_button
    begin
    case action
    when :close_window
      gemguard_close_gtk_window_now(window_ref, closed_ref)
    when :refresh_containers
      set_status.call('Refreshing containers from inventory...')
      choices = gemguard_container_choices
      apply = widgets[:apply_container_choices]
      apply.call(choices) if apply
      set_status.call("Refresh Containers found #{choices.length} container#{choices.length == 1 ? '' : 's'}.")
      if widgets.delete(:startup_scan_pending)
        set_status.call("Refresh Containers found #{choices.length} container#{choices.length == 1 ? '' : 's'}. Startup scan queued.")
        requested[:action] = :scan
        requested[:button] = widgets[:scan_button]
      end
    when :scan
      gemguard_reset_stop_request
      set_status.call('Scanning containers...')
      gemguard_clear_scan_snapshot
      rows = gemguard_scan_review_rows
      state[:sell] = rows[:sell]
      state[:keep] = rows[:keep]
      policy = gemguard_apply_sell_policy_to_state(state)
      state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
      gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
      cleanup_text = rows[:stale_removed].to_i.positive? ? " Removed #{rows[:stale_removed].to_i} stale saved row#{rows[:stale_removed].to_i == 1 ? '' : 's'}." : ''
      set_status.call("Scan complete: #{state[:sell].length} will sell, #{state[:keep].length} will keep. #{gemguard_sell_policy_text(policy)}#{cleanup_text}")
      refresh_text.call
    when :appraise
      gemguard_reset_stop_request
      appraise_rows = state[:sell] + state[:keep]
      set_status.call("Appraising listed gems: 0/#{appraise_rows.length}...")
      gemguard_appraise_review_rows(appraise_rows, false) do |done, total, row|
        set_status.call("Appraising listed gems: #{done}/#{total} - #{row[:name]} = #{row[:value]}")
        gemguard_sync_rows_from_review!(state[:purify], appraise_rows)
        refresh_text.call(row[:id])
        gemguard_pump_gtk_events
      end
      policy = gemguard_apply_sell_policy_to_state(state)
      gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
      gemguard_save_scan_snapshot(state)
      if gemguard_stop_requested?
        set_status.call("Appraisal stopped. #{gemguard_sell_policy_text(policy)}")
      else
        set_status.call("Appraisal complete. #{gemguard_sell_policy_text(policy)}")
      end
      refresh_text.call
    when :sell_approved
      gemguard_reset_stop_request
      set_status.call("Selling #{state[:sell].length} approved gems...")
      sold_ids, failed, total_silver, skipped_ids = gemguard_sell_review_rows(state[:sell]) do |sold, failed_count, silver, row, skipped_count|
        set_status.call("Selling approved gems: sold #{sold}, skipped #{skipped_count.to_i}, failed #{failed_count}, silver #{silver}. Last: #{row[:name]}")
        refresh_text.call(row[:id])
        gemguard_pump_gtk_events
      end
      skipped_ids ||= []
      skipped_rows = state[:sell].select { |row| skipped_ids.include?(row[:id].to_s) }
      state[:sell].reject! { |row| sold_ids.include?(row[:id].to_s) }
      state[:sell].reject! { |row| skipped_ids.include?(row[:id].to_s) }
      skipped_rows.each do |row|
        row[:action] = :keep
        row[:reason] = 'over sell limit'
      end
      state[:keep].concat(skipped_rows)
      gemguard_save_scan_snapshot(state)
      if gemguard_stop_requested?
        set_status.call("Selling stopped. Sold #{sold_ids.length} gems for #{total_silver} silver; #{skipped_ids.length} skipped by value; #{failed} failed. Remaining sell rows: #{state[:sell].length}.")
      else
        set_status.call("Sold #{sold_ids.length} gems for #{total_silver} silver; #{skipped_ids.length} skipped by value; #{failed} failed. Remaining sell rows: #{state[:sell].length}.")
      end
      refresh_text.call
    when :sort_chrisms
      gemguard_reset_stop_request
      sort_rows = state[:sell] + state[:keep]
      if sort_rows.empty?
        set_status.call('Scan gem containers before sorting chrisms.')
      elsif gemguard_setting_value(:chrism_container).to_s.empty?
        set_status.call('Choose a Chrisms container in Settings first.')
      else
        set_status.call("Sorting chrisms: 0/#{sort_rows.length} checked...")
        summary = gemguard_sort_chrisms_review_rows(sort_rows) do |done, total, row, running|
          set_status.call("Sorting chrisms: #{done}/#{total} checked, #{running[:chrisms].to_i} found, #{running[:moved].to_i} moved, #{running[:already_in_container].to_i} already in Chrisms. Last: #{row[:name]}")
          refresh_text.call(row[:id])
          gemguard_pump_gtk_events
        end
        if summary[:error]
          set_status.call(summary[:error])
        else
          gemguard_apply_sell_policy_to_state(state)
          state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          gemguard_save_scan_snapshot(state)
          set_status.call(gemguard_chrism_sort_summary_text(summary).gsub(/\s+/, ' '))
          gemguard_mono_block("\n#{gemguard_chrism_sort_summary_text(summary)}\n\n")
        end
      end
      refresh_text.call
    when :move_purified_to_sell
      moved = state[:keep].select { |row| gemguard_review_row_purified_non_orb?(row) }
      if moved.any?
        move_ids = moved.map { |row| row[:id].to_s }.reject(&:empty?)
        state[:keep].reject! { |row| move_ids.include?(row[:id].to_s) }
        moved.each do |row|
          row[:action] = :sell
          row[:reason] = 'purified'
        end
        state[:sell].concat(moved)
        gemguard_update_inventory_rows(moved)
        gemguard_save_scan_snapshot(state)
        set_status.call("Moved #{moved.length} purified non-orb gem#{moved.length == 1 ? '' : 's'} to Will Sell.")
      else
        set_status.call('No purified non-orb gems found in Will Keep.')
      end
      refresh_text.call
    when Array
      action_name, value = action
      case action_name
      when :scan_purify
        gemguard_reset_stop_request
        stop_purify_clock.call
        if gemguard_bard?
          set_status.call('Scanning unsung gems...')
          set_purify_status.call('Scanning unsung gems...')
          set_purify_report.call('Purify results: none yet.')
          set_purify_progress.call("Scanning unsung gems.\n\nGemGuard is reading the selected gem container and building the purify list.", 0, 0)
          result = gemguard_with_purify_runtime_settings(value) { gemguard_purify_scan_rows }
          state[:purify] = result[:rows]
          gemguard_sync_review_rows_from_source!(state[:sell] + state[:keep], state[:purify])
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          scan_text = "Purify scan complete: #{state[:purify].length} gem#{state[:purify].length == 1 ? '' : 's'} from #{result[:source]}."
          set_status.call(scan_text)
          set_purify_status.call(scan_text)
          set_purify_progress.call("#{scan_text}\n\nSelect gems on the left, then click Purify Selected.", 0, state[:purify].length)
        else
          set_status.call('Purify is only available to bards.')
        end
        refresh_text.call
      when :sort_review
        mode, reverse = value.is_a?(Array) ? value : [value, false]
        mode = mode.to_s
        reverse = !!reverse
        gemguard_sort_state!(state, mode, reverse)
        gemguard_save_scan_snapshot(state)
        direction = if mode == 'value'
                      reverse ? 'high to low' : 'low to high'
                    else
                      reverse ? 'Z to A' : 'A to Z'
                    end
        set_status.call("Sorted lists by #{mode} #{direction}.")
        refresh_text.call
      when :move_to_keep
        selected_ids = Array(value).map(&:to_s).reject(&:empty?)
        moved = state[:sell].select { |row| selected_ids.include?(row[:id].to_s) }
        if moved.any?
          state[:sell].reject! { |row| selected_ids.include?(row[:id].to_s) }
          moved.each do |row|
            row[:action] = :keep
            row[:reason] = 'manual keep'
          end
          state[:keep].concat(moved)
          gemguard_update_inventory_rows(moved)
          gemguard_save_scan_snapshot(state)
          set_status.call("Moved #{moved.length} selected gem#{moved.length == 1 ? '' : 's'} to keep.")
        else
          set_status.call('No sell rows selected.')
        end
        refresh_text.call
      when :move_to_sell
        selected_ids = Array(value).map(&:to_s).reject(&:empty?)
        moved = state[:keep].select { |row| selected_ids.include?(row[:id].to_s) }
        if moved.any?
          state[:keep].reject! { |row| selected_ids.include?(row[:id].to_s) }
          moved.each do |row|
            row[:action] = :sell
            row[:reason] = 'manual sell'
          end
          state[:sell].concat(moved)
          gemguard_update_inventory_rows(moved)
          gemguard_save_scan_snapshot(state)
          set_status.call("Moved #{moved.length} selected gem#{moved.length == 1 ? '' : 's'} to sell.")
        else
          set_status.call('No keep rows selected.')
        end
        refresh_text.call
      when :toggle_protection, :protect_selected
        selected_ids = Array(value).map(&:to_s).reject(&:empty?).uniq
        selected_rows = (state[:sell] + state[:keep]).select { |row| selected_ids.include?(row[:id].to_s) }
        if selected_rows.empty?
          set_status.call('No gems selected.')
        else
          before_terms = gemguard_protected_terms
          before_exceptions = gemguard_protected_exceptions
          selected_protected = selected_rows.select { |row| gemguard_review_row_protected_by_term?(row, before_terms, before_exceptions) }
          selected_unprotected = selected_rows.reject { |row| gemguard_review_row_protected_by_term?(row, before_terms, before_exceptions) }
          remove_terms = []
          add_terms = []
          add_exceptions = []
          remove_exceptions = []
          selected_protected.each do |row|
            exception_name = gemguard_review_row_exception_name(row)
            exception_key = gemguard_protection_exception_key(exception_name)
            matching_terms = gemguard_review_row_matching_protected_terms(row, before_terms, [])
            exact_terms, broad_terms = matching_terms.partition { |term| gemguard_protection_exception_key(term) == exception_key }
            remove_terms.concat(exact_terms)
            add_exceptions << exception_name if broad_terms.any? && !exception_name.empty?
          end
          selected_unprotected.each do |row|
            exception_name = gemguard_review_row_exception_name(row)
            exception_key = gemguard_protection_exception_key(exception_name)
            matching_exception = before_exceptions.find { |term| gemguard_protection_exception_key(term) == exception_key }
            if matching_exception
              remove_exceptions << matching_exception
            else
              add_terms << exception_name unless exception_name.empty?
            end
          end
          remove_terms = remove_terms.uniq { |term| term.downcase }
          add_terms = add_terms.uniq { |term| term.downcase }
          add_exceptions = add_exceptions.uniq { |term| gemguard_protection_exception_key(term) }
          remove_exceptions = remove_exceptions.uniq { |term| gemguard_protection_exception_key(term) }
          remove_lookup = remove_terms.map(&:downcase)
          updated_terms = before_terms.reject { |term| remove_lookup.include?(term.downcase) } + add_terms
          exception_remove_lookup = remove_exceptions.map { |term| gemguard_protection_exception_key(term) }
          updated_exceptions = before_exceptions.reject { |term| exception_remove_lookup.include?(gemguard_protection_exception_key(term)) } + add_exceptions
          gemguard_save_protected_terms(updated_terms)
          gemguard_save_protected_exceptions(updated_exceptions)
          after_terms = gemguard_protected_terms
          after_exceptions = gemguard_protected_exceptions
          added = add_terms.count { |term| after_terms.any? { |existing| existing.downcase == term.downcase } && before_terms.none? { |existing| existing.downcase == term.downcase } }
          removed = remove_terms.count { |term| after_terms.none? { |existing| existing.downcase == term.downcase } }
          exception_added = add_exceptions.count { |term| after_exceptions.any? { |existing| gemguard_protection_exception_key(existing) == gemguard_protection_exception_key(term) } && before_exceptions.none? { |existing| gemguard_protection_exception_key(existing) == gemguard_protection_exception_key(term) } }
          exception_removed = remove_exceptions.count { |term| after_exceptions.none? { |existing| gemguard_protection_exception_key(existing) == gemguard_protection_exception_key(term) } }
          gemguard_refresh_state_protection!(state, after_terms)
          state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          gemguard_save_scan_snapshot(state)
          if selected_protected.any? && selected_unprotected.any?
            set_status.call("Toggled protection: #{added} protected, #{removed} removed, #{exception_added} excepted, #{exception_removed} restored. #{state[:sell].length} will sell, #{state[:keep].length} will keep.")
          elsif selected_protected.any?
            set_status.call("Unprotected #{removed + exception_added} gem name#{removed + exception_added == 1 ? '' : 's'}. #{exception_added} saved as exact exception#{exception_added == 1 ? '' : 's'}. #{state[:sell].length} will sell, #{state[:keep].length} will keep.")
          else
            set_status.call("Protected #{added + exception_removed} gem name#{added + exception_removed == 1 ? '' : 's'}. #{exception_removed} exception#{exception_removed == 1 ? '' : 's'} removed. #{state[:sell].length} will sell, #{state[:keep].length} will keep.")
          end
        end
        refresh_text.call
      when :orb_test_selected
        gemguard_reset_stop_request
        selected_ids = Array(value).map(&:to_s).reject(&:empty?).uniq
        selected_rows = (state[:sell] + state[:keep]).select { |row| selected_ids.include?(row[:id].to_s) }
        selected_rows.reject! { |row| gemguard_review_row_chrism?(row) || gemguard_review_row_orb?(row) || gemguard_review_row_orb_tested_non_orb?(row) }
        if gemguard_orb_test_mode == :disabled
          set_status.call('Orb testing is only available to bards and sorcerers.')
        elsif selected_rows.empty?
          set_status.call('No untested gems selected.')
        else
          label = gemguard_orb_test_mode == :loresing ? 'Loresinging' : 'Phasing'
          set_status.call("#{label} #{selected_rows.length} selected gem#{selected_rows.length == 1 ? '' : 's'} for pure-orb proof...")
          pure_ids, not_pure, unknown, failed = gemguard_orb_test_review_rows(selected_rows) do |done, total, row, progress|
            if progress[:phase] == :testing
              set_status.call("#{label} #{done + 1}/#{total}: #{row[:name]}...")
            else
              set_status.call("#{label} #{done}/#{total}: #{row[:name]} -> #{progress[:result]}. Orbs #{progress[:orbs]}, not pure #{progress[:not_pure]}, unknown #{progress[:unknown]}, failed #{progress[:failed]}.")
              refresh_text.call(row[:id])
            end
            gemguard_pump_gtk_events
          end
          rows = gemguard_scan_review_rows
          state[:sell] = rows[:sell]
          state[:keep] = rows[:keep]
          state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          prefix = gemguard_stop_requested? ? 'Orb test stopped' : 'Orb test complete'
          set_status.call("#{prefix}: #{pure_ids.length} orb#{pure_ids.length == 1 ? '' : 's'}, #{not_pure} not pure, #{unknown} unknown, #{failed} failed.")
        end
        refresh_text.call
      when :save_global_settings
        unsung, sung, orb, chrism, lapidary_box_value, lapidary_box_container_value, gemcutter_device_value, gemcutter_regular_pattern_value, gemcutter_purified_pattern_value, gemcutter_orb_pattern_value, gemcutter_chrism_pattern_value, threshold, appraised_threshold, sell_value_confirm_enabled, sell_value_ignore_protected, sell_purified_ignore_value, purify_all_gems, gemcutter_debug_enabled, scan_values, ignore_values = Array(value)
        gemguard_save_setting_value(:purify_unsung_container, unsung)
        gemguard_save_setting_value(:purify_sung_container, sung)
        gemguard_save_setting_value(:purify_orb_container, orb)
        gemguard_save_setting_value(:chrism_container, chrism)
        gemguard_save_setting_value(:lapidary_box, lapidary_box_value)
        gemguard_save_setting_value(:lapidary_box_container, lapidary_box_container_value)
        gemguard_save_setting_value(:gemcutter_device, gemcutter_device_value)
        gemguard_save_setting_value(:gemcutter_pattern, gemcutter_regular_pattern_value)
        gemguard_save_setting_value(:gemcutter_regular_pattern, gemcutter_regular_pattern_value)
        gemguard_save_setting_value(:gemcutter_purified_pattern, gemcutter_purified_pattern_value)
        gemguard_save_setting_value(:gemcutter_orb_pattern, gemcutter_orb_pattern_value)
        gemguard_save_setting_value(:gemcutter_chrism_pattern, gemcutter_chrism_pattern_value)
        gemguard_save_setting_value(:pure_orb_sell_threshold, threshold.to_s.gsub(/[^\d]/, ''))
        gemguard_save_setting_value(:appraised_gem_sell_threshold, appraised_threshold.to_s.gsub(/[^\d]/, ''))
        gemguard_save_setting_value(:sell_value_confirm_enabled, gemguard_truthy_value?(sell_value_confirm_enabled) ? 'true' : 'false')
        gemguard_save_setting_value(:sell_value_ignore_protected, gemguard_truthy_value?(sell_value_ignore_protected) ? 'true' : 'false')
        gemguard_save_setting_value(:sell_purified_ignore_value, gemguard_truthy_value?(sell_purified_ignore_value) ? 'true' : 'false')
        gemguard_save_setting_value(:purify_all_gems, gemguard_truthy_value?(purify_all_gems) ? 'true' : 'false')
        gemguard_save_setting_value(:gemcutter_debug_enabled, gemguard_truthy_value?(gemcutter_debug_enabled) ? 'true' : 'false')
        gemguard_save_setting_array(:scan_containers, scan_values)
        gemguard_save_setting_array(:ignore_containers, ignore_values)
        policy = gemguard_apply_sell_policy_to_state(state)
        state[:purify] = gemguard_purify_rows_from_review_rows(
          state[:sell] + state[:keep],
          purify_unsung_container: unsung,
          purify_sung_container: sung,
          purify_orb_container: orb,
          chrism_container: chrism,
          purify_all_gems: purify_all_gems
        )
        gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
        gemguard_save_scan_snapshot(state)
        set_status.call("Saved settings. #{gemguard_sell_policy_text(policy)}")
        gemguard_set_text_view(widgets[:gemcutter_status], gemguard_gemcutter_setup_summary)
        refresh_text.call
      when :analyze_lapidary_box
        box = value.to_s.strip
        if box.empty?
          set_status.call('Type a lapidary box name first.')
        else
          set_status.call("Analyzing lapidary box #{box}...")
          result = gemguard_analyze_lapidary_box(box)
          if result[:ok]
            gemguard_save_lapidary_settings(box, result)
            design_count = Array(result[:designs]).length
            Array(widgets[:gemcutter_pattern_controls]).each do |combo|
              gemguard_set_container_dropdown_choices(combo, gemguard_lapidary_pattern_choices(gemguard_control_text(combo)), gemguard_control_text(combo), true)
            end
            gemguard_set_text_view(widgets[:gemcutter_status], gemguard_gemcutter_setup_summary)
            set_status.call("Saved #{design_count} lapidary design#{design_count == 1 ? '' : 's'} for #{box}.")
          else
            gemguard_set_text_view(widgets[:gemcutter_status], [gemguard_gemcutter_setup_summary, '', result[:error].to_s].join("\n"))
            set_status.call(result[:error].to_s.empty? ? 'Lapidary box analyze failed.' : result[:error].to_s)
          end
        end
      when :save_gemcutter_settings
        cutter, regular_pattern, purified_pattern, orb_pattern, chrism_pattern, box, box_container, gemcutter_debug_enabled = Array(value)
        gemguard_save_setting_value(:gemcutter_device, cutter)
        gemguard_save_setting_value(:gemcutter_pattern, regular_pattern)
        gemguard_save_setting_value(:gemcutter_regular_pattern, regular_pattern)
        gemguard_save_setting_value(:gemcutter_purified_pattern, purified_pattern)
        gemguard_save_setting_value(:gemcutter_orb_pattern, orb_pattern)
        gemguard_save_setting_value(:gemcutter_chrism_pattern, chrism_pattern)
        gemguard_save_setting_value(:lapidary_box, box)
        gemguard_save_setting_value(:lapidary_box_container, box_container)
        gemguard_save_setting_value(:gemcutter_debug_enabled, gemguard_truthy_value?(gemcutter_debug_enabled) ? 'true' : 'false')
        gemguard_set_text_view(widgets[:gemcutter_status], gemguard_gemcutter_setup_summary)
        set_status.call('Saved cutter setup.')
      when :cut_selected_gems
        gemguard_reset_stop_request
        selected_ids = Array(value).map(&:to_s).reject(&:empty?).uniq
        selected_rows = (state[:sell] + state[:keep]).select { |row| selected_ids.include?(row[:id].to_s) }
        if selected_rows.empty?
          set_status.call('Select gems in Review before cutting.')
          gemguard_set_text_view(widgets[:gemcutter_status], [gemguard_gemcutter_setup_summary, '', 'No Review gems were selected.'].join("\n"))
        else
          cut_started_at = Time.now
          set_status.call("Cutting selected gems: 0/#{selected_rows.length}...")
          gemguard_set_text_view(
            widgets[:gemcutter_status],
            [
              gemguard_gemcutter_setup_summary,
              '',
              "Cutting selected gems: 0/#{selected_rows.length}",
              'Elapsed: 0s',
              'Average per gem: waiting for first gem',
              'Estimated remaining: waiting for first gem'
            ].join("\n")
          )
          counts = gemguard_lapidary_cut_rows(selected_rows) do |done, total, row, running|
            row_reason = row[:reason].to_s.strip
            reason_text = row_reason.empty? ? '' : " Reason: #{row_reason}."
            elapsed = [Time.now - cut_started_at, 0].max
            average = done.to_i.positive? ? elapsed / done.to_i : nil
            remaining = [total.to_i - done.to_i, 0].max
            eta = average ? average * remaining : nil
            status_line = "Cutting selected gems: #{done}/#{total}. Cut #{running[:cut].to_i}, skipped #{running[:skipped].to_i}, missing #{running[:missing].to_i}, failed #{running[:failed].to_i}. ETA #{eta ? gemguard_duration_text(eta) : 'waiting for first gem'}. Last: #{row[:name]}.#{reason_text}"
            set_status.call(status_line)
            gemguard_set_text_view(
              widgets[:gemcutter_status],
              [
                gemguard_gemcutter_setup_summary,
                '',
                status_line,
                "Elapsed: #{gemguard_duration_text(elapsed)}",
                "Average per gem: #{average ? gemguard_duration_text(average) : 'waiting for first gem'}",
                "Estimated remaining: #{eta ? gemguard_duration_text(eta) : 'waiting for first gem'}",
                "Current gem type: #{gemguard_gemcutter_kind_label(gemguard_gemcutter_row_kind(row))}",
                "Current pattern: #{gemguard_gemcutter_pattern_for_row(row).empty? ? 'not set' : gemguard_gemcutter_pattern_for_row(row)}"
              ].join("\n")
            )
            refresh_text.call(row[:id])
            gemguard_pump_gtk_events
          end
          if counts[:error]
            set_status.call(counts[:error])
            gemguard_set_text_view(widgets[:gemcutter_status], [gemguard_gemcutter_setup_summary, '', counts[:error]].join("\n"))
          else
            state[:sell], state[:keep] = gemguard_refresh_state_protection!(state).values_at(:sell, :keep)
            state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
            gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
            gemguard_save_scan_snapshot(state)
            failed_details = selected_rows.select { |row| row[:reason].to_s =~ /cut|could not|confirm|lapidary|pattern|failed/i }
                                          .map { |row| "Failed: #{row[:name]} - #{row[:reason]}" }
            elapsed = [Time.now - cut_started_at, 0].max
            summary = "Cutting complete: #{counts[:cut].to_i} cut, #{counts[:skipped].to_i} skipped, #{counts[:missing].to_i} missing, #{counts[:failed].to_i} failed. Elapsed #{gemguard_duration_text(elapsed)}."
            summary = ([summary] + failed_details).join("\n") unless failed_details.empty?
            set_status.call(summary)
            gemguard_set_text_view(widgets[:gemcutter_status], [gemguard_gemcutter_setup_summary, '', summary].join("\n"))
          end
          refresh_text.call
        end
      when :purify_selected, :purify_all
        gemguard_reset_stop_request
        stop_purify_clock.call
        if action_name == :purify_all
          purify_settings = value.is_a?(Hash) ? value : {}
          selected_ids = state[:purify].map { |row| row[:id].to_s }
        else
          selected_ids, purify_settings = value.is_a?(Array) && value.length == 2 && value.last.is_a?(Hash) ? value : [value, {}]
          selected_ids = Array(selected_ids).map(&:to_s).reject(&:empty?).uniq
        end
        selected_rows = state[:purify].select { |row| selected_ids.include?(row[:id].to_s) }
        selected_rows.select! { |row| gemguard_cached_purify_candidate?(row, purify_settings) }
        if !gemguard_bard?
          set_status.call('Purify is only available to bards.')
        elsif selected_rows.empty?
          set_status.call('No ready purify gems selected.')
          set_purify_status.call('No ready purify gems selected.')
          set_purify_progress.call("No ready purify gems selected.\n\nCompleted gems stay visible until you scan again, but GemGuard will only work on gems still marked ready.", 0, 0)
        else
          @purify_song_renewal_reserve = gemguard_song_renewal_reserve
          reserve_text = @purify_song_renewal_reserve.to_i.positive? ? " Preserving #{@purify_song_renewal_reserve.to_i} mana for song renewal." : ''
          set_status.call("Purifying #{selected_rows.length} selected gem#{selected_rows.length == 1 ? '' : 's'}...#{reserve_text}")
          set_purify_status.call("Purifying 0/#{selected_rows.length} selected gem#{selected_rows.length == 1 ? '' : 's'}...#{reserve_text}")
          set_purify_report.call(gemguard_purify_summary_text('Purify progress', Hash.new(0), selected_rows.length))
          purify_timing = { started_at: Time.now, current_started_at: nil }
          set_purify_progress.call(gemguard_purify_progress_text('Purify started.', 0, selected_rows.length, nil, nil, Hash.new(0), purify_timing), 0, selected_rows.length)
          summary = gemguard_with_purify_runtime_settings(purify_settings) do
            gemguard_purify_review_rows(selected_rows) do |stage, done, total, row, kind, running_summary|
            if stage == :start
              purify_timing[:current_started_at] = Time.now
              widgets[:purify_clock_state] = {
                active: true,
                prefix: 'Working on gem.',
                done: done - 1,
                total: total,
                row: row,
                kind: nil,
                summary: running_summary,
                timing: purify_timing
              }
              start_purify_clock.call(widgets[:purify_clock_state])
              set_purify_status.call("Purifying #{done}/#{total}: #{row[:name]}.")
              set_purify_progress.call(gemguard_purify_progress_text('Working on gem.', done - 1, total, row, nil, running_summary, purify_timing), done - 1, total)
            else
              widgets[:purify_clock_state][:active] = false if widgets[:purify_clock_state]
              result_text = (kind == :orb || kind == :already_orb) ? 'orb' : kind.to_s.tr('_', ' ')
              elapsed = Time.now - purify_timing[:started_at]
              remaining = [total - done, 0].max
              eta = done.positive? ? (elapsed / done.to_f) * remaining : nil
              set_purify_status.call("Purified #{done}/#{total}: #{row[:name]} -> #{result_text}. ETA #{gemguard_duration_text(eta)}.")
              set_purify_report.call(gemguard_purify_summary_text('Purify progress', running_summary, total))
              set_purify_progress.call(gemguard_purify_progress_text('Gem finished.', done, total, row, kind, running_summary, purify_timing), done, total)
              gemguard_sync_review_rows_from_source!(state[:sell] + state[:keep], [row])
              refresh_text.call
            end
            gemguard_pump_gtk_events
            end
          end
          stop_purify_clock.call
          prefix = gemguard_stop_requested? ? 'Purify stopped' : 'Purify complete'
          summary_text = gemguard_purify_summary_text(prefix, summary, selected_rows.length)
          processed = summary.values.map(&:to_i).inject(0) { |total, amount| total + amount }
          set_status.call(summary_text)
          set_purify_status.call("#{prefix}.")
          set_purify_report.call(summary_text)
          set_purify_progress.call(gemguard_purify_progress_text(summary_text, processed, selected_rows.length, nil, nil, summary, purify_timing), processed, selected_rows.length)
          gemguard_purify_terminal_report(prefix, summary, selected_rows.length)
          gemguard_sync_review_rows_from_source!(state[:sell] + state[:keep], state[:purify])
          gemguard_save_scan_snapshot(state)
        end
        refresh_text.call
      when :mark_selected, :unmark_selected
        gemguard_reset_stop_request
        selected_ids = Array(value).map(&:to_s).reject(&:empty?).uniq
        selected_rows = (state[:sell] + state[:keep]).select { |row| selected_ids.include?(row[:id].to_s) }
        removing = action_name == :unmark_selected
        selected_rows.select! { |row| removing ? gemguard_review_row_marked?(row) : !gemguard_review_row_marked?(row) }
        if selected_rows.empty?
          set_status.call(removing ? 'No marked gems selected.' : 'No unmarked gems selected.')
        else
          set_status.call("#{removing ? 'Unmarking' : 'Marking'} #{selected_rows.length} selected gem#{selected_rows.length == 1 ? '' : 's'}...")
          changed_ids, failed = gemguard_mark_review_rows(selected_rows, removing)
          rows = gemguard_scan_review_rows
          state[:sell] = rows[:sell]
          state[:keep] = rows[:keep]
          state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          prefix = gemguard_stop_requested? ? "#{removing ? 'Unmarking' : 'Marking'} stopped after #{changed_ids.length}" : "#{removing ? 'Unmarked' : 'Marked'} #{changed_ids.length}"
          set_status.call("#{prefix}; #{failed} failed. Rescanned: #{state[:sell].length} will sell, #{state[:keep].length} will keep.")
        end
        refresh_text.call
      when :add_protected
        term = value.to_s.strip
        if term.empty?
          set_status.call('Enter a gem name or noun to protect.')
        else
          gemguard_save_protected_terms(gemguard_protected_terms + [term])
          set_status.call("Protected #{term}.")
          refresh_text.call
        end
      when :remove_protected
        typed, selected_terms = value
        terms = Array(selected_terms).map(&:to_s).map(&:strip).reject(&:empty?)
        typed = typed.to_s.strip
        terms << typed unless typed.empty?
        terms = terms.uniq { |term| term.downcase }
        if terms.empty?
          set_status.call('Select protected terms or enter a protected name to remove.')
        else
          remove_lookup = terms.map(&:downcase)
          gemguard_save_protected_terms(gemguard_protected_terms.reject { |existing| remove_lookup.include?(existing.downcase) })
          set_status.call("Removed #{terms.length} protected term#{terms.length == 1 ? '' : 's'}.")
          refresh_text.call
        end
      when :add_exception
        term = value.to_s.strip
        if term.empty?
          set_status.call('Enter an exact gem name to make an exception.')
        else
          gemguard_save_protected_exceptions(gemguard_protected_exceptions + [term])
          gemguard_refresh_state_protection!(state)
          state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          gemguard_save_scan_snapshot(state)
          set_status.call("Added exception for #{term}.")
          refresh_text.call
        end
      when :remove_exception
        typed, selected_terms = value
        terms = Array(selected_terms).map(&:to_s).map(&:strip).reject(&:empty?)
        typed = typed.to_s.strip
        terms << typed unless typed.empty?
        terms = terms.uniq { |term| gemguard_protection_exception_key(term) }
        if terms.empty?
          set_status.call('Select exceptions or enter an exact gem name to remove.')
        else
          remove_lookup = terms.map { |term| gemguard_protection_exception_key(term) }
          gemguard_save_protected_exceptions(gemguard_protected_exceptions.reject { |existing| remove_lookup.include?(gemguard_protection_exception_key(existing)) })
          gemguard_refresh_state_protection!(state)
          state[:purify] = gemguard_purify_rows_from_review_rows(state[:sell] + state[:keep], current_purify_settings ? current_purify_settings.call : nil)
          gemguard_sync_rows_from_review!(state[:purify], state[:sell] + state[:keep])
          gemguard_save_scan_snapshot(state)
          set_status.call("Removed #{terms.length} exception#{terms.length == 1 ? '' : 's'}.")
          refresh_text.call
        end
      end
    when :restore_defaults
      gemguard_save_protected_terms(GEMGUARD_DEFAULT_PROTECTED_GEMS)
      gemguard_save_protected_exceptions([])
      set_status.call('Restored the default protected list and cleared exceptions.')
      refresh_text.call
    when :send_eloot
      chrism_sell_protect_eloot
      set_status.call('Sent protected list to ELoot exclusions.')
      refresh_text.call
    end
    ensure
      finish_action_button.call if action && action_button
    end
    gemguard_pump_gtk_events
    sleep 0.1
  end
ensure
  gemguard_clear_scan_snapshot
  gemguard_close_gtk_window_now(window_ref, closed_ref) if window_ref
end

# Runs the command requested by the player.
#
# @param raw_command [String, nil] The first command word after ;gemguard.
# @return [void]
def run(raw_command = nil)
  command = raw_command.to_s.downcase

  case command
  when ''
    gemguard_review_window
  when 'sell', 'run'
    chrism_sell_run
  when 'help', '?'
    chrism_sell_help
  when 'status', 'show'
    chrism_sell_status
  when 'sort-chrisms', 'chrismsort'
    gemguard_sort_chrisms_cli
  when 'protect-eloot', 'eloot-protect', 'install-excludes'
    chrism_sell_protect_eloot
  when 'list'
    chrism_sell_list
  when 'changelog', 'changes'
    chrism_sell_changelog
  else
    echo "gemguard: unknown command '#{command}'."
    chrism_sell_help
  end
end

end

GemGuard.run(script.vars[1])
