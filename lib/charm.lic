# charm.lic
# Author: Zedarius
# Name: charm
# Tags: utility, silver, looting
# Version: 1.0
#
# Designed by Zedarius, written with Claude Opus 4.7
#
# Drives a "gather swarm charm":
#   1. RUB MY CHARM once per pile of "some silver coins" on the ground.
#   2. POINT MY CHARM AT MY <noun> for each box-type item held in either hand,
#      after silently checking that the box is open.
#
# Usage: ;charm
#
# Changelog
# - 1.0 - Initial: rub-per-silver-pile, point at any held box.

box_nouns = /\A(?:box|chest|strongbox|trunk|coffer|casket|crate)\z/i

# Pick a random message from a list, avoiding the one used last time (tracked
# per-key in UserVars so it persists across script runs).
def charm_pick(key, options)
  return options.first if options.length <= 1
  var_name = "charm_last_#{key}"
  last = UserVars[var_name].to_s
  last_idx = last.empty? ? -1 : last.to_i
  pool = (0...options.length).to_a - [last_idx]
  idx = pool.sample
  UserVars[var_name] = idx.to_s
  options[idx]
end

def charm_say(template, vars = {})
  msg = template.dup
  vars.each { |k, v| msg.gsub!("{#{k}}", v.to_s) }
  respond "* Charm: #{msg}"
end

# Silently check whether a held box is open.
def box_open?(box)
  lines = Lich::Util.issue_command(
    "look in ##{box.id}",
    /That is closed|^(?:In|Inside) the |There is nothing in there|appears to be empty/i,
    silent: true, quiet: true
  )
  return true if lines.nil? || lines.empty?
  !lines.any? { |l| l =~ /That is closed/i }
end

SILVER_NONE = [
  "No silver glints on the ground -- the swarm rests.",
  "Nothing shiny down here -- the swarm stays put.",
  "No silver to gather -- the swarm idles.",
  "The ground is bare of coin -- the swarm settles in.",
  "Not a glint to be found -- the swarm waits.",
]

SILVER_FOUND = [
  "{n} {pile} of silver on the ground -- releasing the swarm.",
  "{n} {pile} spotted -- the swarm sets out.",
  "{n} {pile} glinting nearby -- the swarm stirs.",
  "{n} {pile} of coin on the floor -- unleashing the swarm.",
  "{n} silver {pile} in sight -- the swarm goes to work.",
  "{n} {pile} catching the light -- loosing the swarm.",
]

BOX_NONE = [
  "No container in hand -- nothing for the swarm to plunder.",
  "Hands empty of boxes -- the swarm has nowhere to go.",
  "No box held -- the swarm has nothing to enter.",
  "Nothing to plunder -- the swarm sulks.",
  "No coffer in sight -- the swarm stays home.",
]

BOX_CLOSED = [
  "Your {noun} is closed -- the swarm cannot enter.",
  "Your {noun} is shut tight -- the swarm is denied.",
  "Your {noun} is sealed -- no way in for the swarm.",
  "Your {noun} is closed -- the swarm waits at the seam.",
  "Your {noun} is latched -- the swarm is shut out.",
]

BOX_POINT = [
  "Sending the swarm into your {noun}...",
  "Loosing the swarm into your {noun}...",
  "The swarm enters your {noun}...",
  "Releasing the swarm into your {noun}...",
  "Pointing the charm at your {noun} -- the swarm is away.",
  "The swarm sets to work in your {noun}...",
]

# --- Silver on the ground -----------------------------------------------------
silver_piles = GameObj.loot.to_a.select { |o| o.name == "some silver coins" }

if silver_piles.empty?
  charm_say charm_pick("silver_none", SILVER_NONE)
else
  pile_word = silver_piles.length == 1 ? "pile" : "piles"
  charm_say charm_pick("silver_found", SILVER_FOUND),
            n: silver_piles.length, pile: pile_word
  silver_piles.length.times do
    waitrt?
    fput "rub my charm"
    sleep 0.5
  end
end

# --- Box-type items in hands --------------------------------------------------
held = [GameObj.left_hand, GameObj.right_hand].compact.reject { |o|
  o.id.nil? || o.noun.to_s.empty?
}
boxes = held.select { |o| o.type.to_s == "box" || o.noun =~ box_nouns }

if boxes.empty?
  charm_say charm_pick("box_none", BOX_NONE)
else
  boxes.each do |box|
    unless box_open?(box)
      charm_say charm_pick("box_closed", BOX_CLOSED), noun: box.noun
      next
    end
    charm_say charm_pick("box_point", BOX_POINT), noun: box.noun
    waitrt?
    fput "point my charm at my #{box.noun}"
    sleep 0.5
  end
end

respond "* Charm: Done."
