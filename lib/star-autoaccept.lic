# star-autoaccept.lic
# Automatically ACCEPTs any offer from anyone.
# To stop: ;kill star-autoaccept

module Star
  class Pass
    def self.run
      echo "[star-pass] Waiting for offers..."
      loop do
        line = get
        next unless line
        if line =~ /\boffers you\b/i
          waitrt?
          fput "ACCEPT"
        end
      end
    end
  end
end

Star::Pass.run
