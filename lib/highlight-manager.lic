def canonical_tag(config, tag_name)
  wanted = tag_name.to_s.strip
  return nil if wanted.empty?

  known_tags = tag_colors(config).keys + DEFAULT_TAG_COLORS.keys + (config['tag_colors'] || {}).keys
  known_tags.find { |tag| tag.downcase == wanted.downcase } || normalize_tag_name(wanted)
end

def valid_tag_name?(tag)
  tag.to_s =~ /\A[A-Za-z0-9][A-Za-z0-9 _-]*\z/
end

def normalize_person_name(name)
  text = name.to_s.strip.gsub(/[,;]/, '')
  return nil unless text =~ /\A[A-Za-z][A-Za-z'-]{1,29}\z/

  text.downcase.split(/([-'])/).map do |part|
    if part == '-' || part == "'"
      part
    else
      part[0].to_s.upcase + part[1, part.length].to_s
    end
  end.join
end

def tag_names(config, tag, names)
  tag = canonical_tag(config, tag)
  unless valid_tag_name?(tag)
    ph_echo "Invalid tag name: #{tag.inspect}. Use letters, numbers, underscores, or dashes."
    return false
  end

  config['tag_colors'] ||= {}
  config['tag_colors'][tag] ||= DEFAULT_TAG_COLORS[tag] || ['#FFFFFF', '#000000']
  data = character_data
  data['names'] ||= {}

  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  if normalized.empty?
    ph_echo 'No valid names provided.'
    return false
  end

  now = Time.now.utc.iso8601
  normalized.each do |name|
    existing = data['names'][name.downcase] || {}
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => existing['profession'].to_s,
      'race' => existing['race'].to_s,
      'manual_profession' => existing['manual_profession'].to_s,
      'manual_race' => existing['manual_race'].to_s,
      'custom_tag' => tag,
      'notes' => note_entries_from_record(existing),
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => now,
      'profession_updated_at' => existing['profession_updated_at'].to_s,
      'race_updated_at' => existing['race_updated_at'].to_s,
      'manual_profession_updated_at' => existing['manual_profession_updated_at'].to_s,
      'manual_race_updated_at' => existing['manual_race_updated_at'].to_s,
      'custom_updated_at' => now,
    }
  end
  save_config(config)
  save_character_data(data)
  ph_echo "Tagged #{normalized.length} name(s) as #{tag}: #{normalized.join(', ')}"
  true
end

def tagged_name_count(tag)
  normalized_tag = tag.to_s.strip.downcase
  return 0 if normalized_tag.empty?

  (character_data['names'] || {}).count do |_key, entry|
    entry.is_a?(Hash) && entry['custom_tag'].to_s.strip.downcase == normalized_tag
  end
end

def tagged_names_for_tag(tag)
  normalized_tag = tag.to_s.strip.downcase
  return [] if normalized_tag.empty?

  (character_data['names'] || {}).each_value.each_with_object([]) do |entry, names|
    next unless entry.is_a?(Hash)
    next unless entry['custom_tag'].to_s.strip.downcase == normalized_tag

    name = entry['name'].to_s.strip
    names << name unless name.empty?
  end.uniq.sort
end

def tagged_name_summary(tag, limit = 2)
  names = tagged_names_for_tag(tag)
  return ['0', 'No saved names for this label.'] if names.empty?

  [names.length.to_s, names.join(', ')]
end

def manual_label_names(config)
  defaults = DEFAULT_TAG_COLORS.keys
  discovered = []
  tag_colors(config).keys.each { |tag| discovered << tag unless discovered.any? { |known| known.downcase == tag.downcase } }
  (character_data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    tag = entry['custom_tag'].to_s.strip
    discovered << tag unless tag.empty? || discovered.any? { |known| known.downcase == tag.downcase }
  end

  custom = discovered.reject { |tag| defaults.any? { |default| default.downcase == tag.downcase } }
  imported, named = custom.partition { |tag| tag =~ /\AImported\s+\d+\z/i }
  imported.sort_by! { |tag| [tag[/\d+/].to_i, tag.downcase] }
  named.sort_by!(&:downcase)
  defaults + named + imported
end

def saved_names_for_field(field, value)
  normalized_value = value.to_s.strip.downcase
  return [] if normalized_value.empty?

  (character_data['names'] || {}).each_value.each_with_object([]) do |entry, names|
    next unless entry.is_a?(Hash)
    entry_value = case field.to_s
                  when 'profession'
                    effective_profession(entry)
                  when 'race'
                    effective_race(entry)
                  else
                    entry[field].to_s.strip
                  end
    next unless entry_value.to_s.strip.downcase == normalized_value

    name = entry['name'].to_s.strip
    names << name unless name.empty?
  end.uniq.sort
end

def label_name_items(config)
  items = []
  items << { kind: 'header', title: 'Manual Labels' }
  manual_label_names(config).each do |tag|
    names = tagged_names_for_tag(tag)
    items << {
      kind: 'manual',
      key: "manual:#{tag.downcase}",
      title: tag,
      count: names.length,
      names: names,
    }
  end

  items << { kind: 'header', title: 'Professions' }
  DEFAULT_PROFESSION_COLORS.keys.each do |profession|
    names = saved_names_for_field('profession', profession)
    items << {
      kind: 'profession',
      key: "profession:#{profession.downcase}",
      title: profession,
      count: names.length,
      names: names,
    }
  end

  items << { kind: 'header', title: 'Races' }
  RACES.each do |race|
    names = saved_names_for_field('race', race)
    items << {
      kind: 'race',
      key: "race:#{race.downcase}",
      title: race,
      count: names.length,
      names: names,
    }
  end

  items
end

def label_names_report_and_ranges_for_item(item, columns = nil)
  item ||= {}
  names = item[:names] || []
  lines = []
  ranges = []
  offset = 0
  if names.empty?
    lines << '(none)'
    offset += lines.last.length + 1
  else
    width = [names.map(&:length).max.to_i + 2, 14].max
    columns ||= if names.length >= 140
                  7
                elsif names.length >= 80
                  6
                elsif names.length >= 35
                  5
                else
                  4
                end
    names.each_slice(columns) do |slice|
      line = ''
      line_ranges = []
      slice.each do |name|
        start_offset = offset + line.length
        cell = name.ljust(width)
        line << cell
        line_ranges << {
          start: start_offset,
          end: start_offset + name.length,
          name: name,
        }
      end
      line = line.rstrip
      line_end = offset + line.length
      line_ranges.each do |range|
        range[:end] = [range[:end], line_end].min
        ranges << range if range[:end] > range[:start]
      end
      lines << line
      offset += line.length + 1
    end
  end
  ["#{lines.join("\n").rstrip}\n", ranges]
end

def apply_label_name_click_styles(text_view, ranges)
  return unless text_view && text_view.respond_to?(:buffer)
  return unless defined?(Gtk::TextTag) && defined?(Pango::Underline)

  buffer = text_view.buffer
  tag = begin
          buffer.tag_table.lookup('highlight-manager-click-name') if buffer.respond_to?(:tag_table) && buffer.tag_table.respond_to?(:lookup)
        rescue
          nil
        end
  unless tag
    tag = if buffer.respond_to?(:create_tag)
            buffer.create_tag('highlight-manager-click-name')
          elsif defined?(Gtk::TextTag)
            Gtk::TextTag.new('highlight-manager-click-name')
          end
    if tag
      tag.underline = Pango::Underline::SINGLE if tag.respond_to?(:underline=)
      tag.foreground = '#66CCFF' if tag.respond_to?(:foreground=)
      begin
        buffer.tag_table.add(tag) if buffer.respond_to?(:tag_table) && buffer.tag_table.respond_to?(:add)
      rescue
        nil
      end
    end
  end
  return unless tag && (buffer.respond_to?(:get_iter_at) || buffer.respond_to?(:get_iter_at_offset)) && buffer.respond_to?(:apply_tag)

  ranges.to_a.each do |range|
    start_offset = range[:start].to_i
    end_offset = range[:end].to_i
    next unless end_offset > start_offset

    start_iter = text_buffer_iter_at_offset(buffer, start_offset)
    end_iter = text_buffer_iter_at_offset(buffer, end_offset)
    buffer.apply_tag(tag, start_iter, end_iter)
  end
rescue => error
  gtk_debug "Label Names clickable style failed: #{error.class}: #{error.message}" if respond_to?(:gtk_debug)
end

def text_buffer_iter_at_offset(buffer, offset)
  if buffer.respond_to?(:get_iter_at)
    buffer.get_iter_at(:offset => offset)
  else
    buffer.get_iter_at_offset(offset)
  end
end

def gdk_click_cursor
  return nil unless defined?(Gdk::Cursor)

  begin
    return Gdk::Cursor.new(:hand2)
  rescue
    nil
  end
  begin
    return Gdk::Cursor.new(Gdk::CursorType::HAND2) if defined?(Gdk::CursorType)
  rescue
    nil
  end
  begin
    display = Gdk::Display.default if defined?(Gdk::Display) && Gdk::Display.respond_to?(:default)
    return Gdk::Cursor.new_from_name(display, 'pointer') if display && Gdk::Cursor.respond_to?(:new_from_name)
  rescue
    nil
  end
  nil
end

def set_clickable_text_view_cursor(text_view)
  cursor = gdk_click_cursor
  return unless cursor && text_view

  if text_view.respond_to?(:window) && text_view.window && text_view.window.respond_to?(:cursor=)
    text_view.window.cursor = cursor
  end
  if text_view.respond_to?(:get_window) && defined?(Gtk::TextWindowType)
    [Gtk::TextWindowType::TEXT, Gtk::TextWindowType::WIDGET].each do |window_type|
      begin
        text_window = text_view.get_window(window_type)
        text_window.cursor = cursor if text_window && text_window.respond_to?(:cursor=)
      rescue
        nil
      end
    end
  end
rescue => error
  gtk_debug "Label Names cursor setup failed: #{error.class}: #{error.message}" if respond_to?(:gtk_debug)
end

def label_names_report_for_item(item, columns = nil)
  label_names_report_and_ranges_for_item(item, columns).first
end

def label_name_columns_for_width(width, names)
  names ||= []
  longest = names.map { |name| name.to_s.length }.max.to_i
  name_width = [longest + 2, 14].max
  # GTK reports pixel width, but the TextView's real usable area loses space to
  # margins, borders, and scrollbars. Use a conservative character estimate so
  # the last column wraps instead of disappearing under the right edge.
  usable_pixels = [width.to_i - 96, 160].max
  columns = (usable_pixels / (name_width * 10.0)).floor
  [[columns, 1].max, 8].min
rescue
  nil
end

def format_local_timestamp(value)
  text = value.to_s.strip
  return 'unknown' if text.empty?

  time = Time.parse(text).localtime
  zone = short_time_zone_name(time)
  "#{time.strftime('%m-%d-%Y %I:%M %p')} #{zone}".strip
rescue
  text
end

def short_time_zone_name(time)
  zone = time.strftime('%Z').to_s.strip
  zone = time.zone.to_s.strip if zone.empty? && time.respond_to?(:zone)
  return '' if zone.empty?

  compact = {
    'Pacific Standard Time' => 'PST',
    'Pacific Daylight Time' => 'PDT',
    'Mountain Standard Time' => 'MST',
    'Mountain Daylight Time' => 'MDT',
    'Central Standard Time' => 'CST',
    'Central Daylight Time' => 'CDT',
    'Eastern Standard Time' => 'EST',
    'Eastern Daylight Time' => 'EDT',
    'Alaskan Standard Time' => 'AKST',
    'Alaskan Daylight Time' => 'AKDT',
    'Hawaiian Standard Time' => 'HST',
    'Hawaii-Aleutian Standard Time' => 'HST',
    'Hawaii-Aleutian Daylight Time' => 'HDT',
  }[zone]
  return compact if compact

  words = zone.scan(/[A-Za-z]+/)
  return words.map { |word| word[0] }.join.upcase if words.length > 1

  zone
end

def format_local_timestamp_or_never(value)
  text = value.to_s.strip
  return 'never' if text.empty?

  format_local_timestamp(text)
end

def lookup_character_report(config, name)
  normalized = normalize_person_name(name)
  return "Type a character name to look up.\n" unless normalized

  record = (character_data['names'] || {})[normalized.downcase]
  return "No saved data for #{normalized}.\n" unless record.is_a?(Hash)

  auto_profession = record['profession'].to_s.strip
  auto_race = record['race'].to_s.strip
  manual_profession = record['manual_profession'].to_s.strip
  manual_race = record['manual_race'].to_s.strip
  profession = effective_profession(record)
  race = effective_race(record)
  custom = record['custom_tag'].to_s.strip
  mode = current_mode(config)
  export_as = if !custom.empty? && tag_colors(config).keys.any? { |tag| tag.downcase == custom.downcase }
                custom
              elsif mode == 'race'
                race.empty? ? '(not exported in race mode)' : race
              elsif mode == 'race_profession'
                if race.empty? && profession.empty?
                  '(not exported in race + profession mode)'
                elsif race.empty?
                  "#{profession} background, unknown-race text"
                elsif profession.empty?
                  "#{race} text, no background"
                else
                  "#{race} text + #{profession} background"
                end
              elsif mode == 'custom'
                '(not exported in custom-only mode)'
              else
                profession.empty? ? '(not exported in profession mode)' : profession
              end

  sections = [
    ['Highlight', [
      ['Manual label', custom.empty? ? 'none' : custom],
      ['Current mode', mode_label(mode)],
      ['Would export as', export_as],
    ]],
    ['Character Data', [
      ['Profession', profession.empty? ? 'unknown' : "#{profession}#{manual_profession.empty? ? '' : ' (manual)'}"],
      ['Race', race.empty? ? 'unknown' : "#{race}#{manual_race.empty? ? '' : ' (manual)'}"],
      ['WHO profession', auto_profession.empty? ? 'unknown' : auto_profession],
      ['WHO race', auto_race.empty? ? 'unknown' : auto_race],
    ]],
  ]
  date_rows = [
    ['Added to data', format_local_timestamp(record['first_seen'])],
    ['Last seen in WHO', format_local_timestamp_or_never(record['last_seen'])],
    ['Profession updated', format_local_timestamp_or_never(manual_profession.empty? ? record['profession_updated_at'] : record['manual_profession_updated_at'])],
    ['Race updated', format_local_timestamp_or_never(manual_race.empty? ? record['race_updated_at'] : record['manual_race_updated_at'])],
    ['Manual label updated', format_local_timestamp_or_never(record['custom_updated_at'])],
  ]
  notes = note_entries_from_record(record)
  width = (sections.flat_map { |_title, rows| rows.map { |label, _value| label.length } } + date_rows.map { |label, _value| label.length } + ['Name'.length]).max || 0
  row_lines = lambda do |label, value|
    lines = value.to_s.lines.map(&:chomp)
    first = lines.shift || ''
    output = ["#{label.rjust(width)}  #{first}"]
    lines.each { |line| output << "#{' ' * width}  #{line}" }
    output.join("\n")
  end
  note_lines = notes.empty? ? ['none'] : notes.each_with_index.map { |entry, index| "#{index + 1}. #{entry['text']}" }
  all_rows = [['Name', record['name'].to_s.strip]] + sections.flat_map { |_title, rows| rows } + date_rows
  content_width = all_rows.map { |label, value| row_lines.call(label, value).lines.map { |line| line.chomp.length }.max.to_i }.max.to_i
  content_width = [content_width, note_lines.map(&:length).max.to_i, 32].max
  section_header = lambda do |title|
    text = " #{title} "
    return text if text.length >= content_width

    left = (content_width - text.length) / 2
    right = content_width - text.length - left
    ('-' * left) + text + ('-' * right)
  end

  output = [row_lines.call('Name', record['name'].to_s.strip), '']
  sections.each do |title, rows|
    output << section_header.call(title)
    rows.each { |label, value| output << row_lines.call(label, value) }
    output << ''
  end
  output << section_header.call('Notes')
  if notes.empty?
    output << 'none'.center(content_width)
  else
    note_lines.each { |line| output << "  #{line}" }
  end
  output << ''
  output << section_header.call('Dates')
  date_rows.each { |label, value| output << row_lines.call(label, value) }
  output << ''
  output.join("\n")
end

def lookup_export_description(config, record)
  custom = record['custom_tag'].to_s.strip
  mode = current_mode(config)
  profession = effective_profession(record)
  race = effective_race(record)

  if !custom.empty? && tag_colors(config).keys.any? { |tag| tag.downcase == custom.downcase }
    custom
  elsif mode == 'race'
    race.empty? ? 'not exported' : race
  elsif mode == 'race_profession'
    if race.empty? && profession.empty?
      'not exported'
    elsif race.empty?
      "#{profession} bg + unknown text"
    elsif profession.empty?
      "#{race} text + no bg"
    else
      "#{race} + #{profession}"
    end
  elsif mode == 'custom'
    'not exported'
  else
    profession.empty? ? 'not exported' : profession
  end
end

def lookup_character_brief(config, name)
  normalized = normalize_person_name(name)
  return nil unless normalized

  record = (character_data['names'] || {})[normalized.downcase]
  return {
    name: normalized,
    race: 'no saved data',
    profession: '',
    label: '',
    export: '',
    manual: false,
    missing: true,
  } unless record.is_a?(Hash)

  race = effective_race(record)
  profession = effective_profession(record)
  label = record['custom_tag'].to_s.strip
  manual_race = !record['manual_race'].to_s.strip.empty?
  manual_profession = !record['manual_profession'].to_s.strip.empty?
  race_text = race.empty? ? 'unknown' : "#{race}#{manual_race ? '*' : ''}"
  profession_text = profession.empty? ? 'unknown' : "#{profession}#{manual_profession ? '*' : ''}"
  label_text = label.empty? ? 'none' : label
  export_text = lookup_export_description(config, record)

  {
    name: record['name'].to_s.strip,
    race: race_text,
    profession: profession_text,
    label: label_text,
    export: export_text,
    manual: manual_race || manual_profession,
    missing: false,
  }
end

def current_room_player_names
  return [] unless defined?(GameObj) && GameObj.respond_to?(:pcs)

  GameObj.pcs.to_a.map do |pc|
    raw = if pc.respond_to?(:noun)
            pc.noun
          elsif pc.respond_to?(:name)
            pc.name
          else
            pc.to_s
          end
    normalize_person_name(raw.to_s.split(/\s+/).first)
  end.compact.uniq.sort
rescue => error
  ph_echo "Room lookup failed: #{error.message}"
  []
end

def lookup_table_lines(rows)
  rows = rows.compact
  return [] if rows.empty?

  columns = [
    [:name, 'Name', 15],
    [:race, 'Race', 18],
    [:profession, 'Profession', 14],
    [:label, 'Label', 12],
    [:export, 'Would Export As', 18],
  ]
  widths = {}
  columns.each do |key, header, minimum|
    content_width = rows.map { |row| row[key].to_s.length }.max || 0
    widths[key] = [minimum, header.length, content_width].max
  end

  header = columns.map { |key, title, _minimum| title.ljust(widths[key]) }.join('  ').rstrip
  divider = columns.map { |key, _title, _minimum| '-' * widths[key] }.join('  ')
  lines = [header, divider]
  rows.each do |row|
    lines << columns.map { |key, _title, _minimum| row[key].to_s.ljust(widths[key]) }.join('  ').rstrip
  end
  lines
end

def handle_lookup_command(config, raw_args, args)
  target = raw_args[0].to_s.strip
  if target.empty?
    ph_echo 'Usage: ;highlight-manager lookup NAME'
    ph_echo '       ;highlight-manager lookup room'
    return
  end

  if args[0] == 'room'
    names = current_room_player_names
    if names.empty?
      ph_echo 'Highlight Manager room lookup: no visible player names found through Lich.'
      return
    end

    ph_echo ''
    ph_echo "Highlight Manager room lookup: #{names.length} visible player(s)"
    ph_echo ''
    rows = names.map { |name| lookup_character_brief(config, name) }.compact
    manual_seen = rows.any? { |row| row[:manual] }
    lookup_table_lines(rows).each { |line| ph_echo "  #{line}" }
    ph_echo '  * = manually entered race/profession' if manual_seen
    ph_echo ''
    return
  end

  names = raw_args.map { |name| normalize_person_name(name) }.compact.uniq
  if names.length <= 1
    normalized = normalize_person_name(target) || target
    ph_echo ''
    ph_echo "Highlight Manager lookup: #{normalized}"
    ph_echo ''
    lookup_character_report(config, target).each_line { |line| ph_echo "  #{line.rstrip}" }
    ph_echo ''
  else
    ph_echo ''
    ph_echo "Highlight Manager lookup: #{names.length} name(s)"
    ph_echo ''
    rows = names.map { |name| lookup_character_brief(config, name) }.compact
    manual_seen = rows.any? { |row| row[:manual] }
    lookup_table_lines(rows).each { |line| ph_echo "  #{line}" }
    ph_echo '  * = manually entered race/profession' if manual_seen
    ph_echo ''
  end
end

def character_record_with_notes(name, existing, notes)
  now = Time.now.utc.iso8601
  {
    'name' => name,
    'profession' => existing['profession'].to_s,
    'race' => existing['race'].to_s,
    'manual_profession' => existing['manual_profession'].to_s,
    'manual_race' => existing['manual_race'].to_s,
    'custom_tag' => existing['custom_tag'].to_s,
    'notes' => notes,
    'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
    'last_seen' => existing['last_seen'].to_s,
    'profession_updated_at' => existing['profession_updated_at'].to_s,
    'race_updated_at' => existing['race_updated_at'].to_s,
    'manual_profession_updated_at' => existing['manual_profession_updated_at'].to_s,
    'manual_race_updated_at' => existing['manual_race_updated_at'].to_s,
    'custom_updated_at' => existing['custom_updated_at'].to_s,
  }
end

def print_character_notes(name, notes)
  ph_echo ''
  ph_echo "Highlight Manager notes: #{name}"
  if notes.empty?
    ph_echo '  (none)'
  else
    notes.each_with_index { |entry, index| ph_echo "  #{index + 1}. #{entry['text']}" }
  end
  ph_echo ''
end

def note_command_usage
  ph_echo 'Usage: ;highlight-manager note add NAME note text'
  ph_echo '       ;highlight-manager note remove NAME #'
  ph_echo '       ;highlight-manager note clear NAME'
  ph_echo '       ;highlight-manager note NAME'
  ph_echo "       Notes are local-only, max #{NOTE_MAX_COUNT} per name, #{NOTE_MAX_LENGTH} characters each."
end

def handle_note_command(config, raw_args, args)
  tokens = raw_args.to_a.map(&:to_s)
  action = args[0].to_s.downcase
  action_aliases = {
    'add' => 'add',
    'new' => 'add',
    'remove' => 'remove',
    'delete' => 'remove',
    'del' => 'remove',
    'rm' => 'remove',
    'clear' => 'clear',
    'clearall' => 'clear',
    'list' => 'show',
    'show' => 'show',
  }
  if action_aliases[action]
    action = action_aliases[action]
    tokens.shift
  else
    action = 'show'
  end

  name = normalize_person_name(tokens.shift)
  unless name
    note_command_usage
    return false
  end
  action = 'add' if action == 'show' && !tokens.empty?

  data = character_data
  data['names'] ||= {}
  existing = data['names'][name.downcase].is_a?(Hash) ? data['names'][name.downcase] : {}
  notes = note_entries_from_record(existing)
  now = Time.now.utc.iso8601

  case action
  when 'add'
    text = tokens.join(' ').strip.gsub(/\s+/, ' ')
    if text.empty?
      ph_echo 'No note text provided.'
      note_command_usage
      return false
    end
    if notes.length >= NOTE_MAX_COUNT
      ph_echo_monsterbold "#{name} already has #{NOTE_MAX_COUNT} note(s). Remove one before adding another."
      ph_echo "Remove one first with: ;highlight-manager note remove #{name} #"
      ph_echo 'Nothing was saved.'
      print_character_notes(name, notes)
      return false
    end
    if text.length > NOTE_MAX_LENGTH
      ph_echo_monsterbold "That note is #{text.length} characters. Notes can be #{NOTE_MAX_LENGTH} characters max."
      ph_echo 'Nothing was saved.'
      return false
    end

    notes << { 'text' => text, 'created_at' => now, 'updated_at' => now }
    data['names'][name.downcase] = character_record_with_notes(name, existing, notes)
    save_character_data(data)
    ph_echo "Added note #{notes.length} for #{name}: #{text}"
    true
  when 'remove'
    index_text = tokens.shift.to_s
    index = index_text.to_i
    if index_text !~ /\A\d+\z/ || index < 1 || index > notes.length
      ph_echo "Choose a note number from 1 to #{notes.length} for #{name}."
      print_character_notes(name, notes)
      return false
    end

    removed = notes.delete_at(index - 1)
    data['names'][name.downcase] = character_record_with_notes(name, existing, notes)
    save_character_data(data)
    ph_echo "Removed note #{index} for #{name}: #{removed['text']}"
    true
  when 'clear'
    data['names'][name.downcase] = character_record_with_notes(name, existing, [])
    save_character_data(data)
    ph_echo "Cleared #{notes.length} note(s) for #{name}."
    true
  else
    print_character_notes(name, notes)
    true
  end
end

def handle_legacy_note_command(config, action, raw_args, args)
  handle_note_command(config, [action, *raw_args], [action, *args])
end

def untag_names(config, names)
  data = character_data
  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  removed = []
  normalized.each do |name|
    record = data['names'][name.downcase]
    next unless record.is_a?(Hash) && !record['custom_tag'].to_s.empty?

    record['custom_tag'] = ''
    record['custom_updated_at'] = Time.now.utc.iso8601
    removed << name
  end
  save_config(config)
  save_character_data(data)
  ph_echo "Removed manual tags from #{removed.length} name(s): #{removed.join(', ')}"
  true
end

def remove_tag(config, tag)
  tag = canonical_tag(config, tag)
  unless valid_tag_name?(tag)
    ph_echo 'Usage: ;highlight-manager untag LABEL'
    return false
  end

  if DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == tag.downcase }
    ph_echo "#{tag} is a built-in tag and cannot be removed. Use remove NAME to clear names from it."
    return false
  end

  config['tag_colors'] ||= {}
  config['disabled_tags'] ||= []

  unless config['tag_colors'].keys.any? { |custom_tag| custom_tag.downcase == tag.downcase }
    ph_echo "No custom tag named #{tag} exists."
    return false
  end

  config['tag_colors'].delete_if { |custom_tag, _pair| custom_tag.to_s.downcase == tag.downcase }
  config['disabled_tags'] << tag.downcase
  config['disabled_tags'].uniq!

  removed_names = []
  data = character_data
  (data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash) && entry['custom_tag'].to_s.downcase == tag.downcase

    removed_names << entry['name']
    entry['custom_tag'] = ''
    entry['custom_updated_at'] = Time.now.utc.iso8601
  end

  save_config(config)
  save_character_data(data)
  ph_echo "Removed tag #{tag} and #{removed_names.length} tagged name(s)."
  true
end

def clear_deleted_label_assignments(config, deleted_tags)
  tags = deleted_tags.map { |tag| normalize_tag_name(tag) || tag.to_s.strip }.reject(&:empty?).uniq
  tags.reject! { |tag| DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == tag.downcase } }
  return {} if tags.empty?

  tag_lookup = tags.each_with_object({}) { |tag, lookup| lookup[tag.downcase] = tag }
  removed_counts = Hash.new(0)
  data = character_data
  (data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    current_tag = entry['custom_tag'].to_s.strip
    deleted_tag = tag_lookup[current_tag.downcase]
    next unless deleted_tag

    entry['custom_tag'] = ''
    entry['custom_updated_at'] = Time.now.utc.iso8601
    removed_counts[deleted_tag] += 1
  end

  config['disabled_tags'] ||= []
  tags.each { |tag| config['disabled_tags'] << tag.downcase }
  config['disabled_tags'].uniq!
  save_character_data(data) unless removed_counts.empty?
  removed_counts
end

def set_tag_color(config, tag, fore, back)
  tag = canonical_tag(config, tag)
  fore = normalize_hex(fore)
  back = normalize_background(back, nil)
  unless valid_tag_name?(tag) && fore && !back.nil?
    ph_echo 'Usage: ;highlight-manager tag LABEL #RRGGBB #RRGGBB'
    ph_echo '       Use none, transparent, clear, or blank for no background.'
    return false
  end

  config['tag_colors'] ||= {}
  config['disabled_tags'] ||= []
  config['disabled_tags'].delete_if { |disabled| disabled.to_s.downcase == tag.downcase }
  config['tag_colors'][tag] = [fore, back]
  save_config(config)
  ph_echo "Set #{tag} colors to #{fore} on #{back}"
  true
end

def split_label_and_names(raw_args)
  joined = raw_args.join(' ')
  if joined.include?(';')
    label, rest = joined.split(';', 2)
    names = rest.to_s.split(/[,\s]+/)
    [label.to_s.strip, names]
  elsif joined.include?(':')
    label, rest = joined.split(':', 2)
    names = rest.to_s.split(/[,\s]+/)
    [label.to_s.strip, names]
  else
    [raw_args[0].to_s.strip, raw_args[1, raw_args.length] || []]
  end
end

def parse_tag_name_lines(text)
  entries = []
  text.to_s.each_line do |line|
    cleaned = line.strip
    next if cleaned.empty?

    if cleaned.include?(';')
      tag, rest = cleaned.split(';', 2)
    elsif cleaned.include?(':')
      tag, rest = cleaned.split(':', 2)
    else
      parts = cleaned.split(/\s+/)
      tag = parts.shift
      rest = parts.join(' ')
    end
    names = rest.to_s.split(/[,\s]+/).map(&:strip).reject(&:empty?)
    entries << [tag.to_s.strip, names] unless tag.to_s.strip.empty? || names.empty?
  end
  entries
end

def manual_set_race(config, raw_args)
  race, names = split_label_and_names(raw_args)
  canonical_race = RACES.find { |known| known.downcase == race.downcase }
  unless canonical_race
    ph_echo "Unknown race: #{race}. Valid races: #{RACES.join(', ')}"
    return false
  end
  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  if normalized.empty?
    ph_echo 'No valid names provided.'
    return false
  end

  data = character_data
  now = Time.now.utc.iso8601
  normalized.each do |name|
    existing = data['names'][name.downcase] || {}
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => existing['profession'].to_s,
      'race' => existing['race'].to_s,
      'manual_profession' => existing['manual_profession'].to_s,
      'manual_race' => canonical_race,
      'custom_tag' => existing['custom_tag'].to_s,
      'notes' => note_entries_from_record(existing),
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => existing['last_seen'].to_s,
      'profession_updated_at' => existing['profession_updated_at'].to_s,
      'race_updated_at' => existing['race_updated_at'].to_s,
      'manual_profession_updated_at' => existing['manual_profession_updated_at'].to_s,
      'manual_race_updated_at' => now,
      'custom_updated_at' => existing['custom_updated_at'].to_s,
    }
  end
  save_character_data(data)
  ph_echo "Manually set race #{canonical_race} for #{normalized.length} name(s): #{normalized.join(', ')}"
  true
end

def manual_set_profession(config, raw_args)
  profession, names = split_label_and_names(raw_args)
  canonical_profession = DEFAULT_PROFESSION_COLORS.keys.find { |known| known.downcase == profession.downcase }
  unless canonical_profession
    ph_echo "Unknown profession: #{profession}. Valid professions: #{DEFAULT_PROFESSION_COLORS.keys.join(', ')}"
    return false
  end
  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  if normalized.empty?
    ph_echo 'No valid names provided.'
    return false
  end

  data = character_data
  now = Time.now.utc.iso8601
  normalized.each do |name|
    existing = data['names'][name.downcase] || {}
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => existing['profession'].to_s,
      'race' => existing['race'].to_s,
      'manual_profession' => canonical_profession,
      'manual_race' => existing['manual_race'].to_s,
      'custom_tag' => existing['custom_tag'].to_s,
      'notes' => note_entries_from_record(existing),
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => existing['last_seen'].to_s,
      'profession_updated_at' => existing['profession_updated_at'].to_s,
      'race_updated_at' => existing['race_updated_at'].to_s,
      'manual_profession_updated_at' => now,
      'manual_race_updated_at' => existing['manual_race_updated_at'].to_s,
      'custom_updated_at' => existing['custom_updated_at'].to_s,
    }
  end
  save_character_data(data)
  ph_echo "Manually set profession #{canonical_profession} for #{normalized.length} name(s): #{normalized.join(', ')}"
  true
end

def clear_manual_info(config, raw_args)
  tokens = raw_args.to_a.map(&:to_s).reject { |token| token.strip.empty? }
  kind_aliases = {
    'race' => 'race',
    'races' => 'race',
    'prof' => 'profession',
    'profession' => 'profession',
    'professions' => 'profession',
    'all' => 'all',
    'both' => 'all',
  }
  kind = nil
  if kind_aliases[tokens.first.to_s.downcase]
    kind = kind_aliases[tokens.shift.downcase]
  elsif kind_aliases[tokens.last.to_s.downcase]
    kind = kind_aliases[tokens.pop.downcase]
  end
  unless kind
    ph_echo 'Usage: ;highlight-manager clearinfo Bob Sue race|profession|all'
    return false
  end

  normalized = tokens.map { |name| normalize_person_name(name) }.compact.uniq
  if normalized.empty?
    ph_echo 'No valid names provided.'
    return false
  end

  data = character_data
  cleared = []
  now = Time.now.utc.iso8601
  normalized.each do |name|
    record = data.dig('names', name.downcase)
    next unless record.is_a?(Hash)

    changed = false
    if %w[race all].include?(kind) && !record['manual_race'].to_s.empty?
      record['manual_race'] = ''
      record['manual_race_updated_at'] = now
      changed = true
    end
    if %w[profession all].include?(kind) && !record['manual_profession'].to_s.empty?
      record['manual_profession'] = ''
      record['manual_profession_updated_at'] = now
      changed = true
    end
    cleared << name if changed
  end
  save_character_data(data)
  ph_echo "Cleared manual #{kind} data from #{cleared.length} name(s): #{cleared.join(', ')}"
  true
end

def manual_mismatch_kind_aliases
  {
    'race' => 'race',
    'races' => 'race',
    'prof' => 'profession',
    'profession' => 'profession',
    'professions' => 'profession',
    'all' => 'all',
    'both' => 'all',
  }
end

def parse_manual_mismatch_target_args(raw_args)
  tokens = raw_args.to_a.map(&:to_s).reject { |token| token.strip.empty? }
  kind_aliases = manual_mismatch_kind_aliases
  kind = 'all'
  if kind_aliases[tokens.first.to_s.downcase]
    kind = kind_aliases[tokens.shift.downcase]
  elsif kind_aliases[tokens.last.to_s.downcase]
    kind = kind_aliases[tokens.pop.downcase]
  end
  names = tokens.map { |name| normalize_person_name(name) }.compact.uniq
  [names, kind]
end

def manual_mismatch_name_matches(rows, names, kind)
  wanted = names.map(&:downcase)
  rows.select do |row|
    wanted.include?(row[:name].downcase) && (kind == 'all' || row[:kind] == kind)
  end
end

def accept_who_for_manual_mismatches(config, raw_args)
  names, kind = parse_manual_mismatch_target_args(raw_args)
  if names.empty?
    ph_echo 'Usage: ;highlight-manager mismatches accept NAME profession|race|all'
    return false
  end

  rows = manual_mismatch_name_matches(manual_data_mismatches(config, true), names, kind)
  if rows.empty?
    ph_echo 'No matching manual/WHO mismatches found.'
    return false
  end

  data = character_data
  acknowledgements = manual_mismatch_acknowledgements(config)
  now = Time.now.utc.iso8601
  cleared = []
  rows.each do |row|
    record = data.dig('names', row[:name].downcase)
    next unless record.is_a?(Hash)

    if row[:kind] == 'profession'
      record['manual_profession'] = ''
      record['manual_profession_updated_at'] = now
    else
      record['manual_race'] = ''
      record['manual_race_updated_at'] = now
    end
    acknowledgements.delete(row[:signature])
    cleared << row
  end
  save_character_data(data)
  save_config(config)
  ph_echo "Accepted WHO data for #{cleared.length} manual #{cleared.length == 1 ? 'mismatch' : 'mismatches'}."
  cleared.each { |row| ph_echo "  #{row[:name]} #{row[:kind]}: now using WHO #{row[:who]}" }
  true
end

def keep_manual_mismatches(config, raw_args)
  tokens = raw_args.to_a.map(&:to_s).reject { |token| token.strip.empty? }
  include_all = tokens.length == 1 && tokens.first.to_s.downcase == 'all'
  rows = manual_data_mismatches(config, false)
  rows = manual_mismatch_name_matches(rows, *parse_manual_mismatch_target_args(tokens)) unless include_all
  if rows.empty?
    ph_echo 'No matching unreviewed manual/WHO mismatches found.'
    return false
  end

  acknowledgements = manual_mismatch_acknowledgements(config)
  now = Time.now.utc.iso8601
  rows.each do |row|
    acknowledgements[row[:signature]] = {
      'name' => row[:name],
      'kind' => row[:kind],
      'manual' => row[:manual],
      'who' => row[:who],
      'kept_at' => now,
    }
  end
  save_config(config)
  ph_echo "Kept manual data for #{rows.length} #{rows.length == 1 ? 'mismatch' : 'mismatches'}."
  ph_echo 'Future scans will not warn about those exact values unless WHO or manual data changes.'
  false
end

def handle_manual_mismatch_command(config, raw_args, args)
  action = args[0].to_s.downcase
  case action
  when '', 'list', 'show'
    print_manual_mismatches(config, false)
    false
  when 'all'
    print_manual_mismatches(config, true)
    false
  when 'accept', 'usewho', 'use-who', 'who'
    accept_who_for_manual_mismatches(config, raw_args[1, raw_args.length] || [])
  when 'keep', 'ack', 'ignore'
    keep_manual_mismatches(config, raw_args[1, raw_args.length] || [])
  else
    ph_echo 'Usage: ;highlight-manager mismatches'
    ph_echo '       ;highlight-manager mismatches all'
    ph_echo '       ;highlight-manager mismatches accept NAME profession|race|all'
    ph_echo '       ;highlight-manager mismatches keep NAME profession|race|all'
    ph_echo '       ;highlight-manager mismatches keep all'
    false
  end
end

def label_move_candidates(config)
  (manual_label_names(config) + saved_custom_tag_names).map { |tag| normalize_tag_name(tag) || tag.to_s.strip }.reject(&:empty?).uniq
end

def label_move_usage
  ph_echo 'Usage: ;highlight-manager move LABEL to profession Empath'
  ph_echo '       ;highlight-manager move LABEL to race Elf'
  ph_echo '       ;highlight-manager move LABEL to label Friend'
  ph_echo 'Example: ;highlight-manager move Imported 1 to profession Empath'
end

def infer_label_move_target(config, kind, target_text)
  text = target_text.to_s.strip
  return nil if text.empty?

  if kind.nil?
    profession = DEFAULT_PROFESSION_COLORS.keys.find { |known| known.downcase == text.downcase }
    return ['profession', profession] if profession

    race = RACES.find { |known| known.downcase == text.downcase }
    return ['race', race] if race

    known_tag = (tag_colors(config).keys + saved_custom_tag_names + DEFAULT_TAG_COLORS.keys).find { |tag| tag.downcase == text.downcase }
    return ['label', known_tag] if known_tag

    return ['label', normalize_tag_name(text)] if valid_tag_name?(normalize_tag_name(text))
    return nil
  end

  case kind
  when 'profession'
    profession = DEFAULT_PROFESSION_COLORS.keys.find { |known| known.downcase == text.downcase }
    return ['profession', profession] if profession
  when 'race'
    race = RACES.find { |known| known.downcase == text.downcase }
    return ['race', race] if race
  when 'label'
    tag = canonical_tag(config, text)
    return ['label', tag] if valid_tag_name?(tag)
  end
  nil
end

def parse_label_move_args(config, raw_args)
  tokens = raw_args.to_a.map(&:to_s).reject { |token| token.strip.empty? }
  return nil if tokens.length < 2

  candidates = label_move_candidates(config)
  source = nil
  source_len = 0
  (1..tokens.length).each do |length|
    candidate_text = tokens[0, length].join(' ')
    match = candidates.find { |tag| tag.downcase == candidate_text.downcase }
    next unless match

    source = match
    source_len = length
  end

  unless source
    separator_index = tokens.index { |token| %w[to as into].include?(token.downcase) }
    if separator_index && separator_index.positive?
      candidate_text = tokens[0, separator_index].join(' ')
      source = candidates.find { |tag| tag.downcase == candidate_text.downcase } || normalize_tag_name(candidate_text)
      source_len = separator_index
    end
  end

  return nil if source.to_s.empty? || source_len <= 0

  remaining = tokens[source_len, tokens.length].to_a
  remaining.shift if remaining.first && %w[to as into].include?(remaining.first.downcase)
  kind_aliases = {
    'profession' => 'profession',
    'prof' => 'profession',
    'class' => 'profession',
    'race' => 'race',
    'label' => 'label',
    'tag' => 'label',
    'custom' => 'label',
  }
  kind = kind_aliases[remaining.first.to_s.downcase]
  remaining.shift if kind
  target = infer_label_move_target(config, kind, remaining.join(' '))
  return nil unless target

  { source: source, target_kind: target[0], target: target[1] }
end

def default_label_move_target(config, target_text)
  target = infer_label_move_target(config, nil, target_text)
  return nil unless target

  kind, label = target
  return target if %w[profession race].include?(kind)
  return target if kind == 'label' && DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == label.to_s.downcase }

  nil
end

def label_move_target_description(target_kind, target)
  case target_kind.to_s
  when 'profession'
    "profession #{target}"
  when 'race'
    "race #{target}"
  else
    "label #{target}"
  end
end

def move_label_members_to_target(config, source, target_kind, target)
  source = source.to_s.strip
  target_kind = target_kind.to_s
  target = target.to_s.strip
  source_downcase = source.downcase
  now = Time.now.utc.iso8601
  data = character_data
  moved = []

  config['tag_colors'] ||= {}
  config['disabled_tags'] ||= []
  if target_kind == 'label'
    config['disabled_tags'].delete_if { |disabled| disabled.to_s.downcase == target.downcase }
    config['tag_colors'][target] ||= DEFAULT_TAG_COLORS[target] || ['#FFFFFF', '#000000'] unless DEFAULT_TAG_COLORS.key?(target)
  end

  (data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)
    next unless entry['custom_tag'].to_s.strip.downcase == source_downcase

    case target_kind
    when 'profession'
      entry['manual_profession'] = target
      entry['manual_profession_updated_at'] = now
      entry['custom_tag'] = ''
      entry['custom_updated_at'] = now
    when 'race'
      entry['manual_race'] = target
      entry['manual_race_updated_at'] = now
      entry['custom_tag'] = ''
      entry['custom_updated_at'] = now
    when 'label'
      entry['custom_tag'] = target
      entry['custom_updated_at'] = now
    end
    moved << entry['name'].to_s.strip
  end

  if moved.empty?
    return {
      source: source,
      target_kind: target_kind,
      target: target,
      moved: 0,
      removed_source_label: false,
    }
  end

  remaining_source_names = (data['names'] || {}).any? do |_key, entry|
    entry.is_a?(Hash) && entry['custom_tag'].to_s.strip.downcase == source_downcase
  end
  source_built_in = DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == source_downcase }
  removed_source_label = false
  unless remaining_source_names || source_built_in || (target_kind == 'label' && target.downcase == source_downcase)
    config['tag_colors'].delete_if { |tag, _pair| tag.to_s.downcase == source_downcase }
    config['disabled_tags'] << source_downcase
    config['disabled_tags'].uniq!
    removed_source_label = true
  end

  save_character_data(data)
  save_config(config)
  {
    source: source,
    target_kind: target_kind,
    target: target,
    moved: moved.length,
    removed_source_label: removed_source_label,
  }
end

def move_label_members(config, raw_args)
  parsed = parse_label_move_args(config, raw_args)
  unless parsed
    label_move_usage
    return false
  end

  result = move_label_members_to_target(config, parsed[:source], parsed[:target_kind], parsed[:target])
  if result[:moved].to_i <= 0
    ph_echo "No saved names currently use label #{result[:source]}."
    return false
  end

  ph_echo "Moved #{result[:moved]} name(s) from label #{result[:source]} to #{label_move_target_description(result[:target_kind], result[:target])}."
  ph_echo "Removed empty label #{result[:source]}." if result[:removed_source_label]
  true
end

def tag_names_from_lines(config, text)
  entries = parse_tag_name_lines(text)
  if entries.empty?
    ph_echo 'No tag/name lines found. Use lines like "Friend: Bob Sue" or "Enemy; Joe, Ann".'
    return false
  end

  any = false
  entries.each do |tag, names|
    any = true if tag_names(config, tag, names)
  end
  any
end

def import_color_pair_from_node(node, palette = WRAYTH_DEFAULT_PALETTE)
  raw_fore = (node.attributes['color'] || node.attributes['foreColor'] || node.attributes['forecolor'] || node.attributes['fgcolor']).to_s.strip
  raw_back = (node.attributes['bgcolor'] || node.attributes['backColor'] || node.attributes['backcolor'] || node.attributes['background']).to_s.strip
  palette_reference = palette_color_reference?(raw_fore) || palette_color_reference?(raw_back)
  fore = resolve_wrayth_palette_color(raw_fore, palette, false)
  back = resolve_wrayth_palette_color(raw_back, palette, true)
  unresolved_palette = false

  if fore.nil?
    unresolved_palette = true unless raw_fore.empty?
    fore = '#FFFFFF'
  end

  if back.nil?
    unresolved_palette = true unless raw_back.empty?
    back = ''
  end

  raw_key = "#{raw_fore}|#{raw_back}"
  {
    pair: [fore, back],
    key: palette_reference ? "palette:#{raw_key}" : nil,
    palette_reference: palette_reference,
    unresolved_palette: unresolved_palette,
  }
end

def string_highlight_from_node(node, palette = WRAYTH_DEFAULT_PALETTE)
  text = node.attributes['text'].to_s.strip
  return nil if text.empty?

  raw_fore = (node.attributes['color'] || node.attributes['foreColor'] || node.attributes['forecolor'] || node.attributes['fgcolor']).to_s.strip
  raw_back = (node.attributes['bgcolor'] || node.attributes['backColor'] || node.attributes['backcolor'] || node.attributes['background']).to_s.strip
  fore = resolve_wrayth_palette_color(raw_fore, palette, false)
  back = resolve_wrayth_palette_color(raw_back, palette, true)

  {
    'text' => text,
    'color' => fore || (palette_color_reference?(raw_fore) ? raw_fore : '#FFFFFF'),
    'bgcolor' => back.nil? && palette_color_reference?(raw_back) ? raw_back : back.to_s,
    'line' => node.attributes['line'].to_s == 'y' ? 'y' : '',
    'case' => node.attributes['case'].to_s == 'y' ? 'y' : '',
    'word' => node.attributes['word'].to_s == 'y' ? 'y' : '',
    'sound' => node.attributes['sound'].to_s.strip,
  }
end

def saved_custom_tag_names(data = nil)
  data ||= character_data
  names = data.is_a?(Hash) ? data['names'] : {}
  return [] unless names.is_a?(Hash)

  names.each_value.each_with_object([]) do |entry, tags|
    next unless entry.is_a?(Hash)

    tag = entry['custom_tag'].to_s.strip
    tags << tag unless tag.empty?
  end.uniq
end

def imported_tag_name_for_pair(config, pair, created, key = nil, allow_existing_match = true, data = nil)
  if allow_existing_match
    existing = tag_colors(config).find do |_tag, colors|
      colors[0].to_s.upcase == pair[0].to_s.upcase && normalize_background(colors[1], '') == normalize_background(pair[1], '')
    end
    return existing[0] if existing
  end

  key ||= "#{pair[0]}|#{normalize_background(pair[1], '')}"
  return created[key] if created[key]

  config['tag_colors'] ||= {}
  reserved_tags = {}
  tag_colors(config).keys.each { |tag| reserved_tags[tag.to_s.downcase] = true }
  saved_custom_tag_names(data).each { |tag| reserved_tags[tag.to_s.downcase] = true }
  created.values.each { |tag| reserved_tags[tag.to_s.downcase] = true }
  index = 1
  loop do
    candidate = "Imported #{index}"
    unless reserved_tags[candidate.downcase]
      config['tag_colors'][candidate] = pair
      created[key] = candidate
      reserved_tags[candidate.downcase] = true
      return candidate
    end
    index += 1
  end
end

def imported_generated_tag?(tag)
  tag.to_s.strip =~ /\AImported \d+\z/i
end

def prune_unused_imported_tag_colors(config, data)
  used_tags = {}
  (data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    tag = entry['custom_tag'].to_s.strip
    used_tags[tag.downcase] = true unless tag.empty?
  end

  removed = 0
  (config['tag_colors'] || {}).keys.each do |tag|
    next unless imported_generated_tag?(tag)
    next if used_tags[tag.downcase]

    config['tag_colors'].delete(tag)
    removed += 1
  end
  removed
end

def cleanup_imported_tags(config)
  data = character_data
  data['names'] ||= {}
  removed = []
  (data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)
    next unless imported_generated_tag?(entry['custom_tag'])

    removed << entry['name'].to_s
    entry['custom_tag'] = ''
    entry['custom_updated_at'] = Time.now.utc.iso8601
  end

  pruned = prune_unused_imported_tag_colors(config, data)
  save_character_data(data)
  save_config(config)
  ph_echo "Removed generated Imported # labels from #{removed.length} name(s)."
  ph_echo "Removed #{pruned} unused imported color group(s)." if pruned > 0
  ph_echo 'Built-in labels and user-created custom labels were left unchanged.'
  true
end

def color_pair_equal?(left, right)
  left_fore = normalize_hex(left[0]) || left[0].to_s.upcase
  right_fore = normalize_hex(right[0]) || right[0].to_s.upcase
  left_back = normalize_background(left[1], '')
  right_back = normalize_background(right[1], '')
  left_fore == right_fore && left_back == right_back
end

def automatic_color_pairs_for_import(config)
  prof_colors = profession_colors(config)
  race_colors_map = race_highlight_colors(config)
  unknown_fore = normalize_hex(config['unknown_race_color']) || UNKNOWN_RACE_COLOR
  candidates = []
  candidates.concat(prof_colors.values)
  candidates.concat(race_colors_map.values)
  race_colors_map.each_value do |race_pair|
    prof_colors.each_value do |profession_pair|
      candidates << [race_pair[0], profession_pair[1]]
    end
  end
  prof_colors.each_value do |profession_pair|
    candidates << [unknown_fore, profession_pair[1]]
  end
  candidates
end

def automatic_import_assignment_for_pair(config, pair)
  prof_colors = profession_colors(config)
  race_colors_map = race_highlight_colors(config)
  unknown_fore = normalize_hex(config['unknown_race_color']) || UNKNOWN_RACE_COLOR

  race_colors_map.each do |race, race_pair|
    prof_colors.each do |profession, profession_pair|
      return { 'race' => race, 'profession' => profession, 'source' => 'race_profession' } if color_pair_equal?([race_pair[0], profession_pair[1]], pair)
    end
  end

  prof_colors.each do |profession, profession_pair|
    return { 'race' => '', 'profession' => profession, 'source' => 'profession' } if color_pair_equal?(profession_pair, pair)
    return { 'race' => '', 'profession' => profession, 'source' => 'race_profession_fallback' } if color_pair_equal?([unknown_fore, profession_pair[1]], pair)
  end

  race_colors_map.each do |race, race_pair|
    return { 'race' => race, 'profession' => '', 'source' => 'race' } if color_pair_equal?(race_pair, pair)
  end

  nil
end

def automatic_color_pair_for_import?(config, entry, pair)
  profession = effective_profession(entry)
  race = effective_race(entry)
  prof_colors = profession_colors(config)
  race_colors_map = race_highlight_colors(config)
  candidates = automatic_color_pairs_for_import(config)
  if !profession.empty? && prof_colors[profession]
    candidates << prof_colors[profession]
  end
  if !race.empty? && race_colors_map[race]
    candidates << race_colors_map[race]
  end
  if !profession.empty? && !race.empty? && prof_colors[profession] && race_colors_map[race]
    candidates << [race_colors_map[race][0], prof_colors[profession][1]]
  end

  candidates.any? { |candidate| color_pair_equal?(candidate, pair) }
end

def import_existing_name_highlights(config, path, replace_existing = false, progress = nil)
  raise "Highlight XML not found: #{path}" unless File.file?(path)

  progress.call(0, 1, 'Reading XML...') if progress
  doc = copy_load_xml(path)
  palette = wrayth_palette_from_doc(doc)
  names_node = copy_section(doc, 'names')
  strings_node = copy_section(doc, 'strings')
  raise "No Name highlights section found in #{path}" unless names_node

  name_nodes = copy_highlight_nodes(names_node)
  string_nodes = strings_node ? copy_highlight_nodes(strings_node) : []
  total_steps = name_nodes.length + string_nodes.length + 2
  completed_steps = 0
  progress.call(completed_steps, total_steps, "Importing name highlights 0/#{name_nodes.length}...") if progress
  data = character_data
  data['names'] ||= {}
  now = Time.now.utc.iso8601
  created = {}
  imported = 0
  automatic = 0
  inferred_profession = 0
  inferred_race = 0
  skipped = 0
  invalid = 0
  palette_resolved = 0
  palette_unresolved = 0
  repaired_self = 0
  name_nodes.each_with_index do |node, index|
    raw_name = node.attributes['text'].to_s
    name = normalize_person_name(raw_name)
    unless name
      invalid += 1
      completed_steps += 1
      progress.call(completed_steps, total_steps, "Importing name highlights #{index + 1}/#{name_nodes.length}...") if progress && ((index + 1) % 25 == 0 || index + 1 == name_nodes.length)
      next
    end

    existing = data['names'][name.downcase].is_a?(Hash) ? data['names'][name.downcase] : {}
    existing_tag = existing['custom_tag'].to_s.strip
    import_color = import_color_pair_from_node(node, palette)
    if import_color[:palette_reference]
      palette_resolved += 1 unless import_color[:unresolved_palette]
      if existing_tag.downcase == 'self'
        repaired_self += 1
      end
    end
    palette_unresolved += 1 if import_color[:unresolved_palette]
    if !replace_existing && !existing_tag.empty? && !imported_generated_tag?(existing_tag) && !(existing_tag.downcase == 'self' && import_color[:palette_reference])
      skipped += 1
      completed_steps += 1
      progress.call(completed_steps, total_steps, "Importing name highlights #{index + 1}/#{name_nodes.length}...") if progress && ((index + 1) % 25 == 0 || index + 1 == name_nodes.length)
      next
    end

    pair = import_color[:pair]
    automatic_assignment = automatic_import_assignment_for_pair(config, pair)
    if automatic_assignment
      tag = ''
      automatic += 1
    else
      tag = imported_tag_name_for_pair(config, pair, created, import_color[:key], !import_color[:palette_reference], data)
    end
    profession = existing['profession'].to_s
    race = existing['race'].to_s
    profession_updated_at = existing['profession_updated_at'].to_s
    race_updated_at = existing['race_updated_at'].to_s
    if automatic_assignment
      assigned_profession = automatic_assignment['profession'].to_s
      assigned_race = automatic_assignment['race'].to_s
      if !assigned_profession.empty? && (profession.empty? || replace_existing)
        inferred_profession += 1 if profession != assigned_profession
        profession = assigned_profession
        profession_updated_at = now
      end
      if !assigned_race.empty? && (race.empty? || replace_existing)
        inferred_race += 1 if race != assigned_race
        race = assigned_race
        race_updated_at = now
      end
    end
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => profession,
      'race' => race,
      'manual_profession' => existing['manual_profession'].to_s,
      'manual_race' => existing['manual_race'].to_s,
      'custom_tag' => tag,
      'notes' => note_entries_from_record(existing),
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => existing['last_seen'].to_s,
      'profession_updated_at' => profession_updated_at,
      'race_updated_at' => race_updated_at,
      'manual_profession_updated_at' => existing['manual_profession_updated_at'].to_s,
      'manual_race_updated_at' => existing['manual_race_updated_at'].to_s,
      'custom_updated_at' => now,
    }
    imported += 1
    completed_steps += 1
    progress.call(completed_steps, total_steps, "Importing name highlights #{index + 1}/#{name_nodes.length}...") if progress && ((index + 1) % 25 == 0 || index + 1 == name_nodes.length)
  end

  string_imported = 0
  if strings_node
    existing_strings = string_highlights(config)
    string_index = {}
    existing_strings.each { |entry| string_index[entry['text'].to_s.downcase] = entry }
    string_nodes.each_with_index do |node, index|
      entry = string_highlight_from_node(node, palette)
      unless entry
        completed_steps += 1
        progress.call(completed_steps, total_steps, "Importing custom text highlights #{index + 1}/#{string_nodes.length}...") if progress && ((index + 1) % 25 == 0 || index + 1 == string_nodes.length)
        next
      end

      string_index[entry['text'].downcase] = entry
      string_imported += 1
      completed_steps += 1
      progress.call(completed_steps, total_steps, "Importing custom text highlights #{index + 1}/#{string_nodes.length}...") if progress && ((index + 1) % 25 == 0 || index + 1 == string_nodes.length)
    end
    config['string_highlights'] = string_index.values.sort_by { |entry| entry['text'].downcase }
  end

  progress.call(total_steps - 1, total_steps, 'Saving imported highlight data...') if progress
  pruned = prune_unused_imported_tag_colors(config, data)
  remember_recent_path(config, 'last_import_xml', path)
  save_config(config)
  save_character_data(data)
  progress.call(total_steps, total_steps, 'Import complete.') if progress
  ph_echo "Imported #{imported} existing Name highlight(s) into character data from #{path}"
  ph_echo "Imported/updated #{string_imported} custom text highlight string(s)." if string_imported > 0
  if automatic > 0
    ph_echo "Recognized #{automatic} automatic race/profession highlight(s) and saved inferred race/profession data when possible."
    ph_echo "  Inferred profession for #{inferred_profession} name(s)." if inferred_profession > 0
    ph_echo "  Inferred race for #{inferred_race} name(s)." if inferred_race > 0
  end
  ph_echo "Resolved #{palette_resolved} Wrayth palette color name highlight(s) to hex colors." if palette_resolved > 0
  ph_echo "Kept #{palette_unresolved} unresolved Wrayth palette color name highlight(s) in imported placeholder color groups." if palette_unresolved > 0
  ph_echo "Repaired #{repaired_self} prior false Self match(es) from Wrayth palette colors." if repaired_self > 0
  ph_echo "Skipped #{skipped} already-custom-tagged name(s)." if skipped > 0
  ph_echo "Ignored #{invalid} invalid/non-name highlight entr#{invalid == 1 ? 'y' : 'ies'}." if invalid > 0
  ph_echo "Removed #{pruned} unused imported tag color group(s)." if pruned > 0
  unless created.empty?
    ph_echo "Created #{created.length} imported tag color group(s): #{created.values.join(', ')}"
  end
  true
rescue => error
  ph_echo "Import existing highlights failed: #{error.message}"
  false
end

def print_profession_changes(config)
  changes = config['profession_changes'] || []
  if changes.empty?
    ph_echo 'No profession changes have been recorded.'
    return
  end

  ph_echo "Recorded profession changes: #{changes.length}"
  changes.last(100).each do |entry|
    ph_echo "  #{entry['name']}: #{entry['old_profession']} -> #{entry['new_profession']} @ #{entry['changed_at']}"
  end
end

def print_profession_legend(config, colors, debug = false)
  mode = current_mode(config)
  remembered = remembered_profession_names(config, mode)
  race_color_map = race_colors(config)
  profession_color_map = profession_colors(config)
  tag_color_map = tag_colors(config)
  ph_echo 'Name highlight legend:'
  if mode != 'race_profession'
    groups = active_highlight_colors(config, mode)
    unless debug
      labels = groups.keys.map { |group| legend_label(group) }
      columns = labels.length >= 9 ? 3 : 2
      rows = (labels.length.to_f / columns).ceil
      width = labels.map(&:length).max.to_i + 4
      rows.times do |row|
        line = ''
        columns.times do |column|
          label = labels[row + (column * rows)]
          line << label.ljust(width) if label
        end
        ph_echo "  #{line.rstrip}"
      end
      ph_echo 'Import Custom highlights to color these labels.'
      return
    end
    groups.each do |group, pair|
      fore, back = pair
      sample_names = remembered[group].to_a.first(5)
      sample = sample_names.empty? ? "#{group} sample" : sample_names.join(', ')
      ph_echo "  #{legend_label(group).ljust(24)} #{fore} on #{back.empty? ? 'None' : back}  #{sample}"
    end
    return
  end

  ph_echo '  Custom labels override race/profession colors.'
  ph_echo ''
  unless debug
    [
      ['Races - Fore', race_color_map.keys],
      ['Professions - Back', profession_color_map.keys],
      ['Custom', tag_color_map.keys],
    ].each do |title, names|
      ph_echo title
      labels = names.map { |name| legend_label(name) }
      columns = labels.length >= 9 ? 3 : 2
      rows = (labels.length.to_f / columns).ceil
      width = labels.map(&:length).max.to_i + 4
      rows.times do |row|
        line = ''
        columns.times do |column|
          label = labels[row + (column * rows)]
          next unless label

          line << label.ljust(width)
        end
        ph_echo "  #{line.rstrip}"
      end
      ph_echo ''
    end
    ph_echo 'Import Custom highlights to color these labels.'
    return
  end

  ph_echo 'Races - Fore:'
  race_color_map.each do |race, pair|
    fore, back = pair
    ph_echo "  #{legend_label(race).ljust(24)} fore #{fore}  race-only back #{back.empty? ? 'None' : back}"
  end
  ph_echo ''
  ph_echo 'Professions - Back:'
  profession_color_map.each do |profession, pair|
    _fore, back = pair
    sample_names = remembered[profession].to_a.first(5)
    sample = sample_names.empty? ? "#{profession} sample" : sample_names.join(', ')
    ph_echo "  #{legend_label(profession).ljust(24)} back #{back}  #{sample}"
  end
  ph_echo ''
  ph_echo 'Custom:'
  tag_color_map.each do |tag, pair|
    fore, back = pair
    ph_echo "  #{legend_label(tag).ljust(24)} #{fore} on #{back.empty? ? 'None' : back}"
  end
end

def xml_escape(text)
  text.to_s.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;').gsub('"', '&quot;').gsub("'", '&apos;')
end

def send_client_xml(xml)
  if defined?(_respond)
    _respond xml
  elsif defined?(respond)
    respond xml
  else
    puts xml
  end
end

def close_legend_window
  send_client_xml "<closeDialog id='HighlightManagerLegend' />"
  send_client_xml "<closeStream id='highlightManagerLegend' />"
  send_client_xml "<clearStream id='highlightManagerLegend' />"
  ph_echo 'Closed the Highlight Manager legend window.'
end

def legend_window_line(text)
  text.to_s.center(LEGEND_WINDOW_TEXT_WIDTH)
end

def open_legend_window(config, colors)
  unless dock_frontend?
    ph_echo 'Legend window requires StormFront/Wrayth/Warlock. Printing the legend here instead.'
    print_profession_legend(config, colors, false)
    return
  end

  buffer = []
  buffer << "<closeDialog id='HighlightManagerLegend' />"
  buffer << "<streamWindow id='highlightManagerLegend' title='Highlight Manager' location='center' save='save' resident='true' />"
  buffer << "<exposeStream id='highlightManagerLegend' />"
  buffer << "<clearStream id='highlightManagerLegend' />"
  buffer << "<pushStream id='highlightManagerLegend' />"
  buffer << "<output class='mono' />"
  if current_mode(config) == 'race_profession'
    buffer << "#{xml_escape(legend_window_line('Custom wins'))}\n\n"
    [
      ['Races - Fore', race_colors(config).keys],
      ['Professions - Back', profession_colors(config).keys],
      ['Custom', tag_colors(config).keys],
    ].each do |title, names|
      buffer << "#{xml_escape(legend_window_line(title))}\n"
      names.each do |group|
        buffer << "#{xml_escape(legend_window_line(legend_label(group)))}\n"
      end
      buffer << "\n"
    end
  else
    active_highlight_colors(config).each_key do |group|
      buffer << "#{xml_escape(legend_window_line(legend_label(group)))}\n"
    end
  end
  buffer << "<output class='' />"
  buffer << "<popStream/>"
  send_client_xml buffer.join
  ph_echo 'Opened/updated the resident Highlight Manager legend window.'
end

def print_remembered_names(config)
  remembered = remembered_profession_names(config, current_mode(config))
  data_names = character_data['names'] || {}
  total = data_names.length
  listed_names = remembered.values.flatten.map { |name| name.to_s.downcase }.uniq
  listed_total = listed_names.length
  unlisted = data_names.each_value.select do |entry|
    next false unless entry.is_a?(Hash)

    name = entry['name'].to_s.strip
    !name.empty? && !listed_names.include?(name.downcase)
  end

  ph_echo "Remembered names: #{total}"
  ph_echo "Listed in #{mode_label(current_mode(config))}: #{listed_total}"
  unless unlisted.empty?
    samples = unlisted.map { |entry| entry['name'].to_s.strip }.reject(&:empty?).sort.first(12)
    ph_echo "Not listed in this mode: #{unlisted.length}#{samples.empty? ? '' : "  sample: #{samples.join(', ')}"}"
  end
  remembered.each do |profession, names|
    ph_echo "#{profession} (#{names.length}):"
    if names.empty?
      ph_echo '  (none)'
    else
      names.each_slice(6) do |slice|
        ph_echo "  #{slice.join(', ')}"
      end
    end
  end
end

