ph_debug(debug, "profession_memberships=#{profession_names.values.flatten.length}")
ph_debug(debug, "race_memberships=#{race_names.values.flatten.length}")

names_to_write = filter_changed_names(grouped_names, config, refresh, mode, race_lookup)
profession_changes = refresh || profession_names.empty? ? [] : changed_profession_names(profession_names, config)
new_total = names_to_write.values.flatten.uniq.length
skipped_total = total_names - new_total
ph_echo "Names already remembered/skipped: #{skipped_total}" unless refresh
ph_echo "New/changed names this run: #{new_total}"
unless profession_changes.empty?
  ph_echo "Profession changes detected: #{profession_changes.length}"
  profession_changes.first(20).each do |entry|
    ph_echo "  #{entry[:name]}: #{entry[:old_profession]} -> #{entry[:new_profession]}"
  end
  ph_echo '  (showing first 20 changes)' if profession_changes.length > 20
end
ph_debug(debug, "new/changed names by active group=#{names_to_write.transform_values(&:length).inspect}")
ph_debug(debug, "new/changed name sample=#{names_to_write.values.flatten.first(25).join(', ')}")

names_to_write.each do |group, names|
  next if names.empty?
  next unless debug

  fore, back = active_colors[group]
  sample = names.first(5).join(', ')
  ph_echo "#{group.ljust(14)} #{names.length.to_s.rjust(3)} names  #{fore} on #{transparent_background?(back) ? 'transparent' : back}  sample: #{sample}"
end

record_profession_changes(profession_changes, config)
remember_names(profession_names, config, 'race_profession', race_lookup)
remember_names(race_names, config, 'race')
print_manual_mismatch_notice(config)
updated_config = load_config
if limited_runtime_frontend?
  ph_echo limited_frontend_message
  ph_echo 'Scan complete. Saved character data only; no highlight import file was written.'
  ph_echo "Remembered names now: #{(character_data['names'] || {}).length}"
  exit
end
cumulative_names = remembered_profession_names(updated_config, mode)
race_export_colors = mode == 'race_profession' ? race_active_colors : {}
result = write_import_file(out_path, cumulative_names, active_colors, export_format, updated_config, race_export_colors)
ph_echo "Wrote #{result[:added]} cumulative highlights to #{result[:file]}"
ph_echo "Remembered names now: #{(character_data['names'] || {}).length}"
ph_debug(debug, "cumulative counts written=#{cumulative_names.transform_values(&:length).inspect}")
ph_debug(debug, "rendered_stats_after_write=#{rendered_highlight_stats(updated_config, mode).inspect}")
ph_debug(debug, "export file size=#{File.size(result[:file]) rescue 'unknown'}")
show_export_instructions(result[:file], export_format, !profession_changes.empty?)
