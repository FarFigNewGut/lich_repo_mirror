  list names lookup note notes add clear changes changed legend window dock panel close colors-list palette tagcolor tag untag remove reset mode frontend copy currentxml xml whichxml importxml importnames addrace addprof clearinfo addcustom
  mismatches mismatch move movelabel move-label reassign cleanup imports imported datafolder folder datadir
]
trailing_shortcut_tag = tag_colors(config).keys.find { |tag| tag.downcase == args[-1].to_s }
if trailing_shortcut_tag && raw_args.length > 1 && (args & command_words).empty?
