  path = DEFAULT_EXISTING_IMPORT_SOURCE if path.empty?
  begin
    if import_existing_name_highlights(config, path, args.include?('replace'))
      rewrite_current_export(load_config, default_export_path(export_format_from_args([], config)), export_format_from_args([], config), true)
    end
  rescue => error
