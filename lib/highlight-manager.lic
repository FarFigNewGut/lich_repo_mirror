    'manual_mismatch_acknowledgements' => {},
    'string_highlights' => [],
  }
end

def recent_paths(config)
  config.is_a?(Hash) && config['recent_paths'].is_a?(Hash) ? config['recent_paths'] : {}
end

def recent_path(config, key, fallback = '')
  path = recent_paths(config)[key].to_s.strip
  path.empty? ? fallback : path
end

def remember_recent_path(config, key, path)
  text = path.to_s.strip
  return if text.empty?

  config['recent_paths'] = {} unless config['recent_paths'].is_a?(Hash)
  config['recent_paths'][key] = begin
    File.expand_path(text)
  rescue
    text
  end
end

def legacy_import_xml_path?(path)
  filename = File.basename(path.to_s.tr('\\', '/'))
  LEGACY_IMPORT_XML_FILENAMES.include?(filename)
end

def migrate_saved_legacy_paths!(config)
  changed = false
  data_folder = configured_data_folder(config)
  preferred_import = File.join(data_folder, IMPORT_XML_FILENAME)
  legacy_imports = LEGACY_IMPORT_XML_FILENAMES.map { |filename| File.join(data_folder, filename) }

  copy_legacy_file_if_needed(preferred_import, legacy_imports)

  copy_settings = config['copy_settings'].is_a?(Hash) ? config['copy_settings'] : {}
  if legacy_import_xml_path?(copy_settings['source_path'])
    copy_settings['source_path'] = preferred_import
    copy_settings['confirmed'] = false
    config['copy_settings'] = copy_settings
    changed = true
  end

  paths = recent_paths(config)
  if legacy_import_xml_path?(paths['last_import_xml'])
    paths['last_import_xml'] = preferred_import
    config['recent_paths'] = paths
    changed = true
  end

  changed
end

def legend_label(group)
  "-={ #{group} }=-"
end

def current_mode(config)
  mode = config['mode'].to_s
  HIGHLIGHT_MODES.include?(mode) ? mode : 'profession'
end

def mode_label(mode)
  case mode.to_s
  when 'race'
    'Race only'
  when 'race_profession'
    'Race + Profession'
  when 'custom'
    'Custom only'
  else
    'Profession only'
  end
end

def load_config
  path = copy_legacy_file_if_needed(CONFIG_PATH, LEGACY_CONFIG_PATHS)
  path = config_read_path unless File.exist?(path)
  return default_config unless File.exist?(path)

  data = YAML.load_file(path)
  data = default_config unless data.is_a?(Hash)
  data['seen_names'] ||= {}
  data['tagged_names'] ||= {}
  data['disabled_tags'] ||= []
  data['profession_changes'] ||= []
  data['profession_colors'] ||= DEFAULT_PROFESSION_COLORS
  data['race_colors'] ||= DEFAULT_RACE_COLORS
  data['tag_colors'] ||= DEFAULT_TAG_COLORS
  data['frontend'] ||= 'auto'
  data['mode'] = HIGHLIGHT_MODES.include?(data['mode'].to_s) ? data['mode'].to_s : 'profession'
  data['data_folder'] = configured_data_folder(data)
  data['unknown_race_color'] = normalize_hex(data['unknown_race_color']) || UNKNOWN_RACE_COLOR
  data['copy_settings'] = {} unless data['copy_settings'].is_a?(Hash)
  data['recent_paths'] = {} unless data['recent_paths'].is_a?(Hash)
  data['manual_mismatch_acknowledgements'] = {} unless data['manual_mismatch_acknowledgements'].is_a?(Hash)
  data['string_highlights'] = [] unless data['string_highlights'].is_a?(Array)
  data
rescue
  default_config
end

def atomic_write_yaml(path, data)
  FileUtils.mkdir_p(File.dirname(path))
  temp_path = "#{path}.tmp"
  File.write(temp_path, data.to_yaml)
  YAML.load_file(temp_path)
  FileUtils.mv(temp_path, path)
ensure
  File.delete(temp_path) if temp_path && File.exist?(temp_path)
end

def save_config(config)
  config['seen_names'] ||= {}
  config['tagged_names'] ||= {}
  config['disabled_tags'] ||= []
  config['profession_changes'] ||= []
  config['profession_colors'] = profession_colors(config)
  config['race_colors'] = race_colors(config)
  config['tag_colors'] = tag_colors(config)
  config['frontend'] ||= 'auto'
  config['mode'] = HIGHLIGHT_MODES.include?(config['mode'].to_s) ? config['mode'].to_s : 'profession'
  config['data_folder'] = configured_data_folder(config)
  config['unknown_race_color'] = normalize_hex(config['unknown_race_color']) || UNKNOWN_RACE_COLOR
  config['copy_settings'] = {} unless config['copy_settings'].is_a?(Hash)
  config['recent_paths'] = recent_paths(config)
  config['manual_mismatch_acknowledgements'] = {} unless config['manual_mismatch_acknowledgements'].is_a?(Hash)
  config['string_highlights'] = string_highlights(config)
  migrate_saved_legacy_paths!(config)
  atomic_write_yaml(CONFIG_PATH, config)
end

def config_needs_migration_save?(config)
  return true unless config['profession_colors'].is_a?(Hash) && config['race_colors'].is_a?(Hash) && config['tag_colors'].is_a?(Hash)
  return true unless config['copy_settings'].is_a?(Hash)
  return true unless config['recent_paths'].is_a?(Hash)
  return true unless config['manual_mismatch_acknowledgements'].is_a?(Hash)
  return true unless config['string_highlights'].is_a?(Array)
  return true if config['data_folder'].to_s.strip.empty?
  return true unless HIGHLIGHT_MODES.include?(config['mode'].to_s)
  return true unless normalize_hex(config['unknown_race_color'])
  return true unless config['frontend'].to_s.empty? || normalize_frontend_setting(config['frontend'])
  return true if (DEFAULT_PROFESSION_COLORS.keys - config['profession_colors'].keys).any?
  return true if (DEFAULT_RACE_COLORS.keys - config['race_colors'].keys).any?
  return true if (DEFAULT_TAG_COLORS.keys - config['tag_colors'].keys).any?
  return true if config['tag_colors'].keys.any? { |tag| automatic_category_name?(tag) }
  return true if config['copy_settings'].is_a?(Hash) && legacy_import_xml_path?(config['copy_settings']['source_path'])
  return true if recent_paths(config).values.any? { |path| legacy_import_xml_path?(path) }
  return true if DEFAULT_PROFESSION_COLORS.keys.any? do |profession|
    pair = config['profession_colors'][profession]
    !pair.is_a?(Array) || pair.length != 2
  end
  return true if DEFAULT_RACE_COLORS.keys.any? do |race|
    pair = config['race_colors'][race]
    !pair.is_a?(Array) || pair.length != 2
  end

  false
end

def migrate_data_folder_files(old_folder, new_folder)
  old_folder = old_folder.to_s.strip
  new_folder = new_folder.to_s.strip
  return [] if old_folder.empty? || new_folder.empty?

  old_path = File.expand_path(old_folder)
  new_path = File.expand_path(new_folder)
  return [] if old_path == new_path || !Dir.exist?(old_path)

  FileUtils.mkdir_p(new_path)
  copied = []
  [
    [CHARACTER_DATA_FILENAME, [CHARACTER_DATA_FILENAME, *LEGACY_CHARACTER_DATA_FILENAMES]],
    [IMPORT_XML_FILENAME, [IMPORT_XML_FILENAME, *LEGACY_IMPORT_XML_FILENAMES]],
    [IMPORT_CMD_FILENAME, [IMPORT_CMD_FILENAME, *LEGACY_IMPORT_CMD_FILENAMES]],
  ].each do |target_filename, source_filenames|
    target = File.join(new_path, target_filename)
    next if File.exist?(target)

    source = source_filenames.map { |filename| File.join(old_path, filename) }.find { |candidate| File.exist?(candidate) }
    next unless source

    FileUtils.cp(source, target)
    copied << target_filename
  end
  copied
end

def apply_data_folder_change(config, requested_folder)
  old_folder = configured_data_folder(config)
  new_folder = requested_folder.to_s.strip
  new_folder = DEFAULT_EXPORT_DIR if new_folder.empty?
  new_folder = File.expand_path(new_folder)
  FileUtils.mkdir_p(new_folder)
  copied_files = migrate_data_folder_files(old_folder, new_folder)
  config['data_folder'] = new_folder
  save_config(config)
  $highlight_manager_config = config
  [new_folder, copied_files]
end

def default_character_data
  { 'names' => {} }
end

def note_entries_from_record(record)
  return [] unless record.is_a?(Hash)

  notes = []
  if record['notes'].is_a?(Array)
    record['notes'].each do |entry|
      if entry.is_a?(Hash)
        text = entry['text'].to_s.strip
        next if text.empty?

        notes << {
          'text' => text,
          'created_at' => entry['created_at'].to_s,
          'updated_at' => entry['updated_at'].to_s,
        }
      else
        text = entry.to_s.strip
        notes << { 'text' => text, 'created_at' => '', 'updated_at' => '' } unless text.empty?
      end
    end
  end

  legacy_note = record['note'].to_s.strip
  if !legacy_note.empty? && notes.none? { |entry| entry['text'].to_s == legacy_note }
    stamp = record['note_updated_at'].to_s
    notes << { 'text' => legacy_note, 'created_at' => stamp, 'updated_at' => stamp }
  end
  notes
end

def normalize_character_record(key, record)
  return nil unless record.is_a?(Hash)

  name = normalize_person_name(record['name'] || key)
  return nil unless name

  {
    'name' => name,
    'profession' => record['profession'].to_s.strip,
    'race' => record['race'].to_s.strip,
    'manual_profession' => record['manual_profession'].to_s.strip,
    'manual_race' => record['manual_race'].to_s.strip,
    'custom_tag' => record['custom_tag'].to_s.strip,
    'notes' => note_entries_from_record(record),
    'first_seen' => record['first_seen'].to_s,
    'last_seen' => record['last_seen'].to_s,
    'profession_updated_at' => record['profession_updated_at'].to_s,
    'race_updated_at' => record['race_updated_at'].to_s,
    'manual_profession_updated_at' => record['manual_profession_updated_at'].to_s,
    'manual_race_updated_at' => record['manual_race_updated_at'].to_s,
    'custom_updated_at' => record['custom_updated_at'].to_s,
  }
end

def backup_broken_character_data(path)
  return unless File.exist?(path)

  stamp = Time.now.strftime('%Y%m%d-%H%M%S')
  backup = File.join(File.dirname(path), "highlight-manager-characterdata-broken-#{stamp}.yml")
  FileUtils.cp(path, backup)
  ph_echo "Character data file could not be read. Backed it up to: #{backup}"
end

def migrate_character_data_from_config(config)
  data = default_character_data
  now = Time.now.utc.iso8601
  (config['seen_names'] || {}).each do |key, record|
    next unless record.is_a?(Hash)

    name = normalize_person_name(record['name'] || key)
    next unless name

    data['names'][name.downcase] = {
      'name' => name,
      'profession' => record['profession'].to_s.strip,
      'race' => record['race'].to_s.strip,
      'manual_profession' => record['manual_profession'].to_s.strip,
      'manual_race' => record['manual_race'].to_s.strip,
      'custom_tag' => '',
      'notes' => note_entries_from_record(record),
      'first_seen' => record['first_seen'].to_s.empty? ? record['last_seen'].to_s : record['first_seen'].to_s,
      'last_seen' => record['last_seen'].to_s.empty? ? now : record['last_seen'].to_s,
      'profession_updated_at' => record['profession_updated_at'].to_s,
      'race_updated_at' => record['race_updated_at'].to_s,
      'manual_profession_updated_at' => record['manual_profession_updated_at'].to_s,
      'manual_race_updated_at' => record['manual_race_updated_at'].to_s,
      'custom_updated_at' => '',
    }
  end
  (config['tagged_names'] || {}).each do |key, record|
    next unless record.is_a?(Hash)

    name = normalize_person_name(record['name'] || key)
    next unless name

    existing = data['names'][name.downcase] || {
      'name' => name,
      'profession' => '',
      'race' => '',
      'manual_profession' => '',
      'manual_race' => '',
      'first_seen' => now,
      'last_seen' => now,
      'profession_updated_at' => '',
      'race_updated_at' => '',
      'manual_profession_updated_at' => '',
      'manual_race_updated_at' => '',
      'notes' => [],
    }
    existing['custom_tag'] = record['tag'].to_s.strip
    existing['custom_updated_at'] = record['tagged_at'].to_s.empty? ? now : record['tagged_at'].to_s
    data['names'][name.downcase] = existing
  end
  data
end

def load_character_data(config)
  path = character_data_path(config)
  copy_legacy_file_if_needed(path, legacy_character_data_paths(config))
  if File.exist?(path)
    raw = YAML.load_file(path)
    raise 'root must be a Hash' unless raw.is_a?(Hash)

    names = raw['names']
    raise 'names must be a Hash' unless names.is_a?(Hash)

    data = default_character_data
    skipped = 0
    names.each do |key, record|
      normalized = normalize_character_record(key, record)
      if normalized
        data['names'][normalized['name'].downcase] = normalized
      else
        skipped += 1
      end
    end
    ph_echo "Skipped #{skipped} invalid character data record(s)." if skipped > 0
    return data
  end

  data = migrate_character_data_from_config(config)
  save_character_data(data)
  data
rescue => error
  ph_echo "Character data load failed: #{error.message}"
  backup_broken_character_data(character_data_path(config))
  default_character_data
end

def save_character_data(data)
  data = default_character_data unless data.is_a?(Hash)
  data['names'] = {} unless data['names'].is_a?(Hash)
  path = character_data_path($highlight_manager_config || {})
  atomic_write_yaml(path, data)
end

def character_data
  $highlight_manager_character_data ||= load_character_data($highlight_manager_config || {})
end

def character_data_stats(data = character_data)
  names = data['names'].is_a?(Hash) ? data['names'].values : []
  profession_counts = Hash.new(0)
  race_counts = Hash.new(0)
  custom_tag_counts = Hash.new(0)
  names.each do |entry|
    next unless entry.is_a?(Hash)

    profession = effective_profession(entry)
    race = effective_race(entry)
    custom_tag = entry['custom_tag'].to_s.strip
    profession_counts[profession] += 1 unless profession.empty?
    race_counts[race] += 1 unless race.empty?
    custom_tag_counts[custom_tag] += 1 unless custom_tag.empty?
  end
  {
    total: names.length,
    with_profession: names.count { |entry| entry.is_a?(Hash) && !effective_profession(entry).empty? },
    with_race: names.count { |entry| entry.is_a?(Hash) && !effective_race(entry).empty? },
    with_both: names.count { |entry| entry.is_a?(Hash) && !effective_profession(entry).empty? && !effective_race(entry).empty? },
    with_custom: names.count { |entry| entry.is_a?(Hash) && !entry['custom_tag'].to_s.strip.empty? },
    profession_only: names.count { |entry| entry.is_a?(Hash) && !effective_profession(entry).empty? && effective_race(entry).empty? },
    race_only: names.count { |entry| entry.is_a?(Hash) && effective_profession(entry).empty? && !effective_race(entry).empty? },
    no_auto_data: names.count { |entry| entry.is_a?(Hash) && effective_profession(entry).empty? && effective_race(entry).empty? },
    profession_counts: profession_counts.sort.to_h,
    race_counts: race_counts.sort.to_h,
    custom_tag_counts: custom_tag_counts.sort.to_h,
  }
end

def rendered_highlight_stats(config, mode = current_mode(config))
  profs = profession_colors(config)
  races = race_colors(config)
  tags = tag_colors(config)
  stats = {
    rendered: 0,
    automatic: 0,
    custom: 0,
    transparent_background: 0,
    race_profession_complete: 0,
    race_only_fallback: 0,
    profession_only_fallback: 0,
    skipped_no_matching_color: 0,
  }

  (character_data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    name = entry['name'].to_s.strip
    next if name.empty?
    custom = entry['custom_tag'].to_s.strip
    if !custom.empty? && tags[custom]
      _fore, back = tags[custom]
      stats[:rendered] += 1
      stats[:custom] += 1
      stats[:transparent_background] += 1 if transparent_background?(back)
      next
    end

    profession = effective_profession(entry)
    race = effective_race(entry)
    case mode
    when 'custom'
      next
    when 'race'
      if races[race]
        _fore, back = races[race]
        stats[:rendered] += 1
        stats[:automatic] += 1
        stats[:transparent_background] += 1 if transparent_background?(back)
      else
        stats[:skipped_no_matching_color] += 1
      end
    when 'race_profession'
      if races[race] && profs[profession]
        stats[:rendered] += 1
        stats[:automatic] += 1
        stats[:race_profession_complete] += 1
      elsif races[race]
        stats[:rendered] += 1
        stats[:automatic] += 1
        stats[:race_only_fallback] += 1
        stats[:transparent_background] += 1
      elsif profs[profession]
        stats[:rendered] += 1
        stats[:automatic] += 1
        stats[:profession_only_fallback] += 1
      else
        stats[:skipped_no_matching_color] += 1
      end
    else
      if profs[profession]
        stats[:rendered] += 1
        stats[:automatic] += 1
        stats[:transparent_background] += 1 if transparent_background?(profs[profession][1])
      else
        stats[:skipped_no_matching_color] += 1
      end
    end
  end

  stats
end

def profession_colors(config)
  saved = config['profession_colors'] || {}
  DEFAULT_PROFESSION_COLORS.each_with_object({}) do |(profession, default_pair), colors|
    pair = saved[profession]
    pair = default_pair unless pair.is_a?(Array) && pair.length == 2
    pair = default_pair if LEGACY_PROFESSION_COLORS[profession] == pair
    fore = normalize_hex(pair[0]) || default_pair[0]
    back = normalize_background(pair[1], default_pair[1])
    colors[profession] = [fore, back]
  end
end

def race_colors(config)
  saved = config['race_colors'] || {}
  DEFAULT_RACE_COLORS.each_with_object({}) do |(race, default_pair), colors|
    pair = saved[race]
    pair = [pair, default_pair[1]] unless pair.is_a?(Array)
    pair = default_pair unless pair.is_a?(Array) && pair.length == 2
    pair = default_pair if LEGACY_RACE_COLORS[race] == pair
    fore = normalize_hex(pair[0]) || default_pair[0]
    fore = default_pair[0] if race == 'Human' && fore == '#FFFFFF'
    back = normalize_background(pair[1], default_pair[1])
    colors[race] = [fore, back]
  end
end

def race_highlight_colors(config)
  race_colors(config)
end

def automatic_category_name?(name)
  text = name.to_s.strip
  return false if text.empty?

  DEFAULT_PROFESSION_COLORS.keys.any? { |profession| profession.downcase == text.downcase } ||
    RACES.any? { |race| race.downcase == text.downcase }
end

def tag_colors(config)
  saved = config['tag_colors'] || {}
  disabled = (config['disabled_tags'] || []).map { |tag| tag.to_s.downcase }
  defaults = DEFAULT_TAG_COLORS.dup
  saved.each do |tag, pair|
    normalized_tag = DEFAULT_TAG_COLORS.keys.find { |default_tag| default_tag.downcase == tag.to_s.downcase } || normalize_tag_name(tag)
    next if automatic_category_name?(normalized_tag)

    pair = DEFAULT_TAG_COLORS['Self'] if normalized_tag == 'Self' && pair.is_a?(Array) && normalize_hex(pair[0]) == '#FFFFFF' && normalize_background(pair[1], '') == '#000000'
    defaults[normalized_tag] = pair
  end
  defaults.each_with_object({}) do |(tag, pair), colors|
    next unless valid_tag_name?(tag)
    next if disabled.include?(tag.to_s.downcase)

    pair = DEFAULT_TAG_COLORS[tag] unless pair.is_a?(Array) && pair.length == 2
    pair ||= ['#FFFFFF', '#000000']
    fore = normalize_hex(pair[0]) || '#FFFFFF'
    back = normalize_background(pair[1], '#000000')
    colors[tag] = [fore, back]
  end
end

def palette_color_reference?(value)
  value.to_s.strip =~ /\A@\d+\z/
end

def wrayth_palette_from_doc(doc)
  palette = WRAYTH_DEFAULT_PALETTE.dup
  REXML::XPath.each(doc, '//palette/i') do |node|
    id = node.attributes['id'].to_s.strip
    next if id.empty?

    palette[id] = normalize_hex(node.attributes['color'].to_s) || ''
  end
  palette
rescue
  WRAYTH_DEFAULT_PALETTE.dup
end

def resolve_wrayth_palette_color(value, palette, allow_blank = false)
  text = value.to_s.strip
  return '' if allow_blank && (text.empty? || text =~ /\A(?:none|transparent|clear)\z/i)

  hex = normalize_hex(text)
  return hex if hex

  if text =~ /\A@(\d+)\z/
    resolved = normalize_hex(palette[$1]) || normalize_hex(WRAYTH_DEFAULT_PALETTE[$1])
    return resolved if resolved
    return '' if allow_blank && [palette[$1], WRAYTH_DEFAULT_PALETTE[$1]].compact.any? { |candidate| candidate.to_s.strip.empty? }
  end

  nil
end

def valid_string_color_value?(value, allow_blank = false)
  text = value.to_s.strip
  return true if allow_blank && text.empty?
  return true if normalize_hex(text)
  return true if palette_color_reference?(text)

  false
end

def missing_sound_file?(path)
  text = path.to_s.strip
  return false if text.empty?

  expanded = File.expand_path(text)
  !File.file?(expanded)
rescue
  true
end

def string_highlight_warning(entry)
  warnings = []
  if palette_color_reference?(entry['color']) || palette_color_reference?(entry['bgcolor'])
    warnings << 'Unknown Wrayth palette color'
  end
  warnings << 'Missing sound file' if missing_sound_file?(entry['sound'])
  warnings.join('; ')
end

def normalize_string_highlight(entry)
  return nil unless entry.is_a?(Hash)

  text = entry['text'].to_s.strip
  return nil if text.empty?

  {
    'text' => text,
    'color' => entry['color'].to_s.strip.empty? ? '#FFFFFF' : entry['color'].to_s.strip,
    'bgcolor' => entry['bgcolor'].to_s.strip,
    'line' => entry['line'].to_s == 'y' ? 'y' : '',
    'case' => entry['case'].to_s == 'y' ? 'y' : '',
    'word' => entry['word'].to_s == 'y' ? 'y' : '',
    'sound' => entry['sound'].to_s.strip,
  }
end

def string_highlights(config)
  rows = config['string_highlights'].is_a?(Array) ? config['string_highlights'] : []
  seen = {}
  rows.each_with_object([]) do |entry, list|
    normalized = normalize_string_highlight(entry)
    next unless normalized

    key = normalized['text'].downcase
    next if seen[key]

    seen[key] = true
    list << normalized
  end
end

def automatic_colors(config, mode = current_mode(config))
  case mode
  when 'race'
    race_highlight_colors(config)
  when 'custom'
    {}
  else
    profession_colors(config)
  end
end

def active_highlight_colors(config, mode = current_mode(config))
  automatic_colors(config, mode).merge(tag_colors(config))
end

def normalize_hex(value)
  text = value.to_s.strip
  text = "##{text}" if text =~ /\A[0-9A-Fa-f]{6}\z/
  return text.upcase if text =~ /\A#[0-9A-Fa-f]{6}\z/

  nil
end

def normalize_tag_name(tag)
  text = tag.to_s.strip.gsub(/[^A-Za-z0-9 _-]/, '').gsub(/\s+/, ' ')
  return nil if text.empty?

  text.downcase.split(/([ _-])/).map do |part|
    if part == '-' || part == '_' || part == ' '
      part
    else
      part[0].to_s.upcase + part[1, part.length].to_s
    end
  end.join
end

def normalize_background(value, default = '#000000')
  text = value.to_s.strip
  return '' if text.empty? || text =~ /\A(?:none|transparent|clear)\z/i

  normalize_hex(text) || default
end

def widget_text(widget)
  widget.respond_to?(:text) ? widget.text.to_s : ''
end

def set_widget_text(widget, text)
  widget.text = text.to_s if widget.respond_to?(:text=)
end

def frontend_client_value
  if defined?(Frontend) && Frontend.respond_to?(:client)
    Frontend.client.to_s
  elsif defined?($frontend)
    $frontend.to_s
  else
    ''
  end
rescue
  ''
end

def frontend_process_signature
  return $highlight_manager_frontend_process_signature if defined?($highlight_manager_frontend_process_signature)

  signature = ''
  if nh_windows? && defined?($_CLIENT_) && $_CLIENT_
    begin
      require 'win32ole'
      client_port = $_CLIENT_.peeraddr[1].to_i
      lich_port = $_CLIENT_.addr[1].to_i
      if client_port.positive? && lich_port.positive?
        cim = WIN32OLE.connect('winmgmts://./root/StandardCimv2')
        tcp = cim.ExecQuery("SELECT OwningProcess FROM MSFT_NetTCPConnection WHERE LocalPort=#{client_port} AND RemotePort=#{lich_port}").each.first
        if tcp
          wmi = WIN32OLE.connect('winmgmts://')
          process = wmi.ExecQuery("SELECT Name,ExecutablePath,CommandLine FROM Win32_Process WHERE ProcessId=#{tcp.OwningProcess.to_i}").each.first
          process_text = [process.Name, process.ExecutablePath, process.CommandLine].compact.join(' ') if process
          signature = 'warlock' if process_text.to_s =~ /warlock/i
        end
      end
    rescue
      signature = ''
    end
  elsif RUBY_PLATFORM.to_s.downcase.include?('darwin')
    begin
      process_text = `ps ax -o comm= -o args= 2>/dev/null`
      signature = 'warlock' if process_text.to_s =~ /warlock/i
    rescue
      signature = ''
    end
  end

  $highlight_manager_frontend_process_signature = signature.to_s.downcase
end

def current_frontend
  client = frontend_client_value.downcase.strip
  case client
  when 'wizard'
    'wizard'
  when 'avalon'
    'avalon'
  else
    process_signature = frontend_process_signature
    return 'warlock' if process_signature.include?('warlock')

    case client
    when 'sf', 'stormfront'
      'stormfront'
    when 'wrayth'
      'wrayth'
    when 'warlock'
      'warlock'
    else
      client
    end
  end
end

def warlock_environment?
  current_frontend == 'warlock'
end

def detected_export_format
  case current_frontend
  when 'stormfront', 'wrayth'
    'wrayth'
  else
    'wrayth'
  end
end

def dock_frontend?
  ['stormfront', 'wrayth', 'warlock'].include?(current_frontend)
end

def debug_companion_running?
  if defined?(Script) && Script.respond_to?(:running)
    Script.running.any? do |running_script|
      running_script.respond_to?(:name) && running_script.name.to_s.downcase == 'debug-highlight-manager'
    end
  elsif defined?(running?)
    running?('debug-highlight-manager')
  else
    false
  end
end

def debug_companion_required_message
  'Private tester debug mode is not available in the public script.'
end

def config_read_path
  return CONFIG_PATH if File.exist?(CONFIG_PATH)

  LEGACY_CONFIG_PATHS.find { |path| File.exist?(path) } || CONFIG_PATH
end

def copy_legacy_file_if_needed(target_path, legacy_paths)
  return target_path if File.exist?(target_path)

  source = legacy_paths.find { |path| File.exist?(path) }
  return target_path unless source

  FileUtils.mkdir_p(File.dirname(target_path))
  FileUtils.cp(source, target_path)
  target_path
rescue
  source || target_path
end

def export_format_from_args(args, config)
  value = frontend_setting_from_args(args) || normalize_frontend_setting(config['frontend']) || config['frontend']
  value = value.to_s.downcase.strip

  case value
  when '', 'auto'
    detected_export_format
  when 'xml', 'wrayth', 'stormfront', 'sf'
    'wrayth'
  when 'warlock'
    'wrayth'
  else
    'wrayth'
  end
end

def frontend_setting_from_args(args)
  explicit = args.find { |arg| arg =~ /\A(?:front|frontend|format|export)=/i }
  return nil unless explicit

  normalize_frontend_setting(explicit.split('=', 2)[1])
end

def normalize_frontend_setting(value)
  text = value.to_s.downcase.strip.tr('-', '_')
  case text
  when '', 'auto'
    'auto'
  when 'xml', 'wrayth'
    'wrayth'
  when 'sf', 'stormfront'
    'stormfront'
  when 'warlock'
    'warlock'
  else
    nil
  end
end

def warlock_instruction_context?(_format)
  $highlight_manager_instruction_frontend.to_s == 'warlock' || warlock_environment?
end

def unsupported_runtime_frontend?
  %w[wizard avalon].include?(current_frontend)
end

def limited_runtime_frontend?
  unsupported_runtime_frontend?
end

def unsupported_frontend_message
  detected = current_frontend
  label = detected.empty? ? 'this front end' : detected.capitalize
  if nh_macos?
    "Highlight Manager does not support #{label}. Wrayth and StormFront are Windows front ends; on Mac, please switch to Warlock: #{WARLOCK_DOWNLOAD_URL}"
  else
    "Highlight Manager does not support #{label}. Please switch to Wrayth, StormFront, or Warlock."
  end
end

def limited_frontend_label
  detected = current_frontend
  detected.empty? ? 'this front end' : detected.capitalize
end

def limited_frontend_message
  "Highlight Manager detected #{limited_frontend_label}. Scan, lookup, notes, list, and basic reports can run here, but highlight import/export/setup/copy features need Wrayth, StormFront, or Warlock."
end

def limited_frontend_blocked_message(command = nil)
  name = command.to_s.strip
  name = 'this command' if name.empty?
  "#{name} is not available in #{limited_frontend_label}. You can still run ;highlight-manager to scan WHO data, ;highlight-manager lookup NAME, and ;highlight-manager lookup room."
end

def limited_frontend_scan_args?(args)
  allowed = %w[refresh full --refresh debug --debug gtkdebug gtk-debug gui-debug verbose-gtk]
  args.to_a.all? { |arg| allowed.include?(arg.to_s.downcase) }
end

def limited_frontend_command_allowed?(args)
  args = args.to_a.map(&:to_s)
  return true if args.empty? || limited_frontend_scan_args?(args)

  command = args[0].downcase
  return true if %w[lookup list names changes changed note notes datafolder folder datadir frontend].include?(command)
  return true if command == 'add' && args[1].to_s.downcase == 'note'
  return true if command == 'remove' && args[1].to_s.downcase == 'note'
  return true if command == 'clear' && args[1].to_s.downcase == 'note'

  false
end

def warlock_frontend_active?(config)
  frontend = normalize_frontend_setting(config['frontend']) || 'auto'
  frontend == 'warlock' || warlock_environment?
end

def copy_to_characters_disabled?(config)
  warlock_frontend_active?(config)
end

def copy_to_characters_disabled_message
  'Copy Highlights To Characters edits Wrayth/StormFront character XML files. Warlock users should use Warlock Settings -> General -> Global import instead.'
end

def default_export_path(_format = nil)
  File.join(configured_data_folder, IMPORT_XML_FILENAME)
end

def export_path_from_args(args, format)
  explicit_index = args.index { |arg| arg =~ /\A(?:out|outfile|file|path)=/i }
  if explicit_index
    value = args[explicit_index].split('=', 2)[1].to_s
    parts = [value]
    args[(explicit_index + 1)..-1].to_a.each do |part|
      text = part.to_s
      break if text =~ /\A[a-zA-Z_][a-zA-Z0-9_-]*=/
      break if %w[
        help --help -h version --version changelog release releases notes config setup colors refresh full --refresh debug --debug
        gtkdebug gtk-debug gui-debug verbose-gtk report debugfile log frontend front format export
        mode legend list names note notes add clear changes changed cleanup copy tag tagcolor addrace addprof
        addcustom untag remove mismatches mismatch move movelabel move-label reassign importxml importnames currentxml xml whichxml datafolder
        folder datadir
      ].include?(text.downcase)

      parts << text
    end
    return parts.join(' ').strip
  end

  default_export_path(format)
end

def path_from_command_args(raw_args, start_index, stop_words = [])
  parts = []
  stop_words = stop_words.map { |word| word.to_s.downcase }
  raw_args[start_index..-1].to_a.each do |part|
    text = part.to_s
    break if text =~ /\A[a-zA-Z_][a-zA-Z0-9_-]*=/
    break if stop_words.include?(text.downcase)

    parts << text
  end
  parts.join(' ').strip
end

def strip_xml_tags(line)
  line.to_s.gsub(/<[^>]+>/, ' ').gsub(/&nbsp;|&#160;/i, ' ').gsub(/&amp;/, '&')
end

def parse_who_names(lines)
  names = []
  in_list = false

  lines.each do |raw|
    line = strip_xml_tags(raw).strip
    next if line.empty?

    if line =~ /Brave Adventurers Questing:/i
      in_list = true
      next
    end

    break if line =~ /^Total:\s*\d+/i
    next unless in_list
    next if line =~ /^Active Players:/i
    next if line =~ /^Staff on duty:/i

    line.scan(/\b[A-Z][A-Za-z'-]{1,29}\b/) do |name|
      names << name
    end
  end

  names.uniq.sort
end

def fetch_names_by_who(category, values, debug = false)
  results = {}

  values.each do |value|
    ph_debug(debug, "Scanning #{category} #{value}...")
    command = "who #{category} #{value.downcase}"
    ph_debug(debug, "command=#{command.inspect}")
    lines = Lich::Util.quiet_command_xml(
      command,
      /Brave Adventurers Questing:|Total:\s*\d+|There are no adventurers/i,
      /<prompt/i,
      true,
      8,
      true
    )
    ph_debug(debug, "#{value}: captured #{lines.length} raw lines")
    lines.first(3).each_with_index do |line, index|
      ph_debug(debug, "#{value}: raw[#{index}]=#{strip_xml_tags(line).strip[0, 160]}")
    end
    names = parse_who_names(lines)
    results[value] = names
    ph_debug(debug, "#{value}: #{names.length} names")
    ph_debug(debug, "#{value}: parsed sample=#{names.first(10).join(', ')}")
  end

  results
end

def fetch_profession_names(colors, debug = false)
  fetch_names_by_who('profession', colors.keys, debug)
end

def fetch_race_names(debug = false)
  fetch_names_by_who('race', RACES, debug)
end

def name_lookup(grouped_names)
  lookup = {}
  grouped_names.each do |group, names|
    names.each { |name| lookup[name.downcase] = group }
  end
  lookup
end

def effective_profession(entry)
  manual = entry['manual_profession'].to_s.strip
  return manual unless manual.empty?

  entry['profession'].to_s.strip
end

def effective_race(entry)
  manual = entry['manual_race'].to_s.strip
  return manual unless manual.empty?

  entry['race'].to_s.strip
end

def filter_changed_names(grouped_names, config, refresh, mode, race_lookup = {})
  return grouped_names if refresh

  records = character_data['names'] || {}
  filtered = {}

  grouped_names.each do |group, names|
    filtered[group] = names.reject do |name|
      record = records[name.downcase] || {}
      next true unless record['custom_tag'].to_s.empty?

      remembered_profession = effective_profession(record)
      remembered_race = effective_race(record)
      manual_profession = record['manual_profession'].to_s.strip
      manual_race = record['manual_race'].to_s.strip
      case mode
      when 'race'
        new_race = manual_race.empty? ? group : manual_race
        remembered_race == new_race
      when 'race_profession'
        new_profession = manual_profession.empty? ? group : manual_profession
        new_race = manual_race.empty? ? race_lookup[name.downcase].to_s : manual_race
        remembered_profession == new_profession && remembered_race == new_race
      else
        new_profession = manual_profession.empty? ? group : manual_profession
        remembered_profession == new_profession
      end
    end
  end

  filtered
end

def changed_profession_names(profession_names, config)
  records = character_data['names'] || {}
  changed = []

  profession_names.each do |profession, names|
    names.each do |name|
      record = records[name.downcase] || {}
      next unless record['custom_tag'].to_s.empty?

      remembered_profession = record['profession'].to_s
      next if remembered_profession.empty? || remembered_profession == profession

      changed << {
        name: name,
        old_profession: remembered_profession,
        new_profession: profession,
      }
    end
  end

  changed.sort_by { |entry| [entry[:new_profession], entry[:name]] }
end

def remember_names(grouped_names, config, mode, race_lookup = {})
  data = character_data
  data['names'] ||= {}
  now = Time.now.utc.iso8601
  grouped_names.each do |group, names|
    names.each do |name|
      existing = data['names'][name.downcase].is_a?(Hash) ? data['names'][name.downcase] : {}
      profession = mode == 'race' ? existing['profession'].to_s : group
      race = mode == 'race' ? group : (race_lookup[name.downcase].to_s.empty? ? existing['race'].to_s : race_lookup[name.downcase].to_s)
      data['names'][name.downcase] = {
        'name' => name,
        'profession' => profession,
        'race' => race,
        'manual_profession' => existing['manual_profession'].to_s,
        'manual_race' => existing['manual_race'].to_s,
        'custom_tag' => existing['custom_tag'].to_s,
        'notes' => note_entries_from_record(existing),
        'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
        'last_seen' => now,
        'profession_updated_at' => profession == existing['profession'].to_s ? existing['profession_updated_at'].to_s : now,
        'race_updated_at' => race == existing['race'].to_s ? existing['race_updated_at'].to_s : now,
        'manual_profession_updated_at' => existing['manual_profession_updated_at'].to_s,
        'manual_race_updated_at' => existing['manual_race_updated_at'].to_s,
        'custom_updated_at' => existing['custom_updated_at'].to_s,
      }
    end
  end
  save_character_data(data)
end

def record_profession_changes(changes, config)
  return if changes.empty?

  config['profession_changes'] ||= []
  changes.each do |entry|
    config['profession_changes'] << {
      'name' => entry[:name],
      'old_profession' => entry[:old_profession],
      'new_profession' => entry[:new_profession],
      'changed_at' => Time.now.utc.iso8601,
    }
  end
  config['profession_changes'] = config['profession_changes'].last(500)
  save_config(config)
end

def manual_mismatch_acknowledgements(config)
  config['manual_mismatch_acknowledgements'] = {} unless config['manual_mismatch_acknowledgements'].is_a?(Hash)
  config['manual_mismatch_acknowledgements']
end

def manual_mismatch_signature(name, kind, manual_value, who_value)
  [name, kind, manual_value, who_value].map { |part| part.to_s.strip.downcase }.join('|')
end

def manual_data_mismatches(config, include_acknowledged = false)
  acknowledgements = manual_mismatch_acknowledgements(config)
  rows = []
  (character_data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    name = entry['name'].to_s.strip
    next if name.empty?

    [
      ['profession', 'manual_profession', 'profession'],
      ['race', 'manual_race', 'race'],
    ].each do |kind, manual_key, who_key|
      manual_value = entry[manual_key].to_s.strip
      who_value = entry[who_key].to_s.strip
      next if manual_value.empty? || who_value.empty?
      next if manual_value.downcase == who_value.downcase

      signature = manual_mismatch_signature(name, kind, manual_value, who_value)
      acknowledged = acknowledgements.key?(signature)
      next if acknowledged && !include_acknowledged

      rows << {
        name: name,
        kind: kind,
        manual: manual_value,
        who: who_value,
        label: entry['custom_tag'].to_s.strip,
        signature: signature,
        acknowledged: acknowledged,
      }
    end
  end
  rows.sort_by { |row| [row[:name].downcase, row[:kind]] }
end

def manual_mismatch_table_lines(rows)
  widths = {
    name: [rows.map { |row| row[:name].length }.max || 4, 4].max,
    kind: [rows.map { |row| row[:kind].length }.max || 4, 4].max,
    manual: [rows.map { |row| row[:manual].length }.max || 6, 6].max,
    who: [rows.map { |row| row[:who].length }.max || 3, 3].max,
    export: [rows.map { |row| row[:label].to_s.empty? ? 'manual'.length : "label #{row[:label]}".length }.max || 6, 6].max,
  }
  header = [
    'Name'.ljust(widths[:name]),
    'Type'.ljust(widths[:kind]),
    'Manual'.ljust(widths[:manual]),
    'WHO'.ljust(widths[:who]),
    'Export'.ljust(widths[:export]),
    'Status',
  ].join('  ')
  divider = [
    '-' * widths[:name],
    '-' * widths[:kind],
    '-' * widths[:manual],
    '-' * widths[:who],
    '-' * widths[:export],
    '------',
  ].join('  ')
  lines = [header, divider]
  rows.each do |row|
    export = row[:label].to_s.empty? ? 'manual' : "label #{row[:label]}"
    status = row[:acknowledged] ? 'kept' : 'review'
    lines << [
      row[:name].ljust(widths[:name]),
      row[:kind].ljust(widths[:kind]),
      row[:manual].ljust(widths[:manual]),
      row[:who].ljust(widths[:who]),
      export.ljust(widths[:export]),
      status,
    ].join('  ')
  end
  lines
end

def print_manual_mismatches(config, include_acknowledged = false)
  rows = manual_data_mismatches(config, include_acknowledged)
  if rows.empty?
    ph_echo include_acknowledged ? 'No manual race/profession mismatches found.' : 'No unreviewed manual race/profession mismatches found.'
    return false
  end

  ph_echo ''
  ph_echo "Manual race/profession mismatches: #{rows.length}"
  ph_echo ''
  manual_mismatch_table_lines(rows).each { |line| ph_echo "  #{line}" }
  ph_echo ''
  ph_echo 'Manual values still win when exporting unless a manual label is set.'
  ph_echo 'Use WHO data:   ;highlight-manager mismatches accept NAME profession|race|all'
  ph_echo 'Keep manual:    ;highlight-manager mismatches keep NAME profession|race|all'
  ph_echo 'Show kept too:  ;highlight-manager mismatches all'
  ph_echo ''
  true
end

def print_manual_mismatch_notice(config)
  rows = manual_data_mismatches(config, false)
  return if rows.empty?

  ph_echo ''
  ph_echo "Manual data differs from WHO for #{rows.length} saved #{rows.length == 1 ? 'field' : 'fields'}."
  rows.first(6).each do |row|
    ph_echo "  #{row[:name]} #{row[:kind]}: manual #{row[:manual]} / WHO #{row[:who]}"
  end
  ph_echo '  (showing first 6)' if rows.length > 6
  ph_echo 'Manual data is still being used for export.'
  ph_echo 'Run ;highlight-manager mismatches to review, accept WHO data, or keep manual data.'
  ph_echo ''
end

def remembered_profession_names(config, mode = current_mode(config))
  remembered = {}
  active_highlight_colors(config, mode).keys.each { |group| remembered[group] = [] }

  (character_data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    name = entry['name'].to_s.strip
    custom_tag = entry['custom_tag'].to_s.strip
    if !custom_tag.empty? && remembered.key?(custom_tag)
      remembered[custom_tag] << name
      next
    end

    profession = effective_profession(entry)
    race = effective_race(entry)
    group = case mode
            when 'race'
              race
            when 'custom'
              nil
            else
              profession
            end
    next if name.empty? || !remembered.key?(group)

    remembered[group] << name
  end

  remembered.each_value do |names|
    names.uniq!
    names.sort!
  end
  remembered
end

def rendered_name_highlights(config, mode = current_mode(config))
  profs = profession_colors(config)
  races = race_colors(config)
  tags = tag_colors(config)
  unknown_fore = normalize_hex(config['unknown_race_color']) || UNKNOWN_RACE_COLOR
  rendered = []

  (character_data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash)

    name = entry['name'].to_s.strip
    next if name.empty?
    custom = entry['custom_tag'].to_s.strip
    if !custom.empty? && tags[custom]
      fore, back = tags[custom]
      rendered << [name, fore, back]
      next
    end

    profession = effective_profession(entry)
    race = effective_race(entry)
    case mode
    when 'custom'
      next
    when 'race'
      next unless races[race]

      rendered << [name, races[race][0], races[race][1]]
    when 'race_profession'
      if races[race] && profs[profession]
        rendered << [name, races[race][0], profs[profession][1]]
      elsif races[race]
        rendered << [name, races[race][0], '']
      elsif profs[profession]
        rendered << [name, unknown_fore, profs[profession][1]]
      end
    else
      next unless profs[profession]

      rendered << [name, profs[profession][0], profs[profession][1]]
    end
  end

  rendered.sort_by { |name, _fore, _back| name.downcase }
end

def build_import_document(profession_names, colors, config = nil, race_color_map = {})
  doc = REXML::Document.new
  settings = doc.add_element('settings')
  settings.add_attribute('client', '1.0.1.28')
  strings_node = settings.add_element('strings')
  strings_node.add_attribute('local', '')
  names_node = settings.add_element('names')
  names_node.add_attribute('local', '')

  added = 0
  existing_string_texts = {}
  if config
    string_highlights(config).each do |entry|
      h = REXML::Element.new('h')
      %w[text color bgcolor sound].each do |attribute|
        value = entry[attribute].to_s
        h.add_attribute(attribute, value) unless value.empty? && attribute != 'bgcolor'
      end
      h.add_attribute('bgcolor', entry['bgcolor'].to_s)
      %w[line case word].each do |attribute|
        h.add_attribute(attribute, 'y') if entry[attribute].to_s == 'y'
      end
      strings_node.add_element(h)
      existing_string_texts[entry['text'].to_s.downcase] = true
      added += 1
    end
  end

  colors.each do |group, pair|
    fore, back = pair
    label = legend_label(group)
    next if existing_string_texts[label.downcase]

    h = REXML::Element.new('h')
    h.add_attribute('text', label)
    h.add_attribute('color', fore)
    h.add_attribute('bgcolor', back)
    h.add_attribute('case', 'y')
    strings_node.add_element(h)
    existing_string_texts[label.downcase] = true
    added += 1
  end

  race_color_map.each do |race, pair|
    fore = pair.is_a?(Array) ? pair[0] : pair
    label = legend_label(race)
    next if existing_string_texts[label.downcase]

    h = REXML::Element.new('h')
    h.add_attribute('text', label)
    h.add_attribute('color', fore)
    h.add_attribute('bgcolor', '')
    h.add_attribute('case', 'y')
    strings_node.add_element(h)
    existing_string_texts[label.downcase] = true
    added += 1
  end

  if config
    rendered_name_highlights(config, current_mode(config)).each do |name, fore, back|
      h = REXML::Element.new('h')
      h.add_attribute('text', name)
      h.add_attribute('color', fore)
      h.add_attribute('bgcolor', back)
      h.add_attribute('case', 'y')
      names_node.add_element(h)
      added += 1
    end
  else
    profession_names.each do |profession, names|
      fore, back = colors[profession]
      names.each do |name|
        h = REXML::Element.new('h')
        h.add_attribute('text', name)
        h.add_attribute('color', fore)
        h.add_attribute('bgcolor', back)
        h.add_attribute('case', 'y')
        names_node.add_element(h)
        added += 1
      end
    end
  end

  [doc, added]
end

def write_import_file(path, profession_names, colors, format = 'wrayth', config = nil, race_color_map = {})
  race_color_map = race_colors(config) if config && current_mode(config) == 'race_profession' && race_color_map.empty?
  doc, added = build_import_document(profession_names, colors, config, race_color_map)
  FileUtils.mkdir_p(File.dirname(path))

  formatter = REXML::Formatters::Pretty.new(2)
  formatter.compact = true
  temp_path = "#{path}.tmp"
  File.open(temp_path, 'w') { |file| formatter.write(doc, file) }
  REXML::Document.new(File.read(temp_path))
  FileUtils.mv(temp_path, path)

  { file: path, added: added, format: format }
ensure
  File.delete(temp_path) if temp_path && File.exist?(temp_path)
end

def rewrite_current_export(config, out_path, export_format, changed = true)
  mode = current_mode(config)
  colors = active_highlight_colors(config, mode)
  result = write_import_file(out_path, remembered_profession_names(config, mode), colors, export_format, config, mode == 'race_profession' ? race_colors(config) : {})
  ph_echo "Rewrote cumulative #{export_format} export with #{result[:added]} highlights: #{result[:file]}"
  show_export_instructions(result[:file], export_format, changed)
end

