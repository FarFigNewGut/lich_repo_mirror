def configured_data_folder(config = nil)
  if config.is_a?(Hash)
    configured = config['data_folder'].to_s.strip
  elsif defined?($highlight_manager_config) && $highlight_manager_config.is_a?(Hash)
    configured = $highlight_manager_config['data_folder'].to_s.strip
  else
    configured = ''
  end
  configured.empty? ? DEFAULT_EXPORT_DIR : File.expand_path(configured)
end

def character_data_path(config = nil)
  File.join(configured_data_folder(config), CHARACTER_DATA_FILENAME)
end

def legacy_character_data_paths(config = nil)
  LEGACY_CHARACTER_DATA_FILENAMES.map { |filename| File.join(configured_data_folder(config), filename) }
end

def copy_default_source(config = nil)
  path = File.join(configured_data_folder(config), IMPORT_XML_FILENAME)
  return path if File.exist?(path)

  legacy = LEGACY_IMPORT_XML_FILENAMES.map { |filename| File.join(configured_data_folder(config), filename) }.find { |candidate| File.exist?(candidate) }
  legacy || path
end

def legacy_wizard_export_path(config = nil)
  File.join(configured_data_folder(config), IMPORT_CMD_FILENAME)
end

def ph_echo(message = '')
  text = message.to_s
  begin
    if defined?(respond)
      respond text
    elsif defined?(_respond)
      _respond text
    else
      puts text
    end
  rescue IOError, SystemCallError
    nil
  end
  if $highlight_manager_report_path.to_s.strip.length > 0
    begin
      File.open($highlight_manager_report_path, 'a') { |file| file.puts(text) }
    rescue
      nil
    end
  end
end

def ph_monsterbold_text(message = '')
  text = message.to_s
  begin
    return Lich::Messaging.monsterbold(text).to_s if defined?(Lich::Messaging) && Lich::Messaging.respond_to?(:monsterbold)

    start_tag = defined?(monsterbold_start) ? monsterbold_start.to_s : ''
    end_tag = defined?(monsterbold_end) ? monsterbold_end.to_s : ''
    return "#{start_tag}#{text}#{end_tag}" unless start_tag.empty? && end_tag.empty?
  rescue
    nil
  end
  text
end

def ph_echo_monsterbold(message = '')
  plain = message.to_s
  styled = ph_monsterbold_text(plain)
  begin
    if defined?(respond)
      respond styled
    elsif defined?(_respond)
      _respond styled
    else
      puts styled
    end
  rescue IOError, SystemCallError
    nil
  end
  if $highlight_manager_report_path.to_s.strip.length > 0
    begin
      File.open($highlight_manager_report_path, 'a') { |file| file.puts(plain) }
    rescue
      nil
    end
  end
end

def ph_debug(enabled, message = '')
  ph_echo "DEBUG: #{message}" if enabled
end

def highlight_manager_version_label
  "v#{HIGHLIGHT_MANAGER_VERSION} build #{HIGHLIGHT_MANAGER_BUILD}"
end

def daily_changelog_entries
  grouped = []
  by_date = {}
  HIGHLIGHT_MANAGER_CHANGELOG.each do |version, date, notes|
    entry = by_date[date]
    unless entry
      entry = { date: date, versions: [], notes: [] }
      by_date[date] = entry
      grouped << entry
    end
    entry[:versions] << version
    notes.each do |note|
      next if entry[:notes].include?(note)

      entry[:notes] << note
    end
  end
  grouped
end

def show_changelog(args = [])
  full = args.map { |arg| arg.to_s.downcase }.any? { |arg| %w[full all complete].include?(arg) }
  entries = daily_changelog_entries
  shown_entries = full ? entries : entries.first(8)
  ph_echo ''
  ph_echo "Highlight Manager changelog (current #{highlight_manager_version_label})"
  ph_echo ''
  shown_entries.each do |entry|
    ph_echo entry[:date].to_s
    notes = entry[:notes]
    notes.each { |note| ph_echo "  - #{note}" }
    ph_echo ''
  end
  ph_echo 'Use ;highlight-manager changelog full to show older days.' unless full || shown_entries.length == entries.length
  ph_echo ''
end

def gtk_debug(message = '')
  ph_echo "GTK DEBUG: #{message}" if $highlight_manager_gtk_debug
end

def report_path_from_args(args)
  explicit = args.find { |arg| arg =~ /\A(?:report|debugfile|log)=/i }
  return explicit.split('=', 2).last if explicit

  index = args.index { |arg| arg.to_s.downcase =~ /\A(?:report|debugfile|log)\z/ }
  value = args[index + 1] if index && args[index + 1]
  return nil if value.to_s.strip.empty?

  value.to_s
end

def expand_report_path(value)
  text = value.to_s.strip
  return nil if text.empty?

  if text =~ /\A[A-Za-z0-9_-]+\z/
    File.join(configured_data_folder, "highlight-manager-command-#{text}.txt")
  else
    text
  end
end

def start_text_report(path, raw_args)
  path = expand_report_path(path)
  return if path.to_s.strip.empty?

  FileUtils.mkdir_p(File.dirname(path))
  header = [
    "Generated: #{Time.now.strftime('%Y-%m-%d %H:%M:%S')}",
    "Highlight Manager: #{highlight_manager_version_label}",
    "Command: ;#{SCRIPT_NAME} #{raw_args.join(' ')}",
    '',
  ]
  if File.exist?(path)
    File.open(path, 'a') { |file| file.puts ['', '---', *header].join("\n") }
  else
    File.write(path, ["Highlight Manager command transcript", *header].join("\n"))
  end
  $highlight_manager_report_path = path
rescue => error
  $highlight_manager_report_path = nil
  if defined?(respond)
    respond "Unable to write debug report #{path}: #{error.message}"
  else
    puts "Unable to write debug report #{path}: #{error.message}"
  end
end

def normalize_script_args(args)
  normalized = args.flat_map { |arg| arg.to_s.strip.split(/\s+/) }.reject(&:empty?)
  half = normalized.length / 2
  normalized = normalized.first(half) if normalized.length.even? && half.positive? && normalized.first(half) == normalized.last(half)
  normalized
end

def strip_report_args(args)
  cleaned = []
  skip_next = false
  args.each do |arg|
    if skip_next
      skip_next = false
      next
    end
    if arg =~ /\A(?:report|debugfile|log)=/i
      next
    elsif arg =~ /\A(?:report|debugfile|log)\z/i
      skip_next = true
      next
    end
    cleaned << arg
  end
  cleaned
end

def current_character_name
  if defined?(Char) && Char.respond_to?(:name) && Char.name.to_s.strip.length > 0
    Char.name.to_s.strip
  elsif defined?(XMLData) && XMLData.respond_to?(:name) && XMLData.name.to_s.strip.length > 0
    XMLData.name.to_s.strip
  else
    nil
  end
end

