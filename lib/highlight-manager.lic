end

def hex_to_rgba(hex)
  hex = normalize_hex(hex) || '#000000'
  r = hex[1, 2].to_i(16) / 255.0
  g = hex[3, 2].to_i(16) / 255.0
  b = hex[5, 2].to_i(16) / 255.0
  Gdk::RGBA.new(r, g, b, 1.0)
end

def rgba_to_hex(rgba)
  r = [[(rgba.red * 255).round.to_i, 0].max, 255].min
  g = [[(rgba.green * 255).round.to_i, 0].max, 255].min
  b = [[(rgba.blue * 255).round.to_i, 0].max, 255].min
  format('#%02X%02X%02X', r, g, b)
end

def transparent_background?(value)
  value.to_s.strip.empty? || value.to_s.strip =~ /\A(?:none|transparent|clear)\z/i
end

def apply_preview_colors(label, fore_hex, back_hex)
  return unless defined?(Gdk)

  fore = hex_to_rgba(fore_hex)
  label.override_color(Gtk::StateFlags::NORMAL, fore)
  if transparent_background?(back_hex)
    label.override_background_color(Gtk::StateFlags::NORMAL, nil)
  else
    back = hex_to_rgba(back_hex)
    label.override_background_color(Gtk::StateFlags::NORMAL, back)
  end
rescue
  nil
end

def color_button(hex)
  return nil unless defined?(Gtk::ColorButton) && defined?(Gdk::RGBA)

  button = Gtk::ColorButton.new
  button.rgba = hex_to_rgba(hex) if button.respond_to?(:rgba=)
  button
rescue
  nil
end

def pump_gtk_events
  return unless defined?(Gtk) && Gtk.respond_to?(:events_pending?)

  iterations = 0
  while Gtk.events_pending? && iterations < 20
    Gtk.main_iteration
    iterations += 1
  end
rescue
  nil
end

def add_browse_filter(dialog, name, patterns)
  return unless defined?(Gtk::FileFilter) && dialog.respond_to?(:add_filter)

  filter = Gtk::FileFilter.new
  filter.name = name if filter.respond_to?(:name=)
  patterns.each { |pattern| filter.add_pattern(pattern) if filter.respond_to?(:add_pattern) }
  dialog.add_filter(filter)
rescue
  nil
end

def supported_browse_extension?(path, file_type)
  return true if file_type.nil? || file_type == :any

  extension = File.extname(path.to_s).downcase
  case file_type
  when :xml
    extension == '.xml'
  when :json
    extension == '.json'
  when :sound
    extension == '.wav'
  else
    true
  end
end

def browse_path(title, current_path = '', action = :open, file_type = :any)
  return nil unless defined?(Gtk::FileChooserDialog)

  gtk_action = case action
               when :folder
                 Gtk::FileChooserAction::SELECT_FOLDER
               else
                 Gtk::FileChooserAction::OPEN
  end
  begin
    dialog = Gtk::FileChooserDialog.new(:title => title, :parent => nil, :action => gtk_action, :buttons => nil)
  rescue ArgumentError
    dialog = Gtk::FileChooserDialog.new(title, nil, gtk_action)
  end
  if action != :folder
    case file_type
    when :xml
      add_browse_filter(dialog, 'XML files (*.xml)', ['*.xml', '*.XML'])
    when :json
      add_browse_filter(dialog, 'JSON files (*.json)', ['*.json', '*.JSON'])
    when :sound
      add_browse_filter(dialog, 'WAV sound files (*.wav)', ['*.wav', '*.WAV'])
    end
    add_browse_filter(dialog, 'All files', ['*'])
  end
  dialog.add_button('Cancel', Gtk::ResponseType::CANCEL) if dialog.respond_to?(:add_button)
  use_open_folder_response = 73
  if action == :folder
    dialog.add_button('Use Open Folder', use_open_folder_response) if dialog.respond_to?(:add_button)
  end
  dialog.add_button('Select', Gtk::ResponseType::ACCEPT) if dialog.respond_to?(:add_button)
  open_folder = ''
  update_open_folder = proc do
    folder = dialog.current_folder if dialog.respond_to?(:current_folder)
    open_folder = folder.to_s unless folder.to_s.strip.empty?
  end
  if !current_path.to_s.strip.empty?
    if action == :folder
      dialog.current_folder = current_path.to_s if dialog.respond_to?(:current_folder=)
    elsif File.directory?(current_path.to_s)
      dialog.current_folder = current_path.to_s if dialog.respond_to?(:current_folder=)
    elsif File.dirname(current_path.to_s) && Dir.exist?(File.dirname(current_path.to_s))
      dialog.current_folder = File.dirname(current_path.to_s) if dialog.respond_to?(:current_folder=)
      dialog.filename = current_path.to_s if dialog.respond_to?(:filename=) && File.exist?(current_path.to_s)
    end
  end
  update_open_folder.call
  if action == :folder && dialog.respond_to?(:signal_connect)
    dialog.signal_connect('current-folder-changed') { update_open_folder.call }
  end
  response = dialog.run
  if response == Gtk::ResponseType::ACCEPT
    if action == :folder
      filename = open_folder
    else
      filename = dialog.filename if dialog.respond_to?(:filename)
    end
  elsif action == :folder && response == use_open_folder_response
    filename = open_folder
  end
  if filename && action != :folder && !supported_browse_extension?(filename, file_type)
    ph_echo "Unsupported file type selected: #{filename}"
    filename = nil
  end
  dialog.destroy if dialog.respond_to?(:destroy)
  filename
rescue => error
  ph_echo "Browse failed: #{error.message}"
  nil
ensure
  begin
    dialog.destroy if dialog && dialog.respond_to?(:destroy)
  rescue
    nil
  end
end

def present_setup_window(window)
  return unless window

  gtk_debug "present_setup_window window=#{window.class}"
  window.show_all if window.respond_to?(:show_all)
  window.deiconify if window.respond_to?(:deiconify)
  window.set_keep_above(true) if window.respond_to?(:set_keep_above)
  window.present if window.respond_to?(:present)
  window.window.raise if window.respond_to?(:window) && window.window && window.window.respond_to?(:raise)
  if defined?(GLib) && GLib.respond_to?(:Timeout)
    GLib::Timeout.add(150) do
      begin
        window.deiconify if window.respond_to?(:deiconify)
        window.present if window.respond_to?(:present)
        window.window.raise if window.respond_to?(:window) && window.window && window.window.respond_to?(:raise)
      rescue
        nil
      end
      false
    end
    GLib::Timeout.add(900) do
      begin
        window.set_keep_above(false) if window.respond_to?(:set_keep_above)
      rescue
        nil
      end
      false
    end
  else
    window.set_keep_above(false) if window.respond_to?(:set_keep_above)
  end
rescue
  nil
end

def close_setup_window(window_ref, closed_ref)
  gtk_debug "close_setup_window name=#{window_ref[:name].inspect} closed=#{closed_ref[:closed]} window=#{window_ref[:window] ? 'yes' : 'no'}" if window_ref.is_a?(Hash)
  return if closed_ref[:closed] && window_ref[:window].nil?

  close_gtk_window_now(window_ref, closed_ref)
rescue
  nil
end

def close_gtk_window_now(window_ref, closed_ref = nil)
  window = window_ref.is_a?(Hash) ? window_ref[:window] : window_ref
  name = window_ref.is_a?(Hash) ? window_ref[:name].to_s : '(direct)'
  gtk_debug "close_gtk_window_now name=#{name.inspect} window=#{window ? window.class : 'nil'}"
  closed_ref[:closed] = true if closed_ref
  forget_gtk_window(name, window_ref, closed_ref) if window_ref.is_a?(Hash)
  return unless window

  if defined?(Gtk)
    Gtk.queue do
      begin
        if window.respond_to?(:hide)
          gtk_debug "gtk hiding #{name.inspect} before close"
          window.hide
        end
        if window.respond_to?(:destroy)
          gtk_debug "gtk closing #{name.inspect} with destroy"
          window.destroy
        elsif window.respond_to?(:close)
          gtk_debug "gtk closing #{name.inspect} with close"
          window.close
        end
      rescue => error
        gtk_debug "queued close_gtk_window_now failed: #{error.class}: #{error.message}"
      end
    end
  else
    begin
      if window.respond_to?(:destroy)
        window.destroy
      elsif window.respond_to?(:hide)
        window.hide
      elsif window.respond_to?(:close)
        window.close
      end
    rescue
      nil
    end
  end
rescue
  nil
end

def handle_gtk_delete_event(label, window_ref, closed_ref)
  gtk_debug "#{label} delete_event"
  gtk_debug "#{label} delete_event handled by script close"
  close_gtk_window_now(window_ref, closed_ref)
  true
rescue => error
  gtk_debug "#{label} delete_event close failed: #{error.class}: #{error.message}"
  true
end

def hide_gtk_window_now(window_ref, closed_ref = nil)
  window = window_ref.is_a?(Hash) ? window_ref[:window] : window_ref
  name = window_ref.is_a?(Hash) ? window_ref[:name].to_s : '(direct)'
  gtk_debug "hide_gtk_window_now name=#{name.inspect} window=#{window ? window.class : 'nil'}"
  closed_ref[:closed] = true if closed_ref
  forget_gtk_window(name, window_ref, closed_ref) if window_ref.is_a?(Hash)
  return unless window

  if defined?(Gtk)
    Gtk.queue {
      begin
        if window.respond_to?(:hide)
          gtk_debug "gtk hiding #{name.inspect}"
          window.hide
        elsif window.respond_to?(:iconify)
          gtk_debug "gtk iconifying #{name.inspect}"
          window.iconify
        end
      rescue => error
        gtk_debug "queued hide_gtk_window_now failed: #{error.class}: #{error.message}"
      end
    }
    5.times do
      pump_gtk_events
      sleep 0.02
    end
  elsif window.respond_to?(:hide)
    window.hide
  end
rescue
  nil
end

def remember_gtk_window(name, window, window_ref = nil)
  gtk_debug "remember_gtk_window name=#{name.inspect} window=#{window ? window.class : 'nil'} global_before=#{$highlight_manager_gtk_windows.class if defined?($highlight_manager_gtk_windows)}"
  $highlight_manager_gtk_windows = {} unless $highlight_manager_gtk_windows.is_a?(Hash)
  @highlight_manager_gtk_windows = {} unless @highlight_manager_gtk_windows.is_a?(Hash)
  if window_ref.is_a?(Hash)
    window_ref[:name] = name
    window_ref[:window] = window
  end
  $highlight_manager_gtk_windows[name] = window
  @highlight_manager_gtk_windows[name] = window
rescue
  nil
end

def forget_gtk_window(name, window_ref = nil, closed_ref = nil)
  gtk_debug "forget_gtk_window name=#{name.inspect}"
  closed_ref[:closed] = true if closed_ref
  window_ref[:window] = nil if window_ref.is_a?(Hash)
  $highlight_manager_gtk_windows = {} unless $highlight_manager_gtk_windows.is_a?(Hash)
  @highlight_manager_gtk_windows = {} unless @highlight_manager_gtk_windows.is_a?(Hash)
  $highlight_manager_gtk_windows.delete(name)
  @highlight_manager_gtk_windows.delete(name)
rescue
  nil
end

def gtk_window_open?(window_ref)
  window = window_ref.is_a?(Hash) ? window_ref[:window] : window_ref
  !!window
rescue
  false
end

def setup_parent_window
  return nil unless $highlight_manager_gtk_windows.is_a?(Hash)

  $highlight_manager_gtk_windows['Setup']
rescue
  nil
end

def active_setup_child_window
  return nil unless $highlight_manager_gtk_windows.is_a?(Hash)

  ['Copy', 'Add Names', 'Import Existing'].each do |name|
    window = $highlight_manager_gtk_windows[name]
    return window if window
  end
  nil
rescue
  nil
end

def make_child_window_modal(window, parent = nil)
  return unless window

  parent ||= setup_parent_window
  if parent
    window.transient_for = parent if window.respond_to?(:transient_for=)
    window.set_transient_for(parent) if window.respond_to?(:set_transient_for)
  end
  window.modal = true if window.respond_to?(:modal=)
  window.set_modal(true) if window.respond_to?(:set_modal)
rescue => error
  gtk_debug "make_child_window_modal failed: #{error.class}: #{error.message}"
end

def default_label_moves_signature(moves)
  moves.map do |move|
    [move[:source], move[:target_kind], move[:target], move[:count]].map(&:to_s).join("\t")
  end.sort.join("\n")
end

def default_label_moves_warning_text(moves, confirmed = false)
  return '' if moves.empty?

  detail_lines = moves.first(4).map do |move|
    "#{move[:source]} -> #{label_move_target_description(move[:target_kind], move[:target])} (#{move[:count]} name(s))"
  end
  detail_lines << "...and #{moves.length - 4} more" if moves.length > 4
  if confirmed
    [
      'MOVE CONFIRMED: review the changes below.',
      *detail_lines,
      'Click Save Again To Apply to move these names and remove the old custom label colors.'
    ].join("\n")
  else
    [
      'WARNING: this rename will move saved names and remove the old custom label colors.',
      *detail_lines,
      'Click Save once to confirm this move, then Save again to apply it.'
    ].join("\n")
  end
end

def gtk_markup_escape(text)
  text.to_s.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;')
end

def default_label_moves_warning_markup(moves, confirmed = false)
  text = default_label_moves_warning_text(moves, confirmed)
  return '' if text.empty?

  lines = text.lines.map { |line| line.chomp }
  return gtk_markup_escape(text) if lines.empty?

  first = lines.shift
  last = lines.pop
  body = lines.map { |line| gtk_markup_escape(line) }
  first_color = confirmed ? '#ffbf40' : '#ff5555'
  [
    "<span foreground=\"#{first_color}\" weight=\"bold\">#{gtk_markup_escape(first)}</span>",
    *body,
    "<span foreground=\"#ffbf40\" weight=\"bold\">#{gtk_markup_escape(last)}</span>"
  ].join("\n")
end

def close_all_gtk_windows_now
  gtk_debug "close_all_gtk_windows_now instance=#{@highlight_manager_gtk_windows.class if defined?(@highlight_manager_gtk_windows)} global=#{$highlight_manager_gtk_windows.class if defined?($highlight_manager_gtk_windows)} refs=#{$highlight_manager_gtk_window_refs.class if defined?($highlight_manager_gtk_window_refs)}"
  windows = @highlight_manager_gtk_windows.is_a?(Hash) ? @highlight_manager_gtk_windows : {}
  ['Import Existing', 'Add Names', 'Copy', 'Setup'].each do |name|
    close_gtk_window_now(windows[name]) if windows[name]
  end

  tracked_windows = $highlight_manager_gtk_windows.is_a?(Hash) ? $highlight_manager_gtk_windows.values : []
  tracked_windows.reverse_each do |window|
    close_gtk_window_now(window)
  end
  tracked_refs = $highlight_manager_gtk_window_refs.is_a?(Array) ? $highlight_manager_gtk_window_refs : []
  tracked_refs.reverse_each do |ref, closed|
    close_gtk_window_now(ref, closed)
  end
  $highlight_manager_gtk_windows = {}
  @highlight_manager_gtk_windows = {}
  $highlight_manager_gtk_window_refs = []
rescue
  nil
end

def register_gtk_window_cleanup(window_ref, closed_ref)
  gtk_debug 'register_gtk_window_cleanup'
  $highlight_manager_gtk_windows = {} unless $highlight_manager_gtk_windows.is_a?(Hash)
  $highlight_manager_gtk_window_refs = [] unless $highlight_manager_gtk_window_refs.is_a?(Array)
  $highlight_manager_gtk_window_refs.reject! { |ref, closed| closed[:closed] || ref[:window].nil? }
  $highlight_manager_gtk_window_refs << [window_ref, closed_ref]
  return if $highlight_manager_gtk_cleanup_registered

  before_dying do
    begin
      gtk_debug 'before_dying GTK cleanup fired'
      close_all_gtk_windows_now
    rescue => error
      gtk_debug "before_dying GTK cleanup failed: #{error.class}: #{error.message}"
    end
  end if defined?(before_dying)
  $highlight_manager_gtk_cleanup_registered = true
rescue
  nil
end

def close_orphaned_gtk_windows
  return unless defined?(Gtk)

  gtk_debug 'close_orphaned_gtk_windows skipped unsafe GTK close; clearing stale trackers only'
  $highlight_manager_gtk_windows = {}
  @highlight_manager_gtk_windows = {}
  $highlight_manager_gtk_window_refs = []
rescue
  nil
end

def unique_timestamped_dir(parent_dir, prefix)
  base = "#{prefix}-#{Time.now.strftime('%Y%m%d-%H%M%S')}"
  1.upto(1_000) do |index|
    suffix = index == 1 ? '' : "-#{format('%03d', index - 1)}"
    path = File.join(parent_dir, "#{base}#{suffix}")
    return path unless Dir.exist?(path)
  end

  raise "Could not create a unique #{prefix} folder in #{parent_dir}"
end

def copy_backup_root(target_dir)
  File.join(target_dir.to_s, COPY_BACKUP_FOLDER_NAME)
end

def copy_backup_roots(target_dir)
  ([COPY_BACKUP_FOLDER_NAME] + LEGACY_COPY_BACKUP_FOLDER_NAMES).map { |folder_name| File.join(target_dir.to_s, folder_name) }
end

def copy_backup_target_folder?(target_dir)
  path = File.expand_path(target_dir.to_s)
  normalized = path.tr('\\', '/')
  parts = normalized.split('/')
  basename = File.basename(normalized)
  return true if basename =~ /\A#{Regexp.escape(SCRIPT_NAME)}-copy-backup-\d{8}-\d{6}(?:-\d{3})?\z/
  return true if basename =~ /\A#{Regexp.escape(LEGACY_SCRIPT_BASENAME)}-copy-backup-\d{8}-\d{6}(?:-\d{3})?\z/
  return true if ([COPY_BACKUP_FOLDER_NAME] + LEGACY_COPY_BACKUP_FOLDER_NAMES).any? { |folder_name| parts.include?(folder_name) }

  false
rescue
  false
end

def copy_real_target_from_backup_target(target_dir)
  path = File.expand_path(target_dir.to_s)
  normalized = path.tr('\\', '/')
  parts = normalized.split('/')
  backup_index = parts.index { |part| ([COPY_BACKUP_FOLDER_NAME] + LEGACY_COPY_BACKUP_FOLDER_NAMES).include?(part) }
  return parts[0...backup_index].join('/') if backup_index && backup_index.positive?
  return File.dirname(normalized) if File.basename(normalized) =~ /\A#{Regexp.escape(SCRIPT_NAME)}-copy-backup-\d{8}-\d{6}(?:-\d{3})?\z/
  return File.dirname(normalized) if File.basename(normalized) =~ /\A#{Regexp.escape(LEGACY_SCRIPT_BASENAME)}-copy-backup-\d{8}-\d{6}(?:-\d{3})?\z/

  target_dir.to_s
rescue
  target_dir.to_s
end

def copy_reject_backup_target!(target_dir)
  return unless copy_backup_target_folder?(target_dir)

  raise 'Target folder is a Highlight Manager backup folder. Choose the real Wrayth/GS4 folder instead.'
end

def copy_generated_backup_dirs(target_dir)
  root = copy_backup_root(target_dir)
  return [] unless Dir.exist?(root)

  Dir.children(root).select { |name| name =~ /\A(?:copy|pre-restore)-\d{8}-\d{6}(?:-\d{3})?\z/ }.map { |name| File.join(root, name) }.select { |path| Dir.exist?(path) }
rescue
  []
end

def copy_backup_sort_key(path)
  [File.mtime(path), path]
rescue
  [Time.at(0), path.to_s]
end

def copy_backup_dirs(target_dir)
  return [] unless target_dir && Dir.exist?(target_dir)

  nested = copy_backup_roots(target_dir).flat_map do |root|
    next [] unless Dir.exist?(root)

    Dir.children(root).select { |name| name =~ /\Acopy-\d{8}-\d{6}(?:-\d{3})?\z/ }.map { |name| File.join(root, name) }
  end
  legacy = Dir.children(target_dir).select { |name| name =~ /\A(?:#{Regexp.escape(SCRIPT_NAME)}|#{Regexp.escape(LEGACY_SCRIPT_BASENAME)})-copy-backup-\d{8}-\d{6}(?:-\d{3})?\z/ }.map { |name| File.join(target_dir, name) }
  (nested + legacy).select { |path| Dir.exist?(path) }.sort_by { |path| copy_backup_sort_key(path) }
rescue
  []
end

def copy_latest_backup(target_dir)
  copy_backup_dirs(target_dir).last
end

def copy_prune_backup_dirs(target_dir)
  keep_count = COPY_BACKUP_KEEP_COUNT.to_i
  return if keep_count <= 0

  dirs = copy_generated_backup_dirs(target_dir).sort_by { |path| copy_backup_sort_key(path) }
  extra_count = dirs.length - keep_count
  return if extra_count <= 0

  dirs.first(extra_count).each { |path| FileUtils.rm_rf(path) }
  ph_echo "Pruned #{extra_count} older Highlight Manager backup folder(s)."
rescue => error
  ph_echo "Backup cleanup warning: #{error.message}"
end

def copy_restore_backup(target_dir, backup_dir)
  copy_reject_backup_target!(target_dir)
  raise "Target folder not found: #{target_dir}" unless Dir.exist?(target_dir)
  raise "Backup folder not found: #{backup_dir}" unless Dir.exist?(backup_dir)

  backup_files = copy_target_files(backup_dir)
  pre_restore_dir = unique_timestamped_dir(copy_backup_root(target_dir), 'pre-restore')
  FileUtils.mkdir_p(pre_restore_dir)
  copy_target_files(target_dir).each do |target_path|
    FileUtils.cp(target_path, File.join(pre_restore_dir, File.basename(target_path)))
  end
  backup_files.each_with_index do |backup_path, index|
    basename = File.basename(backup_path)
    ph_echo "Restoring #{index + 1}/#{backup_files.length}: #{basename}"
    FileUtils.cp(backup_path, File.join(target_dir, basename))
  end
  ph_echo 'Highlight Manager backup restore complete.'
  ph_echo "  Restored from: #{backup_dir}"
  ph_echo "  Safety backup of pre-restore files: #{pre_restore_dir}"
  ph_echo "  Files restored: #{backup_files.length}"
  copy_prune_backup_dirs(target_dir)
rescue => error
  ph_echo "Backup restore failed: #{error.message}"
end

def remember_copy_settings(config, source_path, target_dir, duplicate_mode, confirmed = false)
  if copy_backup_target_folder?(target_dir)
    gtk_debug "remember_copy_settings refused backup target: #{target_dir}"
    return false
  end

  mode = duplicate_mode.to_s
  mode = 'replace' unless COPY_DUPLICATE_MODES.include?(mode)
  config['copy_settings'] = {
    'source_path' => source_path.to_s,
    'target_dir' => target_dir.to_s,
    'duplicates' => mode,
    'confirmed' => !!confirmed,
    (confirmed ? 'confirmed_at' : 'updated_at') => Time.now.utc.iso8601,
  }
  save_config(config)
  true
rescue => error
  gtk_debug "remember_copy_settings failed: #{error.class}: #{error.message}"
  false
end

def show_copy_settings_window(config)
  if copy_to_characters_disabled?(config)
    ph_echo copy_to_characters_disabled_message
    return
  end

  unless defined?(Gtk)
    copy_setup(config, [])
    ph_echo 'GTK is not available. Review the paths above, then run ;highlight-manager copy confirm duplicates=replace|skip|clear.'
    return
  end

  settings = config['copy_settings'].is_a?(Hash) ? config['copy_settings'] : {}
  source_default = settings['source_path'].to_s
  source_default = default_export_path('wrayth') if source_default.empty?
  target_default = settings['target_dir'].to_s
  target_default = copy_detect_target([]) if target_default.empty?
  target_default = copy_real_target_from_backup_target(target_default) if copy_backup_target_folder?(target_default)
  duplicate_default = settings['duplicates'].to_s
  duplicate_default = 'replace' unless COPY_DUPLICATE_MODES.include?(duplicate_default)
  action = nil
  values = {}
  setup_error = nil
  run_state = { running: false, cancel: false }
  set_copy_running = nil
  update_copy_progress = nil
  refresh_backup_label = nil
  refresh_status_label = nil
  window_ref = { window: nil }
  closed_ref = { closed: false }
  register_gtk_window_cleanup(window_ref, closed_ref)

  Gtk.queue {
    begin
      window = Gtk::Window.new(:toplevel)
      remember_gtk_window('Copy', window, window_ref)
      make_child_window_modal(window)
      window.title = 'Copy Highlights To Characters'
      window.border_width = 10
      window.set_position(Gtk::WindowPosition::CENTER) if defined?(Gtk::WindowPosition)
      window.set_default_size(860, 360) if window.respond_to?(:set_default_size)

      source_entry = Gtk::Entry.new
      source_entry.text = source_default
      target_entry = Gtk::Entry.new
      target_entry.text = target_default
      source_browse = Gtk::Button.new(:label => 'Browse')
      target_browse = Gtk::Button.new(:label => 'Browse')
      duplicate_combo = Gtk::ComboBoxText.new if defined?(Gtk::ComboBoxText)
      if duplicate_combo
        [
          ['replace', 'Update matching Name/Custom Text entries and add missing ones'],
          ['skip', 'Only add missing Name/Custom Text entries; leave matches alone'],
          ['clear', 'Clear old player-name highlights first; update Custom Text; add current player-name highlights'],
        ].each do |value, label|
          duplicate_combo.append(value, label)
        end
        duplicate_combo.active_id = duplicate_default if duplicate_combo.respond_to?(:active_id=)
      end

      latest_backup_label = Gtk::Label.new('')
      status_label = Gtk::Label.new('')
      status_label.line_wrap = true if status_label.respond_to?(:line_wrap=)
      current_copy_values = proc do
        {
          source: source_entry.text.to_s,
          target: target_entry.text.to_s,
          duplicates: duplicate_combo && duplicate_combo.respond_to?(:active_id) ? duplicate_combo.active_id.to_s : duplicate_default,
        }
      end
      refresh_backup_label = proc do
        backup = copy_latest_backup(target_entry.text.to_s)
        latest_backup_label.text = backup ? "Latest backup: #{backup}" : 'Latest backup: none found in target folder'
      end
      refresh_status_label = proc do
        begin
          verified = copy_verify_settings(source_entry.text.to_s, target_entry.text.to_s)
          status_label.text = "Detected #{verified[:source][:string_count]} Custom text highlight(s), #{verified[:source][:name_count]} Name highlight(s), and #{verified[:targets].length} character XML file(s)."
        rescue => error
          status_label.text = "Setup check: #{error.message}"
        end
      end
      target_entry.signal_connect('changed') { refresh_backup_label.call }
      source_entry.signal_connect('changed') { refresh_status_label.call }
      target_entry.signal_connect('changed') { refresh_status_label.call }
      source_browse.signal_connect('clicked') do
        selected = browse_path('Select Highlight Manager import XML', source_entry.text.to_s, :open, :xml)
        if selected
          source_entry.text = selected
          values = current_copy_values.call
          action = :remember
        end
      end
      target_browse.signal_connect('clicked') do
        selected = browse_path('Select Wrayth GS4 character XML folder', target_entry.text.to_s, :folder)
        if selected
          if copy_backup_target_folder?(selected)
            fixed = copy_real_target_from_backup_target(selected)
            gtk_debug "Copy window converted backup target selection #{selected.inspect} to #{fixed.inspect}"
            selected = fixed
          end
          target_entry.text = selected
          values = current_copy_values.call
          action = :remember
        end
      end
      duplicate_combo.signal_connect('changed') do
        values = current_copy_values.call
        action = :remember
      end if duplicate_combo && duplicate_combo.respond_to?(:signal_connect)

      progress_bar = Gtk::ProgressBar.new if defined?(Gtk::ProgressBar)
      if progress_bar && progress_bar.respond_to?(:show_text=)
        progress_bar.show_text = true
        progress_bar.text = 'Ready'
      end

      source_box = Gtk::Box.new(:horizontal, 6)
      source_box.pack_start(source_entry, :expand => true, :fill => true)
      source_box.pack_start(source_browse, :expand => false)
      target_box = Gtk::Box.new(:horizontal, 6)
      target_box.pack_start(target_entry, :expand => true, :fill => true)
      target_box.pack_start(target_browse, :expand => false)

      grid = Gtk::Table.new(6, 2, false)
      [['Import XML:', source_box], ['Target folder:', target_box], ['If a highlight already exists:', duplicate_combo || Gtk::Label.new(duplicate_default)]].each_with_index do |(label_text, widget), index|
        grid.attach(Gtk::Label.new(label_text), 0, 1, index, index + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
        grid.attach(widget, 1, 2, index, index + 1, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
      end
      grid.attach(latest_backup_label, 1, 2, 3, 4, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
      grid.attach(status_label, 1, 2, 4, 5, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
      grid.attach(progress_bar, 1, 2, 5, 6, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4) if progress_bar

      warning = Gtk::Label.new('This will edit numeric Wrayth character XML files. Backups are saved in one highlight-manager-backups folder before changes are made. Manual labels like Friend, Family, Enemy, Self, and custom labels are saved as player-name highlights.')
      warning.line_wrap = true if warning.respond_to?(:line_wrap=)
      duplicate_note = Gtk::Label.new('Custom Text highlights are legend labels and phrase/string highlights. Clear mode clears old player-name highlights, then updates Custom Text and adds current player-name highlights.')
      duplicate_note.line_wrap = true if duplicate_note.respond_to?(:line_wrap=)
      backup_note = Gtk::Label.new('Restore Latest Backup copies the newest Highlight Manager backup back into the target folder and first saves a pre-restore backup.')
      backup_note.line_wrap = true if backup_note.respond_to?(:line_wrap=)

      run_button = Gtk::Button.new(:label => 'Confirm And Copy')
      restore_button = Gtk::Button.new(:label => 'Restore Latest Backup')
      cancel_button = Gtk::Button.new(:label => 'Cancel')
      run_button.signal_connect('clicked') do
        next if run_state[:running]

        values = current_copy_values.call
        action = :run
      end
      restore_button.signal_connect('clicked') do
        next if run_state[:running]

        values = current_copy_values.call
        action = :restore
      end
      cancel_button.signal_connect('clicked') do
        gtk_debug 'Copy window cancel clicked'
        if run_state[:running]
          run_state[:cancel] = true
          update_copy_progress.call('Cancel requested. Restoring backup after the current file finishes...', nil, nil) if update_copy_progress
        else
          action = :cancel
          close_gtk_window_now(window_ref, closed_ref)
        end
      end

      set_copy_running = proc do |running|
        Gtk.queue do
          begin
            run_button.sensitive = !running if run_button.respond_to?(:sensitive=)
            restore_button.sensitive = !running if restore_button.respond_to?(:sensitive=)
            source_browse.sensitive = !running if source_browse.respond_to?(:sensitive=)
            target_browse.sensitive = !running if target_browse.respond_to?(:sensitive=)
            duplicate_combo.sensitive = !running if duplicate_combo && duplicate_combo.respond_to?(:sensitive=)
            cancel_button.label = running ? 'Cancel Copy' : 'Cancel' if cancel_button.respond_to?(:label=)
          rescue => error
            gtk_debug "Copy window running-state update failed: #{error.class}: #{error.message}"
          end
        end
      end

      update_copy_progress = proc do |message, current, total|
        Gtk.queue do
          begin
            status_label.text = message.to_s if status_label.respond_to?(:text=)
            if progress_bar
              if current && total && total.to_i > 0
                fraction = [[current.to_f / total.to_f, 0.0].max, 1.0].min
                progress_bar.fraction = fraction if progress_bar.respond_to?(:fraction=)
                progress_bar.text = "#{(fraction * 100).round}%" if progress_bar.respond_to?(:text=)
              elsif message
                progress_bar.pulse if progress_bar.respond_to?(:pulse)
                progress_bar.text = message.to_s[0, 80] if progress_bar.respond_to?(:text=)
              end
            end
          rescue => error
            gtk_debug "Copy window progress update failed: #{error.class}: #{error.message}"
          end
        end
      end

      buttons = Gtk::Box.new(:horizontal, 6)
      buttons.pack_start(run_button, :expand => false)
      buttons.pack_start(restore_button, :expand => false)
      buttons.pack_start(cancel_button, :expand => false)

      vbox = Gtk::Box.new(:vertical, 8)
      vbox.pack_start(warning, :expand => false)
      vbox.pack_start(grid, :expand => false)
      vbox.pack_start(duplicate_note, :expand => false)
      vbox.pack_start(backup_note, :expand => false)
      vbox.pack_start(buttons, :expand => false)

      window.signal_connect('delete_event') do
        if run_state[:running]
          gtk_debug 'Copy window delete_event requested cancel during active copy'
          run_state[:cancel] = true
          update_copy_progress.call('Cancel requested. Restoring backup after the current file finishes...', nil, nil) if update_copy_progress
          true
        else
          action ||= :cancel
          handle_gtk_delete_event('Copy window', window_ref, closed_ref)
        end
      end
      window.signal_connect('destroy') do
        gtk_debug 'Copy window destroy'
        forget_gtk_window(window_ref[:name], window_ref, closed_ref)
      end
      window.add(vbox)
      refresh_backup_label.call
      refresh_status_label.call
      present_setup_window(window)
    rescue => error
      setup_error = error
      action = :error
    end
  }

  loop do
    wait_until { action }
    requested_action = action
    gtk_debug "Copy window loop action=#{requested_action.inspect}"
    action = nil

    if requested_action == :error
      ph_echo "Copy dialog failed: #{setup_error.class}: #{setup_error.message}"
      break
    elsif requested_action == :remember
      remembered = remember_copy_settings(config, values[:source].to_s, values[:target].to_s, values[:duplicates].to_s, false)
      if remembered
        gtk_debug "Copy window remembered paths source=#{values[:source].inspect} target=#{values[:target].inspect} duplicates=#{values[:duplicates].inspect}"
      else
        gtk_debug "Copy window did not remember invalid paths source=#{values[:source].inspect} target=#{values[:target].inspect} duplicates=#{values[:duplicates].inspect}"
      end
      next
    elsif requested_action == :run
      source_path = values[:source].to_s
      target_dir = values[:target].to_s
      if copy_backup_target_folder?(target_dir)
        fixed = copy_real_target_from_backup_target(target_dir)
        gtk_debug "Copy run converted backup target #{target_dir.inspect} to #{fixed.inspect}"
        target_dir = fixed
      end
      mode = values[:duplicates].to_s
      mode = 'replace' unless COPY_DUPLICATE_MODES.include?(mode)
      verified = copy_verify_settings(source_path, target_dir)
      remember_copy_settings(config, source_path, target_dir, mode, true)
      ph_echo 'Confirmed highlight copy settings from GUI:'
      ph_echo "  Source: #{source_path}"
      ph_echo "    Custom text highlights: #{verified[:source][:string_count]}"
      ph_echo "    Name highlights:   #{verified[:source][:name_count]}"
      ph_echo "  Target folder: #{target_dir}"
      ph_echo "    Character XML files: #{verified[:targets].length}"
      ph_echo "  Duplicates: #{mode}"
      run_state[:running] = true
      run_state[:cancel] = false
      set_copy_running.call(true) if set_copy_running
      update_copy_progress.call('Starting Highlight Manager copy...', 0, verified[:targets].length) if update_copy_progress
      completed = copy_run_merge(config, update_copy_progress, proc { run_state[:cancel] })
      run_state[:running] = false
      set_copy_running.call(false) if set_copy_running
      refresh_backup_label.call if refresh_backup_label
      refresh_status_label.call if refresh_status_label
      if completed
        update_copy_progress.call('Copy complete.', verified[:targets].length, verified[:targets].length) if update_copy_progress
        close_gtk_window_now(window_ref, closed_ref)
        break
      end
      next
    elsif requested_action == :restore
      source_path = values[:source].to_s
      target_dir = values[:target].to_s
      if copy_backup_target_folder?(target_dir)
        fixed = copy_real_target_from_backup_target(target_dir)
        gtk_debug "Copy restore converted backup target #{target_dir.inspect} to #{fixed.inspect}"
        target_dir = fixed
      end
      mode = values[:duplicates].to_s
      copy_reject_backup_target!(target_dir)
      remember_copy_settings(config, source_path, target_dir, mode, false)
      backup_dir = copy_latest_backup(target_dir)
      if backup_dir
        ph_echo "Restoring latest Highlight Manager backup from GUI: #{backup_dir}"
        copy_restore_backup(target_dir, backup_dir)
      else
        ph_echo "No Highlight Manager backup folder found in #{target_dir}"
      end
    else
      ph_echo 'Cancelled highlight copy.'
      break
    end
  rescue => error
    ph_echo "Copy dialog action failed: #{error.message}"
    break
  end

  close_setup_window(window_ref, closed_ref)
end

def show_bulk_tag_window(config)
  unless defined?(Gtk)
    ph_echo 'GTK is not available. Use ;highlight-manager addcustom Tag Bob Sue or lines with tag/name commands.'
    return
  end

  action = nil
  setup_error = nil
  entered_text = ''
  window_ref = { window: nil }
  closed_ref = { closed: false }
  register_gtk_window_cleanup(window_ref, closed_ref)

  Gtk.queue {
    begin
      window = Gtk::Window.new(:toplevel)
      remember_gtk_window('Add Names', window, window_ref)
      make_child_window_modal(window)
      window.title = 'Add Names To Tags'
      window.border_width = 10
      window.set_position(Gtk::WindowPosition::CENTER) if defined?(Gtk::WindowPosition)
      window.set_default_size(620, 420) if window.respond_to?(:set_default_size)

      instructions = Gtk::Label.new("Enter one tag per line. Examples:\nFriend: Bob Sue Ann\nEnemy; Joe, Jane\nSelf Mystienne")
      instructions.line_wrap = true if instructions.respond_to?(:line_wrap=)
      text_view = Gtk::TextView.new
      text_view.wrap_mode = Gtk::WrapMode::WORD if defined?(Gtk::WrapMode) && text_view.respond_to?(:wrap_mode=)
      scroller = Gtk::ScrolledWindow.new
      scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::AUTOMATIC) if scroller.respond_to?(:set_policy)
      if scroller.respond_to?(:add)
        scroller.add(text_view)
      end

      add_button = Gtk::Button.new(:label => 'Add Names')
      cancel_button = Gtk::Button.new(:label => 'Cancel')
      add_button.signal_connect('clicked') do
        buffer = text_view.buffer
        if buffer.respond_to?(:bounds)
          start_iter, end_iter = buffer.bounds
          entered_text = buffer.get_text(start_iter, end_iter, true)
        else
          entered_text = buffer.text.to_s
        end
        add_button.sensitive = false if add_button.respond_to?(:sensitive=)
        cancel_button.sensitive = false if cancel_button.respond_to?(:sensitive=)
        gtk_debug "Bulk tag add clicked bytes=#{entered_text.to_s.length}"
        action = :add
        close_gtk_window_now(window_ref, closed_ref)
      end
      cancel_button.signal_connect('clicked') do
        gtk_debug 'Bulk tag cancel clicked'
        action = :cancel
        close_gtk_window_now(window_ref, closed_ref)
      end

      buttons = Gtk::Box.new(:horizontal, 6)
      buttons.pack_start(add_button, :expand => false)
      buttons.pack_start(cancel_button, :expand => false)
      vbox = Gtk::Box.new(:vertical, 8)
      vbox.pack_start(instructions, :expand => false)
      vbox.pack_start(scroller, :expand => true, :fill => true)
      vbox.pack_start(buttons, :expand => false)

      window.signal_connect('delete_event') do
        action ||= :cancel
        handle_gtk_delete_event('Bulk tag', window_ref, closed_ref)
      end
      window.signal_connect('destroy') do
        gtk_debug 'Bulk tag window destroy'
        forget_gtk_window(window_ref[:name], window_ref, closed_ref)
      end
      window.add(vbox)
      present_setup_window(window)
    rescue => error
      setup_error = error
      action = :error
    end
  }

  loop do
    wait_until { action }
    requested_action = action
    gtk_debug "Bulk tag loop action=#{requested_action.inspect}"
    action = nil

    if requested_action == :error
      ph_echo "Bulk tag window failed: #{setup_error.class}: #{setup_error.message}"
      break
    elsif requested_action == :add
      if tag_names_from_lines(config, entered_text)
        rewrite_current_export(load_config, default_export_path(export_format_from_args([], config)), export_format_from_args([], config), true)
      end
      break
    else
      ph_echo 'Cancelled bulk name entry.'
      break
    end
  end

  close_setup_window(window_ref, closed_ref)
end

def show_import_existing_window(config)
  unless defined?(Gtk)
    ph_echo 'GTK is not available. Use ;highlight-manager importxml path/to/settings.xml'
    return
  end

  action = nil
  setup_error = nil
  import_success = false
  values = {}
  status_label = nil
  progress_bar = nil
  import_button_ref = nil
  cancel_button_ref = nil
  window_ref = { window: nil }
  closed_ref = { closed: false }
  default_path = recent_path(config, 'last_import_xml', DEFAULT_EXISTING_IMPORT_SOURCE)
  register_gtk_window_cleanup(window_ref, closed_ref)

  reset_import_controls = proc do |message|
    Gtk.queue {
      status_label.text = message if status_label
      if progress_bar
        progress_bar.fraction = 0.0 if progress_bar.respond_to?(:fraction=)
        progress_bar.text = message if progress_bar.respond_to?(:text=)
      end
      import_button_ref.sensitive = true if import_button_ref && import_button_ref.respond_to?(:sensitive=)
      cancel_button_ref.sensitive = true if cancel_button_ref && cancel_button_ref.respond_to?(:sensitive=)
    }
    pump_gtk_events
  rescue => error
    gtk_debug "reset_import_controls failed: #{error.class}: #{error.message}"
  end

  Gtk.queue {
    begin
      window = Gtk::Window.new(:toplevel)
      remember_gtk_window('Import Existing', window, window_ref)
      make_child_window_modal(window)
      window.title = 'Import Existing Highlights'
      window.border_width = 10
      window.set_position(Gtk::WindowPosition::CENTER) if defined?(Gtk::WindowPosition)
      window.set_default_size(760, 220) if window.respond_to?(:set_default_size)

      path_entry = Gtk::Entry.new
      path_entry.text = default_path.to_s
      path_browse = Gtk::Button.new(:label => 'Browse')
      replace_check = Gtk::CheckButton.new('Replace existing manual tags on imported names') if defined?(Gtk::CheckButton)
      note = Gtk::Label.new("Choose a local front-end settings XML that already contains highlights. Warlock settings XML can include saved login data; Highlight Manager reads only highlight sections and does not save passwords or private settings. Keep full Warlock XML local and do not send it for debugging.\n\nMatching color pairs reuse existing tags; new color pairs become Imported 1, Imported 2, etc.")
      note.line_wrap = true if note.respond_to?(:line_wrap=)
      status_label = Gtk::Label.new('Ready.')
      status_label.xalign = 0.0 if status_label.respond_to?(:xalign=)
      progress_bar = Gtk::ProgressBar.new if defined?(Gtk::ProgressBar)
      if progress_bar
        progress_bar.fraction = 0.0 if progress_bar.respond_to?(:fraction=)
        progress_bar.text = 'Ready' if progress_bar.respond_to?(:text=)
        progress_bar.show_text = true if progress_bar.respond_to?(:show_text=)
      end

      path_box = Gtk::Box.new(:horizontal, 6)
      path_box.pack_start(path_entry, :expand => true, :fill => true)
      path_box.pack_start(path_browse, :expand => false)
      path_browse.signal_connect('clicked') do
        selected = browse_path('Select local front-end settings XML', path_entry.text.to_s, :open, :xml)
        path_entry.text = selected if selected
      end

      grid = Gtk::Table.new(2, 2, false)
      grid.attach(Gtk::Label.new('Settings XML file:'), 0, 1, 0, 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
      grid.attach(path_box, 1, 2, 0, 1, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
      grid.attach(replace_check || Gtk::Label.new(''), 1, 2, 1, 2, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)

      import_button = Gtk::Button.new(:label => 'Import Highlights')
      cancel_button = Gtk::Button.new(:label => 'Cancel')
      import_button_ref = import_button
      cancel_button_ref = cancel_button
      import_button.signal_connect('clicked') do
        gtk_debug "Import existing clicked path=#{path_entry.text}"
        status_label.text = 'Importing highlights... this may take a moment.' if status_label
        import_button.sensitive = false if import_button.respond_to?(:sensitive=)
        cancel_button.sensitive = false if cancel_button.respond_to?(:sensitive=)
        values = {
          path: path_entry.text.to_s,
          replace: replace_check && replace_check.respond_to?(:active?) ? replace_check.active? : false,
        }
        ph_echo "Import requested from GUI: #{values[:path]}"
        action = :import
        pump_gtk_events
      end
      cancel_button.signal_connect('clicked') do
        gtk_debug 'Import existing cancel clicked'
        action = :cancel
        close_gtk_window_now(window_ref, closed_ref)
      end

      buttons = Gtk::Box.new(:horizontal, 6)
      buttons.pack_start(import_button, :expand => false)
      buttons.pack_start(cancel_button, :expand => false)
      vbox = Gtk::Box.new(:vertical, 8)
      vbox.pack_start(note, :expand => false)
      vbox.pack_start(grid, :expand => false)
      vbox.pack_start(status_label, :expand => false)
      vbox.pack_start(progress_bar, :expand => false) if progress_bar
      vbox.pack_start(buttons, :expand => false)

      window.signal_connect('delete_event') do
        action ||= :cancel
        handle_gtk_delete_event('Import existing', window_ref, closed_ref)
      end
      window.signal_connect('destroy') do
        gtk_debug 'Import existing window destroy'
        forget_gtk_window(window_ref[:name], window_ref, closed_ref)
      end
      window.add(vbox)
      present_setup_window(window)
    rescue => error
      setup_error = error
      action = :error
    end
  }

  loop do
    wait_until { action }
    requested_action = action
    gtk_debug "Import existing loop action=#{requested_action.inspect}"
    action = nil

    if requested_action == :error
      ph_echo "Import existing window failed: #{setup_error.class}: #{setup_error.message}"
      break
    elsif requested_action == :import
      begin
        ph_echo "Starting existing highlight import from #{values[:path]}..."
        last_story_milestone = -1
        story_complete_printed = false
        progress = proc do |done, total, message|
          percent = total.to_i.positive? ? ((done.to_f / total.to_f) * 100).round : 0
          status_label.text = "#{message} #{percent}%" if status_label
          if progress_bar
            progress_bar.fraction = [[done.to_f / total.to_f, 0.0].max, 1.0].min if total.to_i.positive? && progress_bar.respond_to?(:fraction=)
            progress_bar.text = "#{percent}% - #{message}" if progress_bar.respond_to?(:text=)
          end
          milestone = percent >= 100 ? 100 : (percent / 10) * 10
          if milestone > last_story_milestone && milestone < 100
            ph_echo "Import progress: #{message} #{percent}%"
            last_story_milestone = milestone
          elsif percent >= 100 && !story_complete_printed && message.to_s =~ /complete/i
            ph_echo "Import progress: #{message} 100%"
            last_story_milestone = 100
            story_complete_printed = true
          end
          pump_gtk_events
        end
        if import_existing_name_highlights(config, values[:path], values[:replace], progress)
          status_label.text = 'Rewriting generated import file...' if status_label
          progress_bar.text = 'Rewriting generated import file...' if progress_bar && progress_bar.respond_to?(:text=)
          ph_echo 'Import progress: rewriting generated import file...'
          pump_gtk_events
          rewrite_current_export(load_config, default_export_path(export_format_from_args([], config)), export_format_from_args([], config), true)
          import_success = true
          gtk_debug 'Import existing completed; hiding window'
          status_label.text = 'Import complete.' if status_label
          progress_bar.text = 'Import complete.' if progress_bar && progress_bar.respond_to?(:text=)
          pump_gtk_events
          hide_gtk_window_now(window_ref, closed_ref)
          break
        else
          gtk_debug 'Import existing returned false; keeping window open'
          reset_import_controls.call('Import did not complete. Verify the file and try again.')
          next
        end
      rescue => error
        ph_echo "Import failed: #{error.message}"
        gtk_debug "Import existing failed; keeping window open: #{error.class}: #{error.message}"
        reset_import_controls.call("Import failed: #{error.message}")
        next
      end
    else
      ph_echo 'Cancelled existing highlight import.'
      break
    end
  end

  close_setup_window(window_ref, closed_ref)
  import_success
end

def show_color_config_window(config)
  unless defined?(Gtk)
    ph_echo 'GTK is not available in this Lich session.'
    return
  end

  races = race_colors(config)
  professions = profession_colors(config)
  tags = tag_colors(config)
  disabled_tags = (config['disabled_tags'] || []).map { |tag| tag.to_s.downcase }
  orphaned_saved_tags = saved_custom_tag_names.map { |tag| normalize_tag_name(tag) || tag.to_s.strip }
  orphaned_saved_tags.reject! do |tag|
    tag.empty? ||
      disabled_tags.include?(tag.downcase) ||
      tags.keys.any? { |known| known.downcase == tag.downcase } ||
      DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == tag.downcase }
  end
  orphaned_imported_tags, orphaned_named_tags = orphaned_saved_tags.uniq.partition { |tag| imported_generated_tag?(tag) }
  orphaned_imported_tags.sort_by! { |tag| [tag[/\d+/].to_i, tag.downcase] }
  orphaned_named_tags.sort_by!(&:downcase)
  (orphaned_named_tags + orphaned_imported_tags).each do |tag|
    tags[tag] = ['#FFFFFF', '#000000']
  end
  race_widgets = {}
  profession_widgets = {}
  tag_rows = []
  string_rows = []
  action = nil
  setup_error = nil
  window_ref = { window: nil }
  closed_ref = { closed: false }
  register_gtk_window_cleanup(window_ref, closed_ref)
  selected_mode = current_mode(config)
  mode_combo = nil
  data_folder_entry = nil
  refresh_tag_rows_from_config = nil
  refresh_string_rows_from_config = nil
  refresh_label_names_text = nil
  persist_string_page = nil
  collect_default_label_moves = nil
  refresh_default_label_move_warning = nil
  confirmation_panel = nil
  confirmation_label = nil
  refresh_mode_visibility = nil
  default_label_move_confirmed_signature = nil
  string_all_entries = []
  tag_container_for_refresh = nil
  requested_data_folder = nil

  Gtk.queue {
    begin
      window = Gtk::Window.new(:toplevel)
      remember_gtk_window('Setup', window, window_ref)
      window.title = 'Highlight Manager'
      window.border_width = 8
      window.set_position(Gtk::WindowPosition::CENTER) if defined?(Gtk::WindowPosition)
      initial_width, initial_height = case selected_mode
                                      when 'race_profession'
                                        [1080, 600]
                                      when 'custom'
                                        [780, 420]
                                      else
                                        [960, 600]
                                      end
      window.set_default_size(initial_width, initial_height) if window.respond_to?(:set_default_size)

      mode_combo = Gtk::ComboBoxText.new if defined?(Gtk::ComboBoxText)
      mode_box = Gtk::Box.new(:horizontal, 6)
      mode_box.pack_start(Gtk::Label.new('Mode:'), :expand => false)
      if mode_combo
        [['Profession only', 'profession'], ['Race only', 'race'], ['Race + Profession', 'race_profession'], ['Custom only', 'custom']].each do |label, value|
          mode_combo.append(value, label)
        end
        mode_combo.active_id = selected_mode if mode_combo.respond_to?(:active_id=)
        mode_box.pack_start(mode_combo, :expand => false)
      else
        mode_box.pack_start(Gtk::Label.new(mode_label(selected_mode)), :expand => false)
      end
      mode_box.pack_start(Gtk::Label.new('Data folder:'), :expand => false)
      data_folder_entry = Gtk::Entry.new
      data_folder_entry.text = configured_data_folder(config)
      data_folder_entry.width_chars = 44 if data_folder_entry.respond_to?(:width_chars=)
      data_folder_entry.tooltip_text = 'Folder for Highlight Manager character data, import files, command transcripts, debug reports, and backups.' if data_folder_entry.respond_to?(:tooltip_text=)
      browse_data_folder = Gtk::Button.new(:label => 'Browse')
      browse_data_folder.tooltip_text = 'Choose a different folder for Highlight Manager files.' if browse_data_folder.respond_to?(:tooltip_text=)
      browse_data_folder.signal_connect('clicked') do
        selected = browse_path('Choose Highlight Manager data folder', data_folder_entry.text, :folder)
        if selected && !selected.to_s.strip.empty?
          gtk_debug "Setup data folder browse selected #{selected.inspect}"
          data_folder_entry.text = selected
          requested_data_folder = selected
          action = :data_folder
        end
      end
      mode_box.pack_start(data_folder_entry, :expand => false)
      mode_box.pack_start(browse_data_folder, :expand => false)

    race_table = Gtk::Table.new(races.length + 1, 7, false)
    race_headers = {}
    ['Race', 'Text', 'Back', 'Pick', 'Pick', 'Clear', 'Preview'].each_with_index do |heading, column|
      label = Gtk::Label.new(heading)
      race_headers[column] = label
      race_table.attach(label, column, column + 1, 0, 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 4)
    end

    races.each_with_index do |(race, pair), index|
      row = index + 1
      fore, back = pair
      fore_entry = Gtk::Entry.new
      fore_entry.text = fore
      fore_entry.width_chars = 9 if fore_entry.respond_to?(:width_chars=)
      back_entry = Gtk::Entry.new
      back_entry.text = back
      back_entry.width_chars = 9 if back_entry.respond_to?(:width_chars=)
      fore_button = color_button(fore)
      back_button = color_button(back)
      clear_button = Gtk::Button.new(:label => 'None')
      preview = Gtk::Label.new(" #{race} ")

      refresh = proc do
        fore_color = normalize_hex(fore_entry.text) || '#FFFFFF'
        back_color = normalize_background(back_entry.text, '')
        apply_preview_colors(preview, fore_color, back_color)
      end

      race_widgets[race] = {
        fore_entry: fore_entry,
        back_entry: back_entry,
        fore_button: fore_button,
        back_button: back_button,
        clear_button: clear_button,
        preview: preview,
        refresh: refresh,
        back_widgets: [back_entry, back_button, clear_button].compact,
      }
      race_table.attach(Gtk::Label.new(race), 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      race_table.attach(fore_entry, 1, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      race_table.attach(back_entry, 2, 3, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      race_table.attach(fore_button || Gtk::Label.new('(n/a)'), 3, 4, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      race_table.attach(back_button || Gtk::Label.new('(n/a)'), 4, 5, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      race_table.attach(clear_button, 5, 6, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      race_table.attach(preview, 6, 7, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)

      fore_entry.signal_connect('changed') { refresh.call }
      back_entry.signal_connect('changed') { refresh.call }
      if fore_button
        fore_button.signal_connect('color-set') do
          fore_entry.text = rgba_to_hex(fore_button.rgba) if fore_button.respond_to?(:rgba)
          refresh.call
        end
      end
      if back_button
        back_button.signal_connect('color-set') do
          back_entry.text = rgba_to_hex(back_button.rgba) if back_button.respond_to?(:rgba)
          refresh.call
        end
      end
      clear_button.signal_connect('clicked') do
        back_entry.text = ''
        refresh.call
      end
      refresh.call
    end

    profession_table = Gtk::Table.new(professions.length + 1, 7, false)
    profession_headers = {}
    ['Profession', 'Text', 'Back', 'Pick', 'Pick', 'Clear', 'Preview'].each_with_index do |heading, column|
      label = Gtk::Label.new(heading)
      profession_headers[column] = label
      profession_table.attach(label, column, column + 1, 0, 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 4)
    end

    professions.each_with_index do |(profession, pair), index|
      row = index + 1
      fore, back = pair
      fore_entry = Gtk::Entry.new
      fore_entry.text = fore
      fore_entry.width_chars = 9 if fore_entry.respond_to?(:width_chars=)
      back_entry = Gtk::Entry.new
      back_entry.text = back
      back_entry.width_chars = 9 if back_entry.respond_to?(:width_chars=)
      fore_button = color_button(fore)
      back_button = color_button(back)
      clear_button = Gtk::Button.new(:label => 'None')
      preview = Gtk::Label.new(" #{profession} ")

      refresh = proc do
        fore_color = normalize_hex(fore_entry.text) || '#FFFFFF'
        back_color = normalize_background(back_entry.text, '')
        apply_preview_colors(preview, fore_color, back_color)
      end

      profession_widgets[profession] = {
        fore_entry: fore_entry,
        back_entry: back_entry,
        fore_button: fore_button,
        back_button: back_button,
        clear_button: clear_button,
        preview: preview,
        refresh: refresh,
        fore_widgets: [fore_entry, fore_button].compact,
      }
      profession_table.attach(Gtk::Label.new(profession), 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      profession_table.attach(fore_entry, 1, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      profession_table.attach(back_entry, 2, 3, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      profession_table.attach(fore_button || Gtk::Label.new('(n/a)'), 3, 4, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      profession_table.attach(back_button || Gtk::Label.new('(n/a)'), 4, 5, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      profession_table.attach(clear_button, 5, 6, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)
      profession_table.attach(preview, 6, 7, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 4, 3)

      fore_entry.signal_connect('changed') { refresh.call }
      back_entry.signal_connect('changed') { refresh.call }
      if fore_button
        fore_button.signal_connect('color-set') do
          fore_entry.text = rgba_to_hex(fore_button.rgba) if fore_button.respond_to?(:rgba)
          refresh.call
        end
      end
      if back_button
        back_button.signal_connect('color-set') do
          back_entry.text = rgba_to_hex(back_button.rgba) if back_button.respond_to?(:rgba)
          refresh.call
        end
      end
      clear_button.signal_connect('clicked') do
        back_entry.text = ''
        refresh.call
      end
      refresh.call
    end

    tag_header_widths = [92, 52, 76, 76, 38, 38, 60, 92, 70]
    tag_header = Gtk::Box.new(:horizontal, 6)
    ['Label', 'Count', 'Text', 'Back', 'Pick', 'Pick', 'Clear', 'Preview', 'Delete'].each_with_index do |heading, index|
      label = Gtk::Label.new(heading)
      label.xalign = 0.5 if heading == 'Count' && label.respond_to?(:xalign=)
      label.set_size_request(tag_header_widths[index], -1) if label.respond_to?(:set_size_request)
      tag_header.pack_start(label, :expand => false)
    end

    tag_list = Gtk::Box.new(:vertical, 4)
    add_tag_row = proc do |tag, pair, built_in|
      if built_in
        tag_entry = Gtk::Label.new(tag.to_s)
        tag_entry.set_size_request(92, -1) if tag_entry.respond_to?(:set_size_request)
      else
        tag_entry = Gtk::Entry.new
        tag_entry.text = tag.to_s
        tag_entry.width_chars = 12 if tag_entry.respond_to?(:width_chars=)
        tag_entry.set_size_request(92, -1) if tag_entry.respond_to?(:set_size_request)
      end
      fore_entry = Gtk::Entry.new
      fore_entry.text = pair[0]
      fore_entry.width_chars = 9 if fore_entry.respond_to?(:width_chars=)
      fore_entry.set_size_request(76, -1) if fore_entry.respond_to?(:set_size_request)
      names_label = Gtk::Label.new('-')
      names_label.xalign = 0.5 if names_label.respond_to?(:xalign=)
      names_label.set_size_request(52, -1) if names_label.respond_to?(:set_size_request)
      back_entry = Gtk::Entry.new
      back_entry.text = pair[1]
      back_entry.width_chars = 9 if back_entry.respond_to?(:width_chars=)
      back_entry.set_size_request(76, -1) if back_entry.respond_to?(:set_size_request)
      fore_button = color_button(pair[0])
      back_button = color_button(pair[1])
      clear_button = Gtk::Button.new(:label => 'None')
      delete_button = Gtk::Button.new(:label => 'Delete')
      delete_widget = built_in ? Gtk::Label.new('') : delete_button
      fore_button.set_size_request(38, -1) if fore_button && fore_button.respond_to?(:set_size_request)
      back_button.set_size_request(38, -1) if back_button && back_button.respond_to?(:set_size_request)
      clear_button.set_size_request(60, -1) if clear_button.respond_to?(:set_size_request)
      delete_widget.set_size_request(70, -1) if delete_widget.respond_to?(:set_size_request)
      preview = Gtk::Label.new(" #{tag.empty? ? 'New label' : tag} ")
      preview.set_size_request(92, -1) if preview.respond_to?(:set_size_request)
      row_box = Gtk::Box.new(:horizontal, 6)
      row_state = { deleted: false }

      refresh = proc do
        fore = normalize_hex(fore_entry.text) || '#FFFFFF'
        back = normalize_background(back_entry.text, '')
        label = normalize_tag_name(widget_text(tag_entry)) || widget_text(tag_entry).to_s.strip
        preview.text = " #{label.empty? ? 'New label' : label} "
        summary, full_names = tagged_name_summary(label)
        names_label.text = summary
        names_label.tooltip_text = full_names if names_label.respond_to?(:tooltip_text=)
        apply_preview_colors(preview, fore, back)
      end

      row_info = {
        built_in: built_in,
        original_tag: normalize_tag_name(tag) || tag.to_s.strip,
        state: row_state,
        row_box: row_box,
        tag_entry: tag_entry,
        names_label: names_label,
        fore_entry: fore_entry,
        back_entry: back_entry,
        fore_button: fore_button,
        back_button: back_button,
        clear_button: clear_button,
        preview: preview,
        refresh: refresh,
      }
      tag_rows << row_info

      row_box.pack_start(tag_entry, :expand => false)
      row_box.pack_start(names_label, :expand => false)
      row_box.pack_start(fore_entry, :expand => false)
      row_box.pack_start(back_entry, :expand => false)
      row_box.pack_start(fore_button || Gtk::Label.new('(n/a)'), :expand => false)
      row_box.pack_start(back_button || Gtk::Label.new('(n/a)'), :expand => false)
      row_box.pack_start(clear_button, :expand => false)
      row_box.pack_start(preview, :expand => false)
      row_box.pack_start(delete_widget, :expand => false)
      tag_list.pack_start(row_box, :expand => false)

      unless built_in
        tag_entry.signal_connect('changed') do
          refresh.call
          default_label_move_confirmed_signature = nil
          refresh_default_label_move_warning.call if refresh_default_label_move_warning
        end
      end
      fore_entry.signal_connect('changed') { refresh.call }
      back_entry.signal_connect('changed') { refresh.call }
      if fore_button
        fore_button.signal_connect('color-set') do
          fore_entry.text = rgba_to_hex(fore_button.rgba) if fore_button.respond_to?(:rgba)
          refresh.call
        end
      end
      if back_button
        back_button.signal_connect('color-set') do
          back_entry.text = rgba_to_hex(back_button.rgba) if back_button.respond_to?(:rgba)
          refresh.call
        end
      end
      clear_button.signal_connect('clicked') do
        back_entry.text = ''
        refresh.call
      end
      delete_button.signal_connect('clicked') do
        next if built_in

        row_state[:deleted] = true
        default_label_move_confirmed_signature = nil
        refresh_default_label_move_warning.call if refresh_default_label_move_warning
        row_box.destroy if row_box.respond_to?(:destroy)
      end
      refresh.call
    end

    tags.each do |tag, pair|
      add_tag_row.call(tag, pair, DEFAULT_TAG_COLORS.key?(tag))
    end

    collect_default_label_moves = proc do
      moves = []
      tag_rows.each do |info|
        next if info[:state][:deleted] || info[:built_in]

        raw_tag = widget_text(info[:tag_entry]).to_s.strip
        tag = normalize_tag_name(raw_tag)
        next if tag.to_s.empty?

        original_tag = info[:original_tag].to_s.strip
        original_tag = normalize_tag_name(original_tag) || original_tag
        next if original_tag.empty? || original_tag.downcase == tag.downcase

        default_target = default_label_move_target(config, tag)
        next unless default_target

        moves << {
          source: original_tag,
          target_kind: default_target[0],
          target: default_target[1],
          count: tagged_name_count(original_tag),
        }
      end
      moves
    end

    refresh_tag_rows_from_config = proc do
      existing_tags = {}
      tag_rows.each do |info|
        next if info[:state][:deleted]

        existing_tags[widget_text(info[:tag_entry]).to_s.downcase] = true
      end
      tag_colors(config).each do |tag, pair|
        next if existing_tags[tag.to_s.downcase]

        add_tag_row.call(tag, pair, DEFAULT_TAG_COLORS.key?(tag))
      end
      tag_rows.each { |info| info[:refresh].call if info[:refresh] && !info[:state][:deleted] }
      if tag_container_for_refresh && tag_container_for_refresh.respond_to?(:show_all)
        tag_container_for_refresh.show_all
      end
      refresh_default_label_move_warning.call if refresh_default_label_move_warning
    end

    string_header_widths = [28, 220, 74, 74, 42, 42, 64, 44, 44, 44, 180, 76, 140, 76]
    string_header = Gtk::Box.new(:horizontal, 6)
    ['#', 'Text/Phrase', 'Text', 'Back', 'Pick', 'Pick', 'Clear', 'Line', 'Word', 'Case', 'Sound', 'Browse', 'Warning', 'Delete'].each_with_index do |heading, index|
      label = Gtk::Label.new(heading)
      label.xalign = 0.5 if label.respond_to?(:xalign=)
      label.set_size_request(string_header_widths[index], -1) if label.respond_to?(:set_size_request)
      string_header.pack_start(label, :expand => false)
    end

    centered_string_cell = proc do |widget, width|
      cell = Gtk::Box.new(:horizontal, 0)
      cell.set_size_request(width, -1) if cell.respond_to?(:set_size_request)
      if widget
        widget.halign = Gtk::Align::CENTER if defined?(Gtk::Align) && widget.respond_to?(:halign=)
        widget.valign = Gtk::Align::CENTER if defined?(Gtk::Align) && widget.respond_to?(:valign=)
        cell.pack_start(widget, :expand => true, :fill => false)
      end
      cell
    end

    string_list = Gtk::Box.new(:vertical, 4)
    string_page_size = 25
    string_page_index = 0
    string_all_entries = string_highlights(config).map { |entry| normalize_string_highlight(entry) }.compact
    add_string_row = proc do |entry, display_number = nil|
      entry = normalize_string_highlight(entry) || { 'text' => '', 'color' => '#FFFFFF', 'bgcolor' => '', 'line' => '', 'case' => 'y', 'word' => '', 'sound' => '' }
      row_box = Gtk::Box.new(:horizontal, 6)
      row_state = { deleted: false }
      number_label = Gtk::Label.new((display_number || string_rows.length + 1).to_s)
      text_entry = Gtk::Entry.new
      text_entry.text = entry['text'].to_s
      fore_entry = Gtk::Entry.new
      fore_entry.text = entry['color'].to_s
      back_entry = Gtk::Entry.new
      back_entry.text = entry['bgcolor'].to_s
      fore_button = color_button(normalize_hex(entry['color']) || '#FFFFFF')
      back_button = color_button(normalize_hex(entry['bgcolor']) || '')
      clear_button = Gtk::Button.new(:label => 'None')
      line_check = Gtk::CheckButton.new
      word_check = Gtk::CheckButton.new
      case_check = Gtk::CheckButton.new
      sound_entry = Gtk::Entry.new
      sound_entry.text = entry['sound'].to_s
      sound_browse = Gtk::Button.new(:label => 'Browse')
      warning = Gtk::Label.new('')
      warning.xalign = 0 if warning.respond_to?(:xalign=)
      delete_button = Gtk::Button.new(:label => 'Delete')

      [number_label, text_entry, fore_entry, back_entry, fore_button, back_button, clear_button, nil, nil, nil, sound_entry, sound_browse, warning, delete_button].each_with_index do |widget, index|
        widget.set_size_request(string_header_widths[index], -1) if widget && widget.respond_to?(:set_size_request)
      end
      [line_check, word_check, case_check].each do |check|
        check.set_size_request(18, -1) if check.respond_to?(:set_size_request)
      end
      text_entry.width_chars = 25 if text_entry.respond_to?(:width_chars=)
      fore_entry.width_chars = 9 if fore_entry.respond_to?(:width_chars=)
      back_entry.width_chars = 9 if back_entry.respond_to?(:width_chars=)
      sound_entry.width_chars = 20 if sound_entry.respond_to?(:width_chars=)
      line_check.active = entry['line'].to_s == 'y' if line_check.respond_to?(:active=)
      word_check.active = entry['word'].to_s == 'y' if word_check.respond_to?(:active=)
      case_check.active = entry['case'].to_s == 'y' if case_check.respond_to?(:active=)

      refresh = proc do
        current = {
          'text' => text_entry.text.to_s,
          'color' => fore_entry.text.to_s,
          'bgcolor' => back_entry.text.to_s,
          'sound' => sound_entry.text.to_s,
        }
        warning.text = string_highlight_warning(current)
        warning.tooltip_text = warning.text if warning.respond_to?(:tooltip_text=)
      end

      row_info = {
        state: row_state,
        row_box: row_box,
        number_label: number_label,
        text_entry: text_entry,
        fore_entry: fore_entry,
        back_entry: back_entry,
        fore_button: fore_button,
        back_button: back_button,
        clear_button: clear_button,
        line_check: line_check,
        word_check: word_check,
        case_check: case_check,
        sound_entry: sound_entry,
        sound_browse: sound_browse,
        warning: warning,
        refresh: refresh,
      }
      string_rows << row_info

      row_box.pack_start(number_label, :expand => false)
      row_box.pack_start(text_entry, :expand => false)
      row_box.pack_start(fore_entry, :expand => false)
      row_box.pack_start(back_entry, :expand => false)
      row_box.pack_start(fore_button || Gtk::Label.new('(n/a)'), :expand => false)
      row_box.pack_start(back_button || Gtk::Label.new('(n/a)'), :expand => false)
      row_box.pack_start(clear_button, :expand => false)
      row_box.pack_start(centered_string_cell.call(line_check, string_header_widths[7]), :expand => false)
      row_box.pack_start(centered_string_cell.call(word_check, string_header_widths[8]), :expand => false)
      row_box.pack_start(centered_string_cell.call(case_check, string_header_widths[9]), :expand => false)
      row_box.pack_start(sound_entry, :expand => false)
      row_box.pack_start(sound_browse, :expand => false)
      row_box.pack_start(warning, :expand => false)
      row_box.pack_start(delete_button, :expand => false)
      string_list.pack_start(row_box, :expand => false)

      fore_entry.signal_connect('changed') { refresh.call }
      back_entry.signal_connect('changed') { refresh.call }
      sound_entry.signal_connect('changed') { refresh.call }
      if fore_button
        fore_button.signal_connect('color-set') do
          fore_entry.text = rgba_to_hex(fore_button.rgba) if fore_button.respond_to?(:rgba)
          refresh.call
        end
      end
      if back_button
        back_button.signal_connect('color-set') do
          back_entry.text = rgba_to_hex(back_button.rgba) if back_button.respond_to?(:rgba)
          refresh.call
        end
      end
      clear_button.signal_connect('clicked') do
        back_entry.text = ''
        refresh.call
      end
      sound_browse.signal_connect('clicked') do
        selected = browse_path('Select sound file', sound_entry.text.to_s, :open, :sound)
        sound_entry.text = selected if selected
      end
      delete_button.signal_connect('clicked') do
        row_state[:deleted] = true
        row_box.destroy if row_box.respond_to?(:destroy)
      end
      refresh.call
    end

    save = Gtk::Button.new(:label => 'Save')
    defaults = Gtk::Button.new(:label => 'Defaults')
    clear = Gtk::Button.new(:label => 'Clear Data')
    copy_button = Gtk::Button.new(:label => 'Copy Highlights To Characters')
    bulk_button = Gtk::Button.new(:label => 'Add Names To Tags')
    import_button = Gtk::Button.new(:label => 'Import Existing Highlights')
    add_label = Gtk::Button.new(:label => 'Add Label')
    close = Gtk::Button.new(:label => 'Close')
    if copy_to_characters_disabled?(config)
      copy_button.sensitive = false if copy_button.respond_to?(:sensitive=)
      copy_button.tooltip_text = copy_to_characters_disabled_message if copy_button.respond_to?(:tooltip_text=)
    end

    save.signal_connect('clicked') { gtk_debug('Setup save clicked'); action = :save }
    clear.signal_connect('clicked') do
      gtk_debug 'Setup clear clicked'
      action = :clear
      close_gtk_window_now(window_ref, closed_ref)
    end
    copy_button.signal_connect('clicked') do
      gtk_debug('Setup copy clicked')
      if copy_to_characters_disabled?(config)
        ph_echo copy_to_characters_disabled_message
      else
        action = :copy_setup
      end
    end
    bulk_button.signal_connect('clicked') { gtk_debug('Setup bulk tags clicked'); action = :bulk_tags }
    import_button.signal_connect('clicked') { gtk_debug('Setup import existing clicked'); action = :import_existing }
    add_label_action = nil
    add_label.signal_connect('clicked') { add_label_action.call if add_label_action }
    close.signal_connect('clicked') do
      gtk_debug 'Setup close clicked'
      if (child = active_setup_child_window)
        gtk_debug "Setup close blocked while child window is open: #{child.class}"
        present_setup_window(child)
      else
        action = :close
        close_gtk_window_now(window_ref, closed_ref)
      end
    end
    defaults.signal_connect('clicked') do
      race_widgets.each do |race, info|
        info[:fore_entry].text = DEFAULT_RACE_COLORS[race][0]
        info[:back_entry].text = DEFAULT_RACE_COLORS[race][1]
        info[:refresh].call
      end
      profession_widgets.each do |profession, info|
        info[:fore_entry].text = DEFAULT_PROFESSION_COLORS[profession][0]
        info[:back_entry].text = DEFAULT_PROFESSION_COLORS[profession][1]
        info[:refresh].call
      end
      tag_rows.each do |info|
        next if info[:state][:deleted]

        tag = widget_text(info[:tag_entry]).to_s.strip
        next unless DEFAULT_TAG_COLORS[tag]

        info[:fore_entry].text = DEFAULT_TAG_COLORS[tag][0]
        info[:back_entry].text = DEFAULT_TAG_COLORS[tag][1]
        info[:refresh].call
      end
    end

    color_content = Gtk::Box.new(:horizontal, 12)
    name_panel = Gtk::Box.new(:vertical, 6)
    content = defined?(Gtk::Notebook) ? Gtk::Notebook.new : Gtk::Box.new(:vertical, 6)
    left = Gtk::Box.new(:vertical, 4)
    right = Gtk::Box.new(:vertical, 4)
    bottom = Gtk::Box.new(:vertical, 4)
    tag_container_for_refresh = bottom
    strings_panel = Gtk::Box.new(:vertical, 4)
    left.pack_start(Gtk::Label.new('Race colors'), :expand => false)
    left.pack_start(race_table, :expand => false)
    right.pack_start(Gtk::Label.new('Profession colors'), :expand => false)
    right.pack_start(profession_table, :expand => false)
    bottom.pack_start(Gtk::Label.new('Manual label override colors'), :expand => false)
    default_label_move_warning_label = Gtk::Label.new('')
    default_label_move_warning_label.xalign = 0 if default_label_move_warning_label.respond_to?(:xalign=)
    default_label_move_warning_label.line_wrap = true if default_label_move_warning_label.respond_to?(:line_wrap=)
    default_label_move_warning_label.selectable = true if default_label_move_warning_label.respond_to?(:selectable=)
    default_label_move_warning_label.no_show_all = true if default_label_move_warning_label.respond_to?(:no_show_all=)
    refresh_default_label_move_warning = proc do
      moves = collect_default_label_moves ? collect_default_label_moves.call : []
      move_signature = moves.empty? ? nil : default_label_moves_signature(moves)
      move_confirmed = !move_signature.to_s.empty? && default_label_move_confirmed_signature == move_signature
      text = default_label_moves_warning_text(moves, move_confirmed)
      if text.empty?
        default_label_move_warning_label.text = '' if default_label_move_warning_label.respond_to?(:text=)
        default_label_move_warning_label.hide if default_label_move_warning_label.respond_to?(:hide)
        confirmation_panel.hide if confirmation_panel && confirmation_panel.respond_to?(:hide)
        mode_box.show if mode_box && mode_box.respond_to?(:show)
        content.show if content && content.respond_to?(:show)
        save.label = 'Save' if save && save.respond_to?(:label=)
        confirmation_label.show if confirmation_label && confirmation_label.respond_to?(:show)
        close.label = 'Close' if close && close.respond_to?(:label=)
        [defaults, clear, copy_button, bulk_button, import_button].each { |button| button.sensitive = true if button && button.respond_to?(:sensitive=) }
        copy_button.sensitive = false if copy_button && copy_button.respond_to?(:sensitive=) && copy_to_characters_disabled?(config)
        refresh_mode_visibility.call if refresh_mode_visibility
      else
        if default_label_move_warning_label.respond_to?(:set_markup)
          default_label_move_warning_label.set_markup(default_label_moves_warning_markup(moves, move_confirmed))
        elsif default_label_move_warning_label.respond_to?(:text=)
          default_label_move_warning_label.text = text
        end
        save.label = (move_confirmed ? 'Save Again To Apply' : 'Save') if save && save.respond_to?(:label=)
        if move_confirmed
          close.label = 'Cancel' if close && close.respond_to?(:label=)
          default_label_move_warning_label.hide if default_label_move_warning_label.respond_to?(:hide)
          mode_box.hide if mode_box && mode_box.respond_to?(:hide)
          content.hide if content && content.respond_to?(:hide)
          if confirmation_label
            if confirmation_label.respond_to?(:set_markup)
              confirmation_label.set_markup(default_label_moves_warning_markup(moves, true))
            elsif confirmation_label.respond_to?(:text=)
              confirmation_label.text = text
            end
            confirmation_label.show if confirmation_label.respond_to?(:show)
          end
          confirmation_panel.show if confirmation_panel && confirmation_panel.respond_to?(:show)
          [defaults, clear, copy_button, bulk_button, import_button].each do |button|
            button.hide if button && button.respond_to?(:hide)
            button.sensitive = false if button && button.respond_to?(:sensitive=)
          end
          window.set_default_size(760, 210) if window.respond_to?(:set_default_size)
          window.resize(760, 210) if window.respond_to?(:resize)
        else
          close.label = 'Close' if close && close.respond_to?(:label=)
          confirmation_panel.hide if confirmation_panel && confirmation_panel.respond_to?(:hide)
          mode_box.show if mode_box && mode_box.respond_to?(:show)
          content.show if content && content.respond_to?(:show)
          [defaults, clear, copy_button, bulk_button, import_button].each do |button|
            button.show if button && button.respond_to?(:show)
            button.sensitive = true if button && button.respond_to?(:sensitive=)
          end
          copy_button.sensitive = false if copy_button && copy_button.respond_to?(:sensitive=) && copy_to_characters_disabled?(config)
          default_label_move_warning_label.show if default_label_move_warning_label.respond_to?(:show)
          refresh_mode_visibility.call if refresh_mode_visibility
        end
      end
    end
    bottom.pack_start(default_label_move_warning_label, :expand => false, :fill => true)
    bottom.pack_start(tag_header, :expand => false)

    tag_scroller = Gtk::ScrolledWindow.new
    tag_scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::AUTOMATIC) if tag_scroller.respond_to?(:set_policy)
    tag_scroller.set_size_request(590, 500) if tag_scroller.respond_to?(:set_size_request)
    if tag_scroller.respond_to?(:add_with_viewport)
      tag_scroller.add_with_viewport(tag_list)
    else
      tag_scroller.add(tag_list)
    end
    bottom.pack_start(tag_scroller, :expand => true, :fill => true)
    bottom.pack_start(add_label, :expand => false)

    string_count_label = Gtk::Label.new("Custom text highlights: #{string_all_entries.length}")
    string_page_label = Gtk::Label.new('')
    string_prev = Gtk::Button.new(:label => 'Previous')
    string_next = Gtk::Button.new(:label => 'Next')
    string_nav = Gtk::Box.new(:horizontal, 6)
    string_nav.pack_start(string_count_label, :expand => false)
    string_nav.pack_start(string_prev, :expand => false)
    string_nav.pack_start(string_page_label, :expand => false)
    string_nav.pack_start(string_next, :expand => false)
    strings_panel.pack_start(string_nav, :expand => false)
    strings_panel.pack_start(string_header, :expand => false)
    string_scroller = Gtk::ScrolledWindow.new
    string_scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::AUTOMATIC) if string_scroller.respond_to?(:set_policy)
    string_scroller.set_size_request(980, 360) if string_scroller.respond_to?(:set_size_request)
    if string_scroller.respond_to?(:add_with_viewport)
      string_scroller.add_with_viewport(string_list)
    else
      string_scroller.add(string_list)
    end
    add_string = Gtk::Button.new(:label => 'Add Text Highlight')
    strings_panel.pack_start(string_scroller, :expand => true, :fill => true)
    strings_panel.pack_start(add_string, :expand => false)

    row_to_string_entry = proc do |info|
      text = info[:text_entry].text.to_s.strip
      next nil if text.empty?

      {
        'text' => text,
        'color' => info[:fore_entry].text.to_s.strip.empty? ? '#FFFFFF' : info[:fore_entry].text.to_s.strip,
        'bgcolor' => info[:back_entry].text.to_s.strip,
        'line' => info[:line_check].respond_to?(:active?) && info[:line_check].active? ? 'y' : '',
        'case' => info[:case_check].respond_to?(:active?) && info[:case_check].active? ? 'y' : '',
        'word' => info[:word_check].respond_to?(:active?) && info[:word_check].active? ? 'y' : '',
        'sound' => info[:sound_entry].text.to_s.strip,
      }
    end

    persist_string_page = proc do
      start_index = string_page_index * string_page_size
      page_entries = []
      string_rows.each do |info|
        next if info[:state][:deleted]

        entry = row_to_string_entry.call(info)
        page_entries << entry if entry
      end
      string_all_entries[start_index, string_page_size] = page_entries
      string_all_entries.compact!
      max_page = string_all_entries.empty? ? 0 : ((string_all_entries.length - 1) / string_page_size)
      string_page_index = [[string_page_index, 0].max, max_page].min
    end

    render_string_page = proc do
      if string_list.respond_to?(:children)
        string_list.children.each { |child| string_list.remove(child) }
      end
      string_rows.clear
      total = string_all_entries.length
      max_page = total.zero? ? 0 : ((total - 1) / string_page_size)
      string_page_index = [[string_page_index, 0].max, max_page].min
      start_index = string_page_index * string_page_size
      page_entries = string_all_entries.slice(start_index, string_page_size) || []
      page_entries.each_with_index do |entry, index|
        add_string_row.call(entry, start_index + index + 1)
      end
      first = total.zero? ? 0 : start_index + 1
      last = total.zero? ? 0 : [start_index + page_entries.length, total].min
      string_count_label.text = "Custom text highlights: #{total}  showing #{first}-#{last}"
      string_page_label.text = "Page #{string_page_index + 1} of #{max_page + 1}"
      string_prev.sensitive = string_page_index.positive? if string_prev.respond_to?(:sensitive=)
      string_next.sensitive = string_page_index < max_page if string_next.respond_to?(:sensitive=)
      string_list.show_all if string_list.respond_to?(:show_all)
    end

    string_prev.signal_connect('clicked') do
      persist_string_page.call
      string_page_index -= 1
      render_string_page.call
    end
    string_next.signal_connect('clicked') do
      persist_string_page.call
      string_page_index += 1
      render_string_page.call
    end

    refresh_string_rows_from_config = proc do
      persist_string_page.call
      string_all_entries = string_highlights(config).map { |entry| normalize_string_highlight(entry) }.compact
      render_string_page.call
      strings_panel.show_all if strings_panel.respond_to?(:show_all)
    end
    render_string_page.call

    label_names_panel = Gtk::Box.new(:vertical, 6)
    selected_label_key = nil
    label_names_click_ranges = []
    label_names_body = Gtk::Box.new(:horizontal, 8)
    label_button_box = Gtk::Box.new(:vertical, 3)
    label_list_scroller = Gtk::ScrolledWindow.new
    label_list_scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::AUTOMATIC) if label_list_scroller.respond_to?(:set_policy)
    label_list_scroller.set_size_request(230, 340) if label_list_scroller.respond_to?(:set_size_request)
    if label_list_scroller.respond_to?(:add_with_viewport)
      label_list_scroller.add_with_viewport(label_button_box)
    elsif label_list_scroller.respond_to?(:add)
      label_list_scroller.add(label_button_box)
    end
    label_names_count = Gtk::Label.new('')
    label_names_count.xalign = 0 if label_names_count.respond_to?(:xalign=)
    label_names_text = Gtk::TextView.new
    label_names_text.editable = false if label_names_text.respond_to?(:editable=)
    label_names_text.cursor_visible = false if label_names_text.respond_to?(:cursor_visible=)
    label_names_text.can_focus = false if label_names_text.respond_to?(:can_focus=)
    label_names_text.monospace = true if label_names_text.respond_to?(:monospace=)
    label_names_text.left_margin = 6 if label_names_text.respond_to?(:left_margin=)
    label_names_text.right_margin = 6 if label_names_text.respond_to?(:right_margin=)
    label_names_text.pixels_above_lines = 1 if label_names_text.respond_to?(:pixels_above_lines=)
    label_names_text.tooltip_text = 'Click a name to look it up below.' if label_names_text.respond_to?(:tooltip_text=)
    label_names_text.override_font(Pango::FontDescription.new('Monospace 11')) if defined?(Pango::FontDescription) && label_names_text.respond_to?(:override_font)
    label_names_text.wrap_mode = Gtk::WrapMode::NONE if defined?(Gtk::WrapMode) && label_names_text.respond_to?(:wrap_mode=)
    label_names_scroller = Gtk::ScrolledWindow.new
    label_names_scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::ALWAYS) if label_names_scroller.respond_to?(:set_policy)
    label_names_scroller.set_size_request(720, 300) if label_names_scroller.respond_to?(:set_size_request)
    if label_names_scroller.respond_to?(:add)
      label_names_scroller.add(label_names_text)
    end
    lookup_entry = Gtk::Entry.new
    lookup_entry.width_chars = 24 if lookup_entry.respond_to?(:width_chars=)
    lookup_entry.tooltip_text = 'Type one character name to inspect what Highlight Manager has saved for them.' if lookup_entry.respond_to?(:tooltip_text=)
    lookup_button = Gtk::Button.new(:label => 'Lookup')
    note_entry = Gtk::Entry.new
    note_entry.width_chars = 54 if note_entry.respond_to?(:width_chars=)
    note_entry.max_length = NOTE_MAX_LENGTH if note_entry.respond_to?(:max_length=)
    note_entry.tooltip_text = "Add a local note to the looked-up name. Max #{NOTE_MAX_LENGTH} characters." if note_entry.respond_to?(:tooltip_text=)
    note_button = Gtk::Button.new(:label => 'Add Note')
    note_delete_entry = Gtk::Entry.new
    note_delete_entry.width_chars = 2 if note_delete_entry.respond_to?(:width_chars=)
    note_delete_entry.max_length = 2 if note_delete_entry.respond_to?(:max_length=)
    note_delete_entry.tooltip_text = 'Type the note number to delete.' if note_delete_entry.respond_to?(:tooltip_text=)
    note_delete_button = Gtk::Button.new(:label => 'Delete')
    note_status = Gtk::Label.new('')
    note_status.xalign = 0 if note_status.respond_to?(:xalign=)
    note_status.line_wrap = true if note_status.respond_to?(:line_wrap=)
    lookup_details = Gtk::TextView.new
    lookup_details.editable = false if lookup_details.respond_to?(:editable=)
    lookup_details.cursor_visible = false if lookup_details.respond_to?(:cursor_visible=)
    lookup_details.monospace = true if lookup_details.respond_to?(:monospace=)
    lookup_details.wrap_mode = Gtk::WrapMode::WORD if defined?(Gtk::WrapMode) && lookup_details.respond_to?(:wrap_mode=)
    lookup_details.override_font(Pango::FontDescription.new('Monospace 10')) if defined?(Pango::FontDescription) && lookup_details.respond_to?(:override_font)
    lookup_scroller = Gtk::ScrolledWindow.new
    lookup_scroller.set_policy(Gtk::PolicyType::AUTOMATIC, Gtk::PolicyType::ALWAYS) if lookup_scroller.respond_to?(:set_policy)
    lookup_scroller.set_size_request(720, 165) if lookup_scroller.respond_to?(:set_size_request)
    lookup_scroller.add(lookup_details) if lookup_scroller.respond_to?(:add)
    set_lookup_details = proc do |text|
      next unless gtk_window_open?(window_ref)

      if lookup_details.buffer.respond_to?(:text=)
        lookup_details.buffer.text = text
      else
        lookup_details.buffer.set_text(text)
      end
    end
    run_lookup = proc do
      set_lookup_details.call(lookup_character_report(config, lookup_entry.text.to_s))
    end
    run_lookup_for_name = proc do |name, clear_status = true|
      normalized = normalize_person_name(name)
      next false unless normalized

      lookup_entry.text = normalized if lookup_entry.respond_to?(:text=)
      run_lookup.call
      note_status.text = '' if clear_status && note_status.respond_to?(:text=)
      true
    end
    add_lookup_note = proc do
      name = normalize_person_name(lookup_entry.text.to_s)
      text = note_entry.text.to_s.strip.gsub(/\s+/, ' ')
      unless name
        note_status.text = 'Look up or click a name first.' if note_status.respond_to?(:text=)
        next
      end
      if text.empty?
        note_status.text = 'Type a note first.' if note_status.respond_to?(:text=)
        next
      end

      if handle_note_command(config, ['add', name, text], ['add', name.downcase, text.downcase])
        note_entry.text = '' if note_entry.respond_to?(:text=)
        note_status.text = "Added note for #{name}." if note_status.respond_to?(:text=)
      else
        note_status.text = 'Note was not saved. See the story window for details.' if note_status.respond_to?(:text=)
      end
      run_lookup_for_name.call(name, false)
    end
    delete_lookup_note = proc do
      name = normalize_person_name(lookup_entry.text.to_s)
      index_text = note_delete_entry.text.to_s.strip
      unless name
        note_status.text = 'Look up or click a name first.' if note_status.respond_to?(:text=)
        next
      end
      if index_text.empty?
        note_status.text = 'Type the note number to delete.' if note_status.respond_to?(:text=)
        next
      end

      if handle_note_command(config, ['remove', name, index_text], ['remove', name.downcase, index_text.downcase])
        note_delete_entry.text = '' if note_delete_entry.respond_to?(:text=)
        note_status.text = "Deleted note #{index_text} for #{name}." if note_status.respond_to?(:text=)
      else
        note_status.text = 'Note was not deleted. See the story window for details.' if note_status.respond_to?(:text=)
      end
      run_lookup_for_name.call(name, false)
    end
    lookup_button.signal_connect('clicked') { run_lookup.call }
    lookup_entry.signal_connect('activate') { run_lookup.call } if lookup_entry.respond_to?(:signal_connect)
    note_button.signal_connect('clicked') { add_lookup_note.call }
    note_entry.signal_connect('activate') { add_lookup_note.call } if note_entry.respond_to?(:signal_connect)
    note_delete_button.signal_connect('clicked') { delete_lookup_note.call }
    note_delete_entry.signal_connect('activate') { delete_lookup_note.call } if note_delete_entry.respond_to?(:signal_connect)
    if label_names_text.respond_to?(:signal_connect)
      label_names_text.signal_connect('realize') { set_clickable_text_view_cursor(label_names_text) }
      label_names_text.signal_connect('button-release-event') do |text_view, event|
        begin
          button = event.respond_to?(:button) ? event.button.to_i : 1
          next false unless button == 1

          x, y = text_view.window_to_buffer_coords(Gtk::TextWindowType::WIDGET, event.x, event.y)
          clicked_iter = text_view.get_iter_at_location(x, y)
          offset = clicked_iter.offset
          clicked = label_names_click_ranges.find { |range| offset >= range[:start].to_i && offset < range[:end].to_i }
          if clicked && run_lookup_for_name.call(clicked[:name])
            next true
          end
        rescue => error
          gtk_debug "Label Names click lookup failed: #{error.class}: #{error.message}"
        end
        false
      end
    end
    lookup_box = Gtk::Box.new(:horizontal, 6)
    lookup_box.pack_start(Gtk::Label.new('Name lookup:'), :expand => false)
    lookup_box.pack_start(lookup_entry, :expand => false)
    lookup_box.pack_start(lookup_button, :expand => false)
    note_box = Gtk::Box.new(:horizontal, 6)
    note_box.pack_start(Gtk::Label.new('Note:'), :expand => false)
    note_box.pack_start(note_entry, :expand => true, :fill => true)
    note_box.pack_start(note_button, :expand => false)
    note_box.pack_start(Gtk::Label.new('Delete #:'), :expand => false)
    note_box.pack_start(note_delete_entry, :expand => false)
    note_box.pack_start(note_delete_button, :expand => false)
    set_lookup_details.call("Type a character name above, then click Lookup.\n")
    label_names_right = Gtk::Box.new(:vertical, 4)
    label_names_right.pack_start(label_names_count, :expand => false)
    label_names_right.pack_start(label_names_scroller, :expand => true, :fill => true)
    label_names_right.pack_start(lookup_box, :expand => false)
    label_names_right.pack_start(note_box, :expand => false, :fill => true)
    label_names_right.pack_start(note_status, :expand => false, :fill => true)
    label_names_right.pack_start(Gtk::Label.new('Character details:'), :expand => false)
    label_names_right.pack_start(lookup_scroller, :expand => false, :fill => true)
    label_names_body.pack_start(label_list_scroller, :expand => false, :fill => true)
    label_names_body.pack_start(label_names_right, :expand => true, :fill => true)
    label_names_panel.pack_start(Gtk::Label.new('Pick a label to view the names saved under it.'), :expand => false)
    label_names_panel.pack_start(label_names_body, :expand => true, :fill => true)
    label_names_refreshing = false
    update_label_names_text = proc do
      items = label_name_items(config).select { |item| item[:kind] != 'header' }
      current = items.find { |item| item[:key] == selected_label_key } || items.first
      selected_label_key = current[:key] if current
      if current
        label_names_count.text = "#{current[:title]}: #{current[:count]} name#{current[:count] == 1 ? '' : 's'}" if label_names_count.respond_to?(:text=)
        width = if label_names_scroller.respond_to?(:allocated_width)
                  label_names_scroller.allocated_width
                elsif label_names_scroller.respond_to?(:allocation) && label_names_scroller.allocation
                  label_names_scroller.allocation.width
                else
                  720
                end
        width = 720 if width.to_i < 200
        columns = label_name_columns_for_width(width, current[:names])
        text, label_names_click_ranges = label_names_report_and_ranges_for_item(current, columns)
      else
        label_names_count.text = 'Names: 0' if label_names_count.respond_to?(:text=)
        text = "No labels found.\n"
        label_names_click_ranges = []
      end
      if label_names_text.buffer.respond_to?(:text=)
        label_names_text.buffer.text = text
      else
        label_names_text.buffer.set_text(text)
      end
      apply_label_name_click_styles(label_names_text, label_names_click_ranges)
      set_clickable_text_view_cursor(label_names_text)
    end
    refresh_label_names_text = proc do
      unless label_names_refreshing
        label_names_refreshing = true
        begin
          if gtk_window_open?(window_ref)
            items = label_name_items(config)
            selectable_items = items.select { |item| item[:kind] != 'header' }
            current = selectable_items.find { |item| item[:key] == selected_label_key } || selectable_items.first
            selected_label_key = current[:key] if current
            if label_button_box.respond_to?(:children)
              label_button_box.children.each { |child| label_button_box.remove(child) }
            end
            items.each do |item|
              if item[:kind] == 'header'
                header = Gtk::Label.new(item[:title])
                begin
                  header.set_markup("<span weight=\"bold\" size=\"large\">#{item[:title]}</span>") if header.respond_to?(:set_markup)
                rescue
                  header.text = item[:title] if header.respond_to?(:text=)
                end
                header.xalign = 0.5 if header.respond_to?(:xalign=)
                header.justify = Gtk::Justification::CENTER if defined?(Gtk::Justification) && header.respond_to?(:justify=)
                header.margin_top = 6 if header.respond_to?(:margin_top=)
                header.margin_bottom = 2 if header.respond_to?(:margin_bottom=)
                header.set_size_request(220, 24) if header.respond_to?(:set_size_request)
                label_button_box.pack_start(header, :expand => false)
                next
              end
              button_item = item
              button = Gtk::Button.new(:label => "#{button_item[:title]} (#{button_item[:count]})")
              button.set_size_request(220, -1) if button.respond_to?(:set_size_request)
              button.tooltip_text = "Show names saved under #{button_item[:title]}" if button.respond_to?(:tooltip_text=)
              button.signal_connect('clicked') do
                selected_label_key = button_item[:key]
                update_label_names_text.call
              end
              label_button_box.pack_start(button, :expand => false)
            end
            label_button_box.show_all if label_button_box.respond_to?(:show_all)
            update_label_names_text.call
          else
            gtk_debug 'Label Names refresh skipped; setup window was closed'
          end
        ensure
          label_names_refreshing = false
        end
      end
    end
    if label_names_scroller.respond_to?(:signal_connect)
      label_names_scroller.signal_connect('size-allocate') do
        update_label_names_text.call if gtk_window_open?(window_ref)
      end
    end

    color_content.pack_start(left, :expand => false)
    color_content.pack_start(right, :expand => false)
    color_content.pack_start(bottom, :expand => true, :fill => true)
    name_panel.pack_start(color_content, :expand => true, :fill => true)
    using_notebook = content.is_a?(Gtk::Notebook)
    if using_notebook
      content.append_page(name_panel, Gtk::Label.new('Names'))
      content.append_page(strings_panel, Gtk::Label.new('Custom Text'))
      content.append_page(label_names_panel, Gtk::Label.new('Label Names'))
    else
      content.pack_start(name_panel, :expand => true, :fill => true)
      content.pack_start(strings_panel, :expand => true, :fill => true)
      content.pack_start(label_names_panel, :expand => true, :fill => true)
    end

    refresh_mode_visibility = proc do |page_override = nil|
      selected_mode = mode_combo && mode_combo.respond_to?(:active_id) ? mode_combo.active_id.to_s : selected_mode
      selected_mode = 'profession' unless %w[profession race race_profession custom].include?(selected_mode)
      current_page = if page_override
                       page_override.to_i
                     elsif content.respond_to?(:current_page)
                       content.current_page.to_i
                     elsif content.respond_to?(:page)
                       content.page.to_i
                     else
                       0
                     end
      show_race_background = selected_mode == 'race'
      show_profession_foreground = selected_mode == 'profession'
      if using_notebook && current_page == 1
        window.set_default_size(1060, 640) if window.respond_to?(:set_default_size)
        window.resize(1060, 640) if window.respond_to?(:resize)
        strings_panel.show_all if strings_panel.respond_to?(:show_all)
      elsif using_notebook && current_page == 2
        window.set_default_size(900, 520) if window.respond_to?(:set_default_size)
        window.resize(900, 520) if window.respond_to?(:resize)
        label_names_panel.show_all if label_names_panel.respond_to?(:show_all)
      else
        case selected_mode
        when 'race'
          tag_scroller.set_size_request(590, 500) if tag_scroller.respond_to?(:set_size_request)
          window.set_default_size(960, 620) if window.respond_to?(:set_default_size)
          window.resize(960, 620) if window.respond_to?(:resize)
          left.show_all if left.respond_to?(:show_all)
          right.hide if right.respond_to?(:hide)
          bottom.show_all if bottom.respond_to?(:show_all)
          strings_panel.hide if !using_notebook && strings_panel.respond_to?(:hide)
        when 'race_profession'
          tag_scroller.set_size_request(590, 500) if tag_scroller.respond_to?(:set_size_request)
          window.set_default_size(1080, 600) if window.respond_to?(:set_default_size)
          window.resize(1080, 600) if window.respond_to?(:resize)
          left.show_all if left.respond_to?(:show_all)
          right.show_all if right.respond_to?(:show_all)
          bottom.show_all if bottom.respond_to?(:show_all)
          strings_panel.hide if !using_notebook && strings_panel.respond_to?(:hide)
        when 'custom'
          tag_scroller.set_size_request(590, 180) if tag_scroller.respond_to?(:set_size_request)
          window.set_default_size(780, 420) if window.respond_to?(:set_default_size)
          window.resize(780, 420) if window.respond_to?(:resize)
          left.hide if left.respond_to?(:hide)
          right.hide if right.respond_to?(:hide)
          bottom.show_all if bottom.respond_to?(:show_all)
          strings_panel.hide if !using_notebook && strings_panel.respond_to?(:hide)
        else
          tag_scroller.set_size_request(590, 500) if tag_scroller.respond_to?(:set_size_request)
          window.set_default_size(960, 620) if window.respond_to?(:set_default_size)
          window.resize(960, 620) if window.respond_to?(:resize)
          left.hide if left.respond_to?(:hide)
          right.show_all if right.respond_to?(:show_all)
          bottom.show_all if bottom.respond_to?(:show_all)
          strings_panel.hide if !using_notebook && strings_panel.respond_to?(:hide)
        end
      end
      bottom.show_all if bottom.respond_to?(:show_all)
      [race_headers[2], race_headers[4], race_headers[5]].compact.each do |widget|
        show_race_background ? widget.show : widget.hide
      end
      race_widgets.each_value do |info|
        info[:back_widgets].each { |widget| show_race_background ? widget.show : widget.hide }
        info[:refresh].call
      end
      [profession_headers[1], profession_headers[3]].compact.each do |widget|
        show_profession_foreground ? widget.show : widget.hide
      end
      profession_widgets.each_value do |info|
        info[:fore_widgets].each { |widget| show_profession_foreground ? widget.show : widget.hide }
        info[:refresh].call
      end
    end
    add_label_action = proc do
      add_tag_row.call('', ['#FFFFFF', '#000000'], false)
      bottom.show_all if bottom.respond_to?(:show_all)
      refresh_default_label_move_warning.call if refresh_default_label_move_warning
      refresh_mode_visibility.call
    end
    add_string_action = proc do
      persist_string_page.call
      string_all_entries << { 'text' => '', 'color' => '#FFFFFF', 'bgcolor' => '', 'case' => 'y' }
      string_page_index = string_all_entries.empty? ? 0 : ((string_all_entries.length - 1) / string_page_size)
      render_string_page.call
      strings_panel.show_all if strings_panel.respond_to?(:show_all)
      refresh_mode_visibility.call
    end
    add_string.signal_connect('clicked') { add_string_action.call }
    mode_combo.signal_connect('changed') { refresh_mode_visibility.call } if mode_combo
    if using_notebook && content.respond_to?(:signal_connect)
      content.signal_connect('switch-page') do |_notebook, _page, page_num|
        refresh_mode_visibility.call(page_num)
      end
    end

    button_box = Gtk::Box.new(:horizontal, 6)
    button_box.pack_start(save, :expand => false)
    button_box.pack_start(defaults, :expand => false)
    button_box.pack_start(clear, :expand => false)
    button_box.pack_start(copy_button, :expand => false)
    button_box.pack_start(bulk_button, :expand => false)
    button_box.pack_start(import_button, :expand => false)
    button_box.pack_start(close, :expand => false)

    confirmation_panel = Gtk::Box.new(:vertical, 12)
    confirmation_panel.set_size_request(720, 120) if confirmation_panel.respond_to?(:set_size_request)
    if confirmation_panel.respond_to?(:margin=)
      confirmation_panel.margin = 12
    else
      confirmation_panel.margin_top = 12 if confirmation_panel.respond_to?(:margin_top=)
      confirmation_panel.margin_bottom = 8 if confirmation_panel.respond_to?(:margin_bottom=)
      confirmation_panel.margin_left = 24 if confirmation_panel.respond_to?(:margin_left=)
      confirmation_panel.margin_right = 24 if confirmation_panel.respond_to?(:margin_right=)
    end
    confirmation_label = Gtk::Label.new('')
    confirmation_label.xalign = 0.5 if confirmation_label.respond_to?(:xalign=)
    confirmation_label.yalign = 0.0 if confirmation_label.respond_to?(:yalign=)
    confirmation_label.line_wrap = true if confirmation_label.respond_to?(:line_wrap=)
    confirmation_label.selectable = true if confirmation_label.respond_to?(:selectable=)
    confirmation_note = Gtk::Label.new('This will change saved character data. Click Save Again To Apply to confirm, or Close to cancel.')
    confirmation_note.xalign = 0.5 if confirmation_note.respond_to?(:xalign=)
    confirmation_note.line_wrap = true if confirmation_note.respond_to?(:line_wrap=)
    confirmation_panel.pack_start(confirmation_label, :expand => false, :fill => true)
    confirmation_panel.pack_start(confirmation_note, :expand => false, :fill => true)
    confirmation_panel.hide if confirmation_panel.respond_to?(:hide)

    vbox = Gtk::Box.new(:vertical, 6)
    vbox.pack_start(mode_box, :expand => false, :fill => false, :padding => 0)
    vbox.pack_start(content, :expand => true, :fill => true, :padding => 0)
    vbox.pack_start(confirmation_panel, :expand => false, :fill => true, :padding => 0)
    vbox.pack_start(button_box, :expand => false, :fill => false, :padding => 0)

      window.signal_connect('delete_event') do
        gtk_debug 'Setup delete_event'
        if (child = active_setup_child_window)
          gtk_debug "Setup delete blocked while child window is open: #{child.class}"
          present_setup_window(child)
          true
        else
          action ||= :close
          gtk_debug 'Setup delete_event handled by script close'
          close_gtk_window_now(window_ref, closed_ref)
          true
        end
      end
      window.signal_connect('destroy') do
        gtk_debug 'Setup destroy'
        forget_gtk_window(window_ref[:name], window_ref, closed_ref)
      end
      window.add(vbox)
      present_setup_window(window)
      refresh_label_names_text.call if refresh_label_names_text
      refresh_default_label_move_warning.call if refresh_default_label_move_warning
      refresh_mode_visibility.call
    rescue => error
      setup_error = error
      action = :error
    end
  }

  loop do
    wait_until { action }
    requested_action = action
    gtk_debug "Setup loop action=#{requested_action.inspect}"
    action = nil

    if requested_action == :error
      ph_echo "GTK setup failed: #{setup_error.class}: #{setup_error.message}"
      break
    elsif requested_action == :copy_setup
      show_copy_settings_window(config)
    elsif requested_action == :bulk_tags
      show_bulk_tag_window(config)
      config = load_config
      refresh_tags = refresh_tag_rows_from_config
      if refresh_tags && gtk_window_open?(window_ref)
        Gtk.queue do
          if gtk_window_open?(window_ref)
            refresh_tags.call
            refresh_label_names_text.call if refresh_label_names_text
            refresh_default_label_move_warning.call if refresh_default_label_move_warning
          else
            gtk_debug 'Setup refresh after bulk tags skipped; setup window was already closed'
          end
        end if defined?(Gtk)
        gtk_debug 'Setup refreshed after bulk tags; waiting for next action'
      else
        gtk_debug 'Setup refresh after bulk tags skipped; refresh proc was not ready or setup window was closed'
      end
      next
    elsif requested_action == :import_existing
      if show_import_existing_window(config)
        config = load_config
        $highlight_manager_config = config
        $highlight_manager_character_data = load_character_data(config)
        refresh_tags = refresh_tag_rows_from_config
        refresh_strings = refresh_string_rows_from_config
        if gtk_window_open?(window_ref)
          Gtk.queue do
            if gtk_window_open?(window_ref)
              refresh_tags.call if refresh_tags
              refresh_strings.call if refresh_strings
              refresh_label_names_text.call if refresh_label_names_text
              refresh_default_label_move_warning.call if refresh_default_label_move_warning
            else
              gtk_debug 'Setup refresh after import skipped; setup window was already closed'
            end
          end if defined?(Gtk)
        else
          gtk_debug 'Setup refresh after import skipped; setup window was closed'
        end
        gtk_debug 'Setup refreshed after importing existing highlights; waiting for next action'
        next
      end
    elsif requested_action == :data_folder
      begin
        new_folder, copied_files = apply_data_folder_change(config, requested_data_folder)
        config = load_config
        $highlight_manager_config = config
        gtk_debug "Setup data folder saved #{new_folder.inspect}"
        ph_echo "Highlight Manager data folder set to: #{new_folder}"
        unless copied_files.empty?
          ph_echo "Copied existing Highlight Manager data file(s) to the new folder: #{copied_files.join(', ')}"
        end
        ph_echo 'Future import files, character data, debug reports, and command transcripts will use that folder.'
        Gtk.queue { data_folder_entry.text = configured_data_folder(config) if data_folder_entry && gtk_window_open?(window_ref) } if defined?(Gtk)
      rescue => error
        ph_echo "Could not set data folder: #{error.message}"
        Gtk.queue { data_folder_entry.text = configured_data_folder(config) if data_folder_entry && gtk_window_open?(window_ref) } if defined?(Gtk)
      end
      next
    elsif requested_action == :clear
      config['seen_names'] = {}
      config['tagged_names'] = {}
      $highlight_manager_character_data = default_character_data
      save_character_data($highlight_manager_character_data)
      config['disabled_tags'] = []
      config['profession_changes'] = []
      config['tag_colors'] = DEFAULT_TAG_COLORS.transform_values(&:dup)
      save_config(config)
      [default_export_path('wrayth'), legacy_wizard_export_path(config)].each do |path|
        File.delete(path) if File.exist?(path)
      end
      ph_echo 'Cleared character data, custom labels, profession changes, and default export files if they existed.'
      break
    elsif requested_action == :save
      race_update = {}
      profession_update = {}
      tag_update = {}
      deleted_label_names = []
      default_label_moves = []
      string_update = []
      save_error = false
      persist_string_page.call if persist_string_page
      race_widgets.each do |race, info|
        fore = normalize_hex(info[:fore_entry].text)
        back = normalize_background(info[:back_entry].text, nil)
        unless fore && !back.nil?
          ph_echo "Invalid race colors for #{race}; use #RRGGBB or leave background blank for transparent."
          save_error = true
          next
        end
        race_update[race] = [fore, back]
      end
      profession_widgets.each do |profession, info|
        fore = normalize_hex(info[:fore_entry].text)
        back = normalize_background(info[:back_entry].text, nil)
        unless fore && !back.nil?
          ph_echo "Invalid profession colors for #{profession}; use #RRGGBB or leave background blank for transparent."
          save_error = true
          next
        end
        profession_update[profession] = [fore, back]
      end
      tag_rows.each do |info|
        if info[:state][:deleted]
          deleted_label = info[:original_tag].to_s.strip
          deleted_label = normalize_tag_name(deleted_label) || deleted_label
          unless deleted_label.empty? || DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == deleted_label.downcase }
            deleted_label_names << deleted_label
          end
          next
        end

        raw_tag = widget_text(info[:tag_entry]).to_s.strip
        tag = normalize_tag_name(raw_tag)
        next if tag.to_s.empty?

        original_tag = info[:original_tag].to_s.strip
        original_tag = normalize_tag_name(original_tag) || original_tag
        if !info[:built_in] && !original_tag.empty? && original_tag.downcase != tag.downcase
          default_target = default_label_move_target(config, tag)
          if default_target
            source_fore = normalize_hex(info[:fore_entry].text)
            source_back = normalize_background(info[:back_entry].text, nil)
            default_label_moves << {
              source: original_tag,
              target_kind: default_target[0],
              target: default_target[1],
              count: tagged_name_count(original_tag),
              source_colors: source_fore && !source_back.nil? ? [source_fore, source_back] : nil,
            }
            next
          end
        end

        fore = normalize_hex(info[:fore_entry].text)
        back = normalize_background(info[:back_entry].text, nil)
        unless fore && !back.nil?
          ph_echo "Invalid manual label colors for #{raw_tag}; use #RRGGBB or leave background blank for transparent."
          save_error = true
          next
        end
        unless valid_tag_name?(tag)
          ph_echo "Invalid manual label #{raw_tag.inspect}; use letters, numbers, spaces, underscores, or dashes."
          save_error = true
          next
        end
        if automatic_category_name?(tag)
          ph_echo "Skipped manual label color row #{tag}; #{tag} is a profession or race category."
          next
        end
        existing_tag = (tag_update.keys + DEFAULT_TAG_COLORS.keys).find { |known| known.downcase == tag.downcase }
        tag = existing_tag || tag
        set_widget_text(info[:tag_entry], tag)
        tag_update[tag] = [fore, back]
      end
      string_all_entries.each do |entry|
        text = entry['text'].to_s.strip
        next if text.empty?

        fore = entry['color'].to_s.strip
        back = entry['bgcolor'].to_s.strip
        unless valid_string_color_value?(fore) && valid_string_color_value?(back, true)
          ph_echo "Invalid custom text highlight colors for #{text.inspect}; use #RRGGBB, blank background, or leave imported Wrayth palette values unchanged."
          save_error = true
          next
        end
        string_update << {
          'text' => text,
          'color' => fore.empty? ? '#FFFFFF' : fore,
          'bgcolor' => back,
          'line' => entry['line'].to_s == 'y' ? 'y' : '',
          'case' => entry['case'].to_s == 'y' ? 'y' : '',
          'word' => entry['word'].to_s == 'y' ? 'y' : '',
          'sound' => entry['sound'].to_s.strip,
        }
      end

      if !save_error && race_update.length == race_widgets.length && profession_update.length == profession_widgets.length
        unless default_label_moves.empty?
          move_signature = default_label_moves_signature(default_label_moves)
          if default_label_move_confirmed_signature != move_signature
            default_label_move_confirmed_signature = move_signature
            ph_echo ''
            ph_echo 'Label move confirmation needed before saving.'
            ph_echo default_label_moves_warning_text(default_label_moves)
            ph_echo ''
            Gtk.queue { refresh_default_label_move_warning.call if refresh_default_label_move_warning && gtk_window_open?(window_ref) } if defined?(Gtk)
            next
          end
        end

        if default_label_moves.empty?
          default_label_move_confirmed_signature = nil
        elsif default_label_move_confirmed_signature != default_label_moves_signature(default_label_moves)
          next
        end

        new_data_folder = data_folder_entry ? data_folder_entry.text.to_s.strip : configured_data_folder(config)
        begin
          new_data_folder, copied_files = apply_data_folder_change(config, new_data_folder)
        rescue => error
          ph_echo "Invalid data folder #{new_data_folder.inspect}: #{error.message}"
          ph_echo 'Colors were not saved because the data folder could not be prepared. The setup window is still open.'
          next
        end
        selected_mode = mode_combo && mode_combo.respond_to?(:active_id) ? mode_combo.active_id.to_s : selected_mode
        selected_mode = 'profession' unless HIGHLIGHT_MODES.include?(selected_mode)
        default_label_moves.each do |move|
          source_colors = move[:source_colors]
          next unless source_colors.is_a?(Array)

          case move[:target_kind].to_s
          when 'profession'
            target = move[:target].to_s
            if profession_update[target].is_a?(Array) && profession_update[target] == source_colors
              profession_update[target] = (DEFAULT_PROFESSION_COLORS[target] || profession_colors(config)[target]).dup
            end
          when 'race'
            target = move[:target].to_s
            if race_update[target].is_a?(Array) && race_update[target] == source_colors
              race_update[target] = (DEFAULT_RACE_COLORS[target] || race_colors(config)[target]).dup
            end
          end
        end
        tag_update.delete_if { |tag, _pair| automatic_category_name?(tag) }
        config['mode'] = selected_mode
        config['data_folder'] = new_data_folder
        config['race_colors'] = race_update
        config['profession_colors'] = profession_update
        config['tag_colors'] = tag_update
        config['string_highlights'] = string_update
        config['disabled_tags'] ||= []
        tag_update.keys.each do |tag|
          config['disabled_tags'].delete_if { |disabled| disabled.to_s.downcase == tag.to_s.downcase }
        end
        move_results = []
        default_label_moves.each do |move|
          move_results << move_label_members_to_target(config, move[:source], move[:target_kind], move[:target])
        end
        removed_label_counts = clear_deleted_label_assignments(config, deleted_label_names)
        save_config(config)
        ph_echo "Saved Highlight Manager mode, colors, manual labels, and #{string_highlights(config).length} custom text highlight(s) to #{CONFIG_PATH}"
        move_results.each do |result|
          next if result[:moved].to_i <= 0

          ph_echo "Moved #{result[:moved]} name(s) from label #{result[:source]} to #{label_move_target_description(result[:target_kind], result[:target])}."
          gtk_debug "Removed empty label #{result[:source]} after default-label rename." if result[:removed_source_label]
        end
        deleted_label_names = deleted_label_names.uniq
        unless deleted_label_names.empty?
          total_cleared = removed_label_counts.values.inject(0) { |sum, count| sum + count.to_i }
          ph_echo "Deleted #{deleted_label_names.length} label(s) and cleared them from #{total_cleared} saved name(s)."
          deleted_label_names.each do |label|
            gtk_debug "Deleted label #{label} and cleared it from #{removed_label_counts[label].to_i} saved name(s)."
          end
        end
        unless copied_files.empty?
          ph_echo "Copied existing Highlight Manager data file(s) to the new folder: #{copied_files.join(', ')}"
        end
        ph_echo "Highlight Manager data folder: #{configured_data_folder(config)}"
        begin
          saved_config = load_config
          saved_export_format = export_format_from_args([], saved_config)
          saved_export_path = File.join(configured_data_folder(saved_config), IMPORT_XML_FILENAME)
          rewrite_current_export(saved_config, saved_export_path, saved_export_format, true)
        rescue => error
          ph_echo "Saved settings, but could not rewrite the import file: #{error.message}"
        end
        break
      else
        ph_echo 'Colors were not saved because one or more rows were invalid. The setup window is still open.'
      end
    else
      ph_echo 'Closed color configuration without saving unsaved color or mode changes.'
      break
    end
  end

  close_setup_window(window_ref, closed_ref)
end

def show_export_instructions(path, format, has_profession_changes = false)
  if warlock_instruction_context?(format)
    ph_echo ''
    ph_echo 'Warlock import'
    ph_echo ''
    ph_echo "  File: #{path}"
    ph_echo ''
    ph_echo '  1. Open Warlock Settings -> General.'
    ph_echo '  2. Select Global for all Warlock characters, or select one character.'
    ph_echo '  3. Click "Import settings from Wrayth settings file".'
    ph_echo '  4. Choose the file above.'
    ph_echo ''
    ph_echo '  Warlock should report imported highlights and names.'
    return
  end

  name_option = 'import all'
  custom_option = 'import all'

  ph_echo ''
  ph_echo 'Import instructions'
  ph_echo ''
  ph_echo "  File: #{path}"
  ph_echo ''
  ph_echo '  Open: Options -> Settings -> Import'
  ph_echo ''
  ph_echo '  Set these import options:'
  ph_echo "    Name highlights       #{name_option}  player names: profession, race, and labels"
  ph_echo "    Custom highlights     #{custom_option}  text/phrase strings and legend labels"
  ph_echo '    Everything else       don''t import'
  ph_echo ''
  ph_echo '  Use import all for Highlight Manager sections so mode, color, label,'
  ph_echo '  and custom string changes update existing entries.'
  ph_echo ''
  ph_echo '  Import option meanings:'
  ph_echo '    only import new       add missing entries; leave existing entries alone'
  ph_echo '    import all            add missing entries and update matching entries'
  ph_echo '    clear and import all  wipe that selected section first, then import'
  ph_echo ''
  ph_echo '  Leave Macros, Scripts, Variables, Window Configuration, and Palette/Colors'
  ph_echo '  set to don''t import.'
  ph_echo ''
  ph_echo '  Click Import.'
end

def copy_arg_value(raw_args, key)
  prefix = "#{key}="
  index = raw_args.index { |arg| arg.downcase.start_with?(prefix) }
  return nil unless index

  value_parts = [raw_args[index].split('=', 2)[1].to_s]
  raw_args[(index + 1)..-1].to_a.each do |part|
    break if part.to_s =~ /\A[a-zA-Z_][a-zA-Z0-9_-]*=/
    break if %w[setup status confirm run replace skip clear].include?(part.to_s.downcase)

    value_parts << part.to_s
  end
  value_parts.join(' ').strip
end

def copy_detect_source(raw_args = [])
  requested = copy_arg_value(raw_args, 'source') || copy_arg_value(raw_args, 'src')
  return requested if requested && requested.length > 0
  default_source = copy_default_source($highlight_manager_config || {})
  return default_source if File.exist?(default_source)
  legacy_source = COPY_LEGACY_SOURCES.find { |path| File.exist?(path) }
  return legacy_source if legacy_source

  default_source
end

def copy_detect_target(raw_args = [])
  requested = copy_arg_value(raw_args, 'target') || copy_arg_value(raw_args, 'dir')
  return requested if requested && requested.length > 0

  COPY_DEFAULT_TARGET
end

def copy_duplicate_mode(raw_args, copy_settings)
  requested = copy_arg_value(raw_args, 'duplicates') || copy_arg_value(raw_args, 'duplicate') || copy_arg_value(raw_args, 'mode')
  mode = (requested || copy_settings['duplicates'] || 'replace').to_s.downcase
  raise "Duplicate mode must be one of: #{COPY_DUPLICATE_MODES.join(', ')}" unless COPY_DUPLICATE_MODES.include?(mode)

  mode
end

def read_frontend_xml_text(path)
  bytes = File.binread(path)
  text = bytes.dup.force_encoding(Encoding::UTF_8)

  unless text.valid_encoding?
    begin
      text = bytes.encode(Encoding::UTF_8, Encoding.find('Windows-1252'), invalid: :replace, undef: :replace, replace: ' ')
    rescue
      text = bytes.dup.force_encoding(Encoding::UTF_8).scrub(' ')
    end
  end

  text = text.scrub(' ')
  text.delete!("\u0000-\u0008\u000B\u000C\u000E-\u001F")
  text
end

def copy_load_xml(path)
  doc = REXML::Document.new(read_frontend_xml_text(path))
  raise "No XML root found in #{path}" unless doc.root

  doc
end

def copy_section(doc, name)
  doc.root.elements[name]
end

def copy_ensure_section(doc, name)
  existing = copy_section(doc, name)
  return existing if existing

  node = doc.root.add_element(name)
  node.add_attribute('local', '')
  node
end

def copy_highlight_nodes(section_node)
  return [] unless section_node

  section_node.get_elements('h')
end

def copy_validate_source(path)
  raise "Source import file not found: #{path}" unless File.file?(path)

  doc = copy_load_xml(path)
  strings = copy_section(doc, 'strings')
  names = copy_section(doc, 'names')
  string_count = copy_highlight_nodes(strings).length
  name_count = copy_highlight_nodes(names).length
  raise "Source has no Custom or Name highlight entries: #{path}" if string_count == 0 && name_count == 0

  { doc: doc, strings: strings, names: names, string_count: string_count, name_count: name_count }
end

def copy_target_files(dir)
  raise "Target folder not found: #{dir}" unless Dir.exist?(dir)

  files = Dir.children(dir).select { |name| name =~ /\A\d+\.xml\z/i }.map { |name| File.join(dir, name) }.sort
  raise "No numeric Wrayth character XML files found in #{dir}" if files.empty?

  files
end

def copy_verify_settings(source_path, target_dir)
  copy_reject_backup_target!(target_dir)
  source = copy_validate_source(source_path)
  files = copy_target_files(target_dir)
  { source: source, targets: files }
end

def xml_text_includes_name?(text, character)
  return false if character.to_s.strip.empty?

  text.to_s.downcase.include?(character.to_s.downcase)
end

def xml_match_snippet(text, character)
  clean_text = text.to_s.gsub(/\s+/, ' ').strip
  return '(empty)' if clean_text.empty?

  needle = character.to_s.downcase
  index = clean_text.downcase.index(needle)
  return clean_text[0, 140] if index.nil?

  start_at = [index - 45, 0].max
  snippet = clean_text[start_at, 140].to_s
  snippet = "...#{snippet}" if start_at > 0
  snippet += '...' if start_at + 140 < clean_text.length
  snippet
end

SENSITIVE_XML_FIELD_PATTERN = /(?:password|pass|pwd|username|user|login|account|token|secret|api[_-]?key|session|cookie|auth)/i

def sensitive_xml_field_name?(name)
  name.to_s =~ SENSITIVE_XML_FIELD_PATTERN
end

def sensitive_xml_context?(node, parents, attribute_name = nil)
  names = [attribute_name, node.respond_to?(:name) ? node.name : nil, *parents].compact
  begin
    names << node.attributes['id'] if node.respond_to?(:attributes) && node.attributes
  rescue
    nil
  end
  names.any? { |name| sensitive_xml_field_name?(name) }
end

def redacted_xml_match_label(node, parents, attribute_name = nil)
  path = (parents + [node.name]).join('/')
  attribute_name ? "#{path}@#{attribute_name}" : "#{path} text"
end

def current_xml_character_reasons(path, character)
  reasons = []
  ignored = []
  return [reasons, ignored] if character.to_s.strip.empty?

  doc = copy_load_xml(path)
  walk = lambda do |node, parents|
    return unless node.is_a?(REXML::Element)

    section = parents.first.to_s
    excluded = %w[names strings scripts].include?(section)
    node.attributes.each_attribute do |attribute|
      next unless xml_text_includes_name?(attribute.value, character)

      if sensitive_xml_context?(node, parents, attribute.name)
        ignored << "#{redacted_xml_match_label(node, parents, attribute.name)} matched #{character}: [redacted private field]"
        next
      end

      snippet = xml_match_snippet(attribute.value, character)
      if excluded
        ignored << "#{section} #{node.name}@#{attribute.name} contains #{character}: #{snippet}"
      elsif section == 'misc' && node.attributes['id'].to_s.downcase == 'logfile'
        reasons << "logFile contains #{character}: #{snippet}"
      else
        reasons << "#{(parents + [node.name]).join('/')}@#{attribute.name} contains #{character}: #{snippet}"
      end
    end
    if node.has_text? && xml_text_includes_name?(node.text, character)
      if sensitive_xml_context?(node, parents)
        ignored << "#{redacted_xml_match_label(node, parents)} matched #{character}: [redacted private field]"
      else
        snippet = xml_match_snippet(node.text, character)
        if excluded
          ignored << "#{section} #{node.name} text contains #{character}: #{snippet}"
        else
          reasons << "#{(parents + [node.name]).join('/')} text contains #{character}: #{snippet}"
        end
      end
    end
    node.elements.each { |child| walk.call(child, parents + [node.name]) }
  end
  doc.root.elements.each { |child| walk.call(child, [child.name]) }
  [reasons.uniq, ignored.uniq]
rescue
  [[], []]
end

def current_xml_target_dir(config)
  settings = config['copy_settings'].is_a?(Hash) ? config['copy_settings'] : {}
  target_dir = settings['target_dir'].to_s.empty? ? COPY_DEFAULT_TARGET : settings['target_dir'].to_s
  copy_backup_target_folder?(target_dir) ? copy_real_target_from_backup_target(target_dir) : target_dir
end

def current_xml_guess(config)
  target_dir = current_xml_target_dir(config)
  return [] unless Dir.exist?(target_dir)

  files = copy_target_files(target_dir)
  character = current_character_name.to_s.strip
  newest_mtime = files.map { |path| File.mtime(path) rescue Time.at(0) }.max || Time.at(0)
  scored = files.map do |path|
    score = 0
    reasons = []
    ignored = []
    mtime = File.mtime(path) rescue Time.at(0)
    if !character.empty?
      reasons, ignored = current_xml_character_reasons(path, character)
      unless reasons.empty?
        score += reasons.any? { |reason| reason.start_with?('logFile ') } ? 120 : 100
      end
    end
    if mtime == newest_mtime
      score += 10
      reasons << 'newest modified'
    end
    { path: path, score: score, reasons: reasons, ignored: ignored, mtime: mtime }
  end
  scored.sort_by { |entry| [-entry[:score], -entry[:mtime].to_i, entry[:path]] }
rescue
  []
end

def print_current_xml_guess(config, debug = false)
  character = current_character_name.to_s.strip
  target_dir = current_xml_target_dir(config)
  ph_echo 'Current client XML detection:'
  ph_echo "  Current character: #{character.empty? ? '(unknown)' : character}"
  unless Dir.exist?(target_dir)
    ph_echo '  This helper only checks Wrayth/StormFront numeric character XML folders.'
    ph_echo "  Folder not found: #{target_dir}"
    ph_echo '  Warlock users can ignore this helper.'
    return
  end
  guesses = current_xml_guess(config)
  best = guesses.first
  if best.nil?
    ph_echo '  No numeric Wrayth character XML files were found.'
    return
  end
  character_matches = guesses.select { |entry| entry[:reasons].any? { |reason| reason.include?("contains #{character}") } }
  confidence = if character_matches.length > 1
                 'ambiguous'
               elsif best[:score] >= 100
                 'high'
               elsif best[:score] > 0
                 'low'
               else
                 'unknown'
               end
  ph_echo "  Best guess: #{best[:path]}"
  ph_echo "  Confidence: #{confidence}"
  if confidence == 'ambiguous'
    ph_echo "  Reason: #{character_matches.length} XML files contain #{character}; newest/highest-scored file selected. Verify manually."
  else
    ph_echo "  Reason: #{best[:reasons].empty? ? 'no character-name match; verify manually' : best[:reasons].join(', ')}"
  end
  if character_matches.length > 1
    ph_echo '  Character-name matches:'
    character_matches.first(10).each do |entry|
      ph_echo "    #{File.basename(entry[:path])}  modified #{entry[:mtime]}  score #{entry[:score]}"
    end
  end
  ignored_highlight_matches = guesses.select { |entry| entry[:ignored] && !entry[:ignored].empty? }
  unless ignored_highlight_matches.empty?
    ph_echo "  Ignored #{ignored_highlight_matches.length} file(s) where the name only matched highlight/script sections."
  end
  ph_echo '  Other recent candidates:'
  guesses.first(5).each do |entry|
    ph_echo "    #{File.basename(entry[:path])}  modified #{entry[:mtime]}  score #{entry[:score]}"
    if debug
      ph_echo "      match reasons: #{entry[:reasons].empty? ? '(none)' : entry[:reasons].join('; ')}"
      ph_echo "      ignored matches: #{entry[:ignored].empty? ? '(none)' : entry[:ignored].first(10).join('; ')}"
    end
  end
rescue => error
  ph_echo "Current XML detection failed: #{error.message}"
end

def copy_print_status(config)
  settings = config['copy_settings'].is_a?(Hash) ? config['copy_settings'] : {}
  ph_echo 'Highlight Manager copy settings:'
  ph_echo "  Source:     #{settings['source_path'] || '(not set)'}"
  ph_echo "  Target dir: #{settings['target_dir'] || '(not set)'}"
  ph_echo "  Duplicates: #{settings['duplicates'] || '(not set)'}"
  ph_echo "  Confirmed:  #{settings['confirmed'] ? 'yes' : 'no'}"
end

def copy_setup(config, raw_args)
  if copy_to_characters_disabled?(config)
    ph_echo copy_to_characters_disabled_message
    return
  end

  source_path = copy_detect_source(raw_args)
  target_dir = copy_detect_target(raw_args)
  mode = copy_duplicate_mode(raw_args, {})
  verified = copy_verify_settings(source_path, target_dir)

  config['copy_settings'] = {
    'source_path' => source_path,
    'target_dir' => target_dir,
    'duplicates' => mode,
    'confirmed' => false,
    'updated_at' => Time.now.utc.iso8601,
  }
  save_config(config)

  ph_echo 'Detected highlight copy settings:'
  ph_echo "  Source: #{source_path}"
  ph_echo "    Custom text highlights: #{verified[:source][:string_count]}"
  ph_echo "    Name highlights:   #{verified[:source][:name_count]}"
  ph_echo "  Target folder: #{target_dir}"
  ph_echo "    Character XML files: #{verified[:targets].length}"
  ph_echo 'Choose duplicate handling: replace, skip, or clear.'
  ph_echo '  replace: update matching Name/Custom Text entries and add missing ones'
  ph_echo '  skip:    only add missing Name/Custom Text entries; leave matches alone'
  ph_echo '  clear:   clear old player-name highlights first, then add current ones'
  ph_echo 'Custom Text highlights are updated in all modes; unrelated custom text is not wiped.'
  ph_echo 'Manual labels are saved as player-name highlights.'
  ph_echo "To confirm and run: ;#{SCRIPT_NAME} copy confirm duplicates=#{mode}"
rescue => error
  ph_echo "Copy setup failed: #{error.message}"
end

def copy_highlight_index(section_node)
  index = Hash.new { |hash, key| hash[key] = [] }
  copy_highlight_nodes(section_node).each do |node|
    text = node.attributes['text'].to_s.strip.downcase
    next if text.empty?

    index[text] << node
  end
  index
end

def copy_remove_indexed_highlights(section_node, nodes)
  removed = 0
  nodes.each do |node|
    section_node.delete(node)
    removed += 1
  rescue
    next
  end
  removed
end

def copy_import_highlights(target_section, source_section, mode)
  summary = { replaced: 0, skipped: 0, added: 0 }
  return summary unless source_section

  if mode == 'clear'
    cleared = copy_highlight_nodes(target_section).length
    copy_highlight_nodes(target_section).each { |node| target_section.delete(node) }
    summary[:replaced] += cleared
  end
  existing_index = copy_highlight_index(target_section)
  copy_highlight_nodes(source_section).each do |source_node|
    text = source_node.attributes['text'].to_s
    key = text.strip.downcase
    next if key.empty?

    existing_nodes = existing_index[key]
    if !existing_nodes.empty? && mode == 'skip'
      summary[:skipped] += 1
      next
    end
    if !existing_nodes.empty? && mode == 'replace'
      summary[:replaced] += copy_remove_indexed_highlights(target_section, existing_nodes)
      existing_index.delete(key)
    end
    clone = source_node.deep_clone
    target_section.add_element(clone)
    existing_index[key] = [clone]
    summary[:added] += 1
  end
  summary
end

def copy_merge_file(target_path, source_info, mode)
  doc = copy_load_xml(target_path)
  strings = copy_ensure_section(doc, 'strings')
  names = copy_ensure_section(doc, 'names')
  string_summary = copy_import_highlights(strings, source_info[:strings], mode == 'clear' ? 'replace' : mode)
  name_summary = copy_import_highlights(names, source_info[:names], mode)
  temp_path = "#{target_path}.highlight-manager.tmp"
  File.write(temp_path, doc.to_s)
  REXML::Document.new(File.read(temp_path))
  FileUtils.mv(temp_path, target_path)
  { strings: string_summary, names: name_summary }
ensure
  File.delete(temp_path) if temp_path && File.exist?(temp_path)
end

def copy_run_merge(config, progress_callback = nil, cancel_requested = nil)
  raise copy_to_characters_disabled_message if copy_to_characters_disabled?(config)

  settings = config['copy_settings'].is_a?(Hash) ? config['copy_settings'] : {}
  raise 'Copy settings are not confirmed. Run copy setup, then copy confirm duplicates=replace|skip|clear.' unless settings['confirmed']

  source_path = settings['source_path'].to_s
  target_dir = settings['target_dir'].to_s
  mode = settings['duplicates'].to_s
  raise "Duplicate mode must be one of: #{COPY_DUPLICATE_MODES.join(', ')}" unless COPY_DUPLICATE_MODES.include?(mode)

  verified = copy_verify_settings(source_path, target_dir)
  backup_dir = unique_timestamped_dir(copy_backup_root(target_dir), 'copy')
  FileUtils.mkdir_p(backup_dir)
  totals = Hash.new(0)
  total_files = verified[:targets].length
  cancelled = false
  ph_echo 'Starting Highlight Manager copy...'
  ph_echo "  Backup folder: #{backup_dir}"
  progress_callback.call('Starting Highlight Manager copy...', 0, total_files) if progress_callback
  verified[:targets].each_with_index do |target_path, index|
    if cancel_requested && cancel_requested.call
      cancelled = true
      break
    end

    basename = File.basename(target_path)
    ph_echo "Copying #{index + 1}/#{verified[:targets].length}: #{basename}"
    progress_callback.call("Copying #{index + 1}/#{total_files}: #{basename}", index, total_files) if progress_callback
    FileUtils.cp(target_path, File.join(backup_dir, File.basename(target_path)))
    result = copy_merge_file(target_path, verified[:source], mode)
    totals[:files] += 1
    totals[:strings_replaced] += result[:strings][:replaced]
    totals[:strings_skipped] += result[:strings][:skipped]
    totals[:strings_added] += result[:strings][:added]
    totals[:names_replaced] += result[:names][:replaced]
    totals[:names_skipped] += result[:names][:skipped]
    totals[:names_added] += result[:names][:added]
    ph_echo "  Done #{basename}: custom text +#{result[:strings][:added]} / replaced #{result[:strings][:replaced]} / skipped #{result[:strings][:skipped]}; names +#{result[:names][:added]} / replaced #{result[:names][:replaced]} / skipped #{result[:names][:skipped]}"
    progress_callback.call("Copied #{index + 1}/#{total_files}: #{basename}", index + 1, total_files) if progress_callback
    if cancel_requested && cancel_requested.call
      cancelled = true
      break
    end
  end

  if cancelled
    if totals[:files] > 0
      ph_echo 'Highlight Manager copy cancelled. Restoring files from the backup made at the start of this run...'
      progress_callback.call('Copy cancelled. Restoring backup...', totals[:files], total_files) if progress_callback
      copy_restore_backup(target_dir, backup_dir)
      ph_echo 'Highlight Manager copy cancelled and restored.'
      progress_callback.call('Copy cancelled and restored.', 0, total_files) if progress_callback
    else
      ph_echo 'Highlight Manager copy cancelled before any character XML files were changed.'
      progress_callback.call('Copy cancelled before any files were changed.', 0, total_files) if progress_callback
    end
    return false
  end

  ph_echo 'Highlight Manager copy complete.'
  ph_echo "  Source: #{source_path}"
  ph_echo "  Backup: #{backup_dir}"
  ph_echo "  Files updated: #{totals[:files]}"
  ph_echo "  Custom text highlights: added #{totals[:strings_added]}, replaced #{totals[:strings_replaced]}, skipped #{totals[:strings_skipped]}"
  ph_echo "  Name highlights:   added #{totals[:names_added]}, replaced #{totals[:names_replaced]}, skipped #{totals[:names_skipped]}"
  copy_prune_backup_dirs(target_dir)
  true
rescue => error
  ph_echo "Copy stopped after #{totals[:files] || 0} file(s). Backups are in: #{backup_dir}" if defined?(backup_dir) && backup_dir
  ph_echo "Copy failed: #{error.message}"
  progress_callback.call("Copy failed: #{error.message}", totals[:files] || 0, defined?(total_files) ? total_files : nil) if progress_callback
  false
end

def copy_confirm(config, raw_args)
  settings = config['copy_settings'].is_a?(Hash) ? config['copy_settings'] : {}
  source_path = copy_arg_value(raw_args, 'source') || copy_arg_value(raw_args, 'src') || settings['source_path'] || copy_detect_source(raw_args)
  target_dir = copy_arg_value(raw_args, 'target') || copy_arg_value(raw_args, 'dir') || settings['target_dir'] || copy_detect_target(raw_args)
  mode = copy_duplicate_mode(raw_args, settings)
  verified = copy_verify_settings(source_path, target_dir)

  config['copy_settings'] = {
    'source_path' => source_path,
    'target_dir' => target_dir,
    'duplicates' => mode,
    'confirmed' => true,
    'confirmed_at' => Time.now.utc.iso8601,
  }
  save_config(config)
  ph_echo 'Confirmed highlight copy settings:'
  ph_echo "  Source: #{source_path}"
  ph_echo "    Custom text highlights: #{verified[:source][:string_count]}"
  ph_echo "    Name highlights:   #{verified[:source][:name_count]}"
  ph_echo "  Target folder: #{target_dir}"
  ph_echo "    Character XML files: #{verified[:targets].length}"
  ph_echo "  Duplicates: #{mode}"
  copy_run_merge(config)
rescue => error
  ph_echo "Copy confirm failed: #{error.message}"
end

def handle_copy_command(config, raw_args, args)
  if copy_to_characters_disabled?(config) && !args.include?('status')
    ph_echo copy_to_characters_disabled_message
    return
  end

  if args.include?('setup')
    copy_setup(config, raw_args)
  elsif args.include?('status')
    copy_print_status(config)
  elsif args.include?('confirm')
    copy_confirm(config, raw_args)
  elsif args.include?('run')
    copy_run_merge(config)
  else
    ph_echo 'Usage: ;highlight-manager copy setup|status|confirm duplicates=replace|skip|clear|run'
  end
end

raw_args = normalize_script_args(Script.current.vars.map(&:to_s))
$highlight_manager_gtk_cleanup_registered = nil
$highlight_manager_gtk_debug = raw_args.any? { |arg| %w[gtkdebug gtk-debug gui-debug verbose-gtk].include?(arg.to_s.downcase) }
config = load_config
$highlight_manager_config = config
report_path = report_path_from_args(raw_args)
if $highlight_manager_gtk_debug && report_path.to_s.strip.empty?
  report_path = File.join(configured_data_folder(config), "highlight-manager-gtkdebug-#{Time.now.strftime('%Y%m%d-%H%M%S')}.txt")
end
start_text_report(report_path, raw_args)
if $highlight_manager_gtk_debug
  ph_echo "GTK debug transcript: #{expand_report_path(report_path)}" unless report_path.to_s.strip.empty?
  gtk_debug "ruby=#{RUBY_VERSION} platform=#{RUBY_PLATFORM}"
  gtk_debug "frontend=#{current_frontend.empty? ? '(unknown)' : current_frontend}"
