# frozen_string_literal: true
#
# reorder-spellbook.lic - v1.0.0
#
# GUI tool for reorganizing spells in a Spell Book item (grimoire / tome /
# book) using the PONDER + TRANSFER mechanics introduced for Rumor Woods 2026.
#
# Reads the book by turning through each page, lets you click-to-prime and
# click-to-swap slots in a Target view, then computes the minimum sequence of
# TRANSFER swaps and executes them in-game. Per-character layouts are saved
# so the window opens instantly on the next run.
#
# == Usage ==
#   ;reorder-spellbook                open window using the saved book noun
#   ;reorder-spellbook <noun>         set/use this book noun (saved per char)
#   ;reorder-spellbook rescan         open and immediately rescan
#
# == In the GUI ==
#   - Type your book noun (e.g. grimoire, tome, book) and click "Use this noun".
#   - Click "Rescan book" the first time, or whenever the book changes outside
#     the script.
#   - You're editing a TARGET layout: click a slot to prime, click another to
#     swap. Changed slots are tinted green vs the original scan. Undo rolls
#     back swaps one at a time; "Reset target to current" clears all edits.
#   - Toggle "Show current (read-only)" to peek at the unmodified scanned
#     layout without losing your edits. Clicks are disabled in this view; flip
#     back to "Show target" to keep editing.
#   - "Show descriptions" toggles a one-line description under each spell
#     (edit SPELL_DESCRIPTIONS at the top of this file to customize).
#   - "Send to game" computes the minimal TRANSFER sequence and executes it.
#     The book is rescanned automatically afterward.
#
# == While running (;send) ==
#   ;send rsb help                    list commands
#   ;send rsb noun <noun>             change the active book noun
#   ;send rsb rescan                  rescan the book
#
# == Data ==
#   data/<game>/<character>/reorder_spellbook.yaml
#
#         author: Zedarius
#         game: Gemstone
#         tags: utility, spell book, grimoire, tome, rumor woods, transfer
#         required: Lich >= 5.6.2
#         version: 1.0.0
#
# == Changelog ==
#   1.0.0 (2026-05-02):
#     - Initial public release.

require 'gtk3' rescue nil
require 'yaml'
require 'set'
require 'cgi'

# Force a clean module reload on every script invocation. Lich keeps the
# module alive across runs, so without this iterative edits to constants
# (regex, VERSION, etc.) would silently never take effect.
#
# Wrinkle: Lich evaluates script bodies via `eval(text, _script.binding)` and
# `_script` lives on `Lich::Common`, so a bare `module Foo` actually creates
# `Lich::Common::Foo`, not `::Foo`. We clean up wherever the prior copy lived
# AND anchor the new module at top-level via `module ::Foo`.
[Object, (Lich::Common rescue nil)].compact.each do |mod|
  mod.send(:remove_const, :ReorderSpellbook) if mod.const_defined?(:ReorderSpellbook, false)
end

module ::ReorderSpellbook
  VERSION         = '1.0.0'.freeze
  SLOTS_PER_PAGE  = 6
  SCHEMA_VERSION  = 1

