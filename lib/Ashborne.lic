  GameObj.loot.each { |i|
    if i.name =~ /stomach wall/
      Ashborne_toolkit.top_menu
      respond "#{Char.name}, you were eaten by a roa'ter or rift crawler.  Grab a dagger and attack the wall, now!"
      fput "stow all"
      Ashborne_toolkit.bottom_menu
      exit
    end
