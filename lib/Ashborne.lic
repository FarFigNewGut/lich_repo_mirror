  def ashborne_data_directory
    path = File.join($lich_dir, "data", "ashborne")
    FileUtils.mkdir_p(path) unless File.directory?(path)
    path
  end

  def ashborne_data_file(filename)
    target = File.join(Ashborne_toolkit.ashborne_data_directory, filename)
    legacy = File.join($lich_dir, "scripts", filename)
    if !File.exist?(target) && File.exist?(legacy)
      FileUtils.mv(legacy, target)
    end
    target
  rescue
    target || File.join($lich_dir, "data", "ashborne", filename)
  end

  def installed_script?(name)
    Script.exists?(name.to_s.sub(/\.lic\z/i, ""))
  rescue
    false
  end

  def release_doctor(version)
    required_scripts = %w[ashborne intel_ashborne]
    recommended_scripts = %w[go2 eloot reactive]
    healing_available = Ashborne_toolkit.installed_script?("eherb") || Ashborne_toolkit.installed_script?("eherbs")
    issues = []
    warnings = []

    required_scripts.each do |name|
      issues << "missing required script: #{name}.lic" unless Ashborne_toolkit.installed_script?(name)
    end
    recommended_scripts.each do |name|
      warnings << "recommended script is not installed: #{name}.lic" unless Ashborne_toolkit.installed_script?(name)
    end
    warnings << "no post-hunt herb script is installed (eherb.lic or eherbs.lic)" unless healing_available

    style = Settings[Char.name]['ashborne_setting_group_style'].to_s
    leader = Settings[Char.name]['ashborne_setting_leader'].to_s
    members = (1..9).map do |number|
      word = %w[zero one two three four five six seven eight nine][number]
      Settings[Char.name]["ashborne_setting_group_#{word}"].to_s.strip
    end.reject { |name| name.empty? || name == "0" }
    members.concat(Settings[Char.name]['ashborne_setting_group_additional'].to_s.split(/[;,\s]+/))
    members.reject! { |name| name.empty? || name == "0" }
    members.uniq!(&:downcase)
    group_configured = leader != "0" || !members.empty?
    account_tool = (Settings[Char.name]['ashborne_setting_multi_account_tool'] || "borg").to_s.downcase
    account_tool = "borg" unless %w[borg thunder].include?(account_tool)
    if group_configured
      if account_tool == "thunder"
        issues << "group mode requires thunder.lic" unless Ashborne_toolkit.installed_script?("thunder")
        issues << "group mode requires struck.lic" unless Ashborne_toolkit.installed_script?("struck")
        warnings << "run ;thunder on the leader or ;struck on each follower" unless Script.running?("thunder") || Script.running?("struck")
      else
        issues << "group mode requires Borg (borg.rb or borg.lic)" unless Ashborne_toolkit.installed_script?("borg")
        issues << "group mode requires drone.lic" unless Ashborne_toolkit.installed_script?("drone")
        issues << "group mode requires queen.lic" unless Ashborne_toolkit.installed_script?("queen")
        warnings << "group mode requires ;drone running on every participating character" unless Script.running?("drone")
      end
    end

    warnings << "group combat style is not set; open ;ashborne gui on this character" unless style =~ /\A[1-9]\z/
    if leader != "0"
      issues << "group leader is also listed as a follower" if members.any? { |name| name.casecmp(leader).zero? }
      duplicate_members = members.group_by(&:downcase).select { |_name, entries| entries.length > 1 }.keys
      issues << "duplicate follower names: #{duplicate_members.join(', ')}" unless duplicate_members.empty?
    end

    health_floor = (Settings[Char.name]['ashborne_setting_health_floor'] || 70).to_i
    loot_handoff = (Settings[Char.name]['ashborne_setting_loot_handoff'] || 30).to_i
    loot_emergency = (Settings[Char.name]['ashborne_setting_loot_emergency'] || 40).to_i
    cycles = (Settings[Char.name]['ashborne_setting_hunt_cycles'] || 1).to_i
    rest_mind = (Settings[Char.name]['ashborne_setting_rest_mind'] || 50).to_i
    issues << "group health floor must be between 1 and 100" unless health_floor.between?(1, 100)
    issues << "loot emergency threshold must be above the handoff threshold" unless loot_emergency > loot_handoff
    issues << "total hunts must be between 1 and 25" unless cycles.between?(1, 25)
    issues << "rest mind target must be between 0 and 100" unless rest_mind.between?(0, 100)

    profile = Ashborne_toolkit.load_capability_profile
    if profile.nil?
      warnings << "capability profile is missing; run ;ashborne setup capabilities"
    elsif profile["version"].to_i < PROFILE_VERSION
      warnings << "capability profile is outdated; run ;ashborne setup capabilities"
    end

    Ashborne_toolkit.top_menu
    respond "Ashborne #{version} release doctor for #{Char.name}: #{issues.empty? ? 'PASS' : 'BLOCKED'}"
    issues.each { |message| respond "  BLOCK: #{message}" }
    warnings.each { |message| respond "  WARN: #{message}" }
    respond "  Required scripts: #{required_scripts.map { |name| "#{name}=#{Ashborne_toolkit.installed_script?(name) ? 'ok' : 'missing'}" }.join(', ')}"
    if group_configured
      if account_tool == "thunder"
        respond "  Group command system: thunder=#{Ashborne_toolkit.installed_script?('thunder') ? 'ok' : 'missing'}, struck=#{Ashborne_toolkit.installed_script?('struck') ? 'ok' : 'missing'}, local listener running=#{Script.running?('thunder') || Script.running?('struck') ? 'yes' : 'no'}"
      else
        respond "  Group command system: borg=#{Ashborne_toolkit.installed_script?('borg') ? 'ok' : 'missing'}, drone=#{Ashborne_toolkit.installed_script?('drone') ? 'ok' : 'missing'}, queen=#{Ashborne_toolkit.installed_script?('queen') ? 'ok' : 'missing'}, drone running=#{Script.running?('drone') ? 'yes' : 'no'}"
      end
    end
    respond "  Configuration: style=#{style == '' ? 'unset' : style}, multi-account=#{account_tool}, hunts=#{cycles}, rest=#{rest_mind}%, health floor=#{health_floor}%"
    respond "  Group: leader=#{leader}, followers=#{members.empty? ? 'none' : members.join(', ')}"
    respond "Run ;ashborne support to write a compact diagnostic report." if issues.any? || warnings.any?
    Ashborne_toolkit.bottom_menu
    { "issues" => issues, "warnings" => warnings }
  rescue => error
    respond "Ashborne release doctor failed: #{error.class}: #{error.message}"
    { "issues" => ["doctor failed"], "warnings" => [] }
  end

  def write_support_report(version)
    safe_name = Char.name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    timestamp = Time.now.strftime("%Y-%m-%d_%H%M%S")
    path = Ashborne_toolkit.ashborne_data_file("#{safe_name}_ashborne_support_#{timestamp}.yml")
    settings = Settings[Char.name] || {}
    setting_names = %w[
      ashborne_setting_group_style ashborne_setting_leader
      ashborne_setting_group_one ashborne_setting_group_two ashborne_setting_group_three
      ashborne_setting_group_four ashborne_setting_group_five ashborne_setting_group_six
      ashborne_setting_group_seven ashborne_setting_group_eight ashborne_setting_group_nine
      ashborne_setting_group_additional ashborne_setting_multi_account_tool
      ashborne_setting_health_floor ashborne_setting_mana_reserve ashborne_setting_stamina_reserve
      ashborne_setting_anti_caster ashborne_setting_anti_caster_mana ashborne_setting_noise_lockdown
      ashborne_setting_huntpro_spell_baseline ashborne_setting_crowd_control ashborne_setting_spell_default
      ashborne_setting_loot_rotation ashborne_setting_loot_handoff ashborne_setting_loot_emergency
      ashborne_setting_hunt_cycles ashborne_setting_rest_mind ashborne_setting_rest_healing
      ashborne_setting_rest_ask_empath ashborne_setting_rest_sell
    ]
    report = {
      "generated_at" => Time.now.strftime("%Y-%m-%d %H:%M:%S %z"),
      "ashborne_version" => version,
      "character" => safe_name,
      "profession" => Stats.prof.to_s,
      "level" => Stats.level.to_i,
      "room_id" => (Ashborne_toolkit.current_room_id rescue nil),
      "settings" => setting_names.each_with_object({}) { |key, values| values[key] = settings[key] },
      "scripts" => %w[ashborne intel_ashborne borg drone queen go2 eloot reactive eherb eherbs].each_with_object({}) do |name, values|
        values[name] = Ashborne_toolkit.installed_script?(name)
      end,
      "capability_profile" => Ashborne_toolkit.load_capability_profile,
      "group_plan" => (File.exist?(Ashborne_toolkit.group_plan_file) ? YAML.load_file(Ashborne_toolkit.group_plan_file) : nil)
    }
    temporary = "#{path}.tmp"
    File.write(temporary, report.to_yaml)
    FileUtils.mv(temporary, path)
    respond "Ashborne support report written to: #{path}"
    respond "It contains configuration and capability data, but no game log or inventory contents."
    path
  rescue => error
    respond "Ashborne could not write the support report: #{error.class}: #{error.message}"
    nil
  end

  def capability_profile_file(name = Char.name)
    safe_name = name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    Ashborne_toolkit.ashborne_data_file("#{safe_name}_ashborne_capabilities.yml")
  end

  def huntpro_capability_profile_file(name = Char.name)
    safe_name = name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    target = File.join($lich_dir, "data", "huntpro", "#{safe_name}_huntpro_capabilities.yml")
    legacy = File.join($lich_dir, "scripts", "#{safe_name}_huntpro_capabilities.yml")
    FileUtils.mkdir_p(File.dirname(target))
    FileUtils.mv(legacy, target) if !File.exist?(target) && File.exist?(legacy)
    target
  end

  def ability_rules_file(name = Char.name)
    safe_name = name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    Ashborne_toolkit.ashborne_data_file("#{safe_name}_ashborne_ability_rules.yml")
  end

  def default_ability_rules
    abilities = CROWD_CONTROL_SPELLS.each_with_object({}) do |(spell_num, details), rules|
      rules["spell:#{spell_num}"] = {
        "label" => "#{details[0]} (#{spell_num})",
        "enabled" => true,
        "min_targets" => details[1],
        "max_targets" => 0,
        "only_creatures" => [],
        "never_creatures" => []
      }
    end
    ANTI_CASTER_SPELLS.each do |spell_num, name, _priority, _purpose, _target_type|
      abilities["spell:#{spell_num}"] ||= {
        "label" => "#{name} (#{spell_num})",
        "enabled" => true,
        "min_targets" => 1,
        "max_targets" => 0,
        "only_creatures" => [],
        "never_creatures" => []
      }
    end
    ANTI_CASTER_SKILLS.each do |family, name, _priority, _purpose|
      abilities["#{family}:#{name.downcase.gsub(/\s+/, '')}"] = {
        "label" => name,
        "enabled" => true,
        "min_targets" => 1,
        "max_targets" => 0,
        "only_creatures" => [],
        "never_creatures" => []
      }
    end
    {
      "version" => ABILITY_RULE_VERSION,
      "crowd_control" => {
        "enabled" => true,
        "min_targets" => 3,
        "max_targets" => 0
      },
      "abilities" => abilities
    }
  end

  def normalized_name_list(value)
    Array(value).flat_map { |item| item.to_s.split(",") }
      .map { |item| item.strip.downcase }
      .reject { |item| item.empty? || item == "0" }
      .uniq
  end

  def merge_ability_rules(defaults, saved)
    return defaults unless saved.is_a?(Hash)

    merged = defaults.dup
    merged["crowd_control"] = defaults["crowd_control"].merge(saved["crowd_control"] || {})
    saved_abilities = saved["abilities"].is_a?(Hash) ? saved["abilities"] : {}
    merged["abilities"] = defaults["abilities"].each_with_object({}) do |(key, rule), abilities|
      abilities[key] = rule.merge(saved_abilities[key] || {})
    end
    saved_abilities.each do |key, rule|
      merged["abilities"][key] ||= rule if rule.is_a?(Hash)
    end
    merged
  end

  def load_ability_rules(name = Char.name)
    path = Ashborne_toolkit.ability_rules_file(name)
    modified = File.exist?(path) ? File.mtime(path).to_i : 0
    cache_key = "#{name}:#{modified}"
    return @ability_rules_cache[cache_key] if @ability_rules_cache && @ability_rules_cache.key?(cache_key)

    saved = File.exist?(path) ? YAML.load_file(path) : {}
    rules = Ashborne_toolkit.merge_ability_rules(Ashborne_toolkit.default_ability_rules, saved)
    @ability_rules_cache = { cache_key => rules }
    rules
  rescue
    Ashborne_toolkit.default_ability_rules
  end

  def save_ability_rules(rules, name = Char.name)
    path = Ashborne_toolkit.ability_rules_file(name)
    temporary_file = "#{path}.tmp"
    File.write(temporary_file, rules.to_yaml)
    FileUtils.mv(temporary_file, path)
    @ability_rules_cache = nil
    true
  end

  def creature_names
    GameObj.targets.map { |target| target.name.to_s.downcase }
  rescue
    []
  end

  def rule_matches_room?(rule, target_count = nil, names = nil)
    return false if rule["enabled"] == false || rule["enabled"].to_s == "0"

    target_count ||= GameObj.targets.length
    names ||= Ashborne_toolkit.creature_names
    minimum = rule["min_targets"].to_i
    maximum = rule["max_targets"].to_i
    return false if target_count < minimum
    return false if maximum > 0 && target_count > maximum

    only = Ashborne_toolkit.normalized_name_list(rule["only_creatures"])
    never = Ashborne_toolkit.normalized_name_list(rule["never_creatures"])
    return false if !only.empty? && names.none? { |name| only.any? { |pattern| name.include?(pattern) } }
    return false if !never.empty? && names.any? { |name| never.any? { |pattern| name.include?(pattern) } }

    true
  end

  def ability_allowed?(family, id, name = Char.name)
    return true if family.to_s == "spell" && Ashborne_toolkit.huntpro_spell_baseline?

    key = "#{family}:#{id.to_s.downcase.gsub(/\s+/, '')}"
    rule = Ashborne_toolkit.load_ability_rules(name).dig("abilities", key)
    rule.nil? || Ashborne_toolkit.rule_matches_room?(rule)
  end

  def crowd_control_allowed?
    return true if Ashborne_toolkit.huntpro_spell_baseline?

    rule = Ashborne_toolkit.load_ability_rules.dig("crowd_control") || {}
    Ashborne_toolkit.rule_matches_room?(rule)
  end

  def huntpro_spell_baseline?
    defined?($ashborne_my_style) && $ashborne_my_style.to_s == "9" &&
      defined?($ashborne_huntpro_spell_baseline) && $ashborne_huntpro_spell_baseline.to_s != "0"
  rescue
    false
  end

  def crowd_control_enabled_for_combat?
    $ashborne_crowd_control.to_s == "1"
  rescue
    false
  end

  def custom_spell_rotation_enabled?
    Array($ashborne_custom_spell_rotation).any?
  rescue
    false
  end

  def huntpro_spell_attack_cycle?
    Ashborne_toolkit.huntpro_spell_baseline? && !Ashborne_toolkit.custom_spell_rotation_enabled?
  rescue
    false
  end

  def known_anti_caster_skill?(family, name)
    case family
    when "cman"
      CMan.known?(name)
    when "shield"
      Shield.known?(name)
    when "armor"
      Armor.known?(name)
    when "weapon"
      Weapon.known?(name)
    when "feat"
      Feat.known?(name)
    else
      false
    end
  rescue
    false
  end

  def skill_ranks(method_name)
    Skills.respond_to?(method_name) ? Skills.public_send(method_name).to_i : 0
  rescue
    0
  end

  def known_ability_names(family)
    manager, lookup_method =
      case family
      when "cman"
        [Lich::Gemstone::CMan, :cman_lookups]
      when "shield"
        [Lich::Gemstone::Shield, :shield_lookups]
      when "armor"
        [Lich::Gemstone::Armor, :armor_lookups]
      when "weapon"
        [Lich::Gemstone::Weapon, :weapon_lookups]
      when "feat"
        [Lich::Gemstone::Feat, :feat_lookups]
      else
        return []
      end

    return [] unless manager.respond_to?(lookup_method)

    manager.public_send(lookup_method).each_with_object([]) do |lookup, names|
      rank = manager[lookup[:short_name]]
      next if rank.nil? || rank.to_i <= 0

      names << lookup[:long_name].to_s.split("_").map(&:capitalize).join(" ")
    end.sort
  rescue
    []
  end

  def normalized_role(value)
    role = value.to_s.downcase.strip
    role = role.gsub(/[^a-z]/, "")
    role = ROLE_ALIASES[role] || role
    ROLE_NAMES.include?(role) ? role : "auto"
  end

  def profile_role_scores(profile)
    skills = profile["skills"].is_a?(Hash) ? profile["skills"] : {}
    abilities = profile["known_combat_abilities"].is_a?(Hash) ? profile["known_combat_abilities"] : {}
    spells = Array(profile["known_spells"]).map(&:to_i)
    anti_caster = Array(profile["anti_caster_abilities"])
    profession = profile["profession"].to_s

    combat_maneuvers = skills["combat_maneuvers"].to_i
    shield_use = skills["shield_use"].to_i
    armor_use = skills["armor_use"].to_i
    spell_aiming = skills["spell_aiming"].to_i
    perception = skills["perception"].to_i
    hiding = skills["stalking_and_hiding"].to_i
    shield_abilities = Array(abilities["shield"]).length
    weapon_abilities = Array(abilities["weapon"]).length
    feat_abilities = Array(abilities["feat"]).length
    highest_interrupt = anti_caster.map { |ability| ability["priority"].to_i }.max.to_i
    control_count = anti_caster.count { |ability| ability["priority"].to_i >= 64 }

    scores = {
      "interrupt" => highest_interrupt,
      "control" => [control_count * 12 + highest_interrupt / 3, 100].min,
      "guardian" => [shield_use + armor_use / 2 + shield_abilities * 8, 100].min,
      "healer" => 0,
      "dispel" => spells.any? { |spell_num| DISPEL_SPELLS.include?(spell_num) } ? 85 : 0,
      "damage" => [[combat_maneuvers, spell_aiming].max + weapon_abilities * 5 + feat_abilities * 3, 100].min,
      "scout" => [perception + hiding, 100].min
    }

    scores["guardian"] = [scores["guardian"] + 15, 100].min if profession =~ /Paladin|Warrior/
    scores["healer"] = 100 if profession == "Empath"
    scores["healer"] = 70 if profession == "Cleric"
    scores["control"] = [scores["control"] + 10, 100].min if profession =~ /Bard|Sorcerer|Wizard/
    scores["scout"] = [scores["scout"] + 10, 100].min if profession =~ /Ranger|Rogue/
    scores["damage"] = 25 if scores["damage"] < 25
    scores
  rescue
    GROUP_JOBS.each_with_object({}) { |job, scores| scores[job] = job == "damage" ? 25 : 0 }
  end

  def normalized_capability_profile(profile)
    return nil unless profile.is_a?(Hash)

    normalized = profile.dup
    current_character = profile["character"].to_s.casecmp(Char.name.to_s).zero?
    normalized["version"] = PROFILE_VERSION
    normalized["role_preference"] = Ashborne_toolkit.normalized_role(
      profile["role_preference"] ||
        (current_character ? Settings[Char.name]['ashborne_setting_role'] : nil) ||
        "auto"
    )
    normalized["resource_reserves"] ||= {
      "mana_percent" => (current_character ? (Settings[Char.name]['ashborne_setting_mana_reserve'] || 40) : 40).to_i,
      "stamina_percent" => (current_character ? (Settings[Char.name]['ashborne_setting_stamina_reserve'] || 20) : 20).to_i,
      "health_percent" => (current_character ? (Settings[Char.name]['ashborne_setting_health_floor'] || 70) : 70).to_i
    }
    normalized["role_scores"] = Ashborne_toolkit.profile_role_scores(normalized)
    normalized
  rescue
    profile
  end

  def equipment_snapshot
    {
      "right_hand" => checkright.to_s,
      "left_hand" => checkleft.to_s,
      "using_shield" => checkleft.to_s =~ /shield/i ? true : false
    }
  rescue
    {}
  end

  def scan_combat_capabilities
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, refreshing combat skills and anti-caster capabilities."
    Ashborne_toolkit.bottom_menu

    ["skill full", "cman info", "shield info", "armor info", "weapon info", "feat info"].each do |command|
      fput command
      sleep 1.25
    end

    abilities = []
    ANTI_CASTER_SPELLS.each do |spell_num, name, priority, purpose, target_type|
      spell = Spell[spell_num]
      next unless spell && spell.known?

      abilities << {
        "family" => "spell",
        "id" => spell_num,
        "name" => name,
        "priority" => priority,
        "purpose" => purpose,
        "target_type" => target_type
      }
    end

    ANTI_CASTER_SKILLS.each do |family, name, priority, purpose|
      next unless Ashborne_toolkit.known_anti_caster_skill?(family, name)

      abilities << {
        "family" => family,
        "id" => name.downcase.gsub(/\s+/, ""),
        "name" => name,
        "priority" => priority,
        "purpose" => purpose
      }
    end

    known_spells = Spell.list.select(&:known?).map(&:num).sort
    known_combat_abilities = {
      "cman" => Ashborne_toolkit.known_ability_names("cman"),
      "shield" => Ashborne_toolkit.known_ability_names("shield"),
      "armor" => Ashborne_toolkit.known_ability_names("armor"),
      "weapon" => Ashborne_toolkit.known_ability_names("weapon"),
      "feat" => Ashborne_toolkit.known_ability_names("feat")
    }

    profile = {
      "version" => PROFILE_VERSION,
      "scanned_at" => Time.now.strftime("%Y-%m-%d %H:%M:%S %z"),
      "character" => Char.name,
      "profession" => Stats.prof,
      "level" => Stats.level,
      "role_preference" => Ashborne_toolkit.normalized_role(Settings[Char.name]['ashborne_setting_role'] || "auto"),
      "resource_reserves" => {
        "mana_percent" => (Settings[Char.name]['ashborne_setting_mana_reserve'] || 40).to_i,
        "stamina_percent" => (Settings[Char.name]['ashborne_setting_stamina_reserve'] || 20).to_i,
        "health_percent" => (Settings[Char.name]['ashborne_setting_health_floor'] || 70).to_i
      },
      "equipment" => Ashborne_toolkit.equipment_snapshot,
      "skills" => {
        "combat_maneuvers" => Ashborne_toolkit.skill_ranks(:combatmaneuvers),
        "shield_use" => Ashborne_toolkit.skill_ranks(:shielduse),
        "armor_use" => Ashborne_toolkit.skill_ranks(:armoruse),
        "physical_fitness" => Ashborne_toolkit.skill_ranks(:physicalfitness),
        "perception" => Ashborne_toolkit.skill_ranks(:perception),
        "stalking_and_hiding" => Ashborne_toolkit.skill_ranks(:stalkingandhiding),
        "spell_aiming" => Ashborne_toolkit.skill_ranks(:spellaiming),
        "spiritual_mana_control" => Ashborne_toolkit.skill_ranks(:spiritualmanacontrol),
        "elemental_mana_control" => Ashborne_toolkit.skill_ranks(:elementalmanacontrol),
        "mental_mana_control" => Ashborne_toolkit.skill_ranks(:mentalmanacontrol)
      },
      "known_spells" => known_spells,
      "known_combat_abilities" => known_combat_abilities,
      "anti_caster_abilities" => abilities.sort_by { |ability| -ability["priority"].to_i }
    }
    profile["role_scores"] = Ashborne_toolkit.profile_role_scores(profile)

    temporary_file = "#{Ashborne_toolkit.capability_profile_file}.tmp"
    File.write(temporary_file, profile.to_yaml)
    FileUtils.mv(temporary_file, Ashborne_toolkit.capability_profile_file)

    Settings[Char.name]['ashborne_setting_capability_scan'] = profile["scanned_at"]
    Settings.save

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, Ashborne profile v#{PROFILE_VERSION} saved with #{abilities.length} verified interrupt options."
    respond "  Preferred role: #{profile['role_preference']}"
    respond "  Role scores: #{profile['role_scores'].map { |role, score| "#{role}=#{score}" }.join(', ')}"
    abilities.each do |ability|
      respond "  #{ability['priority']}: #{ability['name']} - #{ability['purpose']}"
    end
    respond "Profile: #{Ashborne_toolkit.capability_profile_file}"
    Ashborne_toolkit.bottom_menu
    profile
  rescue => error
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, capability scan failed: #{error.class}: #{error.message}"
    Ashborne_toolkit.bottom_menu
    nil
  end

  def load_capability_profile(name = Char.name)
    path = Ashborne_toolkit.capability_profile_file(name)
    unless File.exist?(path)
      huntpro_path = Ashborne_toolkit.huntpro_capability_profile_file(name)
      return nil unless File.exist?(huntpro_path)

      imported_profile = YAML.load_file(huntpro_path)
      imported_profile = Ashborne_toolkit.normalized_capability_profile(imported_profile)
      return nil unless imported_profile

      File.write(path, imported_profile.to_yaml)
      return imported_profile
    end

    profile = YAML.load_file(path)
    Ashborne_toolkit.normalized_capability_profile(profile)
  rescue
    nil
  end

  def group_capability_profiles
    Ashborne_toolkit.configured_group_names.each_with_object({}) do |name, profiles|
      profile = Ashborne_toolkit.load_capability_profile(name)
      profiles[name] = profile if profile
    end
  end

  def import_huntpro_settings
    source_root = Lich::Common::Settings.current_script_settings(":", script_name: "huntpro")
    source_character = source_root.is_a?(Hash) ? source_root[Char.name] : nil
    source_character ||= source_root[Char.name.to_s] if source_root.is_a?(Hash)
    source_character ||= source_root[Char.name.to_sym] if source_root.is_a?(Hash)
    unless source_character.is_a?(Hash)
      respond "No HuntPro settings were found for #{Char.name}."
      return false
    end

    imported = 0
    source_character.each do |key, value|
      source_key = key.to_s
      next unless source_key.start_with?("huntpro_setting_")

      target_key = source_key.sub(/\Ahuntpro_setting_/, "ashborne_setting_")
      Settings[Char.name][target_key] = value
      imported += 1
    end
    Settings[Char.name]['ashborne_setting_role'] ||= "auto"
    Settings[Char.name]['ashborne_setting_job_coordinator'] ||= "1"
    Settings[Char.name]['ashborne_setting_mana_reserve'] ||= 40
    Settings[Char.name]['ashborne_setting_stamina_reserve'] ||= 20
    Settings[Char.name]['ashborne_setting_health_floor'] ||= 70
    Settings.save

    huntpro_profile = Ashborne_toolkit.huntpro_capability_profile_file
    if File.exist?(huntpro_profile)
      imported_profile = YAML.load_file(huntpro_profile)
      imported_profile = Ashborne_toolkit.normalized_capability_profile(imported_profile)
      File.write(Ashborne_toolkit.capability_profile_file, imported_profile.to_yaml) if imported_profile
    end

    respond "Imported #{imported} HuntPro settings for #{Char.name}."
    respond "Run ;ashborne setup capabilities after training or equipment changes."
    true
  rescue => error
    respond "HuntPro import failed: #{error.class}: #{error.message}"
    false
  end

  def import_missing_huntpro_group_settings
    current = Settings[Char.name]
    return {} unless current.is_a?(Hash)
    current_leader = current['ashborne_setting_leader'].to_s
    current_first_member = current['ashborne_setting_group_one'].to_s
    return {} unless (current_leader.empty? || current_leader == "0") &&
      (current_first_member.empty? || current_first_member == "0")

    source_root = Lich::Common::Settings.current_script_settings(":", script_name: "huntpro")
    source = source_root.is_a?(Hash) ? source_root[Char.name] : nil
    source ||= source_root[Char.name.to_s] if source_root.is_a?(Hash)
    source ||= source_root[Char.name.to_sym] if source_root.is_a?(Hash)
    return {} unless source.is_a?(Hash)

    imported = {}
    %w[leader group_one group_two group_three group_four group_five
       group_six group_seven group_eight group_nine group_style].each do |suffix|
      source_key = "huntpro_setting_#{suffix}"
      target_key = "ashborne_setting_#{suffix}"
      value = source[source_key] || source[source_key.to_sym]
      next if value.nil?

      current[target_key] = value
      imported[target_key] = value
    end
    return {} if imported['ashborne_setting_leader'].to_s == "0" ||
      imported['ashborne_setting_group_one'].to_s == "0"

    Settings.save
    respond "Ashborne imported #{Char.name}'s missing group roster from HuntPro."
    imported
  rescue => error
    respond "Ashborne could not import the HuntPro group roster: #{error.message}"
    {}
  end

  def group_plan_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_group_plan.yml")
  end

  def job_coordinator_enabled?
    value = if defined?($ashborne_job_coordinator)
              $ashborne_job_coordinator
            else
              Settings[Char.name]['ashborne_setting_job_coordinator'] || "1"
            end
    value.to_s != "0"
  end

  def mana_reserve
    value = defined?($ashborne_mana_reserve) ? $ashborne_mana_reserve : 40
    [[value.to_i, 0].max, 95].min
  end

  def style9_low_mana_finisher_available?
    return false unless $ashborne_my_style.to_s == "9"
    return false if $ashborne_disable_mana == "1"
    return false unless $ashborne_style9_arcaneblast.to_s == "1"
    return false if percentmana.to_i <= Ashborne_toolkit.critical_mana_floor
    return false if GameObj.targets.empty?
    return false unless Spell[1700].known? && Spell[1700].affordable?

    true
  rescue
    false
  end

  def trigger_style9_low_mana_finisher
    $ashborne_style9_blastround = "1"
    $ashborne_style9_low_mana_return = "1"
    $ashborne_return_why = "You have low mana after finishing the current target."
    true
  rescue
    false
  end

  def critical_mana_floor
    5
  end

  def critical_mana_retreat_if_needed
    return false unless $ashborne_my_style.to_s == "9"
    return false if percentmana.to_i > Ashborne_toolkit.critical_mana_floor

    $ashborne_style9_blastround = "0"
    $ashborne_style9_low_mana_return = "0"
    $ashborne_return_why = "Critical low mana (#{percentmana.to_i}%); returning immediately."
    $ashborne_action = 99
    $ashborne_group_danger_active = "1"
    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.publish_group_danger($ashborne_return_why) if $ashborne_group_ai != "0"
    true
  rescue
    false
  end

  def stamina_reserve
    value = defined?($ashborne_stamina_reserve) ? $ashborne_stamina_reserve : 20
    [[value.to_i, 0].max, 95].min
  end

  def health_floor
    value = defined?($ashborne_health_floor) ? $ashborne_health_floor : 70
    [[value.to_i, 1].max, 100].min
  end

  def build_group_plan(profiles = Ashborne_toolkit.group_capability_profiles)
    return {} if profiles.empty?

    assignments = {}
    used_primary = []
    job_order = %w[guardian interrupt healer control dispel scout damage]
    job_order.each do |job|
      candidates = profiles.map do |character_name, profile|
        scores = profile["role_scores"].is_a?(Hash) ? profile["role_scores"] : Ashborne_toolkit.profile_role_scores(profile)
        preference = Ashborne_toolkit.normalized_role(profile["role_preference"])
        score = scores[job].to_i
        score += 20 if preference == job
        [character_name, score]
      end
      candidates.select! { |_character_name, score| score > 0 || job == "damage" }
      candidates.sort_by! { |character_name, score| [-score, character_name.to_s.downcase] }
      next if candidates.empty?

      primary = candidates.find { |character_name, _score| !used_primary.include?(character_name.downcase) } || candidates.first
      backup = candidates.find { |character_name, _score| !character_name.casecmp(primary[0]).zero? }
      assignments[job] = {
        "primary" => primary[0],
        "primary_score" => primary[1],
        "backup" => backup ? backup[0] : nil,
        "backup_score" => backup ? backup[1] : nil
      }
      used_primary << primary[0].downcase
    end

    {
      "version" => 1,
      "generated_at" => Time.now.to_i,
      "session_id" => Ashborne_toolkit.current_group_session_id,
      "leader" => Ashborne_toolkit.group_bus_leader_name,
      "members" => profiles.keys,
      "assignments" => assignments
    }
  rescue
    {}
  end

  def publish_group_plan
    return {} unless Ashborne_toolkit.job_coordinator_enabled?
    return {} unless defined?($ashborne_group_ai) && $ashborne_group_ai == "1"

    plan = Ashborne_toolkit.build_group_plan
    return {} if plan.empty?

    temporary_file = "#{Ashborne_toolkit.group_plan_file}.tmp"
    File.write(temporary_file, plan.to_yaml)
    FileUtils.mv(temporary_file, Ashborne_toolkit.group_plan_file)
    plan
  rescue
    {}
  end

  def current_group_plan
    return {} unless File.exist?(Ashborne_toolkit.group_plan_file)

    plan = YAML.load_file(Ashborne_toolkit.group_plan_file)
    return {} unless plan.is_a?(Hash)
    return {} if Time.now.to_i - plan["generated_at"].to_i > 3600

    plan
  rescue
    {}
  end

  def assigned_character_for_job(job)
    assignment = Ashborne_toolkit.current_group_plan.dig("assignments", job.to_s)
    assignment.is_a?(Hash) ? assignment["primary"].to_s : ""
  rescue
    ""
  end

  def show_group_plan(plan = nil)
    plan ||= if defined?($ashborne_group_ai) && $ashborne_group_ai == "1"
               Ashborne_toolkit.publish_group_plan
             else
               Ashborne_toolkit.current_group_plan
             end
    Ashborne_toolkit.top_menu
    if plan.nil? || plan.empty?
      respond "No Ashborne group plan is available. Run capability scans on the group first."
    else
      respond "Ashborne group plan led by #{plan['leader']}:"
      plan.fetch("assignments", {}).each do |job, assignment|
        line = "  #{job}: #{assignment['primary']} (#{assignment['primary_score']})"
        line += " | backup #{assignment['backup']} (#{assignment['backup_score']})" if assignment["backup"]
        respond line
      end
    end
    Ashborne_toolkit.bottom_menu
    plan
  end

  def canonical_character_name(value)
    name = value.respond_to?(:name) ? value.name.to_s : value.to_s
    name = name.sub(/\s+\([^)]+\)\s*\z/, "").strip
    name.split(/\s+/).last.to_s.gsub(/[^A-Za-z'\-]/, "")
  end

  def valid_character_name?(value)
    name = Ashborne_toolkit.canonical_character_name(value)
    !name.empty? && name =~ /\A[A-Za-z][A-Za-z'\-]*\z/
  end

  def configured_group_names
    names = [Char.name]
    if defined?($ashborne_group_ai) && $ashborne_group_ai == "1"
      names << $ashborne_captain if defined?($ashborne_captain)
      names.concat(Array($ashborne_group_array)) if defined?($ashborne_group_array)
    elsif defined?($ashborne_group_ai) && $ashborne_group_ai == "2"
      names << $ashborne_captain if defined?($ashborne_captain)
    end
    names.concat(Ashborne_toolkit.group_session_names) if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
    names.map! { |name| Ashborne_toolkit.canonical_character_name(name) }
    names.select! { |name| Ashborne_toolkit.valid_character_name?(name) }
    names << Char.name
    names.uniq { |name| name.downcase }
  rescue
    [Char.name]
  end

  def configured_group_members
    return [] unless defined?($ashborne_group_ai) && $ashborne_group_ai == "1"

    names = Array($ashborne_group_array).map { |name| Ashborne_toolkit.canonical_character_name(name) }
    names.reject do |name|
      !Ashborne_toolkit.valid_character_name?(name) || name.casecmp(Char.name.to_s).zero?
    end.uniq { |name| name.downcase }
  rescue
    []
  end

  def group_combat_style(configured_style = "0", requested_style = "0")
    configured = configured_style.to_s
    return configured if configured =~ /\A[1-9]\z/

    case Stats.prof.to_s
    when "Wizard", "Cleric", "Empath", "Sorcerer"
      "9"
    when "Monk"
      "1"
    else
      weapon_ranks = [
        Skills.bluntweapons, Skills.edgedweapons, Skills.polearmweapons,
        Skills.rangedweapons, Skills.twohandedweapons
      ].map(&:to_i)
      return "1" if Skills.brawling.to_i > weapon_ranks.max.to_i

      requested = requested_style.to_s
      requested =~ /\A[1-9]\z/ ? requested : "3"
    end
  rescue
    "3"
  end

  def verified_reactive_ability?(ability)
    if ability["family"] == "spell"
      VERIFIED_REACTIVE_SPELLS.include?(ability["id"].to_i)
    else
      VERIFIED_REACTIVE_SKILLS.include?(ability["name"].to_s)
    end
  end

  def anti_caster_mana_reserve(profession = Stats.prof)
    configured = defined?($ashborne_anti_caster_mana) ? $ashborne_anti_caster_mana.to_i : 50
    profession_floor =
      case profession.to_s
      when "Paladin"
        65
      when "Bard", "Ranger"
        50
      else
        40
      end
    [configured, profession_floor].max
  end

  def group_state_ready_for_ability?(character_name, profile, ability, event = nil)
    return false unless Ashborne_toolkit.ability_allowed?(ability["family"], ability["id"], character_name)

    state = Ashborne_toolkit.read_group_state(character_name)
    return false unless state
    return false if Time.now.to_i - state["timestamp"].to_i > ANTI_CASTER_STATE_TTL
    return false if event && state["room_id"].to_s != event["room_id"].to_s
    reserves = profile["resource_reserves"].is_a?(Hash) ? profile["resource_reserves"] : {}
    health_floor = [reserves["health_percent"].to_i, Ashborne_toolkit.health_floor].max
    mana_floor = [reserves["mana_percent"].to_i, Ashborne_toolkit.anti_caster_mana_reserve(profile["profession"])].max
    stamina_floor = [reserves["stamina_percent"].to_i, Ashborne_toolkit.stamina_reserve].max
    return false if state["health"].to_i < health_floor
    return false unless state["flags"].to_s.empty?
    return false if state["roundtime"].to_f > 1.5 || state["cast_roundtime"].to_f > 1.5

    if ability["family"] == "spell"
      state["mana"].to_i >= mana_floor
    else
      state["stamina"].to_i >= stamina_floor
    end
  rescue
    false
  end

  def ranked_group_anti_caster_responders(event = nil, excluded_names = [])
    candidates = []
    assigned_interrupt = Ashborne_toolkit.assigned_character_for_job("interrupt")
    Ashborne_toolkit.group_capability_profiles.each do |character_name, profile|
      Array(profile["anti_caster_abilities"]).each do |ability|
        next unless Ashborne_toolkit.verified_reactive_ability?(ability)
        next if excluded_names.any? { |name| name.to_s.casecmp(character_name.to_s).zero? }
        next unless Ashborne_toolkit.group_state_ready_for_ability?(character_name, profile, ability, event)

        candidates << [character_name, ability, profile]
      end
    end

    candidates.sort_by do |character_name, ability, _profile|
      physical_bonus = ability["family"] == "spell" ? 0 : 40
      assignment_bonus = character_name.to_s.casecmp(assigned_interrupt).zero? ? 30 : 0
      [-(ability["priority"].to_i + physical_bonus + assignment_bonus), character_name.to_s.downcase, ability["name"].to_s]
    end
  end

  def local_anti_caster_ability_ready?(ability)
    return false unless Ashborne_toolkit.ability_allowed?(ability["family"], ability["id"])

    return false if Ashborne_toolkit.noise_lockdown?
    return false if checkdead || checkstunned || webbed? || bound?
    return false if percenthealth.to_i < Ashborne_toolkit.health_floor
    return false if checkrt.to_f > 0 || checkcastrt.to_f > 0
    target = GameObj.target
    if ability["target_type"] == "undead"
      return false unless target && target.respond_to?(:type) && target.type.to_s =~ /undead/i
    end
    return false if ability["family"] != "spell" && percentstamina.to_i < Ashborne_toolkit.stamina_reserve

    case ability["family"]
    when "spell"
      spell = Spell[ability["id"].to_i]
      percentmana.to_i >= [Ashborne_toolkit.anti_caster_mana_reserve, Ashborne_toolkit.mana_reserve].max &&
        spell && spell.known? && spell.affordable?
    when "cman"
      CMan.available?(ability["name"]) && CMan.affordable?(ability["name"])
    when "shield"
      checkleft.to_s =~ /shield/i &&
        Shield.available?(ability["name"]) &&
        Shield.affordable?(ability["name"])
    when "armor"
      Armor.available?(ability["name"]) && Armor.affordable?(ability["name"])
    when "weapon"
      Weapon.available?(ability["name"]) && Weapon.affordable?(ability["name"])
    when "feat"
      Feat.available?(ability["name"]) && Feat.affordable?(ability["name"])
    else
      false
    end
  rescue
    false
  end

  def selected_anti_caster_response(event = nil, excluded_names = [])
    candidate = Ashborne_toolkit.ranked_group_anti_caster_responders(event, excluded_names).first
    return nil unless candidate

    character_name, ability, _profile = candidate
    return nil unless character_name.to_s.casecmp(Char.name.to_s).zero?

    ability
  end

  def noise_lockdown?
    $ashborne_noise_lockdown == "1"
  end

  def casting_allowed?
    !Ashborne_toolkit.noise_lockdown?
  end

  def start_owned_script(script_name)
    name = script_name.to_s
    return false if name.empty? || name == "0"
    return false unless Script.exists?(name)
    return false if Script.running?(name)

    do_client ";#{name}"
    $ashborne_owned_scripts ||= {}
    $ashborne_owned_scripts[name] = true
    true
  rescue
    false
  end

  def stop_owned_script(script_name)
    name = script_name.to_s
    return false unless defined?($ashborne_owned_scripts) && $ashborne_owned_scripts.delete(name)

    Script.kill(name) if Script.running?(name)
    true
  rescue
    false
  end

  def stop_noise_lockdown_casting_helpers
    return unless Ashborne_toolkit.noise_lockdown?

    CASTING_HELPER_SCRIPTS.each do |script_name|
      Script.kill(script_name) if Script.running?(script_name)
      $ashborne_owned_scripts.delete(script_name) if defined?($ashborne_owned_scripts)
    rescue
      nil
    end
  end

  def set_noise_lockdown_setting(value)
    normalized_value = value.to_s == "1" ? "1" : "0"
    character_names = [Char.name]
    leader_name = Settings[Char.name]['ashborne_setting_leader'].to_s
    character_names << leader_name unless leader_name.empty? || leader_name == "0"

    character_names.dup.each do |character_name|
      Settings[character_name] ||= Hash.new
      1.upto(9) do |member_number|
        member_name = Settings[character_name]["ashborne_setting_group_#{%w[zero one two three four five six seven eight nine][member_number]}"].to_s
        character_names << member_name unless member_name.empty? || member_name == "0"
      end
      character_names.concat(Settings[character_name]['ashborne_setting_group_additional'].to_s.split(/[;,\s]+/).reject { |name| name.empty? || name == "0" })
    end

    character_names.uniq.each do |character_name|
      Settings[character_name] ||= Hash.new
      Settings[character_name]['ashborne_setting_noise_lockdown'] = normalized_value
    end
    Settings.save

    Ashborne_toolkit.top_menu
    state = normalized_value == "1" ? "enabled" : "disabled"
    respond "Song of Noise melee lockdown #{state} for: #{character_names.uniq.join(', ')}."
    respond "Restart Ashborne on the group so every character loads the new mode."
    Ashborne_toolkit.bottom_menu
  end

  def maintain_noise_lockdown
    return true unless Ashborne_toolkit.noise_lockdown?
    Ashborne_toolkit.stop_noise_lockdown_casting_helpers
    return true unless Stats.prof == "Bard"
    return true if Spell.active? "1017"

    unless Spell[1017].known?
      Ashborne_toolkit.noise_lockdown_failure("the Bard does not know Song of Noise (1017)")
      return false
    end

    unless Spell[1017].affordable?
      Ashborne_toolkit.noise_lockdown_failure("the Bard lacks the 10 mana needed to start Song of Noise (1017)")
      return false
    end

    waitrt?
    waitcastrt?
    Spell[1017].cast()
    $ashborne_noise_warning_at = 0
    active_wait_until = Time.now + 2
    until Spell.active?("1017") || Time.now >= active_wait_until
      sleep 0.1
    end
    return true if Spell.active? "1017"

    Ashborne_toolkit.noise_lockdown_failure("Song of Noise (1017) did not become active")
    false
  rescue => error
    Ashborne_toolkit.noise_lockdown_failure("Song of Noise could not start: #{error.message}")
    false
  end

  def noise_lockdown_failure(reason)
    if Time.now.to_i >= $ashborne_noise_warning_at.to_i
      respond "#{Char.name}, noise lockdown unavailable because #{reason}."
      $ashborne_noise_warning_at = Time.now.to_i + 30
    end

    if $ashborne_group_ai != "0"
      Ashborne_toolkit.publish_group_danger("noise lockdown unavailable: #{reason}")
      Ashborne_toolkit.apply_group_danger_abort
    else
      $ashborne_return_why = "Noise lockdown unavailable: #{reason}."
      $ashborne_action = 99
    end
    false
  end

  def noise_lockdown_attack_round
    Ashborne_toolkit.waitcast_waitrt
    Ashborne_toolkit.stand_check

    if $ashborne_my_style == "1" || $ashborne_my_style == "2"
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.hide_time if $ashborne_my_style == "2"
      Ashborne_toolkit.uac_round
      return
    end

    if $ashborne_my_style =~ /5|6|7|8/
      fput "store ranged"
      fput "ready weapon" if checkright.nil?
    end

    Ashborne_toolkit.mstrike_routine if $ashborne_my_style =~ /3|4/
    Ashborne_toolkit.hide_time if $ashborne_my_style == "4"
    Ashborne_toolkit.stance_offensive
    if $ashborne_my_style == "4" && checkhidden
      Ashborne_toolkit.chicken_ambush
    else
      Ashborne_toolkit.chicken_attack
    end
  end

  def customize_block_1
    nil
  end

  def ashborne_feedback
    respond
    respond "Hello #{Char.name}, I'm Ashborne."
    respond
    respond "My stay offensive setting is - #{$ashborne_stay_offensive}"
  end

  def top_menu
    respond "|0-100 Hunting Script - Please do not AFK Script in Prime.|"
    respond
  end

  def bottom_menu
    respond
    respond "|---------------------------------------------------------|"
  end

