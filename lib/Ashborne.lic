  def get_wands
    # respond "DEBUG Get_wands"
    # respond "#{$ashborne_current_wand_name} is my current wand name."
    # respond "#{$ashborne_current_wand_noun} is my current wand noun."
    # respond "#{$ashborne_use_wands} is my use wands setting."
    # respond "#{$ashborne_dead_wands} is my dead wands container."

    # Add in some kind of check if it's a wand or rod here
    sleep 0.10
    result = dothistimeout "get my #{$ashborne_current_wand_noun} from my #{Vars.wandsack}", 5, /Get what|You remove a|need a free hand|You retrieve an/
    sleep 0.10
    if result =~ /Get what/

      # Check for rods
      $ashborne_current_wand_noun = "rod"
      result = dothistimeout "get my #{$ashborne_current_wand_noun} from my #{Vars.wandsack}", 5, /Get what|You remove a|need a free hand|You retrieve an/

      if result =~ /Get what/

        # Turn off feature
        $ashborne_combat_wands = "0"
        $ashborne_use_wands = "0"

      else
        # $ashborne_current_wand_name = "Placeholder"
        Ashborne_toolkit.identify_wand_ability
      end
    else
      # $ashborne_current_wand_name = "Placeholder"
      Ashborne_toolkit.identify_wand_ability
    end
  end

  def identify_wand_ability
    sleep 0.25
    # respond "DEBUG Wand ability"

    # Aim Wands

    if GameObj.right_hand.name =~ /silver wand/
      $ashborne_current_wand_name = "silver wand"
    elsif GameObj.left_hand.name =~ /silver wand/
      $ashborne_current_wand_name = "silver wand"

    elsif GameObj.right_hand.name =~ /iron wand/
      $ashborne_current_wand_name = "iron wand"
    elsif GameObj.left_hand.name =~ /iron wand/
      $ashborne_current_wand_name = "iron wand"

    elsif GameObj.right_hand.name =~ /aquamarine wand/
      $ashborne_current_wand_name = "aquamarine wand"
    elsif GameObj.left_hand.name =~ /aquamarine wand/
      $ashborne_current_wand_name = "aquamarine wand"

    elsif GameObj.right_hand.name =~ /crystal wand/
      $ashborne_current_wand_name = "crystal wand"
    elsif GameObj.left_hand.name =~ /crystal wand/
      $ashborne_current_wand_name = "crystal wand"

    elsif GameObj.right_hand.name =~ /ebony wand/
      $ashborne_current_wand_name = "grooved ebony wand"
    elsif GameObj.left_hand.name =~ /ebony wand/
      $ashborne_current_wand_name = "grooved ebony wand"

    elsif GameObj.right_hand.name =~ /golden wand/
      $ashborne_current_wand_name = "golden wand"
    elsif GameObj.left_hand.name =~ /golden wand/
      $ashborne_current_wand_name = "golden wand"

    elsif GameObj.right_hand.name =~ /metal wand/
      $ashborne_current_wand_name = "metal wand"
    elsif GameObj.left_hand.name =~ /metal wand/
      $ashborne_current_wand_name = "metal wand"

    elsif GameObj.right_hand.name =~ /blue wand/
      $ashborne_current_wand_name = "slender blue wand"
    elsif GameObj.left_hand.name =~ /blue wand/
      $ashborne_current_wand_name = "slender blue wand"

    elsif GameObj.right_hand.name =~ /coral wand/
      $ashborne_current_wand_name = "green coral wand"
    elsif GameObj.left_hand.name =~ /coral wand/
      $ashborne_current_wand_name = "green coral wand"

    elsif GameObj.right_hand.name =~ /willow wand/
      $ashborne_current_wand_name = "spiraled willow wand"
    elsif GameObj.left_hand.name =~ /willow wand/
      $ashborne_current_wand_name = "spiraled willow wand"

    elsif GameObj.right_hand.name =~ /topaz wand/
      $ashborne_current_wand_name = "faceted topaz wand"
    elsif GameObj.left_hand.name =~ /topaz wand/
      $ashborne_current_wand_name = "faceted topaz wand"

    elsif GameObj.right_hand.name =~ /opal wand/
      $ashborne_current_wand_name = "iridescent opal wand"
    elsif GameObj.left_hand.name =~ /opal wand/
      $ashborne_current_wand_name = "iridescent opal wand"

    elsif GameObj.right_hand.name =~ /crystalline wand/
      $ashborne_current_wand_name = "smooth crystalline wand"
    elsif GameObj.left_hand.name =~ /crystalline wand/
      $ashborne_current_wand_name = "smooth crystalline wand"

    elsif GameObj.right_hand.name =~ /mithril wand/
      $ashborne_current_wand_name = "slender mithril wand"
    elsif GameObj.left_hand.name =~ /mithril wand/
      $ashborne_current_wand_name = "slender mithril wand"

    elsif GameObj.right_hand.name =~ /amethyst wand/
      $ashborne_current_wand_name = "faceted amethyst wand"
    elsif GameObj.left_hand.name =~ /amethyst wand/
      $ashborne_current_wand_name = "faceted amethyst wand"

    elsif GameObj.right_hand.name =~ /azure rod/
      $ashborne_current_wand_name = "slender azure rod"
      $ashborne_current_wand_noun = "rod"
    elsif GameObj.left_hand.name =~ /crimson rod/
      $ashborne_current_wand_name = "slender crimson rod"
      $ashborne_current_wand_noun = "rod"


    # CS Wands
    elsif GameObj.right_hand.name =~ /twisted wand/
      $ashborne_current_wand_name = "twisted wand"
    elsif GameObj.left_hand.name =~ /twisted wand/
      $ashborne_current_wand_name = "twisted wand"

    elsif GameObj.right_hand.name =~ /beryl wand/
      $ashborne_current_wand_name = "lustrous beryl wand"
    elsif GameObj.left_hand.name =~ /beryl wand/
      $ashborne_current_wand_name = "lustrous beryl wand"

    elsif GameObj.right_hand.name =~ /bone wand/
      $ashborne_current_wand_name = "smooth bone wand"
    elsif GameObj.left_hand.name =~ /bone wand/
      $ashborne_current_wand_name = "smooth bone wand"

    elsif GameObj.right_hand.name =~ /witchwood wand/
      $ashborne_current_wand_name = "grooved witchwood wand"
    elsif GameObj.left_hand.name =~ /witchwood wand/
      $ashborne_current_wand_name = "grooved witchwood wand"

    elsif GameObj.right_hand.name =~ /ivory wand/
      $ashborne_current_wand_name = "slender ivory wand"
    elsif GameObj.left_hand.name =~ /ivory wand/
      $ashborne_current_wand_name = "slender ivory wand"








    # Dispose
    elsif GameObj.right_hand.name =~ /glass wand/
      $ashborne_current_wand_name = "clear glass wand"
    elsif GameObj.left_hand.name =~ /glass wand/
      $ashborne_current_wand_name = "clear glass wand"

    elsif GameObj.right_hand.name =~ /amber wand/
      $ashborne_current_wand_name = "smooth amber wand"
    elsif GameObj.left_hand.name =~ /amber wand/
      $ashborne_current_wand_name = "smooth amber wand"

    elsif GameObj.right_hand.name =~ /thanot wand/
      $ashborne_current_wand_name = "pale thanot wand"
    elsif GameObj.left_hand.name =~ /thanot wand/
      $ashborne_current_wand_name = "pale thanot wand"

    elsif GameObj.right_hand.name =~ /bloodwood wand/
      $ashborne_current_wand_name = "polished bloodwood wand"
    elsif GameObj.left_hand.name =~ /bloodwood wand/
      $ashborne_current_wand_name = "polished bloodwood wand"

    elsif GameObj.right_hand.name =~ /oaken wand/
      $ashborne_current_wand_name = "oaken wand"
    elsif GameObj.left_hand.name =~ /oaken wand/
      $ashborne_current_wand_name = "oaken wand"

    elsif GameObj.right_hand.name =~ /grey crystal wand/
      $ashborne_current_wand_name = "wavy grey crystal wand"
    elsif GameObj.left_hand.name =~ /grey crystal wand/
      $ashborne_current_wand_name = "wavy grey crystal wand"

    elsif GameObj.right_hand.name =~ /dark crystal wand/
      $ashborne_current_wand_name = "shadowy dark crystal wand"
    elsif GameObj.left_hand.name =~ /dark crystal wand/
      $ashborne_current_wand_name = "shadowy dark crystal wand"

    elsif GameObj.right_hand.name =~ /prismatic wand/
      $ashborne_current_wand_name = "clear prismatic wand"
    elsif GameObj.left_hand.name =~ /prismatic wand/
      $ashborne_current_wand_name = "clear prismatic wand"

    elsif GameObj.right_hand.name =~ /sapphire wand/
      $ashborne_current_wand_name = "spiraled sapphire wand"
    elsif GameObj.left_hand.name =~ /sapphire wand/
      $ashborne_current_wand_name = "spiraled sapphire wand"

    elsif GameObj.right_hand.name =~ /yew wand/
      $ashborne_current_wand_name = "gnarled yew wand"
    elsif GameObj.left_hand.name =~ /yew wand/
      $ashborne_current_wand_name = "gnarled yew wand"

    elsif GameObj.right_hand.name =~ /alabaster wand/
      $ashborne_current_wand_name = "sleek alabaster wand"
    elsif GameObj.left_hand.name =~ /alabaster wand/
      $ashborne_current_wand_name = "sleek alabaster wand"








    else
      # respond "DEBUG I could not find a wand I could use."
      $ashborne_combat_wands = "0"
      $ashborne_use_wands = "0"
      $ashborne_current_wand_name = "0"
    end
  end

  def wand_aim_check
    if Skills.spellaiming >= 1
      Ashborne_toolkit.stance_offensive
      Ashborne_toolkit.activate_wands
      Ashborne_toolkit.stance_defensive
    else
      Ashborne_toolkit.dispose_wand
    end
  end

  def use_wands
    # respond "DEBUG use_wands"
    Ashborne_toolkit.get_wands if $ashborne_current_wand_name == "0"
    Ashborne_toolkit.identify_wand_ability if $ashborne_current_wand_name == "0"

    # Aim Wands

    if $ashborne_current_wand_name == "silver wand"
      if $ashborne_my_area =~ /wldirge|wlillokeelder/
        Ashborne_toolkit.dispose_wand
      else
        Ashborne_toolkit.wand_aim_check
      end
    elsif $ashborne_current_wand_name == "iron wand"
      if $ashborne_my_area =~ /wldirge|wlillokeelder/
        Ashborne_toolkit.dispose_wand
      else
        Ashborne_toolkit.wand_aim_check
      end
    elsif $ashborne_current_wand_name == "aquamarine wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "crystal wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "grooved ebony wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "golden wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "metal wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "slender blue wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "green coral wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "spiraled willow wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "faceted topaz wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "iridescent opal wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "smooth crystalline wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "slender mithril wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "faceted amethyst wand"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "slender azure rod"
      Ashborne_toolkit.wand_aim_check
    elsif $ashborne_current_wand_name == "slender crimson rod"
      Ashborne_toolkit.wand_aim_check




    # CS Wands

    elsif $ashborne_current_wand_name == "twisted wand"
      Ashborne_toolkit.activate_wands
    elsif $ashborne_current_wand_name == "lustrous beryl wand"
      Ashborne_toolkit.activate_wands
    elsif $ashborne_current_wand_name == "smooth bone wand"
      Ashborne_toolkit.activate_wands
    elsif $ashborne_current_wand_name == "grooved witchwood wand"
      Ashborne_toolkit.activate_wands
    elsif $ashborne_current_wand_name == "slender ivory wand"
      Ashborne_toolkit.activate_wands


    # Dispose Wands

    elsif $ashborne_current_wand_name == "oaken wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "polished bloodwood wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "clear glass wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "smooth amber wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "pale thanot wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "wavy grey crystal wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "shadowy dark crystal wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "clear prismatic wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "spiraled sapphire wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "gnarled yew wand"
      Ashborne_toolkit.dispose_wand
    elsif $ashborne_current_wand_name == "sleek alabaster wand"
      Ashborne_toolkit.dispose_wand


    end
  end

  def dispose_wand
    # respond "DEBUG put wand in dead container"
    # Put wand in deadwand container
    if $ashborne_dead_wands == "0"
      if $ashborne_wand_warning == "0"
        Ashborne_toolkit.top_menu
        respond "#{Char.name}, you do not have a dead wand container set."
        respond
        respond "I'll start dropping all non combat or dead wands."
        respond
        respond "I suggest you ;ka your scripts and set your deadwands container."
        respond
        respond ";ashborne setup change deadwands pack"
        respond
        respond "Pick a container that is not your lootsack."
        Ashborne_toolkit.bottom_menu
        $ashborne_wand_warning = "1"
        sleep 2
      end
      if checkright == "#{$ashborne_current_wand_noun}"
        fput "drop right"
        $ashborne_current_wand_name = "0"
        $ashborne_recent_dead_wand = "1"
      elsif checkleft == "#{$ashborne_current_wand_noun}"
        fput "drop left"
        $ashborne_current_wand_name = "0"
        $ashborne_recent_dead_wand = "1"
      end
    else
      # Dead Wand Container Is set
      # respond "DEBUG wand container is set"
      if checkright == "#{$ashborne_current_wand_noun}"
        fput "put my #{$ashborne_current_wand_noun} in my #{$ashborne_dead_wands}"
        $ashborne_current_wand_name = "0"
        $ashborne_recent_dead_wand = "1"
      elsif checkleft == "#{$ashborne_current_wand_noun}"
        fput "put my #{$ashborne_current_wand_noun} in my #{$ashborne_dead_wands}"
        $ashborne_current_wand_name = "0"
        $ashborne_recent_dead_wand = "1"
      end
    end
  end

  def activate_wands
    # respond "DEBUG activate_wands"
    result = dothistimeout "wave my #{$ashborne_current_wand_noun} at #{$ashborne_current_target}", 3, /Cast Roundtime|You wave to a|PLACEHOLDER|What were you referring/

    if result =~ /Cast Roundtime/
    # respond "DEBUG Cast Roundtime from wand"
    # Wand is still Active
    elsif result =~ /You wave to a/
      # respond "DEBUG You are not holding a wand, let's reset wand name."
      $ashborne_current_wand_name = "0"
    elsif result =~ /What were you referring/
      # respond "DEBUG You are not holding a wand, let's reset wand name."
      $ashborne_current_wand_name = "0"
    else
      Ashborne_toolkit.dispose_wand
    end
  end

  def upkeep_quartz
    if $ashborne_my_style != "9"
      nil

    elsif $ashborne_noquartz == "1"
      # respond "no quartz feature is turned on."
      nil

    else
      if Spell.active? "1711"
        # respond "1711 is active."
        nil
      else
        result = dothistimeout "get my quartz orb", 5, /Get what|You remove a/

        if result =~ /Get what/
          $ashborne_noquartz = "1"
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, you don't have any quartz orbs for this hunt.  I'll stop trying to find them."
          respond
          respond "You can disable the quartz orb feature with ;ashborne setup change noquartz 1 "
          Ashborne_toolkit.bottom_menu
        else
          fput "rub my quartz orb"
          fput "stow my quartz orb"
          waitrt?
          waitcastrt?
          sleep 1
        end
      end
    end
  end

  def empath_self_heal
    if checkmana < 30
      $ashborne_return_why = "Insufficient resources. You are injured or have major scars." unless $ashborne_use_herbs == "1"
      $ashborne_action = 99 unless $ashborne_use_herbs == "1"
    else
      if Wounds.head >= 1 || Scars.head >= 2
        fput "cure head"
      elsif Wounds.neck >= 1 || Scars.neck >= 2
        fput "cure neck"
      elsif Wounds.abs >= 1 || Scars.abs >= 2
        fput "cure abdomen"
      elsif Wounds.lhand >= 1 || Scars.lhand >= 2
        fput "cure left hand"
      elsif Wounds.rhand >= 1 || Scars.rhand >= 2
        fput "cure right hand"
      elsif Wounds.larm >= 1 || Scars.larm >= 2
        fput "cure left arm"
      elsif Wounds.rarm >= 1 || Scars.rarm >= 2
        fput "cure right arm"
      elsif Wounds.lleg >= 1 || Scars.lleg >= 2
        fput "cure left leg"
      elsif Wounds.rleg >= 1 || Scars.rleg >= 2
        fput "cure right leg"
      elsif Wounds.leye >= 1 || Scars.leye >= 2
        fput "cure left eye"
      elsif Wounds.reye >= 1 || Scars.reye >= 2
        fput "cure right eye"
      elsif Wounds.chest >= 1 || Scars.chest >= 2
        fput "cure chest"
      elsif Wounds.back >= 1 || Scars.back >= 2
        fput "cure back"
      elsif Wounds.nerves >= 1 || Scars.nerves >= 2
        fput "cure nerves"
      end
    end
  end

  def confirm_settings
    respond "#{Char.name}, Settings have been updated."
  end


  # Bounty Toolkit

  def bounty_debug
    if $ashborne_qc_debug == "1"
      respond "Bounty Debug"
      respond "$ashborne my area is #{$ashborne_my_area}"
      respond "$ashborne_bounty_intel_watch is #{$ashborne_bounty_intel_watch}"
      respond "$ashborne_bounty_stage is #{$ashborne_bounty_stage}"
      respond "$ashborne_bounty_type is #{$ashborne_bounty_type}"
      respond "$ashborne_bounty_town is #{$ashborne_bounty_town}"
      respond "$ashborne_bounty_guard is #{$ashborne_bounty_guard}"
      respond "$ashborne_bounty_creature_name is #{$ashborne_bounty_creature_name}"
      respond "$ashborne_bounty_ready_to_launch is #{$ashborne_bounty_ready_to_launch}"
      respond "$ashborne_bounty_fast is #{$ashborne_bounty_fast}"
      respond "$ashborne_bounty_heirloom_name is #{$ashborne_bounty_heirloom_name}"
      respond "$ashborne_bounty_heirloom_type is #{$ashborne_bounty_heirloom_type}"
      respond "$ashborne_bounty_creature_match is #{$ashborne_bounty_creature_match}"
      respond "$ashborne_bounty_debug_cooldown is #{$ashborne_bounty_debug_cooldown}"
      respond "$ashborne_bounty_bandit_buddy is #{$ashborne_bounty_bandit_buddy}"
      respond "$ashborne_no_bounty_boost_zonk is #{$ashborne_no_bounty_boost_zonk}"
      respond "$ashborne_no_expedite_vouchers_zonk is #{$ashborne_no_expedite_vouchers_zonk}"



    end
  end

