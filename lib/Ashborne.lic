elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /flee/
  Settings[Char.name]['ashborne_setting_flee']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit


elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /boostlong/
  Settings[Char.name]['ashborne_setting_boost_long']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase == nil
  Ashborne_toolkit.top_menu
  respond "#{Char.name}, that does not appear to be a valid setting."
  respond
  respond "Use ;ashborne help for commands and setup options."
  # Ashborne_toolkit.help
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /(.*)/
  Ashborne_toolkit.top_menu
  respond "#{Char.name}, that does not appear to be a valid setting."
  respond
  respond "Use ;ashborne help for commands and setup options."
  # Ashborne_toolkit.help
  Ashborne_toolkit.bottom_menu
  exit

elsif script.vars[1].downcase =~ /setup/
  Ashborne_toolkit.top_menu
  ashborne_setup.call
  Ashborne_toolkit.bottom_menu
  exit
end

# Cleanup Check
if script.vars[1].downcase =~ /cleanup/
  ashborne_load_settings.call
  Ashborne_toolkit.ashborne_intel_service_check
  Ashborne_toolkit.cleanup
  exit
end

# Nil Room Check

Ashborne_toolkit.check_nil unless script.vars[2].downcase =~ /qlite|quick|grounded/



Ashborne_toolkit.cman_debugger

# Variables load better with a proc compared to oop.
# You can call global variables starting with $ inside oop.
# Can pull setup options through here.

ashborne_load_settings.call

Ashborne_toolkit.cman_debugger

# User Error Trap
ashborne_error_trap.call

# Ready before waiting so the leader can defend the starting room.
ashborne_ready_gear.call

# Followers may receive the remote command before the game group finishes updating.
if $ashborne_group_ai == "2"
  unless Ashborne_toolkit.wait_for_follower_group
    Ashborne_toolkit.top_menu
    respond "#{Char.name} could not verify #{$ashborne_captain} as the game group leader."
    respond "Ashborne stayed in town and stopped instead of hunting outside the configured group."
    Ashborne_toolkit.bottom_menu
    ashborne_kill_script.call
    exit
  end
  Ashborne_toolkit.publish_group_state(true)
  unless Ashborne_toolkit.wait_for_follower_full_group
    Ashborne_toolkit.top_menu
    respond "#{Char.name} joined #{$ashborne_captain}, but the configured group did not finish assembling."
    respond "Ashborne stayed defensive and stopped instead of entering combat with an incomplete group."
    Ashborne_toolkit.bottom_menu
    ashborne_kill_script.call
    exit
  end
end

# Assemble the physical group and require follower Ashborne acknowledgments before hunting.
if $ashborne_group_ai == "1"
  unless Ashborne_toolkit.prepare_group_startup
    Ashborne_toolkit.top_menu
    respond "Ashborne will not leave without the configured group."
    respond "Fix the missing followers or group membership, then restart the hunt."
    Ashborne_toolkit.bottom_menu
    ashborne_kill_script.call
    exit
  end
end

# Run Setup Scripts
ashborne_run_script.call unless $ashborne_zonescripts == "1"

Ashborne_toolkit.publish_group_state(true)
Ashborne_toolkit.coordinate_group_looter if $ashborne_group_ai == "1"
Ashborne_toolkit.install_environmental_danger_hook
Ashborne_toolkit.install_self_danger_hook
Ashborne_toolkit.install_disarm_recovery_hook
Ashborne_toolkit.install_anti_caster_hook
if $ashborne_preflight == "1" && ($ashborne_group_ai != "0" || Ashborne_toolkit.noise_lockdown?)
  unless Ashborne_toolkit.preflight_report(true)
    Ashborne_toolkit.remove_environmental_danger_hook
    Ashborne_toolkit.remove_self_danger_hook
    Ashborne_toolkit.remove_disarm_recovery_hook
    Ashborne_toolkit.remove_anti_caster_hook
    ashborne_kill_script.call
    exit
  end
end
$ashborne_startup_ready = "1"
Ashborne_toolkit.publish_group_state(true)
Ashborne_toolkit.publish_group_plan if $ashborne_group_ai == "1"

unless $ashborne_qfollow == "1" || $ashborne_group_ai == "2"
  Ashborne_toolkit.top_menu
  respond "Ashborne hunt schedule: #{$ashborne_hunt_cycle} of #{$ashborne_hunt_cycles}; repeat at #{$ashborne_rest_mind}% mind."
  respond "Rest actions: healing=#{$ashborne_rest_healing == '1' ? 'on' : 'off'}, empath request=#{$ashborne_rest_ask_empath == '1' ? 'on' : 'off'}, selling=#{$ashborne_rest_sell == '1' ? 'on' : 'off'}."
  Ashborne_toolkit.bottom_menu
end

# Initial Intel Check
Ashborne_toolkit.ashborne_intel_service_check

# Kroderine Soul Check
if Stats.prof =~ /Warrior|Rogue|Monk/
  fput "feat dispel"
end

# Stop looking for your cman abilities.
$ashborne_cman_watch = "0"

# Go to the hunting zone and escape from a nil room. Followers stay with the
# leader instead of pathing to the hunting area on their own.
ashborne_hunting_zones.call unless $ashborne_qfollow == "1" || $ashborne_group_ai == "2"



# Run Setup ZoneScripts
ashborne_run_script.call if $ashborne_zonescripts == "1"




# Personal Debugger
# ashborne_feedback.call
# Ashborne_toolkit.ashborne_feedback

# Pre Loop Group Check
ashborne_group_cluster.call
Ashborne_toolkit.maintain_noise_lockdown if Ashborne_toolkit.noise_lockdown? && Stats.prof == "Bard"
# if $ashborne_group_ai == "1"
#	until $ashborne_group_counter == $ashborne_group_array.length
#		ashborne_group_check.call
#		sleep 1
#	end
# end

# Leaders and solo hunters use the main hunting loop. Followers and quick-follow
# characters continue into their dedicated loops below.
unless $ashborne_qfollow == "1" || $ashborne_group_ai == "2"
loop {
  # Ashborne_toolkit.milk_carton
  # respond "Debug Output - Loop starting."
  # respond "Debug Output - Intel Check."
  Ashborne_toolkit.ashborne_intel_service_check
  Ashborne_toolkit.infomon_check
  # respond "Debug Output - Setup Call."
  ashborne_setup.call if $ashborne_consider_setup == "1"
  # respond "Debug Output - Status Check 1."
  Ashborne_toolkit.boost_long
  Ashborne_toolkit.boost_loot
  Ashborne_toolkit.upkeep_quartz
  ashborne_status_check.call
  Ashborne_toolkit.emergency_return_to_town_if_needed if $ashborne_group_danger_active == "1"
  # Check for all group members
  # respond "Debug Output - Group Cluster."
  ashborne_group_cluster.call
  # respond "Debug Output - Group Support."
  ashborne_group_support.call
  # respond "Debug Output - Status Check 2."
  # respond "Debug Output - Upkeep Buffs."
  ashborne_upkeep_buffs.call
  # ashborne_upkeep_society.call
  # respond "Debug Output - Status Check 3."
  # respond "Debug Output - Game Obj Check."
  ashborne_gameobj_check.call

  # Ashborne Action Choice

  # respond "Debug Output - Ashborne Action Choice"
  # respond "My $ashborne action is #{$ashborne_action}."
  if $ashborne_action == 0
    $ashborne_action = 6

  elsif $ashborne_action == 6
    # respond "Debug Output - Starting Movemgr in loop"
    Ashborne_toolkit.movemgr

  elsif $ashborne_action == 7
    # respond "Debug Output - Starting combat in loop"
    if $ashborne_recent_eviction != "0" && GameObj.targets.empty?
      $ashborne_recent_eviction = "0"
    else
      $ashborne_recent_eviction = "0" unless GameObj.targets.empty?
      Ashborne_toolkit.combat_unique_to_ashborne
    end

  elsif $ashborne_action == 95

    if $grounded_no_room_id_notice == 0

      if Ashborne_toolkit.current_room_id.nil?

        if $grounded_no_room_id_notice == 0
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, you are running grounded mode in an unmapped room."
          respond
          respond "Since I can't figure out what room to stay in, it is up to you to ;kill ashborne when you want to stop."
          Ashborne_toolkit.bottom_menu
          $grounded_no_room_id_notice = 1
        end
      else
        $grounded_no_room_id_notice = 1
      end
    else
      nil
    end


    ashborne_setup.call if $ashborne_consider_setup == "1"
    if GameObj.targets.length >= 1

      ashborne_upkeep_buffs.call
      Ashborne_toolkit.target_check
      Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_recent_eviction == "1"
      $ashborne_recent_eviction = "0" if $ashborne_recent_eviction == "1"

    end



    sleep 0.5



    if Ashborne_toolkit.current_room_id != $ashborne_my_room_number

      Ashborne_toolkit.script_kill

      Ashborne_toolkit.top_menu
      if $ashborne_my_room_number.to_s.empty? || $ashborne_my_room_number.nil?
        respond "#{Char.name}, you're no longer grounded in your unmapped room(s).  Aborting combat."
      else
        respond "#{Char.name}, you're no longer grounded in room #{$ashborne_my_room_number}.  Aborting combat."
      end
      Ashborne_toolkit.bottom_menu
      exit
    end







  elsif $ashborne_action == 96

    ashborne_run_script.call

    if Ashborne_toolkit.current_room_id == 24550
      if Stats.prof == "Wizard"
        waitcastrt?
        Spell[418].cast() if Spell[418].known? && Stats.level >= 18 && Spell[418].affordable?
        waitcastrt?
      end
    else
      Ashborne_toolkit.top_menu
      respond "#{Char.name}, you're not in room 24550 [Duskruin Arena, Dueling Sands] (Duskruin Arena). Return to that room and try again."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.group_kill_scripts
      exit
    end

    until Ashborne_toolkit.current_room_id != 24550
      ashborne_setup.call if $ashborne_consider_setup == "1"
      if GameObj.targets.length >= 1

        Ashborne_toolkit.deed_mana
        ashborne_upkeep_buffs.call
        Ashborne_toolkit.target_check
        Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_recent_eviction == "1"
        $ashborne_recent_eviction = "0" if $ashborne_recent_eviction == "1"

      end

      if percentmana <= 15 || percentstamina <= 15
        if $ashborne_drpray_counter == 3
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, you've already prayed 3 times this match.  You can continue to PRAY manually but bad things may happen.  To give up, SURRENDER."
          Ashborne_toolkit.bottom_menu
          $ashborne_drpray_counter = 4
        elsif $ashborne_drpray_counter >= 4
          nil
        else
          $ashborne_drpray_counter = $ashborne_drpray_counter + 1
          Ashborne_toolkit.waitcast_waitrt
          fput "pray"
          Ashborne_toolkit.waitcast_waitrt
        end
      end

      sleep 0.5
    end

    Ashborne_toolkit.script_kill

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, you're no longer inside the DR Arena. Aborting combat."
    Ashborne_toolkit.bottom_menu
    exit



  elsif $ashborne_action == 97

    ashborne_run_script.call

    until GameObj.targets.length < 1

      ashborne_setup.call if $ashborne_consider_setup == "1"
      ashborne_upkeep_buffs.call
      Ashborne_toolkit.target_check
      Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_recent_eviction == "1"
      $ashborne_recent_eviction = "0" if $ashborne_recent_eviction == "1"

    end

    Ashborne_toolkit.script_kill



    Ashborne_toolkit.top_menu
    respond "#{Char.name}, no more targets to kill."
    Ashborne_toolkit.bottom_menu
    exit



  elsif $ashborne_action == 98
    # respond "Debug Output - I've been evicted in the loop."
    $ashborne_recent_eviction = "0"
    Ashborne_toolkit.evicted

  elsif $ashborne_action == 99
    # respond "Debug Output - I am being told to go home in the loop."
    # Return to Safe Room
    next if Ashborne_toolkit.clear_stale_wrong_equipment_return_if_combat_progress

    $ashborne_right_hand_detect = "#{checkright}" unless checkright == nil
    $ashborne_left_hand_detect = "#{checkleft}" unless checkleft == nil

    Settings[Char.name]['ashborne_setting_right_hand_detect']	= "#{$ashborne_right_hand_detect}" unless $ashborne_right_hand_detect == "0"
    Settings[Char.name]['ashborne_setting_left_hand_detect']	= "#{$ashborne_left_hand_detect}" unless $ashborne_left_hand_detect == "0"
    Settings.save

    ashborne_kill_script.call

    Ashborne_toolkit.emergency_return_to_town_if_needed if $ashborne_group_danger_active == "1"

    if $ashborne_my_area =~ /qlite|quick|drarena|drlite|grounded/
      Ashborne_toolkit.top_menu
      respond "I aborted combat because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.group_kill_scripts
      exit
    end

    if $ashborne_my_society == "Voln" && percenthealth <= 50
      waitrt?
      fput "sym restoration"
      fput "sym restoration"
    end

    Ashborne_toolkit.unhide_before_group_travel("fog return")
    if ashborne_setting_voln_fog != "0" && ashborne_setting_character_society == "Voln"
      fput "symbol of return"
      $ashborne_recent_escape = "1"
      sleep 1

    end

    # Dangerous Area 130 Escape
    if $ashborne_my_area =~ /rift1|rift2|rift3|rift4|rift5|northscatter|southscatter|tiotfnorth/
      Spell[130].cast() if Spell[130].known? && Stats.level >= 30 && Spell[130].affordable? unless $ashborne_recent_escape == "1"
      $ashborne_recent_escape = "1"
      sleep 1
    end

    if ashborne_setting_130_fog != "0"
      Spell[130].cast() if Spell[130].known? && Stats.level >= 30 && Spell[130].affordable? unless $ashborne_recent_escape == "1"
      sleep 1
      $ashborne_recent_escape = "0"
    else
      nil
    end

    if ashborne_setting_1020_fog != "0"
      Spell[1020].cast() if Spell[1020].known? && Stats.level >= 20 && Spell[1020].affordable?
      sleep 1
    else
      nil
    end




    Ashborne_toolkit.safe_room_default

  end


  ashborne_zone_reset_check.call
}
end







# Group followers use this loop and react to the leader's attacks.
if $ashborne_group_ai == "2" && $ashborne_qfollow != "1"
Ashborne_toolkit.follower_status_notice_rc18
loop {
  # respond "I'm in tailmode"
  sleep 0.1
  Ashborne_toolkit.process_follower_control_requests_rc15
  Ashborne_toolkit.publish_group_state
  Ashborne_toolkit.upkeep_quartz
  Ashborne_toolkit.ashborne_intel_service_check
  Ashborne_toolkit.infomon_check
  ashborne_setup.call if $ashborne_consider_setup == "1"
  Ashborne_toolkit.boost_long
  # Ashborne_toolkit.boost_loot
  ashborne_group_status_check.call unless $ashborne_follow_mode == "1"
  Ashborne_toolkit.group_danger_retreat_if_needed
  ashborne_group_support.call unless $ashborne_follow_mode == "1"
  Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") if GameObj.dead.length >= 1 && (GameObj.targets.empty? || Ashborne_toolkit.urgent_loot_needed?)
  Ashborne_toolkit.boost_long
  ashborne_upkeep_buffs.call

  # if checkgrouped

  # respond "Tailmode"
  # respond "Debug Output - I'm grouped."
  # elsif !checkgrouped && checkpcs "#{$ashborne_captain}"
  # respond "Debug Output - I'm not in a group but I'm with the captain."
  # elsif !checkgrouped && !checkpcs "#{$ashborne_captain}"
  # respond "Debug Output - I'm not in a group and the #captain is missing."
  # end

  if $ashborne_follow_mode == "0"
    if checkpcs "#{$ashborne_captain}"
      # respond "Debug Output - I'm with the captain."
      sleep 0.1
    else
      # Ashborne_toolkit.milk_carton

      # Old logic for lost follower
      # respond "Debug Output - Default ELSE, no conditions met."
      # respond "#{Char.name}, I've lost the group leader #{$ashborne_captain}."

      # Ashborne_toolkit.room_nil_walk
      # Ashborne_toolkit.group_find_leader
      # if Ashborne_toolkit.current_room_id == "#{$ashborne_leader_location}"
      #	fput "group open"
      #	fput "join #{$ashborne_captain}"
      #	FileUtils.rm "#{$lich_dir}/scripts/ashborne_lost.lic" if Script.exists? "ashborne_lost"
      # else
      #	nil
      # end

    end
  else
    nil
  end


  # if Script.exists? "ashborne_gcombat"
  #		if GameObj.targets.length >= 1
  #			Ashborne_toolkit.target_check unless $ashborne_group_peace == "1"
  #			Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_group_peace == "1"
  #		else
  #			nil
  #		end
  # sleep 1
  # end

  result = matchtimeout(1, /#{$ashborne_captain} (swings|gestures|fires|attempts to|skillfully weaves|punches with|channels|rushes forward|thrusts with|thrusts with a|lunges at|waves a|launches a .* bash|lashes out with an? awesome shield bash|attempts a shield bash|looping .*? lashes out in a strike|brings .*? around to pummel|sweeping .*? out low to .*? launches a quick bash|whirls in a fury of unrelenting strikes|mstrikes?|starts to climb|begins to climb|begins climbing|begins to descend|confidently climbs|gracefully climbs|climbs up|climbs down|goes through|squeezes through|crawls through|pushes through|pulls open|opens .*door|enters)/).to_s

  if result =~ /#{$ashborne_captain} (swings|gestures|fires|attempts to|skillfully weaves|punches with|channels|thrusts with|rushes forward|thrusts with a|lunges at|waves a|launches a .* bash|lashes out with an? awesome shield bash|attempts a shield bash|looping .*? lashes out in a strike|brings .*? around to pummel|sweeping .*? out low to .*? launches a quick bash|whirls in a fury of unrelenting strikes|mstrikes?)/
    Ashborne_toolkit.target_check unless $ashborne_group_peace == "1"
    Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_group_peace == "1"
  elsif result =~ /#{$ashborne_captain} (starts to climb|begins to climb|begins climbing|begins to descend|confidently climbs|gracefully climbs|climbs up|climbs down|goes through|squeezes through|crawls through|pushes through|pulls open|opens .*door|enters)/
    Ashborne_toolkit.handle_leader_obstacle_event(result)
  else
    Ashborne_toolkit.group_follow_sync
    if GameObj.targets.length >= 1 && $ashborne_group_peace != "1"
      Ashborne_toolkit.target_check
      Ashborne_toolkit.combat_unique_to_ashborne
    end
  end

}
end




# Quick-follow characters use this loop.
Ashborne_toolkit.follower_status_notice_rc18
loop {
  Ashborne_toolkit.process_follower_control_requests_rc15
  Ashborne_toolkit.publish_group_state
  ashborne_group_status_check.call
  Ashborne_toolkit.group_danger_retreat_if_needed
  Ashborne_toolkit.boost_long
  ashborne_upkeep_buffs.call
  Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") if GameObj.dead.length >= 1 && (GameObj.targets.empty? || Ashborne_toolkit.urgent_loot_needed?)

  # respond "I'm in qfollow"
  result = matchtimeout(1, /#{$ashborne_captain} (swings|gestures|fires|attempts to|skillfully weaves|punches with|channels|rushes forward|thrusts with|thrusts with a|lunges at|waves a|launches a .* bash|lashes out with an? awesome shield bash|attempts a shield bash|looping .*? lashes out in a strike|brings .*? around to pummel|sweeping .*? out low to .*? launches a quick bash|whirls in a fury of unrelenting strikes|mstrikes?|starts to climb|begins to climb|begins climbing|begins to descend|confidently climbs|gracefully climbs|climbs up|climbs down|goes through|squeezes through|crawls through|pushes through|pulls open|opens .*door|enters)/).to_s

  if result =~ /#{$ashborne_captain} (swings|gestures|fires|attempts to|skillfully weaves|punches with|channels|thrusts with|rushes forward|thrusts with a|lunges at|waves a|launches a .* bash|lashes out with an? awesome shield bash|attempts a shield bash|looping .*? lashes out in a strike|brings .*? around to pummel|sweeping .*? out low to .*? launches a quick bash|whirls in a fury of unrelenting strikes|mstrikes?)/
    Ashborne_toolkit.target_check unless $ashborne_group_peace == "1"
    Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_group_peace == "1"
  elsif result =~ /#{$ashborne_captain} (starts to climb|begins to climb|begins climbing|begins to descend|confidently climbs|gracefully climbs|climbs up|climbs down|goes through|squeezes through|crawls through|pushes through|pulls open|opens .*door|enters)/
    Ashborne_toolkit.handle_leader_obstacle_event(result)
  else
    Ashborne_toolkit.group_follow_sync
    if GameObj.targets.length >= 1 && $ashborne_group_peace != "1"
      Ashborne_toolkit.target_check
      Ashborne_toolkit.combat_unique_to_ashborne
    end
  end

}
