  respond "Repeat hunts: #{[[ashborne_setting_hunt_cycles.to_i, 1].max, 25].min} total; repeat when mind is at or below #{[[ashborne_setting_rest_mind.to_i, 0].max, 100].min}%."
  respond "Multi-account command tool: #{ashborne_setting_multi_account_tool.to_s.downcase == 'thunder' ? 'Thunder / Struck' : 'Borg / Queen / Drone'}."

