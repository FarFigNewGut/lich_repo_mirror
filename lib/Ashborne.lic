  def check_nil
    if Ashborne_toolkit.current_room_id == nil
      if $ashborne_my_area =~ /qlite|quick|grounded/
        nil
      else
        Ashborne_toolkit.top_menu
        Ashborne_toolkit.nil
        Ashborne_toolkit.bottom_menu
        exit
      end
    end
  end

  def level0
    Ashborne_toolkit.check_nil

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, you appear to be level 0."
    respond
    respond "I'm going to take you to town and attempt to reach level 1."
    respond
    respond "Type ;ka to stop this."
    respond
    respond "Starting in 5 seconds..."
    Ashborne_toolkit.bottom_menu
    sleep 5
    Script.run('go2', 'town')
    Script.run('repository', 'download level1.lic') if !Script.exists?('level1')


    if Ashborne_toolkit.current_room_id == 228
      Script.run('level1', 'wl')
    elsif Ashborne_toolkit.current_room_id == 2300
      Script.run('level1', 'it')
    elsif Ashborne_toolkit.current_room_id == 3519
      Script.run('level1', 'tv')
    end

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, you should be level 1 very soon."
    Ashborne_toolkit.bottom_menu
    exit
  end

  def herb_script_check
    if Script.exists? "eherbs"
      nil
    else
      Script.run('repository', 'download eherbs.lic')
    end

    do_client ";eherbs set buy off"
    wait_while { running? "eherbs" }
  end

  def cleanup
    $ashborne_active_cleanup = "1"

    unless GameObj.targets.empty?
      begin
        fput "stance defensive" unless checkstance == "defensive"
      rescue
        nil
      end
      respond "#{Char.name}, cleanup was stopped because hostile creatures are present."
      $ashborne_active_cleanup = "0"
      return false
    end

    if $ashborne_group_ai != "0"
      fput "disband"
      fput "group open"
    end

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, I'm starting ;ashborne cleanup."
    Ashborne_toolkit.bottom_menu

    if checkarea == "Birthing Sands"
      $ashborne_rift_return = "1"
      Spell[130].cast() if Spell[130].known? && Stats.level >= 30 && Spell[130].affordable?
      do_client ";go2 2300"
      wait_while { running? "go2" }
    end

    if Ashborne_toolkit.current_room_id == 6505
      if Spell[9825].known?
        fput "sym return"
      elsif Spell[130].known? && Stats.level >= 30 && Spell[130].affordable?
        Spell[130].cast()
      end
      Script.run('go2', '228')


    end


    if Spell[1118].known? && Stats.prof == "Empath"
      if Script.exists? "selfhealall"
        nil
      else
        Script.run('repository', 'download selfhealall.lic')
      end
      Script.run('selfhealall')
    end


    if $ashborne_nocleanupherbs == "1"
      nil
    else

      Ashborne_toolkit.herb_script_check

      do_client ";eherbs set buy on"
      wait_while { running? "eherbs" }

      Script.run('eherbs')

    end


    if $ashborne_cleanloot_script == "eloot"

      nil

    else

      if Script.exists? "poolparty"
        nil
      else
        Script.run('repository', 'download poolparty.lic')
      end

      # Script.run('poolparty')
      do_client ";poolparty deposit"
      wait_while { running? "poolparty" }

      sleep 0.5

      do_client ";poolparty loot"
      Ashborne_toolkit.unpause_go2
      wait_while { running? "poolparty" }

      if Script.exists? "collectible"
        nil
      else
        Script.run('repository', 'download collectible.lic')
      end

      Script.run('collectible')

      if Script.exists? "sell_shells"
        nil
      else
        Script.run('repository', 'download sell_shells.lic')
      end

      Script.run('sell_shells')
    end

    do_client ";#{$ashborne_cleanloot_script} sell"
    wait_while { running? "#{$ashborne_cleanloot_script}" }

    Ashborne_toolkit.end_combat_waggle

    if $ashborne_330_sanctify == "1"
      fput "ready weapon"
      result = dothistimeout "look at my #{$ashborne_right_hand_detect}", 5, /flickering aura of holy light radiates from/

      if result =~ /flickering aura of holy light radiates from/
        nil
      else
        if Spell[330].known? && Stats.level >= 30 && Spell[330].affordable?
          fput "prep 330"
          fput "evoke #{$ashborne_right_hand_detect}"
          Ashborne_toolkit.prep_reset
        else
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, you don't have enough mana or don't meet the requirements to refresh sanctify on your weapon."
          Ashborne_toolkit.bottom_menu
        end
      end
    end

    if $ashborne_rift_return == "1"
      do_client ";go2 2635"
      wait_while { running? "go2" }
    end

    if $ashborne_meditate == "1"
      fput "meditate"
    end

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, ;ashborne cleanup is complete."
    Ashborne_toolkit.bottom_menu

    $ashborne_active_cleanup = "0"
  end

  def room_nil_walk
    if $ashborne_my_area =~ /qlite|quick|grounded/
      nil
    else
      if Ashborne_toolkit.current_room_id == nil
        Ashborne_toolkit.reset_zone_combat_check
        until Ashborne_toolkit.current_room_id != nil
          Ashborne_toolkit.safe_walk
        end
      end
    end
  end

  def lnet_check
    #if Script.running? "lnet"
    #  nil
    #else
      #do_client ";lnet"
      #sleep 3
    #end
  end

  def ashborne_intel_service_check
    return nil if Script.running?("intel_ashborne")
    return nil if @intel_ashborne_last_start && Time.now.to_i - @intel_ashborne_last_start < 30

    @intel_ashborne_last_start = Time.now.to_i
    Script.start("intel_ashborne") if Script.exists?("intel_ashborne")
  end

  def ashborne_stop_conflicting_controllers
    %w[huntpro intel_huntpro go2].each do |script_name|
      Script.kill(script_name) if Script.running?(script_name)
    end
    nil
  rescue
    nil
  end

  def infomon_check
    if Script.running?("infomon") || defined?(Infomon)
      nil
    else
      do_client ";fixit"
    end
  end

  def stand_check
    if $ashborne_my_area =~ /moonmagru/
      Ashborne_toolkit.kneel_check
    else
      if !checkstanding
        fput "stand"
        pause 0.25
        waitrt?
      end
    end
  end

  def kneel_check
    if !checkkneeling
      fput "kneel"
      pause 0.25
      waitrt?
    end
  end

  def target_check
    return if Ashborne_toolkit.medical_retreat_if_needed

    # respond "Debug Output - I'm defining creatures"
    if $ashborne_group_ai == "0" ? GameObj.pcs.any? : Ashborne_toolkit.visible_non_group_players.any?
      Ashborne_toolkit.leave_occupied_room
      return nil
    end

    $ashborne_current_target = nil
    $ashborne_id_placeholder = nil
    $ashborne_name_placeholder = nil

    # Define Creatures
    $ashborne_current_id_targets = nil
    $ashborne_current_id_targets = Array.new

    $ashborne_current_id_weak_targets = nil
    $ashborne_current_id_weak_targets = Array.new

    $ashborne_current_name_weak_targets = nil
    $ashborne_current_name_weak_targets = Array.new

    $ashborne_current_name_targets = nil
    $ashborne_current_name_targets = Array.new

    $ashborne_current_noun_targets = nil
    $ashborne_current_noun_targets = Array.new

    $ashborne_current_name_s9_override_targets = nil
    $ashborne_current_name_s9_override_targets = Array.new

    $ashborne_current_id_s9_override_targets = nil
    $ashborne_current_id_s9_override_targets = Array.new

    $ashborne_creature_name_sev_1_attack = nil
    $ashborne_creature_name_sev_1_attack = Array.new

    $ashborne_creature_id_sev_1_attack = nil
    $ashborne_creature_id_sev_1_attack = Array.new




    GameObj.targets.each { |i|
      if i.status =~ /sleeping|to be frozen in place|stunned|lying down/

        $ashborne_current_id_weak_targets.push(i.id)
        $ashborne_current_name_weak_targets.push(i.name)
      end
    }

    GameObj.targets.each { |i|
      $ashborne_current_id_targets.push(i.id)
      $ashborne_current_name_targets.push(i.name)
      $ashborne_current_noun_targets.push(i.noun)
    }

    GameObj.targets.each { |i|
      if $ashborne_creature_sev_1_attack_array.include?(i.name)

        $ashborne_creature_id_sev_1_attack.push(i.id)
        $ashborne_creature_name_sev_1_attack.push(i.name)
      end
    }

    GameObj.targets.each { |i|
      if $ashborne_style_9_creature_override_array.include?(i.name)

        $ashborne_current_id_s9_override_targets.push(i.id)
        $ashborne_current_name_s9_override_targets.push(i.name)
      end
    }

    # respond "Debug Output - Lengths"
    # respond "Debug Output - ID Weak Length #{$ashborne_current_id_weak_targets.length}"
    # respond "Debug Output - Name Weak Length #{$ashborne_current_name_weak_targets.length}"
    # respond "Debug Output - Current ID Targets Length #{$ashborne_current_id_targets.length}"
    # respond "Debug Output - Current Name Targets Length #{$ashborne_current_name_targets.length}"
    # respond "Debug Output - ID S9 Override Length #{$ashborne_current_id_s9_override_targets.length}"
    # respond "Debug Output - Name S9 Override Length #{$ashborne_current_name_s9_override_targets.length}"
    # respond "Debug Output - ID sev 1 Override Length #{$ashborne_creature_id_sev_1_attack.length}"
    # respond "Debug Output - Name sev 1 Override Length #{$ashborne_creature_name_sev_1_attack.length}"


    # respond "Debug Output - Data"
    # respond "Debug Output - ID Weak Length #{$ashborne_current_id_weak_targets}"
    # respond "Debug Output - Name Weak Length #{$ashborne_current_name_weak_targets}"
    # respond "Debug Output - Current ID Targets Length #{$ashborne_current_id_targets}"
    # respond "Debug Output - Current Name Targets Length #{$ashborne_current_name_targets}"
    # respond "Debug Output - ID S9 Override Length #{$ashborne_current_id_s9_override_targets}"
    # respond "Debug Output - Name S9 Override Length #{$ashborne_current_name_s9_override_targets}"
    # respond "Debug Output - ID sev 1 Override Length #{$ashborne_creature_id_sev_1_attack}"
    # respond "Debug Output - Name sev 1 Override Length #{$ashborne_creature_name_sev_1_attack}"

    return nil if Ashborne_toolkit.handle_environmental_hazard_targets

    Ashborne_toolkit.target_reset_check unless $ashborne_my_area == "group"

    if $huuntpro_action == 98
      nil
    else

      if $ashborne_bounty_lite == "1"
        $ashborne_bounty_creature_name = "0"
      end

      # Pick Target
      # Force Target Setup
      # respond "Debug Output - Picking target."
      if $ashborne_force_target != "0"
        if checknpcs "#{$ashborne_force_target}"
          $ashborne_creature_id_sev_1_attack = ["#{$ashborne_force_target}"]
        # respond "Debug Output - Focusing on your target."
        else
          # respond "Debug Output - Your target not found."
          $ashborne_action = 98
          $ashborne_recent_eviction = "1"
          sleep 0.5
        end
      # Bounty Target Setup
      elsif $ashborne_bounty_creature_name != "0"
        # respond "You're on a bounty and I'm going to target your objective."
        if checknpcs "#{$ashborne_bounty_creature_name}"
          nil
        else
          $ashborne_action = 98
          $ashborne_recent_eviction = "1"
          sleep 0.5
        end
      end

      if $ashborne_recent_eviction == "1"
        nil
      else
        if $ashborne_creature_id_sev_1_attack.length >= 1
          # respond "Debug Output - Sev 1."
          if $ashborne_force_target != "0"
            fput "target #{$ashborne_creature_id_sev_1_attack[0]}"
          else
            fput "target ##{$ashborne_creature_id_sev_1_attack[0]}"
          end
          $ashborne_current_target = $ashborne_creature_name_sev_1_attack[0]
          $ashborne_id_placeholder = $ashborne_creature_id_sev_1_attack[0]
          $ashborne_name_placeholder = $ashborne_creature_name_sev_1_attack[0]

        elsif $ashborne_current_id_weak_targets.length >= 1
          # respond "Debug Output - Disabled."
          fput "target ##{$ashborne_current_id_weak_targets[0]}"
          $ashborne_current_target = $ashborne_current_name_weak_targets[0]
          $ashborne_id_placeholder = $ashborne_current_id_weak_targets[0]
          $ashborne_name_placeholder = $ashborne_current_name_weak_targets[0]

        elsif $ashborne_current_id_s9_override_targets.length >= 1
          # respond "Debug Output - S9 Override."
          fput "target ##{$ashborne_current_id_s9_override_targets[0]}"
          $ashborne_current_target = $ashborne_current_name_s9_override_targets[0]
          $ashborne_id_placeholder = $ashborne_current_id_s9_override_targets[0]
          $ashborne_name_placeholder = $ashborne_current_name_s9_override_targets[0]
        else
          # respond "Debug Output - Nothing Special"
          fput "target ##{$ashborne_current_id_targets[0]}"
          $ashborne_current_target = $ashborne_current_name_targets[0]
          $ashborne_id_placeholder = $ashborne_current_id_targets[0]
          $ashborne_name_placeholder = $ashborne_current_name_targets[0]

        end
      end

    end
  end

  def bounty_objective_present?
    bounty_name = $ashborne_bounty_creature_name.to_s
    return false if bounty_name.empty? || bounty_name == "0"

    checknpcs bounty_name
  rescue
    false
  end

  def clear_bounty_movement_blocker
    bounty_name = $ashborne_bounty_creature_name.to_s
    return false if bounty_name.empty? || bounty_name == "0" || $ashborne_bounty_lite == "1"
    return false if Ashborne_toolkit.bounty_objective_present?
    return false if GameObj.targets.empty?

    if $ashborne_group_ai == "0" ? GameObj.pcs.any? : Ashborne_toolkit.visible_non_group_players.any?
      Ashborne_toolkit.leave_occupied_room
      return true
    end

    target = GameObj.targets.find do |creature|
      creature.status.to_s !~ /dead|gone/i
    end || GameObj.targets.first
    return false unless target

    fput "target ##{target.id}"
    $ashborne_current_target = target.name
    $ashborne_id_placeholder = target.id
    $ashborne_name_placeholder = target.name
    $ashborne_recent_eviction = "0"
    $ashborne_action = 7
    $ashborne_own_this_room = 1
    respond "Bounty movement blocker present; clearing #{target.name} so the hunt can keep moving."
    true
  rescue => error
    respond "Bounty movement blocker warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def hidden_threat_present?
    defined?(OverWatch) && OverWatch.respond_to?(:hiders?) && OverWatch.hiders?
  rescue
    false
  end

  def handle_hidden_threat
    return false unless Ashborne_toolkit.hidden_threat_present?

    if Time.now.to_f - $ashborne_last_hidden_search_at.to_f >= 3.0
      waitrt?
      fput "search"
      $ashborne_last_hidden_search_at = Time.now.to_f
    end
    sleep 0.25
    true
  rescue
    false
  end

  def movemgr
    return if Ashborne_toolkit.medical_retreat_if_needed

    # Ashborne_toolkit.group_rt_check
    sleep $ashborne_spawn_delay
    # respond "Debug Output - You are starting movemgr"
    sleep 0.10
    Ashborne_toolkit.stand_check
    # respond "Debug Output - Own this room is #{$ashborne_own_this_room}."

    if $ashborne_own_this_room == 0
      # respond "Debug Output - I do not own the room yet."

      if $ashborne_group_ai == "0"
        if GameObj.pcs.any?
          # respond "Debug Output - There's someone here."
          $ashborne_my_vine = "0"
          Ashborne_toolkit.cock_support
          Ashborne_toolkit.leave_occupied_room
        elsif GameObj.targets.length >= 1
          # respond "Debug Output - No other players here, I'm about to own the room."
          Ashborne_toolkit.target_check
          $ashborne_action = 7 unless $ashborne_action == 98
          $ashborne_own_this_room = 1 unless $ashborne_action == 98
        elsif Ashborne_toolkit.handle_hidden_threat
          nil
        else
          # respond "Debug Output - Own room 0, single player mode, no targets found."
          if Script.running? "#{$ashborne_loot_script}"
            nil
          else
            # respond "Debug output - Own room 0, about to walk"
            sleep 0.10
            $ashborne_own_this_room = 0
            $ashborne_my_vine = "0"
            Ashborne_toolkit.cock_support
            Ashborne_toolkit.safe_walk

          end
        end
      else
        # Group Mode Move Logic
        sleep 0.01
        if Ashborne_toolkit.visible_non_group_players.any?
          # respond "Debug Output - Group Mode - There's someone here besides the permitted group."
          $ashborne_my_vine = "0"
          Ashborne_toolkit.cock_support
          Ashborne_toolkit.purge_group_combat
          # Ashborne_toolkit.group_grounded
          Ashborne_toolkit.leave_occupied_room
        elsif GameObj.targets.length >= 1
          # respond "Debug Output - Group Mode - No extra players here, I'm about to own the room."
          Ashborne_toolkit.target_check
          $ashborne_action = 7 unless $ashborne_action == 98
          $ashborne_own_this_room = 1 unless $ashborne_action == 98
        elsif Ashborne_toolkit.handle_hidden_threat
          nil
        else
          # respond "Debug Output - Group Mode - No targets or dead, about to move."
          if Script.running? "#{$ashborne_loot_script}"
            nil
          else
            sleep 0.10
            $ashborne_own_this_room = 0
            $ashborne_my_vine = "0"
            Ashborne_toolkit.cock_support
            Ashborne_toolkit.purge_group_combat
            # Ashborne_toolkit.group_grounded
            Ashborne_toolkit.safe_walk
          end
        end
      end



    elsif $ashborne_own_this_room == 1
      # respond "Debug Output - I'm in movement and own this room is 1."
      if $ashborne_group_ai == "0" ? GameObj.pcs.any? : Ashborne_toolkit.visible_non_group_players.any?
        # Someone else entered or was revealed after we thought we owned the room.
        Ashborne_toolkit.leave_occupied_room
      elsif GameObj.targets.length >= 1
        # respond "Debug Output - I see at least 1 target."
        if GameObj.dead.length >= 1 && Ashborne_toolkit.urgent_loot_needed?
          Ashborne_toolkit.loot_script("#{$ashborne_loot_script}")
        else
          Ashborne_toolkit.target_check
          $ashborne_action = 7 unless $ashborne_action == 98
          $ashborne_own_this_room = 1 unless $ashborne_action == 98
        end
      elsif GameObj.dead.length >= 1
        # respond "Debug Output - Dead creature detected."
        Ashborne_toolkit.loot_script("#{$ashborne_loot_script}")
      else
        # respond "Debug Output - Own this room is 1, no dead and no targets found."
        if Script.running? "#{$ashborne_loot_script}"
          nil
        else
          # respond "Debug Output - Own room 1, walking"
          sleep 0.10
          $ashborne_own_this_room = 0
          $ashborne_my_vine = "0"
          Ashborne_toolkit.cock_support
          Ashborne_toolkit.purge_group_combat
          # Ashborne_toolkit.group_grounded
          Ashborne_toolkit.safe_walk
        end

      end

    end
  end

  def movement_guard
    safe_to_move = false

    begin
      waitrt?
      Ashborne_toolkit.wait_group_vulnerability_clear

      2.times do
        break if checkstance == "defensive"

        begin
          fput "stance defensive"
          waitrt?
          sleep 0.10
        rescue
          sleep 0.25
        end
      end

      safe_to_move = checkstance == "defensive"

      begin
        shield_expected = ($ashborne_left_hand_detect.to_s =~ /shield/i) || ($ashborne_shield_shieldthrow == "1")
        if shield_expected
          2.times do
            break if checkleft.to_s =~ /shield/i

            fput "ready shield"
            waitrt?
            sleep 0.10
          end
          safe_to_move = false unless checkleft.to_s =~ /shield/i
        end
      rescue
        safe_to_move = false
      end

      safe_to_move
    rescue
      safe_to_move = false
      false
    ensure
      Ashborne_toolkit.publish_group_move_state(safe_to_move) if $ashborne_group_ai != "0"
    end
  end

  def safe_walk
    return nil unless Ashborne_toolkit.group_wait_for_followers_to_move
    return nil if Ashborne_toolkit.group_disarm_recovery_active?
    return nil unless Ashborne_toolkit.movement_guard
    if $ashborne_group_ai == "1" && Ashborne_toolkit.group_incomplete_in_current_room?
      unless Ashborne_toolkit.rally_and_regroup_for_travel("room movement")
        Ashborne_toolkit.stop_group_travel_without_group("could not regroup before room movement")
      end
    end
    return nil if Ashborne_toolkit.recover_disarmed_item_if_needed

    Ashborne_toolkit.learn_room_yield
    avoided_reason = Ashborne_toolkit.avoided_room_reason
    if avoided_reason
      respond "Avoiding this room for #{avoided_reason}; moving on."
      return Ashborne_toolkit.walk_avoiding_environmental_rooms(avoided_reason)
    end

    if !GameObj.targets.empty?
      respond "Movement paused because a hostile creature arrived."
      Ashborne_toolkit.clear_bounty_movement_blocker || Ashborne_toolkit.target_check
      unless GameObj.targets.empty?
        $ashborne_recent_eviction = "0"
        $ashborne_action = 7
        $ashborne_own_this_room = 1
      end
      return nil
    end

    starting_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
    if Ashborne_toolkit.huntplan_catalog_zone?
      result = Ashborne_toolkit.huntplan_catalog_walk
      return result unless result.nil?
    end
    result = walk
    sleep 0.10
    Ashborne_toolkit.learn_room_yield
    avoided_reason = Ashborne_toolkit.avoided_room_reason
    if avoided_reason && GameObj.targets.empty?
      respond "Landed in avoided room for #{avoided_reason}; moving on."
      Ashborne_toolkit.walk_avoiding_environmental_rooms(avoided_reason)
    end
    if starting_room && Room.current && Ashborne_toolkit.current_room_id.to_s == starting_room && !GameObj.targets.empty?
      respond "Movement failed into combat; engaging before trying to move again."
      Ashborne_toolkit.target_check
      $ashborne_recent_eviction = "0"
      $ashborne_action = 7
      $ashborne_own_this_room = 1
    end
    result
  rescue => error
    respond "Movement warning: #{error.message}" if $ashborne_qc_debug == "1"
    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.defend_while_waiting_for_group unless GameObj.targets.empty?
    nil
  end

