# Define Proc Statements
# ashborne_update_check.call <- Call a Proc

ashborne_load_settings = proc {
  # You'll detect all character settings here.
  if ashborne_setting_profile_detection == "1"
    nil
  else
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, I notice some settings need to be detected. Please stand by."
    Ashborne_toolkit.bottom_menu
    sleep 3
    Settings[Char.name]['ashborne_setting_profile_detection']	= "1"

    do_client ";go2 --get-silvers=on"
    wait_while { running? "go2" }
    do_client ";go2 --use-seeking=on" if Society.status == "Order of Voln"
    wait_while { running? "go2" }
    do_client ";go2 typeahead=2"
    wait_while { running? "go2" }
    do_client ";go2 delay=0"
    wait_while { running? "go2" }
    #if Script.exists?('lnet')
      #Ashborne_toolkit.lnet_check
      #do_client ";tune Ashborne"
      #do_client ";tune Help"
      #do_client ";tune Help"
   # else
    #  Ashborne_toolkit.top_menu
    #  respond
    #  respond "********************************************************************************"
    #  respond "Hey #{Char.name}, I noticed you don't have the LNET script downloaded."
    #  respond
    #  respond "Some of the more advanced features of Ashborne use the LNET network."
    #  respond
    #  respond "I have a YouTube video showing how to get this file."
    #  respond
    #  respond "https://youtu.be/wtf-7TnWY0M"
    #  respond
    #  respond "Jump to 09:48 and check the description of the video for more timestamps."
    #  respond "********************************************************************************"
    #  respond
    #  Ashborne_toolkit.bottom_menu
    #  sleep 2
    #end

    if Skills.survival >= 50
      do_client ";go2 --ice-mode=run"
      wait_while { running? "go2" }
    end

    fput "FLAG ObviousHiding ON"


    # Check your Society

    if ashborne_setting_character_society =~ /Voln|Gos|Col|None/
      nil
    else
      if Society.status == "Order of Voln"
        Settings[Char.name]['ashborne_setting_character_society']	= "Voln"
      elsif Society.status == "Council of Light"
        Settings[Char.name]['ashborne_setting_character_society']	= "Col"
      elsif Society.status =~ /Sunfist/
        Settings[Char.name]['ashborne_setting_character_society']	= "Gos"
      elsif Society.status == "None"
        Settings[Char.name]['ashborne_setting_character_society']	= "None"
      end

    end

    Settings.save

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, your settings have been detected.  Please restart the script."
    Ashborne_toolkit.bottom_menu
    exit


  end


  ashborne_my_style = script.vars[1].downcase
  ashborne_my_area = script.vars[2].downcase

  $ashborne_my_style = script.vars[1].downcase
  $ashborne_my_area = script.vars[2].downcase

  imported_group = Ashborne_toolkit.import_missing_huntpro_group_settings
  unless imported_group.empty?
    ashborne_setting_leader = imported_group.fetch("ashborne_setting_leader", ashborne_setting_leader)
    ashborne_setting_group_one = imported_group.fetch("ashborne_setting_group_one", ashborne_setting_group_one)
    ashborne_setting_group_two = imported_group.fetch("ashborne_setting_group_two", ashborne_setting_group_two)
    ashborne_setting_group_three = imported_group.fetch("ashborne_setting_group_three", ashborne_setting_group_three)
    ashborne_setting_group_four = imported_group.fetch("ashborne_setting_group_four", ashborne_setting_group_four)
    ashborne_setting_group_five = imported_group.fetch("ashborne_setting_group_five", ashborne_setting_group_five)
    ashborne_setting_group_six = imported_group.fetch("ashborne_setting_group_six", ashborne_setting_group_six)
    ashborne_setting_group_seven = imported_group.fetch("ashborne_setting_group_seven", ashborne_setting_group_seven)
    ashborne_setting_group_eight = imported_group.fetch("ashborne_setting_group_eight", ashborne_setting_group_eight)
    ashborne_setting_group_nine = imported_group.fetch("ashborne_setting_group_nine", ashborne_setting_group_nine)
    ashborne_setting_group_style = imported_group.fetch("ashborne_setting_group_style", ashborne_setting_group_style)
  end

  if $ashborne_my_area =~ /\Agroup\z/i
    $ashborne_my_style = Ashborne_toolkit.group_combat_style(
      ashborne_setting_group_style,
      $ashborne_my_style
    )
    ashborne_my_style = $ashborne_my_style
    respond "Ashborne group mode is using #{Char.name}'s combat style #{$ashborne_my_style}."
  elsif $ashborne_my_style =~ /\A[1-9]\z/
    Settings[Char.name]['ashborne_setting_group_style'] = $ashborne_my_style
    Settings.save
  end

  detected_society =
    if Society.status == "Order of Voln"
      "Voln"
    elsif Society.status == "Council of Light"
      "Col"
    elsif Society.status.to_s =~ /Sunfist/
      "Gos"
    elsif Society.status == "None"
      "None"
    end
  if detected_society
    ashborne_setting_character_society = detected_society
    Settings[Char.name]['ashborne_setting_character_society'] = detected_society
    Settings.save
  end

  if $ashborne_my_style =~ /1|2|3|4|5|6|7|8/
    if Script.exists? "reactive"
    # respond "Debug Output - You picked style #{$ashborne_my_style} and already downloaded reactive."
    else
      Script.run('repository', 'download reactive.lic')
    end
  end

  if ashborne_setting_character_society =~ /Voln/
    $ashborne_my_society = "Voln"
    if Script.exists? "symbolz"

    else
      Script.run('repository', 'download symbolz.lic') unless $ashborne_no_society == "1"
    end
  end

  if ashborne_setting_character_society =~ /Gos/
    $ashborne_my_society = "Gos"
    if Script.exists? "isigils"

    else
      Script.run('repository', 'download isigils.lic') unless $ashborne_no_society == "1"
    end
  end

  if ashborne_setting_character_society =~ /Col/
    $ashborne_my_society = "Col"
    if Script.exists? "isigns"

    else
      Script.run('repository', 'download isigns.lic') unless $ashborne_no_society == "1"
    end
  end




  if Stats.prof == "Bard"
    if Script.exists? "song-manager"

    else
      Script.run('repository', 'download song-manager.lic')
    end
  end


  if ashborne_setting_force_skip_list == "0"
    nil
  else
    $ashborne_force_skip_array.push(ashborne_setting_force_skip_list)
    $ashborne_force_skip_array.push(ashborne_setting_force_skip_list2)
    $ashborne_force_skip_array.push(ashborne_setting_force_skip_list3)
  end

  if ashborne_setting_compound_ignore == "0"
    nil
  else
    $ashborne_compound_ignore_array = ["#{ashborne_setting_compound_ignore}"]
  end

  if ashborne_setting_stay_offensive == "0"
    nil
  else
    $ashborne_stay_offensive = "1"
  end

  if ashborne_setting_loot_script == "0"
    nil
  else
    $ashborne_loot_script = "#{ashborne_setting_loot_script}"
  end

  if ashborne_setting_cleanloot_script == "0"
    nil
  else
    $ashborne_cleanloot_script = "#{ashborne_setting_cleanloot_script}"
  end

  $ashborne_loot_rotation = ashborne_setting_loot_rotation.to_s
  $ashborne_preferred_looter = ashborne_setting_preferred_looter.to_s
  $ashborne_eligible_looters = ashborne_setting_eligible_looters.to_s
  $ashborne_loot_handoff = [ashborne_setting_loot_handoff.to_i, 1].max
  $ashborne_loot_emergency = [
    ashborne_setting_loot_emergency.to_i,
    $ashborne_loot_handoff + 1
  ].max

  if $ashborne_cleanloot_script == "0"
    $ashborne_cleanloot_script = "#{$ashborne_loot_script}"
  end

  $ashborne_custom_spell_rotation = ashborne_setting_spell_default.to_s.scan(/\d+/).map(&:to_i).select { |spell_number| spell_number > 0 }.uniq
  $ashborne_spell_default = $ashborne_custom_spell_rotation.first.to_s unless $ashborne_custom_spell_rotation.empty?



  if ashborne_setting_evoke_default == "0"
    nil
  else
    $ashborne_evoke_default = "1"
  end

  if ashborne_setting_rest_room == "0"
    nil
  else
    $ashborne_rest_room = "#{ashborne_setting_rest_room}"
  end

  if ashborne_setting_leader == "0"
    nil
  else
    $ashborne_captain = "#{ashborne_setting_leader}"
    if $ashborne_captain.to_s.casecmp(Char.name.to_s).zero?
      $ashborne_group_ai = "1"
      #do_client ";lnet allow locate all" unless script.vars[1].downcase =~ /setup|cleanup/
    else
      $ashborne_group_ai = "2"
    end
  end

  $ashborne_additional_group_members = ashborne_setting_group_additional.to_s.split(/[;,\s]+/).reject { |name| name.empty? || name == "0" }
  if (ashborne_setting_group_one == "0" && $ashborne_additional_group_members.empty?) || $ashborne_group_ai != "1"
    # do_client "flag groupmovement off"
    nil
  else
    # do_client "flag groupmovement on"
    $ashborne_group_array.push(ashborne_setting_group_one)
    $ashborne_group_array.push(ashborne_setting_group_two) unless ashborne_setting_group_two == "0"
    $ashborne_group_array.push(ashborne_setting_group_three) unless ashborne_setting_group_three == "0"
    $ashborne_group_array.push(ashborne_setting_group_four) unless ashborne_setting_group_four == "0"
    $ashborne_group_array.push(ashborne_setting_group_five) unless ashborne_setting_group_five == "0"
    $ashborne_group_array.push(ashborne_setting_group_six) unless ashborne_setting_group_six == "0"
    $ashborne_group_array.push(ashborne_setting_group_seven) unless ashborne_setting_group_seven == "0"
    $ashborne_group_array.push(ashborne_setting_group_eight) unless ashborne_setting_group_eight == "0"
    $ashborne_group_array.push(ashborne_setting_group_nine) unless ashborne_setting_group_nine == "0"
    $ashborne_group_array.concat($ashborne_additional_group_members)
    $ashborne_group_array.map! { |name| Ashborne_toolkit.canonical_character_name(name) }
    $ashborne_group_array.select! { |name| Ashborne_toolkit.valid_character_name?(name) }
    $ashborne_group_array.uniq! { |name| name.downcase }

    $ashborne_group_member1 = "#{ashborne_setting_group_one}" unless ashborne_setting_group_one == "0"
    $ashborne_group_member2 = "#{ashborne_setting_group_two}" unless ashborne_setting_group_two == "0"
    $ashborne_group_member3 = "#{ashborne_setting_group_three}" unless ashborne_setting_group_three == "0"
    $ashborne_group_member4 = "#{ashborne_setting_group_four}" unless ashborne_setting_group_four == "0"
    $ashborne_group_member5 = "#{ashborne_setting_group_five}" unless ashborne_setting_group_five == "0"
    $ashborne_group_member6 = "#{ashborne_setting_group_six}" unless ashborne_setting_group_six == "0"
    $ashborne_group_member7 = "#{ashborne_setting_group_seven}" unless ashborne_setting_group_seven == "0"
    $ashborne_group_member8 = "#{ashborne_setting_group_eight}" unless ashborne_setting_group_eight == "0"
    $ashborne_group_member9 = "#{ashborne_setting_group_nine}" unless ashborne_setting_group_nine == "0"





  end

  if ashborne_setting_group_quiet == "0"
    nil
  else
    $ashborne_group_quiet = "1"
  end

  if ashborne_setting_group_sharemana == "0"
    nil
  else
    $ashborne_group_sharemana = "1"
  end

  if ashborne_setting_group_noise == "0"
    nil
  else
    $ashborne_group_noise = "1"
  end

  if ashborne_setting_noise_lockdown == "0"
    nil
  else
    $ashborne_noise_lockdown = "1"
    $ashborne_group_noise = "1"
  end

  $ashborne_anti_caster = ashborne_setting_anti_caster.to_s == "0" ? "0" : "1"
  $ashborne_anti_caster_mana = ashborne_setting_anti_caster_mana.to_i
  $ashborne_anti_caster_mana = 50 if $ashborne_anti_caster_mana <= 0
  $ashborne_preflight = ashborne_setting_preflight.to_s == "0" ? "0" : "1"
  $ashborne_role_preference = Ashborne_toolkit.normalized_role(ashborne_setting_role)
  $ashborne_job_coordinator = ashborne_setting_job_coordinator.to_s == "0" ? "0" : "1"
  $ashborne_mana_reserve = ashborne_setting_mana_reserve.to_i
  $ashborne_mana_reserve = 40 if $ashborne_mana_reserve <= 0
  $ashborne_stamina_reserve = ashborne_setting_stamina_reserve.to_i
  $ashborne_stamina_reserve = 20 if $ashborne_stamina_reserve <= 0
  $ashborne_health_floor = ashborne_setting_health_floor.to_i
  $ashborne_health_floor = 70 if $ashborne_health_floor <= 0

  if ashborne_setting_group_peace == "0"
    nil
  else
    $ashborne_group_peace = "1"
  end

  if ashborne_setting_wrack == "0"
    nil
  else

    if Script.exists? "wrack"
      nil
    else
      Script.run('repository', 'download wrack.lic')

    end
    $ashborne_wrack = "1"
  end

  if ashborne_setting_deedmana == "0" && ashborne_setting_character_society =~ /Voln/
    nil
  else

    $ashborne_deedmana = "1"
  end




  if ashborne_setting_combat_cleanup == "0"
    nil
  else
    $ashborne_combat_cleanup = "1"
  end

  if ashborne_setting_zonescripts == "0"
    nil
  else
    $ashborne_zonescripts = "1"
  end



  $ashborne_script_one = "#{ashborne_setting_run_script}" unless ashborne_setting_run_script == "0"
  $ashborne_script_two = "#{ashborne_setting_run_script2}" unless ashborne_setting_run_script2 == "0"
  $ashborne_script_three = "#{ashborne_setting_run_script3}" unless ashborne_setting_run_script3 == "0"

  $ashborne_group_support = "1"

  if Stats.prof == "Empath" && Stats.level >= 40
    $ashborne_empath_self_heal = "1"
  end

  if Stats.level >= 20
    $ashborne_crowd_control = "1"
  end

  if ashborne_setting_turbo_crowd_control == "0"
    nil
  else
    $ashborne_turbo_crowd_control = "1"
  end


  if ashborne_setting_crowd_control == "0"
    nil
  else
    $ashborne_crowd_control = "1"
  end

  if ashborne_setting_no_crowd_control == "0"
    nil
  else
    $ashborne_no_crowd_control = "1"
  end


  if Stats.level >= 20
    $ashborne_cman_control = "1" if Skills.combatmaneuvers >= 1
  end

  if ashborne_setting_cman_control == "0"
    nil
  else
    $ashborne_cman_control = "1" if Skills.combatmaneuvers >= 1
  end

  if ashborne_setting_no_cman_control == "0"
    nil
  else
    $ashborne_no_cman_control = "1"
  end

  if Skills.combatmaneuvers == 0
    $ashborne_no_cman_control = "1"
  end

  if ashborne_setting_no_shield_control == "0"
    nil
  else
    $ashborne_no_shield_control = "1"
  end

  if ashborne_setting_no_weapon_control == "0"
    nil
  else
    $ashborne_no_weapon_control = "1"
  end

  if ashborne_setting_no_2weapon_control == "0"
    nil
  else
    $ashborne_no_2weapon_control = "1"
  end

  if ashborne_setting_no_mstrike_control == "0"
    nil
  else
    $ashborne_no_mstrike_control = "1"
    $ashborne_disable_mstrike = "1"
  end

  if Skills.shielduse == 0
    $ashborne_no_shield_control = "1"
  end



  if ashborne_setting_no_society == "0"
    nil
  else
    $ashborne_no_society = "1"
  end

  if ashborne_setting_no_stun == "0"
    nil
  else
    $ashborne_no_stun = "1"
  end


  if ashborne_setting_bounty_noherb == "0"
    nil
  else
    $ashborne_bounty_noherb = "1"
  end

  if ashborne_setting_bounty_noskin == "0"
    nil
  else
    $ashborne_bounty_noskin = "1"
  end

  if ashborne_setting_bounty_nobandit == "0"
    nil
  else
    $ashborne_bounty_nobandit = "1"
  end


  if ashborne_setting_bounty_nogroup == "0"
    nil
  else
    $ashborne_bounty_nogroup = "1"
  end




  if script.vars[1].downcase =~ /update|ereset|sreset|greset|reset|help|setup|cleanup/
    nil
  elsif script.vars[2].downcase =~ /qlite|drlite/
    nil
  else
    # Detect Aim Settings

    result = dothistimeout "aim", 2, /not aiming at anything|head|right (arm|leg|hand|eye)|left (arm|leg|hand|eye)|chest|back|neck|abdomen/
    if result =~ /not aiming at anything/
      $ashborne_current_aim = "0"
    elsif result =~ /head/
      $ashborne_current_aim = "head"
    elsif result =~ /right arm/
      $ashborne_current_aim = "right arm"
    elsif result =~ /right leg/
      $ashborne_current_aim = "right leg"
    elsif result =~ /right hand/
      $ashborne_current_aim = "right hand"
    elsif result =~ /right eye/
      $ashborne_current_aim = "right eye"
    elsif result =~ /left arm/
      $ashborne_current_aim = "right arm"
    elsif result =~ /left leg/
      $ashborne_current_aim = "right leg"
    elsif result =~ /left hand/
      $ashborne_current_aim = "right hand"
    elsif result =~ /left eye/
      $ashborne_current_aim = "right eye"
    elsif result =~ /chest/
      $ashborne_current_aim = "chest"
    elsif result =~ /back/
      $ashborne_current_aim = "back"
    elsif result =~ /neck/
      $ashborne_current_aim = "neck"
    elsif result =~ /abdomen/
      $ashborne_current_aim = "abdomen"

    end
  end

  if $ashborne_towns_landing.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Landing"
  end

  if $ashborne_towns_icemule.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Icemule"
  end

  if $ashborne_towns_solhaven.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Solhaven"
  end

  if $ashborne_towns_riverrest.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "River's Rest"
  end

  if $ashborne_towns_teras.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Teras"
  end

  if $ashborne_towns_vaalor.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Vaalor"
  end

  if $ashborne_towns_illistim.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Illistim"
  end

  if $ashborne_towns_zul.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Zul Logoth"
  end

  if $ashborne_towns_kraken.include?(Ashborne_toolkit.current_room_id)
    $ashborne_bounty_town = "Kraken's Fall"
  end

  if checkarea =~ /The Rift/
    $ashborne_bounty_town = "Icemule"
  end

  if ashborne_setting_force_target == "0"
    nil
  else
    $ashborne_force_target = ashborne_setting_force_target
  end

  if ashborne_setting_bounty_lite == "0"
    nil
  else
    $ashborne_bounty_lite = "1"
  end

  if ashborne_setting_no_cock == "0"
    nil
  else
    $ashborne_no_cock = "1"
  end

  if $ashborne_my_style =~ /7|8/
    if $ashborne_no_cock == "1"
      nil
    else
      $ashborne_use_cock = "1"
    end
  end

  if ashborne_setting_no_waggle == "0"
    nil
  else
    $ashborne_no_waggle = "1"
  end

  if ashborne_setting_no_herbs == "0"
    nil
  else
    $ashborne_no_herbs = "1"
  end

  if $ashborne_my_area =~ /moonmyklian|moonmagru|pineglacei|icebush|iceshrub/
    $ashborne_use_herbs = "1"
    Ashborne_toolkit.herb_script_check

  end

  if ashborne_setting_use_herbs == "0"
    nil
  else

    $ashborne_use_herbs = "1"
    Ashborne_toolkit.herb_script_check

  end

  if ashborne_setting_330_sanctify == "0"
    nil
  else

    $ashborne_330_sanctify = "1" if Stats.prof == "Cleric" && Stats.level >= 30 && Spell[330].known?

  end

  if $ashborne_my_style =~ /9/ && Stats.prof =~ /Empath|Cleric|Wizard|Sorcerer/
    if Ashborne_toolkit.huntpro_spell_baseline? && Stats.level <= 5
      $ashborne_style9_arcaneblast = "1"
    end

    if ashborne_setting_style9_arcaneblast == "0"
      nil
    else
      $ashborne_style9_arcaneblast = "1"
    end

    if ashborne_setting_style9_arcanecs == "0"
      nil
    else
      $ashborne_style9_arcanecs = "1"
    end

  end

  if Stats.prof =~ /Warrior/
    if ashborne_setting_berserk == "0"
      nil
    else
      $ashborne_cman_berserk = "1"
    end
  end

  if ashborne_setting_no_berserk == "0"
    nil
  else
    $ashborne_no_berserk = "1"
  end

  if ashborne_setting_flee == "0"
    nil
  else
    $ashborne_flee_counter = ashborne_setting_flee.to_i
  end

  if ashborne_setting_nocleanupherbs == "0"
    nil
  else
    $ashborne_nocleanupherbs = "1"
  end


  if ashborne_setting_weapon_attune == "0"
    # Set attunement for character
    if Skills.brawling >= 10
      $ashborne_weapon_attune = "brawling"
      Settings[Char.name]['ashborne_setting_weapon_attune']	= "brawling"
      Settings.save
    elsif Skills.bluntweapons >= 10
      $ashborne_weapon_attune = "blunt"
      Settings[Char.name]['ashborne_setting_weapon_attune']	= "blunt"
      Settings.save
    elsif Skills.edgedweapons >= 10
      $ashborne_weapon_attune = "edged"
      Settings[Char.name]['ashborne_setting_weapon_attune']	= "edged"
      Settings.save
    elsif Skills.polearmweapons >= 10
      $ashborne_weapon_attune = "polearm"
      Settings[Char.name]['ashborne_setting_weapon_attune']	= "polearm"
      Settings.save
    elsif Skills.rangedweapons >= 10
      $ashborne_weapon_attune = "ranged"
      Settings[Char.name]['ashborne_setting_weapon_attune']	= "ranged"
      Settings.save
    elsif Skills.twohandedweapons >= 10
      $ashborne_weapon_attune = "2hw"
      Settings[Char.name]['ashborne_setting_weapon_attune']	= "2hw"
      Settings.save
    end
  else
    $ashborne_weapon_attune = "#{ashborne_setting_weapon_attune}"
    $ashborne_weapon_attune = $ashborne_weapon_attune.downcase
  end

  if Stats.prof =~ /Wizard|Cleric|Empath|Sorcerer/
    $ashborne_no_weapon_control = "1"
  end

  if ashborne_setting_meditate == "0"
    nil
  else
    if Stats.prof =~ /Cleric|Empath/
      $ashborne_meditate = "1"
    end
  end

  if ashborne_setting_disable_mana == "0"
    nil
  else
    $ashborne_disable_mana = "1"
  end

  if ashborne_setting_defensive_stance == "0"
    nil
  else
    $ashborne_stance_defensive = "#{ashborne_setting_defensive_stance}"
  end

  if ashborne_setting_offensive_stance == "0"
    nil
  else
    $ashborne_stance_offensive = "#{ashborne_setting_offensive_stance}"
  end

  if ashborne_setting_society_spellactive == "0"
    nil
  else
    $ashborne_society_spellactive = "1"

    if Script.exists? "spellactive"
      nil
    else
      Script.run('repository', 'download spellactive.lic')
    end
  end



  if ashborne_setting_disable_140 == "0"
    nil
  else
    $ashborne_disable_140 = "1"
  end

  if ashborne_setting_disable_240 == "0"
    nil
  else
    $ashborne_disable_240 = "1"
  end

  if ashborne_setting_disable_919 == "0"
    nil
  else
    $ashborne_disable_919 = "1"
  end

  if ashborne_setting_disable_306 == "0"
    nil
  else
    $ashborne_disable_306 = "1"
  end


  if ashborne_setting_boost_long == "0"
    nil
  else
    $ashborne_boost_long = "1"
  end

  if ashborne_setting_boost_loot == "0"
    nil
  else
    $ashborne_boost_loot = "#{ashborne_setting_boost_loot}"
  end


  if ashborne_setting_qc_debug == "0"
    nil
  else
    $ashborne_qc_debug = "1"
  end

  if ashborne_setting_qc_testing == "0"
    nil
  else
    $ashborne_qc_testing = "1"
  end

  if ashborne_setting_taxi == "0"
    nil
  else
    $ashborne_taxi = "1"
  end

  if ashborne_setting_immolate == "0"
    nil
  else
    $ashborne_immolate = "1"
  end

  $ashborne_spell_learning = ashborne_setting_spell_learning.to_s == "1" ? "1" : "0"
  $ashborne_mana_leech_percent = [[ashborne_setting_mana_leech_percent.to_i, 1].max, 100].min

  if Stats.prof =~ /Wizard/ && Stats.level >= 50 && Skills.spellaiming < 1
    $ashborne_immolate = "1"
  else
    nil
  end



  if ashborne_setting_timelimit == "0"
    nil
  else
    $ashborne_timelimit = "#{ashborne_setting_timelimit.to_i}"
  end



  if ashborne_setting_noquartz == "0"
    nil
  else
    $ashborne_noquartz = "1"
  end

  # GameOBJ Disables

  if ashborne_setting_disable_pod == "0"
    nil
  else
    $ashborne_disable_pod = "1"
  end

  if ashborne_setting_disable_cloud == "0"
    nil
  else
    $ashborne_disable_cloud = "1"
  end

  if ashborne_setting_disable_void == "0"
    nil
  else
    $ashborne_disable_void = "1"
  end

  if ashborne_setting_disable_vine == "0"
    nil
  else
    $ashborne_disable_vine = "1"
  end

  if ashborne_setting_disable_sandstorm == "0"
    nil
  else
    $ashborne_disable_sandstorm = "1"
  end

  if ashborne_setting_disable_web == "0"
    nil
  else
    $ashborne_disable_web = "1"
  end

  if ashborne_setting_disable_arms == "0"
    nil
  else
    $ashborne_disable_arms = "1"
  end

  if ashborne_setting_disable_tempest == "0"
    nil
  else
    $ashborne_disable_tempest = "1"
  end

  if ashborne_setting_solo_mode == "0"
    nil
  else
    # DESTROY ALL GROUP VARIABLES
    $ashborne_solo_mode = "1"
    $ashborne_group_ai = "0"

  end

  if ashborne_setting_use_wands == "0"
    nil
  else
    $ashborne_use_wands = "1"
  end

  if ashborne_setting_dead_wands == "0"
    nil
  else
    $ashborne_dead_wands = "#{ashborne_setting_dead_wands}"
  end

  if ashborne_setting_get_invoked == "0"
    nil
  else
    $ashborne_get_invoked = "1"
  end



  if ashborne_setting_rescuebox == "0"
    nil
  else
    $ashborne_rescuebox = "1"
  end


  if ashborne_setting_stomp == "0"
    nil
  else
    $ashborne_stomp = "1"
  end

  if ashborne_setting_705cs == "0"
    nil
  else
    $ashborne_705cs = "1"
  end

  if ashborne_setting_camo == "0"
    nil
  else
    if ((Stats.prof == "Ranger") && (Stats.level >= 8) && (Spell[608].known?))
      $ashborne_camo = "1"
    end
  end

  $ashborne_cman_watch = "1" # if $ashborne_cman_control == "1"
  Script.run('repository', 'download fixit.lic') if !Script.exists?('fixit')
  Script.run('repository', 'download eherbs.lic') if !Script.exists?('eherbs')
}

ashborne_error_trap = proc {
  if ashborne_my_style == "1"
    nil
  elsif ashborne_my_style == "2"
    nil
  elsif ashborne_my_style == "3"
    nil
  elsif ashborne_my_style == "4"
    nil
  elsif ashborne_my_style == "5"
    nil
  elsif ashborne_my_style == "6"
    nil
  elsif ashborne_my_style == "7"
    nil
  elsif ashborne_my_style == "8"
    nil
  elsif ashborne_my_style == "9"
    nil
  elsif ashborne_my_style == "bandit"
    nil
  else
    Ashborne_toolkit.top_menu
    respond "Hi #{Char.name}, I noticed you chose a style that doesn't exist. "
    respond
    respond "Use ;ashborne help for commands and setup options."
    Ashborne_toolkit.bottom_menu
    exit
  end

  # Bandit Style check
  if ashborne_my_style == "bandit"
    if ashborne_my_area == nil
      Ashborne_toolkit.ashborne_intel_service_check
      $ashborne_bounty_bandit_buddy = "1"
      Ashborne_toolkit.get_bandits
      respond "I broke out of my style bandit"
      exit
    else
      Ashborne_toolkit.top_menu
      respond "#{Char.name}, for the get bandit feature, use ;ashborne bandit"
      Ashborne_toolkit.bottom_menu
      exit
    end
  end



  if ashborne_master_hunting_zones.include?(ashborne_my_area) || Ashborne_toolkit.huntplan_catalog_zone(ashborne_my_area)
    nil
  else
    Ashborne_toolkit.top_menu
    respond "Hi #{Char.name}, I noticed you chose an area that doesn't exist. "
    respond
    respond "Use ;ashborne help for commands and setup options."
    Ashborne_toolkit.bottom_menu
    exit
  end


  # Pure Check
  if ashborne_my_style == "9" && Stats.prof =~ /Warrior|Rogue|Monk/
    Ashborne_toolkit.top_menu
    respond "Hi #{Char.name}, I apologize for any confusion."
    respond
    respond "Style 9 only works for Clerics, Empaths, Wizards, Sorcerers, Rangers, Paladins."
    respond
    respond "Use ;ashborne help for commands and setup options."
    Ashborne_toolkit.bottom_menu
    exit
  elsif ashborne_my_style == "9" && Stats.prof =~ /Ranger/
    if Spell[603].known? && Stats.level >= 3
      nil
    else
      Ashborne_toolkit.top_menu
      respond "Hi #{Char.name}, I apologize for any confusion."
      respond
      respond "Style 9 for Rangers requires level 3 and spell knowledge of 603 Wild Entropy."
      respond
      respond "Consider another style for now or train a bit more.  Thanks!"
      respond
    respond "Use ;ashborne help for commands and setup options."
      Ashborne_toolkit.bottom_menu
      exit
    end
  elsif ashborne_my_style == "9" && Stats.prof =~ /Bard/
    if Spell[1008].known? && Stats.level >= 8
      nil
    else
      Ashborne_toolkit.top_menu
      respond "Hi #{Char.name}, I apologize for any confusion."
      respond
      respond "Style 9 for Bards requires level 8 and spell knowledge of 1008 Stunning Shout."
      respond
      respond "Consider another style for now or train a bit more.  Thanks!"
      respond
      respond "Use ;ashborne help for commands and setup options."
      Ashborne_toolkit.bottom_menu
      exit
    end

  elsif ashborne_my_style == "9" && Stats.prof =~ /Paladin/
    if Spell[1603].known? && Stats.level >= 3
      nil
    else
      Ashborne_toolkit.top_menu
      respond "Hi #{Char.name}, I apologize for any confusion."
      respond
      respond "Style 9 for Paladins requires level 3 and spell knowledge of 1603 Templar's Verdict."
      respond
      respond "Consider another style for now or train a bit more.  Thanks!"
      respond
      respond "Use ;ashborne help for commands and setup options."
      Ashborne_toolkit.bottom_menu
      exit
    end

  end


  # Group Leader Check Error Trap
  if ashborne_my_area == "group"
    if ashborne_setting_leader == "0"
      Ashborne_toolkit.top_menu
      respond "Hi #{Char.name}, I apologize for any confusion."
      respond
      respond "You need to set your group leader before activating group mode."
      respond
      respond ";ashborne setup change leader Name"
      respond
      respond "Use ;ashborne help for commands and setup options."
      Ashborne_toolkit.bottom_menu
      exit
    end

    if ashborne_setting_leader == "#{Char.name}"
      Ashborne_toolkit.top_menu
      respond "Hi #{Char.name}, I apologize for any confusion."
      respond
      respond "If you're the group leader, you should pick a creature area instead of group."
      respond
      respond "Use ;ashborne help for commands and setup options."
      Ashborne_toolkit.bottom_menu
      exit
    end

  end
}


ashborne_hunting_zones = proc {
  # fput "disband" if $ashborne_group_ai == "1"
  Ashborne_toolkit.mstrike_setup unless script.vars[2].downcase =~ /qlite|drlite/

  # Landing

  if $ashborne_my_area =~ /wlkobold/

    $ashborne_my_area_level = 1
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6313')
    pause 1

  elsif $ashborne_my_area =~ /wlrolton/

    $ashborne_my_area_level = 1
    $ashborne_my_area_type = "Living"

    Script.run('go2', '414')
    pause 1


  elsif $ashborne_my_area =~ /wlshade/

    $ashborne_spawn_delay = 1

    $ashborne_my_area_level = 2
    $ashborne_my_area_type = "Undead"

    Script.run('go2', '7510')
    pause 1

  elsif $ashborne_my_area =~ /wlcentaur/

    $ashborne_my_area_level = 23
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6997')
    pause 1

  elsif $ashborne_my_area =~ /wlmeingolem/

    $ashborne_spawn_delay = 1

    $ashborne_my_area_level = 37
    $ashborne_my_area_type = "Living"

    Script.run('go2', '7039')
    pause 1



  elsif $ashborne_my_area =~ /wlhobgoblin/

    $ashborne_my_area_level = 3
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6721')
    pause 1

  elsif $ashborne_my_area =~ /wlgak/

    $ashborne_my_area_level = 2
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6739')
    pause 1

  elsif $ashborne_my_area =~ /wlgremlin/

    $ashborne_my_area_level = 5
    $ashborne_my_area_type = "Living"

    Script.run('go2', '14724')
    pause 1

  elsif $ashborne_my_area =~ /wlschieftain/

    $ashborne_my_area_level = 11
    $ashborne_my_area_type = "Living"

    Script.run('go2', '7654')
    pause 1

  elsif $ashborne_my_area =~ /wlworm/

    $ashborne_my_area_level = 1
    $ashborne_my_area_type = "Living"

    Script.run('go2', '483')
    pause 1

  elsif $ashborne_my_area =~ /wlrat/

    $ashborne_my_area_level = 1
    $ashborne_my_area_type = "Living"

    Script.run('go2', '7493')
    pause 1

  elsif $ashborne_my_area =~ /wlsquirrel/

    $ashborne_spawn_delay = 0.25
    $ashborne_my_area_level = 2
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6280')
    pause 1

  elsif $ashborne_my_area =~ /wlkvillage/

    $ashborne_spawn_delay = 0.25
    $ashborne_my_area_level = 1
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6282')
    pause 1


  elsif $ashborne_my_area =~ /wlvysan/

    $ashborne_my_area_level = 3
    $ashborne_my_area_type = "Living"

    Script.run('go2', '7752')
    pause 1

  elsif $ashborne_my_area =~ /wlfisherman/

    $ashborne_my_area_level = 1
    $ashborne_my_area_type = "Undead"

    Script.run('go2', '7644')
    pause 1

  elsif $ashborne_my_area =~ /wlmummy/

    $ashborne_my_area_level = 6
    $ashborne_my_area_type = "Undead"

    Script.run('go2', '4144')
    pause 1

  elsif $ashborne_my_area =~ /wlorc/

    $ashborne_my_area_level = 8
    $ashborne_my_area_type = "Living"

    Script.run('go2', '7937')
    pause 1

  elsif $ashborne_my_area =~ /wlthrak/

    if Ashborne_toolkit.activate_huntplan_catalog_zone("thrak")
      nil
    else
      $ashborne_my_area_level = 9
      $ashborne_my_area_type = "Living"

      Script.run('go2', '4300')
      pause 1
    end

  elsif $ashborne_my_area =~ /wlmonhobgoblin/

    $ashborne_my_area_level = 3
    $ashborne_my_area_type = "Living"

    Script.run('go2', '6783')
    pause 1

  elsif $ashborne_my_area =~ /wlgorc/

    $ashborne_my_area_level = 8
    $ashborne_my_area_type = "Living"

    Script.run('go2', '7964')
    pause 1

  elsif $ashborne_my_area =~ /wlgreyorc/

