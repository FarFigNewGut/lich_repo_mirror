  def ashborne_stow_all
    if $ashborne_right_hand_detect == "0" && $ashborne_left_hand_detect == "0"

      if checkright == nil && checkleft == nil
        nil
      else
        fput "sheath"
        # fput "store weapon"
        fput "store ranged" if $ashborne_my_style =~ /5|6|7|8/
        fput "store shield" if Skills.shielduse >= 1
        fput "stow all"
      end
    else
      nil
    end

    if $ashborne_right_hand_detect != "0" && $ashborne_left_hand_detect == "0"
      if checkleft != nil
        fput "store ranged" if $ashborne_my_style =~ /5|6|7|8/
        fput "store shield" if Skills.shielduse >= 1
        fput "stow left"
      end

      if checkright == "#{$ashborne_right_hand_detect}"
        nil
      else
        fput "sheath"
        # fput "store weapon"
        fput "stow right"
      end
    end


    if $ashborne_right_hand_detect == "0" && $ashborne_left_hand_detect != "0"
      if checkright != nil
        fput "sheath"
        # fput "store weapon"
        fput "stow right"
      end

      if checkleft == "#{$ashborne_left_hand_detect}"
        nil
      else
        fput "store ranged" if $ashborne_my_style =~ /5|6|7|8/
        fput "store shield" if Skills.shielduse >= 1
        fput "stow right"
      end

    end

    if $ashborne_action == 99
      fput "sheath"
      # fput "store weapon"
      fput "store ranged" if $ashborne_my_style =~ /5|6|7|8/
      fput "store shield" if Skills.shielduse >= 1
      fput "stow all"
    end
  end

  def endcombat_actionreset
    Ashborne_toolkit.post_fight_sanity_sweep
    Ashborne_toolkit.stance_guarded

    if $ashborne_action == 4
      nil
    elsif $ashborne_action == 95
      nil
    elsif $ashborne_action == 96
      nil
    elsif $ashborne_action == 97
      nil
    elsif $ashborne_action == 98
      nil
    elsif $ashborne_action == 99
      nil

    else
      $ashborne_action = 0
    end
  end

  def end_combat_waggle
    return nil if Ashborne_toolkit.noise_lockdown?

    if $ashborne_no_waggle != "0"
      nil
    else
      if Script.exists? "ewaggle"
        do_client ";ewaggle"
      else
        Script.run('repository', 'download ewaggle.lic')
        do_client ";ewaggle"
      end

      wait_while { running? "ewaggle" }
    end
  end

  def hold_group
    if $ashborne_group_member1 != "0"
      fput "hold #{$ashborne_group_member1}"
    end
    if $ashborne_group_member2 != "0"
      fput "hold #{$ashborne_group_member2}"
    end
    if $ashborne_group_member3 != "0"
      fput "hold #{$ashborne_group_member3}"
