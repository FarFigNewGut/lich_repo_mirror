  def spell_override_toggles
    # This is only used in the specific creature overrides area to cycle between 2+ spells
    if Stats.prof =~ /Cleric/
      if $ashborne_spell_override_toggle == 0
        $ashborne_cleric_primary_spell = 309 if Spell[309].known?
        $ashborne_spell_override_toggle = 1
      elsif $ashborne_spell_override_toggle == 1
        $ashborne_cleric_primary_spell = 302 if Spell[302].known?
        $ashborne_spell_override_toggle = 0
      end
    end
  end

  def wizard_target_name
    name = $ashborne_current_target.to_s
    name = $ashborne_name_placeholder.to_s if name.empty?
    name = GameObj.targets.first.name.to_s if name.empty? && !GameObj.targets.empty?
    name.downcase
  rescue
    ""
  end

  def select_custom_spell_rotation
    rotation = Array($ashborne_custom_spell_rotation).map(&:to_i).select { |spell_number| spell_number > 0 }
    if rotation.empty?
      $ashborne_spell_default = "0"
      return nil
    end

    ready = rotation.select { |spell_number| Spell[spell_number].known? && Spell[spell_number].affordable? }
    if ready.empty?
      $ashborne_spell_default = "0"
      if Time.now.to_i >= $ashborne_custom_spell_warning_at.to_i
        respond "No configured custom attack spell is currently known and affordable; using HuntPro's normal spell choice."
        $ashborne_custom_spell_warning_at = Time.now.to_i + 30
      end
      return nil
    end

    $ashborne_custom_spell_rotation_index = ($ashborne_custom_spell_rotation_index.to_i + 1) % ready.length
    $ashborne_spell_default = ready[$ashborne_custom_spell_rotation_index].to_s
  rescue => error
    $ashborne_spell_default = "0"
    respond "Custom spell rotation warning: #{error.message}" if $ashborne_qc_debug == "1"
    nil
  end

  def style9_spell_cast
    selected_spell = if $ashborne_spell_default.to_s != "0"
                       $ashborne_spell_default.to_s[/\d+/].to_i
                     else
                       Ashborne_toolkit.current_style9_spell_number
                     end
    selected_spell = 1700 if $ashborne_style9_blastround == "1"
    if selected_spell == 1700 && $ashborne_style9_arcaneblast.to_s != "1"
      $ashborne_style9_blastround = "0"
      $ashborne_return_why = "Arcane Blast (1700) is disabled and no permitted style 9 attack was available."
      $ashborne_action = 99
      return false
    end

    Ashborne_toolkit.spell_cast
  end

  def wizard_spell_ready?(spell_number, minimum_mana = nil)
    return false if minimum_mana && checkmana.to_i < minimum_mana.to_i

    Spell[spell_number].known? && Spell[spell_number].affordable?
  rescue
    false
  end

  def wizard_arcane_fallback
    Skills.spellaiming >= 1 && $ashborne_style9_arcanecs == "0" ? "1700b" : 1700
  rescue
    1700
  end

  def wizard_attunement
    return $ashborne_wizard_attunement if defined?($ashborne_wizard_attunement_checked) &&
      $ashborne_wizard_attunement_checked

    $ashborne_wizard_attunement_checked = true
    response = dothistimeout "attune", 3,
      /You are attuned to the Element of (?:Air|Earth|Fire|Water|Lightning)/i
    match = response.to_s.match(/Element of (Air|Earth|Fire|Water|Lightning)/i)
    $ashborne_wizard_attunement = match ? match[1].downcase : nil
  rescue
    $ashborne_wizard_attunement = nil
  end

  def wizard_target_key
    target = GameObj.targets.find { |creature| creature.name.to_s.downcase == wizard_target_name } ||
      GameObj.targets.first
    target ? "#{target.id}:#{target.name}" : wizard_target_name
  rescue
    wizard_target_name
  end

  def wizard_chromatic_exploit_spell
    # The 502 overlay enhances HuntPro's attack cycle; it must not replace
    # HuntPro's steam-first choice for creatures associated with cold.
    cold_target = wizard_target_name.match?(/(?:ice|icy|frost|frozen|snow|rime|cold|glacier)/)
    if cold_target && Skills.elfire >= 20 && Spell[903].known? &&
        Spell[1707].affordable? && checkmana.to_i >= 6
      return 1707
    end

    case wizard_attunement
    when "fire"
      return 906 if wizard_spell_ready?(906, 6)
      return 908 if wizard_spell_ready?(908, 8)
    when "water"
      return 907 if wizard_spell_ready?(907, 7)
      return 903 if wizard_spell_ready?(903, 3)
    when "lightning"
      return 901 if wizard_spell_ready?(901, 1)
    end
    nil
  rescue
    nil
  end

  def wizard_rotation_spell_choice
    target_key = wizard_target_key
    exploit_spell = wizard_chromatic_exploit_spell
    return nil if target_key.to_s.empty? || exploit_spell.nil?

    state = $ashborne_wizard_rotation_state
    if !state.is_a?(Hash) || state[:target] != target_key
      state = { target: target_key, phase: :setup }
      $ashborne_wizard_rotation_state = state
    end

    if state[:phase] == :setup
      return nil unless wizard_spell_ready?(502, 2) && percentmana > mana_reserve

      state[:phase] = :exploit
      return 502
    end

    # Keep firing the selected exploit spell until the creature changes or dies.
    exploit_spell
  rescue
    nil
  end

  def wizard_damage_spell_choice(low_mana = false)
    # Preserve HuntPro's proven default order. Creature-specific overrides run before this.
    cold_target = wizard_target_name.match?(/(?:ice|icy|frost|frozen|snow|rime|cold|glacier)/)
    return 901 if low_mana && wizard_spell_ready?(901, 1)
    return 1707 if Skills.elfire >= 20 && Spell[903].known? &&
      Spell[1707].affordable? && checkmana.to_i >= 6
    return 906 if cold_target && wizard_spell_ready?(906, 6)
    return 904 if wizard_spell_ready?(904, 4)
    return 903 if percentmana > 30 && wizard_spell_ready?(903, 3)
    return 901 if percentmana > 13 && wizard_spell_ready?(901, 1)

    wizard_arcane_fallback
  rescue
    wizard_arcane_fallback
  end

  def wizard_learned_spell_choice
    return nil unless $ashborne_spell_learning.to_s == "1"

    recommendations = $ashborne_spell_recommendations
    return nil unless recommendations.is_a?(Hash)

    spell_number = recommendations[wizard_target_name].to_i
    return nil if spell_number <= 0
    return nil unless Spell[spell_number].known? && Spell[spell_number].affordable?

    spell_number
  rescue
    nil
  end

  def wizard_mana_leech_due?
    return false unless Stats.prof.to_s == "Wizard"
    threshold = [[(defined?($ashborne_mana_leech_percent) ? $ashborne_mana_leech_percent : 60).to_i, 1].max, 100].min
    return false unless percentmana.to_i <= threshold
    return false unless Ashborne_toolkit.ability_allowed?("spell", 516)
    return false unless Spell[516].known? && Stats.level >= 16 && Spell[516].affordable?
    return false if GameObj.targets.empty?

    target_key = wizard_target_key
    state = $ashborne_wizard_mana_leech_state
    unless state.is_a?(Hash) && state[:target] == target_key
      state = { target: target_key, attempts: 0, next_at: 0.0 }
      $ashborne_wizard_mana_leech_state = state
    end
    state[:attempts].to_i < 2 && Time.now.to_f >= state[:next_at].to_f
  rescue
    false
  end

  def record_wizard_mana_leech_attempt
    state = $ashborne_wizard_mana_leech_state
    return false unless state.is_a?(Hash)

    state[:attempts] = state[:attempts].to_i + 1
    state[:next_at] = Time.now.to_f + 8.0
    true
  rescue
    false
  end

  def wizard_auto_spell_choice(low_mana = false)
    learned_spell = wizard_learned_spell_choice unless low_mana
    learned_spell || wizard_damage_spell_choice(low_mana)
  rescue
    wizard_damage_spell_choice(low_mana)
  end

  def caster_arcane_fallback
    Skills.spellaiming >= 1 && $ashborne_style9_arcanecs == "0" ? "1700b" : 1700
  rescue
    1700
  end

  def caster_spell_ready?(spell_number, minimum_mana = nil)
    return false if minimum_mana && checkmana.to_i < minimum_mana.to_i

    Spell[spell_number].known? && Spell[spell_number].affordable?
  rescue
    false
  end

  def caster_low_mana_spell_choice(profession = Stats.prof)
    case profession.to_s
    when "Wizard"
      wizard_auto_spell_choice(true)
    when "Empath"
      return 1106 if caster_spell_ready?(1106, 6)
      return 1110 if caster_spell_ready?(1110, 10)
      return 111 if caster_spell_ready?(111)
    when "Cleric"
      return 302 if caster_spell_ready?(302, 4)
      return 306 if $ashborne_disable_306.to_s == "0" && caster_spell_ready?(306)
      return 111 if caster_spell_ready?(111)
    when "Sorcerer"
      return 702 if caster_spell_ready?(702)
      return 705 if caster_spell_ready?(705)
      return 711 if caster_spell_ready?(711)
    when "Ranger"
      return 603 if caster_spell_ready?(603)
    when "Bard"
      return 1008 if caster_spell_ready?(1008)
    when "Paladin"
      return 1603 if caster_spell_ready?(1603)
    end

    caster_arcane_fallback
  rescue
    caster_arcane_fallback
  end

  def current_style9_spell_number
    value = case Stats.prof.to_s
            when "Empath" then $ashborne_empath_primary_spell
            when "Cleric" then $ashborne_cleric_primary_spell
            when "Wizard" then $ashborne_wizard_primary_spell
            when "Sorcerer" then $ashborne_sorcerer_primary_spell
            when "Ranger" then $ashborne_ranger_primary_spell
            when "Bard" then $ashborne_bard_primary_spell
            when "Paladin" then $ashborne_paladin_primary_spell
            end
    value.to_s[/\d+/].to_i
  rescue
    0
  end

  def observe_spell_cast_intent
    return false unless $ashborne_spell_learning.to_s == "1"

    spell_number = current_style9_spell_number
    return false if spell_number <= 0 || spell_number == 9999

    $ashborne_spell_observation_seq = $ashborne_spell_observation_seq.to_i + 1
    $ashborne_spell_observation = {
      seq: $ashborne_spell_observation_seq,
      spell: spell_number,
      profession: Stats.prof.to_s,
      creature: wizard_target_name,
      target_key: wizard_target_key,
      mana_before: checkmana.to_i,
      started_at: Time.now.to_f,
      source: $ashborne_style_9_primary_spell_override.to_s == "1700" ? "ashborne" : "forced"
    }
    true
  rescue
    false
  end

  def spell_choice
    Ashborne_toolkit.style_9_spell_overrides

    # Determine if you should make a last minute decision about what spell to cast
    if $ashborne_style_9_primary_spell_override == "1700"
      if Stats.prof == "Empath"

        if $ashborne_empath_primary_spell == "9999"
          nil
        elsif $ashborne_empath_primary_spell == 1115
          nil
        elsif $ashborne_empath_primary_spell == "1115b"
          nil
        elsif $ashborne_empath_primary_spell == 1106
          nil
        elsif $ashborne_empath_primary_spell == 111
          nil
        elsif $ashborne_empath_primary_spell == 1110
          nil
        elsif $ashborne_empath_primary_spell == "1700b"
          nil
        else
          if Stats.level >= 6
            $ashborne_empath_primary_spell = 1106 if Spell[1106].known?
          elsif Skills.spellaiming >= 1
            if $ashborne_style9_arcanecs == "1"
              $ashborne_empath_primary_spell = 1700
            else
              $ashborne_empath_primary_spell = "1700b"
            end
          else
            $ashborne_empath_primary_spell = 1700
          end
        end
      elsif Stats.prof == "Cleric"

        if $ashborne_cleric_primary_spell == "9999"
          nil
        elsif $ashborne_cleric_primary_spell == 302
          nil
        elsif $ashborne_cleric_primary_spell == 309
          nil
        elsif $ashborne_cleric_primary_spell == 111
          nil
        elsif $ashborne_cleric_primary_spell == "1700b"
          nil
        else
          if Stats.level >= 6 && Skills.spellaiming / 2 - 1 >= Stats.level
            if $ashborne_cleric_toggle == 0
              $ashborne_cleric_primary_spell = 309 if Spell[309].known?
              $ashborne_cleric_toggle = 1
            elsif $ashborne_cleric_toggle == 1
              if $ashborne_disable_306 == "0"
                $ashborne_cleric_primary_spell = 306 if Spell[306].known?
                $ashborne_cleric_toggle = 2
              else
                $ashborne_cleric_primary_spell = 302 if Spell[302].known?
                $ashborne_cleric_toggle = 2
              end
            elsif $ashborne_cleric_toggle == 2
              $ashborne_cleric_primary_spell = 302 if Spell[302].known?
              $ashborne_cleric_toggle = 0
            end
          elsif Stats.level >= 20
            if $ashborne_cleric_toggle == 0
              $ashborne_cleric_primary_spell = 309 if Spell[309].known?
              $ashborne_cleric_toggle = 1
            elsif $ashborne_cleric_toggle == 1
              $ashborne_cleric_primary_spell = 302 if Spell[302].known?
              $ashborne_cleric_toggle = 0
            end
          elsif Stats.level >= 2
            $ashborne_cleric_primary_spell = 302 if Spell[302].known?
          elsif Skills.spellaiming >= 1
            if $ashborne_style9_arcanecs == "1"
              $ashborne_cleric_primary_spell = 1700
            else
              $ashborne_cleric_primary_spell = "1700b"
            end
          else
            $ashborne_cleric_primary_spell = 1700
          end
        end

      elsif Stats.prof == "Wizard"

        # Immolation Build Override
        if $ashborne_immolate == "1"
          if $chromatic_toggle == 0
            $chromatic_toggle = 1
            $ashborne_wizard_primary_spell = 519
          elsif $chromatic_toggle == 1
            $chromatic_toggle = 0
            $ashborne_wizard_primary_spell = 502
          end
        end

        if $ashborne_wizard_primary_spell == "9999"
          nil
        elsif $ashborne_wizard_primary_spell == 901
          nil
        elsif $ashborne_wizard_primary_spell == 903
          nil
        elsif $ashborne_wizard_primary_spell == 904
          nil
        elsif $ashborne_wizard_primary_spell == 906
          nil
        elsif $ashborne_wizard_primary_spell == 907
          nil
        elsif $ashborne_wizard_primary_spell == 908
          nil
        elsif $ashborne_wizard_primary_spell == 910
          nil
        elsif $ashborne_wizard_primary_spell == 502
          nil
        elsif $ashborne_wizard_primary_spell == 519
          nil
        elsif $ashborne_wizard_primary_spell == 510
          nil
        elsif $ashborne_wizard_primary_spell == 505
          nil
        elsif $ashborne_wizard_primary_spell == 1707
          nil
        elsif $ashborne_wizard_primary_spell == "1700b"
          nil
        else
          if Skills.elfire >= 20 && Spell[903].known?
            $ashborne_wizard_primary_spell = 1707
          elsif Stats.level >= 4 && Spell[904].known?
            $ashborne_wizard_primary_spell = 904 if Spell[904].known?
          elsif Skills.spellaiming >= 1 && Spell[903].known? && Stats.level >= 3 && percentmana > 30
            $ashborne_wizard_primary_spell = 903 if Spell[903].known?
          elsif Skills.spellaiming >= 1 && Spell[901].known? && Stats.level >= 1 && percentmana > 13
            $ashborne_wizard_primary_spell = 901 if Spell[901].known?
          elsif Skills.spellaiming >= 1
            if $ashborne_style9_arcanecs == "1"
              $ashborne_wizard_primary_spell = 1700
            else
              $ashborne_wizard_primary_spell = "1700b"
            end
          else
            $ashborne_wizard_primary_spell = 1700
          end
        end

      elsif Stats.prof == "Sorcerer"

        if $ashborne_sorcerer_primary_spell == "9999"
          nil
        elsif $ashborne_sorcerer_primary_spell == 702
          nil
        elsif $ashborne_sorcerer_primary_spell == "1700b"
          nil
        else
          if Stats.level >= 70
            if $ashborne_sorcerer_toggle == 0
              $ashborne_sorcerer_primary_spell = 711 if Spell[711].known?
              $ashborne_sorcerer_toggle = 2
            elsif $ashborne_sorcerer_toggle == 1
              $ashborne_sorcerer_primary_spell = 702 if Spell[702].known?
              $ashborne_sorcerer_toggle = 0
            elsif $ashborne_sorcerer_toggle == 2
              $ashborne_sorcerer_primary_spell = 705 if Spell[705].known?
              $ashborne_sorcerer_toggle = 1
            end

          elsif Stats.level >= 20
            if $ashborne_sorcerer_toggle == 0
              $ashborne_sorcerer_primary_spell = 705 if Spell[705].known?
              $ashborne_sorcerer_toggle = 1
            elsif $ashborne_sorcerer_toggle == 1
              $ashborne_sorcerer_primary_spell = 702 if Spell[702].known?
              $ashborne_sorcerer_toggle = 0
            end

          elsif Stats.level >= 2
            $ashborne_sorcerer_primary_spell = 702 if Spell[702].known?
          elsif Skills.spellaiming >= 1
            if $ashborne_style9_arcanecs == "1"
              $ashborne_sorcerer_primary_spell = 1700
            else
              $ashborne_sorcerer_primary_spell = "1700b"
            end
          else
            $ashborne_sorcerer_primary_spell = 1700
          end
        end

      elsif Stats.prof == "Ranger"

        if $ashborne_ranger_primary_spell == "9999"
          nil
        elsif $ashborne_ranger_primary_spell == 603
          nil
        elsif $ashborne_ranger_primary_spell == "1700b"
          nil
        else
          if Stats.level >= 3
            $ashborne_ranger_primary_spell = 603 if Spell[603].known?
          end
        end

      elsif Stats.prof == "Bard"

        if $ashborne_bard_primary_spell == "9999"
          nil
        elsif $ashborne_bard_primary_spell == 1008
          nil
        elsif $ashborne_bard_primary_spell == "1700b"
          nil
        else
          if Stats.level >= 8
            $ashborne_bard_primary_spell = 1008 if Spell[1008].known?
          end
        end

      elsif Stats.prof == "Paladin"

        if $ashborne_paladin_primary_spell == "9999"
          nil
        elsif $ashborne_paladin_primary_spell == 1603
          nil
        elsif $ashborne_paladin_primary_spell == "1700b"
          nil
        else
          if Stats.level >= 3
            $ashborne_paladin_primary_spell = 1603 if Spell[1603].known?
          end
        end

      end
    end

    # Arcane Blast Round Override

    if $ashborne_style9_blastround == "0"
      nil
    else
      if Skills.spellaiming >= 1 && $ashborne_style9_arcanecs == "0"
        $ashborne_empath_primary_spell = "1700b"
        $ashborne_cleric_primary_spell = "1700b"
        $ashborne_wizard_primary_spell = "1700b"
        $ashborne_sorcerer_primary_spell = "1700b"
      # $ashborne_ranger_primary_spell = "1700b"
      # $ashborne_bard_primary_spell = "1700b"
      # $ashborne_paladin_primary_spell = "1700b"
      else
        $ashborne_empath_primary_spell = 1700
        $ashborne_cleric_primary_spell = 1700
        $ashborne_wizard_primary_spell = 1700
        $ashborne_sorcerer_primary_spell = 1700
      end
    end
  end

  def force_spell
    if $ashborne_style9_blastround == "1"
      if Skills.spellaiming >= 1 && $ashborne_style9_arcanecs == "0"
        Ashborne_toolkit.stance_offensive
        fput "incant 1700 evoke" if Spell[1700].known? && Spell[1700].affordable?
        Ashborne_toolkit.true_stance_guarded
      else
        Spell[1700].cast() if Spell[1700].known? && Spell[1700].affordable?
        Ashborne_toolkit.true_stance_guarded
      end

    else
      if $ashborne_evoke_default == "1"
        Ashborne_toolkit.stance_offensive
        if Spell.active? "515"
          fput "incant #{$ashborne_spell_default} evoke" if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitcastrt?
          fput "incant #{$ashborne_spell_default} evoke" if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitcastrt?
          fput "incant #{$ashborne_spell_default} evoke" if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          Ashborne_toolkit.true_stance_guarded
          waitcastrt?
          Ashborne_toolkit.stance_guarded
        else
          fput "incant #{$ashborne_spell_default} evoke" if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitrt?
          Ashborne_toolkit.true_stance_guarded
          Ashborne_toolkit.stance_guarded
        end
      else
        if Spell.active? "515"
          Spell["#{$ashborne_spell_default}"].cast() if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitcastrt?
          Spell["#{$ashborne_spell_default}"].cast() if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitcastrt?
          Spell["#{$ashborne_spell_default}"].cast() if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitcastrt?
          Ashborne_toolkit.true_stance_guarded
          Ashborne_toolkit.stance_guarded
        else
          Spell["#{$ashborne_spell_default}"].cast() if Spell["#{$ashborne_spell_default}"].known? && Spell["#{$ashborne_spell_default}"].affordable?
          waitrt?
          Ashborne_toolkit.true_stance_guarded
          Ashborne_toolkit.stance_guarded
        end
      end
    end
  end

  def spell_cast
    # New Override Lich 5.5 Onward
    if $ashborne_spell_default == "0"
      nil
    else
      $ashborne_empath_primary_spell = "9999"
      $ashborne_cleric_primary_spell = "9999"
      $ashborne_wizard_primary_spell = "9999"
      $ashborne_sorcerer_primary_spell = "9999"
      $ashborne_ranger_primary_spell = "9999"
      $ashborne_bard_primary_spell = "9999"
      $ashborne_paladin_primary_spell = "9999"
    end

    if Stats.prof == "Empath"
      if $ashborne_empath_primary_spell == "9999"
        Ashborne_toolkit.force_spell
      elsif $ashborne_empath_primary_spell == 1115

        Spell[1115].cast() if Spell[1115].known? && Spell[1115].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_empath_primary_spell = 1700

      elsif $ashborne_empath_primary_spell == "1115b"

        Spell[1115].cast() if Spell[1115].known? && Spell[1115].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_empath_primary_spell = 1700

      elsif $ashborne_empath_primary_spell == 1106
        if Char.name =~ /Jara|Jarcation/
          fput "incant 1106" if Spell[1106].known? && Spell[1106].affordable?
          sleep 0.25
          Ashborne_toolkit.true_stance_guarded
          $ashborne_empath_primary_spell = 1700
        else
          Spell[1106].cast() if Spell[1106].known? && Spell[1106].affordable?
          Ashborne_toolkit.true_stance_guarded
          $ashborne_empath_primary_spell = 1700
        end

      elsif $ashborne_empath_primary_spell == 111

        Spell[111].cast() if Spell[111].known? && Spell[111].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_empath_primary_spell = 1700

      elsif $ashborne_empath_primary_spell == 1110

        Spell[1110].cast() if Spell[1110].known? && Spell[1110].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_empath_primary_spell = 1700

      elsif $ashborne_empath_primary_spell == "1700b"

        Ashborne_toolkit.stance_offensive
        fput "incant 1700 evoke" if Spell[1700].known? && Spell[1700].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_empath_primary_spell = 1700
        Ashborne_toolkit.stance_guarded


      elsif $ashborne_empath_primary_spell == 1700

        Spell[1700].cast() if Spell[1700].known? && Spell[1700].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_empath_primary_spell = 1700


      else
        respond "What Empath spell are you trying to cast?"
      end

    elsif Stats.prof == "Cleric"

      if $ashborne_cleric_primary_spell == "9999"
        Ashborne_toolkit.force_spell

      elsif $ashborne_cleric_primary_spell == 302
        Spell[302].cast() if Spell[302].known? && checkmana >= 4
        Ashborne_toolkit.true_stance_guarded
        $ashborne_cleric_primary_spell = 1700


      elsif $ashborne_cleric_primary_spell == 306
        if $ashborne_disable_306 == "0"
          Spell[306].cast() if Spell[306].known? && Spell[306].affordable?
          Ashborne_toolkit.true_stance_guarded
          $ashborne_cleric_primary_spell = 1700
        else
          Spell[302].cast() if Spell[302].known? && checkmana >= 4
          Ashborne_toolkit.true_stance_guarded
          $ashborne_cleric_primary_spell = 1700
        end

      elsif $ashborne_cleric_primary_spell == 309
        if $ashborne_309_toggle == 0
          fput "incant 309 evoke" if Spell[309].known? && Spell[309].affordable?
          Ashborne_toolkit.true_stance_guarded
          $ashborne_309_toggle = 10
          $ashborne_cleric_primary_spell = 1700
        else
          $ashborne_309_toggle = $ashborne_309_toggle - 1
          Spell[309].cast() if Spell[309].known? && Spell[309].affordable?
          Ashborne_toolkit.true_stance_guarded
          $ashborne_cleric_primary_spell = 1700
        end

      elsif $ashborne_cleric_primary_spell == 111
        Spell[111].cast() if Spell[111].known? && Spell[111].affordable?
        Ashborne_toolkit.true_stance_guarded
        $ashborne_cleric_primary_spell = 1700

      elsif $ashborne_cleric_primary_spell == "1700b"
        Ashborne_toolkit.stance_offensive
        fput "incant 1700 evoke" if Spell[1700].known? && Spell[1700].affordable?
        Ashborne_toolkit.true_stance_guarded
