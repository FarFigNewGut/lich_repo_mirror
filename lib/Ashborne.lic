  Settings[Char.name]['ashborne_setting_group_four']	= "#{script.vars[7]}" unless script.vars[7].downcase == nil
  Settings[Char.name]['ashborne_setting_group_five']	= "#{script.vars[8]}" unless script.vars[8].downcase == nil
  Settings[Char.name]['ashborne_setting_group_six']	= "#{script.vars[9]}" unless script.vars[9].downcase == nil
  Settings[Char.name]['ashborne_setting_group_seven']	= "#{script.vars[10]}" unless script.vars[10].downcase == nil
  Settings[Char.name]['ashborne_setting_group_eight']	= "#{script.vars[11]}" unless script.vars[11].downcase == nil
  Settings[Char.name]['ashborne_setting_group_nine']	= "#{script.vars[12]}" unless script.vars[12].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /gquiet/
  Settings[Char.name]['ashborne_setting_group_quiet']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /gpeace/
  Settings[Char.name]['ashborne_setting_group_peace']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /gshare/
  Settings[Char.name]['ashborne_setting_group_sharemana']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /groupnoise/
  Settings[Char.name]['ashborne_setting_group_noise']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /noiselock|noiselockdown/
  Ashborne_toolkit.set_noise_lockdown_setting(script.vars[4])
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\A(multitool|multiaccount|commandtool)\z/
  tool = script.vars[4].to_s.downcase
  unless %w[borg thunder].include?(tool)
    respond "Multi-account tool must be borg or thunder."
    exit
  end
  Settings[Char.name]['ashborne_setting_multi_account_tool'] = tool
  Settings.save
  respond "Ashborne will use #{tool == 'borg' ? 'Borg / Queen / Drone' : 'Thunder / Struck'} for multi-account commands. Set the same tool on every group character."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\A(addfollowers|additionalfollowers|extrafollowers)\z/
  followers = script.vars[4..-1].join(" ").split(/[;,\s]+/).reject { |name| name.empty? || name == "0" }
  invalid = followers.reject { |name| Ashborne_toolkit.valid_character_name?(name) }
  unless invalid.empty?
    respond "Invalid follower name#{invalid.length == 1 ? '' : 's'}: #{invalid.join(', ')}."
    exit
  end
  Settings[Char.name]['ashborne_setting_group_additional'] = followers.empty? ? "0" : followers.uniq(&:downcase).join(",")
  Settings.save
  respond "Additional Ashborne followers: #{followers.empty? ? 'none' : followers.join(', ')}."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /anticaster|anti-caster/
  Settings[Char.name]['ashborne_setting_anti_caster'] = script.vars[4].to_s == "0" ? "0" : "1"
  Settings.save
  respond "Reactive anti-caster coordination is now #{Settings[Char.name]['ashborne_setting_anti_caster'] == '1' ? 'enabled' : 'disabled'}."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /antimana|antireserve/
  reserve = script.vars[4].to_s.to_i
  reserve = 50 if reserve <= 0
  reserve = 90 if reserve > 90
  Settings[Char.name]['ashborne_setting_anti_caster_mana'] = reserve
  Settings.save
  respond "Reactive anti-caster spells will preserve at least #{reserve}% mana."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /preflight/
  Settings[Char.name]['ashborne_setting_preflight'] = script.vars[4].to_s == "0" ? "0" : "1"
  Settings.save
  respond "Automatic Ashborne preflight is now #{Settings[Char.name]['ashborne_setting_preflight'] == '1' ? 'enabled' : 'disabled'}."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\A(groupstyle|gstyle)\z/
  style = script.vars[4].to_s
  unless style =~ /\A[1-9]\z/
    respond "Group style must be an Ashborne combat style from 1 through 9."
    exit
  end
  Settings[Char.name]['ashborne_setting_group_style'] = style
  Settings.save
  respond "#{Char.name}'s Ashborne group combat style is now #{style}."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\Arole\z/
  role = Ashborne_toolkit.normalized_role(script.vars[4])
  Settings[Char.name]['ashborne_setting_role'] = role
  Settings.save
  respond "Ashborne role preference is now #{role}. Run ;ashborne setup capabilities to refresh the profile."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\A(jobs|coordinator)\z/
  Settings[Char.name]['ashborne_setting_job_coordinator'] = script.vars[4].to_s == "0" ? "0" : "1"
  Settings.save
  respond "Ashborne group job coordination is now #{Settings[Char.name]['ashborne_setting_job_coordinator'] == '1' ? 'enabled' : 'disabled'}."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\Amanareserve\z/
  reserve = script.vars[4].to_s.empty? ? 40 : script.vars[4].to_i
  reserve = [[reserve, 0].max, 95].min
  Settings[Char.name]['ashborne_setting_mana_reserve'] = reserve
  Settings.save
  respond "Ashborne general mana reserve is now #{reserve}%."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\Astaminareserve\z/
  reserve = script.vars[4].to_s.empty? ? 20 : script.vars[4].to_i
  reserve = [[reserve, 0].max, 95].min
  Settings[Char.name]['ashborne_setting_stamina_reserve'] = reserve
  Settings.save
  respond "Ashborne general stamina reserve is now #{reserve}%."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\Ahealthfloor\z/
  floor = script.vars[4].to_s.empty? ? 70 : script.vars[4].to_i
  floor = [[floor, 1].max, 100].min
  Settings[Char.name]['ashborne_setting_health_floor'] = floor
  Settings.save
  respond "Ashborne will return the group to town below #{floor}% health."
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /nocleanupherbs/
  Settings[Char.name]['ashborne_setting_nocleanupherbs']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /cleanup/
