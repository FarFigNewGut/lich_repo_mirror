elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /sanctify/
  Settings[Char.name]['ashborne_setting_330_sanctify']	= "#{script.vars[4]}" unless script.vars[4].downcase == nil
