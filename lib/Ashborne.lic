    nil
  else
    respond "Bounty Option: You will not complete bandit bounties."
  end

  if ashborne_setting_bounty_nogroup == "0"
    nil
  else
    respond "Bounty Option: You will not participate in group bounties."
  end



  if ashborne_setting_force_target == "0"
    nil
  else
    respond "Override: You will focus on killing this creature: #{$ashborne_force_target}."
    respond "          Reminder: This disables default bounty targets & ignores built in priority logic."
    respond "                    The ftarget option takes priority over blite option."
    respond "                    You can disable this feature with ;ashborne setup change ftarget 0 "
  end

  if ashborne_setting_bounty_lite == "0"
    nil
  else
    respond "Override: When you're on a bounty, you'll hunt all creatures in that zone."
    respond "          Reminder: The ftarget option takes priority over blite option."
  end

  if ashborne_setting_no_cock == "0"
    nil
  else
    respond "You will not COCK a ranged weapon during combat."
  end

  if ashborne_setting_nocleanupherbs == "0"
    nil
  else
    respond "You will not use ;eherbs during cleanup mode."
  end


  if ashborne_setting_no_herbs == "0"
    nil
  else
    respond "You will not use the combat herb feature for any zone."
  end

  if ashborne_setting_use_herbs == "0"
    nil
  else
    respond "You will use the combat herb feature for all zones."
  end

  if ashborne_setting_330_sanctify == "0"
    nil
  else
    respond "As a cleric with enough training, you will upkeep temporary Holy Fire flares on your weapon during cleanup."
  end

  if ashborne_setting_style9_arcaneblast == "0"
    respond "Automatic Arcane Blast (1700) is disabled."
  else
    respond "Automatic Arcane Blast (1700) is enabled above 5% mana. At 5% or lower, Ashborne returns to town immediately."
  end

  if ashborne_setting_style9_arcanecs == "0"
    nil
  else
    respond "Override: You will use the CS version of 1700 regardless of spell aiming skill."
  end

  if ashborne_setting_berserk == "0"
    nil
  else
    respond "As a warrior, you'll berserk during combat."
  end

  if ashborne_setting_no_berserk == "0"
    nil
  else
    respond "Override: As a warrior, you will not berserk."
  end

  if ashborne_setting_flee.to_i == "0"
    nil
  elsif ashborne_setting_flee.to_i == 0
    nil
  else
    respond "You'll run if there are more than #{ashborne_setting_flee} creatures in a room."
  end

  if ashborne_setting_meditate == "0"
    nil
  else
    respond "As a cleric or empath, you'll meditate after running cleanup."
  end

  if ashborne_setting_boost_long == "0"
    nil
  else
    respond "You will use a long term experience boost when starting the script or during combat if your mind is numbed or higher."
  end

  if ashborne_setting_boost_loot == "0"
    nil
  else
    respond "You will use a #{ashborne_setting_boost_loot} loot boost when running the script."
  end

  if ashborne_setting_qc_debug == "0"
    nil
  else
    respond "Quality Control: Debug Mode Enabled.  ;ashborne setup change debug 0 to disable."
  end

  if ashborne_setting_qc_testing == "0"
    nil
  else
    respond "Quality Control: Testing Mode Enabled.  ;ashborne setup change testing 0 to disable."
  end

  if ashborne_setting_taxi == "0"
    nil
  else
    respond "Taxi Service: You will go to the hunting zone, then exit the script."
  end

  if ashborne_setting_immolate == "0"
    nil
  else
    respond "Wizard 519 Immolation Build Enabled."
  end

  if ashborne_setting_spell_learning == "1"
    respond "Optional spell learning is enabled; manual casts may become evidence-based Wizard choices."
  else
    respond "Optional spell learning is disabled; caster attacks use the standard HuntPro cycle."
  end
  respond "Wizards will attempt Mana Leech at or below #{ashborne_setting_mana_leech_percent}% mana."

  if ashborne_setting_timelimit == "0"
    nil
  else
    respond "You will automatically stop running Ashborne after #{ashborne_setting_timelimit} seconds."
  end

  if ashborne_setting_noquartz == "0"
    nil
  else
    respond "When using style 9, you will not use quartz orbs."
  end


  if ashborne_setting_disable_pod == "0"
    nil
  else
    respond "You will ignore pod GameObjects."
  end

  if ashborne_setting_disable_cloud == "0"
    nil
  else
    respond "You will ignore cloud GameObjects."
  end

  if ashborne_setting_disable_void == "0"
    nil
  else
    respond "You will ignore void GameObjects."
  end

  if ashborne_setting_disable_vine == "0"
    nil
  else
    respond "You will ignore vine GameObjects."
  end

  if ashborne_setting_disable_sandstorm == "0"
    nil
  else
    respond "You will ignore sandstorm GameObjects."
  end

  if ashborne_setting_disable_web == "0"
    nil
  else
    respond "You will ignore web GameObjects."
  end

  if ashborne_setting_disable_arms == "0"
    nil
  else
    respond "You will ignore arms GameObjects."
  end

  if ashborne_setting_disable_tempest == "0"
    nil
  else
    respond "You will ignore tempest GameObjects."
  end

  if ashborne_setting_solo_mode == "0"
    nil
  else
    respond
    respond "***SOLO - You will ignore all group settings. - MODE***"
    respond "To disable use ;ashborne setup change gsolo 0"
    respond
  end

  if ashborne_setting_use_wands == "0"
    nil
  else
    respond "You will use wands during combat when low on mana."
  end


  if ashborne_setting_dead_wands == "0"
    nil
  else
    respond "You will put dead wands in your #{ashborne_setting_dead_wands}."
  end

  if ashborne_setting_get_invoked == "0"
    nil
  else
    nil
    # respond "You will attempt to get spells from the Invoker if you hear the announcement on the Realm channel while hunting in Landing."
  end

  if ashborne_setting_rescuebox == "0"
    nil
  else
    respond "You will abort combat immediately in the field if you can't store a treasure box."
  end

  if ashborne_setting_stomp == "0"
    nil
  else
    respond "Override: You will use STOMP instead of TAP for crowd control using spell 909 Tremors. (Wizard Only)"
  end

  if ashborne_setting_705cs == "0"
    nil
  else
    respond "Override: You will use the CS version of 705 regardless of spell aiming skill."
  end

  if ashborne_setting_camo == "0"
    nil
  else
    if ((Stats.prof == "Ranger") && (Stats.level >= 8) && (Spell[608].known?))
      respond "When you use a hiding style (2, 4, 6, or 8), you will attempt to use the spell Camouflage 608 to hide if you are able to."
    end
  end


  $ashborne_consider_setup = "0"
}


#########################################
#########################################

# Start of Script
# respond "start of script"
#########################################
#########################################


# Ashborne Intel Dependency Check
ashborne_maintenance_command = script.vars[1].to_s.downcase =~ /\A(help|update|doctor|check|diagnose|support|report|diagnostics|gui|menu|config)\z/
Ashborne_toolkit.ashborne_stop_conflicting_controllers unless ashborne_maintenance_command
if Script.exists?('intel_ashborne') || ashborne_maintenance_command
  nil
else
  Ashborne_toolkit.top_menu
  respond "Ashborne requires intel_ashborne.lic in the same scripts folder."
  Ashborne_toolkit.bottom_menu
  exit
end

# Update Check
if script.vars[1].downcase =~ /update/
  Ashborne_toolkit.top_menu
  respond "Ashborne #{ashborne_version} is installed."
  respond "This standalone build does not use HuntPro's repository updater."
  Ashborne_toolkit.bottom_menu
  exit
end

# Equipment Reset

if script.vars[1].downcase =~ /ereset/

  # Equipment Settings

  Settings[Char.name]['ashborne_setting_right_hand_detect'] = "0"
  Settings[Char.name]['ashborne_setting_left_hand_detect'] = "0"
  sleep 1
  Settings.save
  sleep 1
  Ashborne_toolkit.top_menu
  respond "#{Char.name}, Equipment Settings have been reset."
  Ashborne_toolkit.bottom_menu
  exit
end

# Group Reset
if script.vars[1].downcase =~ /greset/
  Ashborne_toolkit.top_menu
