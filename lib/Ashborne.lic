elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\A(hunts|huntcycles|cycles)\z/
  hunts = script.vars[4].to_s.to_i
  hunts = 1 if hunts < 1
  hunts = 25 if hunts > 25
  Settings[Char.name]['ashborne_setting_hunt_cycles'] = hunts
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  respond "Ashborne will run #{hunts} total hunt#{hunts == 1 ? '' : 's'} before stopping."
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /\A(restmind|mindrepeat|repeatmind)\z/
  rest_mind = script.vars[4].to_s.to_i
  rest_mind = 0 if rest_mind < 0
  rest_mind = 100 if rest_mind > 100
  Settings[Char.name]['ashborne_setting_rest_mind'] = rest_mind
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  respond "Ashborne will repeat when mind is at or below #{rest_mind}%."
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit


