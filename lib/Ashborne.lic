=begin
|0-100 Hunting Script - Please do not AFK Script in Prime.|

Please adhere to POLICY 18 & 19.
Owner and maintainer: NecroDeus
author: NecroDeus
game: Gemstone
version: 0.4.0-rc42
tags: hunting, combat, group, gui, utility, automation
required: Lich >= 5.17.1

Ashborne is a mixed-class solo and group hunting coordinator with per-character
combat styles, safety checks, loot rotation, town services, and repeat hunts.
Requires intel_ashborne.lic. Group mode also requires Borg, Drone, and Queen.

Usage: ;ashborne stylenumber areastring
Setup: ;ashborne help

|---------------------------------------------------------|
=end
require 'yaml'
require 'fileutils'
require 'time'

before_dying do
  Ashborne_toolkit.mark_group_not_ready if defined?(Ashborne_toolkit)
  Ashborne_toolkit.remove_anti_caster_hook if defined?(Ashborne_toolkit)
  Ashborne_toolkit.remove_environmental_danger_hook if defined?(Ashborne_toolkit)
  Ashborne_toolkit.remove_self_danger_hook if defined?(Ashborne_toolkit)
  Ashborne_toolkit.remove_disarm_recovery_hook if defined?(Ashborne_toolkit)
end
ASHBORNE_REQUIRED_LICH_VERSION = "5.17.1"
begin
  if defined?(LICH_VERSION) && Gem::Version.new(LICH_VERSION.to_s) < Gem::Version.new(ASHBORNE_REQUIRED_LICH_VERSION)
    respond "Ashborne requires Lich #{ASHBORNE_REQUIRED_LICH_VERSION}+; currently running #{LICH_VERSION}."
    respond "Update Lich before running this Ashborne build."
    exit
  end
rescue
  nil
end
ashborne_version = "0.4.0-rc42"
ashborne_last_update = "7/20/2026"
# Hide Command Inputs
silence_me

Settings.load
Settings[Char.name] ||= Hash.new

