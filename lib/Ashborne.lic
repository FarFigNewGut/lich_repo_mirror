    fput "fire"
  end

  def pod_check
    if $ashborne_my_area =~ /patrol|iceshrub|icebush/
      GameObj.loot.each { |i|
        if i.noun =~ /pod/
          # respond "Debug Output - I detected a pod, RUN."

          Ashborne_toolkit.evicted
          sleep 0.025

        end
      }
    else
      nil
    end
  end

  def cloud_check
    GameObj.loot.each { |i|
      if i.noun =~ /cloud/
        # respond "Debug Output - I detected a cloud."
        if Spell[119].known? && Spell[119].affordable?
          waitcastrt?
          result = dothistimeout "prep 119", 2, /Your spell is ready|You already have a spell readied|You do not|You don't|cannot|can't/i
          if result.to_s =~ /You do not|You don't|cannot|can't/i
            respond "Cloud detected and dispel could not be prepared; leaving this room for 20 seconds."
            Ashborne_toolkit.walk_avoiding_environmental_rooms("cloud hazard")
          else
            fput "cast cloud"
            sleep 0.5
            if GameObj.loot.any? { |obj| obj.noun =~ /cloud/ }
              respond "Cloud did not clear; leaving this room for 20 seconds."
              Ashborne_toolkit.walk_avoiding_environmental_rooms("cloud hazard")
            end
          end
        else
          respond "Cloud detected and no dispel is ready; leaving this room for 20 seconds."
          Ashborne_toolkit.walk_avoiding_environmental_rooms("cloud hazard")
          sleep 0.025
        end
      end
    }
  end

