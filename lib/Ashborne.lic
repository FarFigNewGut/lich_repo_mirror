  def group_bus_leader_name
    leader_name = if defined?($ashborne_group_ai) && $ashborne_group_ai == "1"
                    Char.name
                  elsif defined?($ashborne_captain) && $ashborne_captain && $ashborne_captain != "0"
                    $ashborne_captain
                  else
                    Char.name
                  end
    leader_name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
  end

  def group_state_file(member_name = Char.name)
    safe_name = Ashborne_toolkit.canonical_character_name(member_name).gsub(/[^A-Za-z0-9_\-]/, "")
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_state_#{safe_name}.txt")
  end

  def style9_continue_or_finish_combat
    return false if $ashborne_action == 99

    if GameObj.dead.length >= 1
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}")
    end

    if GameObj.targets.empty?
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/
      return false
    end

    $ashborne_recent_eviction = "0"
    $ashborne_action = 7
    $ashborne_own_this_room = 1
    true
  rescue => error
    respond "Style 9 combat continuation warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def group_looter_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_group_looter.txt")
  end

  def group_session_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_group_session.txt")
  end

  def ashborne_town_service_receipt_file_rc16(member_name)
    safe_name = Ashborne_toolkit.canonical_character_name(member_name).gsub(/[^A-Za-z0-9_\-]/, "")
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_town_service_#{safe_name}.txt")
  end

  def town_service_request_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_town_service_request.txt")
  end

  def group_shutdown_request_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_shutdown_request.txt")
  end

  def cycle_stop_file(member_name = Char.name)
    safe_name = Ashborne_toolkit.canonical_character_name(member_name).gsub(/[^A-Za-z0-9_\-]/, "")
    Ashborne_toolkit.ashborne_data_file("#{safe_name}_ashborne_cycle_stopped.txt")
  end

  def publish_town_service_request(session_id, healing_enabled, selling_enabled, reunion_room)
    return false unless $ashborne_group_ai == "1"

    payload = [
      session_id.to_s,
      Time.now.to_i,
      healing_enabled ? "1" : "0",
      selling_enabled ? "1" : "0",
      reunion_room.to_s
    ].join("|")
    File.write(Ashborne_toolkit.town_service_request_file, payload)
    true
  rescue => error
    respond "Ashborne could not publish the town-service order: #{error.class}: #{error.message}"
    false
  end

  def current_town_service_request
    return nil unless File.exist?(Ashborne_toolkit.town_service_request_file)

    session_id, timestamp, heal, sell, reunion_room =
      File.read(Ashborne_toolkit.town_service_request_file).strip.split("|", 5)
    return nil unless session_id.to_s == Ashborne_toolkit.current_group_session_id.to_s
    return nil if Time.now.to_i - timestamp.to_i > 900

    {
      "session" => session_id.to_s,
      "heal" => heal.to_s == "1",
      "sell" => sell.to_s == "1",
      "room" => reunion_room.to_s
    }
  rescue
    nil
  end

  def publish_town_service_receipt(session_id, room_id, status = "ready")
    payload = [
      session_id.to_s,
      Time.now.to_i,
      Char.name.to_s,
      room_id.to_s,
      status.to_s
    ].join("|")
    File.write(Ashborne_toolkit.ashborne_town_service_receipt_file_rc16(Char.name), payload)
    true
  rescue => error
    respond "Ashborne follower town-service receipt failed: #{error.class}: #{error.message}"
    false
  end

  def publish_group_shutdown_request
    return false unless $ashborne_group_ai == "1"

    payload = [
      Ashborne_toolkit.current_group_session_id,
      Time.now.to_i,
      $ashborne_group_end_heal.to_s,
      $ashborne_group_end_sell.to_s
    ].join("|")
    File.write(Ashborne_toolkit.group_shutdown_request_file, payload)
    true
  rescue => error
    respond "Ashborne could not publish the group shutdown order: #{error.class}: #{error.message}"
    false
  end

  def current_group_shutdown_request
    return nil unless File.exist?(Ashborne_toolkit.group_shutdown_request_file)

    session_id, timestamp, heal, sell =
      File.read(Ashborne_toolkit.group_shutdown_request_file).strip.split("|", 4)
    return nil unless session_id.to_s == Ashborne_toolkit.current_group_session_id.to_s
    return nil if timestamp.to_i <= 0 || Time.now.to_i - timestamp.to_i > 900

    {
      "session" => session_id.to_s,
      "heal" => heal.to_s == "1",
      "sell" => sell.to_s == "1"
    }
  rescue
    nil
  end

  def publish_cycle_stopped_rc15(session_id)
    payload = [session_id.to_s, Time.now.to_i, Char.name.to_s].join("|")
    File.write(Ashborne_toolkit.cycle_stop_file, payload)
    true
  rescue => error
    respond "Ashborne follower shutdown receipt failed: #{error.class}: #{error.message}"
    false
  end

  def group_session_data
    return {} unless File.exist?(Ashborne_toolkit.group_session_file)

    session_id, style, members = File.read(Ashborne_toolkit.group_session_file).strip.split("|", 3)
    {
      "id" => session_id.to_s,
      "style" => style.to_s,
      "members" => members.to_s.split(",")
        .map { |name| Ashborne_toolkit.canonical_character_name(name) }
        .select { |name| Ashborne_toolkit.valid_character_name?(name) }
    }
  rescue
    {}
  end

  def group_session_names
    names = Array(Ashborne_toolkit.group_session_data["members"])
    names << Ashborne_toolkit.group_bus_leader_name
    names.map! { |name| Ashborne_toolkit.canonical_character_name(name) }
    names.select! { |name| Ashborne_toolkit.valid_character_name?(name) }
    names.uniq { |name| name.downcase }
  rescue
    []
  end

  def begin_group_session
    return nil unless $ashborne_group_ai == "1"

    Ashborne_toolkit.clear_group_danger
    session_id = "#{Time.now.to_i}-#{rand(100_000..999_999)}"
    payload = [
      session_id,
      $ashborne_my_style.to_s,
      Ashborne_toolkit.configured_group_members.join(",")
    ].join("|")
    File.write(Ashborne_toolkit.group_session_file, payload)
    $ashborne_group_session_id = session_id
    session_id
  rescue
    nil
  end

  def current_group_session_id
    return $ashborne_group_session_id if $ashborne_group_ai == "1" && $ashborne_group_session_id.to_s != ""
    $ashborne_group_session_id = Ashborne_toolkit.group_session_data["id"].to_s
  rescue
    ""
  end

  def anti_caster_event_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_anti_caster_event.txt")
  end

  def anti_caster_claim_file
    Ashborne_toolkit.ashborne_data_file("#{Ashborne_toolkit.group_bus_leader_name}_ashborne_anti_caster_claim.txt")
  end

  def current_status_flags
    flags = []
    flags << "dead" if checkdead
    flags << "stunned" if checkstunned
    flags << "webbed" if webbed?
    flags << "bound" if bound?
    flags << "disarmed" if defined?($ashborne_disarm_recovery_needed) && $ashborne_disarm_recovery_needed == "1"
    flags << "recovering" if defined?($ashborne_disarm_recovery_active) && $ashborne_disarm_recovery_active == "1"
    if $ashborne_looting_active == "1" ||
        ($ashborne_loot_script.to_s != "" && Script.running?($ashborne_loot_script.to_s))
      flags << "looting"
    end
    flags.join(",")
  rescue
    "unknown"
  end

  def publish_group_state(force = false)
    return nil if defined?($ashborne_group_ai) && $ashborne_group_ai == "0"

    now = Time.now.to_f
    room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
    flags = Ashborne_toolkit.current_status_flags
    Ashborne_toolkit.refresh_group_move_state(flags)
    state_signature = [
      room_id, percenthealth.to_i, percentmana.to_i, percentstamina.to_i, percentmind.to_i,
      percentencumbrance.to_i,
      flags, checkrt.to_f.round, checkcastrt.to_f.round, $ashborne_group_ai.to_s,
      $ashborne_my_area.to_s, $ashborne_my_style.to_s,
      Ashborne_toolkit.current_group_session_id, $ashborne_startup_ready.to_s
    ].join("|")
    elapsed = now - $ashborne_last_group_state_at.to_f
    changed = state_signature != $ashborne_last_group_state_payload
    return nil unless force || elapsed >= 1.0 || (changed && elapsed >= 0.5)

    payload = [
      Char.name, room_id, now.to_i, percenthealth.to_i, percentmana.to_i,
      percentstamina.to_i, flags, checkrt.to_f.round(1), checkcastrt.to_f.round(1),
      $ashborne_group_ai.to_s, $ashborne_my_area.to_s, $ashborne_my_style.to_s,
      Ashborne_toolkit.current_group_session_id, $ashborne_startup_ready.to_s,
      percentencumbrance.to_i, checkencumbrance.to_s, percentmind.to_i,
      [Ashborne_toolkit.max_injury_rank(Wounds), Ashborne_toolkit.max_injury_rank(Scars)].max
    ].join("|")

    File.write(Ashborne_toolkit.group_state_file, payload)
    $ashborne_last_group_state_payload = state_signature
    $ashborne_last_group_state_at = now
    nil
  rescue
    nil
  end

  def read_group_state(character_name)
    path = Ashborne_toolkit.group_state_file(character_name)
    return nil unless File.exist?(path)

    name, room_id, timestamp, health, mana, stamina, flags, roundtime, cast_roundtime,
      group_role, area, style, session_id, startup_ready, encumbrance, encumbrance_text, mind, injury =
      File.read(path).strip.split("|", 18)
    return nil if name.nil? || timestamp.to_i <= 0

    {
      "name" => name,
      "room_id" => room_id,
      "timestamp" => timestamp.to_i,
      "health" => health.to_i,
      "mana" => mana.to_i,
      "stamina" => stamina.to_i,
      "flags" => flags.to_s,
      "roundtime" => roundtime.to_f,
      "cast_roundtime" => cast_roundtime.to_f,
      "group_role" => group_role.to_s,
      "area" => area.to_s,
      "style" => style.to_s,
      "session_id" => session_id.to_s,
      "startup_ready" => startup_ready.to_s,
      "encumbrance" => encumbrance.to_i,
      "encumbrance_text" => encumbrance_text.to_s,
      "mind" => mind.to_i,
      "injury" => injury.to_i
    }
  rescue
    nil
  end

  def group_disarm_recovery_active?
    return false if $ashborne_group_ai == "0"

    names = Ashborne_toolkit.group_session_names
    names = Ashborne_toolkit.configured_group_names if names.empty?
    recovering = names.map { |name| Ashborne_toolkit.read_group_state(name) }.compact.find do |state|
      next false if state["name"].to_s.casecmp(Char.name.to_s).zero?
      next false if Time.now.to_i - state["timestamp"].to_i > 12

      state["flags"].to_s =~ /(?:disarmed|recovering)/
    end
    return false unless recovering

    if Time.now.to_f - $ashborne_last_group_disarm_notice_at.to_f >= 4.0
      respond "Group movement paused while #{recovering['name']} recovers a disarmed item."
      $ashborne_last_group_disarm_notice_at = Time.now.to_f
    end
    Ashborne_toolkit.publish_group_move_state(false) if $ashborne_group_ai != "0"
    true
  rescue
    false
  end

  def loot_rotation_enabled?
    $ashborne_group_ai != "0" && $ashborne_loot_rotation == "1"
  end

  def eligible_looter_names
    session_names = Ashborne_toolkit.group_session_names
    configured = $ashborne_eligible_looters.to_s
    return session_names if configured.empty? || configured.casecmp("all").zero?

    allowed = configured.split(",")
      .map { |name| Ashborne_toolkit.canonical_character_name(name) }
      .select { |name| Ashborne_toolkit.valid_character_name?(name) }
    session_names.select { |name| allowed.any? { |allowed_name| allowed_name.casecmp(name).zero? } }
  rescue
    []
  end

  def preferred_looter_name
    configured = Ashborne_toolkit.canonical_character_name($ashborne_preferred_looter)
    return Ashborne_toolkit.group_bus_leader_name if configured.empty? || configured == "0"

    configured
  rescue
    Ashborne_toolkit.group_bus_leader_name
  end

  def fresh_group_looter_states
    session_id = Ashborne_toolkit.current_group_session_id
    Ashborne_toolkit.eligible_looter_names.each_with_object([]) do |name, states|
      state = Ashborne_toolkit.read_group_state(name)
      next if state.nil?
      next if Time.now.to_i - state["timestamp"].to_i > 5
      next unless state["session_id"].to_s == session_id.to_s
      next if state["flags"].to_s =~ /dead/

      states << state
    end
  rescue
    []
  end

  def current_group_looter
    path = Ashborne_toolkit.group_looter_file
    return nil unless File.exist?(path)

    name, timestamp, session_id = File.read(path).strip.split("|", 3)
    return nil if name.to_s.empty? || Time.now.to_i - timestamp.to_i > 30
    return nil unless session_id.to_s == Ashborne_toolkit.current_group_session_id.to_s

    name
  rescue
    nil
  end

  def assign_group_looter(name)
    return nil if name.to_s.empty?

    previous = Ashborne_toolkit.current_group_looter
    return name if previous.to_s.casecmp(name.to_s).zero?

    File.write(
      Ashborne_toolkit.group_looter_file,
      [name, Time.now.to_i, Ashborne_toolkit.current_group_session_id].join("|")
    )
    respond "Ashborne looter assigned to #{name}." unless previous.to_s.casecmp(name.to_s).zero?
    name
  rescue
    nil
  end

  def coordinate_group_looter
    return Char.name unless Ashborne_toolkit.loot_rotation_enabled?
    return Ashborne_toolkit.current_group_looter unless $ashborne_group_ai == "1"

    states = Ashborne_toolkit.fresh_group_looter_states
    return Ashborne_toolkit.assign_group_looter(Char.name) if states.empty?

    emergency = states.find { |state| Ashborne_toolkit.encumbrance_emergency_state?(state) }
    if emergency
      Ashborne_toolkit.publish_group_danger(
        "#{emergency['name']} advanced beyond moderate encumbrance " \
        "(#{emergency['encumbrance_text']}, meter #{emergency['encumbrance']})"
      )
      return nil
    end

    current_name = Ashborne_toolkit.current_group_looter
    current_state = states.find { |state| state["name"].to_s.casecmp(current_name.to_s).zero? }
    return Ashborne_toolkit.assign_group_looter(current_state["name"]) if current_state &&
      current_state["encumbrance"].to_i < $ashborne_loot_handoff.to_i

    candidates = states.select { |state| state["encumbrance"].to_i < $ashborne_loot_handoff.to_i }
    if candidates.empty?
      Ashborne_toolkit.publish_group_danger(
        "all eligible looters reached #{$ashborne_loot_handoff}% encumbrance"
      )
      return nil
    end

    preferred = Ashborne_toolkit.preferred_looter_name
    selected = candidates.find { |state| state["name"].to_s.casecmp(preferred).zero? }
    selected ||= candidates.min_by { |state| state["encumbrance"].to_i }
    Ashborne_toolkit.assign_group_looter(selected["name"])
  rescue
    Char.name
  end

  def encumbrance_emergency_state?(state)
    value = state["encumbrance"].to_i
    text = state["encumbrance_text"].to_s
    return false if value <= $ashborne_loot_handoff.to_i

    # The server label is authoritative: remain out through moderate, return on the next tier.
    return !text.match?(/moderate/i) unless text.empty?

    value >= $ashborne_loot_emergency.to_i
  rescue
    false
  end

  def personal_encumbrance_emergency?
    Ashborne_toolkit.encumbrance_emergency_state?(
      "encumbrance" => percentencumbrance.to_i,
      "encumbrance_text" => checkencumbrance.to_s
    )
  rescue
    percentencumbrance.to_i >= $ashborne_loot_emergency.to_i
  end

  def group_looter?
    return true if $ashborne_group_ai == "0"
    return true unless Ashborne_toolkit.loot_rotation_enabled?

    assigned = Ashborne_toolkit.coordinate_group_looter
    assigned.to_s.casecmp(Char.name.to_s).zero?
  rescue
    $ashborne_group_ai != "2"
  end

  def mark_group_not_ready
    return nil unless defined?($ashborne_group_ai) && $ashborne_group_ai != "0"

    $ashborne_startup_ready = "0"
    Ashborne_toolkit.publish_group_state(true)
  rescue
    nil
  end

  def capability_profile_stale?(character_name)
    path = Ashborne_toolkit.capability_profile_file(character_name)
    !File.exist?(path) || Time.now - File.mtime(path) > CAPABILITY_PROFILE_MAX_AGE
  rescue
    true
  end

  def actual_group_names
    return [] unless defined?(Group) && Group.respond_to?(:members)

    names = Array(Group.members)
    names << Group.leader if Group.respond_to?(:leader)
    names << Char.name
    names.map { |member| Ashborne_toolkit.canonical_character_name(member) }
      .map { |name| name.casecmp("self").zero? ? Char.name : name }
      .select { |name| Ashborne_toolkit.valid_character_name?(name) }
      .uniq { |name| name.downcase }
  rescue
    [Char.name]
  end

  def actual_group_leader_name
    return "" unless defined?(Group) && Group.respond_to?(:leader)

    leader = Group.leader
    leader_name = leader.respond_to?(:name) ? leader.name.to_s : leader.to_s
    leader_name = Char.name if leader_name.casecmp("self").zero?
    Ashborne_toolkit.canonical_character_name(leader_name)
  rescue
    ""
  end

  def follower_in_expected_group?
    return true unless $ashborne_group_ai == "2"

    captain = Ashborne_toolkit.canonical_character_name($ashborne_captain)
    return false unless Ashborne_toolkit.valid_character_name?(captain)

    names = Ashborne_toolkit.actual_group_names
    captain_present = names.any? { |name| name.casecmp(captain).zero? } ||
      ($ashborne_follower_group_confirmed.to_s == "1" && checkpcs(captain))
    captain_present && Ashborne_toolkit.expected_group_leader_verified?(captain)
  rescue
    false
  end

  def expected_group_leader_verified?(captain_name)
    captain = Ashborne_toolkit.canonical_character_name(captain_name)
    return false unless Ashborne_toolkit.valid_character_name?(captain)

    leader_name = Ashborne_toolkit.actual_group_leader_name
    return true if !leader_name.empty? && leader_name.casecmp(captain).zero?

    $ashborne_follower_group_confirmed.to_s == "1" &&
      $ashborne_group_ai == "2" &&
      checkpcs(captain)
  rescue
    false
  end

  def unhide_before_group_travel(context = "group travel")
    return false unless checkhidden

    waitrt?
    fput "unhide"
    sleep 0.5
    respond "Ashborne is unhiding before #{context}." if $ashborne_qc_debug == "1"
    true
  rescue => error
    respond "Unhide warning before #{context}: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def wait_for_follower_group(timeout_seconds = 22)
    return true unless $ashborne_group_ai == "2"

    captain = Ashborne_toolkit.canonical_character_name($ashborne_captain)
    return false unless Ashborne_toolkit.valid_character_name?(captain)

    Ashborne_toolkit.unhide_before_group_travel("follower group assembly")
    respond "#{Char.name} is waiting to join #{captain}'s group before Ashborne preflight."
    deadline = Time.now + timeout_seconds
    next_join_attempt = Time.at(0)
    until Time.now >= deadline
      Ashborne_toolkit.publish_group_state(true)
      return true if Ashborne_toolkit.follower_in_expected_group?

      Ashborne_toolkit.defend_while_waiting_for_group
      if checkpcs(captain) && Time.now >= next_join_attempt
        waitrt?
        join_result = dothistimeout(
          "join #{captain}",
          2,
          /currently a member of your group|You (?:join|are now following)|joins your group|already (?:joined|following)/i
        ).to_s
        if join_result =~ /currently a member of your group|You (?:join|are now following)|joins your group|already (?:joined|following)/i
          $ashborne_follower_group_confirmed = "1"
          Ashborne_toolkit.publish_group_state(true)
          return true if Ashborne_toolkit.follower_in_expected_group?
        end
        next_join_attempt = Time.now + 2
      end
      sleep 0.5
    end

    false
  rescue => error
    respond "Follower group assembly warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def wait_for_follower_full_group(timeout_seconds = 45)
    return true unless $ashborne_group_ai == "2"

    deadline = Time.now + timeout_seconds
    next_notice = Time.at(0)
    until Time.now >= deadline
      actual_names = Ashborne_toolkit.actual_group_names
      missing = Ashborne_toolkit.configured_group_names.reject do |name|
        actual_names.any? { |actual| actual.casecmp(name).zero? }
      end
      return true if missing.empty?

      Ashborne_toolkit.publish_group_state(true)
      Ashborne_toolkit.defend_while_waiting_for_group
      if Time.now >= next_notice
        respond "#{Char.name} is holding preflight while the group finishes assembling: #{missing.join(', ')}."
        next_notice = Time.now + 5
      end
      sleep 0.5
    end

    false
  rescue => error
    respond "Follower full-group wait warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def group_follower_started?(character_name, session_id = Ashborne_toolkit.current_group_session_id)
    state = Ashborne_toolkit.read_group_state(character_name)
    return false unless state
    return false if Time.now.to_i - state["timestamp"].to_i > 30
    return false unless state["group_role"] == "2"
    return false unless state["area"] =~ /\A(?:group|follow|qfollow)\z/i
    return false unless state["style"].to_s =~ /\A[1-9]\z/
    return false unless state["session_id"].to_s == session_id.to_s
    return false unless Room.current && state["room_id"].to_s == Ashborne_toolkit.current_room_id.to_s

    true
  rescue
    false
  end

  def group_follower_ready?(character_name, session_id = Ashborne_toolkit.current_group_session_id)
    return false unless Ashborne_toolkit.group_follower_started?(character_name, session_id)

    state = Ashborne_toolkit.read_group_state(character_name)
    state && state["startup_ready"] == "1"
  rescue
    false
  end

  def missing_group_follower_starts(session_id = Ashborne_toolkit.current_group_session_id)
    Ashborne_toolkit.configured_group_members.reject do |member_name|
      Ashborne_toolkit.group_follower_started?(member_name, session_id)
    end
  end

  def missing_group_followers(session_id = Ashborne_toolkit.current_group_session_id)
    Ashborne_toolkit.configured_group_members.reject do |member_name|
      Ashborne_toolkit.group_follower_ready?(member_name, session_id)
    end
  end

  def hold_present_group_members
    actual_names = Ashborne_toolkit.actual_group_names
    Ashborne_toolkit.configured_group_members.each do |member_name|
      next unless checkpcs(member_name)
      next if actual_names.any? { |actual| actual.casecmp(member_name).zero? }

      fput "hold #{member_name}"
      sleep 0.25
      actual_names = Ashborne_toolkit.actual_group_names
    end
  rescue
    nil
  end

  def send_remote_group_command(member_name, command)
    if Ashborne_toolkit.multi_account_tool == "thunder"
      return false unless Script.running?("thunder")

      do_client ";thunder #{member_name} #{command}"
      return true
    end

    payload = "5 #{rand(999999)} #{member_name} #{command}"
    if defined?($commands) && $commands.respond_to?(:push)
      $commands.push(payload)
      return true
    end

    return false unless Script.exists?("queen")

    # Queen reads only vars[0], so preserve the entire target and command as one argument.
    Script.start("queen", ["#{member_name} #{command}"])
    true
  rescue => error
    respond "Could not command #{member_name}: #{error.message}"
    false
  end

  def launch_group_followers(member_names)
    member_names.each do |member_name|
      Ashborne_toolkit.send_remote_group_command(
        member_name,
        ";kill #{Ashborne_toolkit.script_command_name}"
      )
      sleep 0.75
      sent = Ashborne_toolkit.send_remote_group_command(
        member_name,
        ";#{Ashborne_toolkit.script_command_name} auto group"
      )
      respond "Restarted Ashborne group startup on #{member_name}." if sent
      sleep 0.25
    end
  end

  def command_missing_followers_for_regroup(missing_members, context = "group travel")
    return nil unless $ashborne_group_ai == "1"
    return nil unless Room.current && Ashborne_toolkit.current_room_id

    room_id = Ashborne_toolkit.current_room_id.to_s
    Ashborne_toolkit.publish_group_leader_room
    Array(missing_members).each do |member_name|
      next unless Ashborne_toolkit.valid_character_name?(member_name)

      state = Ashborne_toolkit.read_group_state(member_name)
      active_follower = state &&
        Time.now.to_i - state["timestamp"].to_i <= 10 &&
        state["group_role"].to_s == "2" &&
        state["area"].to_s =~ /\A(?:group|follow|qfollow)\z/i &&
        state["session_id"].to_s == Ashborne_toolkit.current_group_session_id.to_s
      unless active_follower
        Ashborne_toolkit.send_remote_group_command(
          member_name,
          ";kill #{Ashborne_toolkit.script_command_name}"
        )
        sleep 0.75
        Ashborne_toolkit.send_remote_group_command(member_name, ";#{Ashborne_toolkit.script_command_name} auto group")
        sleep 0.25
      end
      action = active_follower ? "keep active Ashborne and sync" : "restart Ashborne and sync"
      respond "Regroup command sent to #{member_name}: #{action} to room #{room_id} for #{context}."
      sleep 0.25
    end
    nil
  rescue => error
    respond "Regroup command warning: #{error.message}" if $ashborne_qc_debug == "1"
    nil
  end

  def multi_account_tool
    tool = defined?($ashborne_multi_account_tool) ? $ashborne_multi_account_tool.to_s.downcase : "borg"
    %w[borg thunder].include?(tool) ? tool : "borg"
  end

  def rally_group_members
    if Ashborne_toolkit.multi_account_tool == "thunder"
      Ashborne_toolkit.configured_group_members.each do |member_name|
        Ashborne_toolkit.send_remote_group_command(member_name, ";go2 #{Ashborne_toolkit.current_room_id}")
      end
      true
    else
      do_client ";queen rally"
      true
    end
  rescue => error
    respond "Could not rally group through #{Ashborne_toolkit.multi_account_tool}: #{error.message}"
    false
  end

  def defend_while_waiting_for_group
    return false if GameObj.targets.empty?
    if $ashborne_group_danger_active == "1" || Ashborne_toolkit.medical_retreat_reason?
      Ashborne_toolkit.stance_defensive
      respond "Emergency retreat active; Ashborne will not fight while waiting to leave."
      return false
    end

    catalog_regroup = Ashborne_toolkit.huntplan_catalog_zone? && Ashborne_toolkit.group_incomplete_in_current_room?
    if catalog_regroup
      respond "Catalog regroup interrupted by combat; defending while the missing group catches up."
    else
      respond "Group wait interrupted by combat; defending until the room is safe."
    end
    defense_deadline = Time.now + 30
    until GameObj.targets.empty? || Time.now >= defense_deadline
      Ashborne_toolkit.publish_group_leader_room if $ashborne_group_ai == "1"
      Ashborne_toolkit.target_check
      Ashborne_toolkit.combat_unique_to_ashborne
      if checkdead
        Ashborne_toolkit.publish_group_danger("dead") if $ashborne_group_ai != "0"
        respond "Ashborne stopped because #{Char.name} died while waiting for the group."
        Ashborne_toolkit.script_kill
        exit
      end
      if catalog_regroup && !Ashborne_toolkit.group_incomplete_in_current_room?
        respond "Configured group reformed during combat; handing control back to the hunt."
        return true
      end
    end
    unless GameObj.targets.empty?
      Ashborne_toolkit.stance_defensive
      if catalog_regroup && Ashborne_toolkit.group_incomplete_in_current_room?
        Ashborne_toolkit.emergency_retreat_to_town_now(
          "Catalog hunt aborted: group wait defense timed out with hostiles still present."
        )
      else
        respond "Group wait defense timed out; Ashborne remains in defensive stance and will not depart."
      end
    end
    true
  rescue => error
    Ashborne_toolkit.stance_defensive
    respond "Group wait defense warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def recover_from_emergency_blocker(blockers = [])
    return false if blockers.empty?

    Ashborne_toolkit.stance_defensive
    if blockers.include?("webbed") || blockers.include?("bound")
      fput "struggle"
      sleep 0.5
      waitrt? if checkrt.to_f > 0
      return true
    end

    if blockers.include?("stunned")
      sleep 0.5
      return true
    end

    if blockers.include?("roundtime")
      waitrt?
      return true
    end

    if blockers.include?("cast roundtime")
      waitcastrt?
      return true
    end

    if blockers.include?("not standing")
      Ashborne_toolkit.stand_check
      return true
    end

    false
  rescue => error
    respond "Emergency recovery warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def fight_or_recover_for_emergency_retreat(blockers = [])
    Ashborne_toolkit.stance_defensive
    blockers = []
    blockers << "stunned" if checkstunned
    blockers << "webbed" if webbed?
    blockers << "bound" if bound?
    blockers << "roundtime" if checkrt.to_f > 0
    blockers << "cast roundtime" if checkcastrt.to_f > 0
    blockers << "not standing" unless standing?
    blockers = blockers.uniq
    Ashborne_toolkit.recover_from_emergency_blocker(blockers) unless blockers.empty?
    true
  rescue => error
    Ashborne_toolkit.stance_defensive
    respond "Emergency retreat recovery warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def visible_group_pc(name)
    safe_name = Ashborne_toolkit.canonical_character_name(name)
    return nil if safe_name.empty?

    GameObj.pcs.find do |pc|
      pc_name = pc.name.to_s
      pc_noun = pc.noun.to_s
      pc_name.casecmp(safe_name).zero? || pc_noun.casecmp(safe_name).zero?
    end
  rescue
    nil
  end

  def visible_non_group_players
    group_names = Ashborne_toolkit.configured_group_names.map { |name| name.to_s.downcase }
    GameObj.pcs.select do |pc|
      names = [
        Ashborne_toolkit.canonical_character_name(pc.name),
        Ashborne_toolkit.canonical_character_name(pc.noun)
      ].select { |name| Ashborne_toolkit.valid_character_name?(name) }
        .map { |name| name.to_s.downcase }.uniq
      !names.empty? && !names.any? { |name| group_names.include?(name) }
    end
  rescue
    []
  end

  def emergency_retreat_context?(context)
    context.to_s =~ /emergency retreat/i
  end

  def stabilize_for_emergency_retreat
    begin
      fput "stance defensive" unless checkstance == "defensive"
    rescue
      nil
    end

    true
  rescue => error
    respond "Emergency retreat stabilization warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def rescue_visible_groupmate(target_name, reason = "group danger")
    return false if $ashborne_group_ai == "0"
    return false if target_name.to_s.casecmp(Char.name.to_s).zero?
    return false if checkdead || checkstunned || webbed? || bound?

    pc = Ashborne_toolkit.visible_group_pc(target_name)
    return false if pc.nil?

    rescue_key = "rescue_#{target_name.to_s.downcase.gsub(/[^a-z0-9_\\-]/, '')}"
    return false unless Ashborne_toolkit.group_spell_claim(rescue_key, true)

    assisted = false
    respond "#{Char.name} is stabilizing #{target_name} before group retreat: #{reason}."

    if pc.status.to_s =~ /stun/i && Spell[108].known? && Spell[108].affordable? && Stats.level >= 8
      waitcastrt?
      fput "prep 108"
      fput "cast #{pc.noun}"
      sleep 2
      assisted = true
    end

    if pc.status.to_s =~ /lying down|prone|kneeling/i
      waitrt?
      fput "pull #{pc.noun}"
      sleep 2
      assisted = true
    end

    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.defend_while_waiting_for_group unless GameObj.targets.empty?
    assisted
  rescue => error
    Ashborne_toolkit.stance_defensive
    respond "Group rescue warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def rescue_current_group_danger
    danger = Ashborne_toolkit.current_group_danger
    return false if danger.nil?

    danger_name, danger_reason, danger_room = danger
    current_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
    return false unless danger_room.to_s == current_room.to_s

    Ashborne_toolkit.rescue_visible_groupmate(danger_name, danger_reason)
  rescue
    false
  end

  def dead_group_danger?(danger = nil)
    danger ||= Ashborne_toolkit.current_group_danger
    return false if danger.nil?

    danger[1].to_s =~ /\bdead\b/i
  rescue
    false
  end

  def dead_group_rescue_transport(danger = nil)
    danger ||= Ashborne_toolkit.current_group_danger
    return false unless Ashborne_toolkit.dead_group_danger?(danger)

    danger_name, _danger_reason, danger_room = danger
    current_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
    return false unless danger_room.to_s == current_room.to_s
    return false if checkdead || checkstunned || webbed? || bound?
    return false unless Spell[130].known? && Stats.level >= 30 && Spell[130].affordable?
    return false unless Ashborne_toolkit.group_spell_claim("dead_rescue_130_#{danger_name.to_s.downcase.gsub(/[^a-z0-9_\\-]/, '')}", true)

    Ashborne_toolkit.stance_defensive
    waitcastrt?
    respond "#{Char.name} is using Spirit Guide (130) for dead group rescue on #{danger_name}."
    Spell[130].cast()
    sleep 3
    Ashborne_toolkit.script_kill
    Ashborne_toolkit.top_menu
    respond "Ashborne used Spirit Guide (130) for dead group rescue. Verify the body is safe before restarting."
    Ashborne_toolkit.bottom_menu
    true
  rescue => error
    respond "Dead group rescue warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def stop_unsafe_dead_group_drag(danger = nil)
    danger ||= Ashborne_toolkit.current_group_danger
    danger_name = danger && danger[0] ? danger[0] : "a group member"

    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.script_kill
    Ashborne_toolkit.top_menu
    respond "Ashborne will not drag #{danger_name}'s corpse through active hunting terrain."
    respond "A live rescuer with Spirit Guide (130) can transport the group, or handle the rescue manually."
    Ashborne_toolkit.bottom_menu
    exit
  rescue
    exit
  end

  def travel_departure_ready?(context = "travel")
    deadline = Time.now + 45
    last_notice = 0
    emergency_retreat = Ashborne_toolkit.emergency_retreat_context?(context)

    loop do
      return false if checkdead
      Ashborne_toolkit.critical_mana_retreat_if_needed
      emergency_retreat ||= $ashborne_group_danger_active == "1" || Ashborne_toolkit.medical_retreat_reason?

      blockers = []
      blockers << "stunned" if checkstunned
      blockers << "webbed" if webbed?
      blockers << "bound" if bound?
      blockers << "roundtime" if checkrt.to_f > 0
      blockers << "cast roundtime" if checkcastrt.to_f > 0
      blockers << "not standing" if !$ashborne_my_area.to_s.match?(/moonmagru/) && !checkstanding

      if blockers.empty?
        unless GameObj.targets.empty?
          Ashborne_toolkit.stabilize_for_emergency_retreat
          respond "Ashborne return is leaving immediately with hostile creatures present."
        end
        return Ashborne_toolkit.movement_guard
      end

      if Time.now.to_f - last_notice.to_f >= 10
        respond "Ashborne is holding #{context} until safe to move: #{blockers.join(', ')}."
        last_notice = Time.now.to_f
      end

      begin
        fput "stance defensive" unless checkstance == "defensive"
      rescue
        nil
      end

      Ashborne_toolkit.recover_from_emergency_blocker(blockers)

      if Time.now >= deadline
        Ashborne_toolkit.stance_defensive
        respond "Ashborne will not start #{context}; travel is still blocked by #{blockers.join(', ')}."
        return false
      end

      sleep 0.5
    end
  rescue => error
    Ashborne_toolkit.stance_defensive
    respond "Travel departure warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def prepare_group_startup
    return true unless $ashborne_group_ai == "1"

    members = Ashborne_toolkit.configured_group_members
    return true if members.empty?

    Ashborne_toolkit.unhide_before_group_travel("leader group startup")
    missing_in_room = members.reject { |member_name| Ashborne_toolkit.visible_group_pc(member_name) }
    unless missing_in_room.empty?
      respond "Rallying missing group members: #{missing_in_room.join(', ')}."
      Ashborne_toolkit.rally_group_members
      wait_until = Time.now + 12
      until Time.now >= wait_until || missing_in_room.all? { |member_name| Ashborne_toolkit.visible_group_pc(member_name) }
        Ashborne_toolkit.publish_group_leader_room
        Ashborne_toolkit.defend_while_waiting_for_group
        sleep 0.5
      end
    end

    Ashborne_toolkit.hold_present_group_members
    session_id = Ashborne_toolkit.begin_group_session
    return false if session_id.to_s.empty?

    respond "Starting Ashborne group mode on each follower with that character's saved combat style."
    Ashborne_toolkit.launch_group_followers(members)
    wait_until = Time.now + 35
    until Time.now >= wait_until
      Ashborne_toolkit.hold_present_group_members
      Ashborne_toolkit.defend_while_waiting_for_group
      break if Ashborne_toolkit.missing_group_follower_starts(session_id).empty?
      sleep 0.5
    end

    missing_starts = Ashborne_toolkit.missing_group_follower_starts(session_id)
    unless missing_starts.empty?
      respond "Retrying Ashborne startup on followers: #{missing_starts.join(', ')}."
      Ashborne_toolkit.launch_group_followers(missing_starts)
    end

    wait_until = Time.now + 45
    until Time.now >= wait_until
      Ashborne_toolkit.hold_present_group_members
      Ashborne_toolkit.defend_while_waiting_for_group
      missing_followers = Ashborne_toolkit.missing_group_followers(session_id)
      break if missing_followers.empty?
      sleep 0.5
    end

    missing_followers = Ashborne_toolkit.missing_group_followers(session_id)
    if missing_followers.empty?
      respond "Followers confirmed Ashborne group mode: #{members.join(', ')}."
      true
    else
      $ashborne_group_startup_missing = missing_followers
      respond "Followers did not confirm Ashborne group mode: #{missing_followers.join(', ')}."
      false
    end
  rescue => error
    $ashborne_group_startup_missing = members
    respond "Group startup handshake failed: #{error.class}: #{error.message}"
    false
  end

  def preflight_report(automatic = false)
    issues = []
    warnings = []
    Ashborne_toolkit.publish_group_state(true)

    if percenthealth.to_i < 90
      issues << "health is only #{percenthealth.to_i}%"
    end

    injury_rank = [Ashborne_toolkit.max_injury_rank(Wounds), Ashborne_toolkit.max_injury_rank(Scars)].max
    issues << "rank #{injury_rank} injury is present" if injury_rank >= 2
    warnings << "rank 1 injury is present" if injury_rank == 1
    warnings << ";eherb or ;eherbs is not installed" unless Script.exists?("eherb") || Script.exists?("eherbs")

    names = Ashborne_toolkit.configured_group_names
    profiles = Ashborne_toolkit.group_capability_profiles
    plan = Ashborne_toolkit.job_coordinator_enabled? ? Ashborne_toolkit.build_group_plan(profiles) : {}
    missing_profiles = names.reject { |name| profiles.keys.any? { |profile_name| profile_name.casecmp(name).zero? } }
    warnings << "missing capability profile: #{missing_profiles.join(', ')}; advanced group roles and anti-caster choices are limited" unless missing_profiles.empty?

    stale_profiles = names.select do |name|
      !missing_profiles.any? { |missing| missing.casecmp(name).zero? } &&
        Ashborne_toolkit.capability_profile_stale?(name)
    end
    warnings << "capability profile older than 45 days: #{stale_profiles.join(', ')}" unless stale_profiles.empty?

    if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
      if Ashborne_toolkit.multi_account_tool == "thunder"
        issues << "Thunder server script is missing (thunder.lic)" unless Script.exists?("thunder")
        issues << "Struck client script is missing (struck.lic)" unless Script.exists?("struck")
        issues << "Thunder is not running on the group leader" if $ashborne_group_ai == "1" && !Script.running?("thunder")
        issues << "Struck is not running on this follower" if $ashborne_group_ai == "2" && !Script.running?("struck")
      else
        issues << "Borg hive script is missing (borg.rb or borg.lic)" unless Script.exists?("borg")
        issues << "Queen command script is missing (queen.lic)" unless Script.exists?("queen")
        issues << "Drone command listener is missing (drone.lic)" unless Script.exists?("drone")
        issues << "Drone is not running; run ;drone on this character" unless Script.running?("drone")
      end

      actual_names = Ashborne_toolkit.actual_group_names
      if actual_names.empty?
        issues << "no active game group could be verified"
      else
        absent = names.reject do |name|
          actual_names.any? { |actual| actual.casecmp(name).zero? } ||
            ($ashborne_group_ai == "2" &&
              Ashborne_toolkit.expected_group_leader_verified?(name) &&
              name.casecmp($ashborne_captain.to_s).zero?)
        end
        issues << "not currently in the game group: #{absent.join(', ')}" unless absent.empty?

        if defined?(Group) && Group.respond_to?(:leader) && $ashborne_captain.to_s != "0"
          leader_name = Ashborne_toolkit.actual_group_leader_name
          captain_name = Ashborne_toolkit.canonical_character_name($ashborne_captain)
          unless leader_name.empty? || Ashborne_toolkit.expected_group_leader_verified?(captain_name)
            issues << "game group leader is #{leader_name}, expected #{$ashborne_captain}"
          end
        end
      end
    end

    if automatic && $ashborne_group_ai == "1"
      missing_followers = Ashborne_toolkit.missing_group_followers
      unless missing_followers.empty?
        issues << "followers did not confirm their saved Ashborne group styles: #{missing_followers.join(', ')}"
      end
    end

    verified_responses = profiles.values.flat_map do |profile|
      Array(profile["anti_caster_abilities"]).select { |ability| Ashborne_toolkit.verified_reactive_ability?(ability) }
    end
    warnings << "no verified reactive anti-caster response was found" if verified_responses.empty?

    if Ashborne_toolkit.noise_lockdown?
      Ashborne_toolkit.stop_noise_lockdown_casting_helpers
      bard_profile = profiles.values.find { |profile| profile["profession"].to_s == "Bard" }
      unless bard_profile && Array(bard_profile["known_spells"]).map(&:to_i).include?(1017)
        issues << "Song of Noise lockdown is enabled, but no Bard profile verifies spell 1017"
      end

      configured_scripts = [$ashborne_script_one, $ashborne_script_two, $ashborne_script_three]
        .map(&:to_s).reject { |name| name.empty? || name == "0" }
      warnings << "lockdown will skip custom hunt scripts: #{configured_scripts.join(', ')}" unless configured_scripts.empty?
    end

    Ashborne_toolkit.top_menu
    respond "Ashborne preflight for #{Char.name}: #{issues.empty? ? 'READY' : 'BLOCKED'}"
    respond "  Group: #{names.join(', ')}"
    respond "  Capability profiles: #{profiles.keys.join(', ')}" unless profiles.empty?
    unless plan.empty?
      assignments = plan.fetch("assignments", {}).map do |job, assignment|
        "#{job}=#{assignment['primary']}"
      end
      respond "  Group jobs: #{assignments.join(', ')}"
    end
    issues.each { |message| respond "  BLOCK: #{message}" }
    warnings.each { |message| respond "  WARN: #{message}" }
    respond "  Reactive spell reserve: #{Ashborne_toolkit.anti_caster_mana_reserve}% mana"
    respond "  General reserves: #{Ashborne_toolkit.mana_reserve}% mana, #{Ashborne_toolkit.stamina_reserve}% stamina"
    respond "  Group health floor: #{Ashborne_toolkit.health_floor}%"
    respond "  Hunt schedule: #{$ashborne_hunt_cycle} of #{$ashborne_hunt_cycles}; repeat at #{$ashborne_rest_mind}% mind"
    respond "  Rest actions: healing=#{$ashborne_rest_healing == '1' ? 'on' : 'off'}, empath request=#{$ashborne_rest_ask_empath == '1' ? 'on' : 'off'}, selling=#{$ashborne_rest_sell == '1' ? 'on' : 'off'}"
    respond "  Run ;ashborne setup capabilities on each missing character to enable advanced group decisions." unless missing_profiles.empty?
    Ashborne_toolkit.bottom_menu

    return true if issues.empty?

    if automatic
      $ashborne_return_why = "Ashborne preflight failed: #{issues.join('; ')}."
      $ashborne_action = 99
    end
    false
  rescue => error
    respond "Ashborne preflight failed to run: #{error.class}: #{error.message}"
    false
  end

  def anti_caster_enabled?
    defined?($ashborne_anti_caster) &&
      $ashborne_anti_caster == "1" &&
      defined?($ashborne_group_ai) &&
      $ashborne_group_ai != "0" &&
      !Ashborne_toolkit.noise_lockdown?
  end

  def casting_creature_from_line(line)
    text = line.to_s.gsub(/<[^>]+>/, " ").gsub(/\s+/, " ").strip
    return nil unless text =~ /\b(?:prepares?|gestures?|chants?|incants?|invokes?|drones? .+? singing|begins (?:to )?(?:prepare|preparing|chant|chanting|incant|incanting|gesture|gesturing)|raises? .+? (?:hand|hands|arm|arms))\b/i

    Array(GameObj.targets).find do |target|
      next false if target.respond_to?(:status) && target.status.to_s =~ /dead|gone/i

      actor_names = [
        target.respond_to?(:name) ? target.name : nil,
        target.respond_to?(:noun) ? target.noun : nil
      ].compact.map(&:to_s).reject(&:empty?).uniq

      actor_names.any? do |actor_name|
        text =~ /\A(?:An?\s+|The\s+)?#{Regexp.escape(actor_name)}\s+(?:prepares?|gestures?|chants?|incants?|invokes?|drones? .+? singing|begins (?:to )?(?:prepare|preparing|chant|chanting|incant|incanting|gesture|gesturing)|raises? .+? (?:hand|hands|arm|arms))/i
      end
    end
  rescue
    nil
  end

  def observe_anti_caster_line(line)
    return line unless Ashborne_toolkit.anti_caster_enabled?

    target = Ashborne_toolkit.casting_creature_from_line(line)
    return line unless target
    return line unless Room.current && Ashborne_toolkit.current_room_id

    timestamp = Time.now.to_i
    target_id = target.respond_to?(:id) ? target.id.to_s : ""
    target_name = target.respond_to?(:name) ? target.name.to_s : target.to_s
    event_id = [Ashborne_toolkit.current_room_id, target_id, timestamp].join(":")
    payload = [event_id, Ashborne_toolkit.current_room_id, target_id, target_name.gsub("|", " "), timestamp].join("|")

    File.open(Ashborne_toolkit.anti_caster_event_file, File::RDWR | File::CREAT, 0644) do |file|
      file.flock(File::LOCK_EX)
      file.rewind
      existing = file.read.to_s.strip
      existing_event = Ashborne_toolkit.parse_anti_caster_event(existing)
      if existing_event.nil? || timestamp - existing_event["timestamp"].to_i >= 1 ||
          existing_event["target_id"].to_s != target_id
        file.rewind
        file.truncate(0)
        file.write(payload)
        file.flush
      end
    end
    line
  rescue
    line
  end

  def install_anti_caster_hook
    return nil unless Ashborne_toolkit.anti_caster_enabled?
    return nil if $ashborne_anti_caster_hook_name

    $ashborne_anti_caster_hook_name = "ashborne_anti_caster_#{Char.name}"
    DownstreamHook.add(
      $ashborne_anti_caster_hook_name,
      proc { |line| Ashborne_toolkit.observe_anti_caster_line(line) }
    )
    nil
  rescue => error
    respond "Ashborne could not start anti-caster monitoring: #{error.message}"
    nil
  end

  def remove_anti_caster_hook
    return nil unless $ashborne_anti_caster_hook_name

    DownstreamHook.remove($ashborne_anti_caster_hook_name)
    $ashborne_anti_caster_hook_name = nil
    nil
  rescue
    nil
  end

  def environmental_danger_hard_line?(line)
    text = line.to_s
    return true if text =~ /You lose your balance and fall over|You feel weak and feeble, your movements sluggish/i
    return true if text =~ /The ground beneath your feet (?:begins to boil violently|boils with renewed vigor|suddenly frosts and rumbles violently|rumbles with renewed vigor)/i
    return true if text =~ /(?:Fiery|Craggy) debris explodes from the ground beneath you/i
    return true if text =~ /The earth cracks beneath you, releasing a column of frigid air/i
    return true if text =~ /Icy stalagmites burst from the ground beneath you/i

    false
  end

  def environmental_danger_soft_line?(line)
    line.to_s =~ /The ground begins to shake violently|tail strikes the ground, raising a flurry of sparks|spell clashes with the tremors already rocking the area|shimmering fungus starts to shudder|shimmering fungus suddenly shudders from your attack|small writhing tendrils of shadow reach out|vents on a shimmering fungus open and close/i
  end

  def observe_environmental_danger_line(line)
    text = line.to_s
    hard_danger = Ashborne_toolkit.environmental_danger_hard_line?(text)
    soft_danger = Ashborne_toolkit.environmental_danger_soft_line?(text)
    return line unless hard_danger || soft_danger

    now = Time.now.to_i
    if now - $ashborne_environmental_danger_seen_at.to_i > 30
      $ashborne_environmental_danger_hits = 0
    end
    $ashborne_environmental_danger_hits = $ashborne_environmental_danger_hits.to_i + 1
    $ashborne_environmental_danger_seen_at = now
    $ashborne_environmental_danger_until = now + 12
    $ashborne_environmental_danger_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : ""

    $ashborne_return_why = hard_danger ? "Environmental knockdown/feeble danger." : "Repeated environmental tremor danger." if hard_danger
    line
  rescue
    line
  end

  def install_environmental_danger_hook
    return nil if $ashborne_environmental_danger_hook_name

    $ashborne_environmental_danger_hook_name = "ashborne_environmental_danger_#{Char.name}"
    DownstreamHook.add(
      $ashborne_environmental_danger_hook_name,
      proc { |line| Ashborne_toolkit.observe_environmental_danger_line(line) }
    )
    nil
  rescue => error
    respond "Ashborne could not start environmental danger monitoring: #{error.message}"
    nil
  end

  def remove_environmental_danger_hook
    return nil unless $ashborne_environmental_danger_hook_name

    DownstreamHook.remove($ashborne_environmental_danger_hook_name)
    $ashborne_environmental_danger_hook_name = nil
    nil
  rescue
    nil
  end

  def self_danger_line_reason(line)
    text = line.to_s
    return "dead" if text =~ /It seems you have died|You have died|^DEAD>/i
    return "stunned" if text =~ /You are stunned|You are still stunned/i
    return "webbed" if text =~ /You are webbed|webbing pins you|you are caught in .*web/i
    return "bound" if text =~ /You are bound|you are entangled|you are immobilized/i

    nil
  rescue
    nil
  end

  def observe_self_danger_line(line)
    reason = Ashborne_toolkit.self_danger_line_reason(line)
    return line unless reason

    now = Time.now.to_f
    return line if now - $ashborne_last_self_danger_at.to_f < 1.0

    $ashborne_last_self_danger_at = now
    $ashborne_group_danger_active = "1"
    $ashborne_action = 99
    $ashborne_return_why = reason == "dead" ? "You died." : "Emergency retreat: #{reason}."
    if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
      Ashborne_toolkit.publish_group_danger(reason)
      Ashborne_toolkit.publish_group_state(true)
    end
    line
  rescue
    line
  end

  def install_self_danger_hook
    return nil if $ashborne_self_danger_hook_name

    $ashborne_self_danger_hook_name = "ashborne_self_danger_#{Char.name}"
    DownstreamHook.add(
      $ashborne_self_danger_hook_name,
      proc { |line| Ashborne_toolkit.observe_self_danger_line(line) }
    )
    nil
  rescue => error
    respond "Ashborne could not start self-danger monitoring: #{error.message}"
    nil
  end

  def remove_self_danger_hook
    return nil unless $ashborne_self_danger_hook_name

    DownstreamHook.remove($ashborne_self_danger_hook_name)
    $ashborne_self_danger_hook_name = nil
    nil
  rescue
    nil
  end

  def disarm_recovery_line?(line)
    text = line.to_s
    return false if text =~ /^\s*Disarm Weapon\s+disarm\b/i
    return false if text =~ /^\s*(?:Skill|Mnemonic|Ranks|Type|Category|Subcategory)\b/i

    return true if text =~ /attempts? to disarm you/i
    return true if text =~ /Use the RECOVER ITEM command/i
    return true if text =~ /You (?:are|have been) disarmed/i
    return true if text =~ /knock(?:s|ed)? .* (?:from|out of) .* hand/i
    return true if text =~ /flies from .* grasp/i
    return true if text =~ /sent .* flying/i
    return true if text =~ /weapon .* clatters/i
    return true if text =~ /los(?:e|t) .* grip/i
    return true if text =~ /wrenched .* from .* hand/i
    return true if text =~ /drops? .* weapon/i

    false
  rescue
    false
  end

  def bonded_weapon_return_line?(line)
    line.to_s =~ /rises out of .* flies back to .* hand/i
  rescue
    false
  end

  def observe_disarm_recovery_line(line)
    if Ashborne_toolkit.bonded_weapon_return_line?(line)
      $ashborne_disarm_recovery_returned = "1"
      $ashborne_disarm_recovery_needed = "0"
      $ashborne_disarm_recovery_active = "0"
      Ashborne_toolkit.publish_group_state(true) if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
      return line
    end

    if Ashborne_toolkit.disarm_recovery_line?(line)
      $ashborne_disarm_recovery_needed = "1"
      $ashborne_disarm_recovery_seen_at = Time.now.to_i
      Ashborne_toolkit.publish_group_state(true) if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
    end
    line
  rescue
    line
  end

  def install_disarm_recovery_hook
    return nil if $ashborne_disarm_recovery_hook_name

    $ashborne_disarm_recovery_hook_name = "ashborne_disarm_recovery_#{Char.name}"
    DownstreamHook.add(
      $ashborne_disarm_recovery_hook_name,
      proc { |line| Ashborne_toolkit.observe_disarm_recovery_line(line) }
    )
    nil
  rescue => error
    respond "Ashborne could not start disarm recovery monitoring: #{error.message}"
    nil
  end

  def remove_disarm_recovery_hook
    return nil unless $ashborne_disarm_recovery_hook_name

    DownstreamHook.remove($ashborne_disarm_recovery_hook_name)
    $ashborne_disarm_recovery_hook_name = nil
    nil
  rescue
    nil
  end

  def weapon_style_needs_disarm_recovery?
    return false unless $ashborne_my_style.to_s =~ /\A[3-8]\z/
    return true if $ashborne_disarm_recovery_needed == "1"
    return true if $ashborne_group_ai != "0" && !GameObj.targets.empty? && checkright.nil?

    false
  rescue
    false
  end

  def disarm_recovery_control
    return false if GameObj.targets.empty?
    return false unless Spell[610].known? && Spell[610].affordable? && Stats.level >= 10
    return false unless Ashborne_toolkit.ability_allowed?("spell", 610)
    return false unless Ashborne_toolkit.group_spell_claim("610", true)

    respond "Disarm recovery: casting Tangleweed (610) to buy time." if $ashborne_qc_debug == "1"
    Spell[610].cast
    waitcastrt? if checkcastrt.to_f > 0
    true
  rescue
    false
  end

  def recover_disarmed_item_if_needed
    return false unless Ashborne_toolkit.weapon_style_needs_disarm_recovery?
    if $ashborne_disarm_recovery_needed == "1" && Time.now.to_i - $ashborne_disarm_recovery_seen_at.to_i > 300
      $ashborne_disarm_recovery_needed = "0"
      return false
    end

    $ashborne_disarm_recovery_returned = "0"
    $ashborne_disarm_recovery_active = "1"
    Ashborne_toolkit.publish_group_state(true) if $ashborne_group_ai != "0"
    Ashborne_toolkit.stance_defensive
    waitrt? if checkrt.to_f > 0
    Ashborne_toolkit.disarm_recovery_control if $ashborne_group_ai != "0"
    fput "stow all" if checkright || checkleft
    waitrt? if checkrt.to_f > 0

    recovered_any = false
    2.times do
      result = dothistimeout "recover item", 5, /You spy .* recover it|rises out of .* flies back to .* hand|In order to recover something|must get down on your hands and knees|You don't see|You do not see|Recover what|Roundtime/i
      if result.to_s =~ /rises out of .* flies back to .* hand/i
        recovered_any = true
        break
      end
      if result.to_s =~ /In order to recover something|must get down on your hands and knees/i
        sleep 0.5
        if $ashborne_disarm_recovery_returned == "1"
          recovered_any = true
          break
        end
        fput "kneel"
        waitrt? if checkrt.to_f > 0
        result = dothistimeout "recover item", 5, /You spy .* recover it|rises out of .* flies back to .* hand|You don't see|You do not see|Recover what|Roundtime/i
        fput "stand"
        waitrt? if checkrt.to_f > 0
      end
      if result.to_s =~ /You spy .* recover it|rises out of .* flies back to .* hand/i
        recovered_any = true
        fput "stow all" if checkright || checkleft
        waitrt? if checkrt.to_f > 0
        next
      end
      break if result.to_s =~ /You don't see|You do not see|Recover what/i
    end

    $ashborne_disarm_recovery_needed = "0"
    $ashborne_disarm_recovery_active = "0"
    fput "gird"
    waitrt? if checkrt.to_f > 0
    Ashborne_toolkit.publish_group_state(true) if $ashborne_group_ai != "0"
    respond "Disarm recovery: recovered lost item." if recovered_any
    recovered_any
  rescue => error
    $ashborne_disarm_recovery_active = "0"
    Ashborne_toolkit.publish_group_state(true) if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
    respond "Disarm recovery warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def combat_stuck_signature
    target_ids = GameObj.targets.map { |target| target.respond_to?(:id) ? target.id.to_s : target.to_s }.sort.join(",")
    [
      Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0",
      target_ids,
      $ashborne_id_placeholder.to_s,
      $ashborne_current_target.to_s,
      GameObj.dead.length.to_s
    ].join("|")
  rescue
    ""
  end

  def combat_stuck_recovery
    return false if GameObj.targets.empty?
    return false if $ashborne_looting_active == "1"
    return false if checkrt.to_f > 0 || checkcastrt.to_f > 0
    return true if Ashborne_toolkit.handle_environmental_hazard_targets

    signature = Ashborne_toolkit.combat_stuck_signature
    now = Time.now.to_f
    if signature != $ashborne_combat_stuck_signature
      $ashborne_combat_stuck_signature = signature
      $ashborne_combat_stuck_seen_at = now
      return false
    end
    return false if now - $ashborne_combat_stuck_seen_at.to_f < 8.0

    respond "Combat watchdog: refreshing target and forcing the attack loop to continue."
    $ashborne_combat_stuck_seen_at = now
    $ashborne_recent_eviction = "0"
    $ashborne_action = 7
    $ashborne_own_this_room = 1
    Ashborne_toolkit.target_check
    false
  rescue => error
    respond "Combat watchdog warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def post_fight_sanity_sweep
    return false unless GameObj.targets.empty?
    return true if Ashborne_toolkit.medical_retreat_if_needed
    return true if Ashborne_toolkit.recover_disarmed_item_if_needed

    if GameObj.dead.length >= 1
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}")
      return true if GameObj.dead.empty? || Script.running?($ashborne_loot_script.to_s)
    end

    if $ashborne_my_style.to_s =~ /\A[12]\z/
      Ashborne_toolkit.enforce_uac_empty_hands
    elsif !checkright.nil? || !checkleft.nil?
      fput "gird" if $ashborne_my_style.to_s =~ /\A[3-8]\z/
    end
    false
  rescue
    false
  end

  def environmental_danger_active?
    return false if $ashborne_environmental_danger_until.to_i <= Time.now.to_i
    return true if $ashborne_environmental_danger_room.to_s.empty?

    Room.current && Ashborne_toolkit.current_room_id && Ashborne_toolkit.current_room_id.to_s == $ashborne_environmental_danger_room.to_s
  rescue
    false
  end

  def environmental_hazard_target_names
    ["shimmering fungus", "wasp nest"]
  end

  def environmental_hazard_target?(target)
    name = target.respond_to?(:name) ? target.name.to_s.downcase : target.to_s.downcase
    Ashborne_toolkit.environmental_hazard_target_names.include?(name)
  rescue
    false
  end

  def environmental_hazard_target_ids
    Array(GameObj.targets).select { |target| Ashborne_toolkit.environmental_hazard_target?(target) }.map { |target| target.id.to_s rescue target.to_s }
  rescue
    []
  end

  def remove_target_ids_from_parallel_arrays(ids, names, remove_ids, nouns = nil)
    Array(ids).each_index.to_a.reverse_each do |index|
      next unless remove_ids.include?(ids[index].to_s)

      ids.delete_at(index)
      names.delete_at(index) if names
      nouns.delete_at(index) if nouns
    end
  rescue
    nil
  end

  def handle_environmental_hazard_targets
    hazard_ids = Ashborne_toolkit.environmental_hazard_target_ids
    return false if hazard_ids.empty?

    Ashborne_toolkit.remove_target_ids_from_parallel_arrays($ashborne_current_id_targets, $ashborne_current_name_targets, hazard_ids, $ashborne_current_noun_targets)
    Ashborne_toolkit.remove_target_ids_from_parallel_arrays($ashborne_current_id_weak_targets, $ashborne_current_name_weak_targets, hazard_ids)
    Ashborne_toolkit.remove_target_ids_from_parallel_arrays($ashborne_current_id_s9_override_targets, $ashborne_current_name_s9_override_targets, hazard_ids)
    Ashborne_toolkit.remove_target_ids_from_parallel_arrays($ashborne_creature_id_sev_1_attack, $ashborne_creature_name_sev_1_attack, hazard_ids)
    return false unless Array($ashborne_current_id_targets).empty?

    room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : ""
    $ashborne_environmental_danger_until = Time.now.to_i + 12
    $ashborne_environmental_danger_room = room
    Ashborne_toolkit.mark_environmental_room_avoid(room, 20, "environmental hazard target") unless room.empty?
    Ashborne_toolkit.environmental_danger_retreat_if_needed
    true
  rescue
    false
  end

  def mark_environmental_room_avoid(room_id = nil, seconds = 20, reason = "environmental danger")
    room = room_id || (Room.current && Ashborne_toolkit.current_room_id)
    return false unless room

    $ashborne_avoided_rooms ||= {}
    $ashborne_avoided_rooms[room.to_s] = {
      "until" => Time.now.to_i + seconds.to_i,
      "reason" => reason.to_s
    }
    true
  rescue
    false
  end

  def avoided_room_reason(room_id = nil)
    room = room_id || (Room.current && Ashborne_toolkit.current_room_id)
    return nil unless room

    $ashborne_avoided_rooms ||= {}
    data = $ashborne_avoided_rooms[room.to_s]
    return nil unless data
    if data["until"].to_i <= Time.now.to_i
      $ashborne_avoided_rooms.delete(room.to_s)
      return nil
    end
    data["reason"].to_s
  rescue
    nil
  end

  def learn_room_yield
    room = Room.current && Ashborne_toolkit.current_room_id
    return false unless room
    # Stale-debris learning was too aggressive in weapon-dropping hunting areas.
    # Keep environmental and occupied-room avoidance, but never prune normal hunting rooms.
    return false
    return false if Ashborne_toolkit.huntplan_catalog_zone?

    now = Time.now.to_f
    targets = GameObj.targets.length rescue 0
    dead = GameObj.dead.length rescue 0
    loot = GameObj.loot.length rescue 0
    $ashborne_room_yield_stats ||= {}
    stats = ($ashborne_room_yield_stats[room.to_s] ||= {
      "visits" => [],
      "empty_visits" => [],
      "loot_only_visits" => []
    })
    stats["visits"] = Array(stats["visits"]).select { |stamp| now - stamp.to_f <= 45.0 }
    stats["empty_visits"] = Array(stats["empty_visits"]).select { |stamp| now - stamp.to_f <= 45.0 }
    stats["loot_only_visits"] = Array(stats["loot_only_visits"]).select { |stamp| now - stamp.to_f <= 75.0 }
    stats["visits"] << now

    if targets > 0 || dead > 0
      stats["empty_visits"] = []
      stats["loot_only_visits"] = []
      return false
    end

    stats["empty_visits"] << now
    stats["loot_only_visits"] << now if loot >= 6
    return false if Ashborne_toolkit.avoided_room_reason(room)

    if stats["loot_only_visits"].length >= 2
      Ashborne_toolkit.mark_environmental_room_avoid(room, 60, "stale debris room")
      respond "Room #{room} looks stale with debris and no targets; avoiding it for 60 seconds." if $ashborne_qc_debug == "1"
      return true
    end

    if stats["visits"].length >= 5 && stats["empty_visits"].length >= 4
      Ashborne_toolkit.mark_environmental_room_avoid(room, 35, "low-yield loop")
      respond "Room #{room} has been empty too often; avoiding it for 35 seconds." if $ashborne_qc_debug == "1"
      return true
    end

    false
  rescue
    false
  end

  def walk_avoiding_environmental_rooms(reason = "environmental danger")
    starting_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
    Ashborne_toolkit.mark_environmental_room_avoid(starting_room, 20, reason) if starting_room
    moved = false

    3.times do
      moved = Ashborne_toolkit.direct_environmental_room_escape(starting_room)
      walk unless moved
      sleep 0.15
      current_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
      moved = starting_room.nil? || current_room != starting_room
      break if moved && Ashborne_toolkit.avoided_room_reason(current_room).nil?
      waitrt? if checkrt.to_f > 0
    end

    moved && Ashborne_toolkit.avoided_room_reason.nil?
  rescue
    false
  end

  def direct_environmental_room_escape(starting_room = nil)
    room = Room.current
    return false unless room && room.respond_to?(:wayto)

    routes = room.wayto
    return false unless routes.respond_to?(:keys)

    allowed_rooms = Ashborne_toolkit.huntplan_catalog_zone? ? Array($ashborne_huntplan_catalog_rooms).map(&:to_i) : nil
    candidates = routes.keys.map(&:to_i).uniq
    candidates.select! { |room_id| allowed_rooms.include?(room_id) } if allowed_rooms && !allowed_rooms.empty?
    candidates.reject! { |room_id| room_id.to_s == starting_room.to_s }
    candidates.reject! { |room_id| Ashborne_toolkit.avoided_room_reason(room_id) }
    return false if candidates.empty?

    recent = Array($ashborne_environmental_recent_escape_rooms).map(&:to_i)
    destination = (candidates - recent).first || candidates.first
    command = Ashborne_toolkit.huntplan_catalog_simple_exit(room, destination)
    return false unless command

    fput command
    waitrt? if checkrt.to_f > 0
    sleep 0.2
    current_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_i : nil
    if current_room == destination.to_i
      $ashborne_environmental_recent_escape_rooms = (recent + [destination.to_i]).last(6)
      return true
    end
    false
  rescue
    false
  end

  def environmental_danger_retreat_if_needed
    return false unless Ashborne_toolkit.environmental_danger_active?

    Ashborne_toolkit.stance_defensive
    waitrt? if checkrt.to_f > 0
    Ashborne_toolkit.stand_check if checkprone

    respond "Environmental danger detected here; leaving the room before fighting more."
    walked = Ashborne_toolkit.walk_avoiding_environmental_rooms("environmental danger")

    if walked
      $ashborne_environmental_danger_until = 0
      $ashborne_action = 0
      $ashborne_own_this_room = 0
      $ashborne_recent_eviction = "1"
    else
      respond "Environmental danger room-hop failed; staying defensive and trying normal movement next pass."
      $ashborne_environmental_danger_until = 0
      $ashborne_action = 0
      $ashborne_own_this_room = 0
      $ashborne_recent_eviction = "1"
    end
    true
  rescue => error
    respond "Environmental danger retreat warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def parse_anti_caster_event(payload)
    event_id, room_id, target_id, target_name, timestamp = payload.to_s.strip.split("|", 5)
    return nil if event_id.nil? || timestamp.to_i <= 0

    {
      "event_id" => event_id,
      "room_id" => room_id,
      "target_id" => target_id,
      "target_name" => target_name,
      "timestamp" => timestamp.to_i
    }
  end

  def current_anti_caster_event
    path = Ashborne_toolkit.anti_caster_event_file
    return nil unless File.exist?(path)

    event = Ashborne_toolkit.parse_anti_caster_event(File.read(path))
    return nil unless event
    return nil if Time.now.to_i - event["timestamp"].to_i > ANTI_CASTER_EVENT_TTL
    return nil unless Room.current && event["room_id"].to_s == Ashborne_toolkit.current_room_id.to_s

    event
  rescue
    nil
  end

  def parse_anti_caster_claim(payload)
    event_id, responder, status, ability_name, timestamp, failed_names =
      payload.to_s.strip.split("|", 6)
    return nil if event_id.nil? || timestamp.to_i <= 0

    {
      "event_id" => event_id,
      "responder" => responder,
      "status" => status,
      "ability_name" => ability_name,
      "timestamp" => timestamp.to_i,
      "failed_names" => failed_names.to_s.split(",").reject(&:empty?)
    }
  end

  def write_locked_claim(file, event, responder, status, ability_name, failed_names)
    payload = [
      event["event_id"], responder, status, ability_name, Time.now.to_i,
      failed_names.uniq.join(",")
    ].join("|")
    file.rewind
    file.truncate(0)
    file.write(payload)
    file.flush
  end

  def anti_caster_target(event)
    Array(GameObj.targets).find do |target|
      target.respond_to?(:id) &&
        target.id.to_s == event["target_id"].to_s &&
        (!target.respond_to?(:status) || target.status.to_s !~ /dead|gone/i)
    end
  rescue
    nil
  end

  def anti_caster_command(ability)
    case ability["family"]
    when "spell"
      "incant #{ability['id'].to_i}"
    when "cman"
      "cman #{ability['name'].to_s.downcase.gsub(/\s+/, '')} target"
    when "shield"
      name = ability["name"].to_s.downcase.sub(/\Ashield\s+/, "")
      "shield #{name} target"
    when "armor"
      name = ability["name"].to_s.downcase.sub(/\Aarmor\s+/, "")
      "armor #{name} target"
    when "weapon"
      name = ability["name"].to_s.downcase.sub(/\Aweapon\s+/, "")
      "weapon #{name} target"
    when "feat"
      name = ability["name"].to_s.downcase.sub(/\Afeat\s+/, "")
      "feat #{name} target"
    end
  end

  def execute_anti_caster_response(event, ability)
    target = Ashborne_toolkit.anti_caster_target(event)
    return [false, "target is no longer present"] unless target

    fput "target ##{target.id}" unless XMLData.current_target_id.to_s == target.id.to_s
    sleep 0.05
    return [false, "ability is no longer ready"] unless Ashborne_toolkit.local_anti_caster_ability_ready?(ability)

    command = Ashborne_toolkit.anti_caster_command(ability)
    return [false, "no command is defined"] if command.nil?

    result = dothistimeout(
      command,
      3,
      /Roundtime|Cast Roundtime|Sing Roundtime|CS:|SMR result:|You (?:do not|don't|cannot|can't|must|are unable)|not enough|could not|is not a skill you know/i
    )
    failed = result.to_s =~ /You (?:do not|don't|cannot|can't|must|are unable)|not enough|could not|is not a skill you know/i
    [!failed, result.to_s]
  rescue => error
    [false, "#{error.class}: #{error.message}"]
  end

  def process_anti_caster_event
    return false unless Ashborne_toolkit.anti_caster_enabled?

    Ashborne_toolkit.publish_group_state
    event = Ashborne_toolkit.current_anti_caster_event
    return false unless event
    return false unless Ashborne_toolkit.anti_caster_target(event)

    claim_path = Ashborne_toolkit.anti_caster_claim_file
    failed_names = []
    current_claim = File.exist?(claim_path) ? Ashborne_toolkit.parse_anti_caster_claim(File.read(claim_path)) : nil
    if current_claim && current_claim["event_id"] == event["event_id"]
      return false if current_claim["status"] == "sent"
      return false if current_claim["status"] == "claimed" &&
        Time.now.to_i - current_claim["timestamp"].to_i <= 3
      failed_names.concat(current_claim["failed_names"])
      failed_names << current_claim["responder"] if current_claim["status"] == "claimed"
    end

    ability = Ashborne_toolkit.selected_anti_caster_response(event, failed_names)
    return false unless ability

    claimed = false
    File.open(claim_path, File::RDWR | File::CREAT, 0644) do |file|
      file.flock(File::LOCK_EX)
      file.rewind
      locked_claim = Ashborne_toolkit.parse_anti_caster_claim(file.read)
      if locked_claim && locked_claim["event_id"] == event["event_id"] &&
          locked_claim["status"] == "sent"
        next
      end
      if locked_claim && locked_claim["event_id"] == event["event_id"] &&
          locked_claim["status"] == "claimed" &&
          Time.now.to_i - locked_claim["timestamp"].to_i <= 3
        next
      end

      failed_names.concat(locked_claim["failed_names"]) if locked_claim &&
        locked_claim["event_id"] == event["event_id"]
      Ashborne_toolkit.write_locked_claim(file, event, Char.name, "claimed", ability["name"], failed_names)
      claimed = true
    end
    return false unless claimed

    respond "#{Char.name} is interrupting #{event['target_name']} with #{ability['name']}."
    success, detail = Ashborne_toolkit.execute_anti_caster_response(event, ability)

    File.open(claim_path, File::RDWR | File::CREAT, 0644) do |file|
      file.flock(File::LOCK_EX)
      failed_names << Char.name unless success
      status = success ? "sent" : "failed"
      Ashborne_toolkit.write_locked_claim(file, event, Char.name, status, ability["name"], failed_names)
    end

    respond "#{ability['name']} could not fire: #{detail}" unless success
    success
  rescue => error
    respond "Ashborne anti-caster coordinator warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  
  def group_leader_room_file
    leader_name = if $ashborne_group_ai == "1"
                    Char.name
                  else
                    $ashborne_captain
                  end
    Ashborne_toolkit.ashborne_data_file("#{leader_name}_ashborne_group_room.txt")
  end

  def group_ready_file
    leader_name = if $ashborne_group_ai == "1"
                    Char.name
                  else
                    $ashborne_captain
                  end
    Ashborne_toolkit.ashborne_data_file("#{leader_name}_ashborne_group_ready.txt")
  end

  def group_spell_file
    leader_name = if $ashborne_group_ai == "1"
                    Char.name
                  else
                    $ashborne_captain
                  end
    Ashborne_toolkit.ashborne_data_file("#{leader_name}_ashborne_group_spells.txt")
  end

  def group_danger_file
    leader_name = if $ashborne_group_ai == "1"
                    Char.name
                  else
                    $ashborne_captain
                  end
    Ashborne_toolkit.ashborne_data_file("#{leader_name}_ashborne_group_danger.txt")
  end

  def group_move_state_file(member_name = Char.name)
    leader_name = if $ashborne_group_ai == "1"
                    Char.name
                  else
                    $ashborne_captain
                  end
    safe_name = member_name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    Ashborne_toolkit.ashborne_data_file("#{leader_name}_ashborne_group_move_#{safe_name}.txt")
  end

  def mark_group_vulnerable(seconds = 12)
    return nil if $ashborne_group_ai == "0"

    vulnerable_until = Time.now.to_f + seconds.to_f
    $ashborne_group_vulnerable_until = vulnerable_until if vulnerable_until > $ashborne_group_vulnerable_until.to_f
    Ashborne_toolkit.publish_group_move_state(false)
    nil
  end

  def wait_group_vulnerability_clear
    return nil if $ashborne_group_ai == "0"

    while Time.now.to_f < $ashborne_group_vulnerable_until.to_f
      sleep 0.25
    end

    nil
  end

  def publish_group_move_state(safe)
    return nil if $ashborne_group_ai == "0"

    begin
      room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
      payload = [safe ? "1" : "0", room_id, Time.now.to_i.to_s].join("|")
      File.write(Ashborne_toolkit.group_move_state_file, payload)
    rescue
      nil
    end

    nil
  end

  def refresh_group_move_state(flags = nil)
    return nil if $ashborne_group_ai == "0"

    flags = Ashborne_toolkit.current_status_flags if flags.nil?
    safe = flags.to_s.empty? &&
      checkrt.to_f <= 0 &&
      checkcastrt.to_f <= 0 &&
      Time.now.to_f >= $ashborne_group_vulnerable_until.to_f &&
      GameObj.targets.empty?
    Ashborne_toolkit.publish_group_move_state(safe)
    safe
  rescue
    Ashborne_toolkit.publish_group_move_state(false)
    false
  end

  def group_member_move_status(member_name)
    move_file = Ashborne_toolkit.group_move_state_file(member_name)
    return [false, "has not published movement state"] unless File.exist?(move_file)

    begin
      safe_flag, _safe_room, safe_ts = File.read(move_file).strip.split("|", 3)
      move_state_fresh = safe_ts.to_i > 0 && (Time.now.to_i - safe_ts.to_i) <= 10
      return [true, "ready"] if move_state_fresh && safe_flag == "1"
      return [false, "reports it is not ready to move"] if move_state_fresh

      state = Ashborne_toolkit.read_group_state(member_name)
      state_is_fresh = state && (Time.now.to_i - state["timestamp"].to_i) <= 10

      # Cross-account telemetry can stop updating even though the follower is
      # visibly present and following. Once both reports have expired, direct
      # room evidence is safer than freezing the hunting loop indefinitely.
      unless state_is_fresh
        if checkpcs(member_name) && GameObj.targets.empty?
          return [true, "visible in clear shared room despite stale telemetry"]
        end

        return [false, state ? "has stale character state" : "has stale movement state"]
      end

      current_room_id = Room.current && Ashborne_toolkit.current_room_id
      return [false, "is not confirmed in this room"] unless current_room_id &&
        state["room_id"].to_s == current_room_id.to_s
      return [false, "reports #{state["flags"]}"] unless state["flags"].to_s.empty?
      return [false, "has roundtime"] if state["roundtime"].to_f > 1.5
      return [false, "has cast roundtime"] if state["cast_roundtime"].to_f > 1.5

      # A follower can retain a stale local target after combat. The leader's
      # empty target list corroborates that the shared room is safe to leave.
      return [true, "clear shared room"] if GameObj.targets.empty?

      [false, "still reports combat activity"]
    rescue
      [false, "movement state could not be read"]
    end
  end

  def group_member_safe_to_move?(member_name)
    Ashborne_toolkit.group_member_move_status(member_name).first
  end

  def group_wait_for_followers_to_move(timeout_seconds = 30)
    return true unless $ashborne_group_ai == "1"

    members = [
      $ashborne_group_member1, $ashborne_group_member2, $ashborne_group_member3,
      $ashborne_group_member4, $ashborne_group_member5, $ashborne_group_member6,
      $ashborne_group_member7, $ashborne_group_member8, $ashborne_group_member9
    ].compact.reject { |member_name| member_name == "0" }

    wait_until = Time.now + timeout_seconds
    unsafe_member = nil
    unsafe_reason = nil
    until Time.now >= wait_until
      unsafe_member = nil
      unsafe_reason = nil
      members.each do |member_name|
        next unless checkpcs(member_name)

        safe, reason = Ashborne_toolkit.group_member_move_status(member_name)
        next if safe

        unsafe_member = member_name
        unsafe_reason = reason
        break
      end
      return true if unsafe_member.nil?
      sleep 0.25
    end

    detail = unsafe_member ? "#{unsafe_member} #{unsafe_reason}" : "a visible follower is not ready"
    respond "Group movement paused: #{detail}."
    false
  end

  def group_wait_for_loot_to_settle(timeout_seconds = 8)
    return true unless $ashborne_group_ai == "1"
    return true unless GameObj.targets.empty?
    return true if GameObj.dead.empty?

    wait_until = Time.now + timeout_seconds
    notice_sent = false
    until Time.now >= wait_until
      Ashborne_toolkit.publish_group_state(true)
      Ashborne_toolkit.group_wait_for_followers_to_move(2)
      break if GameObj.dead.empty?

      unless notice_sent
        respond "Group movement paused briefly while loot/search finishes."
        notice_sent = true
      end
      sleep 0.5
    end
    true
  rescue
    true
  end

  def injury_parts
    ["head", "neck", "abs", "lhand", "rhand", "larm", "rarm", "chest", "back", "rleg", "lleg", "nerves", "torso", "leye", "reye"]
  end

  def max_injury_rank(source)
    Ashborne_toolkit.injury_parts.map { |part| source.send(part).to_i rescue 0 }.max || 0
  end

  def post_hunt_injured?
    return false if checkdead

    percenthealth.to_i < 100 ||
      Ashborne_toolkit.max_injury_rank(Wounds) >= 1 ||
      Ashborne_toolkit.max_injury_rank(Scars) >= 1
  rescue
    false
  end

  def post_hunt_needs_healing_rc9?
    return false if checkdead

    percenthealth.to_i < Ashborne_toolkit.health_floor ||
      Ashborne_toolkit.max_injury_rank(Wounds) >= 1 ||
      Ashborne_toolkit.max_injury_rank(Scars) >= 1 ||
      checkreallybleeding
  rescue
    false
  end

  def post_hunt_service_safe_rc8?
    return false if checkdead

    percenthealth.to_i >= Ashborne_toolkit.health_floor &&
      Ashborne_toolkit.max_injury_rank(Wounds) < 1 &&
      Ashborne_toolkit.max_injury_rank(Scars) < 1 &&
      !checkreallybleeding
  rescue
    false
  end

  def run_post_hunt_healing_rc8
    if $ashborne_group_ai != "0"
      request = Ashborne_toolkit.current_town_service_request
      reunion_room = request && request["room"].to_s
      current_room = Room.current && Ashborne_toolkit.current_room_id
      unless request && reunion_room != "0" && current_room &&
          current_room.to_s == reunion_room && GameObj.targets.empty?
        respond "#{Char.name} will not begin post-hunt healing until safely home at the group reunion room."
        return false
      end
    end

    unless Ashborne_toolkit.post_hunt_needs_healing_rc9?
      respond "#{Char.name} has no wounds and is above the #{Ashborne_toolkit.health_floor}% safety floor; skipping ;eherbs."
      return true
    end

    healing_script = if Script.exists?("eherb")
                       "eherb"
                     elsif Script.exists?("eherbs")
                       "eherbs"
                     end

    if healing_script.nil?
      respond "#{Char.name} is hurt after the hunt, but ;eherb or ;eherbs is not installed."
      return false
    end

    respond "#{Char.name} is hurt after the hunt. Running ;#{healing_script}."
    waitrt?
    Script.run(healing_script) unless Script.running?(healing_script)
    wait_while { Script.running?(healing_script) }
    if Ashborne_toolkit.post_hunt_service_safe_rc8?
      if Ashborne_toolkit.post_hunt_injured?
        respond "#{Char.name} remains slightly below full health after ;#{healing_script}, but has no wounds and is above the #{Ashborne_toolkit.health_floor}% safety floor."
      else
        respond "#{Char.name} finished post-hunt healing."
      end
    else
      respond "#{Char.name} remains unsafe after ;#{healing_script}; remaining safely in town."
      return false
    end
    true
  rescue => error
    respond "Post-hunt healing could not run: #{error}"
    false
  end

  def combat_gear_ready_rc17?
    if $ashborne_my_style.to_s =~ /\A[12]\z/
      return checkright.nil? && checkleft.nil?
    end

    expected_right = $ashborne_right_hand_detect.to_s
    expected_left = $ashborne_left_hand_detect.to_s
    right_ready = expected_right == "0" || checkright.to_s == expected_right
    left_ready = expected_left == "0" || checkleft.to_s == expected_left
    expected_item = expected_right != "0" || expected_left != "0"

    right_ready && left_ready && (!expected_item || !checkright.nil? || !checkleft.nil?)
  rescue
    false
  end

  def unexpected_hand_items_rc17?
    expected = [$ashborne_right_hand_detect.to_s, $ashborne_left_hand_detect.to_s].reject { |item| item == "0" || item.empty? }
    held = [checkright, checkleft].compact.map(&:to_s)
    (held - expected).any?
  rescue
    true
  end

  def restore_combat_gear_rc17(context = "travel")
    3.times do
      waitrt? if checkrt.to_f > 0
      $ashborne_uac_hands_verified = "0"
      fput "gird"
      Ashborne_toolkit.enforce_uac_empty_hands if $ashborne_my_style.to_s =~ /\A[12]\z/
      sleep 0.25
      return true if Ashborne_toolkit.combat_gear_ready_rc17?
    end

    respond "Ashborne blocked #{context}: GIRD did not restore the saved combat gear."
    false
  rescue => error
    respond "Ashborne could not verify combat gear for #{context}: #{error.message}"
    false
  end

  def fight_post_service_hostiles_rc17
    return true if GameObj.targets.empty?

    respond "Town-service travel interrupted: hostile creature present. Stopping go2 and restoring combat gear."
    Script.kill("go2") if Script.running?("go2")
    Script.kill("eloot") if Script.running?("eloot")
    Ashborne_toolkit.stance_defensive
    return false unless Ashborne_toolkit.restore_combat_gear_rc17("town-service defense")

    original_group_mode = $ashborne_group_ai
    $ashborne_group_ai = "0"
    deadline = Time.now + 45
    until GameObj.targets.empty? || checkdead || Time.now >= deadline
      Ashborne_toolkit.target_check
      Ashborne_toolkit.combat_unique_to_ashborne
      sleep 0.1
    end
    GameObj.targets.empty? && !checkdead
  ensure
    $ashborne_group_ai = original_group_mode if defined?(original_group_mode) && original_group_mode
  end

  def guarded_town_service_go2_rc17(destination, context)
    3.times do
      return false if checkdead
      return false unless Ashborne_toolkit.restore_combat_gear_rc17(context)

      Script.start("go2", destination.to_s)
      interrupted = false
      while Script.running?("go2")
        if checkdead
          Script.kill("go2")
          return false
        end
        unless GameObj.targets.empty?
          interrupted = true
          Script.kill("go2")
          break
        end
        sleep 0.1
      end

      if interrupted
        return false unless Ashborne_toolkit.fight_post_service_hostiles_rc17
        next
      end
      return true if GameObj.targets.empty?
    end

    respond "Ashborne could not complete #{context} safely."
    false
  rescue => error
    respond "Ashborne stopped #{context}: #{error.message}"
    false
  end

  def prepare_eloot_sale_origin_rc18
    return false if checkdead
    return false unless Ashborne_toolkit.restore_combat_gear_rc17("travel to the selling town")

    starting_room = Room.current && Ashborne_toolkit.current_room_id
    respond "Ashborne is traveling to the nearest bank with combat gear equipped before ELoot may stow it."
    return false unless Ashborne_toolkit.guarded_town_service_go2_rc17("bank", "travel to the selling town")

    ending_room = Room.current && Ashborne_toolkit.current_room_id
    if ending_room.nil?
      respond "Ashborne could not verify a mapped selling-town room."
      return false
    end
    respond "Ashborne reached the selling town safely in room #{ending_room}." if starting_room.to_s != ending_room.to_s
    true
  rescue => error
    respond "Ashborne could not prepare a safe ELoot selling origin: #{error.message}"
    false
  end

  def final_repeat_departure_gate_rc17
    return false if checkdead

    if Ashborne_toolkit.post_hunt_needs_healing_rc9?
      unless $ashborne_rest_healing == "1"
        respond "Ashborne blocked the next hunt: #{Char.name} is injured or bleeding and post-hunt healing is disabled."
        return false
      end
      return false unless Ashborne_toolkit.run_post_hunt_healing_rc8
    end

    unless Ashborne_toolkit.post_hunt_service_safe_rc8?
      respond "Ashborne blocked the next hunt: #{Char.name} did not pass the final medical check."
      return false
    end
    unless GameObj.targets.empty?
      respond "Ashborne blocked the next hunt because a hostile creature is present."
      return false
    end

    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.restore_combat_gear_rc17("repeat departure")
  rescue => error
    respond "Ashborne blocked the next hunt because the final safety check failed: #{error.message}"
    false
  end

  def install_post_hunt_sale_failure_hook_rc17
    Ashborne_toolkit.remove_post_hunt_sale_failure_hook_rc17
    $ashborne_post_hunt_sale_failure = nil
    $ashborne_post_hunt_sale_hook_name = "ashborne_post_hunt_sale_#{Char.name}_#{Time.now.to_i}"
    DownstreamHook.add(
      $ashborne_post_hunt_sale_hook_name,
      proc do |line|
        if line.to_s =~ /Failed to find the locksmith pool NPC|hash representation was changed during iteration|go2:.*(?:no recognized response|giving up|unable|failed)|Please start .* in a mapped room/i
          $ashborne_post_hunt_sale_failure ||= line.to_s.strip
        end
        line
      end
    )
  rescue => error
    respond "Ashborne could not start post-hunt sale monitoring: #{error.message}" if $ashborne_qc_debug == "1"
  end

  def remove_post_hunt_sale_failure_hook_rc17
    if $ashborne_post_hunt_sale_hook_name
      DownstreamHook.remove($ashborne_post_hunt_sale_hook_name)
      $ashborne_post_hunt_sale_hook_name = nil
    end
  rescue
    $ashborne_post_hunt_sale_hook_name = nil
  end

  # Keep this name distinct from older Ashborne builds that may still have a
  # zero-argument post_hunt_sell method cached in Lich::Common.
  def run_post_hunt_sale(force = false)
    return false unless force || $ashborne_rest_sell == "1"

    unless Script.exists?("eloot")
      respond "#{Char.name} could not sell post-hunt loot because ;eloot is not installed."
      return false
    end

    unless Ashborne_toolkit.restore_combat_gear_rc17("post-hunt selling")
      respond "#{Char.name} will not begin selling without verified combat gear."
      return false
    end
    unless Ashborne_toolkit.prepare_eloot_sale_origin_rc18
      respond "#{Char.name} will not let ELoot cross hunting terrain without combat gear."
      return false
    end
    Ashborne_toolkit.install_post_hunt_sale_failure_hook_rc17
    respond "#{Char.name} is selling post-hunt loot with ;eloot sell."
    wait_while { Script.running?("eloot") }
    attempts = 0
    clean_sale = false
    needs_retry = false
    begin
      attempts += 1
      clean_sale = false
      needs_retry = false
      Script.start("eloot", "sell")
      held_state = nil
      held_since = nil
      deadline = Time.now + 900
      saw_eloot_running = false
      interrupted_sale = false
      hostile_interruption = false
      while Script.running?("eloot")
        saw_eloot_running = true
        if checkdead
          interrupted_sale = true
          Script.kill("go2") if Script.running?("go2")
          Script.kill("eloot")
          break
        end
        unless GameObj.targets.empty?
          interrupted_sale = true
          hostile_interruption = true
          Script.kill("go2") if Script.running?("go2")
          Script.kill("eloot")
          Ashborne_toolkit.fight_post_service_hostiles_rc17
          break
        end
        storage_failed = false
        if Ashborne_toolkit.unexpected_hand_items_rc17?
          storage_failed, held_state, held_since = Ashborne_toolkit.loot_storage_failure_detected?("eloot", held_state, held_since)
        else
          held_state = nil
          held_since = nil
        end
        if storage_failed
          respond "Ashborne detected ;eloot sell is paused or stuck with loot in hand; clearing the hand-held blocker before retrying."
          interrupted_sale = true
          needs_retry = true
          Script.kill("eloot")
          sleep 0.5
          Ashborne_toolkit.sell_held_storage_blocker || Ashborne_toolkit.ashborne_stow_all
          break
        end
        if Time.now >= deadline
          respond "Ashborne stopped waiting for ;eloot sell after 15 minutes."
          interrupted_sale = true
          Script.kill("eloot")
          break
        end
        sleep 0.25
      end
      clean_sale = !interrupted_sale && $ashborne_post_hunt_sale_failure.nil? &&
        (saw_eloot_running || (checkright.nil? && checkleft.nil?))
      if hostile_interruption
        if checkdead || !GameObj.targets.empty?
          respond "Ashborne could not clear combat during post-hunt selling; ending this repeat safely."
          return false
        end
        unless Ashborne_toolkit.restore_combat_gear_rc17("post-service combat recovery")
          respond "Ashborne could not restore combat gear after sale travel was interrupted; ending this repeat safely."
          return false
        end
        if attempts < 4
          needs_retry = true
          respond "Post-hunt sale travel is clear again. Resuming ;eloot sell from the current room (attempt #{attempts + 1} of 4)."
        else
          respond "Ashborne stopped the post-hunt sale after four combat interruptions. Returning to the nearest town and ending this repeat safely."
          Ashborne_toolkit.guarded_town_service_go2_rc17("town", "post-service emergency return")
          original_group_mode = $ashborne_group_ai
          begin
            $ashborne_group_ai = "0"
            Ashborne_toolkit.run_post_hunt_healing_rc8 if $ashborne_rest_healing == "1"
          ensure
            $ashborne_group_ai = original_group_mode
          end
          Ashborne_toolkit.restore_combat_gear_rc17("post-service recovery")
          return false
        end
      end
    end while attempts < 4 && Script.exists?("eloot") && (needs_retry || Ashborne_toolkit.unexpected_hand_items_rc17?)

    if Ashborne_toolkit.unexpected_hand_items_rc17?
      respond "#{Char.name} still has something in hand after ;eloot sell; town services need attention before hunting."
      return false
    end
    unless clean_sale
      if $ashborne_post_hunt_sale_failure
        respond "ELoot reported a post-hunt sale failure: #{$ashborne_post_hunt_sale_failure}"
      end
      respond "#{Char.name}'s post-hunt sale did not finish cleanly; staying in town instead of falsely advancing the repeat queue."
      return false
    end
    unless Ashborne_toolkit.restore_combat_gear_rc17("post-hunt sale completion")
      respond "#{Char.name}'s sale finished, but combat gear was not restored; remaining in the selling town."
      return false
    end
    respond "#{Char.name} finished selling post-hunt loot."
    true
  rescue => error
    respond "Post-hunt selling could not run: #{error}"
    false
  ensure
    Ashborne_toolkit.remove_post_hunt_sale_failure_hook_rc17
  end

  def encumbrance_return?
    $ashborne_return_why.to_s =~ /encumbrance|eligible looters reached|loot storage failure|container full|hands full/i ? true : false
  rescue
    false
  end

  def repeat_hunt_block_reason
    return "this character is a follower" if $ashborne_group_ai == "2"
    medical_return = Ashborne_toolkit.medical_retreat_reason?
    mana_return = Ashborne_toolkit.repeat_mana_recovery_required?
    return "group danger is active" if $ashborne_group_danger_active == "1" && !Ashborne_toolkit.encumbrance_return? && !medical_return && !mana_return
    return "this character is dead" if checkdead
    return "the #{$ashborne_my_area} mode does not support repeat hunts" if $ashborne_my_area.to_s =~ /qlite|quick|drarena|drlite|grounded/
    if $ashborne_hunt_cycle.to_i >= $ashborne_hunt_cycles.to_i
      return "completed hunt #{$ashborne_hunt_cycle} of #{$ashborne_hunt_cycles}"
    end

    unsafe_reason = $ashborne_return_why.to_s =~ /danger|injur|scar|health|spirit|stun|web|bound|poison|disease|preflight|noise lockdown|died/i
    return "unsafe return reason: #{$ashborne_return_why}" if unsafe_reason && !medical_return

    nil
  rescue
    "the repeat safety check failed"
  end

  def repeat_hunt_available?
    Ashborne_toolkit.repeat_hunt_block_reason.nil?
  end

  def known_visible_empath
    return $ashborne_group_empath if $ashborne_group_empath.to_s != "0" && checkpcs($ashborne_group_empath)

    visible = GameObj.pcs.map { |pc| Ashborne_toolkit.canonical_character_name(pc.noun) }
    visible.each do |name|
      profile = Ashborne_toolkit.load_capability_profile(name)
      return name if profile && profile["profession"].to_s == "Empath"
    end
    nil
  rescue
    nil
  end

  def group_needs_rest_healing?
    return Ashborne_toolkit.post_hunt_needs_healing_rc9? if $ashborne_group_ai == "0"

    Ashborne_toolkit.configured_group_names.any? do |name|
      if name.to_s.casecmp(Char.name.to_s).zero?
        Ashborne_toolkit.post_hunt_needs_healing_rc9?
      else
        state = Ashborne_toolkit.read_group_state(name)
        state && (state["health"].to_i < Ashborne_toolkit.health_floor || state["injury"].to_i > 0)
      end
    end
  rescue
    Ashborne_toolkit.post_hunt_needs_healing_rc9?
  end

  def stale_wrong_equipment_return?
    $ashborne_action == 99 &&
      $ashborne_return_why.to_s =~ /correct equipment|enchanted weapons|armor or ammo/i
  end

  def clear_stale_wrong_equipment_return_if_combat_progress
    return false unless Ashborne_toolkit.stale_wrong_equipment_return?
    return false unless GameObj.dead.length >= 1 || GameObj.targets.empty?

    $ashborne_action = 0
    $ashborne_return_why = nil
    $ashborne_wrong_equipment_hits = 0
    $ashborne_wrong_equipment_last_at = 0
    respond "Ashborne cleared a stale equipment warning after combat progress was confirmed." if $ashborne_qc_debug == "1"
    true
  rescue
    false
  end

  def request_rest_healing
    return false unless $ashborne_rest_ask_empath == "1"
    return false unless Ashborne_toolkit.group_needs_rest_healing?

    empath = Ashborne_toolkit.known_visible_empath
    return false if empath.nil?

    fput "whisper #{empath} please heal us."
    respond "#{Char.name} asked #{empath} to heal the resting group."
    true
  rescue => error
    respond "Could not ask for empath healing: #{error}" if $ashborne_qc_debug == "1"
    false
  end

  def repeat_mana_recovery_required?
    return false if $ashborne_disable_mana == "1"

    $ashborne_return_why.to_s =~ /low mana|mana after finishing|out of mana|mana reserve/i ? true : false
  rescue
    false
  end

  def repeat_mana_ready?(minimum = 90)
    threshold = minimum.to_i
    return percentmana.to_i >= threshold if $ashborne_group_ai == "0"

    Ashborne_toolkit.configured_group_names.all? do |name|
      if name.to_s.casecmp(Char.name.to_s).zero?
        percentmana.to_i >= threshold
      else
        state = Ashborne_toolkit.read_group_state(name)
        state &&
          Time.now.to_i - state["timestamp"].to_i <= 10 &&
          state["mana"].to_i >= threshold
      end
    end
  rescue
    false
  end

  def group_rest_ready?
    mind_ready = if $ashborne_group_ai == "0"
                   percentmind.to_i <= $ashborne_rest_mind.to_i
                 else
                   Ashborne_toolkit.configured_group_names.all? do |name|
                     if name.to_s.casecmp(Char.name.to_s).zero?
                       percentmind.to_i <= $ashborne_rest_mind.to_i
                     else
                       state = Ashborne_toolkit.read_group_state(name)
                       state &&
                         Time.now.to_i - state["timestamp"].to_i <= 10 &&
                         state["mind"].to_i <= $ashborne_rest_mind.to_i
                     end
                   end
                 end
    return false unless mind_ready
    return true unless Ashborne_toolkit.repeat_mana_recovery_required?

    Ashborne_toolkit.repeat_mana_ready?(90)
  rescue
    false
  end

  def follower_town_service_receipt_rc13(member_name, session_id, reunion_room)
    if reunion_room.to_s != "0" &&
       Room.current &&
       Ashborne_toolkit.current_room_id.to_s == reunion_room.to_s &&
       Ashborne_toolkit.visible_group_pc(member_name)
      return {
        "state" => "ready",
        "reason" => "visible at reunion room",
        "name" => member_name.to_s,
        "room" => reunion_room.to_s,
        "timestamp" => Time.now.to_i
      }
    end

    path = Ashborne_toolkit.ashborne_town_service_receipt_file_rc16(member_name)
    return { "state" => "missing", "reason" => "no receipt file" } unless File.exist?(path)

    receipt_session, timestamp, receipt_name, receipt_room, status =
      File.read(path).strip.split("|", 5)
    age = Time.now.to_i - timestamp.to_i
    return { "state" => "pending", "reason" => "receipt belongs to session #{receipt_session}" } unless receipt_session.to_s == session_id.to_s
    return { "state" => "pending", "reason" => "receipt is #{age} seconds old" } if timestamp.to_i <= 0 || age > 900
    return { "state" => "blocked", "reason" => status.to_s } if status.to_s.start_with?("blocked")
    return { "state" => "pending", "reason" => "receipt status is #{status}" } unless status.to_s == "ready"
    return { "state" => "pending", "reason" => "receipt room is #{receipt_room}, expected #{reunion_room}" } unless receipt_room.to_s == reunion_room.to_s

    {
      "state" => "ready",
      "reason" => "ready",
      "name" => receipt_name.to_s,
      "room" => receipt_room.to_s,
      "timestamp" => timestamp.to_i
    }
  rescue => error
    { "state" => "pending", "reason" => "receipt read failed: #{error.class}: #{error.message}" }
  end

  def wait_for_town_service_group_rc13(session_id, reunion_room)
    return true unless $ashborne_group_ai == "1"

    members = Ashborne_toolkit.configured_group_members
    deadline = Time.now + 600
    next_status = Time.now
    loop do
      receipts = members.each_with_object({}) do |name, result|
        result[name] = Ashborne_toolkit.follower_town_service_receipt_rc13(name, session_id, reunion_room)
      end
      break if receipts.values.all? { |receipt| receipt["state"] == "ready" }

      blocked = receipts.select { |_name, receipt| receipt["state"] == "blocked" }.keys
      unless blocked.empty?
        respond "Ashborne stopped the repeat queue because town services could not finish for: #{blocked.join(', ')}."
        return false
      end
      if Time.now >= deadline
        missing = receipts.reject { |_name, receipt| receipt["state"] == "ready" }.keys
        respond "Ashborne stopped the repeat queue because town services did not finish for: #{missing.join(', ')}."
        return false
      end
      if Time.now >= next_status
        pending = receipts.reject { |_name, receipt| receipt["state"] == "ready" }
        details = pending.map { |name, receipt| "#{name} (#{receipt['reason']})" }
        respond "Ashborne is waiting for town services: #{details.join(', ')}."
        next_status = Time.now + 15
      end
      Ashborne_toolkit.publish_group_leader_room
      Ashborne_toolkit.hold_present_group_members
      sleep 1
    end

    Ashborne_toolkit.hold_present_group_members
    grouped_names = Ashborne_toolkit.actual_group_names
    missing_group = members.reject { |name| grouped_names.any? { |grouped| grouped.casecmp(name).zero? } }
    unless missing_group.empty?
      respond "Ashborne stopped the repeat queue because these followers did not rejoin: #{missing_group.join(', ')}."
      return false
    end
    respond "Town services complete. The full group has returned and regrouped."
    true
  rescue => error
    respond "Ashborne town-service coordination failed: #{error.class}: #{error.message}"
    false
  end

  def finish_follower_emergency_town_services_rc10
    return true unless $ashborne_group_ai == "2"

    deadline = Time.now + 600
    next_status = Time.now
    request = nil
    loop do
      request = Ashborne_toolkit.current_town_service_request
      break if request && ((!request["heal"] && !request["sell"]) || request["room"] != "0")
      if Time.now >= deadline
        respond "#{Char.name} did not receive a complete town-service order from #{$ashborne_captain}."
        return false
      end
      if Time.now >= next_status
        respond "#{Char.name} is safely in town and waiting for the leader's town-service order."
        next_status = Time.now + 15
      end
      Ashborne_toolkit.publish_group_state(true)
      sleep 1
    end

    return true unless request["heal"] || request["sell"]

    reunion_room = request["room"]
    Ashborne_toolkit.ashborne_stow_all

    if reunion_room != "0" && (!Room.current || Ashborne_toolkit.current_room_id.to_s != reunion_room)
      Script.run("go2", reunion_room)
      wait_while { Script.running?("go2") }
    end
    unless Room.current && Ashborne_toolkit.current_room_id.to_s == reunion_room && GameObj.targets.empty?
      respond "#{Char.name} could not reach the safe town reunion room and will not begin healing or selling."
      return false
    end

    service_healed = !request["heal"] ||
      !Ashborne_toolkit.post_hunt_needs_healing_rc9? ||
      Ashborne_toolkit.run_post_hunt_healing_rc8
    service_sold = !request["sell"] || Ashborne_toolkit.run_post_hunt_sale(true)

    regroup_deadline = Time.now + 300
    until checkpcs($ashborne_captain) || Time.now >= regroup_deadline
      Ashborne_toolkit.publish_group_state(true)
      sleep 1
    end
    if checkpcs($ashborne_captain)
      fput "join #{$ashborne_captain}"
      sleep 1
    end

    service_status = service_healed && service_sold ? "ready" : "blocked"
    Ashborne_toolkit.publish_group_state(true)
    Ashborne_toolkit.publish_town_service_receipt(request["session"], reunion_room, service_status)
    if service_status == "ready"
      respond "#{Char.name} finished town services and returned to #{$ashborne_captain}."
      true
    else
      respond "#{Char.name} could not finish required town services and will remain safely in town."
      false
    end
  rescue => error
    respond "Ashborne follower town services failed: #{error.class}: #{error.message}"
    false
  end

  def follower_town_service_already_processed_rc15?(session_id)
    path = Ashborne_toolkit.ashborne_town_service_receipt_file_rc16(Char.name)
    return false unless File.exist?(path)

    receipt_session, _timestamp, _name, _room, status = File.read(path).strip.split("|", 5)
    receipt_session.to_s == session_id.to_s && %w[ready blocked].any? { |value| status.to_s.start_with?(value) }
  rescue
    false
  end

  def process_follower_town_service_request_rc15
    return false unless $ashborne_group_ai == "2"

    request = Ashborne_toolkit.current_town_service_request
    return false if request.nil? || request["room"].to_s == "0"
    return false if Ashborne_toolkit.follower_town_service_already_processed_rc15?(request["session"])

    reunion_room = request["room"]
    previous_rest_sell = $ashborne_rest_sell
    $ashborne_rest_sell = request["sell"] ? "1" : "0"
    fput "disband"
    fput "group open"

    if !Room.current || Ashborne_toolkit.current_room_id.to_s != reunion_room
      Script.run("go2", reunion_room)
      wait_while { Script.running?("go2") }
    end
    unless Room.current && Ashborne_toolkit.current_room_id.to_s == reunion_room && GameObj.targets.empty?
      respond "#{Char.name} could not reach the safe town reunion room and will not begin healing or selling."
      return false
    end

    service_healed = !request["heal"] ||
      !Ashborne_toolkit.post_hunt_needs_healing_rc9? ||
      Ashborne_toolkit.run_post_hunt_healing_rc8
    service_sold = !request["sell"] || Ashborne_toolkit.run_post_hunt_sale(true)
    if checkpcs($ashborne_captain)
      fput "join #{$ashborne_captain}"
      sleep 1
    end

    status = service_healed && service_sold ? "ready" : "blocked"
    Ashborne_toolkit.publish_group_state(true)
    Ashborne_toolkit.publish_town_service_receipt(request["session"], reunion_room, status)
    $ashborne_rest_sell = previous_rest_sell
    respond "#{Char.name} completed local town-service order with status #{status}."
    true
  rescue => error
    respond "Ashborne local town-service order failed: #{error.class}: #{error.message}"
    false
  ensure
    $ashborne_rest_sell = previous_rest_sell if defined?(previous_rest_sell)
  end

  def process_follower_shutdown_request_rc15
    return false unless $ashborne_group_ai == "2"

    request = Ashborne_toolkit.current_group_shutdown_request
    return false if request.nil?

    Ashborne_toolkit.run_post_hunt_healing_rc8 if request["heal"]
    Ashborne_toolkit.run_post_hunt_sale(true) if request["sell"]
    Ashborne_toolkit.script_kill
    Ashborne_toolkit.publish_cycle_stopped_rc15(request["session"])
    respond "#{Char.name} received the local Ashborne shutdown order."
    exit
  rescue => error
    respond "Ashborne local shutdown order failed: #{error.class}: #{error.message}"
    false
  end

  def process_follower_control_requests_rc15
    return false unless $ashborne_group_ai == "2"

    return true if Ashborne_toolkit.group_danger_retreat_if_needed
    return true if Ashborne_toolkit.process_follower_shutdown_request_rc15
    Ashborne_toolkit.process_follower_town_service_request_rc15
  end

  def wait_for_repeat_rest
    if Ashborne_toolkit.repeat_mana_recovery_required?
      respond "Ashborne cycle #{$ashborne_hunt_cycle} finished after a mana return. Resting to #{$ashborne_rest_mind}% mind and at least 90% mana before the next hunt."
    else
      respond "Ashborne cycle #{$ashborne_hunt_cycle} finished. Resting the group to #{$ashborne_rest_mind}% mind before the next hunt."
    end
    asked_for_healing = false
    attempted_healing = false
    rest_deadline = Time.now + 1800
    if $ashborne_rest_healing == "1" && Ashborne_toolkit.group_needs_rest_healing?
      Ashborne_toolkit.run_post_hunt_healing_rc8
      attempted_healing = true
      asked_for_healing = Ashborne_toolkit.request_rest_healing
    end
    until Ashborne_toolkit.group_rest_ready?
      if Time.now >= rest_deadline
        respond "Ashborne stopped the repeat queue because the group did not reach the rest target within 30 minutes."
        return false
      end
      Ashborne_toolkit.publish_group_state(true)
      if $ashborne_rest_healing == "1" && !attempted_healing && Ashborne_toolkit.group_needs_rest_healing?
        Ashborne_toolkit.run_post_hunt_healing_rc8
        attempted_healing = true
        asked_for_healing = Ashborne_toolkit.request_rest_healing unless asked_for_healing
      end
      sleep 5
    end
    unless Ashborne_toolkit.final_repeat_departure_gate_rc17
      respond "Ashborne stopped the repeat queue because the final medical or gear check did not pass."
      return false
    end
    if Ashborne_toolkit.repeat_mana_recovery_required?
      respond "The group reached #{$ashborne_rest_mind}% mind and 90% mana. Preparing hunt #{$ashborne_hunt_cycle + 1} of #{$ashborne_hunt_cycles}."
    else
      respond "The group is at or below #{$ashborne_rest_mind}% mind. Preparing hunt #{$ashborne_hunt_cycle + 1} of #{$ashborne_hunt_cycles}."
    end
    true
  end

  def group_town_services(force_sell = false)
    healing_enabled = $ashborne_rest_healing == "1"
    selling_enabled = force_sell || $ashborne_rest_sell == "1"
    return true unless healing_enabled || selling_enabled

    if Script.running?("go2")
      wait_while { Script.running?("go2") }
    end
    unless GameObj.targets.empty?
      respond "Ashborne will not begin town services while hostile creatures are present."
      return false
    end

    Script.run("go2", "town")
    wait_while { Script.running?("go2") }
    unless GameObj.targets.empty?
      respond "Ashborne reached the town route with hostile creatures still present; town services were stopped."
      return false
    end

    session_id = Ashborne_toolkit.current_group_session_id
    reunion_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
    if reunion_room == "0"
      respond "Ashborne could not establish a safe town reunion room."
      return false
    end
    unless Ashborne_toolkit.restore_combat_gear_rc17("town services")
      respond "Ashborne will not begin town services without verified combat gear."
      return false
    end
    if $ashborne_group_ai == "1"
      respond "Ashborne is sending every group member through enabled town services before resting."
      Ashborne_toolkit.publish_town_service_request(session_id, healing_enabled, selling_enabled, reunion_room)
      sleep 1
      fput "disband"
      fput "group open"
    end

    leader_healed = !healing_enabled || !Ashborne_toolkit.post_hunt_needs_healing_rc9? || Ashborne_toolkit.run_post_hunt_healing_rc8
    leader_sold = !selling_enabled || Ashborne_toolkit.run_post_hunt_sale(force_sell)
    $ashborne_leader_town_healed = leader_healed ? "1" : "0"
    $ashborne_leader_town_sold = leader_sold ? "1" : "0"
    unless leader_healed && leader_sold
      respond "Ashborne stopped the repeat queue because #{Char.name} did not finish required town services."
      return false
    end
    unless Ashborne_toolkit.final_repeat_departure_gate_rc17
      respond "Ashborne stopped the repeat queue because #{Char.name} is not medically safe or properly equipped after town services."
      return false
    end
    if reunion_room != "0" && (!Room.current || Ashborne_toolkit.current_room_id.to_s != reunion_room)
      return false unless Ashborne_toolkit.guarded_town_service_go2_rc17(reunion_room, "group reunion travel")
    end
    Ashborne_toolkit.publish_group_state(true)
    return true unless $ashborne_group_ai == "1"

    Ashborne_toolkit.wait_for_town_service_group_rc13(session_id, reunion_room)
  rescue => error
    respond "Ashborne could not complete town services: #{error.class}: #{error.message}"
    false
  end

  def finish_safe_return
    repeat_block_reason = Ashborne_toolkit.repeat_hunt_block_reason
    repeat_hunt = repeat_block_reason.nil?
    town_services_complete = false
    if repeat_hunt
      respond "Ashborne repeat queue: hunt #{$ashborne_hunt_cycle} of #{$ashborne_hunt_cycles} is complete; preparing the next hunt."
    elsif $ashborne_hunt_cycles.to_i > 1
      respond "Ashborne repeat queue stopped: #{repeat_block_reason}."
    else
      respond "Ashborne hunt complete: #{repeat_block_reason}."
    end
    town_services_complete = Ashborne_toolkit.group_town_services
    Ashborne_toolkit.request_rest_healing unless town_services_complete
    repeat_hunt = town_services_complete && Ashborne_toolkit.wait_for_repeat_rest if repeat_hunt
    Ashborne_toolkit.ashborne_stow_all
    $ashborne_group_end_heal = $ashborne_rest_healing == "1" && !town_services_complete && $ashborne_leader_town_healed != "1" ? "1" : "0"
    $ashborne_group_end_sell = $ashborne_rest_sell == "1" && !town_services_complete && $ashborne_leader_town_sold != "1" ? "1" : "0"
    Ashborne_toolkit.group_kill_scripts
    if $ashborne_group_end_sell == "1" && $ashborne_group_ai != "0"
      fput "disband"
      fput "group open"
    end
    Ashborne_toolkit.run_post_hunt_healing_rc8 if $ashborne_group_end_heal == "1"
    Ashborne_toolkit.run_post_hunt_sale if $ashborne_group_end_sell == "1"
    Ashborne_toolkit.cleanup if $ashborne_combat_cleanup != "0" && !repeat_hunt

    if repeat_hunt
      next_cycle = $ashborne_hunt_cycle.to_i + 1
      Ashborne_toolkit.schedule_next_cycle_rc12(
        $ashborne_original_style,
        $ashborne_original_area,
        next_cycle
      )
    end
    exit
  end

  def schedule_next_cycle_rc12(style, area, cycle_number)
    style = style.to_s
    area = area.to_s.strip
    if Ashborne_toolkit.huntplan_catalog_zone(area)
      area = Ashborne_toolkit.huntplan_catalog_key(area)
    end
    cycle = "cycle=#{cycle_number.to_i}"
    unless style =~ /\A[1-9]\z/ && area =~ /\A[A-Za-z0-9_\-']+\z/ && cycle =~ /\Acycle=\d+\z/i
      respond "Ashborne cycle handoff received invalid hunt arguments and stopped."
      return false
    end

    launch_command = ";#{Ashborne_toolkit.script_command_name} #{style} #{area} #{cycle}"
    handoff = <<~RUBY
      deadline = Time.now + 60
      while Script.running?("ashborne") && Time.now < deadline
        sleep 0.25
      end
      if Script.running?("ashborne")
        respond "Ashborne cycle handoff timed out waiting for the completed hunt to exit."
        exit
      end

      data_directory = File.join($lich_dir, "data", "ashborne")
      leader_name = Char.name.to_s.gsub(/[^A-Za-z0-9_\\-]/, "")
      session_file = File.join(data_directory, "\#{leader_name}_ashborne_group_session.txt")
      if File.exist?(session_file)
        session_id, _previous_style, member_list = File.read(session_file).strip.split("|", 3)
        members = member_list.to_s.split(",").map(&:strip).reject(&:empty?)
        shutdown_deadline = Time.now + 300
        loop do
          followers_stopped = members.all? do |member_name|
            begin
              safe_name = member_name.gsub(/[^A-Za-z0-9_\\-]/, "")
              receipt = File.join(data_directory, "\#{safe_name}_ashborne_cycle_stopped.txt")
              next false unless File.exist?(receipt)
              stopped_session, timestamp, _name = File.read(receipt).strip.split("|", 3)
              stopped_session.to_s == session_id.to_s && Time.now.to_i - timestamp.to_i <= 600
            rescue
              false
            end
          end
          break if followers_stopped
          if Time.now >= shutdown_deadline
            respond "Ashborne cycle handoff stopped because one or more followers did not finish shutdown within 5 minutes."
            exit
          end
          sleep 0.5
        end
      end

      sleep 0.5
      do_client #{launch_command.inspect}
    RUBY
    ExecScript.start(handoff, :quiet => true)
    true
  rescue => error
    respond "Ashborne could not schedule hunt #{cycle_number}: #{error.class}: #{error.message}"
    false
  end

  def bleeding_danger?
    checkreallybleeding
  rescue
    false
  end

  def critical_health_floor
    60
  end

  def critical_health_retreat_reason
    health = percenthealth.to_i
    return "critical health (#{health}%)" if health <= Ashborne_toolkit.critical_health_floor

    nil
  rescue
    nil
  end

  def critical_health_retreat_reason?(reason)
    reason.to_s =~ /critical health/i ? true : false
  rescue
    false
  end

  def personal_medical_retreat_reason
    critical_health = Ashborne_toolkit.critical_health_retreat_reason
    return critical_health unless critical_health.nil?

    wound_rank = Ashborne_toolkit.max_injury_rank(Wounds)
    scar_rank = Ashborne_toolkit.max_injury_rank(Scars)
    injury_rank = [wound_rank, scar_rank].max
    bleeding = Ashborne_toolkit.bleeding_danger?

    return "rank #{injury_rank} injury with active bleeding" if injury_rank >= 1 && bleeding
    return "rank #{injury_rank} injury" if injury_rank >= 2
    return "active bleeding" if bleeding
    return "low health (#{percenthealth.to_i}%)" if percenthealth.to_i < Ashborne_toolkit.health_floor

    nil
  rescue
    nil
  end

  def medical_retreat_if_needed
    reason = Ashborne_toolkit.personal_medical_retreat_reason
    return false if reason.nil?

    Ashborne_toolkit.stance_defensive
    $ashborne_return_why = "Medical retreat: #{reason}."
    $ashborne_action = 99
    $ashborne_group_danger_active = "1"
    Ashborne_toolkit.publish_group_danger(reason) if $ashborne_group_ai != "0"
    if Ashborne_toolkit.critical_health_retreat_reason?(reason)
      waitrt? if checkrt.to_f > 0
      waitcastrt? if checkcastrt.to_f > 0
      Ashborne_toolkit.emergency_return_to_town_if_needed
      exit
    end
    true
  rescue
    false
  end

  def medical_retreat_reason?(reason = $ashborne_return_why)
    reason.to_s =~ /medical retreat|injury|bleeding|low health/i ? true : false
  rescue
    false
  end

  def personal_group_danger_reason
    medical_reason = Ashborne_toolkit.personal_medical_retreat_reason
    return medical_reason unless medical_reason.nil?

    if Ashborne_toolkit.loot_rotation_enabled? && Ashborne_toolkit.personal_encumbrance_emergency?
      return "encumbrance advanced beyond moderate (#{checkencumbrance}, #{percentencumbrance.to_i})"
    end

    nil
  end

  def solo_swarm_retreat_threshold
    4
  end

  def solo_swarm_retreat_reason
    return nil unless $ashborne_group_ai == "0"
    target_count = GameObj.targets.length
    return nil if target_count < Ashborne_toolkit.solo_swarm_retreat_threshold

    "solo swarm pressure (#{target_count} hostile creatures)"
  rescue
    nil
  end

  def solo_swarm_retreat_if_needed
    reason = Ashborne_toolkit.solo_swarm_retreat_reason
    return false if reason.nil?

    Ashborne_toolkit.stance_defensive
    waitrt? if checkrt.to_f > 0
    waitcastrt? if checkcastrt.to_f > 0
    starting_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
    respond "Ashborne is stepping out to break up #{reason}."
    Ashborne_toolkit.walk_avoiding_environmental_rooms(reason)
    moved = starting_room.nil? || !Room.current || Ashborne_toolkit.current_room_id.to_s != starting_room
    respond "Ashborne could not move out of the swarm room; staying defensive." unless moved
    $ashborne_action = 0
    $ashborne_own_this_room = 0
    $ashborne_my_vine = "0"
    $ashborne_recent_eviction = "1"
    true
  rescue
    Ashborne_toolkit.stance_defensive
    false
  end

  def publish_group_danger(reason)
    return nil if $ashborne_group_ai == "0"

    begin
      room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
      payload = [Char.name, reason, room_id, Time.now.to_i.to_s].join("|")
      File.write(Ashborne_toolkit.group_danger_file, payload)
    rescue
      nil
    end

    nil
  end

  def current_group_danger
    return nil if $ashborne_group_ai == "0"

    danger_file = Ashborne_toolkit.group_danger_file
    return nil unless File.exist?(danger_file)

    begin
      danger_name, danger_reason, danger_room, danger_ts = File.read(danger_file).strip.split("|", 4)
      return nil if danger_name.nil? || danger_reason.nil? || danger_ts.nil?
      return nil if danger_ts.to_i <= 0
      return nil if (Time.now.to_i - danger_ts.to_i) > 90

      [danger_name, danger_reason, danger_room]
    rescue
      nil
    end
  end

  def clear_group_danger
    return nil if $ashborne_group_ai == "0"

    begin
      File.delete(Ashborne_toolkit.group_danger_file) if File.exist?(Ashborne_toolkit.group_danger_file)
    rescue
      nil
    end
  end

  def apply_group_danger_abort
    danger = Ashborne_toolkit.current_group_danger
    return false if danger.nil?

    $ashborne_group_danger_active = "1"
    $ashborne_return_why = "Group danger: #{danger[0]} reported #{danger[1]}."
    $ashborne_action = 99
    true
  end

  def group_danger_status_check
    if $ashborne_group_ai == "0"
      danger_reason = Ashborne_toolkit.personal_group_danger_reason
      return false if danger_reason.nil?

      $ashborne_group_danger_active = "1"
      $ashborne_return_why = "Medical retreat: #{danger_reason}."
      $ashborne_action = 99
      return true
    end

    if Ashborne_toolkit.apply_group_danger_abort
      Ashborne_toolkit.emergency_return_to_town_if_needed if $ashborne_group_ai == "1"
      return true
    end

    danger_reason = Ashborne_toolkit.personal_group_danger_reason
    return false if danger_reason.nil?

    Ashborne_toolkit.publish_group_danger(danger_reason)
    Ashborne_toolkit.apply_group_danger_abort
    Ashborne_toolkit.emergency_return_to_town_if_needed if $ashborne_group_ai == "1"
    true
  end

  def solo_emergency_return_to_town
    $ashborne_group_danger_active = "1"
    $ashborne_return_why ||= "Emergency retreat."
    Ashborne_toolkit.stance_defensive
    waitrt? if checkrt.to_f > 0
    waitcastrt? if checkcastrt.to_f > 0

    retreat_origin = Room.current && Ashborne_toolkit.current_room_id
    retreat_attempt = 0
    loop do
      retreat_attempt += 1
      Ashborne_toolkit.stance_defensive
      unless Ashborne_toolkit.travel_departure_ready?("emergency retreat")
        Ashborne_toolkit.stance_defensive
        Ashborne_toolkit.script_kill
        Ashborne_toolkit.top_menu
        respond "Solo emergency retreat could not safely start travel. Staying defensive instead of returning to combat."
        Ashborne_toolkit.bottom_menu
        exit
      end

      do_client ";go2 town"
      Ashborne_toolkit.unpause_go2
      wait_while { running? "go2" }

      moved_from_danger = Room.current && Ashborne_toolkit.current_room_id &&
        retreat_origin && Ashborne_toolkit.current_room_id.to_s != retreat_origin.to_s
      break if Ashborne_toolkit.safe_retreat_room_reached? || moved_from_danger

      respond "Solo emergency retreat did not move to safety; retrying go2 town." if retreat_attempt == 1 || retreat_attempt % 3 == 0
      sleep 1
    end

    Ashborne_toolkit.script_kill
    Ashborne_toolkit.top_menu
    respond "I returned to town because: #{$ashborne_return_why}"
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.ashborne_stow_all
    force_sell = Ashborne_toolkit.encumbrance_return?
    town_services_complete = Ashborne_toolkit.group_town_services(force_sell)
    Ashborne_toolkit.run_post_hunt_healing_rc8 if $ashborne_rest_healing == "1" && !town_services_complete
    Ashborne_toolkit.run_post_hunt_sale(force_sell) if (force_sell || $ashborne_rest_sell == "1") && !town_services_complete
    exit
  end

  def emergency_return_to_town_if_needed
    return false unless $ashborne_group_danger_active == "1"
    return Ashborne_toolkit.solo_emergency_return_to_town if $ashborne_group_ai == "0"

    Ashborne_toolkit.group_return_to_town
  end

  def group_return_to_town
    return Ashborne_toolkit.solo_emergency_return_to_town if $ashborne_group_ai == "0"

    $ashborne_group_danger_active = "1"
    $ashborne_return_why ||= "Group danger detected."
    Ashborne_toolkit.stance_defensive
    waitrt? if checkrt.to_f > 0
    waitcastrt? if checkcastrt.to_f > 0
    force_sell = Ashborne_toolkit.encumbrance_return?
    if $ashborne_group_ai == "1"
      Ashborne_toolkit.publish_town_service_request(
        Ashborne_toolkit.current_group_session_id,
        $ashborne_rest_healing == "1",
        force_sell || $ashborne_rest_sell == "1",
        "0"
      )
    end

    urgent_retreat = Ashborne_toolkit.huntplan_catalog_zone? || $ashborne_group_danger_active == "1"
    unless urgent_retreat
      return nil unless Ashborne_toolkit.group_wait_for_followers_to_move
      until Ashborne_toolkit.travel_departure_ready?("emergency retreat")
        return nil if checkdead
        sleep 1
      end
    else
      respond "Emergency retreat is bypassing group movement wait because danger is already active."
      3.times do
        break if checkdead
        break if Ashborne_toolkit.travel_departure_ready?("emergency retreat")

        blockers = []
        blockers << "stunned" if checkstunned
        blockers << "webbed" if webbed?
        blockers << "bound" if bound?
        blockers << "roundtime" if checkrt.to_f > 0
        blockers << "cast roundtime" if checkcastrt.to_f > 0
        Ashborne_toolkit.recover_from_emergency_blocker(blockers)
        sleep 0.5
      end
    end

    retreat_origin = Room.current && Ashborne_toolkit.current_room_id
    retreat_attempt = 0
    loop do
      retreat_attempt += 1
      begin
        fput "stance defensive" unless checkstance == "defensive"
      rescue
        nil
      end

      Ashborne_toolkit.group_wait_for_loot_to_settle(8) unless urgent_retreat
      do_client ";go2 town"
      Ashborne_toolkit.unpause_go2
      wait_while { running? "go2" }

      moved_from_danger = Room.current && Ashborne_toolkit.current_room_id &&
        retreat_origin && Ashborne_toolkit.current_room_id.to_s != retreat_origin.to_s
      safe_here = Ashborne_toolkit.safe_retreat_room_reached?
      break if safe_here
      break if urgent_retreat ? moved_from_danger : (moved_from_danger && GameObj.targets.empty?)

      respond "Emergency retreat did not reach safety; retrying go2 town." if retreat_attempt == 1 || retreat_attempt % 3 == 0
      sleep 1
      unless urgent_retreat
        until Ashborne_toolkit.travel_departure_ready?("emergency retreat retry")
          return nil if checkdead
          sleep 1
        end
      end
    end

    Ashborne_toolkit.script_kill
    Ashborne_toolkit.top_menu
    respond "I returned to town because: #{$ashborne_return_why}"
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.ashborne_stow_all
    respond "Encumbrance emergency: the group will sell before Ashborne exits." if force_sell
    if $ashborne_group_ai == "2"
      Ashborne_toolkit.finish_follower_emergency_town_services_rc10
      exit
    end
    town_services_complete = Ashborne_toolkit.group_town_services(force_sell)
    if $ashborne_group_ai == "1"
      $ashborne_group_end_heal = $ashborne_rest_healing == "1" && !town_services_complete && $ashborne_leader_town_healed != "1" ? "1" : "0"
      $ashborne_group_end_sell = (force_sell || $ashborne_rest_sell == "1") && !town_services_complete && $ashborne_leader_town_sold != "1" ? "1" : "0"
      Ashborne_toolkit.group_kill_scripts
      Ashborne_toolkit.clear_group_danger
    end
    Ashborne_toolkit.run_post_hunt_healing_rc8 if $ashborne_group_end_heal == "1"
    if $ashborne_group_end_sell == "1"
      if $ashborne_group_ai != "0"
        fput "disband"
        fput "group open"
      end
      Ashborne_toolkit.run_post_hunt_sale(force_sell)
    end
    exit
  end

  def safe_retreat_room_reached?
    return false unless Room.current && Ashborne_toolkit.current_room_id
    return false unless GameObj.targets.empty?

    if $ashborne_rest_room.to_s != "0" && Ashborne_toolkit.current_room_id.to_s == $ashborne_rest_room.to_s
      return true
    end

    checkarea.to_s =~ /Ta'Illistim|Wehnimer|Icemule|Solhaven|Vaalor|Mist Harbor|Landing|Town|Bank|Hanging Gardens|BriarStone|Shimmarglin|Kaerinar|Moonglae|Portcullis|Gateyard|Sapphire Gate/i
  rescue
    false
  end

  def group_danger_retreat_if_needed
    Ashborne_toolkit.apply_group_danger_abort
    return false unless $ashborne_group_danger_active == "1"

    danger = Ashborne_toolkit.current_group_danger
    if Ashborne_toolkit.dead_group_danger?(danger)
      exit if Ashborne_toolkit.dead_group_rescue_transport(danger)
      Ashborne_toolkit.stop_unsafe_dead_group_drag(danger)
    end

    Ashborne_toolkit.rescue_current_group_danger
    if $ashborne_group_ai == "1"
      Ashborne_toolkit.emergency_return_to_town_if_needed
      return true
    end
    if $ashborne_group_ai == "2"
      captain = Ashborne_toolkit.canonical_character_name($ashborne_captain)
      if Ashborne_toolkit.valid_character_name?(captain) && Ashborne_toolkit.visible_group_pc(captain)
        Ashborne_toolkit.stance_defensive
        Ashborne_toolkit.publish_group_state(true)
        Ashborne_toolkit.fight_or_recover_for_emergency_retreat([]) unless GameObj.targets.empty?
        if Time.now.to_i - $ashborne_last_retreat_hold_notice.to_i >= 10
          respond "Emergency retreat hold: staying with #{captain} until the leader moves the group."
          $ashborne_last_retreat_hold_notice = Time.now.to_i
        end
        return true
      end
    end

    if $ashborne_group_ai == "2" && danger
      danger_name, _danger_reason, danger_room = danger
      current_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
      if !danger_name.to_s.casecmp(Char.name.to_s).zero? &&
          danger_room.to_s == current_room.to_s &&
          !GameObj.targets.empty?
        Ashborne_toolkit.fight_or_recover_for_emergency_retreat([])
        return true
      end
    end

    Ashborne_toolkit.group_return_to_town
    true
  end

  def group_spell_combat_key
    room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
    target_ids = GameObj.targets.map { |target| target.id.to_s rescue target.to_s }.sort.join(",")
    target_ids = "none" if target_ids.empty?
    "#{room_id}:#{target_ids}"
  end

  def group_spell_room_key
    Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "0"
  end

  def group_spell_same_scope?(spell_data, combat_key, room_scope = false)
    return false unless spell_data

    if room_scope
      spell_data[0].to_s.split(":", 2)[0] == Ashborne_toolkit.group_spell_room_key
    else
      spell_data[0] == combat_key
    end
  end

  def group_spell_state
    spell_state = {}
    spell_file = Ashborne_toolkit.group_spell_file
    return spell_state unless File.exist?(spell_file)

    begin
      File.readlines(spell_file).each do |line|
        combat_key, spell_key, caster_name, cast_ts = line.strip.split("|", 4)
        next if combat_key.nil? || spell_key.nil? || caster_name.nil? || cast_ts.nil?
        next if cast_ts.to_i <= 0
        next if (Time.now.to_i - cast_ts.to_i) > 45
        spell_state[spell_key] = [combat_key, caster_name, cast_ts.to_i]
      end
    rescue
      nil
    end

    spell_state
  end

  def write_group_spell_state(spell_state)
    begin
      lines = spell_state.map { |spell_key, spell_data| "#{spell_data[0]}|#{spell_key}|#{spell_data[1]}|#{spell_data[2]}" }
      File.write(Ashborne_toolkit.group_spell_file, lines.join("\n"))
    rescue
      nil
    end
  end

  def group_spell_claimed?(spell_key, room_scope = false)
    return false if $ashborne_group_ai == "0"

    spell_data = Ashborne_toolkit.group_spell_state[spell_key]
    Ashborne_toolkit.group_spell_same_scope?(spell_data, Ashborne_toolkit.group_spell_combat_key, room_scope)
  end

  def group_spell_claim(spell_key, room_scope = false)
    return true if $ashborne_group_ai == "0"

    spell_state = Ashborne_toolkit.group_spell_state
    combat_key = Ashborne_toolkit.group_spell_combat_key
    spell_data = spell_state[spell_key]
    return false if Ashborne_toolkit.group_spell_same_scope?(spell_data, combat_key, room_scope)

    spell_state[spell_key] = [combat_key, Char.name, Time.now.to_i]
    Ashborne_toolkit.write_group_spell_state(spell_state)
    true
  end

  def group_any_spell_claimed?(spell_keys, room_scope = false)
    spell_keys.any? { |spell_key| Ashborne_toolkit.group_spell_claimed?(spell_key, room_scope) }
  end

  def group_noise_ready?
    return true unless $ashborne_group_noise == "1"
    return true if $ashborne_group_ai == "0"

    pre_noise_spells = ["shield_throw", "610", "1614_open", "1615", "1117", "1120", "335", "917", "1207"]
    if Ashborne_toolkit.group_spell_claimed?("shield_throw", true)
      sleep 1.5
      return true
    end

    if Ashborne_toolkit.group_spell_claimed?("610", true)
      sleep 1.5
      return true
    end

    wait_until = Time.now + 4
    until Time.now >= wait_until
      sleep 0.25
      if Ashborne_toolkit.group_spell_claimed?("shield_throw", true)
        sleep 1.5
        return true
      elsif Ashborne_toolkit.group_spell_claimed?("610", true)
        sleep 1.5
        return true
      elsif Ashborne_toolkit.group_any_spell_claimed?(pre_noise_spells, true)
        sleep 1.5
        return true
      end
    end

    true
  end

  def publish_group_leader_room
    return nil unless $ashborne_group_ai == "1"
    return nil unless Room.current && Ashborne_toolkit.current_room_id

    begin
      File.write(Ashborne_toolkit.group_leader_room_file, Ashborne_toolkit.current_room_id.to_s)
    rescue
      nil
    end

    nil
  end

  def publish_group_ready_state(ready)
    return nil unless $ashborne_group_ai == "1"
    return nil unless Room.current && Ashborne_toolkit.current_room_id

    begin
      payload = [ready ? "1" : "0", Ashborne_toolkit.current_room_id.to_s, Time.now.to_i.to_s].join("|")
      File.write(Ashborne_toolkit.group_ready_file, payload)
    rescue
      nil
    end

    nil
  end

  def leader_group_ready_for_followers?
    return false unless Ashborne_toolkit.group_follower_attack_priority
    return false unless Room.current && Ashborne_toolkit.current_room_id

    ready_file = Ashborne_toolkit.group_ready_file
    return false unless File.exist?(ready_file)

    begin
      ready_flag, ready_room, ready_ts = File.read(ready_file).strip.split("|", 3)
      return false unless ready_flag == "1"
      return false unless ready_room.to_s == Ashborne_toolkit.current_room_id.to_s
      return false if ready_ts.to_i <= 0
      return false if (Time.now.to_i - ready_ts.to_i) > 30

      true
    rescue
      false
    end
  end

  def follower_disabled_target_present?
    return false if GameObj.targets.empty?

    GameObj.targets.any? do |target|
      target.status.to_s =~ /sleeping|to be frozen in place|stunned|lying down|prone|kneeling|bound|webbed|entangled|immobile|dazed|confused|nerveless|unable to stand/i
    end
  end

  def group_follower_should_skip_setup
    Ashborne_toolkit.group_follower_attack_priority && Ashborne_toolkit.follower_disabled_target_present?
  end

  def group_follow_sync(force = false)
    return nil unless $ashborne_group_ai == "2"
    return nil unless $ashborne_my_area =~ /group|follow|qfollow/
    return nil if Script.running?("go2")
    return nil if checkpcs "#{$ashborne_captain}"
    return nil if checkrt > 0 && !force
    return nil unless GameObj.npcs.empty? || force

    leader_room_file = Ashborne_toolkit.group_leader_room_file
    return nil unless File.exist?(leader_room_file)

    leader_room = File.read(leader_room_file).strip
    return nil if leader_room.empty?
    return nil if Room.current && Ashborne_toolkit.current_room_id.to_s == leader_room
    unless Ashborne_toolkit.short_group_sync_route?(leader_room)
      respond "Group sync refused a distant route to room #{leader_room}; holding for a local regroup."
      return nil
    end

    respond "Group sync: moving to #{$ashborne_captain} in room #{leader_room}."
    return nil unless Ashborne_toolkit.movement_guard

    3.times do |attempt|
      do_client ";go2 #{leader_room}"
      sleep 0.25
      wait_while { Script.running?("go2") }
      return nil if Room.current && Ashborne_toolkit.current_room_id.to_s == leader_room

      respond "Group sync go2 stopped early; retrying room #{leader_room} (#{attempt + 2}/3)." if attempt < 2
      sleep 1
    end
    nil
  end

  def short_group_sync_route?(leader_room, max_steps = 12)
    return false unless Room.current

    destination = Room[leader_room.to_i]
    return false unless destination

    path = Room.current.path_to(destination)
    path && path.length <= max_steps
  rescue
    false
  end

  def leader_obstacle_follow_command(event_text)
    text = event_text.to_s

    return "climb landslide" if text =~ /#{$ashborne_captain} .*climbs? (?:up|down) (?:the |a |an )?landslide/i
    return "climb rockslide" if text =~ /#{$ashborne_captain} .*climbs? (?:up|down) (?:the |a |an )?rockslide/i
    return "climb rockslide" if text =~ /#{$ashborne_captain} begins to climb down the rockslide/i

    nil
  rescue
    nil
  end

  def rejoin_captain_group(timeout_seconds = 8)
    return true unless $ashborne_group_ai == "2"
    captain = Ashborne_toolkit.canonical_character_name($ashborne_captain)
    return false unless Ashborne_toolkit.valid_character_name?(captain)

    deadline = Time.now + timeout_seconds
    next_join_attempt = Time.at(0)
    until Time.now >= deadline
      Ashborne_toolkit.publish_group_state(true)
      return true if Ashborne_toolkit.follower_in_expected_group?
      if checkpcs(captain) && Time.now >= next_join_attempt
        waitrt?
        fput "join #{captain}"
        next_join_attempt = Time.now + 2
      end
      sleep 0.5
    end
    false
  rescue
    false
  end

  def handle_leader_obstacle_event(event_text)
    return nil unless $ashborne_group_ai == "2"

    command = Ashborne_toolkit.leader_obstacle_follow_command(event_text)
    if command
      respond "Group obstacle sync: mirroring #{$ashborne_captain}'s #{command} before regrouping."
      return nil unless Ashborne_toolkit.movement_guard
      starting_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
      Ashborne_toolkit.clear_hands_for_group_obstacle
      crossed = false
      3.times do
        break if checkpcs("#{$ashborne_captain}")

        Ashborne_toolkit.clear_hands_for_group_obstacle
        fput command
        waitrt?
        sleep 0.5
        crossed = Room.current && Ashborne_toolkit.current_room_id && Ashborne_toolkit.current_room_id.to_s != starting_room.to_s
        break if crossed
      end
      if crossed || checkpcs("#{$ashborne_captain}")
        $ashborne_uac_hands_verified = "0"
        fput "gird"
        Ashborne_toolkit.enforce_uac_empty_hands
      else
        respond "Group obstacle sync could not cross with #{$ashborne_captain}; holding here for a local regroup."
        return false
      end
      Ashborne_toolkit.rejoin_captain_group(8)
      return true if checkpcs("#{$ashborne_captain}")
    end

    if checkpcs("#{$ashborne_captain}")
      Ashborne_toolkit.rejoin_captain_group(8)
    else
      Ashborne_toolkit.group_follow_sync(true)
      Ashborne_toolkit.rejoin_captain_group(8)
    end
    true
  rescue => error
    respond "Group obstacle sync warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def clear_hands_for_group_obstacle
    Ashborne_toolkit.ashborne_stow_all
    waitrt?
    fput "stow right" if checkright
    fput "stow left" if checkleft
    waitrt?
    checkright.nil? && checkleft.nil?
  rescue
    false
  end
  def group_follower_attack_priority
    if $ashborne_my_area =~ /group|follow|qfollow/ && $ashborne_captain != "0"
      true
    else
      false
    end
  end

  def group_follower_captain_present?
    return false unless Ashborne_toolkit.group_follower_attack_priority
    return false if $ashborne_captain.nil? || $ashborne_captain == "0"
    return false unless checkpcs("#{$ashborne_captain}")
    return false unless Ashborne_toolkit.leader_group_ready_for_followers?

    true
  end

  def group_follower_should_hold?
    return false unless Ashborne_toolkit.group_follower_attack_priority
    return true if Script.running?("go2")
    return true unless Ashborne_toolkit.group_follower_captain_present?

    false
  end

  def follower_status_notice_rc18
    return if defined?($ashborne_follower_status_announced) && $ashborne_follower_status_announced

    if $ashborne_group_peace == "1"
      respond "Group ;ashborne is active in peaceful mode. Leader: #{$ashborne_captain}."
    else
      respond "Group ;ashborne is active. Leader: #{$ashborne_captain}."
    end
    $ashborne_follower_status_announced = true
  end

  def group_follower_safe_hold
    return false unless Ashborne_toolkit.group_follower_attack_priority
    return false unless Ashborne_toolkit.group_follower_should_hold?

    begin
      fput "stop" if checkrt > 0
    rescue
      nil
    end

    begin
      fput "stance defensive" unless checkstance == "defensive"
    rescue
      nil
    end

    if !Script.running?("go2") && GameObj.npcs.empty? && checkrt <= 0
      Ashborne_toolkit.group_follow_sync
    end

    true
  end

  def group_follower_fast_attack
    return false unless Ashborne_toolkit.group_follower_attack_priority
    return false if Ashborne_toolkit.group_follower_should_hold?
    return false if GameObj.targets.length == 0
    return false if Ashborne_toolkit.noise_lockdown?
    return false if $ashborne_my_style == "9"

    begin
      Ashborne_toolkit.waitcast_waitrt
      return false if Ashborne_toolkit.group_follower_should_hold?
      Ashborne_toolkit.stand_check
      return false if Ashborne_toolkit.group_follower_should_hold?

      if Skills.multiopponentcombat >= 5 && percentstamina >= 60
        if GameObj.targets.length >= 2 && $ashborne_my_mstrike_open >= 1
          Ashborne_toolkit.stance_offensive
          fput "mstrike"
          Ashborne_toolkit.mark_group_vulnerable
          return true
        elsif GameObj.targets.length == 1 && $ashborne_my_mstrike_focus >= 1
          Ashborne_toolkit.stance_offensive
          fput "mstrike"
          Ashborne_toolkit.mark_group_vulnerable
          return true
        end
      end

      if $ashborne_my_style == "1" || $ashborne_my_style == "2"
        Ashborne_toolkit.uac_round
      elsif $ashborne_my_style == "4"
        Ashborne_toolkit.hide_time
        Ashborne_toolkit.stance_offensive
        if checkhidden
          Ashborne_toolkit.chicken_ambush
        else
          Ashborne_toolkit.chicken_attack
        end
      elsif $ashborne_my_style == "5" || $ashborne_my_style == "6" || $ashborne_my_style == "7" || $ashborne_my_style == "8"
        Ashborne_toolkit.stance_offensive
        Ashborne_toolkit.chicken_fire
      else
        Ashborne_toolkit.stance_offensive
        Ashborne_toolkit.chicken_attack
      end

      true
    ensure
      Ashborne_toolkit.stance_guarded
    end
  end

