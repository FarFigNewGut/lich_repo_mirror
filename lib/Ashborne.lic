    "ashborne_setting_spell_learning" =>
      "Optional and off by default. When enabled, Intel Ashborne compares manually cast spells with Ashborne's standard attacks for the same creature. A spell needs repeated evidence before it can influence Wizard auto combat. When disabled, Ashborne uses the standard HuntPro spell cycle.",
    "ashborne_setting_group_style" =>
      "The combat method this character uses while following a group leader.\n" \
      "Style 3 already supports one weapon, two weapons, two-handed weapons, and weapon-plus-shield setups.\n\n" \
      "Group mode also requires a multi-account command tool selected below.",
    "ashborne_setting_multi_account_tool" =>
      "Select Borg to use borg.rb, queen.lic, and drone.lic. Select Thunder to run ;thunder on the leader and ;struck on every follower. All characters must use the same selection.",
    "ashborne_setting_group_additional" =>
      "Additional follower names separated by commas. These followers receive the same startup, rally, safety, resting, and shutdown coordination as slots 1 through 9.",
    "ashborne_setting_leader" =>
      "The exact character name of the group leader.\n" \
      "On the leader's own setup, enter the leader's own name.",
    "ashborne_setting_health_floor" =>
      "If any participating character falls below this health percentage, the group returns to town.",
    "ashborne_setting_mana_reserve" =>
      "Ashborne avoids optional spell spending below this mana percentage.",
    "ashborne_setting_stamina_reserve" =>
      "Ashborne avoids optional physical abilities below this stamina percentage.",
    "ashborne_setting_anti_caster" =>
      "Allows one elected group member to interrupt a dangerous casting creature.\n" \
      "The coordinator prevents every character from stopping at once.",
    "ashborne_setting_anti_caster_mana" =>
      "Extra mana reserve specifically for emergency anti-caster spells.",
    "ashborne_setting_preflight" =>
      "Checks group membership, capability profiles, injuries, and follower readiness before leaving town.",
    "ashborne_setting_job_coordinator" =>
      "Elects one primary and one backup for jobs such as interrupt, guardian, healer, and control.",
    "ashborne_setting_noise_lockdown" =>
      "A Bard maintains Song of Noise and the group switches to physical attacks only.\n" \
      "Use this only in hunting areas where preventing spellcasting is safer than casting.",
    "ashborne_setting_group_noise" =>
      "Lets a Bard use Song of Noise after opening crowd control without forcing permanent melee lockdown.",
    "ashborne_setting_role" =>
      "Usually leave this on auto. A specific role adds preference when Ashborne elects group jobs.",
    "ashborne_setting_spell_default" =>
      "Optional. Leave this at 0 to use HuntPro's exact profession and creature-specific spell routine. Enter one spell or a comma-separated rotation such as 903, 904, 908 to use your own affordable attack spells.",
    "ashborne_setting_use_empty" =>
      "Style 9 begins with empty hands instead of readying a weapon.",
    "ashborne_setting_crowd_control" =>
      "Allows appropriate spells and abilities that disable or slow multiple creatures.",
    "ashborne_setting_huntpro_spell_baseline" =>
      "On by default. Style 9 uses HuntPro's complete profession casting cycle before its main attack, including spells such as Earthen Fury (917), Tremors (909), Mana Leech (516), and Chromatic Circle (502) when HuntPro's normal level, mana, training, and cooldown conditions are met. Turn this off only to let Ashborne's custom ability rules filter those spells.",
    "ashborne_setting_cman_control" =>
      "Allows known Combat Maneuvers when Ashborne considers them useful.",
    "ashborne_setting_no_shield_control" =>
      "Disables automatic Shield Specialization abilities. This does not remove the shield itself.",
    "ashborne_setting_no_weapon_control" =>
      "Disables automatic Weapon Technique abilities.",
    "ashborne_setting_no_mstrike_control" =>
      "Disables MSTRIKE use while preserving the selected combat style.",
    "ashborne_setting_flee" =>
      "Return from a room when creature count exceeds this number. Use 0 to disable.",
    "ashborne_setting_loot_script" =>
      "Script used to collect treasure after combat. Most users use eloot.",
    "ashborne_setting_cleanloot_script" =>
      "Script used during cleanup or selling. Use 0 to reuse the normal loot script.",
    "ashborne_setting_loot_rotation" =>
      "Lets one group member loot at a time and rotates that job when the current looter becomes encumbered.",
    "ashborne_setting_preferred_looter" =>
      "Exact character name that should loot first. Use 0 to prefer the group leader.",
    "ashborne_setting_eligible_looters" =>
      "Characters allowed to take the loot job. Use all, or comma-separated exact names.",
    "ashborne_setting_loot_handoff" =>
      "When the current looter reaches this Lich encumbrance-meter value, Ashborne assigns the least-encumbered eligible member.\n" \
      "30 corresponds to the moderate encumbrance tier in the current Lich meter.",
    "ashborne_setting_loot_emergency" =>
      "The group returns as soon as a character advances beyond the moderate encumbrance tier.\n" \
      "40 is used as the fallback when the server tier label is unavailable.",
    "ashborne_setting_rest_room" =>
      "Mapped room number where this character rests between hunts.",
    "ashborne_setting_hunt_cycles" =>
      "Total hunts to run before stopping. After each completed hunt, Ashborne returns, rests, and starts the same area again. Default is 1.",
    "ashborne_setting_rest_mind" =>
      "Ashborne waits until every active group member is at or below this mind percentage before repeating. Default is 50%.",
    "ashborne_setting_rest_healing" =>
      "Runs each character's available post-hunt herb or self-healing behavior while resting.",
    "ashborne_setting_rest_ask_empath" =>
      "If still injured, directly whispers a known visible empath once to ask for healing. Off by default.\n" \
      "This is the only intentional in-game whisper Ashborne sends; script coordination remains local.",
    "ashborne_setting_rest_sell" =>
      "Runs ;eloot sell after resting and healing. On a group leader, this also tells every follower to sell using that character's own ELoot setup. Off by default.",
    "ashborne_setting_combat_cleanup" =>
      "Runs Ashborne cleanup behavior when the hunt ends.",
    "ashborne_setting_use_herbs" =>
      "Enables combat herb use in every hunting area.",
    "ashborne_setting_no_herbs" =>
      "Disables combat herb use in every hunting area.",
    "ashborne_setting_group_peace" =>
      "Follower stays with the group but does not attack.",
    "ashborne_setting_group_quiet" =>
      "Follower suppresses routine status reports to the leader.",
    "ashborne_setting_group_sharemana" =>
      "Legacy option. Local-only coordination does not send mana requests through game chat.\n" \
      "A dangerously low-mana character instead reports through the local safety bus."
  }.freeze

  def script_path
    File.join($lich_dir, "scripts", "ashborne.lic")
  end

  def defaults
    result = {}
    File.foreach(script_path) do |line|
      match = line.match(/^\s*(ashborne_setting_[a-z0-9_]+)\s*=\s*Settings\[Char\.name\]\['[^']+'\]\s*\|\|\s*(.+?)\s*$/i)
      next unless match

      raw = match[2].strip
      value =
        if raw =~ /\A"(.*)"\z/
          Regexp.last_match(1)
        elsif raw =~ /\A-?\d+\z/
          raw.to_i
        else
          raw
        end
      result[match[1]] = value
    end
    result
  rescue => error
    respond "Ashborne GUI could not read defaults: #{error.message}"
    {}
  end

  def settings_root
    Lich::Common::Settings.current_script_settings(":", script_name: "ashborne")
  end

  def character_settings(root)
    root[Char.name] || root[Char.name.to_s] || root[Char.name.to_sym] || {}
  end

  def character_key(root)
    return Char.name if root.key?(Char.name)
    return Char.name.to_s if root.key?(Char.name.to_s)
    return Char.name.to_sym if root.key?(Char.name.to_sym)

    Char.name
  end

  def friendly_name(key)
    key.sub(/\Aashborne_setting_/, "")
      .split("_")
      .map { |word| word =~ /\A\d+\z/ ? word : word.capitalize }
      .join(" ")
      .gsub(/\bCman\b/, "Combat Maneuvers")
      .gsub(/\bNo\b/, "Disable")
  end

  def tooltip_for(key)
    return TOOLTIPS[key] if TOOLTIPS.key?(key)

    name = friendly_name(key)
    explanation =
      if key.include?("upkeep")
        "Keeps the named spell or effect active when the character knows and can use it."
      elsif key.include?("disable") || key.include?("_no_") || key.include?("no")
        "An advanced override that disables the named Ashborne behavior."
      elsif key.include?("bounty")
        "Controls how Ashborne handles the named bounty behavior."
      elsif key.include?("group")
        "Controls the named behavior while Ashborne is operating as a group."
      elsif key.include?("script")
        "Names a Lich script Ashborne may start or stop during its hunting workflow."
      elsif key.include?("spell")
        "Controls the named spell behavior. Ashborne still verifies that the character can use it."
      else
        "Advanced Ashborne behavior. Keep the current value unless you understand the named feature."
      end
    "#{name}\n\n#{explanation}"
  end

  def save(root, settings)
    root[character_key(root)] = settings
    Lich::Common::Settings.save_to_database(root, ":", script_name: "ashborne")
  end

  def ability_rules_file
    safe_name = Char.name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    data_file("#{safe_name}_ashborne_ability_rules.yml")
  end

  def capability_profile
    safe_name = Char.name.to_s.gsub(/[^A-Za-z0-9_\-]/, "")
    path = data_file("#{safe_name}_ashborne_capabilities.yml")
    File.exist?(path) ? (YAML.load_file(path) || {}) : {}
  rescue
    {}
  end

  def data_directory
    path = File.join($lich_dir, "data", "ashborne")
    FileUtils.mkdir_p(path) unless File.directory?(path)
    path
  end

  def data_file(filename)
    target = File.join(data_directory, filename)
    legacy = File.join($lich_dir, "scripts", filename)
    FileUtils.mv(legacy, target) if !File.exist?(target) && File.exist?(legacy)
    target
  rescue
    target || File.join($lich_dir, "data", "ashborne", filename)
  end

  def default_ability_rule(label, minimum = 3)
    {
      "label" => label,
      "enabled" => true,
      "min_targets" => minimum,
      "max_targets" => 0,
      "only_creatures" => [],
      "never_creatures" => []
    }
  end

  def load_ability_rules
    saved = File.exist?(ability_rules_file) ? (YAML.load_file(ability_rules_file) || {}) : {}
    saved["version"] = 1
    saved["crowd_control"] = {
      "enabled" => true,
      "min_targets" => 3,
      "max_targets" => 0
    }.merge(saved["crowd_control"] || {})
    saved["abilities"] ||= {}

    profile = capability_profile
    known_spells = Array(profile["known_spells"]).map(&:to_i)
    spells = known_spells.empty? ? ABILITY_CATALOG.keys : known_spells & ABILITY_CATALOG.keys
    spells.each do |spell_num|
      minimum = [210, 214, 301, 1602].include?(spell_num) ? 1 : 3
      key = "spell:#{spell_num}"
      saved["abilities"][key] = default_ability_rule(
        "#{ABILITY_CATALOG[spell_num]} (#{spell_num})",
        minimum
      ).merge(saved["abilities"][key] || {})
    end

    Array(profile["anti_caster_abilities"]).each do |ability|
      next if ability["family"].to_s == "spell"

      key = "#{ability['family']}:#{ability['id'].to_s.downcase.gsub(/\s+/, '')}"
      saved["abilities"][key] = default_ability_rule(ability["name"].to_s, 1)
        .merge(saved["abilities"][key] || {})
    end
    saved
  rescue => error
    respond "Ashborne GUI could not read ability rules: #{error.message}"
    { "version" => 1, "crowd_control" => { "enabled" => true, "min_targets" => 3, "max_targets" => 0 }, "abilities" => {} }
  end

  def save_ability_rules(rules)
    temporary = "#{ability_rules_file}.tmp"
    File.write(temporary, rules.to_yaml)
    FileUtils.mv(temporary, ability_rules_file)
  end

  def name_list(value)
    Array(value).join(", ")
  end

  def combo(options, current)
    widget = Gtk::ComboBoxText.new
    options.each { |_value, label| widget.append_text(label) }
    index = options.index { |value, _label| value.to_s == current.to_s } || 0
    widget.active = index
    [widget, proc { options[widget.active || 0][0] }]
  end

  def check(label, current, inverted = false)
    widget = Gtk::CheckButton.new(label)
    enabled = current.to_s != "0"
    widget.active = inverted ? !enabled : enabled
    getter = proc do
      active = widget.active?
      active = !active if inverted
      active ? "1" : "0"
    end
    [widget, getter]
  end

  def boolean_setting?(key, default_value)
    return false if NON_BOOLEAN_ZERO_DEFAULT_SETTINGS.include?(key)

    %w[0 1].include?(default_value.to_s)
  end

  def entry(current, width = 220)
    widget = Gtk::Entry.new
    widget.text = current.to_s
    widget.width_request = width
    [widget, proc { widget.text.to_s.strip.empty? ? "0" : widget.text.to_s.strip }]
  end

  def spin(current, minimum, maximum)
    adjustment = Gtk::Adjustment.new(current.to_f, minimum, maximum, 1, 5, 0)
    widget = Gtk::SpinButton.new(adjustment, 1, 0)
    [widget, proc { widget.value.to_i }]
  end

  def add_row(box, label_text, widget, tooltip)
    row = Gtk::Box.new(:horizontal, 8)
    label = Gtk::Label.new(label_text)
    label.width_request = 300
    label.xalign = 0
    label.set_tooltip_text(tooltip)
    widget.set_tooltip_text(tooltip)
    row.pack_start(label, expand: false, fill: false, padding: 4)
    row.pack_start(widget, expand: true, fill: true, padding: 4)
    box.pack_start(row, expand: false, fill: false, padding: 2)
  end

  def page
    outer = Gtk::ScrolledWindow.new
    outer.set_policy(:automatic, :automatic)
    box = Gtk::Box.new(:vertical, 4)
    box.border_width = 12
    outer.add_with_viewport(box)
    [outer, box]
  end

  def heading(box, title, text)
    title_label = Gtk::Label.new
    title_label.set_markup("<b>#{title}</b>")
    title_label.xalign = 0
    text_label = Gtk::Label.new(text)
    text_label.xalign = 0
    text_label.wrap = true
    box.pack_start(title_label, expand: false, fill: false, padding: 4)
    box.pack_start(text_label, expand: false, fill: false, padding: 4)
  end

  def run
    unless defined?(Gtk) && Gtk.const_defined?(:Version) && Gtk::Version::MAJOR == 3
      respond "Ashborne GUI requires the GTK3 Lich client."
      return
    end

    root = settings_root
    root = {} unless root.is_a?(Hash)
    default_settings = defaults
    settings = default_settings.merge(character_settings(root))
    ability_rules = load_ability_rules
    bindings = {}
    ability_bindings = {}
    action = nil
    window = nil

    Gtk.queue do
      window = Gtk::Window.new
      window.title = "Ashborne Setup - #{Char.name}"
      window.set_default_size(940, 720)
      window.border_width = 8

      notebook = Gtk::Notebook.new

      quick_page, quick = page
      heading(
        quick,
        "Start Here",
        "Choose how this character fights. Two-weapon combat is part of melee style 3 or stealth melee style 4; it does not need a separate style."
      )

      style, getter = combo(STYLE_OPTIONS, settings["ashborne_setting_group_style"])
      bindings["ashborne_setting_group_style"] = getter
      add_row(quick, "Group combat style", style, tooltip_for("ashborne_setting_group_style"))

      account_tool, getter = combo([["borg", "Borg / Queen / Drone"], ["thunder", "Thunder / Struck"]], settings["ashborne_setting_multi_account_tool"])
      bindings["ashborne_setting_multi_account_tool"] = getter
      add_row(quick, "Multi-account command tool", account_tool, tooltip_for("ashborne_setting_multi_account_tool"))

      spell, getter = entry(settings["ashborne_setting_spell_default"])
      bindings["ashborne_setting_spell_default"] = getter
      add_row(quick, "Optional custom spell rotation", spell, tooltip_for("ashborne_setting_spell_default"))

      loot, getter = entry(settings["ashborne_setting_loot_script"])
      bindings["ashborne_setting_loot_script"] = getter
      add_row(quick, "Loot script", loot, tooltip_for("ashborne_setting_loot_script"))

      rest, getter = entry(settings["ashborne_setting_rest_room"])
      bindings["ashborne_setting_rest_room"] = getter
      add_row(quick, "Resting room number", rest, tooltip_for("ashborne_setting_rest_room"))

      cycles, getter = spin(settings["ashborne_setting_hunt_cycles"], 1, 25)
      bindings["ashborne_setting_hunt_cycles"] = getter
      add_row(quick, "Total hunts to run", cycles, tooltip_for("ashborne_setting_hunt_cycles"))

      rest_mind, getter = spin(settings["ashborne_setting_rest_mind"], 0, 100)
      bindings["ashborne_setting_rest_mind"] = getter
      add_row(quick, "Repeat when mind reaches %", rest_mind, tooltip_for("ashborne_setting_rest_mind"))

      rest_healing, getter = check("Heal while resting", settings["ashborne_setting_rest_healing"])
      bindings["ashborne_setting_rest_healing"] = getter
      add_row(quick, "Heal while resting", rest_healing, tooltip_for("ashborne_setting_rest_healing"))

      ask_empath, getter = check("Ask a visible empath for healing", settings["ashborne_setting_rest_ask_empath"])
      bindings["ashborne_setting_rest_ask_empath"] = getter
      add_row(quick, "Ask visible empath", ask_empath, tooltip_for("ashborne_setting_rest_ask_empath"))

      rest_sell, getter = check("Sell after resting", settings["ashborne_setting_rest_sell"])
      bindings["ashborne_setting_rest_sell"] = getter
      add_row(quick, "Sell after resting", rest_sell, tooltip_for("ashborne_setting_rest_sell"))

      notebook.append_page(quick_page, Gtk::Label.new("Start Here"))

      group_page, group = page
      heading(
        group,
        "Group Setup",
        "Enter exact character names. Unused member boxes should contain 0.\n\n" \
        "REQUIRED FOR GROUP MODE: Choose the same multi-account command tool on every character. For Borg, start borg.rb once and run ;drone everywhere. For Thunder, run ;thunder on the leader and ;struck on each follower using the same port.\n\n" \
        "Ashborne coordination uses the selected local command tool and local data files, not group whispers or ;chat. Direct whispers to an empath remain available when healing requests are enabled."
      )

      leader, getter = entry(settings["ashborne_setting_leader"])
      bindings["ashborne_setting_leader"] = getter
      add_row(group, "Group leader", leader, tooltip_for("ashborne_setting_leader"))

      1.upto(9) do |number|
        key = "ashborne_setting_group_#{%w[zero one two three four five six seven eight nine][number]}"
        member, member_getter = entry(settings[key])
        bindings[key] = member_getter
        add_row(group, "Follower #{number}", member, "Exact character name for follower #{number}. Use 0 when this slot is unused.")
      end

      additional_members, getter = entry(settings["ashborne_setting_group_additional"], 420)
      bindings["ashborne_setting_group_additional"] = getter
      add_row(group, "Additional followers", additional_members, tooltip_for("ashborne_setting_group_additional"))

      health, getter = spin(settings["ashborne_setting_health_floor"], 1, 100)
      bindings["ashborne_setting_health_floor"] = getter
      add_row(group, "Return-to-town health %", health, tooltip_for("ashborne_setting_health_floor"))

      mana, getter = spin(settings["ashborne_setting_mana_reserve"], 0, 95)
      bindings["ashborne_setting_mana_reserve"] = getter
      add_row(group, "General mana reserve %", mana, tooltip_for("ashborne_setting_mana_reserve"))

      stamina, getter = spin(settings["ashborne_setting_stamina_reserve"], 0, 95)
      bindings["ashborne_setting_stamina_reserve"] = getter
      add_row(group, "General stamina reserve %", stamina, tooltip_for("ashborne_setting_stamina_reserve"))

      rotation, getter = check("Rotate group looter", settings["ashborne_setting_loot_rotation"])
      bindings["ashborne_setting_loot_rotation"] = getter
      add_row(group, "Rotate group looter", rotation, tooltip_for("ashborne_setting_loot_rotation"))

      preferred, getter = entry(settings["ashborne_setting_preferred_looter"])
      bindings["ashborne_setting_preferred_looter"] = getter
      add_row(group, "Preferred looter", preferred, tooltip_for("ashborne_setting_preferred_looter"))

      eligible, getter = entry(settings["ashborne_setting_eligible_looters"])
      bindings["ashborne_setting_eligible_looters"] = getter
      add_row(group, "Eligible looters", eligible, tooltip_for("ashborne_setting_eligible_looters"))

      handoff, getter = spin(settings["ashborne_setting_loot_handoff"], 1, 100)
      bindings["ashborne_setting_loot_handoff"] = getter
      add_row(group, "Loot handoff meter value", handoff, tooltip_for("ashborne_setting_loot_handoff"))

      emergency, getter = spin(settings["ashborne_setting_loot_emergency"], 2, 100)
      bindings["ashborne_setting_loot_emergency"] = getter
      add_row(group, "Emergency encumbrance meter", emergency, tooltip_for("ashborne_setting_loot_emergency"))

      [
        ["ashborne_setting_preflight", "Run safety preflight"],
        ["ashborne_setting_job_coordinator", "Coordinate group jobs"],
        ["ashborne_setting_anti_caster", "React to creature spellcasting"],
        ["ashborne_setting_group_sharemana", "Share mana"],
        ["ashborne_setting_group_quiet", "Quiet follower reports"],
        ["ashborne_setting_group_peace", "Peaceful follower, no attacks"],
        ["ashborne_setting_group_noise", "Allow Bard Song of Noise"],
        ["ashborne_setting_noise_lockdown", "Permanent Song of Noise melee lockdown"]
      ].each do |key, label|
        widget, widget_getter = check(label, settings[key])
        bindings[key] = widget_getter
        add_row(group, label, widget, tooltip_for(key))
      end

      reserve, getter = spin(settings["ashborne_setting_anti_caster_mana"], 0, 95)
      bindings["ashborne_setting_anti_caster_mana"] = getter
      add_row(group, "Emergency spell mana reserve %", reserve, tooltip_for("ashborne_setting_anti_caster_mana"))

      role_options = ROLE_OPTIONS.map { |role| [role, role.capitalize] }
      role, getter = combo(role_options, settings["ashborne_setting_role"])
      bindings["ashborne_setting_role"] = getter
      add_row(group, "Preferred group job", role, tooltip_for("ashborne_setting_role"))

      notebook.append_page(group_page, Gtk::Label.new("Group & Safety"))

      combat_page, combat = page
      heading(combat, "Combat Options", "These switches refine the selected style. Leave unfamiliar options at their defaults.")

      [
        ["ashborne_setting_huntpro_spell_baseline", "Use complete HuntPro casting cycle", false],
        ["ashborne_setting_crowd_control", "Use crowd control", false],
        ["ashborne_setting_cman_control", "Use Combat Maneuvers", false],
        ["ashborne_setting_no_shield_control", "Disable Shield abilities", false],
        ["ashborne_setting_no_weapon_control", "Disable Weapon abilities", false],
        ["ashborne_setting_no_mstrike_control", "Disable MSTRIKE", false],
        ["ashborne_setting_use_empty", "Caster uses empty hands", false],
        ["ashborne_setting_stay_offensive", "Remain in offensive stance", false],
        ["ashborne_setting_combat_cleanup", "Run cleanup after hunting", false],
        ["ashborne_setting_spell_learning", "Learn from manually cast spells", false],
        ["ashborne_setting_style9_arcaneblast", "Allow Arcane Blast (1700)", false],
        ["ashborne_setting_use_herbs", "Use combat herbs everywhere", false],
        ["ashborne_setting_no_herbs", "Never use combat herbs", false]
      ].each do |key, label, inverted|
        widget, widget_getter = check(label, settings[key], inverted)
        bindings[key] = widget_getter
        add_row(combat, label, widget, tooltip_for(key))
      end

      flee, getter = spin(settings["ashborne_setting_flee"], 0, 25)
      bindings["ashborne_setting_flee"] = getter
      add_row(combat, "Flee above this creature count", flee, tooltip_for("ashborne_setting_flee"))

      mana_leech, getter = spin(settings["ashborne_setting_mana_leech_percent"], 1, 100)
      bindings["ashborne_setting_mana_leech_percent"] = getter
      add_row(combat, "Cast Mana Leech at or below %", mana_leech, tooltip_for("ashborne_setting_mana_leech_percent"))

      notebook.append_page(combat_page, Gtk::Label.new("Combat"))

      abilities_page, abilities = page
      heading(
        abilities,
        "Abilities & Rules",
        "Enable only the spells and combat abilities this character may use. Minimum creatures prevents expensive control on small fights. Creature names are comma-separated partial matches."
      )

      crowd_enabled, crowd_enabled_getter = check(
        "Enable crowd control",
        ability_rules.dig("crowd_control", "enabled") == false ? "0" : "1"
      )
      ability_bindings["crowd_control.enabled"] = crowd_enabled_getter
      add_row(abilities, "Crowd control master switch", crowd_enabled, "Controls Ashborne's custom crowd-control rules. Turn off the complete HuntPro casting cycle on the Combat page before using this switch to filter HuntPro's built-in spell routine.")

      crowd_min, crowd_min_getter = spin(ability_rules.dig("crowd_control", "min_targets") || 3, 1, 25)
      ability_bindings["crowd_control.min_targets"] = crowd_min_getter
      add_row(abilities, "Default minimum creatures", crowd_min, "Ashborne will not enter its crowd-control routine below this number. Use 4, 5, or 6 for more conservative casting.")

      ability_rules["abilities"].sort_by { |_key, rule| rule["label"].to_s }.each do |key, rule|
        separator = Gtk::Separator.new(:horizontal)
        abilities.pack_start(separator, expand: false, fill: false, padding: 5)

        enabled, enabled_getter = check("Allow #{rule['label']}", rule["enabled"] == false ? "0" : "1")
        ability_bindings["#{key}.enabled"] = enabled_getter
        add_row(abilities, rule["label"], enabled, "Turn this off to prevent Ashborne from selecting this ability anywhere its rule gate is used.")

        minimum, minimum_getter = spin(rule["min_targets"] || 1, 1, 25)
        ability_bindings["#{key}.min_targets"] = minimum_getter
        add_row(abilities, "  Minimum creatures", minimum, "Required number of live creatures in the room before this ability is allowed.")

        only, only_getter = entry(name_list(rule["only_creatures"]), 360)
        ability_bindings["#{key}.only_creatures"] = only_getter
        add_row(abilities, "  Only use against", only, "Optional comma-separated creature names. Example: greater construct, Ithzir seer. Blank means any creature.")

        never, never_getter = entry(name_list(rule["never_creatures"]), 360)
        ability_bindings["#{key}.never_creatures"] = never_getter
        add_row(abilities, "  Never use against", never, "Optional comma-separated creature names that block this ability.")
      end
      notebook.append_page(abilities_page, Gtk::Label.new("Abilities & Rules"))

      advanced_page, advanced = page
      heading(
        advanced,
        "Advanced Options",
        "Every remaining Ashborne setting appears here. On/off flags use checkboxes; settings that require a name, number, stance, container, or other value keep an editable field."
      )

      settings.keys.grep(/\Aashborne_setting_/).sort.each do |key|
        next if bindings.key?(key)
        next if key == "ashborne_setting_no_2weapon_control"
        next if key == "ashborne_setting_use_shield"

        widget, getter =
          if boolean_setting?(key, default_settings[key])
            check(friendly_name(key), settings[key])
          else
            entry(settings[key], 260)
          end
        bindings[key] = getter
        add_row(advanced, friendly_name(key), widget, tooltip_for(key))
      end
      notebook.append_page(advanced_page, Gtk::Label.new("All Advanced Options"))

      save_button = Gtk::Button.new(label: "Save & Close")
      cancel_button = Gtk::Button.new(label: "Cancel")
      save_button.set_tooltip_text("Save every option shown in this window to this character's Ashborne settings.")
      cancel_button.set_tooltip_text("Close without changing Ashborne settings.")
      save_button.signal_connect("clicked") { action = :save }
      cancel_button.signal_connect("clicked") { action = :cancel }
      window.signal_connect("delete-event") { action = :cancel }

      buttons = Gtk::Box.new(:horizontal, 8)
      buttons.pack_end(cancel_button, expand: false, fill: false, padding: 4)
      buttons.pack_end(save_button, expand: false, fill: false, padding: 4)

      layout = Gtk::Box.new(:vertical, 8)
      layout.pack_start(notebook, expand: true, fill: true, padding: 0)
      layout.pack_start(buttons, expand: false, fill: false, padding: 0)
      window.add(layout)
      window.show_all
      window.keep_above = true
    end

    wait_while { action.nil? }
    if action == :save
      bindings.each { |key, getter| settings[key] = getter.call }
      ability_bindings.each do |path, getter|
        value = getter.call
        if path.start_with?("crowd_control.")
          ability_rules["crowd_control"][path.split(".", 2)[1]] =
            path.end_with?(".enabled") ? value.to_s != "0" : value
          next
        end

        key, field = path.split(".", 2)
        ability_rules["abilities"][key] ||= {}
        ability_rules["abilities"][key][field] =
          case field
          when "enabled"
            value.to_s != "0"
          when "only_creatures", "never_creatures"
            value.to_s.split(",").map(&:strip).reject(&:empty?)
          else
            value
          end
      end
      save(root, settings)
      save_ability_rules(ability_rules)
      respond "Ashborne GUI saved settings for #{Char.name}."
    else
      respond "Ashborne GUI closed without saving."
    end
  ensure
    Gtk.queue { window.destroy if window } if defined?(Gtk)
  end
end
# END EMBEDDED ASHBORNE GUI

