  def safe_room_default
    medical_reason = Ashborne_toolkit.personal_medical_retreat_reason
    if medical_reason
      $ashborne_group_danger_active = "1"
      $ashborne_return_why = "Medical retreat: #{medical_reason}." unless $ashborne_return_why.to_s =~ /medical retreat|injury|bleeding|low health|critical health/i
    end

    emergency_retreat = $ashborne_group_danger_active == "1" || Ashborne_toolkit.medical_retreat_reason? || !GameObj.targets.empty?
    if $ashborne_group_ai == "1"
      unless emergency_retreat
        Ashborne_toolkit.group_wait_for_loot_to_settle(8)
        until Ashborne_toolkit.group_wait_for_followers_to_move(5)
          Ashborne_toolkit.defend_while_waiting_for_group
          unless GameObj.targets.empty?
            Ashborne_toolkit.stance_defensive
            respond "Ashborne will not leave visible followers behind while combat is active."
          end
        end
      end
      return false unless Ashborne_toolkit.movement_guard
    end
    Ashborne_toolkit.unhide_before_group_travel("safe return")
    return false unless Ashborne_toolkit.travel_departure_ready?(emergency_retreat ? "emergency retreat" : "safe return")

    if $ashborne_my_area =~ /moonmagru/
      fput "move clear"
    end
    Ashborne_toolkit.loot_script("#{$ashborne_loot_script}")
    if $ashborne_rest_room != "0"
      do_client ";go2 #{$ashborne_rest_room}"
      Ashborne_toolkit.unpause_go2
      wait_while { running? "go2" }
      Ashborne_toolkit.top_menu
      respond "I am at your preferred resting room because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return

    elsif $ashborne_my_area =~ /moonmonastery|moonfigure|moonbeetle|moonmagru|moonmyklian|moonvortece|moonvruul/
      Script.run('go2', '6505')
      Ashborne_toolkit.top_menu
      respond "I am at this node because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return

    elsif $ashborne_my_area =~ /wlzombie/
      Script.run('go2', '228')
      Ashborne_toolkit.top_menu
      respond "I am at this supernode because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return



    elsif checkarea =~ /The Rift|Breach|Heated Sands|Horde|Birthing Sands/

      Script.run('go2', '2635')
      Ashborne_toolkit.top_menu
      respond "I am at this supernode because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return

    elsif checkarea =~ /Minion Quarters|Dark\-One\'s Keep/

      Script.run('go2', '4195')
      Ashborne_toolkit.top_menu
      respond "I am at this node because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return

    elsif checkarea =~ /Wormwood Slough|Graveyard|Slither Creek|Hall of the Dead|Underbarrow|Under Crypt|Narrow Tunnel|Secluded Valley|A Dark Shaft|Mine Shaft|Mine Tunnels|Shadow Valley|Dark Pasture|Shadow Plain/

      Script.run('go2', '4142')
      Ashborne_toolkit.top_menu
      respond "I am at this node because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return

    elsif checkarea =~ /Melgorehn\'s Valley/

      Script.run('go2', '3600')
      Ashborne_toolkit.top_menu
      respond "I am at this supernode because: #{$ashborne_return_why}"
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.finish_safe_return

    else

      do_client ";go supernode"
      Ashborne_toolkit.unpause_go2
      wait_while { running? "go2" }
      if Ashborne_toolkit.current_room_id == 3807 || checkarea == "Land Tower East"
        Script.run('go2', 'town')
        Ashborne_toolkit.top_menu
        respond "I am at this supernode because: #{$ashborne_return_why}"
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.finish_safe_return
      elsif Ashborne_toolkit.current_room_id == 28719 || checkarea == "Fat Jahck's"
        Script.run('go2', 'town')
        Ashborne_toolkit.top_menu
        respond "I am at this supernode because: #{$ashborne_return_why}"
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.finish_safe_return
      elsif Ashborne_toolkit.current_room_id == 2400
        Script.run('go2', 'town')
        Ashborne_toolkit.top_menu
        respond "I am at this supernode because: #{$ashborne_return_why}"
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.finish_safe_return
      elsif Ashborne_toolkit.current_room_id == 28717
        Script.run('go2', 'town')
        Ashborne_toolkit.top_menu
        respond "I am at this supernode because: #{$ashborne_return_why}"
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.finish_safe_return
      else
        Ashborne_toolkit.top_menu
        respond "I am at this supernode because: #{$ashborne_return_why}"
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.finish_safe_return
      end
    end
  end

  def unpause_go2
    last_unpause = 0
    while Script.running?("go2")
      paused = begin
        Script.respond_to?(:paused?) && Script.paused?("go2")
      rescue
        false
      end

      if paused || Time.now.to_f - last_unpause.to_f >= 3.0
        do_client ";unpause"
        do_client ";ua"
        last_unpause = Time.now.to_f
      end

      sleep 0.25
    end
    true
  rescue => error
    respond "go2 unpause warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def waitroundtime
    waitrt?
  end

  def waitcast_waitrt
    waitrt?
    waitcastrt?
  end

  def current_target_valid?
    target_id = XMLData.current_target_id.to_s rescue ""
    return !GameObj.targets.empty? if target_id.empty? || target_id == "0"

    GameObj.targets.any? { |target| target.id.to_s == target_id && !Ashborne_toolkit.environmental_hazard_target?(target) }
  rescue
    !GameObj.targets.empty?
  end

  def ensure_fresh_attack_target
    return false if Ashborne_toolkit.environmental_danger_retreat_if_needed
    return false if Ashborne_toolkit.medical_retreat_if_needed
    return false if GameObj.targets.empty?
    return true if Ashborne_toolkit.current_target_valid?

    Ashborne_toolkit.target_check
    sleep 0.05
    Ashborne_toolkit.current_target_valid?
  rescue
    false
  end

  def uac_round
    # respond "Debug Output - Starting UAC Round"
    if GameObj.targets.length >= 1
      return unless Ashborne_toolkit.enforce_uac_empty_hands
      unless Ashborne_toolkit.ensure_fresh_attack_target
        Ashborne_toolkit.stance_defensive
        return false
      end

      if $ashborne_uac_current_attack == 0
        $ashborne_uac_current_attack = "jab"
      elsif $ashborne_uac_current_attack == nil
        $ashborne_uac_current_attack = "jab"
      end

      Ashborne_toolkit.stance_offensive
      unless Ashborne_toolkit.ensure_fresh_attack_target
        Ashborne_toolkit.stance_defensive
        return false
      end

      result = dothistimeout "#{$ashborne_uac_current_attack}", 2, /excellent positioning|followup jab|followup punch|followup grapple|followup kick|Roundtime/
      if result =~ /excellent positioning/
        if Stats.prof == "Bard"
          $ashborne_uac_current_attack = "punch"
        else
          $ashborne_uac_current_attack = "kick"
        end

      elsif result =~ /followup jab/
        $ashborne_uac_current_attack = "jab"

      elsif result =~ /followup punch/
        $ashborne_uac_current_attack = "punch"

      elsif result =~ /followup grapple/
        $ashborne_uac_current_attack = "grapple"

      elsif result =~ /followup kick/
        $ashborne_uac_current_attack = "kick"

      elsif result =~ /Roundtime/
        $ashborne_uac_current_attack = "jab"
      end
    else
      nil
    end

    # respond "Debug Output - Ending UAC Round"
  end

  def enforce_uac_empty_hands
    return true unless $ashborne_my_style == "1" || $ashborne_my_style == "2"

    waitrt?
    hands_report_empty = checkright.nil? && checkleft.nil?
    if $ashborne_uac_hands_verified.to_s != "1" || !hands_report_empty
      # Hand XML can lag immediately after GIRD. STOW ALL is authoritative and
      # prevents a newly drawn shield from slipping past a stale empty-hand read.
      fput "stow all"
      sleep 0.25
    end
    waitrt?

    empty = checkright.nil? && checkleft.nil?
    $ashborne_uac_hands_verified = empty ? "1" : "0"
    unless empty
      now = Time.now.to_i
      if now >= $ashborne_uac_hands_warning_at.to_s.to_i
        respond "Ashborne cannot begin UAC until both hands are empty."
        $ashborne_uac_hands_warning_at = now + 10
      end
      Ashborne_toolkit.stance_defensive
      Ashborne_toolkit.trigger_loot_storage_emergency
    end
    empty
  rescue => error
    respond "UAC hand check warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def mstrike_setup
    # Mstrike Detection

    if $ashborne_my_style == "1"
      fput "mstrike set recovery off"
      fput "mstrike set default jab"
    elsif $ashborne_my_style == "2"
      fput "mstrike set recovery off"
      fput "mstrike set default grapple"
    elsif $ashborne_my_style == "3"
      fput "mstrike set recovery off"
      fput "mstrike set default attack"
    elsif $ashborne_my_style == "4"
      fput "mstrike set recovery off"
      fput "mstrike set default attack"
    elsif $ashborne_my_style == "5"
      fput "mstrike set recovery off"
      fput "mstrike set default fire"
    elsif $ashborne_my_style == "6"
      fput "mstrike set recovery off"
      fput "mstrike set default fire"
    elsif $ashborne_my_style == "7"
      fput "mstrike set recovery off"
      fput "mstrike set default fire"
    elsif $ashborne_my_style == "8"
      fput "mstrike set recovery off"
      fput "mstrike set default fire"
    elsif $ashborne_my_style == "9"
      nil
    else
      nil
    end

    if Skills.multiopponentcombat >= 190
      $ashborne_my_mstrike_focus = 6
      $ashborne_my_mstrike_open = 7
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 155
      $ashborne_my_mstrike_focus = 5
      $ashborne_my_mstrike_open = 7
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 135
      $ashborne_my_mstrike_focus = 5
      $ashborne_my_mstrike_open = 6
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 100
      $ashborne_my_mstrike_focus = 4
      $ashborne_my_mstrike_open = 6
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 90
      $ashborne_my_mstrike_focus = 4
      $ashborne_my_mstrike_open = 5
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 60
      $ashborne_my_mstrike_focus = 3
      $ashborne_my_mstrike_open = 5
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 55
      $ashborne_my_mstrike_focus = 3
      $ashborne_my_mstrike_open = 4
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 35
      $ashborne_my_mstrike_focus = 2
      $ashborne_my_mstrike_open = 4
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 30
      $ashborne_my_mstrike_focus = 2
      $ashborne_my_mstrike_open = 3
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 15
      $ashborne_my_mstrike_focus = 0
      $ashborne_my_mstrike_open = 3
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    elsif Skills.multiopponentcombat >= 5
      $ashborne_my_mstrike_focus = 0
      $ashborne_my_mstrike_open = 2
      fput "mstrike set focus #{$ashborne_my_mstrike_focus}"
      fput "mstrike set open  #{$ashborne_my_mstrike_open}"
    end
  end

  def mstrike_routine
    # respond "Debug Output - Starting Mstrike/AOE Round"

    if $ashborne_disable_mstrike == "1"
      nil

    elsif Skills.multiopponentcombat >= 5
      if Spell.active? "9005"
        nil
      else
        if percentstamina >= 50
          if GameObj.targets.length >= 2 && $ashborne_my_mstrike_focus == 0 && $ashborne_my_mstrike_open >= 1
            Ashborne_toolkit.stance_offensive
            # respond "Debug Output - Open Mstrike"
            if percentstamina >= 50
              fput "mstrike"
              Ashborne_toolkit.mark_group_vulnerable
            end
          elsif GameObj.targets.length == 1 && $ashborne_my_mstrike_focus >= 1 && $ashborne_my_mstrike_open >= 1
            Ashborne_toolkit.stance_offensive
            # respond "Debug Output - Focus Mstrike"
            if percentstamina >= 50
              if Ashborne_toolkit.ensure_fresh_attack_target
                fput "mstrike target"
                Ashborne_toolkit.mark_group_vulnerable
              else
                Ashborne_toolkit.stance_defensive
              end
            end
          elsif GameObj.targets.length >= 2 && $ashborne_my_mstrike_focus >= 1 && $ashborne_my_mstrike_open >= 1
            Ashborne_toolkit.stance_offensive
            # respond "Debug Output - Open Mstrike, many in room but I know focus."
            if percentstamina >= 50
              fput "mstrike"
              Ashborne_toolkit.mark_group_vulnerable
            end
          end
        end
      end
    else
      nil
    end

    # respond "Debug Output - Ending Mstrike Round"
    waitrt?
  end

