ashborne_status_check = proc {
  Ashborne_toolkit.publish_group_state
  Ashborne_toolkit.clear_stale_wrong_equipment_return_if_combat_progress
  next if Ashborne_toolkit.medical_retreat_if_needed
  next if Ashborne_toolkit.critical_mana_retreat_if_needed
  next if Ashborne_toolkit.solo_swarm_retreat_if_needed
  Ashborne_toolkit.group_danger_status_check

  if $ashborne_style9_low_mana_return == "1" && GameObj.targets.empty?
    $ashborne_style9_blastround = "0"
    $ashborne_return_why ||= "You have low mana after finishing combat."
    $ashborne_action = 99 unless $ashborne_disable_mana == "1"
  end

  if !checkdead
    nil
  else
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, I'm very sorry, I see you died. If ;ashborne caused your death, please share this feedback."
    Ashborne_toolkit.bottom_menu
    exit
  end

  if checkmind == "must rest"
    if ashborne_setting_hunt_while_fried != "0"
      nil
    else
      if $ashborne_extra_fried <= 60
        $ashborne_extra_fried = $ashborne_extra_fried + 1
      elsif $ashborne_extra_fried >= 61
        $ashborne_return_why = "Your mind is full and you must rest."
        $ashborne_action = 99
      end
    end
  end

  if checkmind == "saturated"
    if ashborne_setting_hunt_while_fried != "0"
      nil
    else
      if $ashborne_extra_fried <= 60
        $ashborne_extra_fried = $ashborne_extra_fried + 1
      elsif $ashborne_extra_fried >= 61
        $ashborne_return_why = "Your mind is saturated and you must rest."
        $ashborne_action = 99
      end
    end
  end

  # Mana Traps
  if $ashborne_group_ai == "1"
    if percentmana >= 50
      nil

    elsif $ashborne_deedmana == "1" && $ashborne_deedmana_zonk == "0"
      Ashborne_toolkit.deed_mana
    elsif percentmana >= 25 && percentmana <= 49 && $ashborne_group_sharemana != "0"

      if $ashborne_mana_cooldown == 0
        $ashborne_mana_cooldown = 25
        $ashborne_group_mana_target = "#{Char.name}"
        Ashborne_toolkit.publish_group_state(true) unless $ashborne_disable_mana == "1"
        sleep 0.5
      elsif $ashborne_mana_cooldown > 0
        $ashborne_mana_cooldown = $ashborne_mana_cooldown - 1
      end
    end

    # Deedmana Goes here
    Ashborne_toolkit.deed_mana

    # Wrack Check Goes Here
    Ashborne_toolkit.wrack_checker if $ashborne_my_society == "Col" && percentmana <= 24

    # Wand Use Goes Here
    if $ashborne_use_wands == "0"

      if ashborne_setting_130_fog != "0" && Stats.level >= 30 && checkmana >= 30 && checkmana <= 41
        $ashborne_return_why = "You have low mana." unless $ashborne_disable_mana == "1"
        $ashborne_action = 99 unless $ashborne_disable_mana == "1"

      elsif percentmana <= 13
        if Ashborne_toolkit.style9_low_mana_finisher_available?
          Ashborne_toolkit.trigger_style9_low_mana_finisher
        else
          $ashborne_return_why = "You have low mana" unless $ashborne_disable_mana == "1"
          $ashborne_action = 99 unless $ashborne_disable_mana == "1"
        end

      # Group Mode Arcane Blast as Leader
      elsif $ashborne_style9_arcaneblast == "1"

        if Stats.level <= 2 && percentmana <= 25
          # respond "Debug Output - You'll use 1700 this round."
          $ashborne_style9_blastround = "1"
        elsif Stats.level <= 2 && percentmana > 25
          # respond "Debug Output - Resuming normal spell choices."
          $ashborne_style9_blastround = "0"
        elsif Stats.level >= 3 && percentmana <= 13
          # respond "Debug Output - You'll use 1700 this round."
          $ashborne_style9_blastround = "1"
        elsif Stats.level >= 3 && percentmana > 13
          # respond "Debug Output - Resuming normal spell choices."
          $ashborne_style9_blastround = "0"
        end
      end
    else
      if percentmana <= 30
        # Ashborne_toolkit.use_wands
        $ashborne_combat_wands = "1"
      elsif percentmana >= 31
        if checkleft == "wand"
          fput "put my wand in my #{Vars.wandsack}"
        elsif checkright == "wand"
          fput "put my wand in my #{Vars.wandsack}"
        elsif checkleft == "rod"
          fput "put my wand in my #{Vars.wandsack}"
        elsif checkright == "rod"
          fput "put my wand in my #{Vars.wandsack}"
        end
        $ashborne_combat_wands = "0"
      else
        nil
      end
    end
  else

    # Deedmana Goes here
    Ashborne_toolkit.deed_mana

    # Wrack Check Goes Here
    Ashborne_toolkit.wrack_checker if $ashborne_my_society == "Col" && percentmana <= 24

    # Wand Use Goes Here
    if $ashborne_use_wands == "0"

      # Style 9 Arcane Blast Toggles Go Here

      if ashborne_setting_130_fog != "0" && Stats.level >= 30 && checkmana >= 30 && checkmana <= 41
        $ashborne_return_why = "You have low mana." unless $ashborne_disable_mana == "1"
        $ashborne_action = 99 unless $ashborne_disable_mana == "1"

      elsif percentmana <= 13
        if Ashborne_toolkit.style9_low_mana_finisher_available?
          Ashborne_toolkit.trigger_style9_low_mana_finisher
        else
          $ashborne_return_why = "You have low mana." unless $ashborne_disable_mana == "1"
          $ashborne_action = 99 unless $ashborne_disable_mana == "1"
        end

      elsif $ashborne_style9_arcaneblast == "1"

        if Stats.level <= 2 && percentmana <= 25
          # respond "Debug Output - You'll use 1700 this round."
          $ashborne_style9_blastround = "1"
        elsif Stats.level <= 2 && percentmana > 25
          # respond "Debug Output - Resuming normal spell choices."
          $ashborne_style9_blastround = "0"
        elsif Stats.level >= 3 && percentmana <= 13
          # respond "Debug Output - You'll use 1700 this round."
          $ashborne_style9_blastround = "1"
        elsif Stats.level >= 3 && percentmana > 13
          # respond "Debug Output - Resuming normal spell choices."
          $ashborne_style9_blastround = "0"
        end
      end
    else
      if percentmana <= 30
        # Ashborne_toolkit.use_wands
        $ashborne_combat_wands = "1"
      elsif percentmana >= 31
        if checkleft == "wand"
          fput "put my wand in my #{Vars.lootsack}"
        elsif checkright == "wand"
          fput "put my wand in my #{Vars.lootsack}"
        elsif checkleft == "rod"
          fput "put my rod in my #{Vars.lootsack}"
        elsif checkright == "rod"
          fput "put my rod in my #{Vars.lootsack}"
        end
        $ashborne_combat_wands = "0"
      else
        nil
      end
    end
  end



  if percenthealth <= 50
    # respond "Debug - Health is less than 50"
    if $ashborne_group_ai == "1" && $ashborne_group_empath != "0"
      if $ashborne_heal_cooldown == 0
        $ashborne_heal_cooldown = 1
        fput "whisper #{$ashborne_group_empath} please heal us."
        $ashborne_return_why = "You have low health and need healing."
        $ashborne_action = 99
      elsif $ashborne_heal_cooldown == 1
        $ashborne_heal_cooldown = 0
      end
    else
      if Stats.prof == "Empath" && checkmana >= 10 && Spell[1101].known?
        fput "cure"
      elsif $ashborne_use_herbs == "1"
        $ashborne_heal_toggle = 1
        Ashborne_toolkit.combat_use_herbs
      else
        $ashborne_return_why = "You have low health."
        $ashborne_action = 99
      end
    end
  end

  if percentstamina <= $ashborne_value_stamina.to_i
    if ashborne_setting_disable_stamina != "0"
      nil
    else
      $ashborne_return_why = "You have low stamina."
      $ashborne_action = 99
    end

  end

  if percentspirit <= 10
    $ashborne_return_why = "You have low spirit."
    $ashborne_action = 99
  end

  if percentencumbrance >= $ashborne_value_encumbrance.to_i &&
      !Ashborne_toolkit.loot_rotation_enabled?
    if ashborne_setting_disable_encumbrance != "0"
      nil
    else
      $ashborne_return_why = "You have encumbrance."
      $ashborne_action = 99
    end
  end



  if ashborne_setting_empath_self_heal != "0" && Stats.prof == "Empath"
    if Wounds.head >= 1 || Wounds.neck >= 1 || Wounds.abs >= 1 || Wounds.lhand >= 1 || Wounds.rhand >= 1 || Wounds.larm >= 1 || Wounds.rarm >= 1 || Wounds.chest >= 1 || Wounds.back >= 1 || Wounds.rleg >= 1 || Wounds.lleg >= 1 || Wounds.nerves >= 1 || Wounds.torso >= 1 || Wounds.leye >= 1 || Wounds.reye >= 1 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      Ashborne_toolkit.empath_self_heal
    end
  elsif $ashborne_empath_self_heal == "1" && Stats.prof == "Empath"
    if Wounds.head >= 1 || Wounds.neck >= 1 || Wounds.abs >= 1 || Wounds.lhand >= 1 || Wounds.rhand >= 1 || Wounds.larm >= 1 || Wounds.rarm >= 1 || Wounds.chest >= 1 || Wounds.back >= 1 || Wounds.rleg >= 1 || Wounds.lleg >= 1 || Wounds.nerves >= 1 || Wounds.torso >= 1 || Wounds.leye >= 1 || Wounds.reye >= 1 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      Ashborne_toolkit.empath_self_heal
    end
  end


  if $ashborne_heal_toggle == 0
    sleep 0.05
    # respond "Debug Output - I'm in heal toggle 0"
    if Wounds.head >= 2 || Wounds.neck >= 2 || Wounds.abs >= 2 || Wounds.lhand >= 2 || Wounds.rhand >= 2 || Wounds.larm >= 2 || Wounds.rarm >= 2 || Wounds.chest >= 2 || Wounds.back >= 2 || Wounds.rleg >= 2 || Wounds.lleg >= 2 || Wounds.nerves >= 2 || Wounds.torso >= 2 || Wounds.leye >= 2 || Wounds.reye >= 2 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2

      if $ashborne_group_ai == "1" && $ashborne_group_empath != "0"
        if $ashborne_heal_cooldown == 0
          $ashborne_heal_cooldown = 1
          fput "whisper #{$ashborne_group_empath} please heal us."
          $ashborne_return_why = "You are injured and need healing."
          $ashborne_action = 99
        elsif $ashborne_heal_cooldown == 1
          $ashborne_heal_cooldown = 0
        end

      elsif $ashborne_use_herbs == "1"
        $ashborne_heal_toggle = 1
        # respond "Debug Output - I'm about to use some herbs."
        Ashborne_toolkit.combat_use_herbs


      else
        sleep 0.10

        if Wounds.head >= 2 || Wounds.neck >= 2 || Wounds.abs >= 2 || Wounds.lhand >= 2 || Wounds.rhand >= 2 || Wounds.larm >= 2 || Wounds.rarm >= 2 || Wounds.chest >= 2 || Wounds.back >= 2 || Wounds.rleg >= 2 || Wounds.lleg >= 2 || Wounds.nerves >= 2 || Wounds.torso >= 2 || Wounds.leye >= 2 || Wounds.reye >= 2 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
          $ashborne_return_why = "You are injured or have major scars."
          $ashborne_action = 99
        end
      end
    end

  elsif $ashborne_heal_toggle == 1
    sleep 0.05
    # respond "Debug Output - I'm in heal toggle 1"
    $ashborne_heal_toggle = 0
    if Wounds.head >= 2 || Wounds.neck >= 2 || Wounds.abs >= 2 || Wounds.lhand >= 2 || Wounds.rhand >= 2 || Wounds.larm >= 2 || Wounds.rarm >= 2 || Wounds.chest >= 2 || Wounds.back >= 2 || Wounds.rleg >= 2 || Wounds.lleg >= 2 || Wounds.nerves >= 2 || Wounds.torso >= 2 || Wounds.leye >= 2 || Wounds.reye >= 2 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      $ashborne_return_why = "You are injured or have major scars."
      $ashborne_action = 99
    end
  end






  if checkstunned

    # Only Warriors
    if $ashborne_cman_berserk == "1"
      if percentstamina >= 50
        waitrt?
        fput "berserk" unless $ashborne_no_berserk == "1"
        sleep 2
      else
        $ashborne_return_why = "You were stunned and I chose to run away so you could fight another day." unless $ashborne_no_stun == "1"
        $ashborne_action = 99 unless $ashborne_no_stun == "1"
      end
    else
      $ashborne_return_why = "You were stunned and I chose to run away so you could fight another day." unless $ashborne_no_stun == "1"
      $ashborne_action = 99 unless $ashborne_no_stun == "1"
    end
  end

  if checkwebbed
    $ashborne_return_why = "You were webbed and I chose to run away so you could fight another day."
    $ashborne_action = 99
  end

  if checkbound
    $ashborne_return_why = "You were bound and I chose to run away so you could fight another day."
    $ashborne_action = 99
  end

  if checkpoison
    if Spell[114].known? && Stats.level >= 14 && Spell[114].affordable?
      waitcastrt?
      Spell[114].cast()
      sleep 3
    else
      $ashborne_return_why = "You were poisoned."
      $ashborne_action = 99
    end
  end

  if checkdisease
    if Spell[113].known? && Stats.level >= 13 && Spell[113].affordable?
      waitcastrt?
      Spell[113].cast()
      sleep 3
    else
      $ashborne_return_why = "You were diseased."
      $ashborne_action = 99
    end
  end

  if checkprone
    fput "stand"
  end

  $ashborne_heal_toggle = 0 if Wounds.head <= 1 && Wounds.neck <= 1 && Wounds.abs <= 1 && Wounds.lhand <= 1 && Wounds.rhand <= 1 && Wounds.larm <= 1 && Wounds.rarm <= 1 && Wounds.chest <= 1 && Wounds.back <= 1 && Wounds.rleg <= 1 && Wounds.lleg <= 1 && Wounds.nerves <= 1 && Wounds.torso <= 1 && Wounds.leye <= 1 && Wounds.reye <= 1 && Scars.head <= 1 && Scars.neck <= 1 && Scars.abs <= 1 && Scars.lhand <= 1 && Scars.rhand <= 1 && Scars.larm <= 1 && Scars.rarm <= 1 && Scars.chest <= 1 && Scars.back <= 1 && Scars.rleg <= 1 && Scars.lleg <= 1 && Scars.nerves <= 1 && Scars.torso <= 1 && Scars.leye <= 1 && Scars.reye <= 1
}

ashborne_group_status_check = proc {
  Ashborne_toolkit.publish_group_state
  next if Ashborne_toolkit.medical_retreat_if_needed
  Ashborne_toolkit.group_danger_retreat_if_needed if Ashborne_toolkit.group_danger_status_check

  if $ashborne_group_quiet == "1"
    nil

  else
    if checkdead
      Ashborne_toolkit.publish_group_danger("dead")
      Script.kill "ashborne"
      exit
    end

    # Deedmana Goes here
    Ashborne_toolkit.deed_mana


    # Wrack Check Goes Here
    Ashborne_toolkit.wrack_checker if $ashborne_my_society == "Col" && percentmana <= 24

    if percentmana <= 10
      if $ashborne_use_wands == "0"

        Ashborne_toolkit.publish_group_danger("low mana") if $ashborne_group_sharemana != "0" unless $ashborne_disable_mana == "1"
        sleep 10 unless $ashborne_disable_mana == "1"
      else
        # Ashborne_toolkit.use_wands
        $ashborne_combat_wands = "1"
      end
    else
      $ashborne_combat_wands = "0"
    end







    if percentstamina <= $ashborne_value_stamina.to_i
      if ashborne_setting_disable_stamina != "0"
        nil
      else
        Ashborne_toolkit.publish_group_danger("low stamina")
        sleep 10
      end
    end

    if percentspirit <= 10
      Ashborne_toolkit.publish_group_danger("low spirit")
      sleep 10
    end

    if percentencumbrance >= $ashborne_value_encumbrance.to_i &&
        !Ashborne_toolkit.loot_rotation_enabled?
      if ashborne_setting_disable_encumbrance != "0"
        nil
      else
        Ashborne_toolkit.publish_group_danger("encumbered")
        sleep 10
      end
    end


    if checkstunned
      Ashborne_toolkit.publish_group_danger("stunned") unless $ashborne_no_stun == "1"
      sleep 10
    end

    if checkwebbed
      Ashborne_toolkit.publish_group_danger("webbed")
      sleep 10
    end

    if checkbound
      Ashborne_toolkit.publish_group_danger("bound")
      sleep 10
    end

    if checkpoison

      if Spell[114].known? && Stats.level >= 14 && Spell[114].affordable?
        waitcastrt?
        Spell[114].cast()
        sleep 3
      else
        Ashborne_toolkit.publish_group_danger("poisoned")
        sleep 10
      end
    end

    if checkdisease
      if Spell[113].known? && Stats.level >= 13 && Spell[113].affordable?
        waitcastrt?
        Spell[113].cast()
        sleep 3
      else
        Ashborne_toolkit.publish_group_danger("diseased")
        sleep 10
      end
    end


  end

  if checkprone

    fput "stand"
  end


  if percenthealth <= 50
    if Stats.prof == "Empath" && checkmana >= 10 && Spell[1101].known?
      fput "cure"
    elsif $ashborne_use_herbs == "1"
      $ashborne_heal_toggle = 1
      Ashborne_toolkit.combat_use_herbs
    else
      Ashborne_toolkit.publish_group_danger("low health")
      sleep 10
    end
  end



  if ashborne_setting_empath_self_heal != "0" && Stats.prof == "Empath"
    if Wounds.head >= 1 || Wounds.neck >= 1 || Wounds.abs >= 1 || Wounds.lhand >= 1 || Wounds.rhand >= 1 || Wounds.larm >= 1 || Wounds.rarm >= 1 || Wounds.chest >= 1 || Wounds.back >= 1 || Wounds.rleg >= 1 || Wounds.lleg >= 1 || Wounds.nerves >= 1 || Wounds.torso >= 1 || Wounds.leye >= 1 || Wounds.reye >= 1 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      Ashborne_toolkit.empath_self_heal
    end
  elsif ($ashborne_empath_self_heal = "1" && Stats.prof == "Empath")
    if Wounds.head >= 1 || Wounds.neck >= 1 || Wounds.abs >= 1 || Wounds.lhand >= 1 || Wounds.rhand >= 1 || Wounds.larm >= 1 || Wounds.rarm >= 1 || Wounds.chest >= 1 || Wounds.back >= 1 || Wounds.rleg >= 1 || Wounds.lleg >= 1 || Wounds.nerves >= 1 || Wounds.torso >= 1 || Wounds.leye >= 1 || Wounds.reye >= 1 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      Ashborne_toolkit.empath_self_heal
    end
  end

  if $ashborne_heal_toggle == 0
    sleep 0.05
    if $ashborne_use_herbs == "1"

      if Wounds.head >= 2 || Wounds.neck >= 2 || Wounds.abs >= 2 || Wounds.lhand >= 2 || Wounds.rhand >= 2 || Wounds.larm >= 2 || Wounds.rarm >= 2 || Wounds.chest >= 2 || Wounds.back >= 2 || Wounds.rleg >= 2 || Wounds.lleg >= 2 || Wounds.nerves >= 2 || Wounds.torso >= 2 || Wounds.leye >= 2 || Wounds.reye >= 2 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
        $ashborne_heal_toggle = 1
        Ashborne_toolkit.combat_use_herbs
      end

    elsif Wounds.head >= 2 || Wounds.neck >= 2 || Wounds.abs >= 2 || Wounds.lhand >= 2 || Wounds.rhand >= 2 || Wounds.larm >= 2 || Wounds.rarm >= 2 || Wounds.chest >= 2 || Wounds.back >= 2 || Wounds.rleg >= 2 || Wounds.lleg >= 2 || Wounds.nerves >= 2 || Wounds.torso >= 2 || Wounds.leye >= 2 || Wounds.reye >= 2 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      Ashborne_toolkit.publish_group_danger("major injury") unless $ashborne_group_quiet == "1"
      sleep 10

    end

  elsif $ashborne_heal_toggle == 1
    sleep 0.05
    $ashborne_heal_toggle = 0
    if Wounds.head >= 2 || Wounds.neck >= 2 || Wounds.abs >= 2 || Wounds.lhand >= 2 || Wounds.rhand >= 2 || Wounds.larm >= 2 || Wounds.rarm >= 2 || Wounds.chest >= 2 || Wounds.back >= 2 || Wounds.rleg >= 2 || Wounds.lleg >= 2 || Wounds.nerves >= 2 || Wounds.torso >= 2 || Wounds.leye >= 2 || Wounds.reye >= 2 || Scars.head >= 2 || Scars.neck >= 2 || Scars.abs >= 2 || Scars.lhand >= 2 || Scars.rhand >= 2 || Scars.larm >= 2 || Scars.rarm >= 2 || Scars.chest >= 2 || Scars.back >= 2 || Scars.rleg >= 2 || Scars.lleg >= 2 || Scars.nerves >= 2 || Scars.torso >= 2 || Scars.leye >= 2 || Scars.reye >= 2
      Ashborne_toolkit.publish_group_danger("major injury") unless $ashborne_group_quiet == "1"
      sleep 10
    end
  end
}


