  def deed_mana
    if $ashborne_deedmana_zonk == "1"
      nil
    elsif Society.status == "Council of Light"
      nil
    elsif $ashborne_deedmana == "0"
      nil
    else
      if percentmana < 50 && $ashborne_my_society =~ /Voln/
        fput "symbol of mana confirm" unless $ashborne_deedmana_zonk == "1"
        sleep 0.5 unless $ashborne_deedmana_zonk == "1"
      end
    end
  end

  def reset_zone_combat_check
    # respond "Debug Output - I'm checking for targets in a reset room."
    # SINGLEPLAYER RESET COMBAT CHECK
    if $ashborne_group_ai == "0"
      # respond "Debug Output - Single Player"
      if GameObj.pcs.empty? && GameObj.targets.length >= 1
        # I see some kind of target.
        if $ashborne_force_target == "0"
          until GameObj.targets.length == 0

            Ashborne_toolkit.target_check
            Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_recent_eviction == "1"
            $ashborne_recent_eviction = "0" if $ashborne_recent_eviction == "1"

          end
        # respond "Debug Output - No more targets, moving on."
        else
          # Quick fix to stop hangups in reset rooms when using ftarget.
          # Enhance this feature later checking for gameobjs that match ftarget
        end
      end

    # MULTIPLAYER RESET COMBAT CHECK
    elsif $ashborne_group_ai == "1"
      if Ashborne_toolkit.visible_non_group_players.any?
        Ashborne_toolkit.leave_occupied_room
      else
        if GameObj.targets.length >= 1
          # I see some kind of target.
          if $ashborne_force_target == "0"
            until GameObj.targets.length == 0

              Ashborne_toolkit.target_check
              Ashborne_toolkit.combat_unique_to_ashborne unless $ashborne_recent_eviction == "1"
              $ashborne_recent_eviction = "0" if $ashborne_recent_eviction == "1"

            end
          # respond "Debug Output - No more targets, moving on."
          else
            # Quick fix to stop hangups in reset rooms when using ftarget.
            # Enhance this feature later checking for gameobjs that match ftarget
          end
        else
          nil
        end
      end
    end
  end

  def combat_unique_to_ashborne
    return if Ashborne_toolkit.critical_mana_retreat_if_needed
    return if Ashborne_toolkit.solo_swarm_retreat_if_needed
    return if Ashborne_toolkit.recover_disarmed_item_if_needed
    return if Ashborne_toolkit.environmental_danger_retreat_if_needed
    return if Ashborne_toolkit.medical_retreat_if_needed
    return if Ashborne_toolkit.post_fight_sanity_sweep
    return if Ashborne_toolkit.group_danger_status_check
    if $ashborne_group_ai == "0" ? GameObj.pcs.any? : Ashborne_toolkit.visible_non_group_players.any?
      Ashborne_toolkit.leave_occupied_room
      return nil
    end

    Ashborne_toolkit.publish_group_state
    if $ashborne_group_ai == "1" && Ashborne_toolkit.configured_followers_missing_in_room.empty?
      Ashborne_toolkit.publish_group_ready_state(true)
    end
    return if Ashborne_toolkit.process_anti_caster_event
    Ashborne_toolkit.publish_group_move_state(false) if $ashborne_group_ai != "0"
    Ashborne_toolkit.publish_group_leader_room
    Ashborne_toolkit.group_follow_sync
    if Ashborne_toolkit.group_follower_safe_hold
      return
    end
    Ashborne_toolkit.combat_stuck_recovery unless $ashborne_my_style == "9"
    Ashborne_toolkit.active_group_combat
    Ashborne_toolkit.customize_block_1
    Ashborne_toolkit.stand_check
    noise_lockdown = Ashborne_toolkit.noise_lockdown?
    Ashborne_toolkit.maintain_noise_lockdown if noise_lockdown

    # Paladin Stamina Recover
    Spell[1607].cast() if !noise_lockdown && Spell[1607].known? && Stats.level >= 7 && Spell[1607].affordable? && percentstamina <= 50 && !Spell.active?("1607")

    Ashborne_toolkit.group_shield_throw_opener

    if $ashborne_group_ai != "0" && !noise_lockdown
      if $ashborne_no_crowd_control == "1"
        nil
      else
        Ashborne_toolkit.crowd_control if Ashborne_toolkit.crowd_control_enabled_for_combat?
      end
    end

    Ashborne_toolkit.feat_control unless noise_lockdown

    Ashborne_toolkit.shield_control
    Ashborne_toolkit.weapon_control

    if $ashborne_group_ai == "0" && !noise_lockdown
      if $ashborne_no_crowd_control == "1"
        nil
      else
        Ashborne_toolkit.crowd_control if Ashborne_toolkit.crowd_control_enabled_for_combat?
      end
    end

    if $ashborne_no_cman_control == "1"
      nil
    else
      Ashborne_toolkit.cman_control if $ashborne_cman_control == "1"
    end

    if noise_lockdown
      Ashborne_toolkit.noise_lockdown_attack_round
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/
      return
    end


    if Ashborne_toolkit.group_follower_fast_attack
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/
      return
    end



    if $ashborne_my_style == "1"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.uac_round
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "2"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.hide_time
      Ashborne_toolkit.uac_round
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "3"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.stance_offensive
      Ashborne_toolkit.chicken_attack
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "4"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.hide_time
      Ashborne_toolkit.stance_offensive
      if checkhidden
        Ashborne_toolkit.chicken_ambush
      else
        Ashborne_toolkit.chicken_attack
      end
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "5"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.stance_offensive
      Ashborne_toolkit.chicken_fire
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "6"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.hide_time
      Ashborne_toolkit.stance_offensive
      Ashborne_toolkit.chicken_fire
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "7"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.kneel_check
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.stance_offensive
      Ashborne_toolkit.chicken_fire
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "8"

      Ashborne_toolkit.waitcast_waitrt
      Ashborne_toolkit.kneel_check
      Ashborne_toolkit.mstrike_routine
      Ashborne_toolkit.hide_time
      Ashborne_toolkit.stance_offensive
      Ashborne_toolkit.chicken_fire
      Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
      Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

    elsif $ashborne_my_style == "9"

      if $ashborne_combat_wands == "0"
        Ashborne_toolkit.stance_guarded
        Ashborne_toolkit.prep_reset
        Ashborne_toolkit.select_custom_spell_rotation unless Ashborne_toolkit.huntpro_spell_attack_cycle?
        Ashborne_toolkit.spell_choice
        Ashborne_toolkit.stand_check
        if Ashborne_toolkit.huntpro_spell_attack_cycle?
          Ashborne_toolkit.spell_cast
        else
          Ashborne_toolkit.style9_spell_cast
        end
        Ashborne_toolkit.stance_guarded
        Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
        Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/

      # Wand Override
      else
        Ashborne_toolkit.stand_check
        Ashborne_toolkit.use_wands
        Ashborne_toolkit.loot_script("#{$ashborne_loot_script}") unless $ashborne_my_area =~ /group|follow|qfollow/
        Ashborne_toolkit.endcombat_actionreset unless $ashborne_my_area =~ /group|follow/
      end


    end
  ensure
    Ashborne_toolkit.movement_guard if $ashborne_group_ai != "0"
  end

  def prep_reset
    if checkprep == "None"
      nil
    else
      fput "release"
    end
  end

