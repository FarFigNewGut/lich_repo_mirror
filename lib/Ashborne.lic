  def script_command_name
    ASHBORNE_SCRIPT_COMMAND
  end

  def current_room
    Room.current
  rescue => error
    respond "Ashborne room lookup warning: #{error.message}" if defined?($ashborne_qc_debug) && $ashborne_qc_debug == "1"
    nil
  end

  def current_room_id
    room = Ashborne_toolkit.current_room
    room && room.id
  rescue => error
    respond "Ashborne room id warning: #{error.message}" if defined?($ashborne_qc_debug) && $ashborne_qc_debug == "1"
    nil
  end

  def huntplan_slug(value)
    value.to_s.downcase.gsub(/[^a-z0-9]+/, "_").gsub(/\A_+|_+\z/, "")
  end

  def huntplan_catalog_key(area)
    text = area.to_s.downcase.strip
    text = text.sub(/\Ahuntplan[:_-]?/, "")
    text = text.sub(/\Ahp[:_-]?/, "")
    key = huntplan_slug(text)
    legacy_aliases = {
      "wlthrak" => "thrak"
    }
    legacy_aliases.fetch(key, key)
  end

  def huntplan_catalog_zone(area)
    HUNTPLAN_ZONE_CATALOG[huntplan_catalog_key(area)]
  end

  def huntplan_catalog_zone?
    !$ashborne_huntplan_catalog_rooms.nil? && !$ashborne_huntplan_catalog_rooms.empty?
  end

  def default_bounty_style
    saved_style = Settings[Char.name]['ashborne_setting_group_style'].to_s
    saved_style =~ /\A[1-9]\z/ ? saved_style : "9"
  rescue
    "9"
  end

  def huntplan_catalog_entry_for_creature(creature_name)
    candidates = Ashborne_toolkit.bounty_creature_name_variants(creature_name).map { |name| Ashborne_toolkit.huntplan_catalog_key(name) }
    candidates.each do |key|
      zone = HUNTPLAN_ZONE_CATALOG[key]
      return [key, zone] if zone
    end

    HUNTPLAN_ZONE_CATALOG.each do |key, zone|
      names = Array(zone[4]).map { |name| Ashborne_toolkit.huntplan_slug(name) }
      return [key, zone] if (names & candidates).any?
    end

    nil
  end

  def bounty_creature_name_variants(creature_name)
    base = creature_name.to_s.downcase.strip.gsub(/\s+/, " ")
    return [] if base.empty?

    variants = [base]
    stripped = base.sub(/\A(?:ancient|grizzled|crazed|scarred|elder|greater|lesser)\s+/, "")
    variants << stripped unless stripped == base
    variants.uniq
  end

  def bounty_task_value(task, key)
    return nil unless task
    return task.send(key) if task.respond_to?(key)
    task.requirements[key] if task.respond_to?(:requirements) && task.requirements.respond_to?(:[])
  rescue
    nil
  end

  def bounty_task_type(task)
    task && task.respond_to?(:type) ? task.type.to_sym : nil
  rescue
    nil
  end

  def bounty_task_summary(task)
    return "unknown bounty" unless task

    values = []
    values << "type=#{Ashborne_toolkit.bounty_task_type(task)}"
    if task.respond_to?(:requirements) && task.requirements.is_a?(Hash)
      task.requirements.each do |key, value|
        next if value.nil? || value.to_s.empty?

        values << "#{key}=#{value}"
      end
    end
    values.join(", ")
  rescue
    "unknown bounty"
  end

  def stop_for_native_bounty_handler(task, reason)
    Ashborne_toolkit.top_menu
    respond "Ashborne bounty router: #{reason}."
    respond "Task: #{Ashborne_toolkit.bounty_task_summary(task)}."
    respond "Ashborne will not hand this to ;ebounty. Native support for this bounty type is not finished yet."
    respond "Use NEWBOUNTY/FASTBOUNTY, handle it manually, or keep testing once this handler is built."
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.script_kill
    exit
  end

  def normalized_forage_herb_name(herb)
    herb = herb.to_s.downcase.strip
    case herb
    when /ayana (weed|lichen|berry|root)/
      "ayana leaf"
    when /ayana'al (weed|lichen|berry|root)/
      "ayana'al leaf"
    when "trollear mushroom"
      "trollfear mushroom"
    when "white mushroom"
      "white hook mushroom"
    when "trafel mushroom"
      "black trafel mushroom"
    when "withered mushroom"
      "withered black mushroom"
    when "soft mushroom"
      "soft white mushroom"
    else
      herb
    end
  end

  def forage_herb_inventory_count(herb)
    Ashborne_toolkit.forage_herb_inventory_items(herb).length
  rescue
    0
  end

  def forage_herb_inventory_items(herb)
    herb = Ashborne_toolkit.normalized_forage_herb_name(herb)
    names = [herb, herb.sub(/\Asome\s+/, "")].uniq
    objects = []
    objects.concat(GameObj.inv.to_a) if GameObj.respond_to?(:inv)
    objects << GameObj.right_hand if GameObj.respond_to?(:right_hand)
    objects << GameObj.left_hand if GameObj.respond_to?(:left_hand)
    objects.compact.select do |item|
      item_name = item.name.to_s.downcase
      names.any? { |name| item_name.include?(name) || (name =~ /ayana/ && name.start_with?(item_name)) }
    end
  rescue
    []
  end

  def forage_room_candidates(herb, location = "nearest")
    herb = Ashborne_toolkit.normalized_forage_herb_name(herb)
    herb_alt = herb.sub(/\Asome\s+/, "")
    pattern = /#{Regexp.escape(herb)}|#{Regexp.escape(herb_alt)}/i
    rooms = Room.list.select do |room|
      tags = room.respond_to?(:tags) ? room.tags : []
      tags.any? do |tag|
        tag_text = tag.to_s.downcase
        tag_text =~ pattern || tag_text.end_with?(herb) || herb.end_with?(tag_text) || (herb =~ /ayana/ && herb.start_with?(tag_text))
      end
    end.map(&:id).uniq

    unless location.to_s.empty? || location.to_s == "nearest"
      location_pattern = /#{Regexp.escape(location.to_s.strip)}/i
      rooms.select! { |room_id| Room[room_id].location.to_s =~ location_pattern rescue false }
    end

    _previous, distances = Room.current.dijkstra
    rooms.select! { |room_id| distances[room_id] }
    rooms.sort_by! { |room_id| distances[room_id] }
    location.to_s == "nearest" ? rooms.first(10) : rooms.first(25)
  rescue
    []
  end

  def native_forage_bounty(task)
    if $ashborne_bounty_noherb == "1"
      Ashborne_toolkit.top_menu
      respond "#{Char.name}, I see you don't want Ashborne to complete herb bounties."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    herb = Ashborne_toolkit.bounty_task_value(task, :herb).to_s
    quantity = Ashborne_toolkit.bounty_task_value(task, :number).to_i
    location = Ashborne_toolkit.bounty_task_value(task, :area).to_s
    location = "nearest" if location.empty?
    quantity = 1 if quantity < 1
    forage_item = Ashborne_toolkit.normalized_forage_herb_name(herb)

    if forage_item.empty?
      Ashborne_toolkit.stop_for_native_bounty_handler(task, "forage/herb bounty with no herb name")
    end

    Ashborne_toolkit.top_menu
    respond "Ashborne native herb bounty: #{quantity} #{forage_item} from #{location}."
    Ashborne_toolkit.bottom_menu

    starting_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id : nil
    current_count = Ashborne_toolkit.forage_herb_inventory_count(forage_item)
    if current_count >= quantity
      respond "Ashborne already sees #{current_count}/#{quantity} #{forage_item}; heading to herbalist."
      Ashborne_toolkit.native_herb_bounty_turnin(forage_item)
      return true
    end

    rooms = Ashborne_toolkit.forage_room_candidates(forage_item, location)
    if rooms.empty?
      Ashborne_toolkit.top_menu
      respond "Ashborne could not find mapped forage rooms for #{forage_item}#{location == 'nearest' ? '' : " in #{location}"}."
      respond "This herb bounty needs map tags before Ashborne can safely automate it."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    rooms.each do |room_id|
      break if current_count >= quantity
      Ashborne_toolkit.stance_defensive
      do_client ";go2 #{room_id}"
      Ashborne_toolkit.unpause_go2
      wait_while { running? "go2" }
      next unless Room.current && Ashborne_toolkit.current_room_id.to_s == room_id.to_s
      next unless GameObj.targets.empty?

      8.times do
        break if current_count >= quantity
        break unless GameObj.targets.empty?

        Ashborne_toolkit.ashborne_stow_all
        fput "kneel" unless kneeling?
        waitrt? if checkrt.to_f > 0
        result = dothistimeout "forage for #{forage_item}", 10,
                               /You forage briefly and manage to find|You forage|can find no|see no evidence|unable to find anything useful|suddenly feel|Roundtime/i
        waitrt? if checkrt.to_f > 0
        if result.to_s =~ /manage to find|You forage/i
          fput "stow right" if checkright
          fput "stow left" if checkleft
          sleep 0.5
          current_count = Ashborne_toolkit.forage_herb_inventory_count(forage_item)
          respond "Ashborne foraged #{current_count}/#{quantity} #{forage_item}."
        elsif result.to_s =~ /can find no|see no evidence|unable to find anything useful/i
          break
        elsif result.to_s =~ /suddenly feel/i
          Ashborne_toolkit.stance_defensive
          break
        else
          break
        end
      end
      fput "stand" unless standing?
    end

    if current_count >= quantity
      Ashborne_toolkit.native_herb_bounty_turnin(forage_item)
    else
      do_client ";go2 #{starting_room}" if starting_room
      wait_while { running? "go2" }
      Ashborne_toolkit.top_menu
      respond "Ashborne only found #{current_count}/#{quantity} #{forage_item}; stopping the herb bounty safely."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    true
  end

  def native_herb_bounty_turnin(herb)
    waitrt? if checkrt.to_f > 0
    do_client ";go2 town"
    Ashborne_toolkit.unpause_go2
    wait_while { running? "go2" }
    Ashborne_toolkit.bounty_town_flash

    herbalist_destination = Ashborne_toolkit.native_herbalist_destination
    do_client ";go2 #{herbalist_destination}"
    Ashborne_toolkit.unpause_go2
    wait_while { running? "go2" }

    herbalist = Ashborne_toolkit.native_herbalist_target
    if herbalist.nil?
      Ashborne_toolkit.top_menu
      respond "Ashborne could not see the herb bounty NPC here. Stopping with your herbs still in inventory."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    items = Ashborne_toolkit.forage_herb_inventory_items(herb)
    if items.empty?
      Ashborne_toolkit.top_menu
      respond "Ashborne reached the herbalist but could not find #{herb} in inventory."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    items.each do |item|
      waitrt? if checkrt.to_f > 0
      give_target = herbalist.respond_to?(:id) && herbalist.id ? "##{herbalist.id}" : herbalist.noun.to_s
      result = dothistimeout "give ##{item.id} to #{give_target}", 8,
                             /This looks perfect|partially used up|You hand|You offer|accepts|doesn't seem interested|What were you referring to|You don't seem to have/i
      break if result.to_s =~ /doesn't seem interested|What were you referring to|You don't seem to have/i
      sleep 0.25
    end

    fput "bounty"
    Ashborne_toolkit.top_menu
    respond "Ashborne finished the native herb bounty turn-in attempt for #{herb}."
    Ashborne_toolkit.bottom_menu
    $ashborne_action = 99
    $ashborne_return_why = "You finished your herb bounty."
    Ashborne_toolkit.script_kill
    exit
  rescue => error
    respond "Ashborne herb bounty turn-in failed: #{error.class}: #{error.message}"
    Ashborne_toolkit.script_kill
    exit
  end

  def native_herbalist_destination
    case $ashborne_bounty_town.to_s
    when "River's Rest"
      "alchemist"
    when "Solhaven"
      "5722"
    when "Vaalor"
      "10396"
    else
      "npchealer"
    end
  end

  def native_herbalist_target
    town_names = {
      "Landing" => /akrash/i,
      "Icemule" => /mirtag/i,
      "Solhaven" => /kelph/i,
      "River's Rest" => /lomara/i,
      "Teras" => /kris/i,
      "Vaalor" => /maraene/i,
      "Illistim" => /valina/i,
      "Zul Logoth" => /cocytel/i,
      "Kraken's Fall" => /delosa/i
    }
    pattern = town_names[$ashborne_bounty_town.to_s] || /herbalist|healer|alchemist/i
    GameObj.npcs.find do |npc|
      npc.name.to_s =~ pattern || npc.noun.to_s =~ pattern
    end || GameObj.npcs.find do |npc|
      npc.name.to_s =~ /herbalist|healer|alchemist/i || npc.noun.to_s =~ /herbalist|healer|alchemist/i
    end
  rescue
    nil
  end

  def route_non_hunting_bounty_task(task)
    type = Ashborne_toolkit.bounty_task_type(task)
    $ashborne_bounty_town = Ashborne_toolkit.bounty_task_value(task, :town).to_s unless Ashborne_toolkit.bounty_task_value(task, :town).to_s.empty?

    case type
    when :none
      $ashborne_bounty_stage = "1"
      return true
    when :taskmaster
      $ashborne_bounty_stage = "7"
      return true
    when :guard, :bandit_assignment, :creature_assignment, :heirloom_assignment, :rescue_assignment, :heirloom_found
      $ashborne_bounty_stage = "4"
      return true
    when :skin_assignment
      $ashborne_bounty_stage = "4.5"
      return true
    when :herb_assignment
      $ashborne_bounty_stage = "4.75"
      return true
    when :bandit
      if $ashborne_bounty_nobandit == "1"
        Ashborne_toolkit.top_menu
        respond "#{Char.name}, I see you don't want Ashborne to complete bandit bounties."
        respond "Use NEWBOUNTY or FASTBOUNTY to pick something else, or handle this manually."
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.script_kill
        exit
      end

      $ashborne_my_area = "bandit"
      $ashborne_original_area = "bandit"
      $ashborne_bounty_type = "Bandit"
      $ashborne_bounty_stage = "6"
      $ashborne_bounty_ready_to_launch = "1"
      return true
    when :herb
      return Ashborne_toolkit.native_forage_bounty(task)
    when :gem, :gem_assignment
      return Ashborne_toolkit.stop_for_native_bounty_handler(task, "gem bounty")
    when :escort, :escort_assignment
      return Ashborne_toolkit.stop_for_native_bounty_handler(task, "escort bounty")
    when :rescue, :rescue_spawned
      return Ashborne_toolkit.stop_for_native_bounty_handler(task, "rescue child bounty")
    when :failed
      $ashborne_bounty_stage = "8"
      $ashborne_return_why = "Your bounty has failed."
      return true
    else
      false
    end
  end

  def prepare_bounty_from_current_task
    return false unless defined?(Bounty) && Bounty.respond_to?(:task)

    task = Bounty.task
    return false unless task

    return true if Ashborne_toolkit.route_non_hunting_bounty_task(task)

    supported_hunting_task =
      (task.respond_to?(:cull?) && task.cull?) ||
      (task.respond_to?(:dangerous?) && task.dangerous?) ||
      (task.respond_to?(:skin?) && task.skin?) ||
      (task.respond_to?(:heirloom?) && task.heirloom?)
    return false unless supported_hunting_task

    if task.respond_to?(:skin?) && task.skin? && $ashborne_bounty_noskin == "1"
      Ashborne_toolkit.top_menu
      respond "#{Char.name}, I see you don't want Ashborne to complete skin bounties."
      respond "You can have someone else skin for you and then turn them in."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    creature_name = Ashborne_toolkit.bounty_task_value(task, :creature).to_s.downcase.strip
    return false if creature_name.empty?

    entry = Ashborne_toolkit.huntplan_catalog_entry_for_creature(creature_name)
    unless entry
      Ashborne_toolkit.top_menu
      respond "Ashborne read your bounty, but I do not have a mapped HuntPlan catalog area for: #{creature_name}."
      respond "For now, use huntsuggest or a direct area name for this bounty."
      Ashborne_toolkit.bottom_menu
      Ashborne_toolkit.script_kill
      exit
    end

    area_key, zone = entry
    catalog_names = Array(zone[4]).map(&:to_s).reject(&:empty?)
    base_creature = Ashborne_toolkit.bounty_creature_name_variants(creature_name).last || creature_name
    target_names = catalog_names.empty? ? [creature_name] : catalog_names.dup

    if task.type.to_s == "dangerous_spawned"
      target_names = ["ancient #{base_creature}", "grizzled #{base_creature}"]
    elsif task.respond_to?(:dangerous?) && task.dangerous?
      target_names |= [creature_name, base_creature]
      $ashborne_bounty_creature_name = base_creature
    else
      target_names |= [creature_name]
      $ashborne_bounty_creature_name = creature_name
    end

    $ashborne_my_area = area_key
    $ashborne_original_area = area_key
    $ashborne_bounty_town = Ashborne_toolkit.bounty_task_value(task, :town).to_s
    $ashborne_bounty_type =
      if task.respond_to?(:skin?) && task.skin?
        "skin"
      elsif task.respond_to?(:heirloom?) && task.heirloom?
        "Heirloom"
      else
        "creature"
      end
    $ashborne_bounty_skin_name = Ashborne_toolkit.bounty_task_value(task, :skin).to_s if $ashborne_bounty_type == "skin"
    $ashborne_combat_cleanup = "1" if $ashborne_bounty_type == "skin"
    $ashborne_creature_sev_1_attack_array = target_names.map(&:downcase).uniq
    $ashborne_bounty_stage = "6"
    $ashborne_bounty_ready_to_launch = "1"

    Ashborne_toolkit.top_menu
    respond "Ashborne bounty scan: #{task.type} for #{creature_name}."
    respond "Mapped to #{area_key} using #{catalog_names.first || creature_name}; #{Array(zone[3]).length} hunting rooms."
    respond "Priority targets: #{$ashborne_creature_sev_1_attack_array.join(', ')}."
    Ashborne_toolkit.bottom_menu
    true
  rescue => error
    respond "Ashborne bounty scan failed: #{error.class}: #{error.message}"
    false
  end

  def group_incomplete_in_current_room?
    return false if $ashborne_group_ai == "0"

    if $ashborne_group_ai == "1"
      !Ashborne_toolkit.configured_followers_missing_in_room.empty?
    elsif $ashborne_group_ai == "2"
      captain = Ashborne_toolkit.canonical_character_name($ashborne_captain)
      return true unless Ashborne_toolkit.valid_character_name?(captain)

      !Ashborne_toolkit.follower_in_expected_group? || !checkpcs(captain)
    else
      false
    end
  rescue
    true
  end

  def configured_followers_missing_in_room
    return [] unless $ashborne_group_ai == "1"

    Ashborne_toolkit.configured_group_members.reject do |member_name|
      Ashborne_toolkit.visible_group_pc(member_name)
    end
  rescue
    Ashborne_toolkit.configured_group_members rescue []
  end

  def stop_group_travel_without_group(reason)
    Script.kill("go2") if Script.running?("go2")
    sleep 0.25
    $ashborne_return_why = "Group travel stopped: #{reason}"
    $ashborne_group_danger_active = "1"
    Ashborne_toolkit.publish_group_danger($ashborne_return_why) if $ashborne_group_ai != "0"
    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.script_kill
    Ashborne_toolkit.top_menu
    respond "#{$ashborne_return_why}."
    respond "Ashborne will not continue toward the hunting area without the configured group."
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.ashborne_stow_all
    exit
  rescue => error
    respond "Group travel stop failed: #{error.class}: #{error.message}"
    exit
  end

  def rally_and_regroup_for_travel(context = "group travel", timeout_seconds = 60)
    return true unless $ashborne_group_ai == "1"

    Script.kill("go2") if Script.running?("go2")
    sleep 0.25
    Ashborne_toolkit.stance_defensive
    Ashborne_toolkit.publish_group_leader_room
    respond "Group travel paused for regroup during #{context}."

    deadline = Time.now + timeout_seconds
    next_rally = Time.at(0)
    until Time.now >= deadline
      missing = Ashborne_toolkit.configured_followers_missing_in_room
      if missing.empty?
        Ashborne_toolkit.hold_present_group_members
        respond "Group reformed; resuming #{context}."
        return true
      end

      if Script.running?("go2")
        Script.kill("go2")
        respond "Regroup hold stopped go2; waiting for #{missing.join(', ')} before moving again."
      end

      Ashborne_toolkit.publish_group_leader_room
      Ashborne_toolkit.defend_while_waiting_for_group unless GameObj.targets.empty?
      if Time.now >= next_rally
        respond "Rallying missing follower(s): #{missing.join(', ')}."
        Ashborne_toolkit.command_missing_followers_for_regroup(missing, context)
        next_rally = Time.now + 5
      end
      sleep 0.5
    end

    false
  rescue => error
    respond "Group regroup warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

  def monitored_group_go2(destination, context = "hunting area")
    regroup_attempts = 0
    travel_attempts = 0
    expected_room_id = destination.to_s =~ /\A\d+\z/ ? destination.to_i : nil

    loop do
      travel_attempts += 1
      last_room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
      # Script.run waits for go2 to finish, which prevents the checks below from
      # noticing a follower lost at an obstacle until the destination is reached.
      Script.start('go2', destination.to_s)
      missing_since = nil
      last_warning = 0
      regroup_needed = false

      while Script.running?('go2')
        if $ashborne_group_ai == "1"
          current_room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
          room_changed = current_room_id && last_room_id && current_room_id != last_room_id
          if current_room_id && current_room_id != last_room_id
            last_room_id = current_room_id
            sleep 0.35
          end

          missing = Ashborne_toolkit.configured_followers_missing_in_room
          if missing.empty?
            missing_since = nil
          else
            missing_since ||= Time.now
            if room_changed || Time.now - missing_since >= 2.0
              regroup_needed = true
              break
            elsif Time.now.to_i > last_warning
              respond "Group travel check: waiting for #{missing.join(', ')} to stay with the group."
              last_warning = Time.now.to_i
            end
          end
        end
        sleep 0.25
      end

      if regroup_needed
        regroup_attempts += 1
        unless regroup_attempts <= 5 && Ashborne_toolkit.rally_and_regroup_for_travel(context)
          Ashborne_toolkit.stop_group_travel_without_group("could not regroup during #{context}")
        end
        next
      end

      if expected_room_id && (!Room.current || Ashborne_toolkit.current_room_id.to_i != expected_room_id)
        current_room_id = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : "unknown"
        if travel_attempts < 3
          respond "go2 stopped in room #{current_room_id} before reaching #{expected_room_id}; retrying #{context}."
          sleep 1
          next
        end

        Ashborne_toolkit.stop_group_travel_without_group(
          "go2 could not reach room #{expected_room_id} for #{context}; stopped in room #{current_room_id}"
        )
      end

      break unless $ashborne_group_ai == "1"

      missing = Ashborne_toolkit.configured_followers_missing_in_room
      if missing.empty?
        return true
      end

      regroup_attempts += 1
      unless regroup_attempts <= 5 && Ashborne_toolkit.rally_and_regroup_for_travel(context)
        Ashborne_toolkit.stop_group_travel_without_group("arrived without follower(s) after #{context}: #{missing.join(', ')}")
      end
    end

    true
  end

  def emergency_retreat_to_town_now(reason)
    $ashborne_return_why = reason.to_s
    $ashborne_group_danger_active = "1"
    Ashborne_toolkit.publish_group_danger(reason.to_s) if $ashborne_group_ai != "0"

    if $ashborne_group_ai == "1"
      Ashborne_toolkit.publish_town_service_request(
        Ashborne_toolkit.current_group_session_id,
        $ashborne_rest_healing == "1",
        $ashborne_rest_sell == "1",
        "0"
      )
    end

    Ashborne_toolkit.stance_defensive
    3.times do
      break if checkdead
      break unless webbed? || bound?

      fput "struggle"
      sleep 0.5
      waitrt? if checkrt.to_f > 0
    end

    return false if checkdead
    waitrt? if checkrt.to_f > 0
    waitcastrt? if checkcastrt.to_f > 0

    respond "Emergency retreat: #{reason}"
    do_client ";go2 town"
    Ashborne_toolkit.unpause_go2
    wait_while { running? "go2" }

    Ashborne_toolkit.script_kill
    Ashborne_toolkit.top_menu
    respond "I returned to town because: #{reason}"
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.ashborne_stow_all
    exit
  rescue => error
    respond "Emergency retreat failed: #{error.class}: #{error.message}"
    false
  end

  def activate_huntplan_catalog_zone(area)
    data = Ashborne_toolkit.huntplan_catalog_zone(area)
    return false unless data

    level, creature_type, anchor, rooms, names = data
    $ashborne_huntplan_catalog_key = Ashborne_toolkit.huntplan_catalog_key(area)
    $ashborne_huntplan_catalog_anchor = anchor.to_i
    $ashborne_huntplan_catalog_rooms = Ashborne_toolkit.huntplan_catalog_connected_rooms(rooms, $ashborne_huntplan_catalog_anchor)
    $ashborne_huntplan_catalog_names = Array(names)
    $ashborne_huntplan_catalog_recent_rooms = []
    $ashborne_huntplan_catalog_sweep_counter = 0
    $ashborne_huntplan_catalog_last_sweep_at = 0.0
    $ashborne_my_area_level = level.to_i
    $ashborne_my_area_type = creature_type.to_s.empty? ? "Living" : creature_type.to_s

    respond "Ashborne catalog area: #{Array(names).join(' / ')}."
    respond "Mapped rooms: #{$ashborne_huntplan_catalog_rooms.length}; anchor room #{$ashborne_huntplan_catalog_anchor}."
    Ashborne_toolkit.monitored_group_go2($ashborne_huntplan_catalog_anchor, "travel to #{Array(names).first || area}")
    true
  end

  def huntplan_catalog_connected_rooms(rooms, anchor)
    allowed = Array(rooms).map(&:to_i).uniq
    anchor = anchor.to_i
    return allowed unless allowed.include?(anchor)

    connected = []
    pending = [anchor]
    until pending.empty?
      room_id = pending.shift
      next if connected.include?(room_id)

      connected << room_id
      room = Room[room_id] rescue nil
      routes = room && room.respond_to?(:wayto) ? room.wayto : nil
      next unless routes.respond_to?(:keys)

      routes.keys.each do |destination|
        destination = destination.to_i
        next unless allowed.include?(destination)
        command = routes[destination] || routes[destination.to_s]
        next if command.to_s.strip =~ /\Aout\z/i

        pending << destination unless connected.include?(destination)
      end
    end
    connected.empty? ? allowed : connected
  rescue
    allowed
  end

  def huntplan_catalog_room_allowed?(room_id)
    return true unless Ashborne_toolkit.huntplan_catalog_zone?

    $ashborne_huntplan_catalog_rooms.include?(room_id.to_i)
  end

  def disable_huntplan_catalog_zone(reason = nil)
    respond "Ashborne catalog boundary disabled for this run: #{reason}" unless reason.to_s.empty?
    $ashborne_huntplan_catalog_key = nil
    $ashborne_huntplan_catalog_rooms = nil
    $ashborne_huntplan_catalog_anchor = nil
    $ashborne_huntplan_catalog_names = nil
    $ashborne_huntplan_catalog_recent_rooms = []
    $ashborne_huntplan_catalog_sweep_counter = 0
    $ashborne_huntplan_catalog_last_sweep_at = 0.0
    nil
  rescue
    nil
  end

  def huntplan_catalog_neighbors(room)
    return [] unless room

    wayto = room.respond_to?(:wayto) ? room.wayto : nil
    return [] unless wayto.respond_to?(:keys)

    allowed = $ashborne_huntplan_catalog_rooms || []
    wayto.keys.map(&:to_i).select { |room_id| allowed.include?(room_id) }.uniq
  rescue
    []
  end

  def huntplan_catalog_simple_exit(room, destination)
    return nil unless room && room.respond_to?(:wayto)

    routes = room.wayto
    return nil unless routes.respond_to?(:[])

    command = routes[destination] || routes[destination.to_s]
    return nil unless command.is_a?(String)

    command = command.strip
    return command if command =~ /\A(?:north|northeast|east|southeast|south|southwest|west|northwest|up|down)\z/i
    return command if command =~ /\Ago\s+[a-z][a-z0-9' -]*\z/i

    nil
  rescue
    nil
  end

  def huntplan_catalog_step(room, destination)
    command = Ashborne_toolkit.huntplan_catalog_simple_exit(room, destination)
    if command
      fput command
      sleep 0.2
      if Room.current && Ashborne_toolkit.current_room_id && Ashborne_toolkit.current_room_id.to_i == destination.to_i
        if $ashborne_group_ai == "1" && Ashborne_toolkit.group_incomplete_in_current_room?
          return Ashborne_toolkit.rally_and_regroup_for_travel("catalog hunting movement")
        end
        return true
      end
    end

    Ashborne_toolkit.monitored_group_go2(destination, "catalog hunting movement")
  end

  def catalog_sweep_destination(current_id, local_candidates = [])
    return nil unless Ashborne_toolkit.huntplan_catalog_zone?
    return nil unless current_id
    return nil unless GameObj.targets.empty? && GameObj.dead.empty?

    allowed = Array($ashborne_huntplan_catalog_rooms).map(&:to_i).uniq
    return nil if allowed.length <= 3

    now = Time.now.to_f
    $ashborne_huntplan_catalog_sweep_counter = $ashborne_huntplan_catalog_sweep_counter.to_i + 1
    return nil if $ashborne_huntplan_catalog_sweep_counter < 7
    return nil if now - $ashborne_huntplan_catalog_last_sweep_at.to_f < 25.0

    recent = Array($ashborne_huntplan_catalog_recent_rooms).map(&:to_i)
    local = Array(local_candidates).map(&:to_i)
    stats = $ashborne_room_yield_stats || {}
    candidates = allowed.reject { |room_id| room_id.to_i == current_id.to_i }
    candidates.reject! { |room_id| Ashborne_toolkit.avoided_room_reason(room_id) }
    remote = candidates.reject { |room_id| local.include?(room_id.to_i) }
    candidates = remote unless remote.empty?
    candidates.reject! { |room_id| recent.last(6).include?(room_id.to_i) }
    return nil if candidates.empty?

    candidates.min_by do |room_id|
      room_stats = stats[room_id.to_s] || {}
      visits = Array(room_stats["visits"])
      [visits.empty? ? 0 : 1, visits.last.to_f, rand]
    end
  rescue
    nil
  end

  def reset_catalog_sweep_timer
    $ashborne_huntplan_catalog_sweep_counter = 0
    $ashborne_huntplan_catalog_last_sweep_at = Time.now.to_f
  rescue
    nil
  end

  def huntplan_catalog_walk
    return nil unless Ashborne_toolkit.huntplan_catalog_zone?

    current_room = Room.current
    current_id = current_room && current_room.id ? current_room.id.to_i : nil
    anchor = $ashborne_huntplan_catalog_anchor.to_i

    unless current_id && Ashborne_toolkit.huntplan_catalog_room_allowed?(current_id)
      respond "Ashborne catalog boundary: returning to anchor room #{anchor}."
      Ashborne_toolkit.monitored_group_go2(anchor, "catalog boundary return")
      return true
    end

    candidates = Ashborne_toolkit.huntplan_catalog_neighbors(current_room)
    if candidates.empty?
      if current_id.to_i == anchor.to_i
        Ashborne_toolkit.disable_huntplan_catalog_zone("anchor room #{anchor} has no mapped in-area exits.")
        return nil
      end

      respond "Ashborne catalog movement has no mapped in-area exits from #{current_id}; returning to anchor."
      Ashborne_toolkit.monitored_group_go2(anchor, "catalog anchor return")
      return true
    end

    recent = Array($ashborne_huntplan_catalog_recent_rooms).map(&:to_i)
    open_candidates = candidates.reject { |room_id| Ashborne_toolkit.avoided_room_reason(room_id) }
    candidates = open_candidates unless open_candidates.empty?
    sweep_destination = Ashborne_toolkit.catalog_sweep_destination(current_id, candidates)
    if sweep_destination
      respond "Ashborne catalog sweep: checking room #{sweep_destination} for missed spawns." if $ashborne_qc_debug == "1"
      Ashborne_toolkit.reset_catalog_sweep_timer
      Ashborne_toolkit.huntplan_catalog_step(current_room, sweep_destination)
      $ashborne_huntplan_catalog_recent_rooms = (recent + [current_id, sweep_destination.to_i]).last(8)
      return true
    end

    preferred = candidates.reject { |room_id| recent.last(5).include?(room_id.to_i) }
    destination = (preferred.empty? ? candidates : preferred).sample
    Ashborne_toolkit.huntplan_catalog_step(current_room, destination)
    $ashborne_huntplan_catalog_recent_rooms = (recent + [current_id, destination.to_i]).last(8)

    if Room.current && Ashborne_toolkit.current_room_id && !Ashborne_toolkit.huntplan_catalog_room_allowed?(Ashborne_toolkit.current_room_id)
      respond "Ashborne catalog boundary caught room #{Ashborne_toolkit.current_room_id}; returning to anchor."
      Ashborne_toolkit.monitored_group_go2(anchor, "catalog boundary correction")
    end
    true
  rescue => error
    respond "Ashborne catalog movement warning: #{error.message}" if $ashborne_qc_debug == "1"
    nil
  end

