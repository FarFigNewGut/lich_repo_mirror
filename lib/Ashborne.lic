    $ashborne_my_area_level = 66
    $ashborne_my_area_type = "Living"

    Script.run('go2', '2256')
    pause 1


  # Kraken's Fall

  elsif $ashborne_my_area =~ /kfatoll/

    $ashborne_my_area_level = 100
    $ashborne_my_area_type = "Living"

    # $ashborne_divergence = "1"

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, you are about to enter a hunting zone affected by Divergence."
    respond
    respond "Divergence: https://gswiki.play.net/Divergence"
    respond
    respond "Spell Sever: https://gswiki.play.net/Spell_sever"
    respond
    respond "Continuing the script in 3 seconds.  ;ka to abort"
    Ashborne_toolkit.bottom_menu
    sleep 3


    Script.run('go2', '30816')
    pause 1

  elsif $ashborne_my_area =~ /kfatemple/

    $ashborne_my_area_level = 100
    $ashborne_my_area_type = "Living"

    # $ashborne_divergence = "1"

    Ashborne_toolkit.top_menu
    respond "#{Char.name}, you are about to enter a hunting zone affected by Divergence."
    respond
    respond "Divergence: https://gswiki.play.net/Divergence"
    respond
    respond "Spell Sever: https://gswiki.play.net/Spell_sever"
    respond
    respond "Continuing the script in 3 seconds.  ;ka to abort"
    Ashborne_toolkit.bottom_menu
    sleep 3


    Script.run('go2', '30851')
    pause 1



  elsif Ashborne_toolkit.activate_huntplan_catalog_zone($ashborne_my_area)

    nil

  elsif $ashborne_my_area =~ /reim/

    respond "Reim Setting Disabled."
    exit


  # Misc

  elsif $ashborne_my_area =~ /drarena/

    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100
    $ashborne_action = 96

  elsif $ashborne_my_area =~ /drlite/

    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100
    $ashborne_action = 96

  elsif $ashborne_my_area =~ /qlite/

    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100
    $ashborne_action = 97

  elsif $ashborne_my_area =~ /quick/

    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100
    $ashborne_action = 97

  elsif $ashborne_my_area =~ /grounded/

    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100
    if Ashborne_toolkit.current_room_id.nil?
      $ashborne_my_room_number = nil
    else
      $ashborne_my_room_number = Ashborne_toolkit.current_room_id
    end
    $ashborne_action = 95

  elsif $ashborne_my_area =~ /patrol/

    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100

  elsif $ashborne_my_area =~ /newbounty/
    $ashborne_bounty_stage = "1.5"
    $ashborne_bounty_intel_watch = "1"
    Ashborne_toolkit.bounty_debug
    Ashborne_toolkit.bounty_control
    ashborne_hunting_zones.call

  elsif $ashborne_my_area =~ /fastbounty/
    $ashborne_bounty_stage = "1.5"
    $ashborne_bounty_intel_watch = "1"
    $ashborne_bounty_fast = "1"
    Ashborne_toolkit.bounty_debug
    Ashborne_toolkit.bounty_control
    ashborne_hunting_zones.call


  elsif $ashborne_my_area =~ /bounty/
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, Ashborne will scan your current bounty and map hunt-style tasks through the catalog."
    respond "Direct: cull, dangerous, skin, heirloom hunts, assignments, and turn-ins. Herb/gem/escort/rescue stay inside Ashborne and stop until native handlers are finished."
    Ashborne_toolkit.bottom_menu
    $ashborne_bounty_creature_match = "1"
    Ashborne_toolkit.bounty_status
    ashborne_hunting_zones.call



  elsif $ashborne_my_area =~ /bandit/
    $ashborne_my_area_type = "Living"
    $ashborne_my_area_level = 100

    $ashborne_bounty_nobandit = "1"

    if $ashborne_qc_testing == "1"
      nil
    else
      if $ashborne_bounty_nobandit == "1"
        Ashborne_toolkit.top_menu
        respond "#{Char.name}, I see you don't want Ashborne to complete bandit bounties."
        respond
        respond "You can choose the NEWBOUNTY or FASTBOUNTY option to pick something else or do them on your own."
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.script_kill
        exit
      end
    end


    Ashborne_toolkit.top_menu
    respond "You are entering a testing portion of Ashborne.  To stop type ;ka and to disable ;ashborne setup change testing 0 "
    respond
    respond "Continuing in 3 seconds..."
    Ashborne_toolkit.bottom_menu
    sleep 3

    Ashborne_toolkit.top_menu
    respond "Bandit Block Missing, this is on purpose."
    respond "Stay tuned for hotfix."
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.script_kill
    exit



  elsif $ashborne_my_area =~ /group/
    respond "Group Mode Activated."
    $ashborne_group_ai = "2"
    $ashborne_qfollow = "0"

  elsif $ashborne_my_area =~ /qfollow/
    # respond "Quick Follow"
    $ashborne_qfollow = "1"
    $ashborne_captain = "#{script.vars[3]}"
    $ashborne_follow_mode = "1"

  elsif $ashborne_my_area =~ /follow/
    # respond "Follow Mode Activated."
    # $ashborne_group_ai = "2"
    $ashborne_qfollow = "1"
    $ashborne_captain = "#{script.vars[3]}"
    $ashborne_follow_mode = "1"

  elsif $ashborne_my_area == "0"
  # respond "Debug exit out of bounty feature.  Not ready for new bounty yet."

  else
    respond "Ashborne Hunting Zone Else Error Trap"
    exit
  end

  Ashborne_toolkit.room_nil_walk

  if $ashborne_taxi == "1"
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, you have arrived at your destination."
    respond
    respond "Good luck with your hunt!"
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.script_kill
    exit
  end
}


