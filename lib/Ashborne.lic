    if $ashborne_current_name_targets.include?('shimmering fungus')
      Ashborne_toolkit.fail_safe_vchange

    end


    # Noun Skip Logic
    if $ashborne_current_noun_targets.any? { |x| $ashborne_force_skip_array.include?(x) }
      Ashborne_toolkit.fail_safe_vchange

    end

    # Name Skip Logic

    if $ashborne_current_name_targets.any? { |x| $ashborne_compound_ignore_array.include?(x) }
      Ashborne_toolkit.fail_safe_vchange

    end

    if $ashborne_flee_counter == "0"
      nil
    elsif $ashborne_flee_counter == 0
      nil
    else
      if GameObj.targets.length >= $ashborne_flee_counter
        # respond "Debug Output - Too Many Mobs!"
        Ashborne_toolkit.fail_safe_vchange
      end
    end
  end

  def fail_safe_vchange
    # respond "Debug Output - Fail Safe VChange"

    # 97 is quick and qlite
    # 96 is is drarena and drlite
    # 95 is grounded
    if $ashborne_action == 97
      # Flee to another room and stop quick / qlite.
      waitrt?
      Ashborne_toolkit.safe_walk
      $ashborne_recent_eviction = "1"
      Ashborne_toolkit.top_menu
      respond "#{Char.name}, you were running quick/qlite mode and a room move was requested by setting or detected room conditions.  Stopping combat."
      Ashborne_toolkit.bottom_menu
      exit
    elsif $ashborne_action == 95
      # You're meant to stay grounded, but something is triggering you to run.
      if Ashborne_toolkit.current_room_id.nil?
        # Your current room isn't mapped, so I'll ignore the run.
        nil
      else
        waitrt?
        Ashborne_toolkit.safe_walk
        # Because you left your original mapped room, combat will stop.
      end
    elsif $ashborne_action == 96
    # Drarena and Drlite, ignore flee requests.
    else
      $ashborne_action = 98
    end
  end

  def cock_support
    if $ashborne_use_cock == "1" && $ashborne_cock_block == "0" && GameObj.targets.length == 0
      waitrt?
      fput "cock #{checkleft}"
      $ashborne_cock_block = "1"
    end
  end

  def unstable_dead_creature_present?
    GameObj.dead.any? do |dead|
      text = [dead.name, dead.noun, dead.to_s].join(" ")
      text =~ /incubus/i
    end
  rescue
    false
  end

  def dead_body_wait_seconds
    if GameObj.dead.empty?
      $ashborne_first_dead_seen_at = nil
      return 0
    end

    $ashborne_first_dead_seen_at ||= Time.now
    Time.now - $ashborne_first_dead_seen_at
  rescue
    0
  end

  def urgent_loot_needed?
    !GameObj.dead.empty?
  rescue
    false
  end

  def loot_safe_to_start?(urgent = false)
    return true if urgent
    return false unless GameObj.targets.empty?

    if Ashborne_toolkit.unstable_dead_creature_present?
      respond "Ashborne is pausing loot briefly because this creature may reform."
      settle_deadline = Time.now + 8
      until Time.now >= settle_deadline
        return false unless GameObj.targets.empty?
        sleep 0.5
      end
      return false unless GameObj.targets.empty?
    end

    true
  rescue
    urgent || GameObj.targets.empty?
  end

  def loot_script(scriptname)
    return nil unless Ashborne_toolkit.group_looter?
    return nil unless GameObj.dead.length >= 1
    urgent_loot = Ashborne_toolkit.urgent_loot_needed?
    return nil unless Ashborne_toolkit.loot_safe_to_start?(urgent_loot)

    waitrt?
    urgent_loot ? Ashborne_toolkit.stance_defensive : Ashborne_toolkit.stance_guarded
    if Script.running? "#{$ashborne_loot_script}"
    # respond "Debug Output - Loot Script is Running."
    else
      if GameObj.dead.length >= 1
        Ashborne_toolkit.put_wand_manager
        $ashborne_looting_active = "1"
        Ashborne_toolkit.publish_group_state(true) if $ashborne_group_ai != "0"
        respond "Ashborne is doing an urgent corpse sweep before bodies decay." if urgent_loot
        do_client ";#{scriptname}"
        sleep 0.1
        held_state = nil
        held_since = nil
        while Script.running?(scriptname.to_s)
          storage_failed, held_state, held_since = Ashborne_toolkit.loot_storage_failure_detected?(scriptname, held_state, held_since)
          if storage_failed
            respond "Ashborne detected #{scriptname} is stuck with loot in hand; returning to town to sell."
            Script.kill(scriptname.to_s)
            Ashborne_toolkit.trigger_loot_storage_emergency
            break
          end

          unsafe_loot = !urgent_loot && !GameObj.targets.empty?
          if unsafe_loot
            respond "Ashborne interrupted #{scriptname} because a hostile creature arrived."
            Script.kill(scriptname.to_s)
            sleep 0.1
            waitrt?
            $ashborne_uac_hands_verified = "0"
            fput "gird"
            Ashborne_toolkit.enforce_uac_empty_hands
            break
          end
          sleep 0.1
        end
        $ashborne_looting_active = "0"
        $ashborne_first_dead_seen_at = nil if GameObj.dead.empty?
        Ashborne_toolkit.publish_group_state(true) if $ashborne_group_ai != "0"

        if $ashborne_aim_fail != 0
          waitrt?
          if $ashborne_current_aim == "0"
            fput "aim clear"
            $ashborne_aim_fail = 0
          else
            fput "aim #{$ashborne_current_aim}"
            $ashborne_aim_fail = 0
          end
        end
        Ashborne_toolkit.get_wands if $ashborne_combat_wands == "1" && $ashborne_use_wands == "1"
      end
    end

    Ashborne_toolkit.cock_support

    # Ashborne_toolkit.get_wand_manager
  ensure
    if $ashborne_looting_active == "1"
      $ashborne_looting_active = "0"
      Ashborne_toolkit.publish_group_state(true) if defined?($ashborne_group_ai) && $ashborne_group_ai != "0"
    end
  end

  def loot_storage_failure_detected?(scriptname, held_state = nil, held_since = nil)
    right = checkright.to_s
    left = checkleft.to_s
    holding = !checkright.nil? || !checkleft.nil?
    unless holding
      return [false, nil, nil]
    end

    current_state = [right, left].join("|")
    if current_state == held_state
      held_since ||= Time.now
    else
      held_state = current_state
      held_since = Time.now
    end

    # ELoot normally pauses itself while go2 carries it between merchants.
    # A pause is only a storage failure when the same item remains in hand.
    stuck = Time.now - held_since >= 6
    [stuck, held_state, held_since]
  rescue
    [false, held_state, held_since]
  end

  def trigger_loot_storage_emergency
    Ashborne_toolkit.stance_defensive
    $ashborne_return_why = "Loot storage failure: hands full or container full; returning to town to sell."
    $ashborne_action = 99
    $ashborne_group_danger_active = "1"
    $ashborne_group_end_sell = "1"
    Ashborne_toolkit.publish_group_danger($ashborne_return_why) if $ashborne_group_ai != "0"
    true
  rescue
    false
  end

  def held_storage_blocker_for_sale
    item = checkright || checkleft
    return "" if item.nil?

    item_name = item.to_s.strip
    return "" if item_name.empty?

    configured_hands = [$ashborne_right_hand_detect, $ashborne_left_hand_detect].map { |value| value.to_s.strip.downcase }
    return "" if configured_hands.include?(item_name.downcase)

    # This recovery is only for loot ELoot left in hand because storage was full.
    # Do not sell obvious personal gear just because it happens to be held.
    return "" if item_name =~ /\b(?:runestaff|staff-of-|spikestar|shield|buckler|weapon harness|scabbard|sheath|cloak|pack|backpack|satchel|tote|container)\b/i

    item_name.sub(/\A(?:a|an|some|the)\s+/i, "").strip
  rescue
    ""
  end

  def sell_held_storage_blocker
    blocker = Ashborne_toolkit.held_storage_blocker_for_sale
    return false if blocker.empty?

    respond "Ashborne is selling the hand-held storage blocker at the pawnshop: #{blocker}."
    Script.kill("go2") if Script.running?("go2")
    Script.run("go2", "pawnshop")
    wait_while { Script.running?("go2") }

    result = dothistimeout "sell #{blocker}", 8, /You offer to sell|hands you|takes your|accepts|You'll have to|isn't interested|You don't seem|What were you referring|Sell what|You can't sell/i
    sleep 0.5
    return true if checkright.nil? && checkleft.nil?

    respond "Ashborne could not clear the hand-held storage blocker with pawnshop sell." if result
    false
  rescue => error
    respond "Ashborne could not sell the hand-held storage blocker: #{error.message}"
    false
  end

