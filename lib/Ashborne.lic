    "roiling_crimson_angargeist" => [110, "Undead", 29954, [29954, 29962, 29963, 30073, 30074, 30075, 29964, 30072, 30071, 30070, 30042, 29955, 29965, 29966, 29973, 29974, 29975, 29990, 29991, 29992, 29993, 29995, 29976, 29978, 29979, 29980, 29981, 29982, 29977, 29983, 29984, 29985, 29987, 29988, 29989, 29986, 29967, 29968, 29969, 29970, 29971, 29972, 30080, 30081, 30082], ['roiling crimson angargeist']],
