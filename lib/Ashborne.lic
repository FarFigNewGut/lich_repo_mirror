ashborne_loot_settings_migrated = false
if ashborne_setting_loot_handoff.to_i == 120
  ashborne_setting_loot_handoff = 30
  Settings[Char.name]['ashborne_setting_loot_handoff'] = 30
  ashborne_loot_settings_migrated = true
end
if ashborne_setting_loot_emergency.to_i == 150
  ashborne_setting_loot_emergency = 40
  Settings[Char.name]['ashborne_setting_loot_emergency'] = 40
  ashborne_loot_settings_migrated = true
elsif ashborne_setting_loot_emergency.to_i == 100
  ashborne_setting_loot_emergency = 40
  Settings[Char.name]['ashborne_setting_loot_emergency'] = 40
  ashborne_loot_settings_migrated = true
end
