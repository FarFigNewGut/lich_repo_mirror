  def bounty_heirloom_flash
    $ashborne_bounty_heirloom_name = "0"
    sleep 0.01

    result = dothistimeout "bounty", 2, /earring|pin|brooch|necklace|circlet|ring|bracer|bracelet/
    if result =~ /earring/
      $ashborne_bounty_heirloom_name = "earring"
      fput "get earring from my #{Vars.lootsack}"
    elsif result =~ /ring/
      $ashborne_bounty_heirloom_name = "ring"
      fput "get ring from my #{Vars.lootsack}"
    elsif result =~ /pin/
      $ashborne_bounty_heirloom_name = "pin"
      fput "get pin from my #{Vars.lootsack}"
    elsif result =~ /brooch/
      $ashborne_bounty_heirloom_name = "brooch"
      fput "get brooch from my #{Vars.lootsack}"
    elsif result =~ /necklace/
      $ashborne_bounty_heirloom_name = "necklace"
      fput "get necklace from my #{Vars.lootsack}"
    elsif result =~ /circlet/
      $ashborne_bounty_heirloom_name = "circlet"
      fput "get circlet from my #{Vars.lootsack}"
    elsif result =~ /bracer/
      $ashborne_bounty_heirloom_name = "bracer"
      fput "get bracer from my #{Vars.lootsack}"
    elsif result =~ /bracelet/
      $ashborne_bounty_heirloom_name = "bracelet"
      fput "get bracelet from my #{Vars.lootsack}"
    else
      nil
      # Ashborne_toolkit.top_menu
      # respond "#{Char.name}, I couldn't determine your heirloom name.  Please share this on Discord if you can.  Thanks!"
      # Ashborne_toolkit.bottom_menu
    end
  end

  def boost_long
    if $ashborne_boost_long == "1"
      if checkmind =~ /saturated|must rest|numbed/
        fput "boost long"
        sleep 0.25
      end
    end
  end

  def boost_loot
    # respond "You're in boost_loot" if $ashborne_qc_testing == "1"

    if $ashborne_boost_loot == "0"
      # respond "Boost Loot is 0" if $ashborne_qc_testing == "1"
      nil
    elsif $ashborne_boost_loot == "minor"
      if Spell.active? "9101"
        # respond "You already have a minor boost active."
        nil
      else
        waitrt?
        fput "boost loot minor"
      end
    elsif $ashborne_boost_loot == "major"
      if Spell.active? "9100"
        # respond "You already have a major boost active."
        nil
      else
        waitrt?
        fput "boost loot major"
      end
    end
  end

  def script_kill
    Script.kill "#{$ashborne_script_one}" if Script.running? "#{$ashborne_script_one}"
    Script.kill "#{$ashborne_script_two}" if Script.running? "#{$ashborne_script_two}"
    Script.kill "#{$ashborne_script_three}" if Script.running? "#{$ashborne_script_three}"

    Script.kill "child2" if Script.running? "child2"
    Ashborne_toolkit.stop_owned_script("song-manager")
    Ashborne_toolkit.stop_owned_script("symbolz")
    Ashborne_toolkit.stop_owned_script("isigns")
    Ashborne_toolkit.stop_owned_script("isigils")
    Ashborne_toolkit.stop_owned_script("reactive")
    Ashborne_toolkit.stop_owned_script("spellactive")
    Ashborne_toolkit.stop_owned_script("signore")
    if $ashborne_started_overwatch == "1" && Script.running?("overwatch")
      Script.kill "overwatch"
      $ashborne_started_overwatch = "0"
    end

    if Spell.active? "1018"
      fput "stop 1018"
    end
  end

  def zone_spell_override_logic
    # This is used mostly for wizards to not use shock spells in certain zones.

    if $ashborne_my_area =~ /wldirge|wlillokeelder/

      if $ashborne_wizard_primary_spell == "9999"
        nil
      elsif $ashborne_wizard_primary_spell == 910
        if Spell[510].known? && Spell[510].affordable?
          $ashborne_wizard_primary_spell = 510
        elsif Spell[1707].known? && Spell[1707].affordable?
          $ashborne_wizard_primary_spell = 1707
        elsif Spell[904].known? && Spell[904].affordable?
          $ashborne_wizard_primary_spell = 904
        elsif Spell[903].known? && Spell[903].affordable?
          $ashborne_wizard_primary_spell = 903
        else
          $ashborne_wizard_primary_spell = "1700b"
        end
      elsif $ashborne_wizard_primary_spell == 901

        if Spell[510].known? && Spell[510].affordable?
          $ashborne_wizard_primary_spell = 510
        elsif Spell[1707].known? && Spell[1707].affordable?
          $ashborne_wizard_primary_spell = 1707
        elsif Spell[904].known? && Spell[904].affordable?
          $ashborne_wizard_primary_spell = 904
        elsif Spell[903].known? && Spell[903].affordable?
          $ashborne_wizard_primary_spell = 903
        else

          $ashborne_wizard_primary_spell = "1700b"
        end

      elsif $ashborne_wizard_primary_spell == 903
        nil
      elsif $ashborne_wizard_primary_spell == 904
        nil
      elsif $ashborne_wizard_primary_spell == "1700b"
        nil
      elsif $ashborne_wizard_primary_spell == 906
        nil
      elsif $ashborne_wizard_primary_spell == 907
        nil
      elsif $ashborne_wizard_primary_spell == 908
        nil
      elsif $ashborne_wizard_primary_spell == 505
        nil
      elsif $ashborne_wizard_primary_spell == 502
        nil
      else
        $ashborne_wizard_primary_spell = "1700b"
      end

    else
      # You're not in a special override zone.
      nil
    end
  end

  def wrack_checker
    if $ashborne_wrack == "0"
      # respond "Wrack Setting is Turned off."
      nil
    else
      # respond "Debug Output - $ashborne_wrack_spirit_cooldown is #{$ashborne_wrack_spirit_cooldown}"
      if $ashborne_wrack_spirit_cooldown == 0
        $ashborne_wrack_spirit_placeholder = 6

        if Spell.active? "9912"
          $ashborne_wrack_spirit_placeholder = $ashborne_wrack_spirit_placeholder + 1
        end

        if Spell.active? "9913"
          $ashborne_wrack_spirit_placeholder = $ashborne_wrack_spirit_placeholder + 1
        end

        if Spell.active? "9914"
          $ashborne_wrack_spirit_placeholder = $ashborne_wrack_spirit_placeholder + 1
        end

        if Spell.active? "9916"
          $ashborne_wrack_spirit_placeholder = $ashborne_wrack_spirit_placeholder + 3
        end

        # respond "Debug Output - My ashborne wrack spirit placeholder is #{$ashborne_wrack_spirit_placeholder}."

        if $ashborne_wrack_spirit_placeholder <= checkspirit
          respond
          respond "#{Char.name} I will try to wrack for you."
          respond
          waitrt?
          waitcastrt?
          sleep 0.10
          do_client ";wrack"
          wait_while { running? "wrack" }
          sleep 0.10
          $ashborne_wrack_spirit_cooldown = 50

        else
          respond
          respond "#{Char.name} with your current active signs and spirit, wracking would kill you."
          respond
          $ashborne_wrack_spirit_cooldown = 50
        end
      end
      $ashborne_wrack_spirit_cooldown = $ashborne_wrack_spirit_cooldown - 1 unless $ashborne_wrack_spirit_cooldown == 0
    end
  end

  def moon_error
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, I couldn't get you to your destination."
    respond
    respond "Most likely because you're not able to walk directly to the Misty Chamber."
    respond
    respond "The easiest way to fix this is to head to room 6505 - Misty Chamber - manually and try this zone again."
    respond
    respond "I recommend having a Voln Master fog you there and then set a ring for future visits."
    respond
    respond "You will need Arcane Symbols ranks usually 15-20 ish to hunt in the Broken Lands."
    respond
    respond "If you feel this message is an error, please provide details on Ashborne Discord Community.  https://discord.gg/NEX6B5DFCX "
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.script_kill
    exit
  end

  def misty_check
    Script.run('go2', '6505')
    pause 1
    if Ashborne_toolkit.current_room_id == 6505
      nil
    else
      Ashborne_toolkit.moon_error
    end
  end

  def misty_logic
    if Spell[9826].known?
      # You have sym seeking so just go directly to your room.
    end

    if checkarea == "The Broken Lands"
      # You're already on the moon."
    end

    if $ashborne_my_area =~ /misty/
      Ashborne_toolkit.misty_check
    end

    if $ashborne_my_area =~ /moonfigure/
      if Spell[9826].known?
        Script.run('go2', '6626')
        pause 1
        if Ashborne_toolkit.current_room_id == 6626
          nil
        else
          Ashborne_toolkit.moon_error
        end
