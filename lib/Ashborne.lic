    if ashborne_setting_group_one != "0" && ashborne_setting_group_two != "0" && ashborne_setting_group_three != "0" && ashborne_setting_group_four != "0" && ashborne_setting_group_five != "0" && ashborne_setting_group_six != "0" && ashborne_setting_group_seven != "0" && ashborne_setting_group_eight != "0" && ashborne_setting_group_nine != "0"
