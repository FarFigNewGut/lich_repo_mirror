        if Stats.level == 100
          $ashborne_709_cooldown = 5
        elsif Stats.level >= 40
          $ashborne_709_cooldown = 5
        elsif Stats.level >= 30
          $ashborne_709_cooldown = 7
        elsif Stats.level >= 20
          $ashborne_709_cooldown = 9
        elsif Stats.level >= 9
          $ashborne_709_cooldown = 10
        end

      end


      if $ashborne_708_cooldown == 0
	  
		#Hex during limb disruption
		waitcastrt?
		fput "stance guarded"
		Spell[715].cast() if Ashborne_toolkit.ability_allowed?("spell", 715) && Spell[715].known? && Stats.level >= 15 && Spell[715].affordable?
		waitcastrt?
        Spell[708].cast() if Ashborne_toolkit.ability_allowed?("spell", 708) && Spell[708].known? && Stats.level >= 8 && Spell[708].affordable? && Skills.spellaiming / 2 - 1 >= Stats.level
        $ashborne_708_cooldown = 10
      end




      if $ashborne_turbo_crowd_control == "1"
        # Shutting off Turbo mode to help a user debug just in case that setting got turned on.
        # This setting is wonky and was thrown together quickly, I suspect it may be causing issues here.
        nil
      else
        nil
        # if $ashborne_turbo_cc_cooldown == 0

        #		waitcastrt?
        #		Spell[709].cast() if Spell[709].known? && Stats.level >= 9 && Spell[709].affordable?
        #		$ashborne_turbo_cc_cooldown = 10

        # elsif $ashborne_turbo_cc_cooldown == 5
        #		waitcastrt?
        #		Spell[410].cast() if Spell[410].known? && Stats.level >= 10 && Spell[410].affordable?
        # end
      end


    end

    # Cleric Crowd Control

    if Stats.prof == "Cleric" && Stats.level - 30 < $ashborne_my_area_level

      if $ashborne_cc_cooldown == 0

        # 212 Boost
        waitcastrt?
        Spell[212].cast() if Ashborne_toolkit.ability_allowed?("spell", 212) && Spell[212].known? && Stats.level >= 12 && Spell[212].affordable?

        waitcastrt?
        Spell[320].cast() if Ashborne_toolkit.ability_allowed?("spell", 320) && Spell[320].known? && Stats.level >= 20 && Spell[320].affordable? unless Spell.active? "399"
        $ashborne_cc_cooldown = 10

      elsif $ashborne_cc_cooldown == 5
        waitcastrt?
        Spell[317].cast() if Ashborne_toolkit.ability_allowed?("spell", 317) && Spell[317].known? && Stats.level >= 40 && Spell[317].affordable?
      end
    end

    # Wizard Crowd Control

    if Stats.prof == "Wizard" && Stats.level - 30 < $ashborne_my_area_level

      if $ashborne_cc_cooldown == 0

        waitcastrt?
        Spell[917].cast() if Ashborne_toolkit.ability_allowed?("spell", 917) && Spell[917].known? && Stats.level >= 17 && Spell[917].affordable? && percentmana >= 60 && Ashborne_toolkit.group_spell_claim("917")
        if Spell[917].known? && Stats.level >= 17 && Spell[917].affordable? && percentmana >= 60
          $ashborne_cc_cooldown = 7
        else
          $ashborne_cc_cooldown = 6
        end

      elsif $ashborne_cc_cooldown == 1

        if percentmana <= 80
          Spell[516].cast() if Ashborne_toolkit.ability_allowed?("spell", 516) && Spell[516].known? && Stats.level >= 16 && Spell[516].affordable?
        end

      elsif $ashborne_cc_cooldown == 4

        if percentmana <= 80
          Spell[516].cast() if Ashborne_toolkit.ability_allowed?("spell", 516) && Spell[516].known? && Stats.level >= 16 && Spell[516].affordable?
        end

        Ashborne_toolkit.turtle_502


      elsif $ashborne_cc_cooldown == 5
        # Setup for STOMP
        #
        if $ashborne_stomp == "1"
          # Do This
          result = dothistimeout "stomp", 2, /stamp your feet|ground begins to shake/
          if result =~ /stamp your feet/
            waitcastrt?
            fput "incant 909 channel" if Ashborne_toolkit.ability_allowed?("spell", 909) && Spell[909].known? && Stats.level >= 9 && Spell[909].affordable?
            fput "stomp"
          # $ashborne_cc_cooldown = 5
          elsif result =~ /ground begins to shake/
            # $ashborne_cc_cooldown = 5
          end

        else
          # respond "Debug output - Wizard tap dancing."
          result = dothistimeout "tap", 2, /tap your foot impatiently|ground begins to shake/
          if result =~ /tap your foot impatiently/
            waitcastrt?
            fput "incant 909 channel" if Ashborne_toolkit.ability_allowed?("spell", 909) && Spell[909].known? && Stats.level >= 9 && Spell[909].affordable?
            fput "tap"
          # $ashborne_cc_cooldown = 5
          elsif result =~ /ground begins to shake/
            # $ashborne_cc_cooldown = 5
          end
        end
      end

      if Skills.elair >= 20 && Spell[505].known? && Skills.spellaiming >= 1
        Ashborne_toolkit.stance_offensive
        if Spell.active? "515"
          Ashborne_toolkit.stand_check
          fput "incant 505 evoke" if Ashborne_toolkit.ability_allowed?("spell", 505) && Spell[505].known? && Spell[505].affordable? && Spell[505].affordable? && checkmana >= 5
          Ashborne_toolkit.stand_check
          waitcastrt?
          fput "incant 505 evoke" if Ashborne_toolkit.ability_allowed?("spell", 505) && Spell[505].known? && Spell[505].affordable? && Spell[505].affordable? && checkmana >= 5
          Ashborne_toolkit.stand_check
          waitcastrt?
          fput "incant 505 evoke" if Ashborne_toolkit.ability_allowed?("spell", 505) && Spell[505].known? && Spell[505].affordable? && Spell[505].affordable? && checkmana >= 5
          waitcastrt?
          Ashborne_toolkit.stance_guarded

        else
          Ashborne_toolkit.stand_check
          fput "incant 505 evoke" if Ashborne_toolkit.ability_allowed?("spell", 505) && Spell[505].known? && Spell[505].affordable? && Spell[505].affordable? && checkmana >= 5
          Ashborne_toolkit.stance_guarded
        end
      end
    end




    # Ranger Crowd Control

    if Stats.prof == "Ranger" && Stats.level - 30 < $ashborne_my_area_level

      # respond "Debug Output - $ashborne_cc_cooldown is #{$ashborne_cc_cooldown}"

      if $ashborne_cc_cooldown == 0

        waitcastrt?
        if checkoutside
          Ashborne_toolkit.stance_offensive
          Spell[610].cast() if Ashborne_toolkit.ability_allowed?("spell", 610) && Spell[610].known? && Stats.level >= 10 && Spell[610].affordable? && Ashborne_toolkit.group_spell_claim("610", true)
          Ashborne_toolkit.stance_guarded
          $ashborne_my_vine = "1"
          $ashborne_cc_cooldown = 20
        elsif Spell.active? "625"
          Ashborne_toolkit.stance_offensive
          Spell[610].cast() if Ashborne_toolkit.ability_allowed?("spell", 610) && Spell[610].known? && Stats.level >= 10 && Spell[610].affordable? && Ashborne_toolkit.group_spell_claim("610", true)
          Ashborne_toolkit.stance_guarded
          $ashborne_my_vine = "1"
          $ashborne_cc_cooldown = 20
        else
          $ashborne_cc_cooldown = 20
        end
      elsif $ashborne_cc_cooldown == 5
		  if $ashborne_my_area =~ /wlyeti|wlminotaur/
			nil
		  else
			waitcastrt?
			Spell[616].cast() if Ashborne_toolkit.ability_allowed?("spell", 616) && Spell[616].known? && Stats.level >= 16 && Spell[616].affordable?
		  end

      elsif $ashborne_cc_cooldown == 7

        waitcastrt?
        Spell[607].cast() if Ashborne_toolkit.ability_allowed?("spell", 607) && Spell[607].known? && Stats.level >= 7 && Spell[607].affordable?

      elsif $ashborne_cc_cooldown == 10

        waitcastrt?
        Spell[603].cast() if Ashborne_toolkit.ability_allowed?("spell", 603) && Spell[603].known? && Stats.level >= 3 && Spell[603].affordable?

      elsif $ashborne_cc_cooldown == 15

        waitcastrt?
        multifput "prep 609", "cast target" if Ashborne_toolkit.ability_allowed?("spell", 609) && Spell[609].known? && Stats.level >= 9 && Spell[609].affordable?

      elsif $ashborne_cc_cooldown == 18

        waitcastrt?
        multifput "prep 611", "cast target" if Ashborne_toolkit.ability_allowed?("spell", 611) && Spell[611].known? && Stats.level >= 50 && Spell[611].affordable?

      end
    end


    # Bard Crowd Control

    if Stats.prof == "Bard" && Stats.level - 30 < $ashborne_my_area_level

      if $ashborne_cc_cooldown == 0

        waitcastrt?
        if $ashborne_group_noise == "1" && Ashborne_toolkit.ability_allowed?("spell", 1017) && Spell[1017].known? && Stats.level >= 17 && Spell[1017].affordable?
          if Ashborne_toolkit.group_spell_claim("1017", true)
            Ashborne_toolkit.group_noise_ready?
            waitcastrt?
            Spell[1017].cast()
          end
        else
          Spell[1008].cast() if Ashborne_toolkit.ability_allowed?("spell", 1008) && Spell[1008].known? && Stats.level >= 8 && Spell[1008].affordable? && Ashborne_toolkit.group_spell_claim("1008")
        end
        $ashborne_cc_cooldown = 10

      elsif $ashborne_cc_cooldown == 5

        waitcastrt?
        Spell[1005].cast() if Ashborne_toolkit.ability_allowed?("spell", 1005) && Spell[1005].known? && Stats.level >= 5 && Spell[1005].affordable?


      elsif $ashborne_cc_cooldown == 8

        waitcastrt?
        Spell[1002].cast() if Ashborne_toolkit.ability_allowed?("spell", 1002) && Spell[1002].known? && Stats.level >= 2 && Spell[1002].affordable?
      end
    end


    # Monk Crowd Control

    if Stats.prof == "Monk" && Stats.level - 30 < $ashborne_my_area_level

      if $ashborne_cc_cooldown == 0

        waitcastrt?
        Spell[1207].cast() if Ashborne_toolkit.ability_allowed?("spell", 1207) && Spell[1207].known? && Stats.level >= 7 && Spell[1207].affordable? && Ashborne_toolkit.group_spell_claim("1207")
        $ashborne_cc_cooldown = 10

      elsif $ashborne_cc_cooldown == 5

        nil

      end
    end


    # Paladin Crowd Control

    if Stats.prof == "Paladin" && Stats.level - 30 < $ashborne_my_area_level

      if $ashborne_cc_cooldown == 0
        waitcastrt?
        Spell[1615].cast() if Ashborne_toolkit.ability_allowed?("spell", 1615) && !Ashborne_toolkit.group_spell_claimed?("shield_throw", true) && Spell[1615].known? && Stats.level >= 15 && Spell[1615].affordable? && Ashborne_toolkit.group_spell_claim("1615")
        $ashborne_cc_cooldown = 10

      elsif $ashborne_cc_cooldown == 5
        waitcastrt?
        Spell[1603].cast() if Ashborne_toolkit.ability_allowed?("spell", 1603) && Spell[1603].known? && Stats.level >= 3 && Spell[1603].affordable?

      elsif $ashborne_cc_cooldown == 10
        waitcastrt?
        fput "incant 1614 closed" if Ashborne_toolkit.ability_allowed?("spell", 1614) && Spell[1614].known? && Stats.level >= 20 && Spell[1614].affordable?


      end
    end






    $ashborne_709_cooldown = $ashborne_709_cooldown - 1 unless $ashborne_709_cooldown == 0
    $ashborne_708_cooldown = $ashborne_708_cooldown - 1 unless $ashborne_708_cooldown == 0
