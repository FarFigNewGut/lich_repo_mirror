    "squamous_reptilian_mutant" => [109, "Living", 29949, [29949, 29950, 29951, 29952, 29953, 29956, 29957, 29960, 29958, 29959, 30076, 30077, 30078, 30079, 29961, 30031, 30032, 30033, 30034, 30035, 30036, 30041, 30040, 30039, 30038, 30043, 30044, 30045, 30049, 30050, 30051, 30052, 30057, 30056, 30055, 30053, 30054, 30058, 30059, 30046, 30047, 30037], ['squamous reptilian mutant']],
