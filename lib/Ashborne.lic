ashborne_upkeep_buffs = proc {
  sleep 0.2

  if ashborne_setting_upkeep140 == "0"
    nil
  elsif $ashborne_disable_140 == "1"
    nil
  else
    # Divergence
    # if $ashborne_divergence == "1"
    #	if $ashborne_140_divergence == "1"
    #		nil
    #	else
    #		Spell[140].cast() if Spell[140].known? && Stats.level >= 40 && Spell[140].affordable?  unless Spell.active? "140"
    #		$ashborne_140_divergence = "1"
    #	end
    # else

    if $ashborne_140_cooldown == "1"
      nil
    else
      Spell[140].cast() if Spell[140].known? && Stats.level >= 40 && Spell[140].affordable? unless Spell.active? "140"
      $ashborne_140_cooldown = "1"
      $ashborne_future_140 = Time.now.to_i + 270
    end

  end

  if ashborne_setting_upkeep240 == "0"
    nil
  elsif $ashborne_disable_240 == "1"
    nil
  else
    # Divergence
    # if $ashborne_divergence == "1"
    #	if $ashborne_240_divergence == "1"
    #		nil
    #	else
    #		Spell[240].cast() if Spell[240].known? && Stats.level >= 40 && Spell[240].affordable?  unless Spell.active? "240"
    #		$ashborne_240_divergence = "1"
    #	end
    # else
    Spell[240].cast() if Spell[240].known? && Stats.level >= 40 && Spell[240].affordable? unless Spell.active? "240"
    # end
  end

  if ashborne_setting_upkeep515 == "0"
    nil
  else
    if Stats.prof != "Wizard"
      nil
    else
      waitcastrt?
      if Spell.active? "599"
        nil
      elsif Spell.active? "515"
        nil
      else
        Spell[515].cast() if Spell[515].known? && Spell[515].affordable?
        sleep 0.25
      end
    end
  end

  if ashborne_setting_upkeep506 == "0"
    nil
  else
    waitcastrt?
    if Spell.active? "506"
      nil
    else
      Spell[506].cast() if Spell[506].known? && Spell[506].affordable? && Stats.level >= 6
      sleep 0.25 if Spell[506].known? && Spell[506].affordable? && Stats.level >= 6
    end
  end

  if ashborne_setting_upkeep650 == "0"
    nil
  else
    if Stats.prof != "Ranger"
      nil
    else
      Spell[650].cast() if Spell[650].known? && Stats.level >= 50 && Spell[650].affordable? unless Spell.active? "650"
      sleep 0.25
    end
  end


  if ashborne_setting_upkeep919 == "0"
    nil
  else
    if Stats.prof != "Wizard"
      nil
    elsif $ashborne_disable_919 == "1"
      nil
    else

      if $ashborne_919_cooldown == "1"
        nil
      else
        Spell[919].cast() if Spell[919].known? && Stats.level >= 19 && Spell[919].affordable? unless Spell.active? "919"
        $ashborne_919_cooldown = "1"
        $ashborne_future_919 = Time.now.to_i + 180
      end

    end
  end

  # Wizards >= 30 will upkeep 515
  if Stats.prof == "Wizard" && Stats.level >= 30
    waitcastrt?
    if Spell.active? "599"
      nil
    elsif Spell.active? "515"
      nil
    else
      sleep 0.25
      Spell[515].cast() if Spell[515].known? && Spell[515].affordable?
    end
  end

  if ashborne_setting_upkeep1035 == "0"
    nil
  else
    Spell[1035].cast() if Spell[1035].known? && Stats.level >= 35 && Spell[1035].affordable? unless Spell.active? "1035"

  end

  # Dangerous Upkeep 140

  # if $ashborne_my_area =~ /rift4|northscatter|southscatter|tiotfnorth|teraswelemental|terasradical|terassentry/
  #	if $ashborne_disable_140 == "1"
  #		nil
  #	else
  #		waitcastrt?
  #		Spell[140].cast() if Spell[140].known? && Stats.level >= 40 && Spell[140].affordable?  unless Spell.active? "140"
  #		waitcastrt?
  #	end
  # end

  # Dangerous Upkeep 240
  # if $ashborne_my_area =~ /rift4|northscatter|southscatter|tiotfnorth/
  #	if $ashborne_disable_240 == "1"
  #		nil
  #	else
  #		waitcastrt?
  #		Spell[240].cast() if Spell[240].known? && Stats.level >= 40 && Spell[240].affordable?  unless Spell.active? "240"
  #		waitcastrt?
  #	end
  # end

  # Dangerous Upkeep 919
  # if $ashborne_my_area =~ /northscatter|southscatter|rift1|rift2|rift3|rift4|rift5|wlillokeelder|tiotfnorth|tiithzir|tiotfwest/
  #	if $ashborne_disable_919 == "1"
  #		nil
  #	else
  #		waitcastrt?
  #		Spell[919].cast() if Spell[919].known? && Stats.level >= 19 && Spell[919].affordable?  unless Spell.active? "919"
  #		waitcastrt?
  #	end
  # end
}


ashborne_run_script = proc {
  custom_hunt_scripts = [
    ashborne_setting_run_script,
    ashborne_setting_run_script2,
    ashborne_setting_run_script3
  ].reject { |script_name| script_name == "0" }

  if Ashborne_toolkit.noise_lockdown?
    unless custom_hunt_scripts.empty?
      respond "Noise lockdown is skipping custom hunt scripts: #{custom_hunt_scripts.join(', ')}."
    end
    Ashborne_toolkit.stop_noise_lockdown_casting_helpers
  else
    custom_hunt_scripts.each do |script_name|
      Ashborne_toolkit.start_owned_script(script_name)
    end
  end

  if $ashborne_my_style =~ /1|2|3|4|5|6|7|8/
    Ashborne_toolkit.start_owned_script("reactive")
  end

  if $ashborne_group_ai == "1" && Script.exists?("overwatch") && !Script.running?("overwatch")
    do_client ";overwatch"
    $ashborne_started_overwatch = "1"
  end


  if ashborne_setting_character_society =~ /Voln/ && Ashborne_toolkit.casting_allowed?
    Ashborne_toolkit.start_owned_script("symbolz") unless $ashborne_no_society == "1"
    Ashborne_toolkit.start_owned_script("signore") unless $ashborne_no_society == "1"
  end

  if $ashborne_society_spellactive == "1" && Ashborne_toolkit.casting_allowed?
    Ashborne_toolkit.start_owned_script("spellactive") unless $ashborne_no_society == "1"
  else
    if ashborne_setting_character_society =~ /Gos/ && Ashborne_toolkit.casting_allowed?
      Ashborne_toolkit.start_owned_script("isigils") unless $ashborne_no_society == "1"
      Ashborne_toolkit.start_owned_script("signore") unless $ashborne_no_society == "1"
    end
    if ashborne_setting_character_society =~ /Col/ && Ashborne_toolkit.casting_allowed?
      Ashborne_toolkit.start_owned_script("isigns") unless $ashborne_no_society == "1"
      Ashborne_toolkit.start_owned_script("signore") unless $ashborne_no_society == "1"
    end
  end
  if Stats.prof == "Bard"
    if Ashborne_toolkit.noise_lockdown?
      Script.kill "song-manager" if Script.running? "song-manager"
      $ashborne_owned_scripts.delete("song-manager")
    else
      Ashborne_toolkit.start_owned_script("song-manager")
    end
  end
}
ashborne_kill_script = proc {
  Ashborne_toolkit.stop_owned_script(ashborne_setting_run_script)
  Ashborne_toolkit.stop_owned_script(ashborne_setting_run_script2)
  Ashborne_toolkit.stop_owned_script(ashborne_setting_run_script3)

  if $ashborne_started_overwatch == "1" && Script.running?("overwatch")
    Script.kill "overwatch"
    $ashborne_started_overwatch = "0"
  end

  if $ashborne_my_style =~ /1|2|3|4|5|6|7|8/
    Ashborne_toolkit.stop_owned_script("reactive")
  end

  if ashborne_setting_character_society =~ /Voln/
    Ashborne_toolkit.stop_owned_script("symbolz")
    Ashborne_toolkit.stop_owned_script("signore")
  end
  if ashborne_setting_character_society =~ /Gos/
    Ashborne_toolkit.stop_owned_script("isigils")
    Ashborne_toolkit.stop_owned_script("signore")
  end
  if ashborne_setting_character_society =~ /Col/
    Ashborne_toolkit.stop_owned_script("isigns")
    Ashborne_toolkit.stop_owned_script("signore")
  end

  if $ashborne_society_spellactive == "1"
    Ashborne_toolkit.stop_owned_script("spellactive")
  end

  if Stats.prof == "Bard"
    Ashborne_toolkit.stop_owned_script("song-manager")

    if Spell.active? "1018"
      fput "stop 1018"
    end

  end
}
ashborne_ready_gear = proc {
  if $ashborne_my_style == "9" && ashborne_setting_use_empty != "0"
    Ashborne_toolkit.ashborne_stow_all
  else
    Ashborne_toolkit.ashborne_stow_all
    $ashborne_uac_hands_verified = "0"
    fput "gird"
    Ashborne_toolkit.enforce_uac_empty_hands
  end

}

ashborne_group_check = proc {
  if $ashborne_group_ai == "1"
    # respond "Debug Output - Group Mode Is Active, checking for group members."

    # if $ashborne_my_area =~ /rift1|rift2|rift3|rift4|rift5|northscatter|southscatter/
    # Spell[213].cast() if Spell[213].known? && Stats.level >= 13 && Spell[213].affordable?
    # end

    ashborne_group_wait_counter = 0
    until Ashborne_toolkit.group_members_present?
      Ashborne_toolkit.publish_group_leader_room
      Ashborne_toolkit.group_follow_sync

      respond "Waiting for group members to arrive."
      Ashborne_toolkit.defend_while_waiting_for_group unless GameObj.targets.empty?
      Ashborne_toolkit.rally_group_members
      ashborne_group_wait_counter = 1
      sleep 3
    end
    Ashborne_toolkit.launch_group_followers(Ashborne_toolkit.configured_group_members) if ashborne_group_wait_counter == 1

    # Ashborne_toolkit.ashborne_path_cleanup

    if ashborne_setting_group_nine == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_nine}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_nine}"
      end
    end

    if ashborne_setting_group_eight == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_eight}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_eight}"
      end
    end

    if ashborne_setting_group_seven == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_seven}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_seven}"
      end
    end

    if ashborne_setting_group_six == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_six}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_six}"
      end
    end

    if ashborne_setting_group_five == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_five}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_five}"
      end
    end

    if ashborne_setting_group_four == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_four}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_four}"
      end
    end

    if ashborne_setting_group_three == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_three}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_three}"
      end
    end

    if ashborne_setting_group_two == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_two}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_two}"
      end
    end

    if ashborne_setting_group_one == "0"
      nil
    else
      if checkpcs "#{ashborne_setting_group_one}"
        $ashborne_group_counter = $ashborne_group_counter + 1
        fput "hold #{ashborne_setting_group_one}"
      end
    end

    Array($ashborne_additional_group_members).each do |member_name|
      if checkpcs(member_name)
        $ashborne_group_counter += 1
        fput "hold #{member_name}"
      end
    end
  else
    nil
  end

  if $ashborne_group_counter == $ashborne_group_array.length
    nil
  else
    respond "Not all group members are here.  Holding hands and waiting for more."
    $ashborne_group_counter = 0
    Ashborne_toolkit.defend_while_waiting_for_group unless GameObj.targets.empty?
    sleep 3
  end
}

ashborne_soft_group = proc {
  Ashborne_toolkit.publish_group_ready_state(false) if $ashborne_group_ai == "1"
  if ashborne_setting_group_nine == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_nine}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_nine} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_eight == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_eight}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_eight} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_seven == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_seven}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_seven} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_six == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_six}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_six} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_five == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_five}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_five} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_four == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_four}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_four} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_three == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_three}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_three} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_two == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_two}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_two} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  if ashborne_setting_group_one == "0"
    nil
  else
    if checkpcs "#{ashborne_setting_group_one}"
      nil
    else
      respond "#{Char.name}, I'm missing #{ashborne_setting_group_one} from the group."
      $ashborne_group_counter = 0
      sleep 1
    end
  end

  Array($ashborne_additional_group_members).each do |member_name|
    next if checkpcs(member_name)

    respond "#{Char.name}, I'm missing #{member_name} from the group."
    $ashborne_group_counter = 0
    sleep 1
  end
}

ashborne_group_cluster = proc {
  if $ashborne_group_ai == "1"
    ashborne_soft_group.call
    if $ashborne_group_counter == 0
      Ashborne_toolkit.defend_while_waiting_for_group unless GameObj.targets.empty?
      until $ashborne_group_counter == $ashborne_group_array.length
        ashborne_group_check.call
        sleep 0.5

        # Area metadata is shared through Ashborne's local data files.

      end
    end
    Ashborne_toolkit.publish_group_leader_room
    Ashborne_toolkit.publish_group_ready_state(true)
  end
}
ashborne_group_support = proc {
  if $ashborne_group_ai == "0"
    nil
  else

    if $ashborne_group_empath != "0"
      nil
    else
      if Stats.prof == "Empath" && $ashborne_group_ai != "0"
        sleep 0.5
        Ashborne_toolkit.publish_group_state(true) unless $ashborne_captain == "#{Char.name}"
        $ashborne_group_empath = "#{Char.name}"
      end
    end

    Ashborne_toolkit.rescue_current_group_danger

    if !checkstunned && !checkdead
      Ashborne_toolkit.group_session_names.each do |member_name|
        next if member_name.to_s.casecmp(Char.name.to_s).zero?

        pc = Ashborne_toolkit.visible_group_pc(member_name)
        next if pc.nil?
        next unless pc.status.to_s =~ /stun|lying down|prone|kneeling/i

        Ashborne_toolkit.rescue_visible_groupmate(member_name, "visible groupmate needs help")
      end
      pause 0.1
    end

    if $ashborne_buff_padding >= 0 && $ashborne_buff_padding <= 9
      $ashborne_buff_padding = $ashborne_buff_padding + 1

    elsif $ashborne_buff_padding >= 10

      if Skills.slblessings >= 65 && Spell[215].known? && Spell[215].affordable?
        if $ashborne_group_upkeep215 == "0"
          waitcastrt?
          Spell[215].cast() if Spell[215].known? && Stats.level >= 15 && Spell[215].affordable?
          $ashborne_group_upkeep215 = "1"
        end
      end

      if Skills.slblessings >= 50 && Spell[211].known? && Spell[211].affordable?
        if $ashborne_group_upkeep211 == "0"
          waitcastrt?
          Spell[211].cast() if Spell[211].known? && Stats.level >= 11 && Spell[211].affordable?
          $ashborne_group_upkeep211 = "1"
        end
      end

      pause 0.1

    end

  end
}



ashborne_setup = proc {
  ashborne_load_settings.call unless $ashborne_consider_setup == "1"

  respond "Hello #{Char.name}!  Your profession is #{Stats.prof} and you're level #{Stats.level}."
  respond "Society: #{ashborne_setting_character_society}"
  respond "Version: #{ashborne_version}"
  if ashborne_setting_weapon_attune == "0"
    nil
  else
    respond
    respond "Weapon attunement: #{ashborne_setting_weapon_attune}"
    respond
  end
  respond
  respond "Left Hand Equipment: #{ashborne_setting_left_hand_detect}" unless ashborne_setting_left_hand_detect == "0"
  respond "Right Hand Equipment: #{ashborne_setting_right_hand_detect}" unless ashborne_setting_right_hand_detect == "0"
  respond
  respond "Use ;ashborne help for commands and setup options."
  respond

  # Force Creature Skip
  if ashborne_setting_force_skip_list == "0"
    nil
  else
    if ashborne_setting_force_skip_list != "0" && ashborne_setting_force_skip_list2 != "0" && ashborne_setting_force_skip_list3 != "0"
      respond "You're currently ignoring these creatures: #{ashborne_setting_force_skip_list}, #{ashborne_setting_force_skip_list2}, #{ashborne_setting_force_skip_list3}."
    elsif ashborne_setting_force_skip_list != "0" && ashborne_setting_force_skip_list2 != "0" && ashborne_setting_force_skip_list3 == "0"
      respond "You're currently ignoring these creatures: #{ashborne_setting_force_skip_list}, #{ashborne_setting_force_skip_list2}."
    else
      respond "You're currently ignoring these creatures: #{ashborne_setting_force_skip_list}."
    end
  end

  # Compound Ignore  (Skip earth elementals, but fight greaters or vice versa.)

  if ashborne_setting_compound_ignore == "0"
    nil
  else
    respond "You're currently ignoring this compound creature: #{ashborne_setting_compound_ignore}."
  end

  # Zonescripts

  if ashborne_setting_zonescripts == "0"
    nil
  else
    respond "You will wait until you reach the hunting zone to activate scripts such as society upkeep, song-manager or setup chosen scripts."
  end

  # Run Scripts
  if ashborne_setting_run_script == "0"
    nil
  else
    if ashborne_setting_run_script != "0" && ashborne_setting_run_script2 != "0" && ashborne_setting_run_script3 != "0"
      respond "You will run these scripts during hunting: #{ashborne_setting_run_script}, #{ashborne_setting_run_script2}, #{ashborne_setting_run_script3}."
    elsif ashborne_setting_run_script != "0" && ashborne_setting_run_script2 != "0" && ashborne_setting_run_script3 == "0"
      respond "You will run these scripts during hunting: #{ashborne_setting_run_script}, #{ashborne_setting_run_script2}."
    else
      respond "You will run these scripts during hunting: #{ashborne_setting_run_script}."
    end
  end

  # Empath Self Heal
  if ashborne_setting_empath_self_heal == "0"
    nil
  else
    if Stats.prof == "Empath"
      respond "With enough resources, you will use healing spells if injured before returning to town."
    else
      nil
    end
  end

  if ashborne_setting_voln_fog == "0"
    nil
  else
    if ashborne_setting_character_society == "Voln"
      respond "You will use the Symbol of Return when finishing a hunt."
    else
      nil
    end
  end

  if ashborne_setting_130_fog == "0"
    nil
  else
    if Spell[130].known? && Stats.level >= 30
      respond "You will use Spirit Guide when finishing a hunt."
    else
      nil
    end
  end

  if ashborne_setting_1020_fog == "0"
    nil
  else
    if Spell[1020].known? && Stats.level >= 20
      respond "You will use Traveler's Song when finishing a hunt."
    else
      nil
    end
  end

  if ashborne_setting_hunt_while_fried == "0"
    nil
  else
    respond "You will continue to hunt while Saturated or Fried."
  end

  if ashborne_setting_value_stamina == 10
    nil
  else
    respond "Your resting stamina value is #{$ashborne_value_stamina} percent."
  end

  if ashborne_setting_value_encumbrance == 50
    nil
  else
    respond "Your resting encumbrance value is #{$ashborne_value_encumbrance} percent."
  end

  if ashborne_setting_disable_encumbrance == "0"
    nil
  else
    respond "You will continue to hunt while encumbered."
  end

  if ashborne_setting_disable_stamina == "0"
    nil
  else
    respond "You will continue to hunt with low stamina."
  end

  if ashborne_setting_disable_mana == "0"
    nil
  else
    respond "You will continue to hunt with low mana."
  end

  if ashborne_setting_defensive_stance == "0"
    nil
  else
    respond "You will use stance #{ashborne_setting_defensive_stance} as your defensive stance."
  end

  if ashborne_setting_offensive_stance == "0"
    nil
  else
    respond "You will use stance #{ashborne_setting_offensive_stance} as your offensive stance."
  end

  if ashborne_setting_society_spellactive == "0"
    nil
  else
    respond "Advanced: Use spellactive.lic instead of isigns or isigils."
  end


  if ashborne_setting_wrack == "0"
    nil
  else
    if Spell[9918].known? && $ashborne_my_society == "Col"
      respond "You will use sign of wracking when low on mana if you have sufficient spirit."
    else
      nil
    end
  end

  if ashborne_setting_deedmana == "0"
    nil
  elsif Society.status == "Council of Light"
    nil
  elsif Society.status == "Guardians of Sunfist"
    nil
  elsif ashborne_setting_deedmana == "1" && $ashborne_my_society == "Voln"
    respond "You will use deeds to restore mana using the Symbol of Mana."
  else
    respond "Ashborne found an invalid deed-mana configuration. Run ;ashborne doctor."

