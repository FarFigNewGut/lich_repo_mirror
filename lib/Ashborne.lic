# OOP

module Ashborne_toolkit
  extend self

  def purge_removed_room_ownership_methods
    stale_methods = [
      ["anti", "poach", "guard"].join("_").to_sym,
      ["huntpro", "anti", "poach", "guard"].join("_").to_sym,
      ["huntpro", "visible", "non", "group", "players"].join("_").to_sym
    ]
    toolkits = [Ashborne_toolkit]
    toolkits << Huntpro_toolkit if defined?(Huntpro_toolkit)
    toolkits.each do |toolkit|
      stale_methods.each do |method_name|
        toolkit.send(:remove_method, method_name) if toolkit.instance_methods(false).include?(method_name)
        singleton = toolkit.singleton_class
        singleton.send(:remove_method, method_name) if singleton.instance_methods(false).include?(method_name)
      end
    end
    nil
  rescue
    nil
  end

