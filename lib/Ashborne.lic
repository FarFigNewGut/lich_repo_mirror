  def feat_control
    Ashborne_toolkit.paladin_feat_control

    if $ashborne_feat_shadowdance == "1"
      waitrt?
      fput "feat shadowdance" if percentstamina >= 50
      waitrt?
    end

    if $ashborne_feat_silentstrike == "1"
      waitrt?
      Ashborne_toolkit.hide_time
      Ashborne_toolkit.stance_offensive
      fput "feat silentstrike target" if percentstamina >= 50
      waitrt?
      Ashborne_toolkit.hide_time
      Ashborne_toolkit.stance_offensive
      fput "feat silentstrike target" if percentstamina >= 50
      waitrt?
    end

    if $ashborne_feat_mysticstrike == "1"
      waitrt?
      fput "feat mysticstrike target" if percentstamina >= 50
      waitrt?
    end

    if $ashborne_feat_dispelmagic == "1"

      fput "feat dispel" if $ashborne_feat_dispelmagic_cooldown == 0
      $ashborne_feat_dispelmagic_cooldown = 10 if $ashborne_feat_dispelmagic_cooldown == 0
    end

    if $ashborne_feat_absorbmagic == "1"
      fput "feat absorb" if $ashborne_feat_absorbmagic_cooldown == 0
      $ashborne_feat_absorbmagic_cooldown = 30
    end

    $ashborne_feat_absorbmagic_cooldown = $ashborne_feat_absorbmagic_cooldown - 1 unless $ashborne_feat_absorbmagic_cooldown == 0
    $ashborne_feat_dispelmagic_cooldown = $ashborne_feat_dispelmagic_cooldown - 1 unless $ashborne_feat_dispelmagic_cooldown == 0
  end

  def paladin_feat_control
    return unless Stats.prof == "Paladin"

    target = GameObj.target
    return if target.nil? || target.status == "dead"

    feat_choices = [["Chastise", "chastise"]]
    feat_choices << ["Excoriate", "excoriate"] if percentmana.to_i >= 70
    feat_name, feat_command = feat_choices.find do |name, _command|
      Feat.available?(name) && Feat.affordable?(name)
    end
    return if feat_name.nil?

    Ashborne_toolkit.waitcast_waitrt
    Ashborne_toolkit.stance_offensive
    dothistimeout(
      "feat #{feat_command} ##{target.id}",
      2,
      /You level your|quick and vicious strike|not ready|seconds|cannot|can't|Could not find|what\?/i
    )
    Ashborne_toolkit.waitcast_waitrt
    Ashborne_toolkit.stance_guarded
  rescue NameError
    nil
  end

  def shield_control
    if $ashborne_no_shield_control == "1"
      nil
    else
      if $ashborne_shield_cooldown == 0

        if $ashborne_shield_steelyresolve == "1"
          Ashborne_toolkit.waitcast_waitrt
          fput "shield resolve" if percentstamina >= 50
        end

        if $ashborne_shield_shieldbash == "1"
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_offensive
          fput "shield bash" if percentstamina >= 50
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_guarded
        end

        # Move Logic Forward
        $ashborne_shield_cooldown = 10

      elsif $ashborne_shield_cooldown == 2
        if $ashborne_shield_shieldstrike == "1"
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_offensive
          fput "shield strike" if percentstamina >= 50
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_guarded
        end

      # if $ashborne_shield_shieldpushe == "1"
      #	Ashborne_toolkit.waitcast_waitrt
      #	Ashborne_toolkit.stance_offensive
      #	fput "shield push" if percentstamina >= 50
      #	Ashborne_toolkit.waitcast_waitrt
      #	Ashborne_toolkit.stance_guarded
      # end
      elsif $ashborne_shield_cooldown == 4
        if $ashborne_shield_shieldpin == "1"
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_offensive
          fput "shield pin" if percentstamina >= 50
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_guarded
        end
      elsif $ashborne_shield_cooldown == 6
        if $ashborne_shield_shieldtrample == "1"
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_offensive
          fput "shield trample" if percentstamina >= 50
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_guarded
        end

        if $ashborne_shield_shieldthrow == "1"
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_offensive
          fput "shield throw" if percentstamina >= 50
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_guarded
        end

      elsif $ashborne_shield_cooldown == 8
        if $ashborne_shield_shieldcharge == "1"
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_offensive
          fput "shield charge" if percentstamina >= 50
          Ashborne_toolkit.waitcast_waitrt
          Ashborne_toolkit.stance_guarded
        end

      end

    end

    $ashborne_shield_cooldown = $ashborne_shield_cooldown - 1 unless $ashborne_shield_cooldown == 0
  end

  def group_shield_throw_opener
    return false if $ashborne_group_ai == "0"
    return false if $ashborne_no_shield_control == "1"
    return false unless Stats.prof == "Paladin"
    return false unless $ashborne_shield_shieldthrow == "1"
    return false unless GameObj.targets.length >= 3
    return false unless percentstamina >= 50
    return false unless Ashborne_toolkit.group_spell_claim("shield_throw", true)

    Ashborne_toolkit.waitcast_waitrt
    Ashborne_toolkit.stance_offensive
    fput "shield throw"
    Ashborne_toolkit.waitcast_waitrt
    Ashborne_toolkit.stance_guarded
    $ashborne_shield_cooldown = 10
    true
  end

