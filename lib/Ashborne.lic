  # Turtle OOP

  def turtle_power_block_1
    if $ashborne_tmnturtle_cc_cooldown == 0
      # Turtle Flare 1
      Ashborne_toolkit.turtle_118 if Stats.prof == "Empath"
      Ashborne_toolkit.turtle_410
      $ashborne_tmnturtle_cc_cooldown = 5
    elsif $ashborne_tmnturtle_cc_cooldown == 2
      # Turtle Flare 2
      # Ashborne_toolkit.turtle_101 if Stats.prof == "Empath"
      Ashborne_toolkit.turtle_519 if Stats.prof == "Wizard"
    elsif $ashborne_tmnturtle_cc_cooldown == 4
      # Turtle Flare 3
      # Ashborne_toolkit.turtle_201 if Stats.prof == "Empath"
      Ashborne_toolkit.turtle_917 if Stats.prof == "Wizard"
    end
  end

  def turtle_power_block_2
    # Empath Blood Attack
    if $ashborne_tmnturtle_cc_cooldown == 0
      # Turtle Flare 1
      Ashborne_toolkit.turtle_1101 if Stats.prof == "Empath"
      $ashborne_tmnturtle_cc_cooldown = 5

    elsif $ashborne_tmnturtle_cc_cooldown == 2
    # Turtle Flare 2

    elsif $ashborne_tmnturtle_cc_cooldown == 4
      # Turtle Flare 3

    end
  end

  def turtle_1101
    waitcastrt?
    fput "prep 1101"
    fput "cast #{$ashborne_current_target}"
    waitcastrt?
  end

  def turtle_101
    waitcastrt?
    Spell[101].cast() if Spell[101].known? && Spell[101].affordable?
    waitcastrt?
  end

  def turtle_107
    waitcastrt?
    Spell[107].cast() if Spell[107].known? && Spell[107].affordable?
    waitcastrt?
  end

  def turtle_118
    if Skills.spellaiming >= 1 && Skills.slsummoning >= 20
      waitcastrt?
      Ashborne_toolkit.stance_offensive
      fput "incant 118 channel evoke" if Spell[118].known? && Spell[118].affordable?
      Ashborne_toolkit.stance_guarded
      waitcastrt?
    end
  end

  def turtle_201
    waitcastrt?
    Spell[201].cast() if Spell[201].known? && Spell[201].affordable?
    waitcastrt?
  end

