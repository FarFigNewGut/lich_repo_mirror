  def bounty_status
    # respond "I'm in bounty status."
    Ashborne_toolkit.bounty_debug
    $ashborne_bounty_intel_watch = "1"

    if Ashborne_toolkit.prepare_bounty_from_current_task
      Ashborne_toolkit.bounty_control
      return
    end

    until $ashborne_bounty_stage != "0"
      Ashborne_toolkit.bounty_debug
      if $ashborne_bounty_type == "skin" && $ashborne_bounty_stage == "0"
        $ashborne_bounty_stage = "5"
      end

      fput "bounty"
      sleep 3

    end
    # respond "I'm out of bounty status."
    Ashborne_toolkit.bounty_control
  end

  def bounty_debug_exit
    Ashborne_toolkit.top_menu
    respond "#{Char.name}, I apologize, your current bounty may not yet be coded.  I invite you to share this on Ashborne Discord."
    Ashborne_toolkit.bottom_menu
    Ashborne_toolkit.script_kill
    exit
  end

  def bandit_winner
    if $ashborne_bounty_type == "Bandit"
      Ashborne_toolkit.get_bandits
      exit
    end
  end

  def insist_bandits
    if $ashborne_bounty_bandit_insist == "0"
      respond "#{Char.name}, I insist you should never see this."
      exit
    elsif $ashborne_bounty_bandit_insist == "1"
      # respond "I've officially entered insist bandits, now looking for bandit task."
      # respond "Here I should be checking to see if you have bandits yet."
      $ashborne_bounty_bandit_insist = "2"
      Ashborne_toolkit.bounty_debug
      fput "bounty"
      sleep 3
      Ashborne_toolkit.insist_bandits
      Ashborne_toolkit.bounty_debug
    elsif $ashborne_bounty_bandit_insist == "2"
      if $ashborne_bounty_type == "Bandit"
        Ashborne_toolkit.get_bandits
      elsif $ashborne_no_bounty_boost_zonk == "1"
        $ashborne_bounty_bandit_insist = "4"
        Ashborne_toolkit.insist_bandits
        exit
      else
        # Here is where you want to check for bounty boost and use if you have.
        # respond "I didn't get bandits yet so let's do a boost"
        fput "boost bounty" unless $ashborne_stop_activating_bounty_boost == "1"
        sleep 1
        # respond "Here I am"
        if $ashborne_no_bounty_boost_zonk == "0"
          # You have bounty boosts, so increasing the insist level.
          $ashborne_bounty_bandit_insist = "3"
          Ashborne_toolkit.insist_bandits
          exit
        elsif $ashborne_no_bounty_boost_zonk == "1"
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, I apologize, you do not have any bounty boosts right now."
          Ashborne_toolkit.bottom_menu
          # exit
          # Here is where you would add expedite.
          $ashborne_bounty_bandit_insist = "4"
          $ashborne_bounty_fast = "1"
          Ashborne_toolkit.insist_bandits

        end

      end

    elsif $ashborne_bounty_bandit_insist == "3"
      # This is where you have bounty boosts and have activated one.  Remove task and acquire until bandit.
      # respond "This is where you have bounty boosts and have activated one.  Remove task and acquire until bandit."
      Ashborne_toolkit.bounty_debug
      Ashborne_toolkit.bounty_remove
      Ashborne_toolkit.bounty_taskmaster_talk
      $ashborne_bounty_bandit_insist = "1"
      Ashborne_toolkit.insist_bandits
      exit

    elsif $ashborne_bounty_bandit_insist == "4"

      # This is where you expedite if you have them.  Remove task and aquire via expedite.
      # respond "This is where you expedite if you have them.  Remove task and aquire via expedite."
      Ashborne_toolkit.bounty_debug
      Ashborne_toolkit.bounty_remove
      Ashborne_toolkit.bounty_taskmaster_talk
      # respond "out of taskmaster talk"
      sleep 1
      Ashborne_toolkit.bounty_debug
      if $ashborne_no_expedite_vouchers_zonk == "0"
        # You should have received a new bounty.  Check to see if it's bandit.
        $ashborne_bounty_bandit_insist = "1"
        Ashborne_toolkit.insist_bandits
        exit
      elsif $ashborne_no_expedite_vouchers_zonk == "1"
        Ashborne_toolkit.top_menu
        respond "#{Char.name}, I apologize, you do not have any bounty expedite vouchers right now."
        Ashborne_toolkit.bottom_menu
        exit
      end
    end
  end

  def get_bandits
    $ashborne_bounty_creature_match = "1"

    Ashborne_toolkit.bounty_debug
    fput "bounty"
    sleep 1
    Ashborne_toolkit.bounty_debug

    # You don't have bandits.
    if $ashborne_bounty_type == "0"

      Ashborne_toolkit.bounty_go_advguild
      Ashborne_toolkit.bounty_town_flash
      Ashborne_toolkit.bounty_debug
      Ashborne_toolkit.bounty_remove
      Ashborne_toolkit.bounty_taskmaster_talk

      $ashborne_bounty_bandit_insist = "1"

      Ashborne_toolkit.insist_bandits
      # respond "I broke out of insist bandits."
      exit

    elsif $ashborne_bounty_type == "Bandit"
      Ashborne_toolkit.top_menu
      respond "Congratulations #{Char.name}!  You have a bandit task."
      Ashborne_toolkit.bottom_menu
      exit
    end

    # respond "911"
  end

  def bounty_go_advguild
    do_client ";go2 advguild"
    wait_while { running? "go2" }
  end

  def bounty_control
    if $ashborne_bounty_bandit_buddy == "1"
      nil

    else
      sleep 1
      # fput "bounty"
      # respond "I'm in bounty control."

      if $ashborne_bounty_debug_cooldown >= 3
        Ashborne_toolkit.bounty_debug_exit
      end
      $ashborne_bounty_creature_match = "1"

      Ashborne_toolkit.bounty_debug
      if $ashborne_bounty_stage == "1"
        # Head to the guild for new bounty.
        Ashborne_toolkit.bounty_debug
        Ashborne_toolkit.bounty_go_advguild
        Ashborne_toolkit.bounty_town_detection
      elsif $ashborne_bounty_stage == "1.5"
        # Remove current bounty
        Ashborne_toolkit.bounty_debug
        do_client ";go2 advguild"
        wait_while { running? "go2" }
        Ashborne_toolkit.bounty_town_flash
        Ashborne_toolkit.bounty_remove
      elsif $ashborne_bounty_stage == "2"
        # Talk to the task master.
        Ashborne_toolkit.bounty_debug
        Ashborne_toolkit.bounty_taskmaster_talk



      elsif $ashborne_bounty_stage == "3"
        Ashborne_toolkit.bounty_debug
        $ashborne_bounty_creature_match = "1"
        # Collect bounty information first pass.
        fput "bounty"
        until $ashborne_bounty_type != "0"
          Ashborne_toolkit.bounty_debug
          # respond " I'm trapped in bounty stage 3 type loop"
          sleep 3
          $ashborne_bounty_debug_cooldown = $ashborne_bounty_debug_cooldown + 1
        end

        Ashborne_toolkit.bounty_debug

        # Fork for skin bounties
        sleep 1
        if $ashborne_bounty_type == "skin"
          $ashborne_bounty_stage = "4.5"
        end

        # Fork for herb bounties
        if $ashborne_bounty_type == "herbs"
          $ashborne_bounty_stage = "4.75"
        end

        # Fork for heirloom bounties
        if $ashborne_bounty_type == "Heirloom"
          $ashborne_bounty_stage = "4"
        end

        # Fork for child bounties
        if $ashborne_bounty_type == "child"
          $ashborne_bounty_stage = "4"
        end
        Ashborne_toolkit.bounty_control

      elsif $ashborne_bounty_stage == "4"
        # Talk to a guard
        do_client ";go2 advguard"
        Ashborne_toolkit.unpause_go2
        Ashborne_toolkit.bounty_guard_talk

      elsif $ashborne_bounty_stage == "4.25"
        # Talk to a guard
        do_client ";go2 advguard"
        Ashborne_toolkit.unpause_go2
        Ashborne_toolkit.bounty_guard_talk

      elsif $ashborne_bounty_stage == "4.5"
        # Talk to furrier

        if $ashborne_bounty_noskin == "1"
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, I see you don't want Ashborne to complete skin bounties."
          respond
          respond "You can have someone else skin for you and then you can turn them in."
          Ashborne_toolkit.bottom_menu
          Ashborne_toolkit.script_kill
          exit
        end


        do_client ";go2 furrier"
        wait_while { running? "go2" }
        Ashborne_toolkit.bounty_furrier_talk

      elsif $ashborne_bounty_stage == "4.75"
        # Talk to Herbalist

        if $ashborne_bounty_noherb == "1"
          Ashborne_toolkit.top_menu
          respond "#{Char.name}, I see you don't want Ashborne to complete herb bounties."
          respond
          respond "You can have someone else forage the herbs for you and then you can turn them in."
          Ashborne_toolkit.bottom_menu
          Ashborne_toolkit.script_kill
          exit
        end
        waitrt?
        do_client ";go2 town"
        Ashborne_toolkit.unpause_go2
        wait_while { running? "go2" }
        Ashborne_toolkit.bounty_town_flash
        if $ashborne_bounty_town == "River's Rest"
          do_client ";go2 alchemist"
          Ashborne_toolkit.unpause_go2
          wait_while { running? "go2" }
          Ashborne_toolkit.bounty_herbalist_talk
        else
          do_client ";go2 npchealer"
          Ashborne_toolkit.unpause_go2
          wait_while { running? "go2" }
          Ashborne_toolkit.bounty_herbalist_talk
        end

      elsif $ashborne_bounty_stage == "4.99"
        Ashborne_toolkit.top_menu
        respond "Ashborne's native herb bounty handler needs the modern Bounty.task data."
        respond "Run ;ashborne bounty again from town so it can read the herb, count, and area cleanly."
        Ashborne_toolkit.bottom_menu
        Ashborne_toolkit.script_kill
        exit




      elsif $ashborne_bounty_stage == "5"
        # Collect bounty information second pass.

        # respond "I'm now in stage 5."

        Ashborne_toolkit.bounty_skin_zone_picker if $ashborne_bounty_type == "skin"

        until $ashborne_bounty_ready_to_launch != "0"
          $ashborne_bounty_creature_match = "1"
          Ashborne_toolkit.bounty_debug
          fput "bounty"
          sleep 2
          Ashborne_toolkit.bounty_debug
          if $ashborne_bounty_debug_cooldown >= 3
            Ashborne_toolkit.bounty_debug_exit
          end
          $ashborne_bounty_debug_cooldown = $ashborne_bounty_debug_cooldown + 1
          Ashborne_toolkit.bounty_debug
          if $ashborne_my_area != "bounty"
            $ashborne_bounty_stage = "6"
            $ashborne_bounty_ready_to_launch = "1"
          end
        end

        $ashborne_bounty_debug_cooldown = 0

        Ashborne_toolkit.bounty_control

      elsif $ashborne_bounty_stage == "6"
        # Launching Pad
        Ashborne_toolkit.bounty_debug
        # respond "I'm in stage 6"

        # respond "Attempting to launch out of bounty."

        # Extra Skin Trap

        if $ashborne_bounty_noskin == "1" && $ashborne_bounty_type == "skin"

          Ashborne_toolkit.top_menu
          respond "#{Char.name}, I see you don't want Ashborne to complete skin bounties."
          respond
          respond "You can have someone else skin for you and then you can turn them in."
          Ashborne_toolkit.bottom_menu
          Ashborne_toolkit.script_kill
          exit
        end

        $ashborne_bounty_creature_match = "0"

      elsif $ashborne_bounty_stage == "7"
        # Turn in a bounty
        Ashborne_toolkit.bounty_debug
        # respond "I'm in stage 7"

        if checkmind == "saturated"
          waitrt?
          if Stats.prof == "Bard"
            fput "stop 1011"
          end
          $ashborne_action = 99
          $ashborne_return_why = "You finished your bounty but are saturated."
        else
          $ashborne_bounty_creature_match = "1"
          waitrt?
          if Stats.prof == "Bard"
            fput "stop 1011"
          end
          if Script.running? "go2"
            Script.kill "go2"
          end
          do_client ";go2 advguild"
          wait_while { running? "go2" }
          Ashborne_toolkit.bounty_town_flash
          Ashborne_toolkit.bounty_taskmaster_talk
          $ashborne_action = 99
          $ashborne_return_why = "You finished your bounty."
          $ashborne_my_area = "0"
          $ashborne_bounty_stage = "9"

        end
      elsif $ashborne_bounty_stage == "8"

        $ashborne_my_area = "0"
        $ashborne_action = 99
        $ashborne_return_why = "You need to wait longer before starting a new bounty."

      elsif $ashborne_bounty_stage == "9"
        # Last pass through before exiting.

        $ashborne_bounty_creature_match = "0"
      end



      # respond "leaving bounty control"

    end
  end

