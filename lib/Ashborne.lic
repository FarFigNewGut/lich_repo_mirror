  def style_9_set_empath_111
    if Spell[111].known? && Stats.level >= 11 && Skills.spellaiming >= 1
      $ashborne_empath_primary_spell = 111
    elsif Spell[1110].known? && Stats.level >= 10 && Skills.spellaiming >= 1
      $ashborne_empath_primary_spell = 1110
    else
      # Forcing you to use this spell for this creature if low level
      $ashborne_empath_primary_spell = "1700b"
    end
  end

  def style_9_set_empath_1110
    if Spell[1110].known? && Stats.level >= 10 && Skills.spellaiming >= 1
      $ashborne_empath_primary_spell = 1110
    elsif Spell[111].known? && Stats.level >= 11 && Skills.spellaiming >= 1
      $ashborne_empath_primary_spell = 111
    else
      # Forcing you to use this spell for this creature if low level
      $ashborne_empath_primary_spell = "1700b"
    end
  end

  def style_9_set_empath_1115
    if Spell[1115].known? && Stats.level >= 15
      $ashborne_empath_primary_spell = 1115
    elsif Spell[111].known? && Stats.level >= 11 && Skills.spellaiming >= 1
      $ashborne_empath_primary_spell = 111
    elsif Spell[1110].known? && Stats.level >= 10 && Skills.spellaiming >= 1
      $ashborne_empath_primary_spell = 1110
    else
      # Forcing you to use this spell for this creature if low level
      $ashborne_empath_primary_spell = "1700b"
    end
  end

