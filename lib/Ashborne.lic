  def bounty_guard_talk_secondpass
    result = dothistimeout "ask guard for bounty", 2, /don\'t have any tasks for you/

    if result =~ /don\'t have any tasks for you/
      respond
      respond "#{Char.name}, I'm sorry, you're in the wrong town for this bounty."
      respond
      exit
    end
  end

  def bounty_guard_talk
    $ashborne_bounty_creature_match = "1"
    # respond "I'm in bounty guard talk"
