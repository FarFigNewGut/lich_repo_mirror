  def crowd_control
    return nil if Ashborne_toolkit.group_follower_should_skip_setup
    return Ashborne_toolkit.maintain_noise_lockdown if Ashborne_toolkit.noise_lockdown?
    return nil unless Ashborne_toolkit.crowd_control_allowed?

    # respond "Debug Output - CC Cooldown is #{$ashborne_cc_cooldown}."
    # respond "Debug Output - My area level is #{$ashborne_my_area_level}."
    # if Stats.level - 30 < $ashborne_my_area_level
    #	respond "Debug Output - Your level minus 30 is smaller than the hunting zone."
    # else
    #	respond "Debug Output - You're far too experienced to use crowd control in this area."
    # end
    waitrt?
    if GameObj.targets.length >= 3

      if $ashborne_my_society == "Voln" && Stats.level - 30 < $ashborne_my_area_level && $ashborne_crowd_society_cooldown == 0
        waitrt?
        waitcastrt?
        # Ashborne_toolkit.top_menu
        # respond "Debug Output - I'm about to use symbol of sleep on a mob."
        # Ashborne_toolkit.bottom_menu
        fput "sym sleep" unless $ashborne_no_society == "1"
        $ashborne_crowd_society_cooldown = 20
      end


      # Empath Crowd Control

      if Stats.prof == "Empath" && Stats.level - 30 < $ashborne_my_area_level

        if $ashborne_cc_cooldown == 0

          waitcastrt?
          Spell[1117].cast() if Ashborne_toolkit.ability_allowed?("spell", 1117) && Spell[1117].known? && Stats.level >= 17 && Spell[1117].affordable? && Ashborne_toolkit.group_spell_claim("1117")
          $ashborne_cc_cooldown = 10 if $ashborne_my_area_type != "Living"
        end
      end



      # Sorcerer Multi Crowd Control
      # 709 is better instead of 410, temporarily disabling this.

      # if Stats.prof == "Sorcerer" && Stats.level - 30 < $ashborne_my_area_level
      #
      #	if $ashborne_cc_cooldown == 0
      #
      #			waitcastrt?
      #			Spell[410].cast() if Spell[410].known? && Stats.level >= 10 && Spell[410].affordable?
      #			$ashborne_cc_cooldown = 12
      #
      #	elsif $ashborne_cc_cooldown == 5
      #			nil
      #	end
      # end

    end

    if GameObj.targets.length >= 2
      # Empath Crowd Control

      if Stats.prof == "Empath" && Stats.level - 30 < $ashborne_my_area_level

        if $ashborne_cc_cooldown == 0

          if $ashborne_my_area_type == "Living"

            waitcastrt?
            Spell[1120].cast() if Ashborne_toolkit.ability_allowed?("spell", 1120) && Spell[1120].known? && Stats.level >= 20 && Spell[1120].affordable? && Ashborne_toolkit.group_spell_claim("1120")
            $ashborne_cc_cooldown = 10
          end
        end
      end




      if Stats.prof == "Cleric" && Stats.level - 30 < $ashborne_my_area_level

        if $ashborne_30_cooldown == 0

          waitcastrt?
          Spell[335].cast() if Ashborne_toolkit.ability_allowed?("spell", 335) && Spell[335].known? && Stats.level >= 50 && Spell[335].affordable? && Ashborne_toolkit.group_spell_claim("335")
          $ashborne_30_cooldown = 15

        end
      end

      if Stats.prof == "Paladin" && Stats.level - 30 < $ashborne_my_area_level

        if $ashborne_30_cooldown == 0
          waitcastrt?
          fput "incant 1614 open" if Ashborne_toolkit.ability_allowed?("spell", 1614) && !Ashborne_toolkit.group_spell_claimed?("shield_throw", true) && Spell[1614].known? && Stats.level >= 14 && Spell[1614].affordable? && Ashborne_toolkit.group_spell_claim("1614_open")
          $ashborne_30_cooldown = 15

        end
      end




      if Stats.prof == "Wizard" && Stats.level >= 4 && Skills.elwater >= 30 && Spell[1710].affordable? && checkmana >= 6

        waitcastrt?
        fput "prep 904"
        Ashborne_toolkit.stance_offensive
        fput "evoke target"
        Ashborne_toolkit.stance_guarded
      end

    end



    # General Crowd Control

    # Empath General Crowd Control
    if Stats.prof == "Empath" && Stats.level - 30 < $ashborne_my_area_level
      if $ashborne_212_cooldown == 0
        # 212 Boost
        waitcastrt?
        Spell[212].cast() if Ashborne_toolkit.ability_allowed?("spell", 212) && Spell[212].known? && Stats.level >= 12 && Spell[212].affordable?
        $ashborne_212_cooldown = 10
      end
    end

    # Sorcerer General Crowd Control

    if Stats.prof == "Sorcerer" && Stats.level - 30 < $ashborne_my_area_level

      if $ashborne_my_area =~ /wlyeti|wlminotaur/
        nil
      else
        if $ashborne_cc_cooldown == 0
          waitcastrt?
          Spell[703].cast() if Ashborne_toolkit.ability_allowed?("spell", 703) && Spell[703].known? && Stats.level >= 3 && Spell[703].affordable?
          $ashborne_cc_cooldown = 10

        elsif $ashborne_cc_cooldown == 5
