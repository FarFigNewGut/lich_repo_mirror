  def evicted
    # respond "Debug Output - Evicted"
    $ashborne_action = 0
    $ashborne_own_this_room = 0
    $ashborne_my_vine = "0"
    Ashborne_toolkit.safe_walk
    sleep 0.10
  end

  def leave_occupied_room
    players = if $ashborne_group_ai == "0"
                GameObj.pcs
              else
                Ashborne_toolkit.visible_non_group_players
              end
    return false if players.empty?

    names = players.map { |player| Ashborne_toolkit.canonical_character_name(player.name) }
      .select { |name| Ashborne_toolkit.valid_character_name?(name) }
    respond "Room already occupied by #{names.join(', ')}; leaving without engaging."

    waitrt?
    Ashborne_toolkit.stance_defensive
    starting_room = Room.current && Ashborne_toolkit.current_room_id ? Ashborne_toolkit.current_room_id.to_s : nil
    moved = Ashborne_toolkit.walk_avoiding_environmental_rooms("occupied by another player")
    moved = starting_room.nil? || !Room.current || Ashborne_toolkit.current_room_id.to_s != starting_room if moved

    $ashborne_action = 0
    $ashborne_own_this_room = 0
    $ashborne_my_vine = "0"
    respond "Occupied-room exit failed; remaining defensive." unless moved
    moved
  rescue => error
    Ashborne_toolkit.stance_defensive
    respond "Occupied-room exit warning: #{error.message}" if $ashborne_qc_debug == "1"
    false
  end

