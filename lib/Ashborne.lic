  def hide_time
    if GameObj.targets.length >= 1
      if checkhidden
        nil
      else
        if (($ashborne_camo == "1") && (Spell[608].affordable?) && (!checkhidden)) && ((Spell.active? "625") or (checkoutside))

          $result = nil

          Lich::Util.issue_command("release", /You/, /<prompt/, include_end: true, silent: true, quiet: true) if checkprep != "None"
          $result = Lich::Util.issue_command("prep 608", /You/, /<prompt/, include_end: true, silent: true, quiet: true)

          # Check if any element in $result array contains "Your spell is ready."
          if $result.any? { |line| line.match?(/Your spell is ready\./i) }
            sleep 0.1
            Lich::Util.issue_command("cast", /You/, /<prompt/, include_end: true, silent: true, quiet: true)
            sleep 0.1
            waitcastrt?
            sleep 0.1
          end
          if checkhidden
          # You were able to hide
          else
            # Original Hide Block
            result = dothistimeout "hide", 2, /fail to slip|that no one has noticed|but can't see anywhere/
            if result =~ /fail to slip/
              waitrt?
              fput "hide"
            elsif result =~ /that no one has noticed/
              nil
            elsif result =~ /but can't see anywhere/
              nil
            end
          end
        else
          # Original Hide Block
          result = dothistimeout "hide", 2, /fail to slip|that no one has noticed|but can't see anywhere/
          if result =~ /fail to slip/
            waitrt?
            fput "hide"
          elsif result =~ /that no one has noticed/
            nil
          elsif result =~ /but can't see anywhere/
            nil
          end
        end
      end
    end
  end

  def chicken_attack
    if $ashborne_my_style == "1" || $ashborne_my_style == "2"
      Ashborne_toolkit.uac_round
      return
    end

    unless Ashborne_toolkit.ensure_fresh_attack_target
      Ashborne_toolkit.stance_defensive
      return false
    end

    fput "attack"
  end

