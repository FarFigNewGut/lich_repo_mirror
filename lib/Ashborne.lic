elsif script.vars[1].downcase =~ /setup/ && script.vars[2].downcase =~ /change/ && script.vars[3].downcase =~ /spell/
  spell_rotation = script.vars[4..-1].join(" ").scan(/\d+/).map(&:to_i).select { |spell_number| spell_number > 0 }.uniq
  Settings[Char.name]['ashborne_setting_spell_default'] = spell_rotation.empty? ? "0" : spell_rotation.join(",")
  sleep 0.25
  Settings.save
  Ashborne_toolkit.top_menu
  respond "Custom spell rotation: #{spell_rotation.empty? ? 'off; HuntPro spell selection is active' : spell_rotation.join(', ')}."
  Ashborne_toolkit.confirm_settings
  Ashborne_toolkit.bottom_menu
  exit
