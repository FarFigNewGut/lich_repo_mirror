# encoding: utf-8
=begin
  lp.lic - Cast spell 116 (Locate Person) on one or more targets.
  Prints realm name if out of range. If in range, the game output speaks for itself.
  With no args, incants 116 for locate-back.

  Usage: ;lp
         ;lp Name1 Name2 Name3
=end

targets = (script.vars[1..-1] || []).map(&:strip).reject(&:empty?)

if targets.empty?
  fput "incant 116"
  exit
end

realm_map = {
  /patterned as if by an enormous/i                           => "Broken Lands",
  /dragonflies.*damselflies/i                                 => "Cysaegir",
  /cradled to the bosom of a glacier/i                        => "Icemule Trace",
  /dark storm clouds encompass a single tropical/i            => "Kraken's Fall",
  /surrounded by mists on all sides/i                         => "Mist Harbor",
  /tangled vines and creeping grasses/i                       => "Old Ta'Faendryl",
  /resting amongst the clouds.*rustic trading/i               => "Pinefar",
  /long tendrils of rainbow-colored/i                         => "Reim",
  /pulsating like the heartbeat/i                             => "The Rift",
  /surrounded by the vibrancy of the jungle/i                 => "River's Rest",
  /spectral shapes dance upon a twisted/i                     => "Shadow Valley",
  /glittering like a thousand tears falling from the cliffs/i => "Solhaven",
  /nestled beneath the gaze of glacial peaks/i                => "Ta'Illistim",
  /imposing crenellation.*remarkable in design/i              => "Ta'Vaalor",
  /ash rains down upon a dwarven/i                            => "Teras Isle",
  /high walls surround a sprawling frontier/i                 => "Wehnimer's Landing",
  /clouds race past.*carrying the waters/i                    => "Solhaven Trail / Zul Logoth Trail",
  /toadstool-illuminated walls/i                              => "Zul Logoth",
  /blur of the countryside as you soar/i                      => "In flight (Griffin)",
}

hidden_pattern    = /What were you referring to/i
blocked_pattern   = /unseen force/i
withered_pattern  = /magic of your spell withers/i
terminal_pattern  = /beyond the reach of your spell|Cast Roundtime|What were you referring|unseen force|withers on contact|Cast at what/i
roundtime_pattern = /Cast Roundtime (\d+) Sec/i
in_range_pattern  = /your sight begins to clear and a vision/i

script_timeout = 30

print_result = proc { |target, message|
  width    = 50
  text     = ">> #{target.upcase}: #{message}"
  padding  = [(width - text.length) / 2, 0].max
  centered = " " * padding + text
  echo ""
  echo "~" * 50
  echo centered
  echo "~" * 50
  echo ""
}

script_start = Time.now

targets.each do |target|

  if (Time.now - script_start) > script_timeout
    echo "[lp] Timed out - exiting."
    exit
  end

  result = dothistimeout "prepare 116", 10, /Your spell is ready|already preparing/i
  if result.nil?
    echo "[lp] Timed out waiting to prepare - exiting."
    exit
  end

  fput "cast #{target}"

  result_lines = []
  realm        = nil
  roundtime    = 3.5
  in_range     = false

  start_time = Time.now
  while (Time.now - start_time) < 10
    if (Time.now - script_start) > script_timeout
      echo "[lp] Timed out - exiting."
      exit
    end

    line = get?
    next if line.nil?
    result_lines << line

    in_range = true if line =~ in_range_pattern

    if realm.nil?
      match = realm_map.find { |pattern, _| line =~ pattern }
      realm = match[1] if match
    end

    if line =~ roundtime_pattern
      roundtime = $1.to_f + 0.5
    end

    break if line =~ terminal_pattern
  end

  full_text = result_lines.join("\n")

  if full_text =~ /Cast at what/i
    print_result.call(target, "Not found.")
  elsif full_text =~ hidden_pattern
    print_result.call(target, "Hidden or invisible.")
  elsif full_text =~ blocked_pattern
    print_result.call(target, "Blocked area (warcamp or shielded zone).")
  elsif full_text =~ withered_pattern
    print_result.call(target, "Unknown location.")
  elsif in_range
    # Game output already shows the room info, nothing extra needed
  elsif realm
    print_result.call(target, realm)
  else
    print_result.call(target, "Out of range (unknown realm).")
  end

  sleep roundtime
end
