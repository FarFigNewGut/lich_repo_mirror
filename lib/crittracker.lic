  # ---- Regex compilation -------------------------------------------------
  # Turn a crit message template into a tolerant regex that matches the raw
  # game line regardless of [target] substitution, punctuation, or spacing.
  def compile_regex(msg)
    sentinel = "\u0001"
    tmp = msg.dup
    # All target placeholder variants -> single sentinel (the live name may
    # carry a trailing possessive 's, which the wildcard will absorb).
    tmp = tmp.gsub(/\[target's\]/i, sentinel)
    tmp = tmp.gsub(/\[target\]'s/i, sentinel)
    tmp = tmp.gsub(/\[target\]/i, sentinel)

    tokens = []
    buf = +""
    tmp.each_char do |c|
      if c == sentinel
        tokens << buf unless buf.empty?
        buf = +""
        tokens << :T
      elsif c =~ /[A-Za-z0-9]/
        buf << c
      else
        tokens << buf unless buf.empty?
        buf = +""
      end
    end
    tokens << buf unless buf.empty?

    # Drop article words; the gap pattern makes them optional in matching.
    sig = tokens.reject { |t| t.is_a?(String) && ARTICLES.include?(t.downcase) }
    sig = tokens if sig.empty?

    parts = sig.map do |t|
      if t == :T
        "[A-Za-z][A-Za-z0-9'\\- ]*?"
      elsif PRONOUNS.include?(t.downcase)
        # Tables use it/its for the creature; gendered foes show he/she/his/her.
        PRONOUN_ALT
      else
        Regexp.escape(t)
      end
    end
    Regexp.new(parts.join(GAP), Regexp::IGNORECASE)
  end

  PRONOUNS = %w[it its itself he him his she her hers herself himself they them their themselves].freeze
  PRONOUN_ALT = "(?:#{PRONOUNS.join('|')})".freeze
  ARTICLES = %w[the a an].freeze
  # Separator between significant words, optionally swallowing a dropped article.
  GAP = "(?:[^A-Za-z0-9]+(?:the|a|an)\\b)*[^A-Za-z0-9]+".freeze

  # Lines that mean a creature is attacking YOU; their crits/swings are never
  # yours. Keyed on GemStone's universal pronoun grammar (you/your), not on any
  # creature name, so it generalizes to any monster.
  INCOMING_RE = /\bat you\b|\bMDR result:|\bhits? you\b|\byou are struck\b|partially deflects the onslaught|fend off (?:the|this) attack|manage to (?:parry|block|evade)|\btries to\b[^.!]*\byou\b|\b(?:bites?|claws?|gnaws?|mauls?|gores?|rakes?|stabs?|spits?|breathes?) you\b/i
  # Lines that mark a clearly player-initiated attack (you are the subject, or
  # the hit resolves with "and hit for", which only your own attacks ever say).
  PLAYER_RE = /\band hit for \d+ points? of damage|\bYou (?:swing|take aim|leap|uncoil|crouch|angle|rotate|advance|attack|lunge|thrust|jab|slash|chop|hack|stab|punch|kick|fire|hurl|throw|lob|deftly switch|slip|spring|whirl|carve|sweep|round|guide|weave)\b|\byou (?:carve|sweep|round on|guide|weave|lick out|swing|slip|thrust|jab)\b|\bYour blades\b/i

  # Build the flat entry list, merging genuinely side-less LEFT/RIGHT pairs.
  def build_entries
    list = []
    TABLES.each do |type, locs|
      locs.each do |loc, rows|
        rows.each do |row|
          rank, dmg, message, status, wound = row
          list << {
            type: type, loc: loc, rank: rank, dmg: dmg,
            status: status, wound: wound, msg: message,
            re: compile_regex(message), disp: nil
          }
        end
      end
    end

    grouped = Hash.new { |h, k| h[k] = [] }
    list.each { |e| grouped[[e[:type], e[:rank], e[:msg]]] << e }
    grouped.each_value do |grp|
      locs = grp.map { |e| e[:loc] }.uniq
      next unless locs.size == 2
      has_left  = locs.any? { |l| l.start_with?("LEFT ") }
      has_right = locs.any? { |l| l.start_with?("RIGHT ") }
      bases     = locs.map { |l| l.sub(/\A(LEFT|RIGHT) /, "") }.uniq
      if has_left && has_right && bases.size == 1
        grp.each { |e| e[:disp] = bases.first }
      end
    end
    list.each { |e| e[:disp] ||= e[:loc] }
    list
  end

  # ---- Matching ----------------------------------------------------------
  def match_line(line, observed_dmg)
    hits = @entries.select { |e| e[:re].match?(line) }
    return nil if hits.empty?
    return hits.first if hits.size == 1
    if observed_dmg
      hits.min_by { |e| [(e[:dmg] - observed_dmg).abs, e[:rank]] }
    else
      hits.min_by { |e| e[:rank] }
    end
  end

  # ---- Effects formatting ------------------------------------------------
  def format_effects(status, wound)
    parts = []
    st = status.to_s
    parts << "STUN #{$1} ROUND" if st =~ /S(\d+)/
    parts << "KNOCKDOWN"        if st =~ /\bK\b/
    parts << "AMPUTATION"       if st =~ /\bA\b/
    parts << "FATAL"            if st =~ /\bF\b/ || st =~ /fatal/i
    w = wound.to_s.strip
    parts << "#{w.upcase} WOUND" unless w.empty? || w.downcase == "none"
    parts
  end

  # ---- Output ------------------------------------------------------------
  def echo_to_familiar_window(message)
    if $frontend =~ /stormfront|profanity/i
      b = "<pushStream id=\"familiar\" ifClosedStyle=\"watching\"/><output class=\"mono\"/>\n"
      e = "\n<output class=\"\"/><popStream/>\r\n"
    else
      b = "\034GSe\r\n"
      e = "\034GSf\r\n"
    end
    _respond("#{b}#{message}#{e}")
  end

  def echo_to_main(message)
    if $frontend =~ /stormfront|profanity/i
      _respond("<output class=\"mono\"/>\n#{message}\n<output class=\"\"/>\r\n")
    else
      respond(message)
    end
  end

  def live_output(e, dmg = nil)
    header = "#{e[:type]} #{e[:disp]}: RANK #{e[:rank]}"
    parts = format_effects(e[:status], e[:wound])
    parts << "DMG: #{dmg}" if dmg
    msg = parts.empty? ? header : "#{header} | #{parts.join(' | ')}"
    if @data['prefs']['familiar']
      echo_to_familiar_window(msg)
    else
      echo(msg)
    end
  end

  # ---- Data --------------------------------------------------------------
  def blank_dataset
    {
      'date'           => Time.now.strftime('%Y-%m-%d'),
      'total_hits'     => 0,
      'by_type'        => {},
      'by_location'    => {},
      'total_attacks'  => 0,   # melee swings resolved (AS vs DS endroll lines)
      'misses'         => 0,   # swings with endroll <= 100 (complete misses)
      'aimed_attacks'  => 0,   # swings made while aiming a location (pending sample)
      'aimed_misses'   => 0    # aimed swings that did not land on the aimed area
    }
  end

  def ensure_dataset(ds)
    ds = {} unless ds.is_a?(Hash)
    ds['date']           ||= Time.now.strftime('%Y-%m-%d')
    ds['total_hits']     ||= 0
    ds['by_type']        ||= {}
    ds['by_location']    ||= {}
    ds['total_attacks']  ||= 0
    ds['misses']         ||= 0
    ds['aimed_attacks']  ||= 0
    ds['aimed_misses']   ||= 0
    # Migration: older versions stored by_location as a flat {LOC => rec} hash,
    # mixing damage types. The new format nests by type {TYPE => {LOC => rec}}.
    # Old entries can't be re-typed, so reset just the crit tallies (attacks and
    # misses are kept). Detected when a value looks like a location record.
    if ds['by_location'].values.any? { |v| v.is_a?(Hash) && v.key?('hits') }
      ds['by_location'] = {}
      ds['by_type']     = {}
      ds['total_hits']  = 0
      @migrated = true
    end
    ds
  end

  def blank_location
    { 'hits' => 0, 'dmg_sum' => 0, 'dmg_high' => 0, 'dmg_count' => 0, 'ranks' => {} }
  end

  def load_data
    base = "#{$data_dir}#{XMLData.game}"
    dir  = "#{base}/#{Char.name}"
    Dir.mkdir(base) unless Dir.exist?(base)
    Dir.mkdir(dir)  unless Dir.exist?(dir)
    @datafile = "#{dir}/crittracker.yaml"

    if File.exist?(@datafile)
      begin
        @data = YAML.load_file(@datafile)
      rescue StandardError => ex
        echo("CritTracker: could not read data file (#{ex.message}); starting fresh.")
        @data = nil
      end
    end
    @data = {} unless @data.is_a?(Hash)
    @data['lifetime'] = ensure_dataset(@data['lifetime'])
    @data['daily']    = ensure_dataset(@data['daily'])
    @data['prefs']  ||= {}
    @data['prefs']['familiar'] = true  if @data['prefs']['familiar'].nil?
    @data['prefs']['debug']    = false if @data['prefs']['debug'].nil?
    @save_counter = 0
  end

  def save
    begin
      tmp = @datafile + ".tmp"
      File.open(tmp, "w") do |f|
        f.write(@data.to_yaml)
        f.fsync
      end
      File.rename(tmp, @datafile)
    rescue StandardError => ex
      echo("CritTracker: failed to save data: #{ex.message}")
    end
  end

  def check_daily_reset
    today = Time.now.strftime('%Y-%m-%d')
    if @data['daily']['date'] != today
      @data['daily'] = blank_dataset
    end
  end

  def record(ds, type, loc, rank, dmg)
    ds['total_hits'] += 1
    ds['by_type'][type] = (ds['by_type'][type] || 0) + 1
    tl = (ds['by_location'][type] ||= {})
    l = (tl[loc] ||= blank_location)
    l['hits'] += 1
    l['ranks'][rank] = (l['ranks'][rank] || 0) + 1
    if dmg
      l['dmg_sum']   += dmg
      l['dmg_count'] += 1
      l['dmg_high']   = dmg if dmg > l['dmg_high']
    end
  end

  def record_crit(e, dmg)
    check_daily_reset
    record(@data['lifetime'], e[:type], e[:disp], e[:rank], dmg)
    record(@data['daily'],    e[:type], e[:disp], e[:rank], dmg)
    @save_counter += 1
    save if (@save_counter % 10).zero?
  end

  # Tally a resolved melee swing. is_miss = endroll <= 100 (complete miss).
  def record_attack(is_miss)
    check_daily_reset
    [@data['lifetime'], @data['daily']].each do |ds|
      ds['total_attacks'] += 1
      ds['misses'] += 1 if is_miss
    end
    @save_counter += 1
    save if (@save_counter % 10).zero?
  end

  # Tally an aimed swing whose crit location is known. missed = landed off-target.
  def record_aim(missed)
    check_daily_reset
    [@data['lifetime'], @data['daily']].each do |ds|
      ds['aimed_attacks'] += 1
      ds['aimed_misses'] += 1 if missed
    end
    @save_counter += 1
    save if (@save_counter % 10).zero?
  end

  # Valid aim phrases, longest first so "right leg" is matched before "leg".
  AIM_LOCATIONS = [
    "right eye", "left eye", "right arm", "left arm", "right hand", "left hand",
    "right leg", "left leg", "head", "neck", "chest", "abdomen", "back",
    "eye", "arm", "hand", "leg"
  ].sort_by { |s| -s.length }

  # Reduce a location to its side-less base (so a sided crit can be compared to
  # a possibly side-less aim, since crit messaging is unreliable about sides).
  def base_location(loc)
    loc.to_s.downcase.sub(/\A(left|right)\s+/, '').strip
  end

  # Extract a trailing aim location from a manually-typed attack command.
  def parse_attack_aim(cmd)
    c = cmd.to_s.downcase.strip
    return nil unless c =~ /\A(attack|kill|ambush|waylay|fire|hurl)\b/
    AIM_LOCATIONS.each { |loc| return loc if c =~ /\b#{Regexp.escape(loc)}\z/ }
    nil
  end

  # ---- Stats display -----------------------------------------------------
  def show_stats(ds, label)
    lines = []
    lines << ("=" * 64)
    title = "CRITICAL STATS - #{label}"
    title += "  (#{ds['date']})" if label == "DAILY"
    lines << title
    lines << "Total hits: #{ds['total_hits']}"
    unless ds['by_type'].empty?
      tline = ds['by_type'].sort_by { |_, v| -v }.map { |k, v| "#{k}: #{v}" }.join("   ")
      lines << "By type: #{tline}"
    end

    atk = ds['total_attacks'].to_i
    miss = ds['misses'].to_i
    miss_pct = atk > 0 ? (miss * 100.0 / atk).round : 0
    lines << "Attacks: #{atk} | TOTAL MISS: #{miss_pct}% (#{miss})"
    aimed = ds['aimed_attacks'].to_i
    if aimed > 0
      amiss = ds['aimed_misses'].to_i
      apct = (amiss * 100.0 / aimed).round
      lines << "Aimed attacks: #{aimed} | AIMED MISSES: #{apct}% (#{amiss})"
    end
    lines << ("-" * 64)

    bl = ds['by_location']
    if bl.nil? || bl.empty? || bl.values.all? { |t| t.nil? || t.empty? }
      lines << "No critical hits recorded yet."
    else
      type_order = ["CRUSH", "PUNCTURE", "SLASH"]
      ordered = type_order + (bl.keys - type_order)
      ordered.each do |type|
        locs = bl[type]
        next if locs.nil? || locs.empty?
        type_total = locs.values.sum { |d| d['hits'].to_i }
        lines << "[ #{type} CRITS ]  (#{type_total})"
        locs.sort_by { |_, d| -d['hits'].to_i }.each do |loc, d|
          hits = d['hits'].to_i
          pct  = type_total > 0 ? (hits * 100.0 / type_total).round : 0
          avg  = d['dmg_count'].to_i > 0 ? (d['dmg_sum'].to_f / d['dmg_count']).round : 0
          high = d['dmg_high'].to_i
          lines << "  #{loc} | HIT %: #{pct}% (#{hits}) | AVG DMG: #{avg} | HIGH DMG: #{high}"
          ranks = d['ranks'] || {}
          keys  = ranks.keys.map { |k| k.to_i }.sort
          rstrs = keys.map do |r|
            c  = ranks[r] || ranks[r.to_s] || 0
            rp = hits > 0 ? (c * 100.0 / hits).round : 0
            "RANK #{r}: #{rp}% (#{c})"
          end
          lines << ("     " + rstrs.join(" / ")) unless rstrs.empty?
        end
      end

      # Aggregate rank distribution across all locations/types.
      rank_totals = Hash.new(0)
      bl.each_value do |locs|
        next unless locs.is_a?(Hash)
        locs.each_value do |d|
          (d['ranks'] || {}).each do |r, c|
            rank_totals[r.to_i] += c.to_i
          end
        end
      end
      grand = rank_totals.values.sum
      if grand > 0
        lines << ("-" * 64)
        lines << "[ RANK TOTALS ]  (#{grand})"
        rank_totals.keys.sort.each do |r|
          c = rank_totals[r]
          rp = (c * 100.0 / grand).round
          lines << "  RANK #{r} | #{c} TOTAL | #{rp}%"
        end
      end

      # Aggregate hit distribution across all damage types, per body location.
      loc_totals = Hash.new(0)
      bl.each_value do |locs|
        next unless locs.is_a?(Hash)
        locs.each do |loc, d|
          loc_totals[loc] += d['hits'].to_i
        end
      end
      lgrand = loc_totals.values.sum
      if lgrand > 0
        lines << ("-" * 64)
        lines << "[ LOCATION TOTALS ]  (#{lgrand})"
        loc_totals.sort_by { |loc, c| [-c, loc] }.each do |loc, c|
          lp = (c * 100.0 / lgrand).round
          lines << "  #{loc} | #{c} TOTAL | #{lp}%"
        end
      end
    end
    lines << ("=" * 64)
    echo_to_main(lines.join("\n"))
  end

  def show_help
    msg = [
      "CritTracker commands (type at the prompt, no semicolon):",
      "  crit daily          today's stats",
      "  crit life           lifetime stats",
      "  crit familiar       toggle live familiar-window output (now: #{@data['prefs']['familiar'] ? 'ON' : 'OFF'})",
      "  crit debug          toggle unmatched-line debug (now: #{@data['prefs']['debug'] ? 'ON' : 'OFF'})",
      "  crit reset daily | life | all",
      "  crit help           this help"
    ].join("\n")
    echo_to_main(msg)
  end

  # ---- Command handling --------------------------------------------------
  def handle_command(raw)
    cmd = raw.to_s.strip.downcase.gsub(/\s+/, ' ')
    @mutex.synchronize do
      case cmd
      when "crit daily"
        check_daily_reset
        show_stats(@data['daily'], "DAILY")
      when "crit life", "crit lifetime"
        show_stats(@data['lifetime'], "LIFETIME")
      when "crit familiar"
        @data['prefs']['familiar'] = !@data['prefs']['familiar']
        save
        echo("CritTracker: live familiar output #{@data['prefs']['familiar'] ? 'ON' : 'OFF'}")
      when "crit debug"
        @data['prefs']['debug'] = !@data['prefs']['debug']
        save
        echo("CritTracker: debug #{@data['prefs']['debug'] ? 'ON' : 'OFF'}")
      when "crit reset daily"
        @data['daily'] = blank_dataset
        save
        echo("CritTracker: DAILY stats reset.")
      when "crit reset life", "crit reset lifetime"
        @data['lifetime'] = blank_dataset
        save
        echo("CritTracker: LIFETIME stats reset.")
      when "crit reset all"
        @data['daily']    = blank_dataset
        @data['lifetime'] = blank_dataset
        save
        echo("CritTracker: ALL stats reset.")
      else
        show_help
      end
    end
  end

  def install_hook
    UpstreamHook.add(HOOK_ID, proc do |client_string|
      # Wrayth/Stormfront prefix client input with "<c>"; strip it before matching.
      cmd = client_string.to_s.sub(/\A<c>/i, '').strip
      if cmd =~ /\Acrit(?:\s+.*)?\z/i
        begin
          handle_command(cmd)
        rescue StandardError => ex
          echo("CritTracker command error: #{ex.message}")
        end
        nil # swallow so the game never sees it
      else
        # Not a crit command: pass through, but note any aimed attack location
        # the player typed (script-issued commands are not seen here).
        loc = parse_attack_aim(cmd)
        @mutex.synchronize { @aim_oneshot = loc } if loc
        client_string
      end
    end)
  end

  def remove_hook
    UpstreamHook.remove(HOOK_ID)
  rescue StandardError
    nil
  end

  def shutdown
    @mutex.synchronize { save } if @mutex && @data
  rescue StandardError
    nil
  ensure
    remove_hook
  end

  # Rough filter: lines worth reporting as "unmatched" while debugging.
  DEBUG_HINT = /\b(slash|slashes|slashing|strike|strikes|blow|shot|crush|crushing|pierce|pierces|punctures?|sever|severs|smash|smashes|gash|shatters?|skewers?|gouges?|vapor|ethereal|mist|misty|reform|reforms|reseals|whistles|wisp|tendrils|vaporizes|amputates|obliterates)\b/i

  # ---- Main loop ---------------------------------------------------------
  def run
    @mutex = Mutex.new
    load_data
    @entries = build_entries
    install_hook
    echo("CritTracker active. Tracking CRUSH/PUNCTURE/SLASH melee crits. Type 'crit help' for commands.")
    if @migrated
      echo("CritTracker: stats format updated; prior per-location crit counts were cleared so types could be separated. Attack/miss totals were kept.")
    end

    pending = 0       # lines remaining in which to look for a crit message
    hit_dmg = nil     # damage of OUR weapon swing this round (never a flare's)
    buf = +""         # rolling buffer so crits split across lines still match
    swing_aim = nil   # aim location in effect for the swing currently resolving
    flare_pending = false   # next bare "... N points" is flare damage (skip it)
    prev_announce = false   # the previous line was a "** ... **" flare banner
    attacker = :mine        # whose attack is currently resolving (:mine / :incoming)
    @aim_pref = nil   # persistent AIM preference (from downstream echo)
    @aim_oneshot = nil # location typed on a single attack command (hook-set)
    begin
      while true
        line = get

        # Persistent AIM preference, echoed by the game for AIM <loc> / clear.
        if line =~ /[Yy]ou.?re now aiming at the (.+?) of your target/
          @aim_pref = $1.strip.downcase
          next
        elsif line =~ /no longer aiming at anything/i
          @aim_pref = nil
          next
        end

        # Track attack ownership. Incoming attacks (a creature striking YOU) must
        # never be counted as your crits or swings. Your attacks say "at a/the
        # <creature>" and resolve with "and hit for"; incoming say "at you", etc.
        if line =~ INCOMING_RE
          attacker = :incoming
        elsif line =~ PLAYER_RE
          attacker = :mine
        end

        # Incoming creature maneuver (Maneuver Defense Roll): its bite/crit is on
        # YOU. Mark incoming and drop any open window so it can't be captured.
        if line =~ /\A\s*\[MDR result:/i
          attacker = :incoming
          pending = 0
          hit_dmg = nil
          buf = +""
          next
        end

        # Flare banner "** ... **": the next bare "... N points" is flare damage.
        if line =~ /\A\s*\*\*.*\*\*\s*\z/
          flare_pending = true
          prev_announce = true
          next
        end

        # SMR maneuver result. If it directly follows a flare banner, this SMR
        # belongs to that flare. Otherwise it's a weapon maneuver (eviscerate,
        # etc.) whose damage prints as a bare "... N points" with no AS/DS line.
        if line =~ /\A\s*\[SMR result:/i
          flare_pending = prev_announce
          unless prev_announce
            pending = 0
            hit_dmg = nil
            buf = +""
          end
          prev_announce = false
          next
        end
        prev_announce = false

        # New weapon swing resolution: "AS: +N vs DS: +N ... = +ENDROLL"
        # Endroll <= 100 is a complete miss (standard GS d100 mechanic).
        if line =~ /\bAS:\s*[+-]?\d+\s+vs\s+DS:.*?=\s*([+-]?\d+)/i
          endroll = $1.to_i
          if attacker == :mine
            # Snapshot the aim for this swing, then consume any one-shot location.
            @mutex.synchronize do
              swing_aim = @aim_oneshot || @aim_pref
              @aim_oneshot = nil
            end
            @mutex.synchronize { record_attack(endroll <= 100) }
          else
            swing_aim = nil   # incoming swing: not ours, don't count or aim-check
          end
          pending = 0          # close any prior crit window at the swing boundary
          hit_dmg = nil
          buf = +""
          flare_pending = false
          next
        end

        # Our weapon hit damage (drives the DMG figure; flares never do).
        if line =~ /\band hit for (\d+) points? of damage/i
          hit_dmg = $1.to_i
          pending = 8
          buf = +""
          flare_pending = false
          next
        # Bare "... N points of damage!": flare damage if flagged (skip it),
        # otherwise a weapon maneuver strike -> open a crit window.
        elsif line =~ /\A\s*\.\.\.\s*(\d+) points? of damage/i
          if flare_pending
            flare_pending = false
          elsif attacker == :mine
            hit_dmg = $1.to_i
            pending = 8
            buf = +""
          end
          next
        # Incoming hit on us: not ours.
        elsif line =~ /\bhits? you\b.*?\d+ points? of damage/i
          pending = 0
          hit_dmg = nil
          buf = +""
          next
        # Any other "points of damage" line (e.g. another player): leave state alone.
        elsif line =~ /points? of damage/i
          next
        end

        next if pending <= 0

        buf << " " << line
        buf = buf[-600..-1].to_s if buf.length > 600

        e = match_line(buf, hit_dmg)
        if e
          @mutex.synchronize do
            record_crit(e, hit_dmg)
            if swing_aim
              record_aim(base_location(swing_aim) != base_location(e[:disp]))
            end
          end
          live_output(e, hit_dmg)
          swing_aim = nil
          pending = 0
          buf = +""
        else
          pending -= 1
          if @data['prefs']['debug'] && line.strip =~ DEBUG_HINT
            echo("[crit-debug unmatched] #{line.strip}")
          end
        end
      end
    ensure
      shutdown
    end
  end

  before_dying { CritTracker.shutdown }
end

CritTracker.run
