  ph_echo '   ;namehighlights frontend warlock        Save Warlock import instructions'
  ph_echo '   ;namehighlights frontend=warlock        One-run frontend override'
  ph_echo '   ;namehighlights out=/path/to/names.xml  Write a custom export file'
  ph_echo '   Supported front ends: Wrayth, StormFront, and Warlock. Wizard/Avalon are not supported.'
  ph_echo '   Mac compatibility supported thanks to Eternil.'
  ph_echo "   Import file: #{default_export_path('wrayth')}"
  ph_echo "   Character data: #{CHARACTER_DATA_PATH}"
  ph_echo ''
end

def canonical_tag(config, tag_name)
  wanted = tag_name.to_s.strip
  return nil if wanted.empty?

  known_tags = tag_colors(config).keys + DEFAULT_TAG_COLORS.keys + (config['tag_colors'] || {}).keys
  known_tags.find { |tag| tag.downcase == wanted.downcase } || normalize_tag_name(wanted)
end

def valid_tag_name?(tag)
  tag.to_s =~ /\A[A-Za-z0-9][A-Za-z0-9 _-]*\z/
end

def normalize_person_name(name)
  text = name.to_s.strip.gsub(/[,;]/, '')
  return nil unless text =~ /\A[A-Za-z][A-Za-z'-]{1,29}\z/

  text.downcase.split(/([-'])/).map do |part|
    if part == '-' || part == "'"
      part
    else
      part[0].to_s.upcase + part[1, part.length].to_s
    end
  end.join
end

def tag_names(config, tag, names)
  tag = canonical_tag(config, tag)
  unless valid_tag_name?(tag)
    ph_echo "Invalid tag name: #{tag.inspect}. Use letters, numbers, underscores, or dashes."
    return false
  end

  config['tag_colors'] ||= {}
  config['tag_colors'][tag] ||= DEFAULT_TAG_COLORS[tag] || ['#FFFFFF', '#000000']
  data = character_data
  data['names'] ||= {}

  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  if normalized.empty?
    ph_echo 'No valid names provided.'
    return false
  end

  now = Time.now.utc.iso8601
  normalized.each do |name|
    existing = data['names'][name.downcase] || {}
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => existing['profession'].to_s,
      'race' => existing['race'].to_s,
      'custom_tag' => tag,
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => now,
      'profession_updated_at' => existing['profession_updated_at'].to_s,
      'race_updated_at' => existing['race_updated_at'].to_s,
      'custom_updated_at' => now,
    }
  end
  save_config(config)
  save_character_data(data)
  ph_echo "Tagged #{normalized.length} name(s) as #{tag}: #{normalized.join(', ')}"
  true
end

def untag_names(config, names)
  data = character_data
  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  removed = []
  normalized.each do |name|
    record = data['names'][name.downcase]
    next unless record.is_a?(Hash) && !record['custom_tag'].to_s.empty?

    record['custom_tag'] = ''
    record['custom_updated_at'] = Time.now.utc.iso8601
    removed << name
  end
  save_config(config)
  save_character_data(data)
  ph_echo "Removed manual tags from #{removed.length} name(s): #{removed.join(', ')}"
  true
end

def remove_tag(config, tag)
  tag = canonical_tag(config, tag)
  unless valid_tag_name?(tag)
    ph_echo 'Usage: ;namehighlights untag LABEL'
    return false
  end

  if DEFAULT_TAG_COLORS.keys.any? { |default_tag| default_tag.downcase == tag.downcase }
    ph_echo "#{tag} is a built-in tag and cannot be removed. Use remove NAME to clear names from it."
    return false
  end

  config['tag_colors'] ||= {}
  config['disabled_tags'] ||= []

  unless config['tag_colors'].keys.any? { |custom_tag| custom_tag.downcase == tag.downcase }
    ph_echo "No custom tag named #{tag} exists."
    return false
  end

  config['tag_colors'].delete_if { |custom_tag, _pair| custom_tag.to_s.downcase == tag.downcase }
  config['disabled_tags'] << tag.downcase
  config['disabled_tags'].uniq!

  removed_names = []
  data = character_data
  (data['names'] || {}).each_value do |entry|
    next unless entry.is_a?(Hash) && entry['custom_tag'].to_s.downcase == tag.downcase

    removed_names << entry['name']
    entry['custom_tag'] = ''
    entry['custom_updated_at'] = Time.now.utc.iso8601
  end

  save_config(config)
  save_character_data(data)
  ph_echo "Removed tag #{tag} and #{removed_names.length} tagged name(s)."
  true
end

def set_tag_color(config, tag, fore, back)
  tag = canonical_tag(config, tag)
  fore = normalize_hex(fore)
  back = normalize_background(back, nil)
  unless valid_tag_name?(tag) && fore && !back.nil?
    ph_echo 'Usage: ;namehighlights tag LABEL #RRGGBB #RRGGBB'
    ph_echo '       Use none, transparent, clear, or blank for no background.'
    return false
  end

  config['tag_colors'] ||= {}
  config['disabled_tags'] ||= []
  config['disabled_tags'].delete_if { |disabled| disabled.to_s.downcase == tag.downcase }
  config['tag_colors'][tag] = [fore, back]
  save_config(config)
  ph_echo "Set #{tag} colors to #{fore} on #{back}"
  true
end

def split_label_and_names(raw_args)
  joined = raw_args.join(' ')
  if joined.include?(';')
    label, rest = joined.split(';', 2)
    names = rest.to_s.split(/[,\s]+/)
    [label.to_s.strip, names]
  else
    [raw_args[0].to_s.strip, raw_args[1, raw_args.length] || []]
  end
end

def manual_set_race(config, raw_args)
  race, names = split_label_and_names(raw_args)
  canonical_race = RACES.find { |known| known.downcase == race.downcase }
  unless canonical_race
    ph_echo "Unknown race: #{race}. Valid races: #{RACES.join(', ')}"
    return false
  end
  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  return ph_echo('No valid names provided.') || false if normalized.empty?

  data = character_data
  now = Time.now.utc.iso8601
  normalized.each do |name|
    existing = data['names'][name.downcase] || {}
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => existing['profession'].to_s,
      'race' => canonical_race,
      'custom_tag' => existing['custom_tag'].to_s,
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => now,
      'profession_updated_at' => existing['profession_updated_at'].to_s,
      'race_updated_at' => now,
      'custom_updated_at' => existing['custom_updated_at'].to_s,
    }
  end
  save_character_data(data)
  ph_echo "Set race #{canonical_race} for #{normalized.length} name(s): #{normalized.join(', ')}"
  true
end

def manual_set_profession(config, raw_args)
  profession, names = split_label_and_names(raw_args)
  canonical_profession = DEFAULT_PROFESSION_COLORS.keys.find { |known| known.downcase == profession.downcase }
  unless canonical_profession
    ph_echo "Unknown profession: #{profession}. Valid professions: #{DEFAULT_PROFESSION_COLORS.keys.join(', ')}"
    return false
  end
  normalized = names.map { |name| normalize_person_name(name) }.compact.uniq
  return ph_echo('No valid names provided.') || false if normalized.empty?

  data = character_data
  now = Time.now.utc.iso8601
  normalized.each do |name|
    existing = data['names'][name.downcase] || {}
    data['names'][name.downcase] = {
      'name' => name,
      'profession' => canonical_profession,
      'race' => existing['race'].to_s,
      'custom_tag' => existing['custom_tag'].to_s,
      'first_seen' => existing['first_seen'].to_s.empty? ? now : existing['first_seen'].to_s,
      'last_seen' => now,
      'profession_updated_at' => now,
      'race_updated_at' => existing['race_updated_at'].to_s,
      'custom_updated_at' => existing['custom_updated_at'].to_s,
    }
  end
  save_character_data(data)
  ph_echo "Set profession #{canonical_profession} for #{normalized.length} name(s): #{normalized.join(', ')}"
  true
end

def print_profession_changes(config)
  changes = config['profession_changes'] || []
  if changes.empty?
    ph_echo 'No profession changes have been recorded.'
    return
  end

  ph_echo "Recorded profession changes: #{changes.length}"
  changes.last(100).each do |entry|
    ph_echo "  #{entry['name']}: #{entry['old_profession']} -> #{entry['new_profession']} @ #{entry['changed_at']}"
  end
end

def print_profession_legend(config, colors, debug = false)
  mode = current_mode(config)
  remembered = remembered_profession_names(config, mode)
  race_color_map = race_colors(config)
  profession_color_map = profession_colors(config)
  tag_color_map = tag_colors(config)
  ph_echo 'Name highlight legend:'
  if mode != 'race_profession'
    groups = active_highlight_colors(config, mode)
    unless debug
      labels = groups.keys.map { |group| legend_label(group) }
      columns = labels.length >= 9 ? 3 : 2
      rows = (labels.length.to_f / columns).ceil
      width = labels.map(&:length).max.to_i + 4
      rows.times do |row|
        line = ''
        columns.times do |column|
          label = labels[row + (column * rows)]
          line << label.ljust(width) if label
        end
        ph_echo "  #{line.rstrip}"
      end
      ph_echo 'Import Custom highlights to color these labels.'
      return
    end
    groups.each do |group, pair|
      fore, back = pair
      sample_names = remembered[group].to_a.first(5)
      sample = sample_names.empty? ? "#{group} sample" : sample_names.join(', ')
      ph_echo "  #{legend_label(group).ljust(24)} #{fore} on #{back.empty? ? 'None' : back}  #{sample}"
    end
    return
  end

  ph_echo '  Custom labels override race/profession colors.'
  ph_echo ''
  unless debug
    [
      ['Races - Fore', race_color_map.keys],
      ['Professions - Back', profession_color_map.keys],
      ['Custom', tag_color_map.keys],
    ].each do |title, names|
      ph_echo title
      labels = names.map { |name| legend_label(name) }
      columns = labels.length >= 9 ? 3 : 2
      rows = (labels.length.to_f / columns).ceil
      width = labels.map(&:length).max.to_i + 4
      rows.times do |row|
        line = ''
        columns.times do |column|
          label = labels[row + (column * rows)]
          next unless label

          line << label.ljust(width)
        end
        ph_echo "  #{line.rstrip}"
      end
      ph_echo ''
    end
    ph_echo 'Import Custom highlights to color these labels.'
    return
  end

  ph_echo 'Races - Fore:'
  race_color_map.each do |race, pair|
    fore, back = pair
    ph_echo "  #{legend_label(race).ljust(24)} fore #{fore}  race-only back #{back.empty? ? 'None' : back}"
  end
  ph_echo ''
  ph_echo 'Professions - Back:'
  profession_color_map.each do |profession, pair|
    fore, back = pair
    sample_names = remembered[profession].to_a.first(5)
    sample = sample_names.empty? ? "#{profession} sample" : sample_names.join(', ')
    ph_echo "  #{legend_label(profession).ljust(24)} back #{back}  #{sample}"
  end
  ph_echo ''
  ph_echo 'Custom:'
  tag_color_map.each do |tag, pair|
    fore, back = pair
    ph_echo "  #{legend_label(tag).ljust(24)} #{fore} on #{back.empty? ? 'None' : back}"
  end
end

def xml_escape(text)
  text.to_s.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;').gsub('"', '&quot;').gsub("'", '&apos;')
end

def send_client_xml(xml)
  if defined?(_respond)
    _respond xml
  elsif defined?(respond)
    respond xml
  else
    puts xml
  end
end

def close_legend_window
  send_client_xml "<closeDialog id='NameHighlightsLegend' />"
  send_client_xml "<closeDialog id='namehighlightsLegend' />"
  send_client_xml "<closeStream id='namehighlightsLegend' />"
  send_client_xml "<clearStream id='namehighlightsLegend' />"
  ph_echo 'Closed the Name Highlights legend window.'
end

def open_legend_window(config, colors)
  unless dock_frontend?
    ph_echo 'Legend window requires StormFront/Wrayth/Warlock. Printing the legend here instead.'
    print_profession_legend(config, colors, false)
    return
  end

  buffer = []
  buffer << "<closeDialog id='NameHighlightsLegend' />"
  buffer << "<streamWindow id='namehighlightsLegend' title='Name Highlights' location='center' save='save' resident='true' />"
  buffer << "<exposeStream id='namehighlightsLegend' />"
  buffer << "<clearStream id='namehighlightsLegend' />"
  buffer << "<pushStream id='namehighlightsLegend' />"
  buffer << "<output class='mono' />"
  if current_mode(config) == 'race_profession'
    buffer << "Custom wins\n\n"
    [
      ['Races - Fore', race_colors(config).keys],
      ['Professions - Back', profession_colors(config).keys],
      ['Custom', tag_colors(config).keys],
    ].each do |title, names|
      buffer << "#{xml_escape(title)}\n"
      names.each do |group|
        buffer << "#{xml_escape(legend_label(group))}\n"
      end
      buffer << "\n"
    end
  else
    active_highlight_colors(config).each_key do |group|
      buffer << "#{xml_escape(legend_label(group))}\n"
    end
  end
  buffer << "<output class='' />"
  buffer << "<popStream/>"
  send_client_xml buffer.join
  ph_echo 'Opened/updated the resident Name Highlights legend window.'
end

def print_remembered_names(config)
  remembered = remembered_profession_names(config, current_mode(config))
  total = remembered.values.flatten.length
  ph_echo "Remembered names: #{total}"
  remembered.each do |profession, names|
    ph_echo "#{profession} (#{names.length}):"
    if names.empty?
      ph_echo '  (none)'
    else
      names.each_slice(6) do |slice|
        ph_echo "  #{slice.join(', ')}"
      end
    end
  end
end

