#quiet
=begin
  tutelog
    author: Mystienne
   credits: Peggyanne - preset-colored report style inspiration
      game: GemStone
   version: 1.3.7
      tags: utility, experience, lumnis, tutelage

  Watches live EXP pulses in the background.

  It sends one silent EXPERIENCE check when it starts so it can tell whether
  Tutelage is active, then it watches Lich's live EXP data without sending more
  EXPERIENCE commands.

  tutelog can be used by itself for pulse messages and CSV logging, but it is
  recommended to use tutelog with xp2. xp2 is the command, setup, and report
  side. tutelog is the background pulse watcher. When both are used, tutelog can
  feed xp2 better Tutelage status, current Tutelage reports, pulse session
  totals, and shared settings.

  It can print optional pulse messages, keep simple pulse session totals, and
  save one CSV log per character per Lumnis/Tutelage cycle. It also keeps a
  small private checkpoint so totals can survive restarts.

  Normal settings are handled from ;xp2 setup. Use ;tutelog help to see direct
  commands. A second watcher will refuse to start so two copies do not record
  the same pulses.
=end
require 'fileutils'
require 'yaml'

script_name = 'tutelog'
command = script.vars[0].to_s.downcase.strip
command_value = script.vars[1].to_s.downcase.strip
preview_command = %w[tu tut tute tutel tutela tutelag tutelage].include?(command)
tutelog_running_count = begin
  Script.running.count { |running_script| running_script.name.to_s.downcase == script_name }
rescue
  1
end
if command.empty? && tutelog_running_count > 1
  echo 'tutelog is already running. Use ;kill tutelog first, or ;force tutelog <command> for settings.'
  exit
end
save_vars = proc {}
lich_dir_for_room_modes = defined?(LICH_DIR) ? LICH_DIR : File.expand_path('..', File.dirname(__FILE__))
tutelog_room_modes_path = proc do
  game = begin
           XMLData.respond_to?(:game) && XMLData.game ? XMLData.game.to_s : 'GSIV'
         rescue
           'GSIV'
         end
  char = begin
           XMLData.respond_to?(:name) && XMLData.name ? XMLData.name.to_s : 'unknown'
         rescue
           'unknown'
         end
  folder = "#{game}-#{char}".gsub(/[^A-Za-z0-9_.-]+/, '_')
  File.join(lich_dir_for_room_modes, 'data', 'tutelog', folder, 'settings.yaml')
end
tutelog_current_game = proc do
  begin
    XMLData.respond_to?(:game) && XMLData.game ? XMLData.game.to_s : 'GSIV'
  rescue
    'GSIV'
  end
end
tutelog_current_room_id = proc do
  begin
    room_id = Room.current.id if defined?(Room) && Room.respond_to?(:current) && Room.current && Room.current.respond_to?(:id)
    room_id.to_s unless room_id.nil? || room_id.to_s.empty?
  rescue
    nil
  end
end
tutelog_load_room_modes = proc do
  begin
    data = File.exist?(tutelog_room_modes_path.call) ? YAML.load_file(tutelog_room_modes_path.call) : {}
    data.is_a?(Hash) ? data : {}
  rescue
    {}
  end
end
tutelog_settings_yaml_keys = %w[
  xp2_check_lumnis xp2_check_resource xp2_check_ascension xp2_debug xp2_layout xp2_goal
  xp2_tutelage_bonus_used xp2_tutelage_reset_at xp2_tutelage_last_exp xp2_tutelage_state
  xp2_tutelage_state_at xp2_tutelage_days xp2_lumnis_phase xp2_lumnis_phase_remaining
  xp2_lumnis_expired xp2_rpa_active xp2_tutelage_source xp2_tutelage_tutelog_at
  xp2_tutelage_tutelog_cycle xp2_tutelage_tutelog_reset_at xp2_tutelage_tutelog_total_exp
  xp2_tutelage_reward_exp xp2_last_atps xp2_last_absorb_rate
]
tutelog_legacy_tutelog_keys = {
  'hint' => 'tutelog_hint',
  'notify_pulses' => 'tutelog_notify_pulses',
  'logging_enabled' => 'tutelog_logging_enabled',
  'preserve_cycles' => 'tutelog_preserve_cycles',
  'output_style' => 'tutelog_output_style',
  'lumnis_remaining_est' => 'tutelog_lumnis_remaining_est',
  'lumnis_source_remaining' => 'tutelog_lumnis_source_remaining',
  'last_xp2_refresh_at' => 'tutelog_last_xp2_refresh_at',
  'last_xp2_refresh_reason' => 'tutelog_last_xp2_refresh_reason',
  'started_at' => 'tutelog_started_at',
  'tutelage_started_at' => 'tutelog_tutelage_started_at',
  'log_path' => 'tutelog_log_path',
  'csv_path' => 'tutelog_csv_path',
  'cycle_label' => 'tutelog_cycle_label',
  'last_next_text' => 'tutelog_last_next_text',
  'last_next_value' => 'tutelog_last_next_value',
  'last_next_mode' => 'tutelog_last_next_mode',
  'session_exp_total' => 'tutelog_session_exp_total',
  'session_bonus_total' => 'tutelog_session_bonus_total',
  'pulse_count' => 'tutelog_pulse_count',
  'reward_exp_total' => 'tutelog_reward_exp_total',
  'reward_count' => 'tutelog_reward_count'
}
tutelog_load_settings_yaml = proc do
  begin
    data = File.exist?(tutelog_room_modes_path.call) ? YAML.load_file(tutelog_room_modes_path.call) : {}
    data.is_a?(Hash) ? data : {}
  rescue
    {}
  end
end
tutelog_save_settings_yaml = proc do |data|
  FileUtils.mkdir_p(File.dirname(tutelog_room_modes_path.call))
  File.open(tutelog_room_modes_path.call, 'w') { |file| file.write(data.to_yaml) }
end
tutelog_apply_yaml_settings = proc do |data|
  tutelog_settings_yaml_keys.each { |key| Vars[key] = data[key] if data.key?(key) }
  Vars['tutelog'] = data['tutelog'] if data['tutelog'].is_a?(Hash)
end
tutelog_collect_runtime_settings = proc do
  data = tutelog_load_settings_yaml.call
  tutelog_settings_yaml_keys.each { |key| data[key] = Vars[key] unless Vars[key].nil? }
  data['tutelog'] = Vars['tutelog'] if Vars['tutelog'].is_a?(Hash)
  unless data['tutelog'].is_a?(Hash)
    legacy_tutelog = {}
    tutelog_legacy_tutelog_keys.each { |new_key, old_key| legacy_tutelog[new_key] = Vars[old_key] unless Vars[old_key].nil? }
    data['tutelog'] = legacy_tutelog unless legacy_tutelog.empty?
  end
  data
end
tutelog_prune_persisted_vars = proc do |data|
  next unless Vars.respond_to?(:delete)
  tutelog_settings_yaml_keys.each { |key| Vars.delete(key) }
  Vars.delete('tutelog')
  tutelog_legacy_tutelog_keys.values.each { |key| Vars.delete(key) }
  Vars.keys.map(&:to_s).grep(/^tutelog_/).each { |key| Vars.delete(key) } if Vars.respond_to?(:keys)
  Vars.save if Vars.respond_to?(:save)
  tutelog_apply_yaml_settings.call(data)
end
tutelog_persist_settings = proc do
  data = tutelog_collect_runtime_settings.call
  tutelog_save_settings_yaml.call(data)
  tutelog_prune_persisted_vars.call(data)
  data
end
tutelog_migrate_settings = proc do
  data = tutelog_load_settings_yaml.call
  if data.empty?
    data = tutelog_collect_runtime_settings.call
    unless data.empty?
      tutelog_save_settings_yaml.call(data)
      tutelog_prune_persisted_vars.call(data)
    end
  else
    tutelog_apply_yaml_settings.call(data)
    tutelog_prune_persisted_vars.call(data)
  end
end
tutelog_migrate_settings.call
save_vars = proc { tutelog_persist_settings.call }
tutelog_save_room_modes = proc do |data|
  FileUtils.mkdir_p(File.dirname(tutelog_room_modes_path.call))
  File.open(tutelog_room_modes_path.call, 'w') { |file| file.write(data.to_yaml) }
end
tutelog_absorb_modes = %w[auto supernode node town other]
tutelog_room_mode_override_for = proc do |room_id = tutelog_current_room_id.call|
  room_key = room_id.to_s
  next nil if room_key.empty?
  data = tutelog_load_settings_yaml.call
  room_modes = data['room_modes'] || data[:room_modes] || {}
  mode = room_modes[room_key] || room_modes[room_key.to_i] || room_modes[room_key.to_sym]
  mode = mode.to_s.downcase
  tutelog_absorb_modes.include?(mode) && mode != 'auto' ? mode : nil
end
tutelog_set_room_mode_override = proc do |mode|
  room_id = tutelog_current_room_id.call
  next [ false, 'current room is not available' ] if room_id.to_s.empty?
  data = tutelog_load_settings_yaml.call
  room_modes = data['room_modes'] || data[:room_modes] || {}
  room_modes = {} unless room_modes.is_a?(Hash)
  data.delete(:room_modes) if data.key?(:room_modes)
  data['room_modes'] = room_modes.transform_keys(&:to_s)
  if mode == 'auto'
    data['room_modes'].delete(room_id.to_s)
    tutelog_save_settings_yaml.call(data)
    [ true, "room #{room_id} will use auto absorb mode." ]
  else
    data['room_modes'][room_id.to_s] = mode
    tutelog_save_settings_yaml.call(data)
    [ true, "room #{room_id} absorb mode saved as #{mode}." ]
  end
end
tutelog_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : {}
legacy_tutelog_keys = {
  'hint' => 'tutelog_hint',
  'notify_pulses' => 'tutelog_notify_pulses',
  'logging_enabled' => 'tutelog_logging_enabled',
  'preserve_cycles' => 'tutelog_preserve_cycles',
  'output_style' => 'tutelog_output_style',
  'lumnis_remaining_est' => 'tutelog_lumnis_remaining_est',
  'lumnis_source_remaining' => 'tutelog_lumnis_source_remaining',
  'last_xp2_refresh_at' => 'tutelog_last_xp2_refresh_at',
  'last_xp2_refresh_reason' => 'tutelog_last_xp2_refresh_reason',
  'started_at' => 'tutelog_started_at',
  'tutelage_started_at' => 'tutelog_tutelage_started_at',
  'log_path' => 'tutelog_log_path',
  'csv_path' => 'tutelog_csv_path',
  'cycle_label' => 'tutelog_cycle_label',
  'last_next_text' => 'tutelog_last_next_text',
  'last_next_value' => 'tutelog_last_next_value',
  'last_next_mode' => 'tutelog_last_next_mode',
  'session_exp_total' => 'tutelog_session_exp_total',
  'session_bonus_total' => 'tutelog_session_bonus_total',
  'pulse_count' => 'tutelog_pulse_count',
  'reward_exp_total' => 'tutelog_reward_exp_total',
  'reward_count' => 'tutelog_reward_count'
}
legacy_tutelog_keys.each do |new_key, old_key|
  tutelog_state[new_key] = Vars[old_key] if tutelog_state[new_key].nil? && !Vars[old_key].nil?
end
tutelog_state['hint'] = 'unknown' if tutelog_state['hint'].to_s.empty?
tutelog_state['notify_pulses'] = 'off' if tutelog_state['notify_pulses'].to_s.empty?
tutelog_state['logging_enabled'] = 'on' if tutelog_state['logging_enabled'].to_s.empty?
tutelog_state['preserve_cycles'] = '6' if tutelog_state['preserve_cycles'].to_i < 1
tutelog_output_styles = %w[csv none]
tutelog_state['output_style'] = 'csv' unless tutelog_output_styles.include?(tutelog_state['output_style'].to_s)

tutelog_state['absorb_room_mode'] = 'auto' unless tutelog_absorb_modes.include?(tutelog_state['absorb_room_mode'].to_s)
tutelog_reset_modes = %w[daily run idle]
tutelog_state['general_reset_mode'] = 'run' if tutelog_state['general_reset_mode'].to_s.empty?
tutelog_state['general_reset_mode'] = 'run' unless tutelog_reset_modes.include?(tutelog_state['general_reset_mode'].to_s)
tutelog_state['general_idle_minutes'] = '480' if tutelog_state['general_idle_minutes'].to_i < 1
tutelog_state['no_pulse_alert'] = 'off' if tutelog_state['no_pulse_alert'].to_s.empty?
tutelog_state['no_pulse_minutes'] = '10' if tutelog_state['no_pulse_minutes'].to_i < 1
save_tutelog_state = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : {}
  tutelog_state['notify_pulses'] = current_state['notify_pulses'] if current_state.key?('notify_pulses')
  tutelog_state['hint'] = current_state['hint'] if current_state.key?('hint')
  tutelog_state['logging_enabled'] = current_state['logging_enabled'] if current_state.key?('logging_enabled')
  tutelog_state['preserve_cycles'] = current_state['preserve_cycles'] if current_state.key?('preserve_cycles')
  tutelog_state['output_style'] = current_state['output_style'] if current_state.key?('output_style')
  tutelog_state['absorb_room_mode'] = current_state['absorb_room_mode'] if current_state.key?('absorb_room_mode')
  tutelog_state['general_reset_mode'] = current_state['general_reset_mode'] if current_state.key?('general_reset_mode')
  tutelog_state['general_idle_minutes'] = current_state['general_idle_minutes'] if current_state.key?('general_idle_minutes')
  tutelog_state['no_pulse_alert'] = current_state['no_pulse_alert'] if current_state.key?('no_pulse_alert')
  tutelog_state['no_pulse_minutes'] = current_state['no_pulse_minutes'] if current_state.key?('no_pulse_minutes')
  %w[
    general_started_at general_session_date general_pulse_count general_exp_total
    general_reward_count general_reward_exp_total general_rpa_pulse_count
    general_rpa_exp_total general_last_pulse_at general_last_pulse_exp
    general_last_mind general_last_reset_at general_reset_reason
    general_last_decode_mode general_last_expected_pulse general_last_observed_multiplier
    general_last_extra_multiplier general_last_extra_exp general_last_decode_confidence
  ].each { |key| tutelog_state[key] = current_state[key] if current_state.key?(key) }

  tutelog_state['logging_enabled'] = 'on' if tutelog_state['logging_enabled'].to_s.empty?
  tutelog_state['preserve_cycles'] = '6' if tutelog_state['preserve_cycles'].to_i < 1
  tutelog_state['output_style'] = 'csv' unless tutelog_output_styles.include?(tutelog_state['output_style'].to_s)
  tutelog_state['absorb_room_mode'] = 'auto' unless tutelog_absorb_modes.include?(tutelog_state['absorb_room_mode'].to_s)
  tutelog_state['general_reset_mode'] = 'run' if tutelog_state['general_reset_mode'].to_s.empty?
  tutelog_state['general_reset_mode'] = 'run' unless tutelog_reset_modes.include?(tutelog_state['general_reset_mode'].to_s)
  tutelog_state['general_idle_minutes'] = '480' if tutelog_state['general_idle_minutes'].to_i < 1
  tutelog_state['no_pulse_alert'] = 'off' if tutelog_state['no_pulse_alert'].to_s.empty?
  tutelog_state['no_pulse_minutes'] = '10' if tutelog_state['no_pulse_minutes'].to_i < 1
  Vars['tutelog'] = tutelog_state
  legacy_tutelog_keys.values.each { |old_key| Vars.delete(old_key) if Vars.respond_to?(:delete) }
  save_vars.call
end
save_tutelog_hint = proc do |value|
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
  current_state['hint'] = value
  Vars['tutelog'] = current_state
  tutelog_state.replace(current_state)
  legacy_tutelog_keys.values.each { |old_key| Vars.delete(old_key) if Vars.respond_to?(:delete) }
  save_vars.call
end
save_tutelog_state.call unless preview_command
checkbox_active = proc { |checkbox| checkbox.respond_to?(:active?) ? checkbox.active? : checkbox.active }
clear_tutelage_live_cache = proc do
  Vars['xp2_tutelage_bonus_used'] = '0'
  Vars['xp2_tutelage_source'] = 'xp2'
  Vars['xp2_tutelage_tutelog_at'] = '0'
  Vars['xp2_tutelage_tutelog_cycle'] = ''
  Vars['xp2_tutelage_tutelog_reset_at'] = '0'
  Vars['xp2_tutelage_tutelog_total_exp'] = '0'
  Vars['xp2_tutelage_reward_exp'] = '0'
  %w[session_exp_total session_bonus_total reward_exp_total reward_count pulse_count].each { |key| tutelog_state[key] = '0' }
  tutelog_state['tutelage_started_at'] = ''
  Vars['tutelog'] = tutelog_state
end
tutelog_changelog_text = proc do
  output = "\n"
  output.concat "tutelog changelog:\n"
  output.concat "\n"
  output.concat "06-30-2026\n"
  output.concat "   1.3.7 chore(docs): explain how tutelog and xp2 work together and why using both is recommended.\n"
  output.concat "\n"
  output.concat "06-28-2026\n"
  output.concat "   1.3.6 chore(docs): clean up the header, changelog labels, and help command coverage.\n"
  output.concat "\n"
  output.concat "06-23-2026\n"
  output.concat "   1.3.5 feat(tutelage): allow bonus percent to show over 100% when the estimate goes over the expected bonus amount.\n"
  output.concat "\n"
  output.concat "06-21-2026\n"
  output.concat "   1.3.4 fix(tutelage): clear stale estimates when LUMNIS INFO says Tutelage is not presently available.\n"
  output.concat "   1.3.4 chore(reports): stop asking users to send Tutelage files in story-window reports.\n"
  output.concat "\n"
  output.concat "06-14-2026\n"
  output.concat "   1.3.0 feat(settings): move xp2/tutelog settings to per-character settings.yaml and save room absorb overrides per room.\n"
  output.concat "   1.3.0 chore(output): simplify public output to CSV or none and keep report color and alignment cleanup.\n"
  output.concat "\n"
  output.concat "06-13-2026\n"
  output.concat "   1.1.0 feat(pulses): add general pulse session stats, mind/RPA pulse notices, no-pulse alerts, reward EXP handling, idle reset options, and startup Tutelage detection.\n"
  output.concat "   1.1.0 fix(reports): add OSA-style report colors, cleaner Tutelage report alignment, and safer setup closing.\n"
  output.concat "\n"
  output.concat "06-12-2026\n"
  output.concat "   1.1.0 feat(settings): add output controls, hidden no-log cycle tracking, setup tooltips, second-watcher protection, and cleaner current/latest Tutelage reports.\n"
  output.concat "\n"
  output.concat "06-11-2026\n"
  output.concat "   1.1.0 feat(tutelage): add Tutelage pulse watching, Lumnis countdown checks, offline absorb estimates, pulse notifications, and end-of-Tutelage reports.\n"
  output
end
if [ 'help', '--help', '-h', '?' ].include?(command)
  output = "\n"
  help_inline_preset = proc do |preset, text|
    preset = preset.to_s
    if %w[monster creature error yellow bold].include?(preset)
      "#{monsterbold_start}#{text}#{monsterbold_end}"
    else
      "<preset id=\"#{preset}\">#{text}</preset>"
    end
  end
  help_mono_block = proc do |text|
    if defined?(_respond)
      _respond %Q{<output class="mono"/>\n#{text}<output class=""/>}
    else
      respond text
    end
  end
  command_width = 45
  help_section = proc do |text|
    output.concat "\n#{help_inline_preset.call('thought', "#{text}:")}\n"
  end
  help_line = proc do |command_text, description = ''|
    command_text = command_text.to_s
    padding = ' ' * [command_width - command_text.length, 2].max
    output.concat "   #{help_inline_preset.call('speech', command_text)}#{padding}#{description}\n"
  end
  help_note = proc do |text|
    output.concat "      #{text}\n"
  end
  output.concat "#{help_inline_preset.call('thought', 'tutelog help:')}\n"
  help_section.call('start / stop')
  help_line.call(";#{script_name}", 'start watching EXP pulses')
  help_line.call(";kill #{script_name}", 'stop watching EXP pulses')
  help_line.call(";#{script_name} help", 'show this help')
  help_section.call('settings')
  help_line.call(";force #{script_name} setup", 'open settings while tutelog is running')
  help_line.call(";force #{script_name} settings|gui", 'open settings while tutelog is running')
  help_line.call(";force #{script_name} logging on|off", 'turn public logging on or off')
  help_line.call(";force #{script_name} output csv|none", 'set file output style')
  help_line.call(";force #{script_name} roommode auto|supernode|node|town|other", 'set current room absorb mode')
  help_line.call(";force #{script_name} preserve #", 'set how many cycles to keep')
  help_line.call(";force #{script_name} nopulse on|off|#", 'set no-pulse alerts')
  help_section.call('pulse session')
  help_line.call(";force #{script_name} resetmode daily|run|idle", 'set pulse reset mode')
  help_line.call(";force #{script_name} idle #", 'set idle reset minutes')
  help_section.call('reports')
  help_line.call(";force #{script_name} tutelage", 'show current/latest Tutelage report')
  help_line.call(";force #{script_name} changelog", 'show recent changes')
  help_line.call(";force #{script_name} changes|history", 'show recent changes')
  help_section.call('testing')
  help_line.call(";force #{script_name} active", 'mark later rows as active for testing')
  help_line.call(";force #{script_name} inactive", 'mark later rows as inactive for testing')
  help_line.call(";force #{script_name} unknown", 'clear the testing hint')
  help_section.call('notes')
  help_note.call('Most settings are easier from ;xp2 setup.')
  help_note.call('CSV files open cleanly in Excel or Google Sheets.')
  output.concat "\n"
  help_mono_block.call(output)
  exit
end
if [ 'changelog', 'changes', 'history' ].include?(command)
  respond tutelog_changelog_text.call
  exit
end

if command == 'logging'
  case command_value
  when 'on', 'yes', 'true', '1'
    current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
    current_state['logging_enabled'] = 'on'
    Vars['tutelog'] = current_state
    save_vars.call
    echo 'logging is now on.'
  when 'off', 'no', 'false', '0'
    current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
    current_state['logging_enabled'] = 'off'
    Vars['tutelog'] = current_state
    save_vars.call
    echo 'logging is now off.'
  else
    echo "Usage: ;#{script_name} logging on|off"
  end
  exit
end

if command == 'output'
  style = command_value
  if tutelog_output_styles.include?(style)
    current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
    current_state['output_style'] = style
    Vars['tutelog'] = current_state
    save_vars.call
    echo "output style is now #{style}."
  else
    echo "Usage: ;#{script_name} output csv|none"
  end
  exit
end

if command == 'roommode'
  mode = command_value
  if tutelog_absorb_modes.include?(mode)
    ok, message = tutelog_set_room_mode_override.call(mode)
    echo message
  else
    echo "Usage: ;#{script_name} roommode auto|supernode|node|town|other"
  end
  exit
end

if command == 'preserve'
  preserve_cycles = script.vars[1].to_s.gsub(/[^0-9]/, '').to_i
  if preserve_cycles < 1
    echo "Usage: ;#{script_name} preserve #"
  else
    current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
    current_state['preserve_cycles'] = preserve_cycles.to_s
    Vars['tutelog'] = current_state
    save_vars.call
    echo "preserving #{preserve_cycles} Tutelage cycle log#{preserve_cycles == 1 ? '' : 's'}."
  end
  exit
end

if command == 'resetmode'
  mode = command_value
  if tutelog_reset_modes.include?(mode)
    current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
    current_state['general_reset_mode'] = mode
    Vars['tutelog'] = current_state
    save_vars.call
    echo "general pulse reset mode is now #{mode}."
  else
    echo "Usage: ;#{script_name} resetmode daily|run|idle"
  end
  exit
end

if command == 'idle'
  minutes = script.vars[1].to_s.gsub(/[^0-9]/, '').to_i
  if minutes < 1
    echo "Usage: ;#{script_name} idle #"
  else
    current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
    current_state['general_idle_minutes'] = minutes.to_s
    Vars['tutelog'] = current_state
    save_vars.call
    echo "general pulse idle reset is now #{minutes} minute#{minutes == 1 ? '' : 's'}."
  end
  exit
end

if command == 'nopulse'
  value = command_value
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
  case value
  when 'on', 'yes', 'true', '1'
    current_state['no_pulse_alert'] = 'on'
    Vars['tutelog'] = current_state
    save_vars.call
    echo 'no-pulse alerts are now on.'
  when 'off', 'no', 'false', '0'
    current_state['no_pulse_alert'] = 'off'
    Vars['tutelog'] = current_state
    save_vars.call
    echo 'no-pulse alerts are now off.'
  else
    minutes = value.to_s.gsub(/[^0-9]/, '').to_i
    if minutes > 0
      current_state['no_pulse_minutes'] = minutes.to_s
      current_state['no_pulse_alert'] = 'on'
      Vars['tutelog'] = current_state
      save_vars.call
      echo "no-pulse alerts are now on at #{minutes} minute#{minutes == 1 ? '' : 's'}."
    else
      echo "Usage: ;#{script_name} nopulse on|off|#"
    end
  end
  exit
end

if [ 'setup', 'settings', 'gui' ].include?(command)
  unless defined?(Gtk)
    echo 'tutelog setup is not available because GTK is not loaded.'
    exit
  end
  if defined?($tutelog_settings_window) && $tutelog_settings_window
    Gtk.queue { $tutelog_settings_window.present }
    exit
  end

  done = false
  settings_closed = false
  settings_message = nil
  Gtk.queue {
    set_tooltip = proc do |widget, text|
      if widget.respond_to?(:tooltip_text=)
        widget.tooltip_text = text
      elsif widget.respond_to?(:set_tooltip_text)
        widget.set_tooltip_text(text)
      end
    end
    table = Gtk::Table.new(10, 2)
    row = 0

    logging_checkbox = Gtk::CheckButton.new('Log Tutelage data')
    logging_checkbox.active = tutelog_state['logging_enabled'].to_s !~ /^(off|no|false|0)$/i
    set_tooltip.call(logging_checkbox, 'When on, tutelog writes a public CSV file when output is set to CSV. When off, tutelog still keeps a hidden per-character cycle state file for tracking, but does not ask anyone to send it.')
    table.attach(logging_checkbox, 0, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    notify_checkbox = Gtk::CheckButton.new('Print pulse notifications')
    notify_checkbox.active = tutelog_state['notify_pulses'].to_s =~ /^(on|yes|true|1)$/i
    set_tooltip.call(notify_checkbox, 'When on, tutelog prints pulse messages in the story window, including pulse EXP and Tutelage totals when active. When off, it keeps tracking quietly.')
    table.attach(notify_checkbox, 0, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    no_pulse_checkbox = Gtk::CheckButton.new('Warn when pulses stop')
    no_pulse_checkbox.active = tutelog_state['no_pulse_alert'].to_s =~ /^(on|yes|true|1)$/i
    set_tooltip.call(no_pulse_checkbox, 'When on, tutelog prints one story-window warning if no EXP pulse arrives for the chosen number of minutes. It is off by default.')
    table.attach(no_pulse_checkbox, 0, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    reset_mode_label = Gtk::Label.new('General reset')
    reset_mode_combo = Gtk::ComboBoxText.new
    tutelog_reset_modes.each { |mode| reset_mode_combo.append_text(mode) }
    reset_mode_combo.active = tutelog_reset_modes.index(tutelog_state['general_reset_mode'].to_s) || 0
    set_tooltip.call(reset_mode_label, 'Chooses when non-Tutelage pulse session stats reset. daily resets on a new local date, run resets whenever tutelog starts, idle resets after the chosen idle minutes.')
    set_tooltip.call(reset_mode_combo, 'Chooses when non-Tutelage pulse session stats reset. daily resets on a new local date, run resets whenever tutelog starts, idle resets after the chosen idle minutes.')
    table.attach(reset_mode_label, 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    table.attach(reset_mode_combo, 1, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    idle_minutes_label = Gtk::Label.new('Idle reset minutes')
    idle_minutes_entry = Gtk::Entry.new
    idle_minutes_entry.text = tutelog_state['general_idle_minutes'].to_i.to_s
    set_tooltip.call(idle_minutes_label, 'Only used when General reset is idle. If tutelog starts after this many minutes without a pulse, the general pulse session starts fresh. Default is 480 minutes, which is 8 hours.')
    set_tooltip.call(idle_minutes_entry, 'Only used when General reset is idle. Use 1 or higher. Default is 480 minutes, which is 8 hours.')
    table.attach(idle_minutes_label, 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    table.attach(idle_minutes_entry, 1, 2, row, row + 1, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    no_pulse_minutes_label = Gtk::Label.new('No-pulse minutes')
    no_pulse_minutes_entry = Gtk::Entry.new
    no_pulse_minutes_entry.text = tutelog_state['no_pulse_minutes'].to_i.to_s
    set_tooltip.call(no_pulse_minutes_label, 'When no-pulse warnings are on, this is how many minutes without EXP before tutelog prints a warning. Default is 10.')
    set_tooltip.call(no_pulse_minutes_entry, 'When no-pulse warnings are on, this is how many minutes without EXP before tutelog prints a warning. Use 1 or higher. Default is 10.')
    table.attach(no_pulse_minutes_label, 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    table.attach(no_pulse_minutes_entry, 1, 2, row, row + 1, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    output_style_label = Gtk::Label.new('Output style')
    output_style_combo = Gtk::ComboBoxText.new
    tutelog_output_styles.each { |style| output_style_combo.append_text(style) }
    output_style_combo.active = tutelog_output_styles.index(tutelog_state['output_style'].to_s) || 0
    set_tooltip.call(output_style_label, 'Controls public tutelog output. csv writes the spreadsheet file. none writes no public file and keeps only the hidden state file.')
    set_tooltip.call(output_style_combo, 'Controls public tutelog output. csv writes the spreadsheet file. none writes no public file and keeps only the hidden state file.')
    table.attach(output_style_label, 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    table.attach(output_style_combo, 1, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    preserve_label = Gtk::Label.new('Cycles to keep')
    preserve_entry = Gtk::Entry.new
    preserve_entry.text = tutelog_state['preserve_cycles'].to_i.to_s
    set_tooltip.call(preserve_label, 'How many old Tutelage cycle files to keep per character. Older CSV files and hidden state files are pruned after this limit.')
    set_tooltip.call(preserve_entry, 'How many old Tutelage cycle files to keep per character. Use 1 or higher. Default is 6.')
    table.attach(preserve_label, 0, 1, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    table.attach(preserve_entry, 1, 2, row, row + 1, Gtk::AttachOptions::EXPAND | Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    feedback = Gtk::Label.new('Changes save when this window closes.')
    feedback.use_markup = true if feedback.respond_to?(:use_markup=)
    table.attach(feedback, 0, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 4)
    row += 1

    update_feedback = proc {
      keep = preserve_entry.text.to_s.strip
      idle_minutes = idle_minutes_entry.text.to_s.strip
      no_pulse_minutes = no_pulse_minutes_entry.text.to_s.strip
      if keep !~ /^\d+$/ || keep.to_i < 1
        if feedback.respond_to?(:markup=)
          feedback.markup = '<span foreground="red">Cycles to keep must be 1 or higher.</span>'
        else
          feedback.text = 'Cycles to keep must be 1 or higher.'
        end
      elsif idle_minutes !~ /^\d+$/ || idle_minutes.to_i < 1
        if feedback.respond_to?(:markup=)
          feedback.markup = '<span foreground="red">Idle reset minutes must be 1 or higher.</span>'
        else
          feedback.text = 'Idle reset minutes must be 1 or higher.'
        end
      elsif no_pulse_minutes !~ /^\d+$/ || no_pulse_minutes.to_i < 1
        if feedback.respond_to?(:markup=)
          feedback.markup = '<span foreground="red">No-pulse minutes must be 1 or higher.</span>'
        else
          feedback.text = 'No-pulse minutes must be 1 or higher.'
        end
      else
        feedback.text = 'Changes save when this window closes.'
      end
    }
    preserve_entry.signal_connect('changed') { update_feedback.call }
    idle_minutes_entry.signal_connect('changed') { update_feedback.call }
    no_pulse_minutes_entry.signal_connect('changed') { update_feedback.call }
    update_feedback.call

    close_button = Gtk::Button.new(:label => 'Close')
    table.attach(close_button, 0, 2, row, row + 1, Gtk::AttachOptions::FILL, Gtk::AttachOptions::FILL, 6, 6)

    initial_settings = {
      'logging_enabled' => tutelog_state['logging_enabled'].to_s,
      'notify_pulses' => tutelog_state['notify_pulses'].to_s,
      'output_style' => tutelog_state['output_style'].to_s,
      'preserve_cycles' => tutelog_state['preserve_cycles'].to_i.to_s,
      'general_reset_mode' => tutelog_state['general_reset_mode'].to_s,
      'general_idle_minutes' => tutelog_state['general_idle_minutes'].to_i.to_s,
      'no_pulse_alert' => tutelog_state['no_pulse_alert'].to_s =~ /^(on|yes|true|1)$/i ? 'on' : 'off',
      'no_pulse_minutes' => tutelog_state['no_pulse_minutes'].to_i.to_s
    }

    save_settings = proc {
      keep = preserve_entry.text.to_s.strip
      idle_minutes = idle_minutes_entry.text.to_s.strip
      no_pulse_minutes = no_pulse_minutes_entry.text.to_s.strip
      if keep !~ /^\d+$/ || keep.to_i < 1
        settings_message = 'settings were not saved: cycles to keep must be 1 or higher.'
        update_feedback.call
        next false
      elsif idle_minutes !~ /^\d+$/ || idle_minutes.to_i < 1
        settings_message = 'settings were not saved: idle reset minutes must be 1 or higher.'
        update_feedback.call
        next false
      elsif no_pulse_minutes !~ /^\d+$/ || no_pulse_minutes.to_i < 1
        settings_message = 'settings were not saved: no-pulse minutes must be 1 or higher.'
        update_feedback.call
        next false
      end

      current_settings = {
        'logging_enabled' => checkbox_active.call(logging_checkbox) ? 'on' : 'off',
        'notify_pulses' => checkbox_active.call(notify_checkbox) ? 'on' : 'off',
        'output_style' => tutelog_output_styles[output_style_combo.active || 0] || 'csv',
        'preserve_cycles' => keep.to_i.to_s,
        'general_reset_mode' => tutelog_reset_modes[reset_mode_combo.active || 0] || 'run',
        'general_idle_minutes' => idle_minutes.to_i.to_s,
        'no_pulse_alert' => checkbox_active.call(no_pulse_checkbox) ? 'on' : 'off',
        'no_pulse_minutes' => no_pulse_minutes.to_i.to_s
      }
      if current_settings == initial_settings
        settings_message = 'settings were not saved: no changes were made.'
        feedback.text = 'No changes.'
        next false
      end

      current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
      current_settings.each { |key, value| current_state[key] = value }
      Vars['tutelog'] = current_state
      save_vars.call
      settings_message = 'settings saved.'
      feedback.text = 'Saved.'
      true
    }

    close_settings_window = proc {
      next if settings_closed
      settings_closed = true
      save_settings.call
      done = true
      window = $tutelog_settings_window
      $tutelog_settings_window = nil
      begin
        window.set_keep_above(false) if window && window.respond_to?(:set_keep_above)
      rescue
      end
      begin
        window.hide if window && window.respond_to?(:hide)
      rescue
      end
      if defined?(Gtk) && window
        Gtk.queue {
          begin
            window.destroy if window.respond_to?(:destroy)
          rescue
          end
        }
      end
    }

    close_button.signal_connect('clicked') { close_settings_window.call }

    $tutelog_settings_window = Gtk::Window.new
    $tutelog_settings_window.title = 'tutelog Settings'
    $tutelog_settings_window.add(table)
    $tutelog_settings_window.signal_connect('delete_event') {
      close_settings_window.call
      true
    }
    $tutelog_settings_window.signal_connect('destroy') {
      settings_closed = true
      done = true
      $tutelog_settings_window = nil
    }
    $tutelog_settings_window.set_default_size(360, 340)
    $tutelog_settings_window.set_keep_above(true)
    $tutelog_settings_window.set_window_position(:center)
    $tutelog_settings_window.show_all
  }
  wait_until { done }
  echo settings_message if settings_message
  Gtk.queue { $tutelog_settings_window = nil } if defined?(Gtk)
  exit
end

if [ 'active', 'inactive', 'unknown' ].include?(command)
  save_tutelog_hint.call(command)
  echo "Tutelage log hint set to #{command}."
  exit
end

timestamp = proc { Time.now.strftime('%Y-%m-%d %H:%M:%S') }
clean_value = proc { |value| value.to_s.gsub(/<[^>]+>/, ' ').gsub('|', '/').gsub(/\s+/, ' ').strip }
format_number = proc { |num| num.to_i.to_s.reverse.scan(/\d{1,3}/).join(',').reverse }
percent_text = proc do |value|
  value = [[value.to_f, 0.0].max, 100.0].min
  value >= 99.95 ? '100%' : format('%.1f%%', value)
end
tutelage_bonus_percent = proc do |bonus|
  value = [(bonus.to_f / 100_000.0) * 100.0, 0.0].max
  bonus.to_i > 100_000 ? format('%.1f%%', value) : percent_text.call(value)
end

format_duration = proc do |seconds|
  seconds = [ seconds.to_i, 0 ].max
  days = seconds / 86_400
  seconds %= 86_400
  hours = seconds / 3_600
  seconds %= 3_600
  minutes = seconds / 60
  parts = []
  parts << "#{days}d" if days > 0
  parts << "#{hours}h" if hours > 0 || days > 0
  parts << "#{minutes}m"
  parts.join(' ')
end
csv_columns = %w[
  timestamp event pulse bonus_est session_exp_total session_bonus_total
  reward_exp_total reward_count seconds_since_last rpa mind mind_previous
  tutelage_state lumnis_remaining_est room_id decode_mode room_tags room_location logic_bonus
  field_exp field_exp_max pool_bonus expected_pulse known_multiplier
  observed_multiplier extra_multiplier extra_exp decode_confidence decode_note details
]
csv_escape = proc do |value|
  text = clean_value.call(value)
  if text =~ /[",\r\n]/
    '"' + text.gsub('"', '""') + '"'
  else
    text
  end
end
output_style = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  style = current_state['output_style'].to_s
  tutelog_output_styles.include?(style) ? style : 'csv'
end
text_output_enabled = proc { false }
csv_output_enabled = proc { output_style.call == 'csv' }
notify_pulses = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  current_state['notify_pulses'].to_s =~ /^(on|yes|true|1)$/i
end
logging_enabled = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  current_state['logging_enabled'].to_s !~ /^(off|no|false|0)$/i
end
tutelage_available = proc do
  Vars['xp2_tutelage_state'].to_s == 'active' || Vars['xp2_tutelage_days'].to_i > 0
end
preserve_cycles = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  [ current_state['preserve_cycles'].to_i, 1 ].max
end
number_from_text = proc do |text|
  match = text.to_s.gsub(',', '').match(/-?\d+/)
  match ? match[0].to_i : nil
end
next_mode = proc { |text| text.to_s =~ /until next/i ? 'until_next' : 'total_exp' }
startup_total_exp = nil
current_exp_checkpoint = proc do
  computed_exp = nil
  begin
    computed_exp = Gemstone::Stats.exp if defined?(Gemstone::Stats) && Gemstone::Stats.respond_to?(:exp)
  rescue
    computed_exp = nil
  end
  computed_exp = computed_exp.to_i if computed_exp && computed_exp.to_i > 0
  if computed_exp && computed_exp > 0
    next { 'text' => "#{computed_exp} computed total exp", 'value' => computed_exp, 'mode' => 'total_exp', 'source' => 'computed_total_exp' }
  end
  if startup_total_exp.to_i > 0
    seeded_exp = startup_total_exp.to_i
    startup_total_exp = nil
    next { 'text' => "#{seeded_exp} startup total exp", 'value' => seeded_exp, 'mode' => 'total_exp', 'source' => 'startup_experience_total_exp' }
  end

  total_exp = nil
  begin
    total_exp = Gemstone::Experience.txp if defined?(Gemstone::Experience) && Gemstone::Experience.respond_to?(:txp)
  rescue
    total_exp = nil
  end
  total_exp = total_exp.to_i if total_exp && total_exp.to_i > 0
  if total_exp && total_exp > 0
    { 'text' => "#{total_exp} total exp", 'value' => total_exp, 'mode' => 'total_exp', 'source' => 'infomon_total_exp' }
  else
    text = XMLData.respond_to?(:next_level_text) && XMLData.next_level_text ? XMLData.next_level_text.to_s : ''
    { 'text' => text, 'value' => number_from_text.call(text), 'mode' => next_mode.call(text), 'source' => 'next_level' }
  end
end

lich_dir = defined?(LICH_DIR) ? LICH_DIR : File.expand_path('..', File.dirname(__FILE__))
game_name = XMLData.respond_to?(:game) && XMLData.game ? XMLData.game : 'GS'
char_name = XMLData.respond_to?(:name) && XMLData.name ? XMLData.name : 'unknown'
cycle_reset_at = Vars['xp2_tutelage_reset_at'].to_i
cycle_time = cycle_reset_at > 0 ? Time.at(cycle_reset_at) : Time.now
cycle_label = cycle_reset_at > 0 ? cycle_time.strftime('%Y%m%d') : 'unknown'
log_dir = File.join(lich_dir, 'logs', "#{game_name}-#{char_name}")
FileUtils.mkdir_p(log_dir) unless preview_command
log_path = File.join(log_dir, "tute_#{char_name}_c#{cycle_label}.log")
csv_path = File.join(log_dir, "tute_#{char_name}_c#{cycle_label}.csv")
state_dir = File.join(lich_dir, 'data', 'tutelog', "#{game_name}-#{char_name}".gsub(/[^A-Za-z0-9_.-]+/, '_'))
private_state_path = File.join(state_dir, "tute_#{char_name}_c#{cycle_label}.state")
read_private_state = proc do
  state = {}
  begin
    File.open(private_state_path, 'r') do |file|
      file.each_line do |line|
        key, value = line.chomp.split('=', 2)
        state[key] = value if key && value
      end
    end
  rescue
  end
  state
end
private_state = read_private_state.call
write_private_state = proc {}
styled_report_block = proc do |text, _preset = 'speech'|
  if defined?(_respond)
    _respond %Q{<output class="mono"/>\n#{text}<output class=""/>}
  else
    respond text
  end
end
styled_inline_preset = proc do |preset, text|
  preset = preset.to_s
  if %w[monster creature error yellow bold].include?(preset)
    "#{monsterbold_start}#{text}#{monsterbold_end}"
  else
    "<preset id=\"#{preset}\">#{text}</preset>"
  end
end
styled_inline_emphasis = proc { |text| styled_inline_preset.call('thought', text) }
styled_report_line = proc do |_preset, text|
  styled_report_block.call(text)
end
summary_file_lines = proc do |style, summary|
  report_style = style.to_s
  report_style = 'csv' if report_style.empty?
  summary ||= {}
  current_log_path = summary['log_path'].to_s.empty? ? log_path.to_s : summary['log_path'].to_s
  current_csv_path = summary['csv_path'].to_s.empty? ? csv_path.to_s : summary['csv_path'].to_s
  lines = []
  lines << "CSV: #{current_csv_path}" if report_style == 'csv' && !current_csv_path.empty?

  lines
end
print_finished_report = proc do |summary, style = output_style.call, preview = false|
  line = '------------------------------------------------------------'
  report_indent = '        '
  report_text = proc { |text| "#{report_indent}#{text}" }
  title = preview && summary['preview_title'] ? summary['preview_title'] : (preview ? '*~ Example Tutelage Report ~*' : '*~ Tutelage Logging Complete ~*')
  name = summary['character'].to_s.empty? ? char_name : summary['character'].to_s
  cycle = summary['cycle_label'].to_s.empty? ? cycle_label : summary['cycle_label'].to_s
  sendable_report = !preview || summary['sendable_report']
  file_lines = sendable_report ? summary_file_lines.call(style, summary) : []
  if sendable_report && style != 'none' && (preview || !summary['log_path'].to_s.empty? || !summary['csv_path'].to_s.empty?)
    file_lines = []
    file_lines << "CSV: #{summary['csv_path']}" if style == 'csv' && File.exist?(summary['csv_path'].to_s)

  end

  report_row = proc do |left_label, left_value, right_label = nil, right_value = nil|
    left_label_text = left_label.to_s.rjust(13)
    left_value_text = left_value.to_s
    left_plain = "#{left_label_text}: #{left_value_text}"
    left = "#{styled_inline_preset.call('speech', left_label_text)}: #{left_value_text}"
    if right_label
      right_label_text = right_label.to_s.rjust(13)
      right_value_text = right_value.to_s
      right = "#{styled_inline_preset.call('speech', right_label_text)}: #{right_value_text}"
      "  #{left}#{' ' * [31 - left_plain.length, 1].max}#{right}"
    else
      "  #{left}"
    end
  end

  report_lines = []
  report_lines << styled_inline_emphasis.call(title.center(line.length))
  report_lines << ''
  if preview && !summary['real_data']
    report_lines << "  Example data only - no Tutelage data was found for #{name}."
    report_lines << '  These numbers are only a sample of how a finished report will look.'
    report_lines << ''
  end
  report_lines << report_row.call('Character', name, 'Cycle', cycle)
  report_lines << report_row.call('Duration', summary['duration_text'], 'Pulses', format_number.call(summary['pulse_count']))
  report_lines << ''
  report_lines << report_row.call('EXP Tracked', format_number.call(summary['session_exp_total']), 'Est. Bonus', "#{format_number.call(summary['session_bonus_total'])} (#{tutelage_bonus_percent.call(summary['session_bonus_total'])})")
  if summary['reward_exp_total'].to_i > 0 || summary['reward_count'].to_i > 0
    report_lines << report_row.call('Reward EXP', format_number.call(summary['reward_exp_total']), 'Rewards', format_number.call(summary['reward_count']))
  end
  report_lines << ''
  report_lines << styled_inline_emphasis.call('  Pulse Stats')
  report_lines << report_row.call('Average', "#{summary['average_pulse']} EXP", 'Median', "#{format_number.call(summary['median_pulse'])} EXP")
  report_lines << report_row.call('Largest', "#{format_number.call(summary['largest_pulse'])} EXP", 'Unusual', "#{format_number.call(summary['unusual_pulse_count'])} pulses")
  report_lines << report_row.call('Unusual EXP', format_number.call(summary['unusual_exp_total']), 'Threshold', 'avg + 50')
  report_lines << ''
  report_lines << styled_inline_emphasis.call('  Adjusted Estimate')
  report_lines << report_row.call('Reward EXP removed', format_number.call(summary['reward_exp_total'])) if summary['reward_exp_total'].to_i > 0
  report_lines << report_row.call('EXP minus reward/unusual', format_number.call(summary['adjusted_exp_total']))
  report_lines << report_row.call('Bonus minus unusual', format_number.call(summary['adjusted_bonus_total']))
  report_lines << ''
  report_lines << styled_inline_preset.call('watching', '  Note: RPA or other stacked EXP bonuses may raise normal pulse size.')
  report_lines << ''
  if preview && !summary['real_data']
    report_lines << '  No CSV exists for this example.'
  elsif summary['still_recording']
    report_lines << styled_inline_preset.call('watching', '  This cycle is still recording.')
  elsif !sendable_report
    report_lines << styled_inline_preset.call('watching', '  Tutelage is not active now, and no completed CSV report was saved.')
  elsif style == 'none'
    report_lines << styled_inline_preset.call('watching', '  Logging was off, so no public CSV was saved.')
  elsif (preview || summary['real_data']) && file_lines.empty?
    report_lines << styled_inline_preset.call('watching', '  No public CSV was saved for this cycle.')
    report_lines << "  Hidden state: #{summary['state_path']}"
  else
    file_lines.each { |file_line| report_lines << "  #{file_line}" }
  end
  if preview
    report_lines << ''
    report_lines << "  #{summary['preview_note'] || 'Example only - no character data was saved or changed.'}"
  end
  styled_report_block.call(report_lines.join("\n"), 'speech')
end
if preview_command
  preview_styles = %w[csv none]
  preview_style = command_value.empty? ? output_style.call : command_value
  preview_style = 'csv' unless preview_styles.include?(preview_style)
  preview_char = char_name.to_s.empty? || char_name == 'unknown' ? 'Maraella' : char_name

  preview_parse_csv_line = proc do |line_text|
    fields = []
    current = ''
    quoted = false
    line_text.to_s.chomp.each_char do |char|
      if quoted
        if char == '"'
          quoted = false
        else
          current << char
        end
      else
        if char == '"'
          quoted = true
        elsif char == ','
          fields << current
          current = ''
        else
          current << char
        end
      end
    end
    fields << current
    fields
  end
  preview_blank_totals = proc { { 'session_exp_total' => 0, 'session_bonus_total' => 0, 'reward_exp_total' => 0, 'reward_count' => 0, 'pulses' => 0, 'pulse_values' => [], 'started_at' => 0, 'ended_at' => 0, 'saw_tutelage_data' => false, 'saw_log_request' => false } }
  preview_parse_time = proc do |text|
    begin
      Time.parse(text.to_s).to_i
    rescue
      0
    end
  end
  preview_apply_fields = proc do |totals, fields, fallback_time|
    event = fields['event'].to_s
    row_time = fields['timestamp'].to_s.empty? ? fallback_time.to_i : preview_parse_time.call(fields['timestamp'])
    row_time = fallback_time.to_i if row_time <= 0
    if event == 'tutelage_start_message'
      totals['session_exp_total'] = 0
      totals['session_bonus_total'] = 0
      totals['pulses'] = 0
      totals['pulse_values'] = []
      totals['reward_exp_total'] = 0
      totals['reward_count'] = 0
      totals['started_at'] = row_time if row_time > 0
      totals['saw_tutelage_data'] = true
    end
    if event == 'pulse'
      totals['pulses'] += 1
      totals['pulse_values'] << fields['pulse'].to_i if fields['pulse'].to_i > 0
      totals['saw_tutelage_data'] = true
    elsif event == 'reward'
      totals['reward_exp_total'] += fields['pulse'].to_i if fields['reward_exp_total'].to_s.empty?
      totals['reward_count'] += 1 if fields['reward_count'].to_s.empty?
      totals['saw_tutelage_data'] = true
    elsif event == 'offline_absorb' || event == 'summary' || event == 'log_request'
      totals['saw_tutelage_data'] = true
    end
    totals['saw_log_request'] = true if event == 'log_request'
    totals['started_at'] = fields['started_at'].to_i if fields['started_at'].to_i > 0
    totals['ended_at'] = fields['ended_at'].to_i if fields['ended_at'].to_i > 0
    totals['session_exp_total'] = fields['session_exp_total'].to_i if fields['session_exp_total'] && !fields['session_exp_total'].to_s.empty?
    totals['session_bonus_total'] = fields['session_bonus_total'].to_i if fields['session_bonus_total'] && !fields['session_bonus_total'].to_s.empty?
    totals['reward_exp_total'] = fields['reward_exp_total'].to_i if fields['reward_exp_total'] && !fields['reward_exp_total'].to_s.empty?
    totals['reward_count'] = fields['reward_count'].to_i if fields['reward_count'] && !fields['reward_count'].to_s.empty?
    if fields['pulse_count'] && !fields['pulse_count'].to_s.empty?
      totals['pulses'] = [totals['pulses'].to_i, fields['pulse_count'].to_i].max
    elsif fields['pulses'] && !fields['pulses'].to_s.empty?
      totals['pulses'] = [totals['pulses'].to_i, fields['pulses'].to_i].max
    end
    totals['ended_at'] = row_time if row_time > 0 && row_time > totals['ended_at'].to_i
    totals['started_at'] = row_time if totals['started_at'].to_i <= 0 && row_time > 0 && totals['saw_tutelage_data']
  end
  preview_parse_text_totals = proc do |path|
    totals = preview_blank_totals.call
    begin
      File.open(path, 'r') do |file|
        file.each_line do |row|
          fallback_time = preview_parse_time.call(row[/\A[^|]+/, 0].to_s.strip)
          fields = {}
          row.strip.split(/\s+\|\s+/).each do |part|
            key, value = part.split('=', 2)
            fields[key] = value if key && value
          end
          preview_apply_fields.call(totals, fields, fallback_time)
        end
      end
    rescue
    end
    totals
  end
  preview_parse_csv_totals = proc do |path|
    totals = preview_blank_totals.call
    begin
      lines = File.readlines(path)
      headers = preview_parse_csv_line.call(lines.shift || '')
      lines.each do |row|
        values = preview_parse_csv_line.call(row)
        fields = {}
        headers.each_with_index { |key, index| fields[key] = values[index] if key && !key.empty? }
        fields['details'].to_s.split(/\s*;\s*/).each do |detail|
          key, value = detail.split('=', 2)
          fields[key] = value if key && value && !key.empty? && fields[key].to_s.empty?
        end
        preview_apply_fields.call(totals, fields, preview_parse_time.call(fields['timestamp']))
      end
    rescue
    end
    totals
  end
  preview_pulse_stats = proc do |totals|
    values = Array(totals['pulse_values']).map(&:to_i).select { |value| value > 0 }
    sorted = values.sort
    count = values.length
    average = count > 0 ? (values.inject(0.0) { |sum, value| sum + value } / count) : 0.0
    median = if count == 0
               0
             elsif count.odd?
               sorted[count / 2]
             else
               ((sorted[(count / 2) - 1] + sorted[count / 2]) / 2.0).round
             end
    largest = sorted.last || 0
    threshold = average + 50.0
    unusual_values = values.select { |value| value > threshold }
    unusual_exp = unusual_values.inject(0) { |sum, value| sum + value }
    unusual_bonus = unusual_values.inject(0) { |sum, value| sum + (value * 0.8).round }
    {
      'average_pulse' => count > 0 ? format('%.1f', average) : '0',
      'median_pulse' => median,
      'largest_pulse' => largest,
      'unusual_pulse_count' => unusual_values.length,
      'unusual_exp_total' => unusual_exp,
      'reward_exp_total' => totals['reward_exp_total'].to_i,
      'reward_count' => totals['reward_count'].to_i,
      'adjusted_exp_total' => [ totals['session_exp_total'].to_i - totals['reward_exp_total'].to_i - unusual_exp, 0 ].max,
      'adjusted_bonus_total' => [ totals['session_bonus_total'].to_i - unusual_bonus, 0 ].max
    }
  end

  preview_candidates = []
  preview_candidates.concat(Dir[File.join(state_dir, "tute_#{preview_char}_c*.state")])
  preview_candidates.concat(Dir[File.join(log_dir, "tute_#{preview_char}_c*.log")])
  preview_candidates.concat(Dir[File.join(log_dir, "tute_#{preview_char}_c*.csv")])
  preview_candidates = preview_candidates.select { |path| File.file?(path) }
  latest_preview_path = preview_candidates.max_by { |path| [File.mtime(path).to_i, path] }
  preview_real_data = false

  if latest_preview_path
    cycle_match = File.basename(latest_preview_path).match(/_c(\d+|unknown)\.(?:state|log|csv)\z/)
    preview_cycle = cycle_match ? cycle_match[1] : 'unknown'
    totals = latest_preview_path =~ /\.csv\z/i ? preview_parse_csv_totals.call(latest_preview_path) : preview_parse_text_totals.call(latest_preview_path)
    if totals['pulses'].to_i > 0 || totals['saw_tutelage_data']
      preview_real_data = true
      started_at = totals['started_at'].to_i
      ended_at = totals['ended_at'].to_i
      duration_seconds = started_at > 0 && ended_at > started_at ? ended_at - started_at : 0
      preview_summary = {
        'character' => preview_char,
        'cycle_label' => preview_cycle,
        'duration_text' => format_duration.call(duration_seconds),
        'session_exp_total' => totals['session_exp_total'].to_i,
        'session_bonus_total' => totals['session_bonus_total'].to_i,
        'reward_exp_total' => totals['reward_exp_total'].to_i,
        'reward_count' => totals['reward_count'].to_i,
        'pulse_count' => totals['pulses'].to_i,
        'log_path' => File.join(log_dir, "tute_#{preview_char}_c#{preview_cycle}.log"),
        'csv_path' => File.join(log_dir, "tute_#{preview_char}_c#{preview_cycle}.csv"),
        'state_path' => File.join(state_dir, "tute_#{preview_char}_c#{preview_cycle}.state"),
        'preview_title' => (!totals['saw_log_request'] && Vars['xp2_tutelage_state'].to_s == 'active') ? '*~ Current Tutelage Data ~*' : '*~ Latest Tutelage Data ~*',
        'real_data' => true,
        'still_recording' => !totals['saw_log_request'] && Vars['xp2_tutelage_state'].to_s == 'active',
        'sendable_report' => !!totals['saw_log_request'],
        'preview_note' => if totals['saw_log_request']
                            "Latest completed data from #{File.basename(latest_preview_path)}."
                          elsif Vars['xp2_tutelage_state'].to_s == 'active'
                            "Still recording data for this cycle. Latest data from #{File.basename(latest_preview_path)}."
                          else
                            "Latest saved data from #{File.basename(latest_preview_path)}. Tutelage is not active now."
                          end
      }.merge(preview_pulse_stats.call(totals))
    end
  end

  unless preview_real_data
    preview_summary = {
      'character' => preview_char,
      'cycle_label' => '20260614',
      'duration_text' => '46h 41m',
      'session_exp_total' => 136_105,
      'session_bonus_total' => 108_957,
      'reward_exp_total' => 0,
      'reward_count' => 0,
      'pulse_count' => 696,
      'average_pulse' => '176.6',
      'median_pulse' => 155,
      'largest_pulse' => 536,
      'unusual_pulse_count' => 38,
      'unusual_exp_total' => 15_845,
      'adjusted_exp_total' => 120_260,
      'adjusted_bonus_total' => 96_281,
      'log_path' => File.join(log_dir, "tute_#{preview_char}_c20260614.log"),
      'csv_path' => File.join(log_dir, "tute_#{preview_char}_c20260614.csv"),
      'state_path' => File.join(state_dir, "tute_#{preview_char}_c20260614.state"),
      'real_data' => false,
      'sendable_report' => false,
      'preview_title' => '*~ Example Tutelage Report ~*',
      'preview_note' => 'Example only - no character data was saved or changed.'
    }
  end
  print_finished_report.call(preview_summary, preview_style, true)
  exit
end
prune_cycle_logs = proc do
  keep = preserve_cycles.call
  files = Dir[File.join(log_dir, "tute_#{char_name}_c*.{log,csv}")].sort_by do |path|
    match = File.basename(path).match(/_c(\d+|unknown)\.(?:log|csv)\z/)
    match ? match[1] : File.mtime(path).to_i.to_s
  end.reverse
  cycle_keys = []
  files.each do |path|
    match = File.basename(path).match(/\Atute_#{Regexp.escape(char_name)}_c(\d+|unknown)\.(?:log|csv)\z/)
    cycle_keys << (match ? match[1] : File.mtime(path).to_i.to_s)
  end
  keep_keys = cycle_keys.uniq.first(keep)
  files.each do |old_path|
    match = File.basename(old_path).match(/_c(\d+|unknown)\.(?:log|csv)\z/)
    next if match && keep_keys.include?(match[1])
    next if File.expand_path(old_path) == File.expand_path(log_path)
    next if File.expand_path(old_path) == File.expand_path(csv_path)
    begin
      File.delete(old_path)
    rescue
    end
  end
  private_files = Dir[File.join(state_dir, "tute_#{char_name}_c*.state")].sort_by do |path|
    match = File.basename(path).match(/_c(\d+|unknown)\.state\z/)
    match ? match[1] : File.mtime(path).to_i.to_s
  end.reverse
  private_keep_keys = private_files.map do |path|
    match = File.basename(path).match(/_c(\d+|unknown)\.state\z/)
    match ? match[1] : File.mtime(path).to_i.to_s
  end.uniq.first(keep)
  private_files.each do |old_path|
    match = File.basename(old_path).match(/_c(\d+|unknown)\.state\z/)
    next if match && private_keep_keys.include?(match[1])
    next if File.expand_path(old_path) == File.expand_path(private_state_path)
    begin
      File.delete(old_path)
    rescue
    end
  end
end
parse_text_log_totals = proc do |path|
  totals = { 'session_exp_total' => 0, 'session_bonus_total' => 0, 'reward_exp_total' => 0, 'reward_count' => 0, 'pulses' => 0, 'pulse_values' => [], 'saw_tutelage_data' => false, 'saw_log_request' => false }
  begin
    File.open(path, 'r') do |file|
      file.each_line do |line|
        fields = {}
        line.strip.split(/\s+\|\s+/).each do |part|
          key, value = part.split('=', 2)
          fields[key] = value if key && value
        end
        if fields['event'] == 'tutelage_start_message'
          totals['session_exp_total'] = 0
          totals['session_bonus_total'] = 0
          totals['pulses'] = 0
          totals['pulse_values'] = []
          totals['reward_exp_total'] = 0
          totals['reward_count'] = 0
          totals['saw_tutelage_data'] = true
        end
        if fields['event'] == 'pulse'
          totals['pulses'] += 1
          totals['pulse_values'] << fields['pulse'].to_i if fields['pulse'].to_i > 0
          totals['saw_tutelage_data'] = true
        elsif fields['event'] == 'reward'
          totals['reward_exp_total'] += fields['pulse'].to_i if fields['reward_exp_total'].to_s.empty?
          totals['reward_count'] += 1 if fields['reward_count'].to_s.empty?
          totals['saw_tutelage_data'] = true
        elsif fields['event'] == 'offline_absorb' || fields['event'] == 'summary' || fields['event'] == 'log_request'
          totals['saw_tutelage_data'] = true
        end
        totals['saw_log_request'] = true if fields['event'] == 'log_request'
        totals['session_exp_total'] = fields['session_exp_total'].to_i if fields['session_exp_total']
        totals['session_bonus_total'] = fields['session_bonus_total'].to_i if fields['session_bonus_total']
        totals['reward_exp_total'] = fields['reward_exp_total'].to_i if fields['reward_exp_total']
        totals['reward_count'] = fields['reward_count'].to_i if fields['reward_count']
        if fields['pulse_count'] && !fields['pulse_count'].to_s.empty?
          totals['pulses'] = [totals['pulses'].to_i, fields['pulse_count'].to_i].max
        elsif fields['pulses'] && !fields['pulses'].to_s.empty?
          totals['pulses'] = [totals['pulses'].to_i, fields['pulses'].to_i].max
        end
      end
    end
  rescue
  end
  totals
end
parse_csv_line = proc do |line|
  fields = []
  current = ''
  quoted = false
  line.to_s.chomp.each_char do |char|
    if quoted
      if char == '"'
        quoted = false
      else
        current << char
      end
    else
      if char == '"'
        quoted = true
      elsif char == ','
        fields << current
        current = ''
      else
        current << char
      end
    end
  end
  fields << current
  fields
end
parse_csv_log_totals = proc do |path|
  totals = { 'session_exp_total' => 0, 'session_bonus_total' => 0, 'reward_exp_total' => 0, 'reward_count' => 0, 'pulses' => 0, 'pulse_values' => [], 'saw_tutelage_data' => false, 'saw_log_request' => false }
  begin
    lines = File.readlines(path)
    headers = parse_csv_line.call(lines.shift || '')
    lines.each do |line|
      values = parse_csv_line.call(line)
      fields = {}
      headers.each_with_index { |key, index| fields[key] = values[index] if key && !key.empty? }
      fields['details'].to_s.split(/\s*;\s*/).each do |detail|
        key, value = detail.split('=', 2)
        fields[key] = value if key && value && !key.empty? && fields[key].to_s.empty?
      end
      if fields['event'] == 'tutelage_start_message'
        totals['session_exp_total'] = 0
        totals['session_bonus_total'] = 0
        totals['pulses'] = 0
        totals['pulse_values'] = []
        totals['reward_exp_total'] = 0
        totals['reward_count'] = 0
        totals['saw_tutelage_data'] = true
      end
      if fields['event'] == 'pulse'
        totals['pulses'] += 1
        totals['pulse_values'] << fields['pulse'].to_i if fields['pulse'].to_i > 0
        totals['saw_tutelage_data'] = true
      elsif fields['event'] == 'reward'
        totals['reward_exp_total'] += fields['pulse'].to_i if fields['reward_exp_total'].to_s.empty?
        totals['reward_count'] += 1 if fields['reward_count'].to_s.empty?
        totals['saw_tutelage_data'] = true
      elsif fields['event'] == 'offline_absorb' || fields['event'] == 'summary' || fields['event'] == 'log_request'
        totals['saw_tutelage_data'] = true
      end
      totals['saw_log_request'] = true if fields['event'] == 'log_request'
      totals['session_exp_total'] = fields['session_exp_total'].to_i if fields['session_exp_total'] && !fields['session_exp_total'].empty?
      totals['session_bonus_total'] = fields['session_bonus_total'].to_i if fields['session_bonus_total'] && !fields['session_bonus_total'].empty?
      totals['reward_exp_total'] = fields['reward_exp_total'].to_i if fields['reward_exp_total'] && !fields['reward_exp_total'].empty?
      totals['reward_count'] = fields['reward_count'].to_i if fields['reward_count'] && !fields['reward_count'].empty?
      if fields['pulse_count'] && !fields['pulse_count'].to_s.empty?
        totals['pulses'] = [totals['pulses'].to_i, fields['pulse_count'].to_i].max
      elsif fields['pulses'] && !fields['pulses'].to_s.empty?
        totals['pulses'] = [totals['pulses'].to_i, fields['pulses'].to_i].max
      end
    end
  rescue
  end
  totals
end
read_log_totals = proc do |text_path, sheet_path|
  csv_totals = File.exist?(sheet_path) ? parse_csv_log_totals.call(sheet_path) : nil
  if csv_totals && (csv_totals['pulses'] > 0 || csv_totals['saw_tutelage_data'])
    next csv_totals
  end
  text_totals = File.exist?(text_path) ? parse_text_log_totals.call(text_path) : nil
  if text_totals && (text_totals['pulses'] > 0 || text_totals['saw_tutelage_data'])
    next text_totals
  end
  { 'session_exp_total' => 0, 'session_bonus_total' => 0, 'reward_exp_total' => 0, 'reward_count' => 0, 'pulses' => 0, 'pulse_values' => [], 'saw_tutelage_data' => false, 'saw_log_request' => false }
end
text_log_file = nil
csv_log_file = nil
saw_tutelage_data = false

open_current_cycle_log = proc do
  new_reset_at = Vars['xp2_tutelage_reset_at'].to_i
  new_cycle_time = new_reset_at > 0 ? Time.at(new_reset_at) : Time.now
  new_cycle_label = new_reset_at > 0 ? new_cycle_time.strftime('%Y%m%d') : 'unknown'
  next if new_cycle_label == cycle_label
  begin
    if (text_log_file && !text_log_file.closed?) || (csv_log_file && !csv_log_file.closed?)
      old_cycle_label = cycle_label
      cycle_reset_at = new_reset_at
      cycle_time = new_cycle_time
      cycle_label = new_cycle_label
      write_log.call({ 'event' => 'cycle_change', 'old_cycle' => old_cycle_label, 'new_cycle' => new_cycle_label })
      cycle_label = old_cycle_label
    end
    if text_log_file && !text_log_file.closed?
      text_log_file.close
    end
    if csv_log_file && !csv_log_file.closed?
      csv_log_file.close
    end
  rescue
  end
  cycle_reset_at = new_reset_at
  cycle_time = new_cycle_time
  cycle_label = new_cycle_label
  log_path = File.join(log_dir, "tute_#{char_name}_c#{cycle_label}.log")
  csv_path = File.join(log_dir, "tute_#{char_name}_c#{cycle_label}.csv")
  private_state_path = File.join(state_dir, "tute_#{char_name}_c#{cycle_label}.state")
  text_log_file = nil
  csv_log_file = nil
end

open_log_file = proc do
  next unless logging_enabled.call && (Vars['xp2_tutelage_state'].to_s == 'active' || saw_tutelage_data)
  if text_output_enabled.call && (text_log_file.nil? || text_log_file.closed?)
    text_log_file = File.open(log_path, 'a')
    text_log_file.sync = true
  end
  if csv_output_enabled.call && (csv_log_file.nil? || csv_log_file.closed?)
    expected_csv_header = csv_columns.map { |value| csv_escape.call(value) }.join(',')
    if File.exist?(csv_path) && File.size(csv_path) > 0
      begin
        existing_csv_header = File.open(csv_path, 'r') { |file| file.gets.to_s.strip }
        if existing_csv_header != expected_csv_header
          old_csv_path = "#{csv_path}.wide_#{Time.now.strftime('%Y%m%d_%H%M%S')}"
          FileUtils.mv(csv_path, old_csv_path)
        end
      rescue
      end
    end
    new_csv = !File.exist?(csv_path) || File.size(csv_path) == 0
    csv_log_file = File.open(csv_path, 'a')
    csv_log_file.sync = true
    if new_csv
      csv_log_file.puts expected_csv_header
      metadata_details = [
        "character=#{clean_value.call(char_name)}",
        "game=#{clean_value.call(game_name)}",
        "cycle_label=#{clean_value.call(cycle_label)}",
        "cycle_reset_at=#{clean_value.call(cycle_reset_at)}",
        "log_path=#{clean_value.call(log_path)}",
        "csv_path=#{clean_value.call(csv_path)}"
      ].join('; ')
      metadata_row = csv_columns.map do |key|
        case key
        when 'timestamp'
          timestamp.call
        when 'event'
          'metadata'
        when 'tutelage_state'
          Vars['xp2_tutelage_state'] || 'unknown'
        when 'lumnis_remaining_est'
          tutelog_state['lumnis_remaining_est'] || Vars['xp2_lumnis_phase_remaining'] || '0'
        when 'details'
          metadata_details
        else
          nil
        end
      end
      csv_log_file.puts metadata_row.map { |value| csv_escape.call(value) }.join(',')
    end
  end
  if (text_log_file && !text_log_file.closed?) || (csv_log_file && !csv_log_file.closed?)
    prune_cycle_logs.call
  end
end

public_tutelage_log_event = proc do |fields|
  %w[
    tutelage_start_message tutelage_active_detected offline_absorb pulse reward
    pulse_anomaly pulse_drop_check pulse_drop_rollback tutelage_end_message summary log_request
  ].include?(fields['event'].to_s)
end

write_log = proc do |fields|
  next unless Vars['xp2_tutelage_state'].to_s == 'active' || saw_tutelage_data
  begin
    FileUtils.mkdir_p(state_dir)
    File.open(private_state_path, 'a') do |file|
      parts = [ timestamp.call ]
      fields.each { |key, value| parts << "#{key}=#{clean_value.call(value)}" }
      file.puts parts.join(' | ')
    end
  rescue
  end
  next unless logging_enabled.call
  next unless public_tutelage_log_event.call(fields)
  open_log_file.call
  now_text = timestamp.call
  if text_output_enabled.call && text_log_file && !text_log_file.closed?
    parts = [ now_text ]
    fields.each { |key, value| parts << "#{key}=#{clean_value.call(value)}" }
    text_log_file.puts parts.join(' | ')
  end
  if csv_output_enabled.call && csv_log_file && !csv_log_file.closed?
    known_keys = csv_columns - [ 'timestamp', 'details' ]
    details = fields.keys.map(&:to_s).reject { |key| known_keys.include?(key) }.sort.map { |key| "#{key}=#{clean_value.call(fields[key])}" }.join('; ')
    row = csv_columns.map do |key|
      if key == 'timestamp'
        now_text
      elsif key == 'details'
        details
      else
        fields[key]
      end
    end
    csv_log_file.puts row.map { |value| csv_escape.call(value) }.join(',')
  end
end

current_next_text = proc do
  current_exp_checkpoint.call['text']
end

current_mind_state = proc do
  begin
    mind = XMLData.respond_to?(:mind_text) && XMLData.mind_text ? XMLData.mind_text.to_s : ''
    mind = XMLData.instance_variable_get(:@mind_text).to_s if mind.to_s.empty? && XMLData.respond_to?(:instance_variable_get)
    mind = mind.gsub(/<[^>]+>/, ' ').gsub(/\s+/, ' ').strip
    mind.empty? ? 'unknown' : mind
  rescue
    'unknown'
  end
end

current_logic_bonus = proc do
  begin
    if defined?(Lich::Gemstone::Stats) && Lich::Gemstone::Stats.respond_to?(:log)
      bonus = Lich::Gemstone::Stats.log[1]
      next bonus.to_i if bonus
    elsif defined?(Stats) && Stats.respond_to?(:log)
      bonus = Stats.log[1]
      next bonus.to_i if bonus
    end
  rescue
  end
  nil
end

current_field_bucket = proc do
  current = nil
  maximum = nil
  begin
    if defined?(Lich::Gemstone::Experience)
      current = Lich::Gemstone::Experience.fxp_current
      maximum = Lich::Gemstone::Experience.fxp_max
    elsif defined?(Experience)
      current = Experience.fxp_current if Experience.respond_to?(:fxp_current)
      maximum = Experience.fxp_max if Experience.respond_to?(:fxp_max)
    end
  rescue
  end
  current = current.to_i if current && current.to_i >= 0
  maximum = maximum.to_i if maximum && maximum.to_i > 0
  { 'current' => current, 'max' => maximum }
end

current_room_tags = proc do
  tags = []
  begin
    tags.concat(Array(Room.current.tags)) if defined?(Room) && Room.respond_to?(:current) && Room.current && Room.current.respond_to?(:tags)
  rescue
  end
  begin
    tags.concat(Array(Map.current.tags)) if defined?(Map) && Map.respond_to?(:current) && Map.current && Map.current.respond_to?(:tags)
  rescue
  end
  tags.map { |tag| tag.to_s.downcase }.reject(&:empty?).uniq
end

current_room_location = proc do
  begin
    location = Room.current.location if defined?(Room) && Room.respond_to?(:current) && Room.current && Room.current.respond_to?(:location)
    location = location.to_s.gsub(/<[^>]+>/, ' ').gsub(/\s+/, ' ').strip
    next location unless location.empty?
  rescue
  end
  ''
end

group_absorb_bonus = proc do
  begin
    if defined?(Group) && Group.respond_to?(:members)
      members = Array(Group.members)
      next members.length > 1 ? 1 : 0
    end
  rescue
  end
  0
end

lumnis_total_multiplier = proc do
  remaining = Vars['xp2_lumnis_phase_remaining'].to_i
  phase = Vars['xp2_lumnis_phase'].to_s.downcase
  expired = Vars['xp2_lumnis_expired'].to_s =~ /^(true|yes|1)$/i
  next 1.0 if expired || remaining <= 0
  case phase
  when /quint/ then 5.0
  when /quad/ then 4.0
  when /trip/ then 3.0
  when /doubl/ then 2.0
  else 1.0
  end
end

decode_absorb_pulse = proc do |pulse, reward_pulse, tutelage_state|
  tags = current_room_tags.call
  logic_bonus = current_logic_bonus.call
  bucket = current_field_bucket.call
  field_current = bucket['current']
  field_max = bucket['max']
  pool_bonus = field_current ? [[field_current.to_i / 200, 0].max, 10].min : nil
  location = current_room_location.call
  room_id = tutelog_current_room_id.call
  override_mode = tutelog_room_mode_override_for.call(room_id) || 'auto'
  location_town = location =~ /Wehnimer|Landing|River's Rest|Solhaven|Icemule|Kharam-Dzu|Teras|Ta'Illistim|Ta'Vaalor|Zul Logoth|Cysaegir|Mist Harbor|Kraken's Fall|Pinefar|Ravelin|Four Winds/i
  ship_captains_supernode = location =~ /Ships/i && tags.include?('captains_quarters')
  auto_supernode = tags.include?('supernode') || ship_captains_supernode
  auto_node = auto_supernode || tags.include?('node')
  auto_town = tags.include?('town') || !!location_town
  auto_mode = if auto_supernode
                'supernode'
              elsif auto_node
                'node'
              elsif auto_town
                'town'
              elsif tags.empty? && location.empty?
                'other_guess'
              else
                'other'
              end
  mode = override_mode == 'auto' ? auto_mode : override_mode
  supernode = mode == 'supernode'
  node = supernode || mode == 'node'
  town = mode == 'town'
  base = town || node ? 22 : 19
  base = 25 if node
  logic_divisor = town || node ? 5 : 7
  logic_piece = logic_bonus ? (logic_bonus.to_i / logic_divisor) : nil
  group_bonus = group_absorb_bonus.call
  super_bonus = supernode ? 2 : 0
  expected = if logic_piece && pool_bonus
               base + logic_piece + pool_bonus + group_bonus + super_bonus
             end
  known_multiplier = tutelage_state.to_s == 'active' ? 5.0 : lumnis_total_multiplier.call
  observed_multiplier = expected && expected > 0 ? (pulse.to_f / expected.to_f) : nil
  expected_known = expected && expected > 0 ? expected.to_f * known_multiplier.to_f : nil
  extra_multiplier = expected_known && expected_known > 0 ? (pulse.to_f / expected_known) : nil
  extra_exp = expected_known ? [pulse.to_f - expected_known, 0.0].max.round : nil
  confidence = if reward_pulse
                 'reward'
               elsif expected.nil?
                 'low_no_baseline'
               elsif mode == 'other_guess'
                 'low_room_guess'
               elsif extra_multiplier && extra_multiplier.between?(0.85, 1.20)
                 'high'
               else
                 'medium'
               end
  note_bits = []
  note_bits << "known=tutelage" if tutelage_state.to_s == 'active'
  note_bits << "known=lumnis_#{Vars['xp2_lumnis_phase']}" if tutelage_state.to_s != 'active' && known_multiplier.to_f > 1.0
  note_bits << 'rpa_seen' if Vars['xp2_rpa_active'].to_s =~ /^(on|yes|true|1)$/i
  note_bits << "roommode_override=#{override_mode}:#{room_id}" unless override_mode == 'auto'
  note_bits << 'ship_captains_quarters_supernode' if ship_captains_supernode && override_mode == 'auto'
  note_bits << 'town_from_location' if location_town && !tags.include?('town') && override_mode == 'auto'
  note_bits << 'extra_possible_rpa_or_boost' if extra_multiplier && extra_multiplier > 1.20
  note_bits << 'reward_excluded' if reward_pulse
  {
    'room_id' => room_id,
    'decode_mode' => mode,
    'room_tags' => tags.join('|'),
    'room_location' => location,
    'logic_bonus' => logic_bonus,
    'field_exp' => field_current,
    'field_exp_max' => field_max,
    'pool_bonus' => pool_bonus,
    'expected_pulse' => expected,
    'known_multiplier' => expected ? format('%.2f', known_multiplier.to_f) : nil,
    'observed_multiplier' => observed_multiplier ? format('%.2f', observed_multiplier) : nil,
    'extra_multiplier' => extra_multiplier ? format('%.2f', extra_multiplier) : nil,
    'extra_exp' => extra_exp,
    'decode_confidence' => confidence,
    'decode_note' => note_bits.join(',')
  }
end

truthy_setting = proc { |value| value.to_s =~ /^(on|yes|true|1)$/i }
general_reset_keys = %w[
  general_started_at general_session_date general_pulse_count general_exp_total
  general_reward_count general_reward_exp_total general_rpa_pulse_count
  general_rpa_exp_total general_last_pulse_at general_last_pulse_exp
    general_last_mind general_last_reset_at general_reset_reason
    general_last_decode_mode general_last_expected_pulse general_last_observed_multiplier
    general_last_extra_multiplier general_last_extra_exp general_last_decode_confidence
]
general_today = proc { Time.now.strftime('%m%d%Y') }
current_general_reset_mode = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  mode = current_state['general_reset_mode'].to_s
  tutelog_reset_modes.include?(mode) ? mode : 'run'
end
general_idle_minutes = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  [ current_state['general_idle_minutes'].to_i, 1 ].max
end
no_pulse_alert_enabled = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  truthy_setting.call(current_state['no_pulse_alert'])
end
no_pulse_minutes = proc do
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  [ current_state['no_pulse_minutes'].to_i, 1 ].max
end
reset_general_stats = proc do |reason|
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
  general_reset_keys.each { |key| current_state.delete(key) }
  now_i = Time.now.to_i
  current_state['general_started_at'] = now_i.to_s
  current_state['general_session_date'] = general_today.call
  current_state['general_pulse_count'] = '0'
  current_state['general_exp_total'] = '0'
  current_state['general_reward_count'] = '0'
  current_state['general_reward_exp_total'] = '0'
  current_state['general_rpa_pulse_count'] = '0'
  current_state['general_rpa_exp_total'] = '0'
  current_state['general_last_pulse_at'] = '0'
  current_state['general_last_pulse_exp'] = '0'
  current_state['general_last_mind'] = current_mind_state.call
  current_state['general_last_reset_at'] = now_i.to_s
  current_state['general_reset_reason'] = reason.to_s
  Vars['tutelog'] = current_state
  tutelog_state.replace(current_state)
  save_vars.call
end
maybe_reset_general_stats = proc do |reason|
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  now_i = Time.now.to_i
  started_at = current_state['general_started_at'].to_i
  mode = current_general_reset_mode.call
  should_reset = started_at <= 0
  should_reset ||= mode == 'run' && reason.to_s == 'startup'
  should_reset ||= mode == 'daily' && current_state['general_session_date'].to_s != general_today.call
  if mode == 'idle' && started_at > 0
    reference_at = current_state['general_last_pulse_at'].to_i
    reference_at = started_at if reference_at <= 0
    should_reset ||= reference_at > 0 && (now_i - reference_at) >= (general_idle_minutes.call * 60)
  end
  reset_general_stats.call(reason) if should_reset
end
update_general_stats = proc do |pulse, reward, mind, rpa_state, decode = nil|
  maybe_reset_general_stats.call('pulse')
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'].dup : tutelog_state.dup
  current_state['general_session_date'] = general_today.call
  current_state['general_pulse_count'] = (current_state['general_pulse_count'].to_i + 1).to_s
  current_state['general_exp_total'] = (current_state['general_exp_total'].to_i + pulse.to_i).to_s
  if reward
    current_state['general_reward_count'] = (current_state['general_reward_count'].to_i + 1).to_s
    current_state['general_reward_exp_total'] = (current_state['general_reward_exp_total'].to_i + pulse.to_i).to_s
  end
  if rpa_state.to_s =~ /^(on|yes|true|1)$/i
    current_state['general_rpa_pulse_count'] = (current_state['general_rpa_pulse_count'].to_i + 1).to_s
    current_state['general_rpa_exp_total'] = (current_state['general_rpa_exp_total'].to_i + pulse.to_i).to_s
  end
  current_state['general_last_pulse_at'] = Time.now.to_i.to_s
  current_state['general_last_pulse_exp'] = pulse.to_i.to_s
  current_state['general_last_mind'] = mind.to_s.empty? ? 'unknown' : mind.to_s
  if decode && decode.respond_to?(:[])
    current_state['general_last_decode_mode'] = decode['decode_mode'].to_s
    current_state['general_last_expected_pulse'] = decode['expected_pulse'].to_s
    current_state['general_last_observed_multiplier'] = decode['observed_multiplier'].to_s
    current_state['general_last_extra_multiplier'] = decode['extra_multiplier'].to_s
    current_state['general_last_extra_exp'] = decode['extra_exp'].to_s
    current_state['general_last_decode_confidence'] = decode['decode_confidence'].to_s
  end
  Vars['tutelog'] = current_state
  tutelog_state.replace(current_state)
  save_vars.call
end
maybe_reset_general_stats.call('startup')

lumnis_remaining_est = tutelog_state['lumnis_remaining_est'].to_i
lumnis_source_remaining = tutelog_state['lumnis_source_remaining'].to_i

save_lumnis_est = proc do
  tutelog_state['lumnis_remaining_est'] = lumnis_remaining_est.to_i.to_s
  tutelog_state['lumnis_source_remaining'] = lumnis_source_remaining.to_i.to_s
  save_tutelog_state.call
end

sync_lumnis_est = proc do
  saved_remaining = Vars['xp2_lumnis_phase_remaining'].to_i
  lumnis_expired = Vars['xp2_lumnis_expired'].to_s =~ /^(true|yes|1)$/i
  if saved_remaining > 0 && saved_remaining != lumnis_source_remaining
    lumnis_remaining_est = saved_remaining
    lumnis_source_remaining = saved_remaining
    save_lumnis_est.call
  elsif lumnis_expired && lumnis_remaining_est != 0
    lumnis_remaining_est = 0
    lumnis_source_remaining = 0
    save_lumnis_est.call
  end
  lumnis_remaining_est
end

refresh_lumnis_info = proc do |reason, min_interval = 120|
  now_i = Time.now.to_i
  last_refresh = tutelog_state['last_lumnis_info_at'].to_i
  next false if (now_i - last_refresh) < min_interval
  tutelog_state['last_lumnis_info_at'] = now_i.to_s
  tutelog_state['last_lumnis_info_reason'] = reason.to_s
  save_tutelog_state.call

  lumnis_lines = []
  begin
    lumnis_lines = Lich::Util.quiet_command_xml(
      'lumnis info',
      /Gift of Lumnis|recent donation|Fash'lo'nae's Tutelage/i,
      /<prompt/,
      false,
      6,
      true
    )
  rescue
    lumnis_lines = []
  end

  lumnis_text = Array(lumnis_lines).join("\n").gsub(/<[^>]+>/, ' ').gsub(/\s+/, ' ').strip
  phase = nil
  remaining = nil
  refresh = nil
  expired = nil
  days = nil
  inactive = false

  Array(lumnis_lines).join("\n").split(/\r?\n/).each do |raw_line|
    line = raw_line.to_s.gsub(/<[^>]+>/, ' ').gsub(/\s+/, ' ').strip
    next if line.empty?
    if line =~ /([0-9,]+).*?points.*?of.*?(quintupled|quadrupled|tripled|doubled).*?experience.*?remaining/i
      remaining = $1.gsub(',', '').to_i
      phase = $2.downcase
      expired = false
    elsif line =~ /You have\s+([\d,]+)\s+points/i
      remaining = $1.gsub(',', '').to_i
    end
    phase = $1.downcase if line =~ /points\s+of\s+(quintupled|quadrupled|tripled|doubled)\s+experience/i
    refresh = $1.strip if line =~ /refresh in\s+([^.]*)\./i
    expired = true if line =~ /Gift of Lumnis has expired/i
    days = $1.gsub(',', '').to_i if line =~ /You are receiving Fash'lo'nae's Tutelage with ([0-9,]+) day\(s\) remaining\./
    inactive = true if line =~ /You are not presently receiving Fash'lo'nae's Tutelage\./
  end

  if remaining
    lumnis_remaining_est = remaining
    lumnis_source_remaining = remaining
    tutelog_state['lumnis_remaining_est'] = remaining.to_s
    tutelog_state['lumnis_source_remaining'] = remaining.to_s
    Vars['xp2_lumnis_phase_remaining'] = remaining.to_s
  elsif expired
    lumnis_remaining_est = 0
    lumnis_source_remaining = 0
    tutelog_state['lumnis_remaining_est'] = '0'
    tutelog_state['lumnis_source_remaining'] = '0'
    Vars['xp2_lumnis_phase_remaining'] = '0'
  end
  Vars['xp2_lumnis_phase'] = phase.to_s if phase
  Vars['xp2_lumnis_expired'] = expired.to_s unless expired.nil?
  if days
    Vars['xp2_tutelage_days'] = days.to_s
    Vars['xp2_tutelage_state'] = 'inactive' if Vars['xp2_tutelage_state'].to_s != 'active'
    Vars['xp2_tutelage_state_at'] = now_i.to_s
  elsif inactive
    Vars['xp2_tutelage_days'] = ''
    Vars['xp2_tutelage_state'] = 'inactive'
    Vars['xp2_tutelage_state_at'] = now_i.to_s
    clear_tutelage_live_cache.call
  end
  save_vars.call
  save_tutelog_state.call

  write_log.call({
    'event' => 'lumnis_info',
    'reason' => reason,
    'phase' => phase,
    'remaining' => remaining,
    'expired' => expired,
    'tutelage_days' => days,
    'tutelage_inactive' => inactive,
    'refresh' => refresh
  })
  true
end

startup_experience_check = proc do
  exp_lines = []
  begin
    exp_lines = Lich::Util.quiet_command_xml(
      'Experience',
      /Level:|Experience:|You are a ghost|heightened understanding|Knowledge that is not your own teases|Wisdom of the Ages/i,
      /<prompt/,
      false,
      6,
      true
    )
  rescue
    exp_lines = []
  end
  exp_text = Array(exp_lines).join("\n").gsub(/<[^>]+>/, ' ').gsub(/\s+/, ' ').strip
  if exp_text =~ /\bExperience:\s*([0-9,]+)/
    startup_total_exp = $1.gsub(',', '').to_i
  end
  Vars['xp2_rpa_active'] = exp_text =~ /recent adventures echo powerfully in your mind/i ? 'on' : 'off'
  if exp_text =~ /heightened understanding of events around you|Knowledge that is not your own teases/i
    Vars['xp2_tutelage_state'] = 'active'
    Vars['xp2_tutelage_state_at'] = Time.now.to_i.to_s
  elsif Vars['xp2_tutelage_state'].to_s == 'active'
    Vars['xp2_tutelage_state'] = Vars['xp2_tutelage_days'].to_i > 0 ? 'inactive' : 'unknown'
    Vars['xp2_tutelage_state_at'] = Time.now.to_i.to_s
  end
  tutelog_state['startup_experience_at'] = Time.now.to_i.to_s
  tutelog_state['startup_experience_exp'] = startup_total_exp.to_i.to_s if startup_total_exp.to_i > 0
  tutelog_state['startup_experience_tutelage_state'] = Vars['xp2_tutelage_state'].to_s
  save_vars.call
  save_tutelog_state.call
end
startup_experience_check.call

old_text = current_next_text.call
until old_text && !old_text.empty?
  pause 0.5
  old_text = current_next_text.call
end
old_value = number_from_text.call(old_text)
saved_totals_match_cycle = tutelog_state['cycle_label'].to_s == cycle_label
log_totals = read_log_totals.call(log_path, csv_path)
log_has_totals = log_totals['pulses'].to_i > 0 || log_totals['saw_tutelage_data']
private_totals = File.exist?(private_state_path) ? parse_text_log_totals.call(private_state_path) : { 'session_exp_total' => 0, 'session_bonus_total' => 0, 'reward_exp_total' => 0, 'reward_count' => 0, 'pulses' => 0, 'pulse_values' => [], 'saw_tutelage_data' => false, 'saw_log_request' => false }
private_has_totals = private_totals['pulses'].to_i > 0 || private_totals['saw_tutelage_data']
if log_has_totals
  session_exp_total = log_totals['session_exp_total'].to_i
  session_bonus_total = log_totals['session_bonus_total'].to_i
  pulse_count = log_totals['pulses'].to_i
  reward_exp_total = log_totals['reward_exp_total'].to_i
  reward_count = log_totals['reward_count'].to_i
  pulse_values = Array(log_totals['pulse_values']).map(&:to_i).select { |value| value > 0 }
elsif private_has_totals
  session_exp_total = private_totals['session_exp_total'].to_i
  session_bonus_total = private_totals['session_bonus_total'].to_i
  pulse_count = private_totals['pulses'].to_i
  reward_exp_total = private_totals['reward_exp_total'].to_i
  reward_count = private_totals['reward_count'].to_i
  pulse_values = Array(private_totals['pulse_values']).map(&:to_i).select { |value| value > 0 }
elsif saved_totals_match_cycle
  session_exp_total = tutelog_state['session_exp_total'].to_i
  session_bonus_total = tutelog_state['session_bonus_total'].to_i
  pulse_count = tutelog_state['pulse_count'].to_i
  reward_exp_total = tutelog_state['reward_exp_total'].to_i
  reward_count = tutelog_state['reward_count'].to_i
  pulse_values = private_state['pulse_values'].to_s.split(',').map(&:to_i).select { |value| value > 0 }
else
  session_exp_total = 0
  session_bonus_total = 0
  pulse_count = 0
  reward_exp_total = 0
  reward_count = 0
  pulse_values = []
end
last_pulse_at = nil
pulse_window = []
drop_refresh_sent = false
pending_drop_pulse = nil
saw_tutelage_data = log_totals['saw_tutelage_data'] || private_totals['saw_tutelage_data'] || session_exp_total > 0 || session_bonus_total > 0
log_request_sent = false
log_request_sent = log_totals['saw_log_request'] || private_totals['saw_log_request']
sync_lumnis_est.call
tutelog_state['started_at'] = Time.now.to_i.to_s
tutelog_state['log_path'] = log_path
tutelog_state['csv_path'] = csv_path
save_tutelog_state.call

save_next_checkpoint = proc do |text, value, mode|
  tutelog_state['last_next_text'] = text.to_s
  tutelog_state['last_next_value'] = value.to_i.to_s if value
  tutelog_state['last_next_mode'] = mode.to_s
end

checkpoint_source_changed = proc do |old_text_value, old_mode_value, new_text_value, new_mode_value|
  old_text_value = old_text_value.to_s
  new_text_value = new_text_value.to_s
  next true if old_mode_value.to_s != new_mode_value.to_s
  next true if old_text_value =~ /until next/i && new_text_value =~ /total exp/i
  next true if old_text_value =~ /total exp/i && new_text_value =~ /until next/i
  next true if old_text_value =~ /computed total exp/i && new_text_value !~ /computed total exp/i
  next true if old_text_value !~ /computed total exp/i && new_text_value =~ /computed total exp/i
  next true if old_text_value =~ /\bexperience\z/i && old_text_value !~ /total exp/i && new_text_value =~ /total exp/i
  next true if old_text_value =~ /total exp/i && new_text_value =~ /\bexperience\z/i && new_text_value !~ /total exp/i
  false
end

save_totals = proc do
  tutelog_state['cycle_label'] = cycle_label
  tutelog_state['session_exp_total'] = session_exp_total.to_i.to_s
  tutelog_state['session_bonus_total'] = session_bonus_total.to_i.to_s
  tutelog_state['pulse_count'] = pulse_count.to_i.to_s
  tutelog_state['reward_exp_total'] = reward_exp_total.to_i.to_s
  tutelog_state['reward_count'] = reward_count.to_i.to_s
  if Vars['xp2_tutelage_state'].to_s == 'active' || saw_tutelage_data || session_bonus_total.to_i > 0
    Vars['xp2_tutelage_bonus_used'] = session_bonus_total.to_i.to_s
    Vars['xp2_tutelage_source'] = 'tutelog'
    Vars['xp2_tutelage_tutelog_at'] = Time.now.to_i.to_s
    Vars['xp2_tutelage_tutelog_cycle'] = cycle_label.to_s
    Vars['xp2_tutelage_tutelog_reset_at'] = cycle_reset_at.to_i.to_s
    Vars['xp2_tutelage_tutelog_total_exp'] = session_exp_total.to_i.to_s
    Vars['xp2_tutelage_reward_exp'] = reward_exp_total.to_i.to_s
  end
  save_tutelog_state.call
end

ensure_totals_cycle = proc do
  next if tutelog_state['cycle_label'].to_s == cycle_label
  session_exp_total = 0
  session_bonus_total = 0
  pulse_count = 0
  reward_exp_total = 0
  reward_count = 0
  pulse_values = []
  pulse_window = []
  drop_refresh_sent = false
  pending_drop_pulse = nil
  saw_tutelage_data = false
  tutelog_state['tutelage_started_at'] = ''
  save_totals.call
end
save_totals.call

saved_next_text = tutelog_state['last_next_text'].to_s
saved_next_value = tutelog_state['last_next_value'].to_i
saved_next_mode = tutelog_state['last_next_mode'].to_s
current_mode = next_mode.call(old_text)
if checkpoint_source_changed.call(saved_next_text, saved_next_mode, old_text, current_mode)
  write_log.call({
    'event' => 'checkpoint_source_changed',
    'old_next' => saved_next_text,
    'new_next' => old_text,
    'old_mode' => saved_next_mode,
    'new_mode' => current_mode,
    'action' => 'checkpoint_reset_no_exp_counted'
  })
elsif Vars['xp2_tutelage_state'].to_s == 'active' && saved_totals_match_cycle && saved_next_value > 0 && old_value && saved_next_mode == current_mode
  offline_exp = if current_mode == 'until_next'
                  saved_next_value - old_value
                else
                  old_value - saved_next_value
                end
  if offline_exp && offline_exp > 0
    offline_bonus = (offline_exp * 0.8).round
    session_exp_total += offline_exp
    session_bonus_total += offline_bonus
    saw_tutelage_data = true
    save_next_checkpoint.call(old_text, old_value, current_mode)
    save_totals.call
    write_log.call({
      'event' => 'offline_absorb',
      'pulse' => offline_exp,
      'bonus_est' => offline_bonus,
      'session_exp_total' => session_exp_total,
      'session_bonus_total' => session_bonus_total,
      'offline_next_text' => saved_next_text,
      'offline_next_value' => saved_next_value,
      'offline_next_mode' => saved_next_mode,
      'next_text' => old_text,
      'next_value' => old_value,
      'next_mode' => current_mode,
      'rpa' => Vars['xp2_rpa_active'] || 'unknown',
      'mind' => current_mind_state.call
    })
      echo "| #{Time.now.strftime('%H:%M:%S')} | Offline absorb: #{format_number.call(offline_exp)} exp | Mind: #{current_mind_state.call} | Total: #{format_number.call(session_exp_total)} exp | Est Bonus: #{format_number.call(session_bonus_total)} (#{tutelage_bonus_percent.call(session_bonus_total)})" if notify_pulses.call
  elsif offline_exp && offline_exp < 0
    write_log.call({
      'event' => 'offline_absorb_anomaly',
      'old_next' => saved_next_text,
      'new_next' => old_text,
      'old_value' => saved_next_value,
      'new_value' => old_value,
      'old_mode' => saved_next_mode,
      'new_mode' => current_mode,
      'raw_delta' => offline_exp,
      'action' => 'ignored_negative_delta'
    })
  end
end
save_next_checkpoint.call(old_text, old_value, current_mode)
save_tutelog_state.call

write_log.call({
  'event' => 'start',
  'character' => char_name,
  'game' => game_name,
  'cycle_reset_at' => cycle_reset_at,
  'cycle_label' => cycle_label,
  'next_text' => old_text,
  'next_value' => old_value,
  'next_mode' => next_mode.call(old_text),
  'tutelage_state' => Vars['xp2_tutelage_state'] || 'unknown',
  'lumnis_remaining_est' => lumnis_remaining_est,
  'rpa' => Vars['xp2_rpa_active'] || 'unknown',
  'mind' => current_mind_state.call
})

last_tutelage_state = Vars['xp2_tutelage_state'].to_s
if Vars['xp2_tutelage_state'].to_s == 'active'
  echo "Tutelage logging to #{log_path}"
elsif tutelage_available.call
  echo 'Tutelage is available but not active yet; watching pulses until Lumnis is used up.'
else
  echo 'Tutelage is not available on this character; watching pulses only.'
end

lumnis_expired_now = proc { Vars['xp2_lumnis_expired'].to_s =~ /^(true|yes|1)$/i }
summary_pulse_stats = proc do
  values = Array(pulse_values).map(&:to_i).select { |value| value > 0 }
  sorted = values.sort
  count = values.length
  average = count > 0 ? (values.inject(0.0) { |sum, value| sum + value } / count) : 0.0
  median = if count == 0
             0
           elsif count.odd?
             sorted[count / 2]
           else
             ((sorted[(count / 2) - 1] + sorted[count / 2]) / 2.0).round
           end
  largest = sorted.last || 0
  threshold = average + 50.0
  unusual_values = values.select { |value| value > threshold }
  unusual_exp = unusual_values.inject(0) { |sum, value| sum + value }
  unusual_bonus = unusual_values.inject(0) { |sum, value| sum + (value * 0.8).round }
  {
    'average_pulse' => count > 0 ? format('%.1f', average) : '0',
    'median_pulse' => median,
    'largest_pulse' => largest,
    'unusual_pulse_count' => unusual_values.length,
    'unusual_exp_total' => unusual_exp,
    'reward_exp_total' => reward_exp_total.to_i,
    'reward_count' => reward_count.to_i,
    'adjusted_exp_total' => [ session_exp_total.to_i - reward_exp_total.to_i - unusual_exp, 0 ].max,
    'adjusted_bonus_total' => [ session_bonus_total.to_i - unusual_bonus, 0 ].max
  }
end
summary_snapshot = proc do
  started_at = tutelog_state['tutelage_started_at'].to_i
  started_at = tutelog_state['started_at'].to_i if started_at <= 0
  ended_at = Time.now.to_i
  duration_seconds = started_at > 0 ? ended_at - started_at : 0
  {
    'character' => char_name,
    'cycle_label' => cycle_label,
    'session_exp_total' => session_exp_total,
    'session_bonus_total' => session_bonus_total,
    'reward_exp_total' => reward_exp_total,
    'reward_count' => reward_count,
    'pulse_count' => pulse_count,
    'started_at' => started_at,
    'ended_at' => ended_at,
    'duration_seconds' => duration_seconds,
    'duration_text' => format_duration.call(duration_seconds),
    'log_path' => log_path,
    'csv_path' => csv_path
  }.merge(summary_pulse_stats.call)
end
send_log_request = proc do |reason|
  next if log_request_sent || !saw_tutelage_data
  next if reason.to_s !~ /tutelage_end|pulse_drop/i && !lumnis_expired_now.call
  log_request_sent = true
  summary = summary_snapshot.call
  begin
    write_log.call(summary.merge({ 'event' => 'summary', 'reason' => reason, 'mind' => current_mind_state.call }))
    write_log.call({ 'event' => 'log_request', 'reason' => reason, 'log_path' => log_path, 'csv_path' => csv_path })
  rescue
  end
  report_style = logging_enabled.call ? output_style.call : 'none'
  print_finished_report.call(summary, report_style, false)
end

reset_active_tracking = proc do |reason, text, value, mode|
  session_exp_total = 0
  session_bonus_total = 0
  pulse_count = 0
  reward_exp_total = 0
  reward_count = 0
  pulse_values = []
  pulse_window = []
  drop_refresh_sent = false
  pending_drop_pulse = nil
  saw_tutelage_data = true
  tutelog_state['tutelage_started_at'] = Time.now.to_i.to_s
  save_next_checkpoint.call(text, value, mode)
  save_totals.call
  write_log.call({
    'event' => 'tutelage_active_detected',
    'reason' => reason,
    'next_text' => text,
    'next_value' => value,
    'next_mode' => mode,
    'rpa' => Vars['xp2_rpa_active'] || 'unknown',
    'mind' => current_mind_state.call
  })
end

rollback_suspect_drop = proc do |reason|
  next unless pending_drop_pulse
  session_exp_total = [ session_exp_total - pending_drop_pulse['pulse'].to_i, 0 ].max
  session_bonus_total = [ session_bonus_total - pending_drop_pulse['bonus_est'].to_i, 0 ].max
  pulse_count = [ pulse_count - 1, 0 ].max
  pulse_values.pop
  save_totals.call
  write_log.call({
    'event' => 'pulse_drop_rollback',
    'reason' => reason,
    'removed_pulse' => pending_drop_pulse['pulse'],
    'removed_bonus_est' => pending_drop_pulse['bonus_est'],
    'session_exp_total' => session_exp_total,
    'session_bonus_total' => session_bonus_total
  })
  echo "| #{Time.now.strftime('%H:%M:%S')} | Tutelage ended | Removed: #{format_number.call(pending_drop_pulse['pulse'])} exp | Total: #{format_number.call(session_exp_total)} exp" if notify_pulses.call
  pending_drop_pulse = nil
end

tutelage_start_message = 'A sensation of heightened understanding crests over you, ecstatic in its intensity. Knowledge that is not your own teases at the edges of your mind, luring your thoughts down forbidden alleyways and into dark shadows where unknown secrets await.'
tutelage_end_message = 'The feeling of heightened understanding departs, leaving behind a cold hunger for forbidden knowledge that is slow to fade.'
lumnis_end_message = 'The soft feeling of serenity slowly dissipates from your mind.'
tutelage_hook_name = "#{script.name}_tutelage_state"
tutelage_start_seen = false
tutelage_end_seen = false
lumnis_end_seen = false
begin
  DownstreamHook.remove(tutelage_hook_name)
  DownstreamHook.add(tutelage_hook_name, proc do |xml|
    clean_xml = clean_value.call(xml)
    if !lumnis_end_seen && clean_xml.include?(lumnis_end_message)
      lumnis_end_seen = true
      lumnis_remaining_est = 0
      lumnis_source_remaining = 0
      tutelog_state['lumnis_remaining_est'] = '0'
      tutelog_state['lumnis_source_remaining'] = '0'
      Vars['xp2_lumnis_phase_remaining'] = '0'
      Vars['xp2_lumnis_expired'] = 'true'
      save_vars.call
      save_tutelog_state.call
      write_log.call({ 'event' => 'lumnis_end_message', 'message' => lumnis_end_message })
      echo "| #{Time.now.strftime('%H:%M:%S')} | Lumnis ended" if notify_pulses.call
    end
    if !tutelage_start_seen && clean_xml.include?(tutelage_start_message)
      tutelage_start_seen = true
      session_exp_total = 0
      session_bonus_total = 0
      pulse_count = 0
      reward_exp_total = 0
      reward_count = 0
      pulse_values = []
      pulse_window = []
      drop_refresh_sent = false
      pending_drop_pulse = nil
      saw_tutelage_data = true
      tutelog_state['tutelage_started_at'] = Time.now.to_i.to_s
      save_totals.call
      Vars['xp2_tutelage_state'] = 'active'
      Vars['xp2_tutelage_state_at'] = Time.now.to_i.to_s
      save_vars.call
      write_log.call({ 'event' => 'tutelage_start_message', 'message' => tutelage_start_message })
      echo "| #{Time.now.strftime('%H:%M:%S')} | Tutelage started" if notify_pulses.call
    end
    if !tutelage_end_seen && clean_xml.include?(tutelage_end_message)
      tutelage_end_seen = true
      Vars['xp2_tutelage_state'] = 'inactive'
      Vars['xp2_tutelage_state_at'] = Time.now.to_i.to_s
      save_vars.call
      write_log.call({ 'event' => 'tutelage_end_message', 'message' => tutelage_end_message })
      rollback_suspect_drop.call('tutelage_end_message')
      send_log_request.call('tutelage_end_message')
    end
    xml
  end)
rescue
end

before_dying do
  begin
    DownstreamHook.remove(tutelage_hook_name) if defined?(DownstreamHook)
    save_next_checkpoint.call(current_next_text.call, number_from_text.call(current_next_text.call), next_mode.call(current_next_text.call))
    save_totals.call
    write_log.call({
      'event' => 'stop',
      'pulses' => pulse_count,
      'session_exp_total' => session_exp_total,
      'session_bonus_total' => session_bonus_total,
      'reward_exp_total' => reward_exp_total,
      'reward_count' => reward_count,
      'next_text' => current_next_text.call,
      'mind' => current_mind_state.call
    })
    text_log_file.close if text_log_file && !text_log_file.closed?
    csv_log_file.close if csv_log_file && !csv_log_file.closed?
  rescue
  end
end

last_notify_state = notify_pulses.call
last_mind_state = current_mind_state.call
no_pulse_alert_reference = nil
check_notify_change = proc do
  current_notify_state = notify_pulses.call
  next if current_notify_state == last_notify_state
  last_notify_state = current_notify_state
  echo "| #{Time.now.strftime('%H:%M:%S')} | Notifications #{current_notify_state ? 'on' : 'off'}"
end

check_no_pulse_alert = proc do
  next unless no_pulse_alert_enabled.call
  current_state = Vars['tutelog'].is_a?(Hash) ? Vars['tutelog'] : tutelog_state
  reference_at = current_state['general_last_pulse_at'].to_i
  reference_at = current_state['general_started_at'].to_i if reference_at <= 0
  next if reference_at <= 0
  threshold_seconds = no_pulse_minutes.call * 60
  next if (Time.now.to_i - reference_at) < threshold_seconds
  next if no_pulse_alert_reference == reference_at
  no_pulse_alert_reference = reference_at
  echo "| #{Time.now.strftime('%H:%M:%S')} | No EXP pulse for #{no_pulse_minutes.call}m"
end

loop do
  while current_next_text.call == old_text
    check_notify_change.call
    check_no_pulse_alert.call
    pause 0.5
  end

  new_text = current_next_text.call
  new_value = number_from_text.call(new_text)
  old_mode = next_mode.call(old_text)
  new_mode = next_mode.call(new_text)
  now = Time.now
  seconds_since_last = last_pulse_at ? (now - last_pulse_at).round(1) : nil
  last_pulse_at = now

  source_changed = checkpoint_source_changed.call(old_text, old_mode, new_text, new_mode)
  raw_delta = if old_value && new_value && !source_changed
                if old_mode == 'until_next' && new_mode == 'until_next'
                  old_value - new_value
                elsif old_mode == 'total_exp' && new_mode == 'total_exp'
                  new_value - old_value
                else
                  nil
                end
              end

  pulse = raw_delta ? raw_delta.abs : nil
  valid_pulse = pulse && pulse > 0 && pulse <= 2499
  mind_before = last_mind_state.to_s
  mind_now = current_mind_state.call
  reward_pulse = valid_pulse && mind_before.downcase != 'saturated' && mind_now.to_s.downcase == 'saturated'
  bonus_est = valid_pulse && !reward_pulse ? (pulse * 0.8).round : 0
  tutelage_state_now = Vars['xp2_tutelage_state'].to_s
  decode = valid_pulse ? decode_absorb_pulse.call(pulse, reward_pulse, tutelage_state_now) : {}
  if valid_pulse
    update_general_stats.call(pulse, reward_pulse, mind_now, Vars['xp2_rpa_active'] || 'unknown', decode)
    no_pulse_alert_reference = nil
  end

  has_tutelage = tutelage_available.call
  skip_active_log = false
  if tutelage_state_now == 'active' && last_tutelage_state != 'active'
    open_current_cycle_log.call
    reset_active_tracking.call('xp2_state_became_active', old_text, old_value, old_mode)
  end
  last_tutelage_state = tutelage_state_now
  if pending_drop_pulse && tutelage_state_now != 'active'
    rollback_suspect_drop.call('xp2_confirmed_tutelage_inactive')
  end
  if saw_tutelage_data && tutelage_state_now != 'active'
    send_log_request.call('tutelage_not_active')
  end
  if valid_pulse
    saved_reset_at = Vars['xp2_tutelage_reset_at'].to_i
    if saved_reset_at > 0 && Time.now.to_i >= saved_reset_at
      refresh_lumnis_info.call('reset_time_passed_after_pulse', 120)
      tutelage_state_now = Vars['xp2_tutelage_state'].to_s
      has_tutelage = tutelage_available.call
      if tutelage_state_now == 'active' && last_tutelage_state != 'active'
        open_current_cycle_log.call
        reset_active_tracking.call('xp2_state_became_active_after_lumnis_refresh', old_text, old_value, old_mode)
      end
      last_tutelage_state = tutelage_state_now
      skip_active_log = tutelage_state_now != 'active'
    elsif has_tutelage && tutelage_state_now != 'active'
      sync_lumnis_est.call
      lumnis_before = lumnis_remaining_est
      if lumnis_before > 0
        lumnis_remaining_est = [ lumnis_remaining_est - pulse, 0 ].max
        save_lumnis_est.call
        lumnis_refresh_reason = nil
        lumnis_refresh_interval = 300
        if lumnis_remaining_est <= 0
          lumnis_refresh_reason = 'lumnis_countdown_empty_after_pulse'
          lumnis_refresh_interval = 120
        elsif lumnis_remaining_est <= [ pulse * 2, 1_000 ].max
          lumnis_refresh_reason = 'lumnis_countdown_near_empty'
          lumnis_refresh_interval = 120
        elsif lumnis_remaining_est <= 5_000
          lumnis_refresh_reason = 'lumnis_countdown_low'
          lumnis_refresh_interval = 300
        end
        if lumnis_refresh_reason
          open_current_cycle_log.call
          write_log.call({
            'event' => 'lumnis_check',
            'reason' => lumnis_refresh_reason,
            'pulse' => pulse,
            'lumnis_remaining_before' => lumnis_before,
            'lumnis_remaining_est' => lumnis_remaining_est,
            'mind' => current_mind_state.call
          })
          refresh_lumnis_info.call(lumnis_refresh_reason, lumnis_refresh_interval)
          tutelage_state_now = Vars['xp2_tutelage_state'].to_s
          has_tutelage = tutelage_available.call
          if tutelage_state_now == 'active' && last_tutelage_state != 'active'
            open_current_cycle_log.call
            reset_active_tracking.call('xp2_state_became_active_after_lumnis_countdown', old_text, old_value, old_mode)
          end
          last_tutelage_state = tutelage_state_now
        end
      end
    end
    if tutelage_state_now != 'active' && notify_pulses.call
      pulse_label = if reward_pulse
                      'Reward'
                    else
                      old_text =~ /computed total exp/i && new_text =~ /computed total exp/i ? 'Pulse' : 'Gain'
                    end
      rpa_text = Vars['xp2_rpa_active'].to_s =~ /^(on|yes|true|1)$/i ? ' | RPA' : ''
      echo "| #{Time.now.strftime('%H:%M:%S')} | #{pulse_label}: #{format_number.call(pulse)} exp | Mind: #{mind_now}#{rpa_text}"
    end
  end

  if has_tutelage && tutelage_state_now == 'active' && !skip_active_log
    open_current_cycle_log.call
    ensure_totals_cycle.call
    if valid_pulse && !reward_pulse
      recent_average = pulse_window.empty? ? nil : (pulse_window.inject(0.0) { |sum, value| sum + value } / pulse_window.length)
      if recent_average && pulse_window.length >= 3 && !drop_refresh_sent && pulse < (recent_average * 0.6)
        drop_refresh_sent = true
        pending_drop_pulse = { 'pulse' => pulse, 'bonus_est' => bonus_est }
        write_log.call({
          'event' => 'pulse_drop_check',
          'pulse' => pulse,
          'recent_average' => recent_average.round(1),
          'reason' => 'possible_tutelage_end',
          'action' => 'logged_only',
          'mind' => current_mind_state.call
        })
      end
      pulse_window << pulse
      pulse_window.shift while pulse_window.length > 5
    end
    saw_tutelage_data = true if valid_pulse
    session_exp_total += pulse if valid_pulse
    session_bonus_total += bonus_est
    if valid_pulse && reward_pulse
      reward_exp_total += pulse
      reward_count += 1
    elsif valid_pulse
      pulse_count += 1
      pulse_values << pulse
    end
    save_next_checkpoint.call(new_text, new_value, new_mode) if valid_pulse
    save_totals.call if valid_pulse

    event = valid_pulse ? (reward_pulse ? 'reward' : 'pulse') : 'pulse_anomaly'
    if valid_pulse
      write_log.call({
        'event' => event,
        'pulse' => pulse,
        'bonus_est' => bonus_est,
        'session_exp_total' => session_exp_total,
        'session_bonus_total' => session_bonus_total,
        'reward_exp_total' => reward_exp_total,
        'reward_count' => reward_count,
        'seconds_since_last' => seconds_since_last,
        'rpa' => Vars['xp2_rpa_active'] || 'unknown',
        'mind' => mind_now,
        'mind_previous' => mind_before,
        'old_next' => old_text,
        'new_next' => new_text,
        'old_value' => old_value,
        'new_value' => new_value,
        'old_mode' => old_mode,
        'new_mode' => new_mode,
        'raw_delta' => raw_delta,
        'room_id' => decode['room_id'],
        'decode_mode' => decode['decode_mode'],
        'room_tags' => decode['room_tags'],
        'room_location' => decode['room_location'],
        'logic_bonus' => decode['logic_bonus'],
        'field_exp' => decode['field_exp'],
        'field_exp_max' => decode['field_exp_max'],
        'pool_bonus' => decode['pool_bonus'],
        'expected_pulse' => decode['expected_pulse'],
        'known_multiplier' => decode['known_multiplier'],
        'observed_multiplier' => decode['observed_multiplier'],
        'extra_multiplier' => decode['extra_multiplier'],
        'extra_exp' => decode['extra_exp'],
        'decode_confidence' => decode['decode_confidence'],
        'decode_note' => decode['decode_note']
      })
    else
      write_log.call({
        'event' => event,
        'old_next' => old_text,
        'new_next' => new_text,
        'old_value' => old_value,
        'new_value' => new_value,
        'old_mode' => old_mode,
        'new_mode' => new_mode,
        'raw_delta' => raw_delta,
        'action' => source_changed ? 'checkpoint_reset_no_exp_counted' : nil
      })
    end
    if valid_pulse && notify_pulses.call
      pulse_label = if reward_pulse
                      'Reward'
                    else
                      old_text =~ /computed total exp/i && new_text =~ /computed total exp/i ? 'Pulse' : 'Gain'
                    end
      rpa_text = Vars['xp2_rpa_active'].to_s =~ /^(on|yes|true|1)$/i ? ' | RPA' : ''
      echo "| #{Time.now.strftime('%H:%M:%S')} | #{pulse_label}: #{format_number.call(pulse)} exp | Mind: #{mind_now}#{rpa_text} | Total: #{format_number.call(session_exp_total)} exp | Est Bonus: #{format_number.call(session_bonus_total)} (#{tutelage_bonus_percent.call(session_bonus_total)})"
    end
  end
  save_next_checkpoint.call(new_text, new_value, new_mode) if source_changed && new_value
  last_mind_state = mind_now
  old_text = new_text
  old_value = new_value
end












